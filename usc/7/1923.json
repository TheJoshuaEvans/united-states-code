{"tag":"section","attrib":{"id":"idef034bf3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923"},"text":null,"children":[{"tag":"num","attrib":{"value":"1923"},"text":"§ 1923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef034bf4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowed purposes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef034bf5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A farmer or rancher may use a direct loan made under this subchapter only for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef034bf6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquiring or enlarging a farm or ranch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef034bf7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making capital improvements to a farm or ranch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef034bf8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paying loan closing costs related to acquiring, enlarging, or improving a farm or ranch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef034bf9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paying for activities to promote soil and water conservation and protection described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1924"},"text":"section 1924 of this title","children":[],"tail":" on a farm or ranch; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef034bfa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" refinancing a temporary bridge loan made by a commercial or cooperative lender to a farmer or rancher for the acquisition of land for a farm or ranch, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef034bfb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary approved an application for a direct farm ownership loan to the farmer or rancher for acquisition of the land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef034bfc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds for direct farm ownership loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1994/b"},"text":"section 1994(b) of this title","children":[],"tail":" were not available at the time at which the application was approved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef034bfd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guaranteed loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A farmer or rancher may use a loan guaranteed under this subchapter only for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef034bfe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquiring or enlarging a farm or ranch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef034bff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making capital improvements to a farm or ranch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef034c00-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paying loan closing costs related to acquiring, enlarging, or improving a farm or ranch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef034c01-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paying for activities to promote soil and water conservation and protection described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1924"},"text":"section 1924 of this title","children":[],"tail":" on a farm or ranch; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef034c02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refinancing indebtedness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef034c03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferences","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making or guaranteeing a loan under this subchapter for purchase of a farm or ranch, the Secretary shall give preference to a person who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef034c04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a dependent family;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef034c05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, is able to make an initial down payment on the farm or ranch; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef034c06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an owner of livestock or farm or ranch equipment that is necessary to successfully carry out farming or ranching operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef034c07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hazard insurance requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef034c08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the Secretary makes the determination required by paragraph (2), the Secretary may not make a loan to a farmer or rancher under this subchapter unless the farmer or rancher has, or agrees to obtain, hazard insurance on any real property to be acquired or improved with the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef034c09-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1923/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":", the Secretary shall determine the appropriate level of insurance to be required under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef034c0a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s303"},"text":"Pub. L. 87–128, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"t