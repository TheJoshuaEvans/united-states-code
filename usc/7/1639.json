{"tag":"section","attrib":{"id":"ideedf70a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639"},"text":null,"children":[{"tag":"num","attrib":{"value":"1639"},"text":"§ 1639.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf70aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bioengineering","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “bioengineering”, and any similar term, as determined by the Secretary, with respect to a food, refers to a food—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e0ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that contains genetic material that has been modified through in vitro recombinant deoxyribonucleic acid (DNA) techniques; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e0ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the modification could not otherwise be obtained through conventional breeding or found in nature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “food” means a food (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of title 21","children":[],"tail":") that is intended for human consumption."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e0ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideee1e0af-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 291, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/216/s1"},"text":"Pub. L. 114–216, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-29"},"text":"July 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/834"},"text":"130 Stat. 834","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
