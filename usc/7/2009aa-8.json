{"tag":"section","attrib":{"id":"idef2bbb61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–8"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009aa–8"},"text":"§ 2009aa–8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of development plans and projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef2bbb62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–8/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or regional development plan or any multistate subregional plan that is proposed for development under this subchapter shall be reviewed and approved by the Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2bbb63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–8/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation by State member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application for a grant or any other assistance for a project under this subchapter shall be made through and evaluated for approval by the State member of the Authority representing the applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2bbb64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–8/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application for a grant or other assistance for a project shall be approved only on certification by the State member that the application for the project—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2bbb65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–8/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes ways in which the project complies with any applicable State development plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbb66-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–8/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets applicable criteria under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009aa–7"},"text":"section 2009aa–7 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbb67-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–8/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides adequate assurance that the proposed project will be properly administered, operated, and maintained; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbb68-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–8/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise meets the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2bbb69-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–8/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of grant applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On certification by a State member of the Authority of an application for a grant or other assistance for a specific project under this section, an affirmative vote of the Authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009aa–1/c"},"text":"section 2009aa–1(c) of this title","children":[],"tail":" shall be required for approval of the application."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef2bbb6a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s382I"},"text":"Pub. L. 87–128, title III, § 382I","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tV/s503"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title V, § 503]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–279; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6027/f"},"text":"Pub. L. 107–171, title VI, § 6027(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/374"},"text":"116 Stat. 374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef2bbb6b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef2bbb6c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef2bbb6d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6027/f/1"},"text":"Pub. L. 107–171, § 6027(f)(1)","children":[],"tail":", inserted “and approved” after “reviewed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6027/f/2"},"text":"Pub. L. 107–171, § 6027(f)(2)","children":[],"tail":", substituted “Approval of grant applications” for “Votes for decisions” in heading."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
