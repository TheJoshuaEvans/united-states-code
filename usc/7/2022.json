ub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef545170-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" inserted “or the payment or disposition of a State share under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2013/a/2"},"text":"section 2013(a)(2) of this title","children":[],"tail":"” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2025/c/1/D/i/II"},"text":"section 2025(c)(1)(D)(i)(II) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2025/c/1/D/i/II"},"text":"section 2025(c)(1)(D)(i)(II) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2025/c/1/D/i/III"},"text":"section 2025(c)(1)(D)(i)(III) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4115/b/9"},"text":"Pub. L. 110–246, § 4115(b)(9)","children":[],"tail":", substituted “benefits” for “coupons” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4133"},"text":"Pub. L. 110–246, § 4133","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", inserted subsec. (a) heading, redesignated par. (2) as (4) and inserted heading, designated existing provisions of par. (1) as pars. (1) to (3) and inserted headings, in par. (1) substituted “Except in the case of an at-risk amount required under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2025/c/1/D/i/III"},"text":"section 2025(c)(1)(D)(i)(III) of this title","children":[],"tail":", the Secretary” for “The Secretary” and struck out “In determining whether to settle, adjust, compromise, or waive a claim arising against a State agency pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2025/c"},"text":"section 2025(c) of this title","children":[],"tail":", the Secretary shall review a State agency’s plans for new dollar investment in activities to improve program administration in order to reduce payment error, and shall take the State agency’s plans for new dollar investment in such activities into consideration as the Secretary considers appropriate.” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2023"},"text":"section 2023 of this title","children":[],"tail":".”, and in par. (2) substituted “claim established under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2025/c/1"},"text":"section 2025(c)(1) of this title","children":[],"tail":"” for “claim established under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2025/c/1/C"},"text":"section 2025(c)(1)(C) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s844/a/1"},"text":"Pub. L. 104–193, § 844(a)(1)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which provided for reduction of allotment for households with ineligible individuals and collection by State agencies of claims against households arising from overissuance of coupons."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s844/a/2"},"text":"Pub. L. 104–193, § 844(a)(2)","children":[],"tail":", substituted “, as determined under subsection (b)(1),” for “as determined under subsection (b) and except for claims arising from an error of the State agency,” and inserted before period at end “or a Federal income tax refund as authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3720A"},"text":"section 3720A of title 31","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13951/a"},"text":"Pub. L. 103–66, § 13951(a)","children":[],"tail":", in fifth sentence, struck out “(after a determination on any request for a waiver for good cause related to the claim has been made by the Secretary)” after “30 days from the date on which the bill for collection” and in sixth sentence substituted “1 year” for “2 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s13941/b"},"text":"Pub. L. 103–66, § 13941(b)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" inserted before period at end of first sentence “, except that the household shall be given notice permitting it to elect another means of repayment and given 10 days to make such an election before the State agency commences action to reduce the household’s monthly allotment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" substituted “on the date of receipt (or, if the date of receipt is not a business day, on the next business day)” for “within thirty days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/435/s601"},"text":"Pub. L. 100–435, § 601","children":[],"tail":", inserted provisions relating to review of State agency’s plans for program investment to reduce payment error when Secretary determines whether to settle, etc., claims under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2025/c"},"text":"section 2025(c) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/435/s602"},"text":"Pub. L. 100–435, § 602","children":[],"tail":", inserted provisions relating to failure of State agency to pay a claim under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2025/c/1/C"},"text":"section 2025(c)(1)(C) of this title","children":[],"tail":" and interest with respect to unpaid portion of such claims."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1533"},"text":"Pub. L. 99–198, § 1533","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1534"},"text":"Pub. L. 99–198, § 1534","children":[],"tail":", substituted “shall” for “may” and inserted “, unless the State agency demonstrates to the satisfaction of the Secretary that such other means are not cost effective”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1535/a"},"text":"Pub. L. 99–198, § 1535(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/253"},"te