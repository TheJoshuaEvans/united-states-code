{"tag":"section","attrib":{"id":"ideeeb5740-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1726c"},"text":"§ 1726c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local and regional food aid procurement projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeeb5741-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb5742-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Agency for International Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb5743-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committee of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate committee of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeeb5744-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5745-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5746-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb5747-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible commodity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible commodity” means an agricultural commodity (or the product of an agricultural commodity) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeeb5748-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is produced in, and procured from, a developing country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5749-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a minimum, meets each nutritional, quality, and labeling standard of the country that receives the agricultural commodity, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb574a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible organization” means an organization that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeeb574b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1722/d"},"text":"section 1722(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb574c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to nongovernmental organizations, subject to regulations promulgated or guidelines issued to carry out this section, including United States audit requirements that are applicable to nongovernmental organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb574d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Field-based projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb574e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with paragraph (2), the Secretary shall provide grants to, or enter into cooperative agreements with, eligible organizations to carry out field-based projects that consist of local or regional procurements of eligible commodities to respond to food crises and disasters in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb574f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the development and implementation of field-based projects under paragraph (1), the Secretary shall consult with the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb5750-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb5751-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any eligible commodity that is procured for a field-based project carried out under subsection (b) shall be procured through any approach or methodology that the Secretary considers to be an effective approach or methodology to provide adequate information regarding the manner by which to expedite, to the maximum extent practicable, the provision of food aid to affected populations without significantly increasing commodity costs for low-income consumers who procure commodities sourced from the same markets at which the eligible commodity is procured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb5752-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeeb5753-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impact on local farmers and countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the local or regional procurement of any eligible commodity under this section will not have a disruptive impact on farmers located in, or the economy of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideeeb5754-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient country of the eligible commodity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeeb5755-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any country in the region in which the eligible commodity may be procured.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5756-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transshipment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, in accordance with such terms and conditions as the Secretary considers to be appropriate, require from each eligible organization commitments designed to prevent or restrict—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideeeb5757-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resale or transshipment of any eligible commodity procured under this section to any country other than the recipient country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeeb5758-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of the eligible commodity for any purpose other than food aid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5759-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" World prices","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideeeb575a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall take any precaution that the Secretary considers to be reasonable to ensure that the procurement of eligible commodities will not unduly disrupt—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideeeb575b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/c/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" world prices for agricultural commodities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideeeb575c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/c/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" normal patterns of commercial trade with foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeeb575d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The procurement of any eligible commodity shall be made at a reasonable market price with respect to the economy of the country in which the eligible commodity is procured, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb575e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Field-based project grants or cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb575f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants to, or enter into cooperative agreements with, eligible organizations to carry out field-based projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb5760-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements of eligible organizations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeeb5761-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant from, or enter into a cooperative agreement with, the Secretary under this subsection, an eligible organization shall submit to the Secretary an application by such date, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5762-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other applicable requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any other applicable requirement relating to the submission of proposals for consideration shall apply to the submission of an application required under subparagraph (A), as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb5763-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements of Secretary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeeb5764-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project diversity","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideeeb5765-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to clause (ii) and subparagraph (B), in selecting proposals for field-based projects to fund under this section, the Secretary shall select a diversity of projects, including projects located in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideeeb5766-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food surplus regions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideeeb5767-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food deficit regions (that are carried out using regional procurement methods); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideeedc768-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d/3/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiple geographical regions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeedc769-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting proposals for field-based projects under clause (i), the Secretary shall ensure that the majority of selected proposals are for field-based projects that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideeedc76a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are located in Africa; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideeedc76b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure eligible commodities that are produced in Africa.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeedc76c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A portion of the funds provided under this subsection shall be made available for field-based projects that provide development assistance for a period of not less than 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc76d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeedc76e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $80,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc76f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary may give a preference to eligible organizations that have, or are working toward, projects under the McGovern-Dole International Food for Education and Child Nutrition Program established under section 1736","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":"–1 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc770-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each year, the Secretary shall submit to the appropriate committees of Congress a report that describes the use of funds under this section, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeedc771-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the impact of procurements and projects on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideeedc772-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local and regional agricultural producers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeedc773-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" markets and consumers, including low-income consumers; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeedc774-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726c/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation time frames and costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeedc775-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3206"},"text":"Pub. L. 110–246, title III, § 3206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1840"},"text":"122 Stat. 1840","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIII/s3207"},"text":"Pub. L. 113–79, title III, § 3207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/780"},"text":"128 Stat. 780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII/s3311"},"text":"Pub. L. 115–334, title III, § 3311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4623"},"text":"132 Stat. 4623","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeedc776-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeedc777-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideeedc778-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food, Conservation, and Energy Act of 2008, and not as part of the Food for Peace Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideeedc779-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" inserted “to the Secretary” after “appropriated” and substituted “2019 through 2023” for “2014 through 2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3207/1/A"},"text":"Pub. L. 113–79, § 3207(1)(A)","children":[],"tail":", (B), substituted “Field-based projects” for “Study; field-based projects” in heading, struck out par. (2) designation and heading, redesignated subpars. (A) and (B) of former par. (2) as pars. (1) and (2), respectively, and struck out former par. (1) which required a study of prior local and regional procurements for food aid programs and a report to Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3207/1/C"},"text":"Pub. L. 113–79, § 3207(1)(C)","children":[],"tail":", substituted “paragraph (2)” for “subparagraph (B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3207/1/D"},"text":"Pub. L. 113–79, § 3207(1)(D)","children":[],"tail":", substituted “paragraph (1)” for “subparagraph (A)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3207/2"},"text":"Pub. L. 113–79, § 3207(2)","children":[],"tail":", substituted “subsection (b)” for “subsection (b)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3207/3"},"text":"Pub. L. 113–79, § 3207(3)","children":[],"tail":", (4), redesignated subsec. (e) as (d) and struck out former subsec. (d) which related to regulations and guidelines."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3207/5/A"},"text":"Pub. L. 113–79, § 3207(5)(A)","children":[],"tail":", struck out subpar. (A) designation and heading, redesignated cls. (i) and (ii) of former subpar. (A) as subpars. (A) and (B), respectively, substituted “subparagraph (A)” for “clause (i)” in subpar. (B), and struck out former subpar. (B). Prior to amendment, text of subpar. (B) read as follows: “To be eligible to receive a grant from, or enter into a cooperative agreement with, the Secretary under this subsection, an eligible organization shall agree—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) to collect by ","children":[{"tag":"date","attrib":{"date":"2011-09-30"},"text":"September 30, 2011","children":[],"tail":", data containing the information required under subsection (f)(1)(B) relating to the field-based project funded through the grant; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) to provide to the Secretary the data collected under clause (i).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3207/5/B"},"text":"Pub. L. 113–79, § 3207(5)(B)","children":[],"tail":", struck out par. (4). Text read as follows: “The Secretary shall not award a grant to any eligible organization under paragraph (1) until the date on which the Secretary promulgates regulations or issues guidelines under subsection (d)(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3207/6"},"text":"Pub. L. 113–79, § 3207(6)","children":[],"tail":", added subsec. (e). Former subsec. (e) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3207/3"},"text":"Pub. L. 113–79, § 3207(3)","children":[],"tail":", struck out subsecs. (f) and (g) which related, respectively, to independent evaluations of field-based projects and report to Congress and to Commodity Credit Corporation funding and funding amounts for fiscal years 2009 through 2012."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeedc77a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideeedc77b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"ideeedc77c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” as meaning the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
