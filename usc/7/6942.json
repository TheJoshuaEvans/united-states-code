{"tag":"section","attrib":{"id":"ideff41496-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6942"},"text":null,"children":[{"tag":"num","attrib":{"value":"6942"},"text":"§ 6942.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural Utilities Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff41497-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6942/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and maintain within the Department the Rural Utilities Service and assign to the Service such functions as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff41498-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6942/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff41499-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6942/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Rural Utilities Service shall be headed by an Administrator who shall be appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff4149a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6942/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Rural Utilities Service shall receive basic pay at a rate not to exceed the maximum amount of compensation payable to a member of the Senior Executive Service under subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff4149b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6942/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out through the Rural Utilities Service the following functions that are under the jurisdiction of the Department:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff4149c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6942/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Electric and telephone loan programs and water and waste facility activities authorized by law, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff4149d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6942/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Rural Electrification Act of 1936 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s901"},"text":"7 U.S.C. 901","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff4149e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6942/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value"