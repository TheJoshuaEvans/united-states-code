{"tag":"section","attrib":{"id":"idee23246f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242"},"text":null,"children":[{"tag":"num","attrib":{"value":"242"},"text":"§ 242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers of Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee232470-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall have exclusive power, jurisdiction, and authority, to the extent that this chapter applies, with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee232471-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each warehouse operator licensed under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee232472-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each person that has obtained an approval to engage in an activity under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee232473-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each person claiming an interest in an agricultural product by means of a document or receipt subject to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee232474-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered agricultural products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall specify, after an opportunity for notice and comment, those agricultural products for which a warehouse license may be issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee232475-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may investigate the storing, warehousing, classifying according to grade and otherwise, weighing, and certifying of agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee232476-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may inspect or cause to be inspected any person or warehouse licensed under this chapter and any warehouse for which a license is applied for under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee232477-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suitability for storage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may determine whether a licensed warehouse, or a warehouse for which a license is applied for under this chapter, is suitable for the proper storage of the agricultural product or products stored or proposed for storage in the warehouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee232478-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may classify a licensed warehouse, or a warehouse for which a license is applied for under this chapter, in accordance with the ownership, location, surroundings, capacity, conditions, and other qualities of the warehouse and as to the kinds of licenses issued or that may be issued for the warehouse under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee232479-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warehouse operator’s duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the other provisions of this chapter, the Secretary may prescribe the duties of a warehouse operator operating a warehouse licensed under this chapter with respect to the warehouse operator’s care of and responsibility for agricultural products stored or handled by the warehouse operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee23247a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Systems for electronic conveyance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee23247b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations governing electronic systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Secretary may promulgate regulations governing one or more electronic systems under which electronic receipts may be issued and transferred and other electronic documents relating to the shipment, payment, and financing of the sale of agricultural products may be issued or transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee23247c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not have the authority under this chapter to establish—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee23247d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more central filing systems for the filing of financing statements or the filing of the notice of financing statements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee23247e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules to determine security interests of persons affected by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee23247f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination and audits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the authority provided under subsection (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), on request of the person, State agency, or commodity exchange, the Secretary may conduct an examination, audit, or similar activity with respect to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idee232480-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person that is engaged in the business of storing an agricultural product that is subject to this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee232481-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any State agency that regulates the storage of an agricultural product by such a person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee232482-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any commodity exchange with regulatory authority over the storage of agricultural products that are subject to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee232483-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licenses for operation of warehouses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may issue to any warehouse operator a license for the operation of a warehouse in accordance with this chapter if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee232484-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the warehouse is suitable for the proper storage of the agricultural product or products stored or proposed for storage in the warehouse; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee232485-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the warehouse operator agrees, as a condition of the license, to comply with this chapter (including regulations promulgated under this chapter).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee232486-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing of other persons","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee232487-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On presentation of satisfactory proof of competency to carry out the activities described in this paragraph, the Secretary may issue to any person a Federal license—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee232488-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/k/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to inspect any agricultural product stored or handled in a warehouse subject to this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee232489-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/k/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sample such an agricultural product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee23248a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/k/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to classify such an agricultural product according to condition, grade, or other class and certify the condition, grade, or other class of the agricultural product; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee23248b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/k/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to weigh such an agricultural product and certify the weight of the agricultural product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee23248c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of a license issued under paragraph (1), the licensee shall agree to comply with this chapter (including regulations promulgated under this chapter).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee23248d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examination of books, records, papers, and accounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may examine and audit, using designated officers, employees, or agents of the Department, all books, records, papers, and accounts relating to activities subject to this chapter of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee23248e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a warehouse operator operating a warehouse licensed under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee23248f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person operating a system for the electronic recording and transfer of receipts and other documents authorized by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee232490-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person issuing receipts or electronic documents authorized by the Secretary under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee232491-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee232492-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate with officers and employees of a State who administer or enforce State laws relating to warehouses, warehouse operators, weighers, graders, inspectors, samplers, or classifiers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee232493-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s242/m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into cooperative agreements with States to perform activities authorized under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee232494-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 3, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tII/s201"},"text":"Pub. L. 106–472, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2062"},"text":"114 Stat. 2062","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee232495-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee232496-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee232497-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 242, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 2, "},{"tag":"ref","attrib":{"href":"/us/stat/39/486"},"text":"39 Stat. 486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1923-02-23/ch106"},"text":"Feb. 23, 1923, ch. 106","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1282"},"text":"42 Stat. 1282","children":[],"tail":", defined terms, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s241"},"text":"section 241 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 3 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s243"},"text":"section 243 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
