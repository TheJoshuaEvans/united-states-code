{"tag":"section","attrib":{"id":"idee65d2ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"950bb–2"},"text":"§ 950bb–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative Broadband Advancement Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee65d2cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to be known as the “Innovative Broadband Advancement Program”, under which the Secretary may provide a grant, a loan, or both to an eligible entity for the purpose of demonstrating innovative broadband technologies or methods of broadband deployment that significantly decrease the cost of broadband deployment, and provide substantially faster broadband speeds than are available, in a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d2d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “rural area” has the meaning provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s950bb/b/3"},"text":"section 950bb(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d2d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to obtain assistance under this section for a project, an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d2d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Secretary an application—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d2d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–2/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that describes a project designed to decrease the cost of broadband deployment, and substantially increase broadband speed to not less than the maximum ","children":[{"tag":"ref","attrib":{"idref":"fn002128"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002128"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “minimum”."}],"tail":" broadband buildout requirements established under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s950bb/e/4"},"text":"section 950bb(e)(4) of this title","children":[],"tail":", in a rural area to be served by the project; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d2d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–2/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at such time, in such manner, and containing such other information as the Secretary may require;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d2d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate that the entity is able to carry out the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d2d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to complete the project build-out within 5 years after the date the assistance is first provided for the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d2d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding assistance under this section, the Secretary shall give priority to proposals for projects that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d2d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve partnerships between or among multiple entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d2d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would provide broadband service to the greatest number of rural entities at or above the broadband requirements referred to in subsection (c)(1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d2da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–2/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines could be replicated in rural areas described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d2db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee65d2dc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title VI, § 603, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVI/s6105"},"text":"Pub. L. 113–79, title VI, § 6105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/856"},"text":"128 Stat. 856","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6203"},"text":"Pub. L. 115–334, title VI, § 6203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4736"},"text":"132 Stat. 4736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee65d2dd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee65d2de-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee65d2df-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6203/1"},"text":"Pub. L. 115–334, § 6203(1)","children":[],"tail":", substituted “Innovative Broadband Advancement” for “Rural Gigabit Network Pilot” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6203/4"},"text":"Pub. L. 115–334, § 6203(4)","children":[],"tail":", added subsecs. (a) to (d) and struck out former subsecs. (a) to (c) which defined “ultra-high speed service”, established the Rural Gigabit Network Pilot Program, and set out eligibility requirements for participation in Program, respectively. Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6203/2"},"text":"Pub. L. 115–334, § 6203(2)","children":[],"tail":", (3), redesignated subsec. (d) as (e) and substituted “2019 through 2023” for “2014 through 2018”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
