{"tag":"section","attrib":{"id":"idef841481-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2424"},"text":null,"children":[{"tag":"num","attrib":{"value":"2424"},"text":"§ 2424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Death or incapacity of breeder","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Legal representatives of deceased breeders and of those under legal incapacity may make application for plant variety protection upon compliance with the requirements and on the same terms and conditions applicable to the breeder or the successor in interest of the breeder.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef841482-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tII/s54"},"text":"Pub. L. 91–577, title II, § 54","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1548"},"text":"84 Stat. 1548","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s13/h"},"text":"Pub. L. 103–349, § 13(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3143"},"text":"108 Stat. 3143","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef841483-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef841484-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef841485-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/349"},"text":"Pub. L. 103–349","children":[],"tail":" substituted “the successor in interest of the breeder” for “his successor in interest”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef841486-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef841487-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/349"},"text":"Pub. L. 103–349","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s15"},"text":"section 15 of Pub. L. 103–349","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2401"},"text":"section 2401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
