,{"tag":"ref","attrib":{"href":"/us/stat/139/106"},"text":"139 Stat. 106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideec5318d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideec5318e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideec5318f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(2)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “for each of fiscal years 2014 through 2025 and $10,000,000 for fiscal year 2026 and each fiscal year thereafter” for “for each fiscal year” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsecs. (a)(2)(C), (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" substituted “subsection (a)(3)(E)(ii) of that section” for “subsections (a)(3)(E)(ii) and (b)(10) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1523"},"text":"section 1523 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “$7,000,000” for “$9,000,000” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/s147/a"},"text":"Pub. L. 106–224, § 147(a)","children":[],"tail":", in introductory provisions, substituted “years the following:” for “years—”, in subpar. (A), substituted “The” for “the” and a period for “; and” at end, in subpar. (B), substituted “Premium” for “premium”, and added subpars. (C) and (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/s147/b"},"text":"Pub. L. 106–224, § 147(b)","children":[],"tail":", in introductory provisions, substituted “including the following:” for “including—”, in subpar. (A), substituted “Premium” for “premium” and a period for the semicolon at end, in subpar. (B), substituted “Administrative” for “administrative” and a period for “; and” at end, in subpar. (C), substituted “All” for “all”, and added subpars. (D) and (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/s147/c/1"},"text":"Pub. L. 106–224, § 147(c)(1)","children":[],"tail":", substituted “Policy consideration and implementation” for “Research and development expenses” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/s147/c/2"},"text":"Pub. L. 106–224, § 147(c)(2)","children":[],"tail":", substituted “may use” for “may pay from”, struck out “research and development expenses of the Corporation” before “, but not to exceed”, substituted “, to pay the following:” for period at end, and added cls. (i) and (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/s147/c/3"},"text":"Pub. L. 106–224, § 147(c)(3)","children":[],"tail":", struck out “research and development” after “the limitation on”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/s147/d"},"text":"Pub. L. 106–224, § 147(d)","children":[],"tail":", substituted “income,” for “income and” and inserted “, and civil fines collected under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1515/h"},"text":"section 1515(h) of this title","children":[],"tail":"” before “, to be available”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s531/1/A"},"text":"Pub. L. 105–185, § 531(1)(A)","children":[],"tail":", added par. (1) and struck out heading and text of former par. (1). Text read as follows: “There are authorized to be appropriated for each of fiscal years 1995 through 2001 such sums as are necessary to cover—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the salaries and expenses of the Corporation; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the administrative and operating expenses of the Corporation for the sales commissions of agents.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s531/1/B/i"},"text":"Pub. L. 105–185, § 531(1)(B)(i)","children":[],"tail":", inserted “for each of the 1999 and subsequent reinsurance years” after “are necessary to cover” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s531/1/B/ii"},"text":"Pub. L. 105–185, § 531(1)(B)(ii)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A) which read as follows: “in the case of each of the 1995 through 1997 reinsurance years, the administrative and operating expenses of the Corporation for the sales commissions of agents, consistent with subsection (b)(1) of this section; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s531/2"},"text":"Pub. L. 105–185, § 531(2)","children":[],"tail":", added subsec. (b) and struck out heading and text of former subsec. (b). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Administrative and operating expenses","children":[],"tail":".—In the case of each of the 1995 through 1997 reinsurance years, the Corporation is authorized to pay from the insurance fund established under subsection (c) of this section, the administrative and operating expenses of an approved insurance provider, including expenses covered by subsection (a)(1)(B) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Other expenses","children":[],"tail":".—The Corporation is authorized to pay from the insurance fund established under subsection (c) of this section—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) all other expenses of the Corporation (other than expenses covered by subsection (a)(1) of this section), including all premium subsidies and indemnities;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) in the case of each of the 1995 through 1997 reinsurance years, all administrative and expense reimbursements due under a reinsurance agreement with an approved insurance provider; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) to the extent necessary, expenses incurred by the Corporation to carry out research and development.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s193/e/1"},"text":"Pub. L. 104–127, § 193(e)(1)","children":[],"tail":", struck out subpar. (C) which read as follows: “payments for noninsured assistance losses under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1519"},"text":"section 1519 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s193/e/2/A"},"text":"Pub. L. 104–127, § 193(e)(2)(A)","children":[],"tail":", struck out subpar. (A) designation and heading “In general”, substituted “In the case of each” for “Except as provided in subparagraph (B), in the case of each”, and struck out heading and text of subpar. (B). Prior to amendment, text read as follows: “In the case of the 1997 reinsurance year, the amount of the payments from the insurance fund established under subsection (c) of this section for the expenses of the Corporation for the sales commissions of agents may not exceed 8.5 percent of the total amount of premiums paid for additional coverage for the 1997 reinsurance year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s193/e/3"},"text":"Pub. L. 104–127, § 193(e)(3)","children":[],"tail":", struck out “, noninsured assistance benefits,” after “all premium subsidies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s193/e/2/B"},"text":"Pub. L. 104–127, § 193(e)(2)(B)","children":[],"tail":", struck out “subject to paragraph (1)(B),” before “in the case of each”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" amended section generally, substituting subsecs. (a) to (c) for former subsecs. (a) to (d) relating to authorization of appropriations to cover operating and administrative costs of Corporation, issuance of regulations, emergency funding, and borrowing authority."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" struck out provision that Secretary’s authority to use the funds of Commodity Credit Corporation for purposes of this subsection would expire one year after date on which that authority was first used."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/11"},"text":"Pub. L. 97–11","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/365/s109"},"text":"Pub. L. 96–365, § 109","children":[],"tail":", substituted appropriations authorization of necessary sums for former limitation of $12,000,000 for each fiscal year beginning after "},{"tag":"date","attrib":{"date":"1938-06-30"},"text":"June 30, 1938","children":[],"tail":"; included as costs agents’ and brokers’ commissions, interest on Treasury notes and other obligations, partial premium payments by the Corporation, and the direct cost of loss adjusters for crop inspections and loss adjustments and authorized payment of these costs from premium income and other Corporation funds and restoration of such payments through subsequent year appropriations; prescribed limitation on employment of additional personnel except during emergencies; and deleted provisions for for consideration as being nonadministrative or nonoperating expenses such expenses as related to purchase, transportation, handling, or sale of the agricultural commodity and the direct cost of loss adjusters for crop inspections and loss adjustments and provision for use of premium income for administrative and operating costs within limits prescribed in applicable appropriations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/365/s110"},"text":"Pub. L. 96–365, § 110","children":[],"tail":", added subsecs. (c) and (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1956—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1956-08-03"},"text":"Aug. 3, 1956","children":[],"tail":", added to list of costs which may be considered as nonadministrative or nonoperating, the direct cost of loss adjusters for crop inspections and loss adjustment, and authorized use of premium income for administrative and operating costs within limits prescribed by applicable appropriation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1941—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1941-06-21"},"text":"June 21, 1941","children":[],"tail":", substituted “the agricultural commodity” for “wheat”, and “$12,000,000” for “$6,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideec7a190-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideec7a191-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185"},"text":"Pub. L. 105–185","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1998-07-01"},"text":"July 1, 1998","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/s537"},"text":"section 537 of Pub. L. 105–185","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1506"},"text":"section 1506 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideec7a192-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", and applicable to provision of crop insurance under Federal Crop Insurance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.) beginning with 1995 crop year, with such Act, as in effect on the day before "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", to continue to apply with respect to 1994 crop year, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/s120"},"text":"section 120 of Pub. L. 103–354","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1502"},"text":"section 1502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideec7a193-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/365/tI/s109"},"text":"Pub. L. 96–365, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1317"},"text":"94 Stat. 1317","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/365/tI/s110"},"text":"Pub. L. 96–365, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1318"},"text":"94 Stat. 1318","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideec7a194-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Appropriation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1944-12-23/ch713/s6"},"text":"Act Dec. 23, 1944, ch. 713, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/920"},"text":"58 Stat. 920","children":[],"tail":", provided an additional appropriation not to exceed $3,000,000 to be available for the fiscal year 1945 to carry out the provisions of this chapter for the fiscal years 1943 and 1944."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ideec7a195-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ideec7a196-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Administration of program of Federal Crop Insurance Corporation transferred to Secretary of Agriculture by 1946 Reorg. Plan No. 3, § 501, eff. ","children":[{"tag":"date","attrib":{"date":"1946-07-16"},"text":"July 16, 1946","children":[],"tail":", 11 F.R. 7877, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1100"},"text":"60 Stat. 1100","children":[],"tail":". See note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1503"},"text":"section 1503 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Wartime consolidation of Federal Crop Insurance Corporation into Agricultural Conservation and Adjustment Administration, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1503"},"text":"section 1503 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
