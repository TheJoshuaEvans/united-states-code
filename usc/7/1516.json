{"tag":"section","attrib":{"id":"ideec5316b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516"},"text":null,"children":[{"tag":"num","attrib":{"value":"1516"},"text":"§ 1516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideec5316c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideec5316d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for fiscal year 1999 and each subsequent fiscal year such sums as are necessary to cover the salaries and expenses of the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec5316e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory expenses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to cover for each of the 1999 and subsequent reinsurance years the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideec5316f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The administrative and operating expenses of the Corporation for the sales commissions of agents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec53170-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Premium subsidies, including the administrative and operating expenses of an approved insurance provider for the delivery of policies with additional coverage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec53171-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs associated with the conduct of livestock and wild salmon pilot programs carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1523"},"text":"section 1523 of this title","children":[],"tail":", subject to the limitations in subsection (a)(3)(E)(ii) of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec53172-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs associated with the reimbursement, contracting, and partnerships for research and development under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideec53173-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of Corporation expenses from insurance fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideec53174-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses generally","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of the 1999 and subsequent reinsurance years, the Corporation may pay from the insurance fund established under subsection (c) all expenses of the Corporation (other than expenses covered by subsection (a)(1) and expenses covered by paragraph (2)(A)), including the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideec53175-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Premium subsidies and indemnities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec53176-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administrative and operating expenses of the Corporation necessary to pay the sales commissions of agents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec53177-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All administrative and operating expense reimbursements due under a reinsurance agreement with an approved insurance provider.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec53178-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs associated with the conduct of livestock and wild salmon pilot programs carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1523"},"text":"section 1523 of this title","children":[],"tail":", subject to the limitations in subsection (a)(3)(E)(ii) of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec53179-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs associated with the reimbursement, contracting, and partnerships for research and development under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec5317a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy consideration and implementation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideec5317b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of the 1999 and subsequent reinsurance years, the Corporation may use the insurance fund established under subsection (c), but not to exceed $3,500,000 for each fiscal year, to pay the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideec5317c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs associated with the consideration and implementation of policies, plans of insurance, and related materials submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1508/h"},"text":"section 1508(h) of this title","children":[],"tail":" or developed under section 1522 or 1523 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideec5317d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Costs to contract for the review of policies, plans of insurance, and related materials under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1505/e"},"text":"section 1505(e) of this title","children":[],"tail":" and to contract for other assistance in considering policies, plans of insurance, and related materials."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec5317e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dairy options pilot program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts necessary to carry out the dairy options pilot program shall not be counted toward the limitation on expenses specified in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec5317f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviews, compliance, and integrity","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideec53180-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of the 2014 and subsequent reinsurance years, the Corporation may use the insurance fund established under subsection (c), but not to exceed $7,000,000 for each of fiscal years 2014 through 2025 and $10,000,000 for fiscal year 2026 and each fiscal year thereafter, to pay costs—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideec53181-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/2/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reimburse expenses incurred for the operations and review of policies, plans of insurance, and related materials (including actuarial and related information); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideec53182-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/2/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the Corporation in maintaining program actuarial soundness and financial integrity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideec53183-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretarial action","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes described in clause (i), the Secretary may, without further appropriation—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideec53184-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" merge some or all of the funds made available under this subparagraph into the accounts of the Risk Management Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideec53185-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obligate those funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideec53186-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this subparagraph shall be in addition to other funds made available for costs incurred by the Corporation or the Risk Management Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideec53187-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insurance fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideec53188-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established an insurance fund, for the deposit of premium income, amounts made available under subsection (a)(2), and civil fines collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1515/h"},"text":"section 1515(h) of this title","children":[],"tail":", to be available without fiscal year limitation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec53189-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity Credit Corporation funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If at any time the amounts in the insurance fund are insufficient to enable the Corporation to carry out subsection (b), to the extent the funds of the Commodity Credit Corporation are available—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideec5318a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Corporation may request the Secretary to use the funds of the Commodity Credit Corporation to carry out subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec5318b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1516/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may use the funds of the Commodity Credit Corporation to carry out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideec5318c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","chil