{"tag":"section","attrib":{"id":"ideefc1fc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1768"},"text":null,"children":[{"tag":"num","attrib":{"value":"1768"},"text":"§ 1768.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Operations Administration unaffected","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to affect personnel employed by or funds available to the Foreign Operations Administration or programs conducted under its authorities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideefc1fc8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041"},"text":"Aug. 28, 1954, ch. 1041","children":[],"tail":", title VI, § 608, "},{"tag":"ref","attrib":{"href":"/us/stat/68/910"},"text":"68 Stat. 910","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideefc1fc9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ideefc1fca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"ideefc1fcb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Operations Administration was abolished by Ex. Ord. No. 10610 of ","children":[{"tag":"date","attrib":{"date":"1955-05-09"},"text":"May 9, 1955","children":[],"tail":", and its functions and offices were transferred to the Department of State and to the Department of Defense, effective "},{"tag":"date","attrib":{"date":"1955-06-30"},"text":"June 30, 1955","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
