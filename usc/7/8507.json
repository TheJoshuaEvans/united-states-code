{"tag":"section","attrib":{"id":"idf03ba4ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8507"},"text":null,"children":[{"tag":"num","attrib":{"value":"8507"},"text":"§ 8507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous matters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf03ba4f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated under this chapter shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03ba4f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the amounts appropriated to carry out this chapter for a fiscal year, the Secretaries may expend not more than five percent to cover the administrative expenses necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf03ba4f2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/384/s8"},"text":"Pub. L. 108–384, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2226"},"text":"118 Stat. 2226","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
