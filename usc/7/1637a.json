{"tag":"section","attrib":{"id":"ideedf6ff6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1637a"},"text":"§ 1637a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6ff7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dairy products","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “dairy products” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf6ff8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufactured dairy products that are used by the Secretary to establish minimum prices for Class III and Class IV milk under a Federal milk marketing order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s608c"},"text":"section 608c of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf6ff9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially identical products designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6ffa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “manufacturer” means any person engaged in the business of buying milk in commerce for the purpose of manufacturing dairy products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6ffb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedf6ffc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 272, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/532/s2"},"text":"Pub. L. 106–532, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2541"},"text":"114 Stat. 2541","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1504"},"text":"Pub. L. 107–171, title I, § 1504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/207"},"text":"116 Stat. 207","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideedf6ffd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideedf6ffe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},