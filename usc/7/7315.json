{"tag":"section","attrib":{"id":"idf004b604-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7315"},"text":null,"children":[{"tag":"num","attrib":{"value":"7315"},"text":"§ 7315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf004b605-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may, for the purpose of carrying out this subchapter, conduct such hearings, sit and act at such times, take such testimony, and receive such evidence, as the Commission considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b606-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance from other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may secure directly from any department or agency of the Federal Government such information as may be necessary for the Commission to carry out its duties under this subchapter. On the request of the chairperson of the Commission, the head of the department or agency shall, to the extent permitted by law, furnish such information to the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b607-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7315/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mail","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may use the United States mails in the same manner and under the same conditions as the departments and agencies of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b608-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7315/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance from Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide to the Commission appropriate office space and such reasonable administrative and support services as the Commission may request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf004b609-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s185"},"text":"Pub. L. 104–127, title I, § 185","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/940"},"text":"110 Stat. 940","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
