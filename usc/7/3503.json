{"tag":"section","attrib":{"id":"idefaef518-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3503"},"text":null,"children":[{"tag":"num","attrib":{"value":"3503"},"text":"§ 3503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigative actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may take such actions as the Secretary considers necessary to monitor compliance with the provisions of this chapter and to determine whether the information contained in any report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3501"},"text":"section 3501 of this title","children":[],"tail":" accurately and fully reveals the ownership interest of all foreign persons in any foreign person who is required to submit a report under such section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefaef519-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/460/s4"},"text":"Pub. L. 95–460, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-14"},"text":"Oct. 14, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1265"},"text":"92 Stat. 1265","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
