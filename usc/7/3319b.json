{"tag":"section","attrib":{"id":"idefa7c97a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3319b"},"text":"§ 3319b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint requests for proposals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa7c97b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out any competitive agricultural research, education, or extension grant program authorized under this or any other Act, the Secretary may cooperate with 1 or more other Federal agencies (including the National Science Foundation) in issuing joint requests for proposals, awarding grants, and administering grants, for similar or related research, education, or extension projects or activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c97c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa7c97d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may delegate authority to issue requests for proposals, make grant awards, or administer grants, in whole or in part, to a cooperating Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa7c97e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperating Federal agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cooperating Federal agency may delegate to the Secretary authority to issue requests for proposals, make grant awards, or administer grants, in whole or in part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c97f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and a cooperating Federal agency may agree to make applicable to recipients of grants—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa7c980-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the post-award grant administration regulations applicable to recipients of grants from the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa7c981-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the post-award grant administration regulations applicable to recipients of grants from the cooperating Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c982-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint peer review panels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3129a"},"text":"section 3129a of this title","children":[],"tail":", the Secretary and a cooperating Federal agency may establish joint peer review panels for the purpose of evaluating grant proposals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa7c983-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1473B"},"text":"Pub. L. 95–113, title XIV, § 1473B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7403/b"},"text":"Pub. L. 107–171, title VII, § 7403(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/456"},"text":"116 Stat. 456","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa7c984-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa7c985-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idefa7c986-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3319b, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1473B"},"text":"Pub. L. 95–113, title XIV, § 1473B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXIV/s1427"},"text":"Pub. L. 99–198, title XIV, § 1427","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1553"},"text":"99 Stat. 1553","children":[],"tail":", provided for technology development for small- and medium-sized farming operations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1601/f/1/E"},"text":"Pub. L. 101–624, title XVI, § 1601(f)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3704"},"text":"104 Stat. 3704","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefa7c987-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefa7c988-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purposes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7403/a"},"text":"Pub. L. 107–171, title VII, § 7403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/456"},"text":"116 Stat. 456","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/171/tVII/s7403/a"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“The purposes of this section [enacting this section] are—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the duplication of administrative functions relating to grant awards and administration among Federal agencies conducting similar types of research, education, and extension programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maximize the use of peer review resources in research, education, and extension programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the burden on potential recipients that may offer similar proposals to receive competitive grants under different Federal programs in overlapping subject areas.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idefa7c989-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7401"},"text":"Pub. L. 107–171, title VII, § 7401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/455"},"text":"116 Stat. 455","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/171/tVII/s7401"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this subtitle [subtitle D (§ 7401–7412) of title VII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", enacting this section and sections [former] 3310a, [former] 3319f, 5925c, 5925d, and 7630 of this title and provisions set out as notes under this section and sections 3101, [former] 3319f, [former] 5925a, and 5925b of this title]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Department’ means the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of Agriculture.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
