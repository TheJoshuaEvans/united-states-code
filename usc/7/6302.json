{"tag":"section","attrib":{"id":"idefde917c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302"},"text":null,"children":[{"tag":"num","attrib":{"value":"6302"},"text":"§ 6302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefde917d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the United Soybean Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6304/b"},"text":"section 6304(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde917e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commerce” includes interstate, foreign, and intrastate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde917f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Committee” means the Soybean Program Coordinating Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6304/g"},"text":"section 6304(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9180-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumer information” means information that will assist consumers and other persons in making evaluations and decisions regarding the purchase, preparation, and use of soybeans or soybean products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9181-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9182-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First purchaser","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “first purchaser” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde9183-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (B), any person buying or otherwise acquiring from a producer soybeans produced by such producer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde9184-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commodity Credit Corporation, in any case in which soybeans are pledged as collateral for a loan issued under any price support loan program administered by the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9185-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “industry information” means information and programs that will lead to the development of new markets, new marketing strategies, or increased efficiency for the soybean industry, and activities to enhance the image of the soybean industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9186-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marketing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “marketing” means the sale or other disposition of soybeans or soybean products in any channel of commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9187-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Net market price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “net market price” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde9188-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (B), the sales price or other value received by a producer for soybeans after adjustments for any premium or discount based on grading or quality factors, as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde9189-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for soybeans pledged as collateral for a loan issued under any price support loan program administered by the Commodity Credit Corporation, the principal amount of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde918a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “order” means an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6303"},"text":"section 6303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde918b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any individual, group of individuals, partnership, corporation, association, cooperative, or any other legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde918c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” means any person engaged in the growing of soybeans in the United States who owns, or who shares the ownership and risk of loss of, such soybeans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde918d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “promotion” means any action, including paid advertising, technical assistance, and trade servicing activities, to enhance the image or desirability of soybeans or soybean products in domestic and foreign markets, and any activity designed to communicate to consumers, importers, processors, wholesalers, retailers, government officials, or others information relating to the positive attributes of soybeans or soybean products or the benefits of importation, use, or distribution of soybeans and soybean products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde918e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified State soybean board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified State soybean board” means a State soybean promotion entity that is authorized by State law. If no such entity exists in a State, the term “qualified State soybean board” means a soybean producer-governed entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde918f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is organized and operating within a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde9190-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that receives voluntary contributions and conducts soybean promotion, research, consumer information, or industry information programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde9191-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that meets criteria established by the Board as approved by the Secretary relating to the qualifications of such entity to perform duties under the order and is recognized by the Board as the soybean promotion and research entity within the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9192-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “research” means any type of study to advance the image, desirability, marketability, production, product development, quality, or functional or nutritional value of soybeans or soybean products, including any research activity designed to identify and analyze barriers to export sales of soybeans and soybean products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9193-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9194-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Soybean products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “soybean products” means products produced in whole or in part from soybeans or soybean by-products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9195-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Soybeans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “soybeans” means all varieties of Glycine max or Glycine soya.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9196-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6302/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “State” and “United States” consist of the 50 States of the United States of America, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefde9197-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1967"},"text":"Pub. L. 101–624, title XIX, § 1967","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3882"},"text":"104 Stat. 3882","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
