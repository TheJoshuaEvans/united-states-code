{"tag":"section","attrib":{"id":"idefd0602b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5854"},"text":null,"children":[{"tag":"num","attrib":{"value":"5854"},"text":"§ 5854.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State agricultural weather information systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd0602c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5854/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory program grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd0602d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5854/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With funds allocated to carry out this section, the Secretary of Agriculture shall make grants to not fewer than 10 eligible States to plan and administer, in cooperation with persons described in paragraph (2), advisory programs for State agricultural weather information systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd0602e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5854/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The persons referred to in paragraph (1) are the Director of the Agricultural Weather Office, the Director of the National Institute of Food and Agriculture, and other persons as appropriate (such as the directors of the appropriate State agricultural experiment stations and State extension programs).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd0602f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5854/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of selecting among applications submitted by States for grants under this section, the Secretary shall consult with the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd06030-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5854/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, the chief executive officer of a State shall submit to the Secretary an application that contains—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd06031-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5854/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assurances that the State will expend such grant to plan and administer a State agricultural weather system that will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd06032-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5854/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect observational weather data throughout the State and provide such data to the National Weather Service and the Agricultural Weather Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd06033-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5854/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop methods for packaging information received from the national system for use by agricultural producers (with State Cooperative Extension Services and the private sector to serve as the primary conduit of agricultural weather forecasts and climatic information to producers); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd06034-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5854/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop programs to educate agricultural producers on how to best use weather and climate information to improve management decisions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd06035-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5854/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other assurances and information as the Secretary may require by rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd06036-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1640"},"text":"Pub. L. 101–624, title XVI, § 1640","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3749"},"text":"104 Stat. 3749","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7304/b"},"text":"Pub. L. 107–171, title VII, § 7304(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/455"},"text":"116 Stat. 455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7511/c/19"},"text":"Pub. L. 110–234, title VII, § 7511(c)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1269"},"text":"122 Stat. 1269","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7511(c)(19), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2030.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefd06037-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefd06038-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefd06039-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefd0603a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/19"},"text":"Pub. L. 110–246, § 7511(c)(19)","children":[],"tail":", substituted “the Director of the National Institute of Food and Agriculture” for “the Administrator of the Extension Service, the Administrator of the Cooperative State Research Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" struck out “take into consideration the recommendation of the Advisory Board on Agricultural Weather and” before “consult with the Director”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefd0603b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefd0603c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/11