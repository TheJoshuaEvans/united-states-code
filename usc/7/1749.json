{"tag":"section","attrib":{"id":"ideefc1f32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1749"},"text":null,"children":[{"tag":"num","attrib":{"value":"1749"},"text":"§ 1749.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attaché educational program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator of the Foreign Agricultural Service shall establish a program within the Service that directs attachés of the Service who are reassigned from abroad to the United States, and other personnel of the Service, to visit and consult with producers and exporters of agricultural commodities and products and State officials throughout the United States concerning various methods to increase exports of United States agricultural commodities and products.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideefc1f33-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041"},"text":"Aug. 28, 1954, ch. 1041","children":[],"tail":", title I, § 109, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1532"},"text":"Pub. L. 101–624, title XV, § 1532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3690"},"text":"104 Stat. 3690","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s316"},"text":"Pub. L. 102–237, title III, § 316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1856"},"text":"105 Stat. 1856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideefc1f34-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideefc1f35-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideefc1f36-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s316"},"text":"Pub. L. 102–237, § 316","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1532"},"text":"Pub. L. 101–624, § 1532","children":[],"tail":", which enacted this section, resulting in no change in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
