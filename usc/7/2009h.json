{"tag":"section","attrib":{"id":"idef29715a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009h"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009h"},"text":"§ 2009h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local involvement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An application for assistance under this subchapter shall include evidence of significant community support for the project for which the assistance is requested. In the case of assistance for a community facilities or infrastructure project, the evidence shall be in the form of a certification of support for the project from each affected general purpose local government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef29715b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s381I"},"text":"Pub. L. 87–128, title III, § 381I","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s761"},"text":"Pub. L. 104–127, title VII, § 761","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1146"},"text":"110 Stat. 1146","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
