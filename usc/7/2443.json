{"tag":"section","attrib":{"id":"idef8414af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2443"},"text":null,"children":[{"tag":"num","attrib":{"value":"2443"},"text":"§ 2443.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When an application for plant variety protection has been refused by the Plant Variety Protection Office, the applicant may appeal to the Secretary. The Secretary shall seek the advice of the Plant Variety Protection Board on all appeals, before deciding the appeal.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef8414b0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tII/s63"},"text":"Pub. L. 91–577, title II, § 63","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1550"},"text":"84 Stat. 1550","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
