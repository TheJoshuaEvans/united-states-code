{"tag":"section","attrib":{"id":"idee06753c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q"},"text":null,"children":[{"tag":"num","attrib":{"value":"136q"},"text":"§ 136q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Storage, disposal, transportation, and recall","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee06753d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Storage, disposal, and transportation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee06753e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data requirements and registration of pesticides","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may require under section 136a or 136d of this title that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee06753f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the registrant or applicant for registration of a pesticide submit or cite data or information regarding methods for the safe storage and disposal of excess quantities of the pesticide to support the registration or continued registration of a pesticide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee067540-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the labeling of a pesticide contain requirements and procedures for the transportation, storage, and disposal of the pesticide, any container of the pesticide, any rinsate containing the pesticide, or any other material used to contain or collect excess or spilled quantities of the pesticide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee067541-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the registrant of a pesticide provide evidence of sufficient financial and other resources to carry out a recall plan under subsection (b), and provide for the disposition of the pesticide, in the event of suspension and cancellation of the pesticide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee067542-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pesticides","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may by regulation, or as part of an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136d"},"text":"section 136d of this title","children":[],"tail":" or an amendment to such an order—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee067543-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue requirements and procedures to be followed by any person who stores or transports a pesticide the registration of which has been suspended or canceled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee067544-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue requirements and procedures to be followed by any person who disposes of stocks of a pesticide the registration of which has been suspended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee067545-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue requirements and procedures for the disposal of any pesticide the registration of which has been canceled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee067546-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Containers, rinsates, and other materials","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may by regulation, or as part of an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136d"},"text":"section 136d of this title","children":[],"tail":" or an amendment to such an order—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee067547-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue requirements and procedures to be followed by any person who stores or transports any container of a pesticide the registration of which has been suspended or canceled, any rinsate containing the pesticide, or any other material used to contain or collect excess or spilled quantities of the pesticide;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee067548-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue requirements and procedures to be followed by any person who disposes of stocks of any container of a pesticide the registration of which has been suspended, any rinsate containing the pesticide, or any other material used to contain or collect excess or spilled quantities of the pesticide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee067549-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue requirements and procedures for the disposal of any container of a pesticide the registration of which has been canceled, any rinsate containing the pesticide, or any other material used to contain or collect excess or spilled quantities of the pesticide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee06754a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Container recycling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may promulgate a regulation for the return and recycling of disposable pesticide containers used for the distribution or sale of registered pesticide products in interstate commerce. Any such regulation requiring recycling of disposable pesticide containers shall not apply to antimicrobial pesticides (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"section 136 of this title","children":[],"tail":") or other pesticide products intended for non-agricultural uses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee06754b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recalls","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee06754c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the registration of a pesticide has been suspended and canceled under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136d"},"text":"section 136d of this title","children":[],"tail":", and if the Administrator finds that recall of the pesticide is necessary to protect health or the environment, the Administrator shall order a recall of the pesticide in accordance with this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee06754d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary recall","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after determining under paragraph (1) that a recall is necessary, the Administrator finds that voluntary recall by the registrant and others in the chain of distribution may be as safe and effective as a mandatory recall, the Administrator shall request the registrant of the pesticide to submit, within 60 days of the request, a plan for the voluntary recall of the pesticide. If such a plan is requested and submitted, the Administrator shall approve the plan and order the registrant to conduct the recall in accordance with the plan unless the Administrator determines, after an informal hearing, that the plan is inadequate to protect health or the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee06754e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory recall","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after determining under paragraph (1) that a recall is necessary, the Administrator does not request the submission of a plan under paragraph (2) or finds such a plan to be inadequate, the Administrator shall issue a regulation that prescribes a plan for the recall of the pesticide. A regulation issued under this paragraph may apply to any person who is or was a registrant, distributor, or seller of the pesticide, or any successor in interest to such a person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee06754f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recall procedure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A regulation issued under this subsection may require any person that is subject to the regulation to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee067550-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange to make available one or more storage facilities to receive and store the pesticide to which the recall program applies, and inform the Administrator of the location of each such facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee067551-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept and store at such a facility those existing stocks of such pesticide that are tendered by any other person who obtained the pesticide directly or indirectly from the person that is subject to such regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee067552-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the request of a person making such a tender, provide for proper transportation of the pesticide to a storage facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee067553-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such reasonable steps as the regulation may prescribe to inform persons who may be holders of the pesticide of the terms of the recall regulation and how those persons may tender the pesticide and arrange for transportation of the pesticide to a storage facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee067554-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of recall plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recall plan established under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee067555-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level in the distribution chain to which the recall is to extend, and a schedule for recall; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee067556-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the means to be used to verify the effectiveness of the recall.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee067557-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements or procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No requirement or procedure imposed in accordance with paragraph (2) of subsection (a) may require the recall of existing stocks of the pesticide except as provided by this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee067558-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Storage costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee067559-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A registrant who wishes to become eligible for reimbursement of storage costs incurred as a result of a recall prescribed under subsection (b) for a pesticide whose registration has been suspended and canceled shall, as soon as practicable after the suspension of the registration of the pesticide, submit to the Administrator a plan for the storage and disposal of the pesticide that meets criteria established by the Administrator by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee06755a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within a reasonable period of time after such storage costs are incurred and paid by the registrant, the Administrator shall reimburse the registrant, on request, for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee06755b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" none of the costs incurred by the registrant before the date of submission of the plan referred to in paragraph (1) to the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee06755c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent of the costs incurred by the registrant after the date of submission of the plan to the Administrator or the date of cancellation of the registration of the pesticide, whichever is later, but before the approval of the plan by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee06755d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the costs incurred by the registrant during the 1-year period beginning on the date of the approval of the plan by the Administrator or the date of cancellation of the registration of the pesticide, whichever is later;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee06755e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" none of the costs incurred by the registrant during the 3-year period beginning on the 366th day following approval of the plan by the Administrator or the date of cancellation of the registration of the pesticide, whichever is later; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee06755f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent of the costs incurred by the registrant during the period beginning on the first day of the 5th year following the date of the approval of the plan by the Administrator or the date of cancellation of the registration of the pesticide, whichever is later, and ending on the date that a disposal permit for the pesticide is issued by a State or an alternative plan for disposal of the pesticide in accordance with applicable law has been developed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee067560-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of storage, disposal, transportation, and recall programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee067561-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as preventing or making unlawful any agreement between a seller and a buyer of any pesticide or other substance regarding the ultimate allocation of the costs of storage, transportation, or disposal of a pesticide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee067562-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule and regulation review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136w/a/4"},"text":"Section 136w(a)(4) of this title","children":[],"tail":" shall not apply to any regulation issued under subsection (a)(2) or (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee067563-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No registrant shall be responsible under this section for a pesticide the registration of which is held by another person. No distributor or seller shall be responsible under this section for a pesticide that the distributor or seller did not hold or sell.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee067564-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seizure and penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator finds that a person who is subject to a regulation or order under subsection (a)(2) or (b) has failed substantially to comply with that regulation or order, the Administrator may take action under section 136k or 136","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of this title or obtain injunctive relief under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136n/c"},"text":"section 136n(c) of this title","children":[],"tail":" against such person or any successor in interest of any such person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee067565-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Container design","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee067566-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee067567-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 3 years after the effective date of this subsection, the Administrator shall, in consultation with the heads of other interested Federal agencies, promulgate regulations for the design of pesticide containers that will promote the safe storage and disposal of pesticides.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee067568-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The regulations shall ensure, to the fullest extent practicable, that the containers—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee067569-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accommodate procedures used for the removal of pesticides from the containers and the rinsing of the containers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee06756a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the safe use of the containers, including elimination of splash and leakage of pesticides from the containers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee06756b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/e/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the safe disposal of the containers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee06756c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/e/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the safe refill and reuse of the containers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee06756d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall require compliance with the regulations referred to in paragraph (1) not later than 5 years after the effective date of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee06756e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pesticide residue removal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee06756f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee067570-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 3 years after the effective date of this subsection, the Administrator shall, in consultation with the heads of other interested Federal agencies, promulgate regulations prescribing procedures and standards for the removal of pesticides from containers prior to disposal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee067571-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The regulations may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee067572-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify, for each major type of pesticide container, procedures and standards providing for, at a minimum, triple rinsing or the equivalent degree of pesticide removal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee067573-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify procedures that can be implemented promptly and easily in various circumstances and conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee067574-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/f/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for reuse, whenever practicable, or disposal of rinse water and residue; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee08e575-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/f/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be coordinated with requirements for the rinsing of containers imposed under the Solid Waste Disposal Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6901"},"text":"42 U.S.C. 6901","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee08e576-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may, at the discretion of the Administrator, exempt products intended solely for household use from the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee08e577-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective beginning 5 years after the effective date of this subsection, a State may not exercise primary enforcement responsibility under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136w–1"},"text":"section 136w–1 of this title","children":[],"tail":", or certify an applicator under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136i"},"text":"section 136i of this title","children":[],"tail":", unless the Administrator determines that the State is carrying out an adequate program to ensure compliance with this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee08e578-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solid Waste Disposal Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall affect the authorities or requirements concerning pesticide containers under the Solid Waste Disposal Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6901"},"text":"42 U.S.C. 6901","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee08e579-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pesticide container study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee08e57a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee08e57b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall conduct a study of options to encourage or require—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee08e57c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/g/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the return, refill, and reuse of pesticide containers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee08e57d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/g/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and use of pesticide formulations that facilitate the removal of pesticide residues from containers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee08e57e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/g/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of bulk storage facilities to reduce the number of pesticide containers requiring disposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee08e57f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In conducting the study, the Administrator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee08e580-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/g/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the heads of other interested Federal agencies, State agencies, industry groups, and environmental organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee08e581-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/g/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the feasibility, costs, and environmental benefits of encouraging or requiring various measures or actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee08e582-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after the effective date of this subsection, the Administrator shall submit to Congress a report describing the results of the study required under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee08e583-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to Solid Waste Disposal Act","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee08e584-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall diminish the authorities or requirements of the Solid Waste Disposal Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6901"},"text":"42 U.S.C. 6901","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee08e585-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136q/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antimicrobial products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A household, industrial, or institutional antimicrobial product that is not subject to regulation under the Solid Waste Disposal Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6901"},"text":"42 U.S.C. 6901","children":[],"tail":" et seq.) shall not be subject to the provisions of subsections (a), (e), and (f), unless the Administrator determines that such product must be subject to such provisions to prevent an unreasonable adverse effect on the environment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee08e586-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125/s19"},"text":"June 25, 1947, ch. 125, § 19","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/516/s2"},"text":"Pub. L. 92–516, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/995"},"text":"86 Stat. 995","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/396/s19"},"text":"Pub. L. 95–396, § 19","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/833"},"text":"92 Stat. 833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/532/tIV"},"text":"Pub. L. 100–532, title IV","children":[],"tail":", §§ 401–403, title VIII, § 801(q)(1)(D), "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2669"},"text":"102 Stat. 2669","children":[],"tail":", 2672, 2683; "},{"tag":"ref","attrib":{"href":"/us/pl/104/170/tII/s225"},"text":"Pub. L. 104–170, title II, § 225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-03"},"text":"Aug. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1507"},"text":"110 Stat. 1507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14209/b"},"text":"Pub. L. 110–234, title XIV, § 14209(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"}