{"tag":"section","attrib":{"id":"idf023d761-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7812"},"text":null,"children":[{"tag":"num","attrib":{"value":"7812"},"text":"§ 7812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may issue such regulations as are necessary to carry out this chapter and the powers vested in the Secretary by this chapter, including regulations relating to the assessment of late payment charges and interest.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf023d762-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tXII/s1213"},"text":"Pub. L. 106–387, § 1(a) [title XII, § 1213]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–97.)"}],"tail":"\n"}],"tail":null}
