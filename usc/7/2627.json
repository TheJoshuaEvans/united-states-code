{"tag":"section","attrib":{"id":"idef88cf1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2627"},"text":null,"children":[{"tag":"num","attrib":{"value":"2627"},"text":"§ 2627.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is hereby made available from the funds provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"section 612c of this title","children":[],"tail":" such sums as are necessary to carry out the provisions of this chapter: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no such sum shall be used for the payment of any expenses or expenditures of the board in administering any provision of any plan issued under authority of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef88cf1d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/670/tIII/s318"},"text":"Pub. L. 91–670, title III, § 318","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-11"},"text":"Jan. 11, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2047"},"text":"84 Stat. 2047","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
