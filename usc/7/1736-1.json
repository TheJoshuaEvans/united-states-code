{"tag":"section","attrib":{"id":"ideef038a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1736–1"},"text":"§ 1736–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special Assistant for Agricultural Trade and Food Assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef038a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment by President","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall appoint a Special Assistant to the President for Agricultural Trade and Food Assistance (hereinafter in this section referred to as the “Special Assistant”). The President shall appoint the initial Special Assistant not later than ","children":[{"tag":"date","attrib":{"date":"1986-05-01"},"text":"May 1, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef038a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service in Executive Office of President","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Special Assistant shall serve in the Executive Office of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef038a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Special Assistant shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef038a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist and advise the President in order to improve and enhance food assistance programs carried out in the United States and foreign countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef038a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be available to receive suggestions and complaints concerning the implementation of United States food aid and agricultural export programs anywhere in the United States Government and provide prompt responses thereto, including expediting the program implementation in any instances in which there is unreasonable delay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef038aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the President on means to coordinate and streamline the manner in which food assistance programs are carried out by the Department of Agriculture and the Agency for International Development, in order to improve their overall effectiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef038ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the President on measures to be taken to increase use of United States agricultural commodities and the products thereof through food assistance programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef038ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the President on agricultural trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef038ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the President on the Food for Progress Program and expedite its implementation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef038ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a member of the Development Coordination Committee and the Food Aid Subcommittee of such Committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef038af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise departments and agencies of the Federal Government on their policy guidelines on basic issues of food assistance policy to the extent necessary to assure the coordination of food assistance programs, consistent with law, and with the advice of such Subcommittee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef038b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit a report to the President and Congress each year through 1990 containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef038b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/c/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a global analysis of world food needs and production; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef038b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/c/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed plan for using available export and food aid authorities to increase United States agricultural exports to those targeted countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef038b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Compensation for the Special Assistant shall be fixed by the President at an annual rate of basic pay of not less than the rate applicable to positions in level III of the Executive Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef038b4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXI/s1113/a"},"text":"Pub. L. 99–198, title XI, § 1113(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1479"},"text":"99 Stat. 1479","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/260/s4/a/1"},"text":"Pub. L. 99–260, § 4(a)(1)","children":[],"tail":", (b), (d), "},{"tag":"date","attrib":{"date":"1986-03-20"},"text":"Mar. 20, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/49"},"text":"100 Stat. 49","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1572/2"},"text":"Pub. L. 101–624, title XV, § 1572(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3702"},"text":"104 Stat. 3702","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef038b5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef038b6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideef038b7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Level III of the Executive Schedule, referred to in subsec. (d), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideef038b8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food Security Act of 1985, and not as part of the Food for Peace Act which comprises this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1113/d"},"text":"section 1113(d) of Pub. L. 99–198","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5312"},"text":"section 5312 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideef038b9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (c)(9)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" redesignated subpar. (C) as (B) and struck out former subpar. (B) which required that report contain identification of at least 15 target countries most likely to emerge as growth markets for commodities in next 5 to 10 years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/260/s4/a/1/A"},"text":"Pub. L. 99–260, § 4(a)(1)(A)","children":[],"tail":", substituted “Food Assistance” for “Food Aid” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/260/s4/a/1/B"},"text":"Pub. L. 99–260, § 4(a)(1)(B)","children":[],"tail":", (b), substituted “Food Assistance” for “Food Aid” and inserted provision that the President appoint the initial Special Assistant not later than "},{"tag":"date","attrib":{"date":"1986-05-01"},"text":"May 1, 1986","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/260/s4/d"},"text":"Pub. L. 99–260, § 4(d)","children":[],"tail":", amended subsec. (d) generally, substituting provision relating to compensation of the Special Assistant for provision relating to additional required functions of the Special Assistant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
