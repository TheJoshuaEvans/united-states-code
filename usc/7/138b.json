{"tag":"section","attrib":{"id":"idee14ccbd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138b"},"text":null,"children":[{"tag":"num","attrib":{"value":"138b"},"text":"§ 138b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accreditation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee14ccbe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue certificates of accreditation to laboratories that meet the requirements of this chapter, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee14ccbf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for accreditation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To receive accreditation under this chapter, a laboratory shall prepare and submit an application for accreditation to the Secretary and shall complete such required tests, and meet such standards as established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s138a"},"text":"section 138a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee14ccc0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to meet accreditation standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall deny an application for accreditation or shall revoke any existing accreditation with respect to any laboratory that fails to meet the requirements for accreditation under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee14ccc1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited accreditation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may issue certificates of accreditation to laboratories that are limited to specific fields of testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee14ccc2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIII/s1323"},"text":"Pub. L. 101–624, title XIII, § 1323","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3563"},"text":"104 Stat. 3563","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
