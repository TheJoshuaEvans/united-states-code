{"tag":"section","attrib":{"id":"idee65d319-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"950bb–5"},"text":"§ 950bb–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Default and deobligation; deferral","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee65d31a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Default and deobligation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to other authority under applicable law, the Secretary shall establish written procedures for all broadband programs so that, to the maximum extent practicable, the programs are administered to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d31b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recover funds from loan and grant defaults;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d31c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deobligate any awards, less allowable costs that demonstrate an insufficient level of performance (including metrics determined by the Secretary) or fraudulent spending, to the extent funds with respect to the award are available in the account relating to the program established by this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d31d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award those funds, on a competitive basis, to new or existing applicants consistent with this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d31e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–5/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize overlap among the programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d31f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferral period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the terms and conditions of assistance provided under this subchapter, the Secretary may establish a deferral period of not shorter than the buildout period established for the project involved in order to support the financial feasibility and long-term sustainability of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee65d320-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title VI, § 606, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6206"},"text":"Pub. L. 115–334, title VI, § 6206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4739"},"text":"132 Stat. 4739","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
