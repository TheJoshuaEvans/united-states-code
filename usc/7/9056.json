{"tag":"section","attrib":{"id":"idf04eb7b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056"},"text":null,"children":[{"tag":"num","attrib":{"value":"9056"},"text":"§ 9056.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dairy margin coverage payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04eb7b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage level threshold and coverage percentage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb7ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage level threshold","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04eb7bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of receiving dairy margin coverage payments for a month, a participating dairy operation shall annually elect a coverage level threshold that is equal to $4.00, $4.50, $5.00, $5.50, $6.00, $6.50, $7.00, $7.50, $8.00, $8.50, $9.00, or $9.50.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb7bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (C), the coverage level threshold elected under subparagraph (A) shall apply to the covered production elected by the participating dairy operation under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb7bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second coverage election for tier II","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a participating dairy operation that elects a coverage level threshold of $8.50, $9.00, or $9.50 under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf04eb7be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that coverage level threshold shall apply to the first 6,000,000 pounds of milk marketings included in the covered production elected by the participating dairy operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04eb7bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participating dairy operation shall elect a coverage level threshold that is equal to $4.00, $4.50, $5.00, $5.50, $6.00, $6.50, $7.00, $7.50, or $8.00 to apply to milk marketings in excess of 6,000,000 pounds included in the covered production elected by the participating dairy operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb7c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage percentage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of receiving dairy margin coverage payments for a month, a participating dairy operation shall annually elect a percentage of coverage, in 5-percent increments, not exceeding 95 percent of the production history of the participating dairy operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb7c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment threshold","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A participating dairy operation shall receive a dairy margin coverage payment whenever the average actual dairy production margin for a month is less than the coverage level threshold selected by the participating dairy operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb7c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The dairy margin coverage payment for the participating dairy operation shall be determined as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb7c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall calculate the amount by which the coverage level threshold selected by the participating dairy operation exceeds the average actual dairy production margin for the month.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb7c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount determined under paragraph (1) shall be multiplied by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04eb7c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coverage percentage selected by the participating dairy operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb7c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9056/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production history of the participating dairy operation divided by 12.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04eb7c7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1406"},"text":"Pub. L. 113–79, title I, § 1406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/691"},"text":"128 Stat. 691","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dF/s60101/b/1/C"},"text":"Pub. L. 115–123, div. F, § 60101(b)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/311"},"text":"132 Stat. 311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1401/g"},"text":"Pub. L. 115–334, title I, § 1401(g)","children":[],"tail":", (k)(7), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4513"},"text":"132 Stat. 4513","children":[],"tail":", 4517; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10313/b"},"text":"Pub. L. 119–21, title I, § 10313(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/100"},"text":"139 Stat. 100","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04eb7c8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04eb7c9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04eb7ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “6,000,000” for “5,000,000” in cls. (i) and (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/7/A"},"text":"Pub. L. 115–334, § 1401(k)(7)(A)","children":[],"tail":" substituted “Dairy margin coverage” for “Margin protection” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/b/1/C/i"},"text":"Pub. L. 115–123, § 60101(b)(1)(C)(i)","children":[],"tail":", substituted “month” for “consecutive 2-month period” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/g"},"text":"Pub. L. 115–334, § 1401(g)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “For purposes of receiving margin protection payments for a month, a participating dairy operation shall annually elect—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) a coverage level threshold that is equal to $4.00, $4.50, $5.00, $5.50, $6.00, $6.50, $7.00, $7.50, or $8.00; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) a percentage of coverage, in 5-percent increments, beginning with 25 percent and not exceeding 90 percent of the production history of the participating dairy operation.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/7/B"},"text":"Pub. L. 115–334, § 1401(k)(7)(B)","children":[],"tail":", substituted “dairy margin coverage” for “margin protection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/7/B"},"text":"Pub. L. 115–334, § 1401(k)(7)(B)","children":[],"tail":", (C), struck out “margin protection” before “payment” in heading and substituted “dairy margin coverage” for “margin protection” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/b/1/C/ii"},"text":"Pub. L. 115–123, § 60101(b)(1)(C)(ii)","children":[],"tail":", substituted “divided by 12” for “divided by 6”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf04eb7cb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf04eb7cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/m"},"text":"section 1401(m) of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9051"},"text":"section 9051 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" applicable beginning with the 2018 calendar year, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/b/5"},"text":"section 60101(b)(5) of Pub. L. 115–123","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9051"},"text":"section 9051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf04eb7cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Supplemental Dairy Margin Coverage Payments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tVII/s761"},"text":"Pub. L. 116–260, div. N, title VII, § 761","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2109"},"text":"134 Stat. 2109","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dN/tVII/s761"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide supplemental dairy margin coverage payments to participating eligible dairy operations described in subsection (b)(1) whenever the average actual dairy production margin (as defined in section 1401 of the Agricultural Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9051"},"text":"7 U.S.C. 9051","children":[],"tail":")) for a month is less than the coverage level threshold selected by such eligible dairy operation under section 1406 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9056"},"text":"7 U.S.C. 9056","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Dairy Operation Described.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible dairy operation described in this subsection is a dairy operation that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during a calendar year in which such dairy operation is a participating dairy operation (as defined in section 1401 of the Agricultural Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9051"},"text":"7 U.S.C. 9051","children":[],"tail":")), has a production history established under the dairy margin coverage program under section 1405 of the Agricultural Act of 2014 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9055"},"text":"7 U.S.C. 9055","children":[],"tail":") of less than 5,000,000 pounds, as determined in accordance with subsection (c) of such section 1405."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible dairy operation shall only be eligible for payments under this section during a calendar year in which such eligible dairy operation is enrolled in the dairy margin coverage (as defined in section 1401 of the Agricultural Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9051"},"text":"7 U.S.C. 9051","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplemental Production History Calculation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of determining the supplemental production history of an eligible dairy operation under this section, such dairy operation’s supplemental production history shall be equal to 75 percent of the amount described in paragraph (2) with respect to such dairy operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount referred to in paragraph (1) is, with respect to an eligible dairy operation, the amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production volume of such dairy operation for the 2019 milk marketing year; minus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dairy margin coverage production history of such dairy operation established under section 1405 of the Agricultural Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9055"},"text":"7 U.S.C. 9055","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coverage Percentage.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of calculating payments to be issued under this section during a calendar year, an eligible dairy operation’s coverage percentage shall be equal to the coverage percentage selected by such eligible dairy operation with respect to such calendar year under section 1406 of the Agricultural Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9056"},"text":"7 U.S.C. 9056","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 5 ","children":[{"tag":"inline","attrib":{},"text":"million pound limitation.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not provide supplemental dairy margin coverage on an eligible dairy operation’s actual production for a calendar year such that the total covered production history of such dairy operation exceeds 5,000,000 pounds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In calculating the total covered production history of an eligible dairy operation under subparagraph (A), the Secretary shall multiply the coverage percentage selected by such operation under section 1406 of the Agricultural Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9056"},"text":"7 U.S.C. 9056","children":[],"tail":") by the sum of—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supplemental production history calculated under subsection (c) with respect to such dairy operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dairy margin coverage production history described in subsection (c)(2)(B) with respect to such dairy operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Premium Cost","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The premium cost for an eligible dairy operation under this section for a calendar year shall be equal to the product of multiplying—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tier I premium cost calculated with respect to such dairy operation for such year under section 1407(b) of the Agricultural Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9057/b"},"text":"7 U.S.C. 9057(b)","children":[],"tail":"); by"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supplemental production history with respect to such dairy operation calculated under subsection (c) (such that total covered production history does not exceed 5,000,000 pounds).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 45 days after the date of the enactment of this section [","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"], the Secretary shall issue regulations to carry out this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition With Respect to Dairy Margin Coverage Enrollment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not reopen or otherwise provide a special enrollment for dairy margin coverage (as defined in section 1401 of the Agricultural Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9051"},"text":"7 U.S.C. 9051","children":[],"tail":")) for purposes of establishing eligibility for supplemental dairy margin coverage payments under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clarification with respect to supplemental dairy margin coverage payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may open a special enrollment for supplemental dairy margin coverage under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"“(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application for Calendar Year","children":[],"tail":" 2021.—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make payments under this section to eligible dairy operations described in subsection (b)(1) for months after and including January, 2021.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to make payments under this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2023-12-31"},"text":"December 31, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"“(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is appropriated, out of any funds in the Treasury not otherwise appropriated, to carry out this section such sums as necessary, to remain available until the date specified in subsection (i).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “Secretary” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/s761"},"text":"section 761 of div. N of Pub. L. 116–260","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/s760"},"text":"section 760 of div. N of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5936a"},"text":"section 5936a of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
