{"tag":"section","attrib":{"id":"ideffb3ff3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7032"},"text":null,"children":[{"tag":"num","attrib":{"value":"7032"},"text":"§ 7032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accessing information and filing over the Internet","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffb3ff4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", in accordance with subsection (b), the Secretary shall expand implementation of the Internet-based system established under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7031"},"text":"section 7031 of this title","children":[],"tail":" by enabling agricultural producers to access and file all forms and, at the option of the Secretary, selected records and information of the agencies of the Department specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7031/b"},"text":"section 7031(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffb3ff5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary shall ensure that an agricultural producer is able—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffb3ff6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7032/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to file electronically or in paper form, at the option of the agricultural producer, all forms required by agencies of the Department specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7031/b"},"text":"section 7031(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb3ff7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7032/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to file electronically or in paper form, at the option of the agricultural producer, all documentation required by agencies of the Department specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7031/b"},"text":"section 7031(b) of this title","children":[],"tail":" and determined appropriate by the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb3ff8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7032/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to access information of the Department concerning farm programs, quarterly trade, economic, and production reports, and other similar production agriculture information that is readily available to the public in paper form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffb3ff9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/222/s3"},"text":"Pub. L. 106–222, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/354"},"text":"114 Stat. 354","children":[],"tail":".)"}],"tail":"\n"}],"tail":nul