{"tag":"section","attrib":{"id":"idef2701a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008x"},"text":"§ 2008x.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef2701aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of farm loan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “farm loan” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2701ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a farm ownership loan under subtitle A of the Consolidated Farm and Rural Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1922"},"text":"7 U.S.C. 1922","children":[],"tail":" et seq.); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2701ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an operating loan under subtitle B of that Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1941"},"text":"7 U.S.C. 1941","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2701ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2701ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, the Secretary shall prepare a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2701af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" aggregate data based on a review of each outstanding farm loan made or guaranteed by the Secretary describing, for the United States and for each State and county in the United States—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2701b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the age of the recipient producer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration that the recipient producer has engaged in agricultural production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size of the farm or ranch of the recipient producer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the race, ethnicity, and gender of the recipient producer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agricultural commodity or commodities, or type of enterprise, for which the loan was secured;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the farm loan made or guaranteed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of the farm loan made or guaranteed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the default rate of the farm loan made or guaranteed;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2701b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each State and county in the United States, data demonstrating the number of outstanding farm loans made or guaranteed, according to loan size cohort; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2701b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of actual loans made or guaranteed as measured against target participation rates for beginning and socially disadvantaged farmers, broken down by State, as described in sections 346(b)(2) and 355 of the Consolidated Farm and Rural Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1994/b/2"},"text":"7 U.S.C. 1994(b)(2)","children":[],"tail":", 2003)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2701ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report described in paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2701bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submitted—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2701bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef2701bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef2701be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef2701bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/2/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef2701c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/2/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than ","children":[{"tag":"date","attrib":{"date":"2019-12-30"},"text":"December 30, 2019","children":[],"tail":", and annually thereafter; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2701c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made publicly available not later than 90 days after the date described in subparagraph (A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2701c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2701c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":" (and every 5 years thereafter), the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2701c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare a comprehensive review of all reports submitted under subsection (b)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2701c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify trends within data outlined in subsection (b)(1), including the extent to which target annual participation rates for beginning and socially disadvantaged farmers (as defined by the Secretary) are being met for each loan type; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2701c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide specific actions the Department will take to improve the performance of direct and guaranteed loans with respect to underserved producers and any recommendations the Secretary may make for further congressional action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2701c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of comprehensive review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The comprehensive review described in paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2701c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submitted to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2701ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2701cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2701ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made publicly available not later than 90 days after the date of submission under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2701cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008x/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In preparing any report or review under this section, the Secretary shall aggregate or de-identify the data in a manner sufficient to ensure that the identity of a recipient producer associated with the data cannot be ascertained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef2701d0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5413"},"text":"Pub. L. 115–334, title V, § 5413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4722"},"text":"132 Stat. 4722","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef2701d1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef2701d2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef2970d3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Consolidated Farm and Rural Development Act, referred to in subsec. (a), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":". Subtitles A and B of the Act are classified generally to subchapters I (§ 1922 et seq.) and II (§ 1941 et seq.), respectively, of this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef2970d4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agriculture Improvement Act of 2018, and not as part of the Consolidated Farm and Rural Development Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef2970d5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idef2970d6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” as meaning the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/344/s2"},"text":"section 2 of Pub. L. 115–344","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
