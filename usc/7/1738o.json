{"tag":"section","attrib":{"id":"ideef9aec6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738o"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738o"},"text":"§ 1738o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of qualified debt to eligible countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef9aec7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738o/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef9aec8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738o/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President may sell to an eligible country up to 40 percent of such country’s qualified debt, only if an amount of the local currency of such country (other than the price paid for the debt) equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef9aec9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738o/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 40 percent of the price paid for such debt by such eligible country, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef9aeca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738o/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the difference between the price paid for such debt and the face value of such debt;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whichever is less, is used by such country through an Environmental Fund for eligible activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738k"},"text":"section 1738k of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9aecb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738o/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “Environmental Fund” means an Environmental Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738g"},"text":"section 1738g of this title","children":[],"tail":". In the case of Mexico, such fund may be designated as the Good Neighbor Environmental Fund for the Border."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9aecc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738o/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and operation of environmental funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President should advise eligible countries on the procedures required to establish and operate the Environmental Funds required to be established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aecd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738o/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish the terms and conditions, including the amount to be paid by the eligible country, under which such country’s qualified debt may be sold under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aece-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738o/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorities provided by this section may be exercised only in such amounts and to such extent as is provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aecf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738o/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain prohibitions inapplicable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A sale of debt under this section shall not be considered assistance for purposes of any provision of law limiting assistance to a country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aed0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738o/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation by Facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A sale of debt authorized under this section shall be accomplished at the direction of the Facility. The Facility shall direct the Commodity Credit Corporation to carry out such sale. The Commodity Credit Corporation shall make an adjustment in its accounts to reflect the sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aed1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738o/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proceeds from a sale of qualified debt under this section shall be deposited in the account or accounts established by the Commodity Credit Corporation for the repayment of such debt by the eligible country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aed2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738o/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debtor consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before any sale of qualified debt may occur under this section, the President should consult with the eligible country’s government concerning such sale. The topics addressed in the consultation shall include the amount of qualified debt involved in the transaction and the uses to which funds made available as a result of the sale shall be applied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef9aed3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title VI, § 616, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/532/s2"},"text":"Pub. L. 102–532, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3509"},"text":"106 Stat. 3509","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
