{"tag":"section","attrib":{"id":"idef64f351-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034"},"text":null,"children":[{"tag":"num","attrib":{"value":"2034"},"text":"§ 2034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance for community food projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef64f352-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f353-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community food project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “community food project” means a community-based project that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef64f354-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires a 1-time contribution of Federal assistance to become self-sustaining; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f355-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is designed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef64f356-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef64f357-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet the food needs of low-income individuals through food distribution, community outreach to assist in participation in Federally assisted nutrition programs, or improving access to food as part of a comprehensive service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef64f358-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the self-reliance of communities in providing for the food needs of the communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef64f359-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/1/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote comprehensive responses to local food, food access, farm, and nutrition issues; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef64f35a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to meet specific State, local, or neighborhood food and agricultural needs, including needs relating to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef64f35b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment necessary for the efficient operation of a project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef64f35c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning for long-term solutions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef64f35d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the creation of innovative marketing activities that mutually benefit agricultural producers and low-income consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f35e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gleaner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “gleaner” means an entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef64f35f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collects edible, surplus food that would be thrown away and distributes the food to agencies or nonprofit organizations that feed the hungry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f360-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" harvests for free distribution to the needy, or for donation to agencies or nonprofit organizations for ultimate distribution to the needy, an agricultural crop that has been donated by the owner of the crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f361-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hunger-free communities goal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “hunger-free communities goal” means any of the 14 goals described in House Concurrent Resolution 302, 102nd Congress, agreed to ","children":[{"tag":"date","attrib":{"date":"1992-10-05"},"text":"October 5, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef64f362-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to provide assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f363-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available to carry out this chapter, the Secretary may make grants to assist eligible private nonprofit entities to establish and carry out community food projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f364-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total amount of funds provided as grants under this section may not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef64f365-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for fiscal year 1996;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f366-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for each of fiscal years 2008 through 2014;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f367-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $9,000,000 for each of fiscal years 2015 through 2018; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f368-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for fiscal year 2019 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef64f369-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant under subsection (b), a public food program service provider, a tribal organization, or a private nonprofit entity, including gleaners, must—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f36a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have experience in the area of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef64f36b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community food work, particularly concerning small and medium-sized farms, including the provision of food to people in low-income communities and the development of new markets in low-income communities for agricultural producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f36c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" job training and business development activities for food-related activities in low-income communities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f36d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to reduce food insecurity in the community, including food distribution, improving access to services, or coordinating services and programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f36e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate competency to implement a project, provide fiscal accountability, collect data, and prepare reports and other necessary documentation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f36f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a willingness to share information with researchers, practitioners, and other interested parties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f370-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with 1 or more local partner organizations to achieve at least 1 hunger-free communities goal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef64f371-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference for certain projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting community food projects to receive assistance under subsection (b), the Secretary shall give a preference to projects designed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f372-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop linkages between 2 or more sectors of the food system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f373-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of entrepreneurial projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f374-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop innovative linkages between the for-profit and nonprofit food sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f375-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage long-term planning activities, and multisystem, interagency approaches with multistakeholder collaborations, that build the long-term capacity of communities to address the food and agricultural problems of the communities, such as food policy councils and food planning associations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f376-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop new resources and strategies to help reduce food insecurity in the community and prevent food insecurity in the future by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef64f377-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing creative food resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f378-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating food services with park and recreation programs and other community-based outlets to reduce barriers to access; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f379-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating nutrition education programs for at-risk populations to enhance food-purchasing and food-preparation skills and to heighten awareness of the connection between diet and health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef64f37a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f37b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of establishing or carrying out a community food project that receives assistance under subsection (b) may not exceed 50 percent of the cost of the project during the term of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f37c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing for the non-Federal share of the cost of carrying out a community food project, the entity receiving the grant shall provide for the share through a payment in cash or in kind, fairly evaluated, including facilities, equipment, or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f37d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity may provide for the non-Federal share through State government, local government, or private sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef64f37e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of grant","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f37f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A community food project may be supported by only a single grant under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f380-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of a grant under subsection (b) may not exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef64f381-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance and related information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f382-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary may provide technical assistance regarding community food projects, processes, and development to an entity seeking the assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f383-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef64f384-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide for the sharing of information concerning community food projects and issues among and between government, private for-profit and nonprofit groups, and the public through publications, conferences, and other appropriate forums.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f385-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other interested parties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may share information concerning community food projects with researchers, practitioners, and other interested parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef64f386-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2014-09-30"},"text":"September 30, 2014","children":[],"tail":", and each year thereafter, the Secretary shall submit to Congress a report that describes each grant made under this section, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f387-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any activity funded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f388-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree of success of each activity funded in achieving hunger-free community goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f389-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2034/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree of success in improving the long-term capacity of a community to address food and agriculture problems related to hunger or access to healthy food.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef64f38a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/525/s25"},"text":"Pub. L. 88–525, § 25","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIV/s401/h"},"text":"Pub. L. 104–127, title IV, § 401(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1027"},"text":"110 Stat. 1027","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIV/s4125/a"},"text":"Pub. L. 107–171, title IV, § 4125(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/326"},"text":"116 Stat. 326","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIV"},"text":"Pub. L. 110–234, title IV","children":[],"tail":", §§ 4402, 4406(a)(7), "},{"tag":"date","attrib":{"date":"2008-05-22"}