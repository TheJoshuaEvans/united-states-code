,"children":[],"tail":", and the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4406/a/7"},"text":"section 4406(a)(7) of Pub. L. 110–246","children":[],"tail":" was effective "},{"tag":"date","attrib":{"date":"2008-10-01"},"text":"Oct. 1, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/110/380"},"text":"Pub. L. 110–380","children":[],"tail":" had no effect on the execution of the amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4406/a/7"},"text":"section 4406(a)(7) of Pub. L. 110–246","children":[],"tail":" to this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef64f38f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1)(B)(i)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s4022/8"},"text":"Pub. L. 115–334, § 4022(8)","children":[],"tail":", substituted “service;” for “service;;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s4017/2"},"text":"Pub. L. 115–334, § 4017(2)","children":[],"tail":", substituted “each of fiscal years 2015 through 2018; and” for “fiscal year 2015 and each fiscal year thereafter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s4017/1"},"text":"Pub. L. 115–334, § 4017(1)","children":[],"tail":", (3), added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(1)(B)(i)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s4026/1/A/i/I"},"text":"Pub. L. 113–79, § 4026(1)(A)(i)(I)","children":[],"tail":", inserted “through food distribution, community outreach to assist in participation in Federally assisted nutrition programs, or improving access to food as part of a comprehensive service;” after “individuals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(i)(III). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s4026/1/A/i/II"},"text":"Pub. L. 113–79, § 4026(1)(A)(i)(II)","children":[],"tail":", inserted “food access,” after “food,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B)(ii)(I). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s4026/1/A/ii"},"text":"Pub. L. 113–79, § 4026(1)(A)(ii)","children":[],"tail":", added subcl. (I) and struck out former subcl. (I) which read as follows: “infrastructure improvement and development;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s4026/1/B"},"text":"Pub. L. 113–79, § 4026(1)(B)","children":[],"tail":", added pars. (2) and (3) and struck out former pars. (2) and (3) which defined “Center” and “underserved community”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s4026/2/B"},"text":"Pub. L. 113–79, § 4026(2)(B)","children":[],"tail":", substituted “each of fiscal years 2008 through 2014; and” for “fiscal year 2008 and each fiscal year thereafter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s4026/2"},"text":"Pub. L. 113–79, § 4026(2)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s4026/3/A"},"text":"Pub. L. 113–79, § 4026(3)(A)","children":[],"tail":", substituted “public food program service provider, a tribal organization, or a private nonprofit entity, including gleaners,” for “private nonprofit entity” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s4026/3/B"},"text":"Pub. L. 113–79, § 4026(3)(B)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s4026/3/C"},"text":"Pub. L. 113–79, § 4026(3)(C)","children":[],"tail":"–(E), added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s4026/4"},"text":"Pub. L. 113–79, § 4026(4)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s4026/5"},"text":"Pub. L. 113–79, § 4026(5)","children":[],"tail":", substituted “5 years” for “3 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h), (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s4026/6"},"text":"Pub. L. 113–79, § 4026(6)","children":[],"tail":", added subsec. (h) and struck out former subsecs. (h) and (i) which related to healthy urban food enterprise development center and innovative programs for addressing common community problems, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4402/1"},"text":"Pub. L. 110–246, § 4402(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which defined “community food project”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4406/a/7/A"},"text":"Pub. L. 110–246, § 4406(a)(7)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/380"},"text":"Pub. L. 110–380","children":[],"tail":", substituted “for fiscal year 2008 and each fiscal year thereafter” for “for each of fiscal years 1997 through 2007”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h), (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4402/2"},"text":"Pub. L. 110–246, § 4402(2)","children":[],"tail":", (3), added subsec. (h) and redesignated former subsec. (h) as (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4406/a/7/B"},"text":"Pub. L. 110–246, § 4406(a)(7)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/380"},"text":"Pub. L. 110–380","children":[],"tail":", substituted “each fiscal year thereafter” for “each of fiscal years 2003 through 2007”. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s4125/a/1"},"text":"Pub. L. 107–171, § 4125(a)(1)","children":[],"tail":", designated pars. (1) to (3) as subpars. (A) to (C) of par. (1), respectively, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s4125/a/2"},"text":"Pub. L. 107–171, § 4125(a)(2)","children":[],"tail":", substituted “$5,000,000” for “$2,500,000” and “2007” for “2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s4125/a/3"},"text":"Pub. L. 107–171, § 4125(a)(3)","children":[],"tail":", added par. (4) and struck out former par. (4) which read as follows: “encourage long-term planning activities and multi-system, interagency approaches.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s4125/a/4"},"text":"Pub. L. 107–171, § 4125(a)(4)","children":[],"tail":", added subsec. (h) and struck out heading and text of former subsec. (h). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—The Secretary shall provide for the evaluation of the success of community food projects supported using funds under this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—Not later than "},{"tag":"date","attrib":{"date":"2002-01-30"},"text":"January 30, 2002","children":[],"tail":", the Secretary shall submit a report to Congress regarding the results of the evaluation.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef64f390-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef64f391-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"ta