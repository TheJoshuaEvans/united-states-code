{"tag":"section","attrib":{"id":"idefaef56f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3702"},"text":null,"children":[{"tag":"num","attrib":{"value":"3702"},"text":"§ 3702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefaef570-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “bulk agricultural commodity” means any agricultural commodity that can be transported in bulk and can be temporarily stored in bulk quantities without undergoing processing or packaging. Such term also includes any commodity or product that is used by producers in the production of agricultural commodities and that can be stored or shipped in bulk, such as fertilizer and fuel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaef571-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “unprocessed agricultural products” means food, fiber, and other agricultural products that have not been packaged or otherwise prepared for retail sale, including animal products and unfinished cotton, wool, leather, or any other unfinished natural material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaef572-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means Secretary of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaef573-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “subterminal facility” means any facility that is located in the area of production or consumption of agricultural commodities or any major storage or major export point for such commodities and is located at a place that conveniently serves the needs of producers, purchasers, and consumers of bulk agricultural commodities, and is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefaef574-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3702/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used for the transient storage of bulk agricultural commodities and may include equipment or structures necessary for the transportation, upgrading, receiving, drying, or loading out of such commodities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaef575-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3702/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rail siding, loading, or unloading facility that can accommodate unit railroad trains or multiple car trains and other appropriate transportation modes designed for the transport of bulk agricultural commodities and production materials; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaef576-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “region” means two or more States acting together to develop a coordinated regional subterminal facilities plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefaef577-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/358/s3"},"text":"Pub. L. 96–358, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-25"},"text":"Sept. 25, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1184"},"text":"94 Stat. 1184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefaef578-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefaef579-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefaef57a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in the introductory phrase, was in the original “this Act,” meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/358"},"text":"Pub. L. 96–358","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-25"},"text":"Sept. 25, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1184"},"text":"94 Stat. 1184","children":[],"tail":", known as the Agricultural Subterminal Facilities Act of 1980, which enacted this chapter and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1932"},"text":"section 1932 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3701"},"text":"section 3701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefaef57b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefaef57c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/358/s6"},"text":"section 6 of Pub. L. 96–358","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3701"},"text":"section 3701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
