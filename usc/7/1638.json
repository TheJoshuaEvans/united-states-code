{"tag":"section","attrib":{"id":"ideedf7034-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638"},"text":null,"children":[{"tag":"num","attrib":{"value":"1638"},"text":"§ 1638.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf7035-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered commodity","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf7036-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered commodity” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedf7037-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" muscle cuts of lamb and venison;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf7038-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ground lamb and ground venison;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf7039-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" farm-raised fish;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf703a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wild fish;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf703b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a perishable agricultural commodity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf703c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" peanuts; and ","children":[{"tag":"ref","attrib":{"idref":"fn002189"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002189"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf703d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/1/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meat produced from goats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf703e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/1/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chicken, in whole and in part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf703f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/1/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ginseng;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf7040-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/1/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pecans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf7041-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/1/A/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" macadamia nuts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7042-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered commodity” does not include an item described in subparagraph (A) if the item is an ingredient in a processed food item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7043-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm-raised fish","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “farm-raised fish” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf7044-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" farm-raised shellfish; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7045-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fillets, steaks, nuggets, and any other flesh from a farm-raised fish or shellfish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7046-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food service establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “food service establishment” means a restaurant, cafeteria, lunch room, food stand, saloon, tavern, bar, lounge, or other similar facility operated as an enterprise engaged in the business of selling food to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7047-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lamb","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “lamb” means meat, other than mutton, produced from sheep.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7048-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Perishable agricultural commodity; retailer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “perishable agricultural commodity” and “retailer” have the meanings given the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s499a/b"},"text":"section 499a(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7049-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture, acting through the Agricultural Marketing Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf704a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Wild fish","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf704b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wild fish” means naturally-born or hatchery-raised fish and shellfish harvested in the wild.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf704c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wild fish” includes a fillet, steak, nugget, and any other flesh from wild fish or shellfish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf704d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “wild fish” excludes net-pen aquacultural or other farm-raised fish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedf704e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 281, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10816"},"text":"Pub. L. 107–171, title X, § 10816","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/533"},"text":"116 Stat. 533","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXI/s11002/1"},"text":"Pub. L. 110–234, title XI, § 11002(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1351"},"text":"112 Stat. 1351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XI, § 11002(1), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat