{"tag":"section","attrib":{"id":"idee14ccd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138e"},"text":null,"children":[{"tag":"num","attrib":{"value":"138e"},"text":"§ 138e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee14ccd7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each laboratory or individual that performs, brokers, or otherwise arranges for the performance of a pesticide chemical analysis of food shall prepare and submit a report, simultaneously to the Secretary, the Secretary of Health and Human Services, and to the owner of such food, that shall contain any finding of pesticide chemical residues in such food—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee14ccd8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which no chemical residue tolerance or exemption has been established;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee14ccd9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is in excess of residue tolerances; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee14ccda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the chemical residue tolerance has been revoked or the chemical residue is otherwise not permitted by the Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee14ccdb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A laboratory shall submit the report required under subsection (a) to the Secretary, the Secretary of Health and Human Services, and the owner of such food as soon as practicable after the completion of the analysis of such food.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee14ccdc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall adopt standardized reporting guidelines to be applied to laboratories under this section and shall provide such guidelines to laboratories accredited under this chapter, as well as other sources of information regarding applicable pesticide chemical tolerances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee14ccdd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIII/s1326"},"text":"Pub. L. 101–624, title XIII, § 1326","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3565"},"text":"104 Stat. 3565","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
