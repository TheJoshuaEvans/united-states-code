{"tag":"section","attrib":{"id":"idf04eb7f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9058"},"text":null,"children":[{"tag":"num","attrib":{"value":"9058"},"text":"§ 9058.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of failure to pay administrative fees or premiums","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04eb7fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9058/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss of benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A participating dairy operation that fails to pay the required annual administrative fee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9054"},"text":"section 9054 of this title","children":[],"tail":" or is in arrears on premium payments under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9057"},"text":"section 9057 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb7fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9058/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remains legally obligated to pay the administrative fee or premiums, as the case may be; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb7fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9058/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not receive dairy margin coverage payments until the fees or premiums are fully paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb7fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9058/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may take such action as necessary to collect administrative fees and premium payments for participation in dairy margin coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04eb7fe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1408"},"text":"Pub. L. 113–79, title I, § 1408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/693"},"text":"128 Stat. 693","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1401/k/9"},"text":"Pub. L. 115–334, title I, § 1401(k)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4517"},"text":"132 Stat. 4517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04eb7ff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04eb800-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04eb801-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/9/A"},"text":"Pub. L. 115–334, § 1401(k)(9)(A)","children":[],"tail":", substituted “dairy margin coverage” for “margin protection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/9/B"},"text":"Pub. L. 115–334, § 1401(k)(9)(B)","children":[],"tail":", substituted “dairy margin coverage” for “the margin protection program”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf04eb802-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf04eb803-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/m"},"text":"section 1401(m) of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9051"},"text":"section 9051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
