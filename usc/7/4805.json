{"tag":"section","attrib":{"id":"idefbf9645-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4805"},"text":null,"children":[{"tag":"num","attrib":{"value":"4805"},"text":"§ 4805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and issuance of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbf9646-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4805/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Necessary findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for public comment have been provided in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4804"},"text":"section 4804 of this title","children":[],"tail":", the Secretary shall issue and publish an order if the Secretary finds, and sets forth in such order, that the issuance of such order and all terms and conditions thereof will assist in carrying out this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9647-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4805/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of orders in effect at a time","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than one order may be in effect at a time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9648-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4805/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order shall become effective on a date that is not more than 90 days following the publication of such order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9649-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4805/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order shall contain such terms and conditions as are required in sections 4806 through 4809 of this title and, except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4810"},"text":"section 4810 of this title","children":[],"tail":", no others."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbf964a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1616"},"text":"Pub. L. 99–198, title XVI, § 1616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1609"},"text":"99 Stat. 1609","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbf964b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefbf964c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefbf964d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1631"},"text":"section 1631 of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4801"},"text":"section 4801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
