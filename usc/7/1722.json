{"tag":"section","attrib":{"id":"ideee90c8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722"},"text":null,"children":[{"tag":"num","attrib":{"value":"1722"},"text":"§ 1722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of agricultural commodities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideee90c8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Administrator may provide agricultural commodities to meet emergency food needs under this subchapter through governments and public or private agencies, including intergovernmental organizations such as the World Food Program and other multilateral organizations, in such manner and on such terms and conditions as the Administrator determines appropriate to respond to the emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee90c8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonemergency assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee90c90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may provide agricultural commodities for nonemergency assistance under this subchapter through eligible organizations (as described in subsection (d)) that have entered into an agreement with the Administrator to use the commodities in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90c91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may not use as a sole rationale for denying a request for funds submitted under this subsection because the program for which the funds are requested—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee90c92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be carried out by the eligible organization in a foreign country in which the Agency for International Development does not have a mission, office, or other presence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee90c93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not part of a development plan for the country prepared by the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90c94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program diversity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee90c95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage eligible organizations to propose and implement program plans to address 1 or more aspects of the program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1721"},"text":"section 1721 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee90c96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider proposals that incorporate a variety of program objectives and strategic plans based on the identification by eligible organizations of appropriate activities, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1721"},"text":"section 1721 of this title","children":[],"tail":", to assist development of foreign countries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee90c97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Agricultural commodities provided under this subchapter may be made available for direct distribution, sale, barter, or other appropriate disposition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee90c98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible organizations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive assistance under subsection (b) an organization shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee90c99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private voluntary organization or cooperative that is, to the extent practicable, registered with the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90c9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intergovernmental organization, such as the World Food Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee90c9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for eligible organizations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee90c9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds made available in each fiscal year under this subchapter to the Administrator, not less than 7.5 percent nor more than 20 percent of the funds shall be made available in each fiscal year to eligible organizations described in subsection (d), to assist the organizations in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee90c9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and enhancing programs under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee90c9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meeting specific administrative, management, personnel, transportation, storage, and distribution costs for carrying out programs in foreign countries under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee90c9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing income-generating, community development, health, nutrition, cooperative development, agricultural, and other developmental activities within 1 or more recipient countries or within 1 or more countries in the same region; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee90ca0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving and implementing methodologies for food aid programs, including needs assessments (upon the request of the Administrator), monitoring, and evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90ca1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To receive funds made available under paragraph (1), an eligible organization described in subsection (d) shall submit a request for the funds that is subject to approval by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90ca2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance with respect to sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of an eligible organization, the Administrator may provide assistance to the eligible organization with respect to the sale of agricultural commodities made available to it under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90ca3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible organization that receives funds made available under paragraph (1) may invest the funds pending the eligible organization’s use of the funds. Any interest earned on such investment may be used for the purposes for which the assistance was provided to the eligible organization without further appropriation by Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee90ca4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective use of commodities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure that agricultural commodities made available under this subchapter are used effectively and in the areas of greatest need, organizations or cooperatives through which such commodities are distributed shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee90ca5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent feasible, work with indigenous institutions and employ indigenous workers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90ca6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess and take into account nutritional and other needs of beneficiary groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90ca7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help such beneficiary groups design and carry out mutually acceptable projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90ca8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend to the Administrator methods of making assistance available that are the most appropriate for each local setting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90ca9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervise the distribution of commodities provided and the implementation of programs carried out under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90caa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically evaluate the effectiveness of projects undertaken under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee90cab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labeling of assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Agricultural commodities and other assistance provided under this subchapter shall, to the extent practicable, be clearly identified with appropriate markings on the package or container of such agricultural commodities or food procured outside of the United States, or on printed material that accompanies other assistance, in the language of the locality in which such commodities and other assistance are distributed, as being furnished by the people of the United States of America.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee90cac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food aid quality","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee90cad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall use funds made available for fiscal year 2014 and subsequent fiscal years to carry out this subchapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee90cae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess the types and quality of agricultural commodities and products donated for food aid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee90caf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to adjust products and formulations, including potential introduction of new fortificants and products, as necessary to cost-effectively meet nutrient needs of target populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee90cb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to test prototypes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee90cb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/h/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to adopt new specifications or improve existing specifications for micronutrient fortified food aid products, based on the latest developments in food and nutrition science, and in coordination with other international partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee90cb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/h/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop new program guidance to facilitate improved matching of products to purposes having nutritional intent, in coordination with other international partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee90cb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/h/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop improved guidance for implementing partners on how to address nutritional deficiencies that emerge among recipients for whom food assistance is the sole source of diet in emergency programs that extend beyond 1 year, in coordination with other international partners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee90cb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/h/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate, in appropriate settings and as necessary, the performance and cost-effectiveness of new or modified specialized food products and program approaches designed to meet the nutritional needs of the most vulnerable groups, such as pregnant and lactating mothers, and children under the age of 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90cb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee90cb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall carry out this subsection in consultation with and through independent entities with proven expertise in food aid commodity quality enhancements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee90cb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into contracts to obtain the services of such entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee90cb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consult with the Food Aid Consultative Group on how to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee90cb9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1722/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1726a/f"},"text":"section 1726a(f) of this title","children":[],"tail":","},{"tag":"ref","attrib":{"idref":"fn002194"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002194"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" for fiscal years 2014 through 2023, not more than $4,500,000 may be used to carry out this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideee90cba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title II, § 202, "},{"tag":"ref","attrib":{"href":"/us/stat/68/458"},"text":"68 Stat. 458","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/86/472"},"text":"Pub. L. 86–472","children":[],"tail":", ch. VI, § 601(a)(1), "},{"tag":"date","attrib":{"date":"1960-05-14"},"text":"May 14, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/140"},"text":"74 Stat. 140","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/205"},"text":"Pub. L. 88–205","children":[],"tail":", pt. IV, § 403(d), "},{"tag":"date","attrib":{"date":"1963-12-16"},"text":"Dec. 16, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/390"},"text":"77 Stat. 390","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s2/C"},"text":"Pub. L. 89–808, § 2(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-11"},"text":"Nov. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1534"},"text":"80 Stat. 1534","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/88/tII"},"text":"Pub. L. 95–88, title II","children":[],"tail":", §§ 207, 208(a), "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/547"},"text":"91 Stat. 547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/tI/s121"},"text":"Pub. L. 96–53, title I, § 121","children":[],"tail":", title II, § 202, "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/366"},"text":"93 Stat. 366","children":[],"tail":", 368; "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tX"},"text":"Pub. L. 99–83, title X","children":[],"tail":", §§ 1003, 1004(a), 1005, "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/270"},"text":"99 Stat. 270","children":[],"tail":", 271; "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s11"},"text":"Pub. L. 100–202, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-448"},"text":"101 Stat. 1329–448","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tI/s1204/b/1"},"text":"Pub. L. 101–508, title I, § 1204(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-11"},"text":"104 Stat. 1388–11","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3636"},"text":"104 Stat. 3636","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s207/a"},"text":"Pub. L. 104–127, title II, § 207(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/953"},"text":"110 Stat. 953","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIII/s3002"},"text":"Pub. L. 107–171, title III, § 3002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/280"},"text":"116 Stat. 280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3008"},"text":"Pub. L. 110–246, title III, § 3008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1823"},"text":"122 Stat. 1823","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIII"},"text":"Pub. L. 113–79, title III","children":[],"tail":", §§ 3002, 3003, "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/773"},"text":"128 Stat. 773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII"},"text":"Pub. L. 115–334, title III","children":[],"tail":", §§ 3101, 3102, "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4603"},"text":"132 Stat. 4603","children":[],"tail":", 4604.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideee90cbb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideee90cbc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideee90cbd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3101"},"text":"Pub. L. 115–334, § 3101","children":[],"tail":", amended subsec. (g) generally. Prior to amendment, text read as follows: “Commodities provided under this subchapter shall, to the extent practicable, be clearly identified with appropriate markings on the package or container of such commodity in the language of the locality in which such commodities are distributed, as being furnished by the people of the United States of America.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3102"},"text":"Pub. L. 115–334, § 3102","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3002/1/A"},"text":"Pub. L. 113–79, § 3002(1)(A)","children":[],"tail":", substituted “20 percent” for “13 percent” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3002/1/B"},"text":"Pub. L. 113–79, § 3002(1)(B)","children":[],"tail":", substituted “and enhancing” for “new”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(B) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3002/1/C"},"text":"Pub. L. 113–79, § 3002(1)(C)","children":[],"tail":"–(E), added subpars. (B) and (C), redesignated former subpar. (C) as (D), and struck out former subpar. (B). Prior to amendment, subpar. (B) read as follows: “meeting specific administrative, management, personnel and internal transportation and distribution costs for carrying out programs in foreign countries under this subchapter; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3002/2"},"text":"Pub. L. 113–79, § 3002(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3003/1"},"text":"Pub. L. 113–79, § 3003(1)","children":[],"tail":", added par. (1) and struck out former par. (1). Prior to amendment, text read as follows: “The Administrator shall use funds made available for fiscal year 2009 and subsequent fiscal years to carry out this subchapter—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) to assess the types and quality of agricultural commodities and products donated for food aid;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) to adjust products and formulations (including the potential introduction of new fortificants and products) as necessary to cost-effectively meet nutrient needs of target populations; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) to test prototypes.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3003/2"},"text":"Pub. L. 113–79, § 3003(2)","children":[],"tail":", substituted “fiscal years 2014 through 2018” for “fiscal years 2009 through 2011”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3008/1"},"text":"Pub. L. 110–246, § 3008(1)","children":[],"tail":", substituted “may not use as a sole rationale for denying a request for funds” for “may not deny a request for funds” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3008/2/A"},"text":"Pub. L. 110–246, § 3008(2)(A)","children":[],"tail":", substituted “not less than 7.5 percent nor more than 13 percent” for “not less than 5 percent nor more than 10 percent” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3008/2/B"},"text":"Pub. L. 110–246, § 3008(2)(B)","children":[],"tail":"–(D), added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3008/3"},"text":"Pub. L. 110–246, § 3008(3)","children":[],"tail":", added subsec. (h) and struck out former subsec. (h) which required Administrator to streamline program procedures and guidelines not later than 1 year after "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", and incorporate changes, to the maximum extent practicable, beginning in fiscal year 2004."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3002/1"},"text":"Pub. L. 107–171, § 3002(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3002/2"},"text":"Pub. L. 107–171, § 3002(2)","children":[],"tail":", substituted “not less than 5 percent nor more than 10 percent of the funds” for “not less than $10,000,000, and not more than $28,000,000,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3002/3"},"text":"Pub. L. 107–171, § 3002(3)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s207/a/1"},"text":"Pub. L. 104–127, § 207(a)(1)","children":[],"tail":", added subsec. (b) and struck out heading and text of former subsec. (b). Text read as follows: “The Administrator may provide agricultural commodities for non-emergency assistance under this subchapter through eligible organizations (as described in subsection (d) of this section) that have entered into an agreement with the Administrator to use such commodities in accordance with this subchapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s207/a/2/A"},"text":"Pub. L. 104–127, § 207(a)(2)(A)","children":[],"tail":", substituted “eligible organizations” for “private voluntary organizations and cooperatives” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s207/a/2/B"},"text":"Pub. L. 104–127, § 207(a)(2)(B)","children":[],"tail":", in introductory provisions, substituted “$28,000,000” for “$13,500,000” and “eligible organizations described in subsection (d), to assist the organizations” for “private voluntary organizations and cooperatives to assist such organizations and cooperatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s207/a/2/C"},"text":"Pub. L. 104–127, § 207(a)(2)(C)","children":[],"tail":", added par. (2) and struck out heading and text of former par. (2). Text read as follows: “In order to receive funds made available under paragraph (1), a private voluntary organization or cooperative must submit a request for such funds (which must be approved by the Administrator) when submitting a proposal to the Administrator for an agreement under this subchapter. Such request for funds shall include a specific explanation of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the program costs to be offset by such funds;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the reason why such funds are needed in carrying out the particular assistance program; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) the degree to which such funds will improve the provision of food assistance to foreign countries (particularly those in sub-Saharan Africa suffering from acute, long-term food shortages).”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s207/a/2/D"},"text":"Pub. L. 104–127, § 207(a)(2)(D)","children":[],"tail":", substituted “an eligible organization, the Administrator may provide assistance to the eligible organization” for “a private voluntary organization or cooperative, the Administrator may provide assistance to that organization or cooperative”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section generally, substituting present provisions for provisions relating to furnishing commodities through friendly governments, agencies, and organizations, assistance for community and other self-help activities, and multiyear agreements for distribution of commodities through nonprofit voluntary agencies and cooperatives."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":", in introductory provisions, substituted “the Administrator, not less than $10,000,000, and not more than $13,500,000, shall be made available in each fiscal year to private voluntary organizations and cooperatives” for “private voluntary organizations and cooperatives, not less than $10,000,000 and not more than $13,500,000 shall be made available by the Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" inserted “or cooperatives” after “voluntary agencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1003"},"text":"Pub. L. 99–83, § 1003","children":[],"tail":", inserted provisions relating to appropriate disposition under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1721"},"text":"section 1721 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1004/a"},"text":"Pub. L. 99–83, § 1004(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/83/s1005"},"text":"Pub. L. 99–83, § 1005","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53/s121"},"text":"Pub. L. 96–53, § 121","children":[],"tail":", substituted “Agency for International Development” for “Advisory Committee on Voluntary Foreign Aid”, and “Advisory Committee” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53/s202"},"text":"Pub. L. 96–53, § 202","children":[],"tail":", substituted provisions relating to encouragement of entities distributing commodities to work with indigenous institutions and to employ indigenous workers, for provisions relating to employment of indigenous workers."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88"},"text":"Pub. L. 95–88","children":[],"tail":", §§ 207(1), (2), 208(a), designated existing provisions as subsec. (a), struck out requirement that assistance to needy persons, insofar as practicable, be directed toward community and other self-help activities designed to alleviate the causes of the need for such assistance, and inserted provisions authorizing the President to utilize a foreign nonprofit voluntary agency which is registered with and approved by the Advisory Committee on Voluntary Foreign Aid if no United States nonprofit voluntary agency registered with and approved by the Advisory Committee is available."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88/s207/3"},"text":"Pub. L. 95–88, § 207(3)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/808"},"text":"Pub. L. 89–808","children":[],"tail":" substituted provisions for furnishing commodities for prescribed purposes through use of friendly governments, agencies, and organizations, using to extent practicable registered and approved nonprofit voluntary agencies, identification of source of commodities, determination by the President of the manner and terms and conditions of furnishing the commodities and for directions of the assistance toward community and self-help activities for former provisions for transfer of commodities on a grant bases to assist the prescribed programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1963—","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/205"},"text":"Pub. L. 88–205","children":[],"tail":" substituted “economic and community development” for “economic developments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1960—","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/472"},"text":"Pub. L. 86–472","children":[],"tail":" substituted “In order to facilitate the utilization of surplus agricultural commodities in meeting the requirements of needy peoples, and in order to promote economic development in underdeveloped areas in addition to that which can be accomplished under sections 1701 to 1704 and 1705 to 1709 of this title, the” for “The”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideee90cbe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideee90cbf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effe