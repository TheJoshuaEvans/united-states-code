{"tag":"section","attrib":{"id":"idef8414ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2485"},"text":null,"children":[{"tag":"num","attrib":{"value":"2485"},"text":"§ 2485.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Correction of applicant’s mistake","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever a mistake of a clerical or typographical nature, or of minor character, or in the description of the variety, which was not the fault of the Plant Variety Protection Office, appears in a certificate of plant variety protection and a showing has been made that such mistake occurred in good faith, the Secretary may, upon payment of the required fee, issue a corrected certificate if the correction could have been made before the certificate issued. Such certificate of plant variety protection shall have the same effect and operation in law as if the same had been originally issued in such corrected form.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef8414f0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tII/s85"},"text":"Pub. L. 91–577, title II, § 85","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1552"},"text":"84 Stat. 1552","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/574/s16"},"text":"Pub. L. 96–574, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3351"},"text":"94 Stat. 3351","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8414f1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef8414f2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef8414f3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/574"},"text":"Pub. L. 96–574","children":[],"tail":" struck out applicability of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2484"},"text":"section 2484 of this title","children":[],"tail":" to manner and form of certificate, and reference to trials of actions thereafter arising with respect to effect and operation in law of certificate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
