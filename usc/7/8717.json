{"tag":"section","attrib":{"id":"idf03deeb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717"},"text":null,"children":[{"tag":"num","attrib":{"value":"8717"},"text":"§ 8717.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planting flexibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf03deeb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted crops","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), any commodity or crop may be planted on base acres on a farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03deeb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations regarding certain commodities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03deeb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The planting of an agricultural commodity specified in paragraph (3) shall be prohibited on base acres unless the commodity, if planted, is destroyed before harvest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deeb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of trees and other perennials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The planting of an agricultural commodity specified in paragraph (3) that is produced on a tree or other perennial plant shall be prohibited on base acres.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deeb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered agricultural commodities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraphs (1) and (2) apply to the following agricultural commodities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03deeb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fruits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deeb9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vegetables (other than mung beans and pulse crops).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deeba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wild rice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03deebb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraphs (1) and (2) of subsection (b) shall not limit the planting of an agricultural commodity specified in paragraph (3) of that subsection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03deebc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any region in which there is a history of double-cropping of covered commodities with agricultural commodities specified in subsection (b)(3), as determined by the Secretary, in which case the double-cropping shall be permitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deebd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a farm that the Secretary determines has a history of planting agricultural commodities specified in subsection (b)(3) on base acres, except that direct payments and counter-cyclical payments shall be reduced by an acre for each acre planted to such an agricultural commodity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deebe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by the producers on a farm that the Secretary determines has an established planting history of a specific agricultural commodity specified in subsection (b)(3), except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03deebf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity planted may not exceed the average annual planting history of such agricultural commodity by the producers on the farm in the 1991 through 1995 or 1998 through 2001 crop years (excluding any crop year in which no plantings were made), as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deec0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct payments and counter-cyclical payments shall be reduced by an acre for each acre planted to such agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03deec1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planting transferability pilot project","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03deec2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot project authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraphs (1) and (2) of subsection (b) and in addition to the exceptions provided in subsection (c), the Secretary shall carry out a pilot project to permit the planting of cucumbers, green peas, lima beans, pumpkins, snap beans, sweet corn, and tomatoes grown for processing on base acres during each of the 2009 through 2012 crop years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deec3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot project States and acres","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The number of base acres eligible during each crop year for the pilot project under paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03deec4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 9,000 acres in the State of Illinois;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deec5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 9,000 acres in the State of Indiana;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deec6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1,000 acres in the State of Iowa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deec7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 9,000 acres in the State of Michigan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deec8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 34,000 acres in the State of Minnesota;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deec9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4,000 acres in the State of Ohio; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deeca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 9,000 acres in the State of Wisconsin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deecb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract and management requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for selection to participate in the pilot project, the producers on a farm shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03deecc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate to the Secretary that the producers on the farm have entered into a contract to produce a crop of a commodity specified in paragraph (1) for processing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deecd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to produce the crop as part of a program of crop rotation on the farm to achieve agronomic and pest and disease management benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deece-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide evidence of the disposition of the crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deecf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary reduction in base acres","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The base acres on a farm for a crop year shall be reduced by an acre for each acre planted under the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deed0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of reductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reduction in the base acres of a farm for a crop year under paragraph (4) shall expire at the end of the crop year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deed1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recalculation of base acres","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03deed2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary recalculates base acres for a farm while the farm is included in the pilot project, the planting and production of a crop of a commodity specified in paragraph (1) on base acres for which a temporary reduction was made under this section shall be considered to be the same as the planting and production of a covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deed3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph provides authority for the Secretary to recalculate base acres for a farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deed4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot impact evaluation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03deed5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall periodically evaluate the pilot project conducted under this subsection to determine the effects of the pilot project on the supply and price of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03deed6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fresh fruits and vegetables; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03deed7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fruits and vegetables for processing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deed8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An evaluation under subparagraph (A) shall include a determination as to whether—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03deed9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" producers of fresh fruits and vegetables are being negatively impacted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03deeda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing production capacities are being supplanted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deedb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8717/d/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after conducting an evaluation under subparagraph (A), the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that describes the results of the evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf03deedc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1107"},"text":"Pub. L. 110–234, title I, § 1107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/950"},"text":"122 Stat. 950","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1107, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1679.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf03deedd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf03deede-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf03deedf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf03deee0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf03deee1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
