{"tag":"section","attrib":{"id":"ideef9aed4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738p"},"text":"§ 1738p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale, reduction, or cancellation of qualified debt to facilitate certain debt swaps","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef9aed5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to sell, reduce, or cancel qualified debt","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of facilitating eligible debt swaps, the President, in accordance with this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef9aed6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may sell to an eligible purchaser (as determined pursuant to subsection (c)(1)) any qualified debt of an eligible country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9aed7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may reduce or cancel eligible debt of an eligible country upon receipt of payment from an eligible payor (as determined under subsection (c)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aed8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish the terms and conditions under which qualified debt may be sold, reduced, or canceled pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aed9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible purchasers and eligible payors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef9aeda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sales of debt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Qualified debt may be sold pursuant to subsection (a)(1) only to a purchaser who presents plans satisfactory to the President for using the debt for the purpose of engaging in eligible debt swaps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9aedb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction or cancellation of debt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Qualified debt may be reduced or cancelled pursuant to subsection (a)(2) only if the payor presents plans satisfactory to the President for using such reduction or cancellation for the purpose of facilitating eligible debt swaps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aedc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debtor consultation and right of first refusal","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef9aedd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before selling, reducing, or canceling any qualified debt of an eligible country pursuant to this section, the President should consult with that country concerning, among other things, the amount of debt to be sold, reduced, or canceled and the uses of such debt for eligible debt swaps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9aede-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of first refusal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The qualified debt of an eligible country may be sold, reduced, or cancelled pursuant to this section only if that country has been offered the opportunity to purchase that debt pursuant to section 1738","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title and has not accepted that offer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aedf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the aggregate, not more than 40 percent of the qualified debt of an eligible country may be sold, reduced, or cancelled under this section or sold under section 1738","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aee0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Facility shall notify the Commodity Credit Corporation of purchasers and payors the President has determined to be eligible under subsection (c), and shall direct the corporation to carry out the sale, reduction, or cancellation of a qualified debt pursuant to this section. The Commodity Credit Corporation shall make an adjustment in its accounts to reflect such sale, reduction, or cancellation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aee1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorities provided by this section may be exercised only in such amounts and to such extent as is provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aee2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proceeds from the sale, reduction, or cancellation of qualified debt pursuant to this section shall be deposited in the United States Government account or accounts established for the repayment of such debt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aee3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738p/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible debt swaps","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As used in this section, the term “eligible debt swap” means a debt-for-development swap or debt-for-nature swap.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef9aee4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title VI, § 617, as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/532/s2"},"text":"Pub. L. 102–532, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3510"},"text":"106 Stat. 3510","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
