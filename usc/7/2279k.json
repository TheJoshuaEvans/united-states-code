{"tag":"section","attrib":{"id":"idef7f3326-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279k"},"text":"§ 2279k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of protection operations for the Secretary of Agriculture and others","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7f3327-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Department of Agriculture is authorized to employ qualified law enforcement officers or special agents to provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f3328-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection for the Secretary and the Deputy Secretary during the performance of official duties by each such officer and during any activity that is preliminary or postliminary to the performance of official duties by each such officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f3329-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection, incidental to the protection provided pursuant to paragraph (1), to an individual accompanying each such officer who is participating in an activity or event relating to the official duties of each such officer when there is an articulable threat to such individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a32a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuous protection to the Secretary and Deputy Secretary (including during periods not described in paragraph (1)) if there is an articulable threat of physical harm, in accordance with guidelines established by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a32b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection of another senior officer representing the Secretary (including a person nominated to be the Secretary during the pendency of such nomination) if there is an articulable threat of physical harm, in accordance with guidelines established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef81a32c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities of the protective operation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef81a32d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may authorize officers or special agents employed pursuant to subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef81a32e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry firearms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef81a32f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct criminal investigations into potential threats to the security of persons protected under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef81a330-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make arrests without a warrant for any offense against the United States committed in the presence of such officer or special agent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef81a331-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perform protective intelligence work, including identifying and mitigating potential threats and conducting advance work to review security matters relating to sites and events; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef81a332-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate with local law enforcement agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a333-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority conveyed under this section shall be exercised in accordance with any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef81a334-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines issued by the Attorney General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef81a335-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional guidelines as may be issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef81a336-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authorities granted under this section may be exercised notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1343/b/1"},"text":"section 1343(b)(1) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef81a337-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2019-09-30"},"text":"September 30, 2019","children":[],"tail":", and each September 30 through 2024, the Secretary shall provide to the Committee on Agriculture of the House of Representatives and Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing the protection provided, and accounting for the expenditures made, pursuant to this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef81a338-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12520"},"text":"Pub. L. 115–334, title XII, § 12520","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5001"},"text":"132 Stat. 5001","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef81a339-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef81a33a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idef81a33b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” means the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2"},"text":"section 2 of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
