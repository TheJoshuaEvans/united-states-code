:"1990—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/577"},"text":"Pub. L. 101–577","children":[],"tail":" added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/180"},"text":"Pub. L. 98–180","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/524"},"text":"Pub. L. 91–524","children":[],"tail":" temporarily inserted provision that term “acreage allotments” include the farm base acreage allotments for upland cotton and the domestic allotment for wheat. See Effective and Termination Dates of 1970 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee90daf0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee90daf1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" applicable to the 2005 and subsequent crops of tobacco, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s643"},"text":"section 643 of Pub. L. 108–357","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s518"},"text":"section 518 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee90daf2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"hea