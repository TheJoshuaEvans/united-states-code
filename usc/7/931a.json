{"tag":"section","attrib":{"id":"idee5c5d3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s931a"},"text":null,"children":[{"tag":"num","attrib":{"value":"931a"},"text":"§ 931a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Level of loan programs under Rural Electrification and Telephone Revolving Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":", no funds in this Act or any other Act shall be available to carry out loan programs under the Rural Electrification and Telephone Revolving Fund at levels other than those provided for in advance in appropriations Acts."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee5c5d3e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/142/tIII"},"text":"Pub. L. 102–142, title III","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/903"},"text":"105 Stat. 903","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee5c5d3f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee5c5d40-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee5c5d41-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agriculture, Rural Development, Food and Drug Administration, and Related Agencies Appropriations Act, 1992, and not as part of the Rural Electrification Act of 1936 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
