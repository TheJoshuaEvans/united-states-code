{"tag":"section","attrib":{"id":"idee6cfeaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1031"},"text":null,"children":[{"tag":"num","attrib":{"value":"1031"},"text":"§ 1031.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conveyance of mineral rights with land","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any conveyance of real estate by the Government or any Government agency under this Act shall include all mineral rights.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee6cfeab-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch964/s9"},"text":"Aug. 14, 1946, ch. 964, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/1080"},"text":"60 Stat. 1080","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee6cfeac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee6cfead-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee6cfeae-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch964"},"text":"act Aug. 14, 1946, ch. 964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/1062"},"text":"60 Stat. 1062","children":[],"tail":", known as the Farmers’ Home Administration Act of 1946. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee6cfeaf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Farmers’ Home Administration Act of 1946, and not as part of the Bankhead-Jones Farm Tenant Act which constitutes a major part of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idee6cfeb0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idee6cfeb1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of all officers, agencies, and employees of Department of Agriculture transferred, with certain exceptions, to Secretary of Agriculture by 1953 Reorg. Plan No. 2, § 1, eff. ","children":[{"tag":"date","attrib":{"date":"1953-06-04"},"text":"June 4, 1953","children":[],"tail":", 18 F.R. 3219, "},{"tag":"ref","attrib":{"href":"/us/stat/67/633"},"text":"67 Stat. 633","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
