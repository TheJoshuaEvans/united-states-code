{"tag":"section","attrib":{"id":"idef0cc0cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1930"},"text":null,"children":[{"tag":"num","attrib":{"value":"1930"},"text":"§ 1930.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued availability of appropriated funds for direct real estate loans to farmers and ranchers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds appropriated for the purpose of making direct real estate loans to farmers and ranchers under this subchapter shall remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef0cc0d0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s310"},"text":"Pub. L. 87–128, title III, § 310","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/91/524/tVIII/s806/b"},"text":"Pub. L. 91–524, title VIII, § 806(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-11-30"},"text":"Nov. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1383"},"text":"84 Stat. 1383","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
