":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s10502/b/1"},"text":"Pub. L. 107–171, § 10502(b)(1)","children":[],"tail":", substituted “packer or swine contractor” for “packer” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s10502/b/2/A"},"text":"Pub. L. 107–171, § 10502(b)(2)(A)","children":[],"tail":", inserted “, swine contractor,” after “other packer” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78"},"text":"Pub. L. 106–78","children":[],"tail":", §§ 912, 942, temporarily struck out “whatsoever” after “locality in any respect” and after “disadvantage in any respect”. See Termination Date of 1999 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted a comma for period after second reference to “dealer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/173/s3/1"},"text":"Pub. L. 100–173, § 3(1)","children":[],"tail":", substituted “for any packer with respect to livestock, meats, meat food products, or livestock products in unmanufactured form, or for any live poultry dealer with respect to live poultry, to” for “with respect to livestock, meats, meat food products, livestock products in unmanufactured form, poultry, or poultry products for any packer or any live poultry dealer or handler to” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/173/s3/2"},"text":"Pub. L. 100–173, § 3(2)","children":[],"tail":", struck out reference to poultry handlers wherever appearing and substituted “such persons” for “such packers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/410"},"text":"Pub. L. 94–410","children":[],"tail":" struck out “in commerce” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/909"},"text":"Pub. L. 85–909","children":[],"tail":" inserted “with respect to livestock, meats, meat food products, livestock products in unmanufactured form, poultry, or poultry products” after “unlawful”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1935—Act ","children":[{"tag":"date","attrib":{"date":"1921-08-15"},"text":"Aug. 15, 1921","children":[],"tail":", title V, § 503, as added "},{"tag":"date","attrib":{"date":"1935-08-14"},"text":"Aug. 14, 1935","children":[],"tail":", inserted “or any live poultry dealer or handler” after “packer” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee1bf85c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"idee1bf85d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78"},"text":"Pub. L. 106–78","children":[],"tail":" to terminate "},{"tag":"date","attrib":{"date":"2025-03-14"},"text":"Mar. 14, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/s942"},"text":"section 942 of Pub. L. 106–78","children":[],"tail":", set out in a Livestock Mandatory Reporting note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1635"},"text":"section 1635 of this title","children":[],"tail":"."}],"ta