{"tag":"section","attrib":{"id":"idee1bf84f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s192"},"text":null,"children":[{"tag":"num","attrib":{"value":"192"},"text":"§ 192.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful practices enumerated","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any packer or swine contractor with respect to livestock, meats, meat food products, or livestock products in unmanufactured form, or for any live poultry dealer with respect to live poultry, to:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee1bf850-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s192/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Engage in or use any unfair, unjustly discriminatory, or deceptive practice or device; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf851-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s192/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Make or give any undue or unreasonable preference or advantage to any particular person or locality in any respect, or subject any particular person or locality to any undue or unreasonable prejudice or disadvantage in any respect; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf852-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s192/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sell or otherwise transfer to or for any other packer, swine contractor, or any live poultry dealer, or buy or otherwise receive from or for any other packer, swine contractor, or any live poultry dealer, any article for the purpose or with the effect of apportioning the supply between any such persons, if such apportionment has the tendency or effect of restraining commerce or of creating a monopoly; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf853-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s192/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sell or otherwise transfer to or for any other person, or buy or otherwise receive from or for any other person, any article for the purpose or with the effect of manipulating or controlling prices, or of creating a monopoly in the acquisition of, buying, selling, or dealing in, any article, or of restraining commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf854-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s192/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Engage in any course of business or do any act for the purpose or with the effect of manipulating or controlling prices, or of creating a monopoly in the acquisition of, buying, selling, or dealing in, any article, or of restraining commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf855-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s192/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conspire, combine, agree, or arrange with any other person (1) to apportion territory for carrying on business, or (2) to apportion purchases or sales of any article, or (3) to manipulate or control prices; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf856-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s192/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conspire, combine, agree, or arrange with any other person to do, or aid or abet the doing of, any act made unlawful by subdivisions (a), (b), (c), (d), or (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee1bf857-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title II, § 202, "},{"tag":"ref","attrib":{"href":"/us/stat/42/161"},"text":"42 Stat. 161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title V, § 503, as added "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch532"},"text":"Aug. 14, 1935, ch. 532","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/649"},"text":"49 Stat. 649","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/909/s1/1"},"text":"Pub. L. 85–909, § 1(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1749"},"text":"72 Stat. 1749","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/410/s3/a"},"text":"Pub. L. 94–410, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-13"},"text":"Sept. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1249"},"text":"90 Stat. 1249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/173/s3"},"text":"Pub. L. 100–173, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-23"},"text":"Nov. 23, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/917"},"text":"101 Stat. 917","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1008/1"},"text":"Pub. L. 102–237, title X, § 1008(1