{"tag":"section","attrib":{"id":"idee50769a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–4"},"text":null,"children":[{"tag":"num","attrib":{"value":"612c–4"},"text":"§ 612c–4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of specialty crops","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee50769b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–4/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General purchase authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"section 612c of this title","children":[],"tail":", for fiscal year 2002 and each subsequent fiscal year, the Secretary of Agriculture shall use not less than $200,000,000 each fiscal year to purchase fruits, vegetables, and other specialty food crops."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee50769c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–4/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of fresh fruits and vegetables for distribution to schools and service institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall purchase fresh fruits and vegetables for distribution to schools and service institutions in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1755/a"},"text":"section 1755(a) of title 42","children":[],"tail":" using, of the amount specified in subsection (a), not less than $50,000,000 for each of fiscal years 2008 through 2023."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"t