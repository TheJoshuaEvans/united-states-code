{"tag":"section","attrib":{"id":"idefe82cdf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518"},"text":null,"children":[{"tag":"num","attrib":{"value":"6518"},"text":"§ 6518.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Organic Standards Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe82ce0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a National Organic Standards Board (hereafter referred to in this section as the “Board”) in accordance with chapter 10 of title 5 to assist in the development of standards for substances to be used in organic production and to advise the Secretary on any other aspects of the implementation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82ce1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be composed of 15 members, of which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82ce2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" four shall be individuals who own or operate an organic farming operation, or employees of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82ce3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two shall be individuals who own or operate an organic handling operation, or employees of such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82ce4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be an individual who owns or operates a retail establishment with significant trade in organic products, or an employee of such individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82ce5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three shall be individuals with expertise in areas of environmental protection and resource conservation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82ce6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three shall be individuals who represent public interest or consumer interest groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82ce7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be an individual with expertise in the fields of toxicology, ecology, or biochemistry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82ce8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one shall be an individual who is a certifying agent as identified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6515"},"text":"section 6515 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82ce9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", the Secretary shall appoint the members of the Board under paragraph (1) through (6) of subsection (b) (and under subsection (b)(7) at an appropriate date after the certification of individuals as certifying agents under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6515"},"text":"section 6515 of this title","children":[],"tail":") from nominations received from organic certifying organizations, States, and other interested persons and organizations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82cea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board shall serve for a term of 5 years, except that the Secretary shall appoint the original members of the Board for staggered terms. A member cannot serve consecutive terms unless such member served an original term that was less than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82ceb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall convene a meeting of the Board not later than 60 days after the appointment of its members and shall convene subsequent meetings on a periodic basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82cec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board shall serve without compensation. While away from their homes or regular places of business on the business of the Board, members of the Board may be allowed travel expenses, including per diem in lieu of subsistence, as is authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":" for persons employed intermittently in the Government service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82ced-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall select a Chairperson for the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82cee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quorum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A majority of the members of the Board shall constitute a quorum for the purpose of conducting business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82cef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decisive votes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82cf0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"⅔ of the votes cast at a meeting of the Board at which a quorum is present shall be decisive of any motion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82cf1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National list","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vote on a motion proposing to amend the national list shall be considered to be a decisive vote that requires ⅔ of the votes cast at a meeting of the Board at which a quorum is present to prevail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82cf2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall authorize the Board to hire a staff director and shall detail staff of the Department of Agriculture or allow for the hiring of staff and may, subject to necessary appropriations, pay necessary expenses incurred by such Board in carrying out the provisions of this chapter, as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82cf3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82cf4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall provide recommendations to the Secretary regarding the implementation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82cf5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National List","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall develop the proposed National List or proposed amendments to the National List for submission to the Secretary in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6517"},"text":"section 6517 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82cf6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical advisory panels","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall convene technical advisory panels to provide scientific evaluation of the materials considered for inclusion in the National List. Such panels may include experts in agronomy, entomology, health sciences and other relevant disciplines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82cf7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/k/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special review of botanical pesticides","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall, prior to the establishment of the National List, review all botanical pesticides used in agricultural production and consider whether any such botanical pesticide should be included in the list of prohibited natural substances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82cf8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/k/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Product residue testing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall advise the Secretary concerning the testing of organically produced agricultural products for residues caused by unavoidable residual environmental contamination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82cf9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/k/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency spray programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall advise the Secretary concerning rules for exemptions from specific requirements of this chapter (except the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6511"},"text":"section 6511 of this title","children":[],"tail":") with respect to agricultural products produced on certified organic farms if such farms are subject to a Federal or State emergency pest or disease treatment program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82cfa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the proposed National List or proposed amendments to the National List, the Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82cfb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review available information from the Environmental Protection Agency, the National Institute of Environmental Health Studies, and such other sources as appropriate, concerning the potential for adverse human and environmental effects of substances considered for inclusion in the proposed National List;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82cfc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with manufacturers of substances considered for inclusion in the proposed National List to obtain a complete list of ingredients and determine whether such substances contain inert materials that are synthetically produced; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82cfd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary, along with the proposed National List or any proposed amendments to such list, the results of the Board’s evaluation and the evaluation of the technical advisory panel of all substances considered for inclusion in the National List.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82cfe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating substances considered for inclusion in the proposed National List or proposed amendment to the National List, the Board shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82cff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential of such substances for detrimental chemical interactions with other materials used in organic farming systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d00-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the toxicity and mode of action of the substance and of its breakdown products or any contaminants, and their persistence and areas of concentration in the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d01-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/m/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the probability of environmental contamination during manufacture, use, misuse or disposal of such substance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/m/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of the substance on human health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/m/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of the substance on biological and chemical interactions in the agroecosystem, including the physiological effects of the substance on soil organisms (including the salt index and solubility of the soil), crops and livestock;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/m/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the alternatives to using the substance in terms of practices or other available materials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/m/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its compatibility with a system of sustainable agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82d06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall establish procedures under which persons may petition the Board for the purpose of evaluating substances for inclusion on the National List.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82d07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6518/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any confidential business information obtained by the Board in carrying out this section shall not be released to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe82d08-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2119"},"text":"Pub. L. 101–624, title XXI, § 2119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3947"},"text":"104 Stat. 3947","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1001/7"},"text":"Pub. L. 102–237, title X, § 1001(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1893"},"text":"105 Stat. 1893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10104/e"},"text":"Pub. L. 115–334, title X, § 10104(e)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4901"},"text":"132 Stat. 4901","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/39"},"text":"Pub. L. 117–286, § 4(a)(39)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4309"},"text":"136 Stat. 4309","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe82d09-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe82d0a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe82d0b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"te