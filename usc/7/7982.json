{"tag":"section","attrib":{"id":"idf02adb7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982"},"text":null,"children":[{"tag":"num","attrib":{"value":"7982"},"text":"§ 7982.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National dairy market loss payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02adb80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adb81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Class I milk","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Class I milk” means milk (including milk components) classified as Class I milk under a Federal milk marketing order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible production","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible production” means milk produced by a producer in a participating State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal milk marketing order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal milk marketing order” means an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s608c"},"text":"section 608c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participating State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “participating State” means each State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “producer” means an individual or entity that directly or indirectly (as determined by the Secretary)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adb86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shares in the risk of producing milk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adb87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes contributions (including land, labor, management, equipment, or capital) to the dairy farming operation of the individual or entity that are at least commensurate with the share of the individual or entity of the proceeds of the operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adb88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall offer to enter into contracts with producers on a dairy farm located in a participating State under which the producers receive payments on eligible production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adb89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payments to a producer under this section shall be calculated by multiplying (as determined by the Secretary)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adb8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment quantity for the producer during the applicable month established under subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adb8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $16.94 per hundredweight; less","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adb8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Class I milk price per hundredweight in Boston under the applicable Federal milk marketing order; by","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adb8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the period beginning on the first day of the month the producers on a dairy farm enter into a contract under this section and ending on ","children":[{"tag":"date","attrib":{"date":"2005-09-30"},"text":"September 30, 2005","children":[],"tail":", 45 percent; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adb90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2005-10-01"},"text":"October 1, 2005","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":", 34 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adb91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment quantity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adb92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the payment quantity for a producer during the applicable month under this section shall be equal to the quantity of eligible production marketed by the producer during the month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The payment quantity for all producers on a single dairy operation during the months of the applicable fiscal year for which the producers receive payments under subsection (b) shall not exceed 2,400,000 pounds. For purposes of determining whether producers are producers on separate dairy operations or a single dairy operation, the Secretary shall apply the same standards as were applied in implementing the dairy program under section 805 of the Agriculture, Rural Development, Food and Drug Administration, and Related Agencies Appropriations Act, 2001 (as enacted into law by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387"},"text":"Public Law 106–387","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":"A–50)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconstitution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations to ensure that a producer does not reconstitute a dairy operation for the sole purpose of receiving additional payments under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adb95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A payment under a contract under this section shall be made on a monthly basis not later than 60 days after the last day of the month for which the payment is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adb96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Signup","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall offer to enter into contracts under this section during the period beginning on the date that is 60 days after ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adb97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of contract","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adb98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), any contract entered into by producers on a dairy farm under this section shall cover eligible production marketed by the producers on the dairy farm during the period starting with the first day of month the producers on the dairy farm enter into the contract and ending on ","children":[{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adb99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a producer violates the contract, the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adb9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate the contract and allow the producer to retain any payments received under the contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adb9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7982/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the contract to remain in effect and require the producer to repay a portion of the payments received under the contract based on the severity of the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02adb9c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1502"},"text":"Pub. L. 107–171, title I, § 1502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/205"},"text":"116 Stat. 205","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tI/s1101"},"text":"Pub. L. 109–171, title I, § 1101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/4"},"text":"120 Stat. 4","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/28/tIX/s9006/a"},"text":"Pub. L. 110–28, title IX, § 9006(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/217"},"text":"121 Stat. 217","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf02adb9d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf02adb9e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf02adb9f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 805 of the Agriculture, Rural Development, Food and Drug Administration, and Related Agencies Appropriations Act, 2001, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s805"},"text":"section 805 of Pub. L. 106–387","children":[],"tail":", § 1(a) [title VIII], "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–50, which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf02adba0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Pub. L. 110–28","children":[],"tail":" inserted “and” at end of subpar. (A), substituted “"},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":", 34 percent.” for “"},{"tag":"date","attrib":{"date":"2007-08-31"},"text":"August 31, 2007","children":[],"tail":", 34 percent; and” in subpar. (B), and struck out subpar. (C), which read as follows: “during the period beginning on "},{"tag":"date","attrib":{"date":"2007-09-01"},"text":"September 1, 2007","children":[],"tail":", 0 percent.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s1101/a"},"text":"Pub. L. 109–171, § 1101(a)","children":[],"tail":", added par. (3) and struck out former par. (3) which read as follows: “45 percent.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s1101/b"},"text":"Pub. L. 109–171, § 1101(b)","children":[],"tail":", substituted “2007” for “2005”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s1101/b"},"text":"Pub. L. 109–171, § 1101(b)","children":[],"tail":", (c)(1), struck out “and subsection (h) of this section” after “paragraph (2)” and substituted “2007” for “2005”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s1101/c/2"},"text":"Pub. L. 109–171, § 1101(c)(2)","children":[],"tail":", struck out subsec. (h), which related to transition rule."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
