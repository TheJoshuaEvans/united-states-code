{"tag":"section","attrib":{"id":"idee61185d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c"},"text":null,"children":[{"tag":"num","attrib":{"value":"940c"},"text":"§ 940c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cushion of credit payments program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee61185e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee61185f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee611860-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and promotion of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and promote a program to encourage borrowers to voluntarily make deposits into cushion of credit accounts established within the Rural Electrification and Telephone Revolving Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee611861-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective on ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", no deposits may be made under subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee611862-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee611863-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in each cushion of credit account shall accrue interest to the borrower at a rate of 5 percent per annum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee611864-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subparagraph (A), amounts in each cushion of credit account shall accrue interest to the borrower at a rate equal to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee611865-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 percent per annum in fiscal year 2021; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee611866-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the then applicable 1-year Treasury rate thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee611867-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Balance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee611868-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A borrower may reduce the balance of its cushion of credit account only if the amount obtained from the reduction is used to make scheduled payments on loans made or guaranteed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee611869-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prepayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A) and subject to subparagraph (C), beginning on ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", and ending with "},{"tag":"date","attrib":{"date":"2020-09-30"},"text":"September 30, 2020","children":[],"tail":", a borrower may, at the sole discretion of the borrower, reduce the balance of its cushion of credit account if the amount obtained from the reduction is used to prepay loans made or guaranteed under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee61186a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No prepayment premium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, no prepayment premium shall be imposed or collected with respect to that portion of a loan that is prepaid by a borrower in accordance with subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee61186b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661c"},"text":"section 661c of title 2","children":[],"tail":", out of any funds in the Treasury not otherwise appropriated, the Secretary of the Treasury shall make available such sums as necessary to cover any loan modification costs as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s661a"},"text":"section 661a of title 2","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee61186c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of cushion of credit payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee61186d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee61186e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash balance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Cushion of credit payments shall be held in the Rural Electrification and Telephone Revolving Fund as a cash balance in the cushion of credit accounts of borrowers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee61186f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All cash balance amounts (obtained from cushion of credit payments, loan payments, and other sources) held by the Fund shall bear interest to the Fund at a rate equal to the weighted average rate on outstanding certificates of beneficial ownership issued by the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee611870-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of interest accrued on the cash balances shall be credited to the Fund as an offsetting reduction to the amount of interest paid by the Fund on its certificates of beneficial ownership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee611871-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural economic development subaccount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain a subaccount within the Rural Electrification and Telephone Revolving Fund to which shall be credited, on a monthly basis, a sum determined by multiplying the outstanding cushion of credit payments made after ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":", by the difference (converted to a monthly basis) between the average weighted interest rate paid on outstanding certificates of beneficial ownership issued by the Fund and 5 percent."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee611872-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title III, § 313, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tI/s1403"},"text":"Pub. L. 100–203, title I, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-21"},"text":"101 Stat. 1330–21","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/13"},"text":"Pub. L. 103–354, title II, § 235(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI"},"text":"Pub. L. 115–334, title VI","children":[],"tail":", §§ 6503, 6504(b), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4772"},"text":"132 Stat. 4772","children":[],"tail":", 4773.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee611873-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee611874-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee611875-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6503/1"},"text":"Pub. L. 115–334, § 6503(1)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6503/2"},"text":"Pub. L. 115–334, § 6503(2)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6503/3"},"text":"Pub. L. 115–334, § 6503(3)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6504/b"},"text":"Pub. L. 115–334, § 6504(b)","children":[],"tail":", struck out subpar. (A) designation and heading before “The Secretary shall”, substituted “5 percent.” for “the 5 percent rate of interest provided to borrowers on cushion of credit payments.”, and struck out subpars. (B) to (E) which related to grants, repayments, proceeds, and number of grants, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a)(1), (b)(2)(A) to (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
