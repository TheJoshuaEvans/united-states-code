{"tag":"section","attrib":{"id":"ideef764b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736u"},"text":null,"children":[{"tag":"num","attrib":{"value":"1736u"},"text":"§ 1736u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperator market development program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef764ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736u/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the cooperator market development program of the Foreign Agricultural Service should be continued to help develop new markets and expand and maintain existing markets for United States agricultural commodities, using nonprofit agricultural trade organizations to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef764bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736u/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from requirements of OMB circular","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The cooperator market development program shall be exempt from the requirements of Circular A 110 issued by the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef764bc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXI/s1126/a"},"text":"Pub. L. 99–198, title XI, § 1126(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1482"},"text":"99 Stat. 1482","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef764bd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef764be-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideef764bf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consists of subsecs. (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1126"},"text":"section 1126 of Pub. L. 99–198","children":[],"tail":". Subsec. (c) of section 1126 amended "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1736m/a/5/B"},"text":"section 1736m(a)(5)(B) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food Security Act of 1985, and not as part of the Food for Peace Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
