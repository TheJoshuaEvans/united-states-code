{"tag":"section","attrib":{"id":"ideffb4010-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7035"},"text":null,"children":[{"tag":"num","attrib":{"value":"7035"},"text":"§ 7035.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out this subchapter, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffb4011-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7035/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not make available any information over the Internet that would otherwise not be available for release under section 552 or 552a of title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4012-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7035/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ensure, to the maximum extent practicable, that the confidentiality of persons is maintained.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffb4013-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/222/s6"},"text":"Pub. L. 106–222, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/355"},"text":"114 Stat. 355","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
