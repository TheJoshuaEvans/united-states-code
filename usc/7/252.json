{"tag":"section","attrib":{"id":"idee2324f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s252"},"text":null,"children":[{"tag":"num","attrib":{"value":"252"},"text":"§ 252.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or revocation of licenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee2324f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s252/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After providing notice and an opportunity for a hearing in accordance with this section, the Secretary may suspend or revoke any license issued, or approval for an activity provided, under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee2324f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s252/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a material violation of, or failure to comply, with any provision of this chapter (including regulations promulgated under this chapter); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s252/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the ground that unreasonable or exorbitant charges have been imposed for services rendered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2324f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s252/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary suspension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may temporarily suspend a license or approval for an activity under this chapter prior to an opportunity for a hearing for any violation of, or failure to comply with, any provision of this chapter (including regulations promulgated under this chapter).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2324f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s252/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to conduct hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The agency within the Department that is responsible for administering regulations promulgated under this chapter shall have exclusive authority to conduct any hearing required under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2324f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s252/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee2324fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s252/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A final administrative determination issued subsequent to a hearing may be reviewable only in a district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s252/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The review shall be conducted in accordance with the standards set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s706/2"},"text":"section 706(2) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee2324fc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 13, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tII/s201"},"text":"Pub. L. 106–472, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2067"},"text":"114 Stat. 2067","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2324fd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee2324fe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee2324ff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 252, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 11, "},{"tag":"ref","attrib":{"href":"/us/stat/39/487"},"text":"39 Stat. 487","