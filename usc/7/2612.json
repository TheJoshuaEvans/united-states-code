{"tag":"section","attrib":{"id":"idef865ea2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2612"},"text":null,"children":[{"tag":"num","attrib":{"value":"2612"},"text":"§ 2612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef865ea3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef865ea4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means any individual, partnership, corporation, association, or other entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef865ea5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “potatoes” means all varieties of Irish potatoes grown by producers in the 50 States of the United States, and grown in foreign countries and imported into the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef865ea6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2612/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “handler” means any person (except a common or contract carrier of potatoes owned by another person) who handles potatoes in a manner specified in a plan issued pursuant to this chapter or in the rules and regulations issued thereunder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef865ea7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2612/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “producer” means any person engaged in the growing of five or more acres of potatoes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef865ea8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2612/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “promotion” means any action taken by the National Potato Promotion Board, pursuant to this chapter, to present a favorable image for potatoes to the public with the express intent of improving their competitive positions and stimulating sales of potatoes and shall include, but shall not be limited to, paid advertising.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef865ea9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2612/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “importer” means any person who imports tablestock, frozen, or processed potatoes for ultimate consumption by humans or seed potatoes into the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef865eaa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/670/tIII/s303"},"text":"Pub. L. 91–670, title III, § 303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-11"},"text":"Jan. 11, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2041"},"text":"84 Stat. 2041","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1937"},"text":"Pub. L. 101–624, title XIX, § 1937","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3866"},"text":"104 Stat. 3866","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef865eab-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef865eac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef865ead-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1937/1"},"text":"Pub. L. 101–624, § 1937(1)","children":[],"tail":", substituted “50” for “forty-eight contiguous” and inserted before the period at the end “, and grown in foreign countries and imported into the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1937/2"},"text":"Pub. L. 101–624, § 1937(2)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
