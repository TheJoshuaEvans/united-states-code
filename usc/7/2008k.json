{"tag":"section","attrib":{"id":"idef249035-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008k"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008k"},"text":"§ 2008k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Making and servicing of loans by personnel of State, county, or area committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall use personnel of a State, county or area committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b/5"},"text":"section 590h(b)(5) of title 16","children":[],"tail":" to make and service loans under this chapter to the extent the personnel have been trained to do so."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef249036-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s376"},"text":"Pub. L. 87–128, title III, § 376","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tV/s5320"},"text":"Pub. L. 107–171, title V, § 5320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/349"},"text":"116 Stat. 349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef249037-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef249038-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef249039-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","at