{"tag":"section","attrib":{"id":"ideeedc834-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733"},"text":null,"children":[{"tag":"num","attrib":{"value":"1733"},"text":"§ 1733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeedc835-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No agricultural commodity, food procured outside of the United States, food voucher, or cash transfer for food shall be made available under this chapter unless it is determined that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeedc836-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the provision of an agricultural commodity, adequate storage facilities will be available in the recipient country at the time of the arrival of the commodity to prevent the spoilage or waste of the commodity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc837-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution of the agricultural commodity or use of the food procured outside of the United States, food voucher, or cash transfer for food in the recipient country will not result in a substantial disincentive to or interference with domestic production or marketing in that country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc838-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Impact on local farmers and economy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as appropriate, shall ensure that the importation of United States agricultural commodities, the use of food procured outside of the United States, food vouchers, and cash transfers for food, and the use of local currencies for development purposes will not have a disruptive impact on the farmers or the local economy of the recipient country. The Secretary or the Administrator, as appropriate, shall seek information, as part of the regular proposal and submission process, from implementing agencies on the potential costs and benefits to the local economy within the recipient country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc839-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transshipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as appropriate, shall, under such terms and conditions as are determined to be appropriate, require commitments designed to prevent or restrict the resale or transshipment to other countries, or use for other than domestic purposes, of agricultural commodities donated or purchased under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc83a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private trade channels and small business","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Private trade channels shall be used under this chapter to the maximum extent practicable in the United States and in the recipient countries with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeedc83b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sales from privately owned stocks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc83c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sales from stocks owned by the Commodity Credit Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc83d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donations.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Small businesses shall be provided adequate and fair opportunity to participate in such sales.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc83e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" World prices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeedc83f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this chapter, reasonable precautions shall be taken to assure that sales or donations of agricultural commodities will not unduly disrupt world prices for agricultural commodities or normal patterns of commercial trade with foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc840-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sales of agricultural commodities described in paragraph (1) shall be made at a reasonable market price in the economy where the agricultural commodity is to be sold, as determined by the Secretary or the Administrator, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc841-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publicity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Commitments shall be obtained from countries or private entities, as appropriate, receiving commodities under this chapter that such countries or private entities will widely publicize, to the extent practicable, through the use of the public media and through other means, that such commodities are being provided through the friendship of the American people as food for peace.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc842-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of private sector","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as appropriate, shall encourage the private sector of the United States and private importers in developing countries to participate in the programs established under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc843-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safeguard usual marketings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this chapter, reasonable precautions shall be taken to safeguard the usual marketings of the United States and to avoid displacing any sales of the United States agricultural commodities that the Secretary or Administrator determines would otherwise be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc844-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military distribution of food aid","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeedc845-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary or the Administrator, as appropriate, shall attempt to ensure that agricultural commodities made available under this chapter will be provided without regard to the political affiliation, geographic location, ethnic, tribal, or religious identity of the recipient or without regard to other extraneous factors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc846-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on handling of commodities by the military","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef03847-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the Secretary or the Administrator, as appropriate, shall not enter into an agreement under this chapter to provide agricultural commodities if such agreement requires or permits the distribution, handling, or allocation of such commodities by the military forces of any government or insurgent group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef03848-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subparagraph (A), the Secretary or the Administrator, as appropriate, may authorize the handling or distribution of commodities by the military forces of a country in exceptional circumstances in which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideef03849-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/i/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonmilitary channels are not available for such handling or distribution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef0384a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/i/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such action is consistent with the requirements of paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideef0384b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/i/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary or the Administrator, as appropriate, determines that such action is necessary to meet the emergency health, safety, or nutritional requirements of the recipient population.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef0384c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouragement of safe passage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When entering into agreements under this chapter that involve areas within recipient countries that are experiencing protracted warfare or civil strife, the Secretary or the Administrator, as appropriate, shall, to the extent practicable, encourage all parties to the conflict to permit safe passage of the commodities and other relief supplies and to establish safe zones for medical and humanitarian treatment and evacuation of injured persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef0384d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations of human rights","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef0384e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligible countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or the Administrator, as appropriate, shall not enter into any agreement under this chapter to provide agricultural commodities, or to finance the sale of agricultural commodities, to the government of any country determined by the President to engage in a consistent pattern of gross violations of internationally recognized human rights, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef0384f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the torture or cruel, inhuman, or degrading treatment or punishment of individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef03850-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prolonged detention of individuals without charges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef03851-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/j/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsibility for causing the disappearance of individuals through the abduction and clandestine detention of such individuals; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef03852-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/j/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other flagrant denials of the right to life, liberty, and the security of persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef03853-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not prohibit the provision of assistance to such a country if the assistance is targeted to the most needy people in such country and is made available in such country through channels other than the government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef03854-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Abortion prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Local currencies that are made available for use under this chapter may not be used to pay for the performance of abortions as a method of family planning or to motivate or coerce any person to practice abortions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef03855-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef03856-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (b) and (h) shall apply to sales of commodities in recipient countries to generate proceeds to carry out projects under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef03857-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/l/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapters II and III;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef03858-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/l/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431/b"},"text":"section 1431(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef03859-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/l/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Food for Progress Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1736"},"text":"7 U.S.C. 1736","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef0385a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1733/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Currency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A sale described in paragraph (1) may be made in United States dollars or other currencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef0385b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title IV, § 403, as added "},{"tag":"ref","attrib":{"href":"/us/pl/86/341/tI/s14"},"text":"Pub. L. 86–341, title I, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1959-09-21"},"text":"Sept. 21, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/610"},"text":"73 Stat. 610","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/87/703/tII/s201/3"},"text":"Pub. L. 87–703, title II, § 201(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-27"},"text":"Sept. 27, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/611"},"text":"76 Stat. 611","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/638/s1/17"},"text":"Pub. L. 88–638, § 1(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-08"},"text":"Oct. 8, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1037"},"text":"78 Stat. 1037","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s2/E"},"text":"Pub. L. 89–808, § 2(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-11"},"text":"Nov. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1536"},"text":"80 Stat. 1536","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXII/s1206"},"text":"Pub. L. 95–113, title XII, § 1206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/956"},"text":"91 Stat. 956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/533/tIV/s407"},"text":"Pub. L. 96–533, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3151"},"text":"94 Stat. 3151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXII/s1214"},"text":"Pub. L. 97–98, title XII, § 1214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1282"},"text":"95 Stat. 1282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3646"},"text":"104 Stat. 3646","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s321"},"text":"Pub. L. 102–237, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1857"},"text":"105 Stat. 1857","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s213"},"text":"Pub. L. 104–127, title II, § 213","children":[],"tail":", "},{"tag":"date",