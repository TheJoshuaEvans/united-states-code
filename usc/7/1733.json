ef":"/us/pl/99/198/tXI/s1110"},"text":"Pub. L. 99–198, title XI, § 1110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1472"},"text":"99 Stat. 1472","children":[],"tail":", which is classified to section 1736"},{"tag":"i","attrib":{},"text":"o","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideef0385f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3109/a/1"},"text":"Pub. L. 115–334, § 3109(a)(1)","children":[],"tail":", inserted “, food procured outside of the United States, food voucher, or cash transfer for food” after “agricultural commodity” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3109/a/2"},"text":"Pub. L. 115–334, § 3109(a)(2)","children":[],"tail":", inserted “in the case of the provision of an agricultural commodity,” before “adequate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3109/a/3"},"text":"Pub. L. 115–334, § 3109(a)(3)","children":[],"tail":", substituted “agricultural commodity or use of the food procured outside of the United States, food voucher, or cash transfer for food” for “commodity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3109/b"},"text":"Pub. L. 115–334, § 3109(b)","children":[],"tail":", in first sentence, inserted “, the use of food procured outside of the United States, food vouchers, and cash transfers for food,” after “agricultural commodities” and, in second sentence, struck out “of sales of agricultural commodities” after “benefits to the local economy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (m). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3112/b"},"text":"Pub. L. 115–334, § 3112(b)","children":[],"tail":", struck out subsec. (m) which related to annual report on use of funds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3008/a"},"text":"Pub. L. 113–79, § 3008(a)","children":[],"tail":", inserted at end “The Secretary or the Administrator, as appropriate, shall seek information, as part of the regular proposal and submission process, from implementing agencies on the potential costs and benefits to the local economy of sales of agricultural commodities within the recipient country.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (m). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3008/b"},"text":"Pub. L. 113–79, § 3008(b)","children":[],"tail":", added subsec. (m)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3009/a/1"},"text":"Pub. L. 107–171, § 3009(a)(1)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"). "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3009/a/2"},"text":"Pub. L. 107–171, § 3009(a)(2)","children":[],"tail":", added subsec. ("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s213/1"},"text":"Pub. L. 104–127, § 213(1)","children":[],"tail":", inserted heading and struck out former heading “Consultations” and in text struck out “consult with representatives from the International Monetary Fund, the Intern