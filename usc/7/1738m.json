{"tag":"section","attrib":{"id":"ideef9aeb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738m"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738m"},"text":"§ 1738m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef9aeb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than December 31 of each fiscal year, the President shall prepare and submit to the Speaker of the House of Representatives and the President Pro Tempore of the Senate an annual report concerning the operation of the Facility for the prior fiscal year. This report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef9aeb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities undertaken by the Facility during the previous fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9aeb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any Enviromental ","children":[{"tag":"ref","attrib":{"idref":"fn002203"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002203"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Environmental”."}],"tail":" Framework Agreement entered into under this subchapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9aeb9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738m/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report on what Environmental Funds have been established under this subchapter and on the operations of such Funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9aeba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738m/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any grants that have been extended by administering bodies pursuant to an Enviromental ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" Framework Agreement under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aebb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental views in annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No later than December 15 of each fiscal year, each member of the Board shall be entitled to receive a copy of the report required under subsection (a). Each member of the Board may prepare and submit supplemental views to the President on the implementation of this subchapter by December 31 for inclusion in the annual report when it is transmitted to Congress pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef9aebc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title VI, § 614, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3662"},"text":"104 Stat. 3662","children":[],"tail":"; as amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s330"},"text":"Pub. L. 102–237, title III, § 330","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1858"},"text":"105 Stat. 1858","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/532/s3"},"text":"Pub. L. 102–532, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3512"},"text":"106 Stat. 3512","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef9aebd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef9aebe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideef9aebf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/532"},"text":"Pub. L. 102–532","children":[],"tail":" inserted at end “This report shall include—” and pars. (1) to (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideef9aec0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideef9aec1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which certain reporting requirements under this section are listed on page 20), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, and section 1(a)(4) [div. A, § 1402(1)] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":", set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ideef9aec2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"ideef9aec3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Function