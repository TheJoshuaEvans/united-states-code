{"tag":"section","attrib":{"id":"idef88cf29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655"},"text":null,"children":[{"tag":"num","attrib":{"value":"2655"},"text":"§ 2655.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural firefighters and emergency medical service assistance program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef88cf2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of emergency medical services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef88cf2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “emergency medical services” means resources used by a public or nonprofit entity to deliver medical care outside of a medical facility under emergency conditions that occur as a result of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef88cf2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the condition of a patient; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef88cf2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a natural disaster or related condition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “emergency medical services” includes services (whether compensated or volunteer) delivered by an emergency medical services provider or other provider recognized by the State involved that is licensed or certified by the State as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef88cf2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an emergency medical technician or the equivalent (as determined by the State);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef88cf30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a registered nurse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef88cf31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a physician assistant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef88cf32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a physician that provides services similar to services provided by such an emergency medical services provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef88cf33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall award grants to eligible entities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef88cf34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable the entities to provide for improved emergency medical services in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay the cost of training firefighters and emergency medical personnel in firefighting, emergency medical practices, and responding to hazardous materials and bioagents in rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef88cf36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef88cf37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef88cf38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State emergency medical services office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef88cf39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State emergency medical services association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef88cf3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State office of rural health or an equivalent agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef88cf3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local government entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef88cf3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef88cf3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or local ambulance provider; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef88cf3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other public or nonprofit entity determined appropriate by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepare and submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require, that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef88cf40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities to be carried out under the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef88cf41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assurance that the applicant will comply with the matching requirement of subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef88cf42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity shall use amounts received under a grant made under subsection (b) only in a rural area—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef88cf43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to hire or recruit emergency medical service personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recruit or retain volunteer emergency medical service personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train emergency medical service personnel in emergency response, injury prevention, safety awareness, or other topics relevant to the delivery of emergency medical services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf46-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fund training to meet State or Federal certification requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf47-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide training for firefighters or emergency medical personnel for improvements to the training facility, equipment, curricula, or personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf48-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop new ways to educate emergency health care providers through the use of technology-enhanced educational methods (such as distance learning);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf49-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire emergency medical services vehicles, including ambulances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire emergency medical services equipment, including cardiac defibrillators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire personal protective equipment for emergency medical services personnel as required by the Occupational Safety and Health Administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to educate the public concerning cardiopulmonary resuscitation (CPR), first aid, injury prevention, safety awareness, illness prevention, or other related emergency preparedness topics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef88cf4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall give preference to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef88cf4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications that reflect a collaborative effort by 2 or more of the entities described in subparagraphs (A) through (G) of subsection (c)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applications submitted by entities that intend to use amounts provided under the grant to fund activities described in any of paragraphs (1) through (5) of subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef88cf50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a grant under this section to an entity unless the entity makes available (directly or through contributions from other public or private entities) non-Federal contributions toward the activities to be carried out under the grant in an amount equal to at least 5 percent of the amount received under the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef88cf51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef88cf52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section not more than $30,000,000 for each of fiscal years 2008 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef88cf53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2655/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 5 percent of the amount appropriated under paragraph (1) for a fiscal year may be used for administrative expenses incurred in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef88cf54-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6405"},"text":"Pub. L. 107–171, title VI, § 6405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/430"},"text":"116 Stat. 430","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tI/s1405/a"},"text":"Pub. L. 109–171, title I, § 1405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/7"},"text":"120 Stat. 7","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6204"},"text":"Pub. L. 110–234, title VI, § 6204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1208"},"text":"122 Stat. 1208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6204, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1969.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef88cf55-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef88cf56-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef88cf57-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef88cf58-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6204"},"text":"Pub. L. 110–246, § 6204","children":[],"tail":", amended section generally. Prior to amendment, section consisted of subsecs. (a) to (c) relating to authority to make grants to pay the cost of training firefighters and emergency medical personnel in rural areas, use of funds, and appropriations for fiscal years 2003 through 2006."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":" substituted “2006” for “2007”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef88cf59-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef88cf5a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
