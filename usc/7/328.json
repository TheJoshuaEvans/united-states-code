{"tag":"section","attrib":{"id":"idee27dfae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s328"},"text":null,"children":[{"tag":"num","attrib":{"value":"328"},"text":"§ 328.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Power to amend, repeal, etc., reserved","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Congress may at any time amend, suspend, or repeal any or all of the provisions of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee27dfaf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-08-30/ch841/s6"},"text":"Aug. 30, 1890, ch. 841, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/419"},"text":"26 Stat. 419","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
