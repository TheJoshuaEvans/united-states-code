{"tag":"section","attrib":{"id":"ideffb4054-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7103"},"text":null,"children":[{"tag":"num","attrib":{"value":"7103"},"text":"§ 7103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance and amendment of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffb4055-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the Secretary shall issue orders under this chapter applicable to producers, feeders, importers, handlers, and purchasers of sheep and sheep products. Any order shall be national in scope. Not more than 1 order shall be in effect under this chapter at any 1 time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffb4056-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffb4057-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal or request for issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may propose the issuance of an order under this chapter, or an association of producers may request the issuance of, and submit a proposal for, an order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4058-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and comment concerning proposed order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the receipt of a request and proposal for an order under paragraph (1), the Secretary shall publish a proposed order and give due notice and opportunity for public comment on the proposed order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4059-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for public comment are given as provided in paragraph (2), the Secretary shall issue an order, taking into consideration the comments received, that includes provisions necessary to ensure that the order is in conformity with this chapter. The order shall be issued not later than 180 days following publication of the proposed order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb405a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7103/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referendum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall go into effect only if the order is approved by producers, feeders, and importers in a referendum conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7105"},"text":"section 7105 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffb405b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, from time to time, may amend any order issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffb405c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/407/s4"},"text":"Pub. L. 103–407, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4213"},"text":"108 Stat. 4213","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
