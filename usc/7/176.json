{"tag":"section","attrib":{"id":"idee173e8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s176"},"text":null,"children":[{"tag":"num","attrib":{"value":"176"},"text":"§ 176.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of guayule shrub to Reconstruction Finance Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Guayule shrub may be sold to the Reconstruction Finance Corporation at a price reflecting the net realization from the sale of the rubber recovered from such shrub in mills operated by said Corporation after deducting the cost of milling and amortization of the cost of mills constructed for the purpose by said Corporation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee173e8e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-06-30/ch215/s1"},"text":"June 30, 1945, ch. 215, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/310"},"text":"59 Stat. 310","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1945-07-05/ch271"},"text":"July 5, 1945, ch. 271","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/59/423"},"text":"59 Stat. 423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee173e8f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee173e90-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idee173e91-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Rubber Reserve Company dissolved and functions transferred to Reconstruction Finance Corporation by Joint Res. ","children":[{"tag":"date","attrib":{"date":"1945-06-30"},"text":"June 30, 1945","children":[],"tail":", eff. "},{"tag":"date","attrib":{"date":"1945-07-01"},"text":"July 1, 1945","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idee173e92-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee173e93-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Reconstruction Finance Corporation","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6(a) of 1957 Reorg. Plan No. 1, eff. ","children":[{"tag":"date","attrib":{"date":"1957-06-30"},"text":"June 30, 1957","children":[],"tail":", 22 F.R. 4633, "},{"tag":"ref","attrib":{"href":"/us/stat/71/649"},"text":"71 Stat. 649","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s601"},"text":"section 601 of Title 15","children":[],"tail":", Commerce and Trade, abolished Reconstruction Finance Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
