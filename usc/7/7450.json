{"tag":"section","attrib":{"id":"idf00be240-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7450"},"text":null,"children":[{"tag":"num","attrib":{"value":"7450"},"text":"§ 7450.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall, whenever the Secretary finds that an order or a provision of an order obstructs or does not tend to effectuate the declared policy of this subchapter, suspend or terminate the operation of the order or provision. The suspension or termination of an order shall not be considered an order within the meaning of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf00be241-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s541"},"text":"Pub. L. 104–127, title V, § 541","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1063"},"text":"110 Stat. 1063","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
