{"tag":"section","attrib":{"id":"ideeb21ec8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1471a"},"text":"§ 1471a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency livestock assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeb21ec9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide emergency feed assistance under this subchapter for the preservation and maintenance of livestock in any State or area of a State where, because of disease, insect infestation, flood, drought, fire, hurricane, earthquake, storm, hot weather, or other natural disaster, the Secretary determines that a livestock emergency exists.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb21eca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeb21ecb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall provide emergency feed assistance under this subchapter for the preservation and maintenance of livestock, to livestock producers that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeb21ecc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct farming, ranching, or aquaculture operations in any county contiguous to a county where the Secretary has determined, under subsection (a), that a livestock emergency exists, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeb21ecd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are otherwise eligible for assistance under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb21ece-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall accept applications for assistance under this subsection from producers that are affected by the livestock emergency at any time during the eight-month period beginning on the date on which the Secretary determines that such emergency exists in the other county.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeb21ecf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"Oct. 31, 1949, ch. 792","children":[],"tail":", title VI, § 603, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/387/tI/s101/a"},"text":"Pub. L. 100–387, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-11"},"text":"Aug. 11, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/927"},"text":"102 Stat. 927","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeb21ed0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeb21ed1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and R