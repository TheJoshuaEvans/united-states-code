{"tag":"section","attrib":{"id":"ideefc1f19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1746"},"text":null,"children":[{"tag":"num","attrib":{"value":"1746"},"text":"§ 1746.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation shall keep such records and accounts as may be necessary to show, for each commodity set-aside, the initial and current composition, value (in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1742"},"text":"section 1742 of this title","children":[],"tail":"), current investment, quantity disposed of, method of disposition, and amounts received on disposition."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideefc1f1a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041"},"text":"Aug. 28, 1954, ch. 1041","children":[],"tail":", title I, § 106, "},{"tag":"ref","attrib":{"href":"/us/stat/68/898"},"text":"68 Stat. 898","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
