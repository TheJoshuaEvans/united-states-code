{"tag":"section","attrib":{"id":"idef249040-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008m"},"text":"§ 2008m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Rural Development Partnership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef249041-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef249042-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency with rural responsibilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agency with rural responsibilities” means any executive agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":") that implements a Federal law, or administers a program, targeted at or having a significant impact on rural areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef249043-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinating Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Coordinating Committee” means the National Rural Development Coordinating Committee established by subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef249044-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Partnership” means the National Rural Development Partnership continued by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef249045-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State rural development council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State rural development council” means a State rural development council that meets the requirements of subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef249046-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef249047-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall continue the National Rural Development Partnership composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef249048-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Coordinating Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef249049-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State rural development councils.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef24904a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purposes of the Partnership are to empower and build the capacity of States and rural communities to design flexible and innovative responses to their own special rural development needs, with local determinations of progress and selection of projects and activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef24904b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing panel","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef24904c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A panel consisting of representatives of the Coordinating Committee and State rural development councils shall be established to lead and coordinate the strategic operation, policies, and practices of the Partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef24904d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conjunction with the Coordinating Committee and State rural development councils, the panel shall prepare and submit to Congress an annual report on the activities of the Partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef24904e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Role of Federal Government","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The role of the Federal Government in the Partnership may be that of a partner and facilitator, with Federal agencies authorized—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef24904f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cooperate with States to implement the Partnership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef249050-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide States with the technical and administrative support necessary to plan and implement tailored rural development strategies to meet local needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef249051-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the head of each agency with rural responsibilities designates a senior-level agency official to represent the agency on the Coordinating Committee and directs appropriate field staff to participate fully with the State rural development council within the jurisdiction of the field staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef249052-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into cooperative agreements with, and to provide grants and other assistance to, the Coordinating Committee and State rural development councils.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef249053-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Rural Development Coordinating Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef249054-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a National Rural Development Coordinating Committee within the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef249055-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Coordinating Committee shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef249056-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative of each agency with rural responsibilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef249057-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" representatives, approved by the Secretary, of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef249058-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national associations of State, regional, local, and tribal governments and intergovernmental and multijurisdictional agencies and organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270059-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national public interest groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef27005a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other national nonprofit organizations that elect to participate in the activities of the Coordinating Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef27005b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef27005c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Coordinating Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef27005d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the work of the State rural development councils;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef27005e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate coordination of rural development policies, programs, and activities among Federal agencies and with those of State, local, and tribal governments, the private sector, and nonprofit organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef27005f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and comment on policies, regulations, and proposed legislation that affect or would affect rural areas and gather and provide related information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270060-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and facilitate strategies to reduce or eliminate administrative and regulatory impediments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270061-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require each State rural development council receiving funds under this section to submit an annual report on the use of the funds, including a description of strategic plans, goals, performance measures, and outcomes for the State rural development council of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270062-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal participation in Coordinating Committee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef270063-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal employee shall fully participate in the governance and operations of the Coordinating Committee, including activities related to grants, contracts, and other agreements, in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270064-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Participation by a Federal employee in the Coordinating Committee in accordance with this paragraph shall not constitute a violation of section 205 or 208 of title 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270065-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide such administrative support for the Coordinating Committee as the Secretary determines is necessary to carry out the duties of the Coordinating Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270066-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may prescribe such regulations, bylaws, or other procedures as are necessary for the operation of the Coordinating Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef270067-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State rural development councils","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef270068-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding chapter 63 of title 31, each State may elect to participate in the Partnership by entering into an agreement with the Secretary to recognize a State rural development council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270069-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State rural development council shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef27006a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be composed of representatives of Federal, State, local, and tribal governments, nonprofit organizations, regional organizations, the private sector, and other entities committed to rural advancement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef27006b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" have a nonpartisan and nondiscriminatory membership that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef27006c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is broad and representative of the economic, social, and political diversity of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef27006d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be responsible for the governance and operations of the State rural development council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef27006e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State rural development council shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef27006f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate collaboration among Federal, State, local, and tribal governments and the private and nonprofit sectors in the planning and implementation of programs and policies that have an impact on rural areas of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270070-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor, report, and comment on policies and programs that address, or fail to address, the needs of the rural areas of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270071-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of the Partnership, in conjunction with the Coordinating Committee, facilitate the development of strategies to reduce or eliminate conflicting or duplicative administrative or regulatory requirements of Federal, State, local, and tribal governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270072-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef270073-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the Coordinating Committee an annual plan with goals and performance measures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef270074-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Coordinating Committee an annual report on the progress of the State rural development council in meeting the goals and measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270075-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal participation in State rural development councils","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef270076-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State Director for Rural Development of the Department of Agriculture, other employees of the Department, and employees of other Federal agencies with rural responsibilities shall fully participate as voting members in the governance and operations of State rural development councils (including activities related to grants, contracts, and other agreements in accordance with this section) on an equal basis with other members of the State rural development councils.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270077-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Participation by a Federal employee in a State rural development council in accordance with this paragraph shall not constitute a violation of section 205 or 208 of title 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef270078-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative support of the Partnership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef270079-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of employees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef27007a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to provide experience in intergovernmental collaboration, the head of an agency with rural responsibilities that elects to participate in the Partnership may, and is encouraged to, detail to the Secretary for the support of the Partnership 1 or more employees of the agency with rural responsibilities without reimbursement for a period of up to 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef27007b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil service status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The detail shall be without interruption or loss of civil service status or privilege.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef27007c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide for any additional support staff to the Partnership as the Secretary determines to be necessary to carry out the duties of the Partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef27007d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermediaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into a contract with a qualified intermediary under which the intermediary shall be responsible for providing administrative and technical assistance to a State rural development council, including administering the financial assistance available to the State rural development council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef27007e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirements for State rural development councils","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef27007f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), a State rural development council shall provide matching funds, or in-kind goods or services, to support the activities of the State rural development council in an amount that is not less than 33 percent of the amount of Federal funds received from a Federal agency under subsection (g)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270080-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions to matching requirement for certain Federal funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply to funds, grants, funds provided under contracts or cooperative agreements, gifts, contributions, or technical assistance received by a State rural development council from a Federal agency that are used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef270081-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support 1 or more specific program or project activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270082-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reimburse the State rural development council for services provided to the Federal agency providing the funds, grants, funds provided under contracts or cooperative agreements, gifts, contributions, or technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270083-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department’s share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop a plan to decrease, over time, the share of the Department of Agriculture of the cost of the core operations of State rural development councils.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef270084-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef270085-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2008 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270086-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agencies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef270087-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law limiting the ability of an agency, along with other agencies, to provide funds to the Coordinating Committee or a State rural development council in order to carry out the purposes of this section, a Federal agency may make grants, gifts, or contributions to, provide technical assistance to, or enter into contracts or cooperative agreements with, the Coordinating Committee or a State rural development council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270088-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal agencies are encouraged to use funds made available for programs that have an impact on rural areas to provide assistance to, and enter into contracts with, the Coordinating Committee or a State rural development council, as described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270089-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Coordinating Committee and a State rural development council may accept private contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef27008a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008m/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided under this section shall terminate on ","children":[{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef27008b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s378"},"text":"Pub. L. 87–128, title III, § 378","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6021"},"text":"Pub. L. 107–171, title VI, § 6021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/363"},"text":"116 Stat. 363","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6019"},"text":"Pub. L. 110–234, title VI, § 6019","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1172"},"text":"122 Stat. 1172","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6019, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1933; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVI/s6021"},"text":"Pub. L. 113–79, title VI, § 6021","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/847"},"text":"128 Stat. 847","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6420"},"text":"Pub. L. 115–334, title VI, § 6420","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4765"},"text":"132 Stat. 4765","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef27008c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef27008d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef27008e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The authorities provided by each provision of, and each amendment made by, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", to continue, and authorities to be carried out, until the later of "},{"tag":"date","attrib":{"date":"2024-09-30"},"text":"Sept. 30, 2024","children":[],"tail":", or the date specified in the provision of, or amendment made by, "},{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/a"},"text":"section 102(a) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","childre