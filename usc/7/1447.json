{"tag":"section","attrib":{"id":"ideeb21e8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1447"},"text":null,"children":[{"tag":"num","attrib":{"value":"1447"},"text":"§ 1447.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Price support levels for other nonbasic agricultural commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to make available through loans, purchases, or other operations price support to producers for any nonbasic agricultural commodity not designated in sections 1446, 1446a, and 1446d ","children":[{"tag":"ref","attrib":{"idref":"fn002162"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002162"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title at a level not in excess of 90 per centum of the parity price for the commodity."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideeb21e8c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"Oct. 31, 1949, ch. 792","children":[],"tail":", title III, § 301, "},{"tag":"ref","attrib":{"href":"/us/stat/63/1053"},"text":"63 Stat. 1053","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/tX/s1003/a"},"text":"Pub. L. 95–113, title X, § 1003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/950"},"text":"91 Stat. 950","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeb21e8d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeb21e8e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib"