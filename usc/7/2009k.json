{"tag":"section","attrib":{"id":"idef297164-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009k"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009k"},"text":"§ 2009k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural development interagency working group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef297165-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide leadership within the Executive branch for, and assume responsibility for, establishing an interagency working group chaired by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297166-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The working group shall establish policy for, coordinate, make recommendations with respect to, and evaluate the performance of, all Federal rural development efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef297167-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s381L"},"text":"Pub. L. 87–128, title III, § 381L","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s761"},"text":"Pub. L. 104–127, title VII, § 761","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1146"},"text":"110 Stat. 1146","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
