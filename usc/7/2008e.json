{"tag":"section","attrib":{"id":"idef248ffd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008e"},"text":"§ 2008e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition under rural development programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef248ffe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assistance under any rural development program administered by the Rural Development Administration, the Farmers Home Administration, the Rural Electrification Administration, or any other agency of the Department of Agriculture shall not be conditioned on any requirement that the recipient of such assistance accept or receive electric service from any particular utility, supplier, or cooperative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248fff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ensuring compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, by regulation, adequate safeguards to ensure that assistance under such rural development programs is not subject to such a condition. Such safeguards shall include periodic certifications and audits, and appropriate measures and sanctions against any person violating, or attempting to violate, the prohibition in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef249000-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"1993-11-01"},"text":"November 1, 1993","children":[],"tail":", the Secretary shall issue interim final regulations to ensure compliance with subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef249001-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s370"},"text":"Pub. L. 87–128, title III, § 370","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/103/129/s5"},"text":"Pub. L. 103–129, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-01"},"text":"Nov. 1, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1366"},"text":"107 Stat. 1366","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
