{"tag":"section","attrib":{"id":"ideedd266d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1635k"},"text":"§ 1635k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory reporting of wholesale pork cuts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedd266e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The corporate officers or officially designated representatives of each packer shall report to the Secretary information concerning the price and volume of wholesale pork cuts, as the Secretary determines is necessary and appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedd266f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publish information reported under subsection (a) as the Secretary determines necessary and appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedd2670-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 233, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/239/s2/b/1"},"text":"Pub. L. 111–239, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2501"},"text":"124 Stat. 2501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideedd2671-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideedd2672-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideedd2673-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Negotiated Rulemaking Process","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/239/s2/b/2"},"text":"Pub. L. 111–239, § 2(b)(2)","children":[],"tail":"–(4), "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2501"},"text":"124 Stat. 2501","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/25"},"text":"Pub. L. 117–286, § 4(a)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4307"},"text":"136 Stat. 4307","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/286/s4/a/25"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Negotiated rulemaking","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Agriculture shall establish a negotiated rulemaking process pursuant to subchapter III of chapter 5 of title 5, United States Code, to negotiate and develop a proposed rule to implement the amendment made by paragraph (1) [enacting this section].","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Negotiated rulemaking committee.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any negotiated rulemaking committee established by the Secretary of Agriculture pursuant to paragraph (2) shall include representatives from—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations representing swine producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations representing packers of pork, processors of pork, retailers of pork, and buyers of wholesale pork;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" among interested parties that participate in swine or pork production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of chapter ","children":[],"tail":"10"},{"tag":"inline","attrib":{},"text":" of title ","children":[],"tail":"5"},{"tag":"inline","attrib":{},"text":", united states code","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any negotiated rulemaking committee established by the Secretary of Agriculture pursuant to paragraph (2) shall not be subject to chapter 10 of title 5, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing of proposed and final rules","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the negotiated rulemaking process under paragraph (2), the Secretary of Agriculture shall ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendation for a proposed rule or report is provided to the Secretary of Agriculture not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a final rule is promulgated not later than one and a half years after the date of the enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
