{"tag":"section","attrib":{"id":"idefac83f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352"},"text":null,"children":[{"tag":"num","attrib":{"value":"3352"},"text":"§ 3352.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agriculture research facility expansion and security upgrades","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefac83f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To enhance the security of agriculture in the United States against threats posed by bioterrorism, the Secretary shall make expansion or security upgrade grants on a competitive basis to colleges and universities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103/4"},"text":"section 3103(4) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac83f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants to a recipient under this section shall not exceed $10,000,000 in any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac83f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make a grant under this section only if the grant applicant provides satisfactory assurances to the Secretary that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefac83f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient funds are available to pay the non-Federal share of the cost of the proposed expansion or security upgrades; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac83f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed expansion or security upgrades meet such reasonable qualifications as may be established by the Secretary with respect to biosafety and biosecurity requirements necessary to protect facility staff, members of the public, and the food supply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac83fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements for grants for facility expansion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make a grant under this section for the expansion, renovation, remodeling, or alteration (collectively referred to in this section as “expansion”) of a facility only if the grant applicant provides such assurances as the Secretary determines to be satisfactory to ensure the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefac83fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For not less than 20 years after the grant is awarded, the facility shall be used for the purposes of the research for which the facility was expanded, as described in the grant application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac83fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sufficient funds will be available, as of the date of completion of the expansion, for the effective use of the facility for the purposes of the research for which the facility was expanded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac83fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The proposed expansion—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefac83fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will increase the capability of the applicant to conduct research for which the facility was expanded; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefac83ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to improve the quality of the research of the applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8400-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant awarded under this section shall be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8401-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of any expansion or security upgrade carried out using funds from a grant provided under this section shall not exceed 50 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8402-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3352/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as are necessary for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefac8403-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1485"},"text":"Pub. L. 95–113, title XIV, § 1485","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7221/a"},"text":"Pub. L. 107–171, title VII, § 7221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/453"},"text":"116 Stat. 453","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
