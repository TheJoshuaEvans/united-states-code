{"tag":"section","attrib":{"id":"ideefc1fa0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1766"},"text":null,"children":[{"tag":"num","attrib":{"value":"1766"},"text":"§ 1766.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations; advance payment for rent and other service; funds for courtesies to foreign representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may make rules and regulations necessary to carry out the purposes of this chapter and may cooperate with any Department or agency of the United States Government, State, Territory, or possession or any organization or person. In any foreign country where custom or practice requires payment in advance for rent or other service, such payment may be authorized by the Secretary of Agriculture. Funds available for the purposes of this chapter may be used for extending courtesies to representatives of foreign countries, when so provided in appropriation or other law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideefc1fa1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041"},"text":"Aug. 28, 1954, ch. 1041","children":[],"tail":", title VI, § 606A, formerly § 606, "},{"tag":"ref","attrib":{"href":"/us/stat/68/909"},"text":"68 Stat. 909","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-03/ch950/s8"},"text":"Aug. 3, 1956, ch. 950, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1034"},"text":"70 Stat. 1034","children":[],"tail":"; renumbered § 606A, "},{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIV/s401/2"},"text":"Pub. L. 95–501, title IV, § 401(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-21"},"text":"Oct. 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1690"},"text":"92 Stat. 1690","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideefc1fa2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideefc1fa3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideefc1fa4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1956—Act ","children":[{"tag":"date","attrib":{"date":"1956-08-03"},"text":"Aug. 3, 1956","children":[],"tail":", inserted sentence relating to availability of funds for extending courtesies to representatives of foreign countries."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
