{"tag":"section","attrib":{"id":"idef9be2ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3172"},"text":null,"children":[{"tag":"num","attrib":{"value":"3172"},"text":"§ 3172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary of Agriculture","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to carry out the policy of this subchapter, the Secretary shall develop and implement a national food and human nutrition research and extension program that shall include, but not be limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9be2bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3172/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on human nutritional requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9be2bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3172/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on the nutrient composition of foods and the effects of agricultural practices, handling, food processing, and cooking on the nutrients they contain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9be2bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3172/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surveillance of the nutritional benefits provided to participants in the food programs administered by the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9be2be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3172/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on the factors affecting food preference and habits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9be2bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3172/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of techniques and equipment to assist consumers in the home or in institutions in selecting food that supplies a nutritionally adequate diet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9be2c0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1422"},"text":"Pub. L. 95–113, title XIV, § 1422","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/999"},"text":"91 Stat. 999","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9be2c1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef9be2c2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef9be2c3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
