{"tag":"section","attrib":{"id":"idef8ffb71-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907"},"text":null,"children":[{"tag":"num","attrib":{"value":"2907"},"text":"§ 2907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refunds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8ffb72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of escrow account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the period prior to the approval of the continuation of an order pursuant to the referendum required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2906/a"},"text":"section 2906(a) of this title","children":[],"tail":", subject to subsection (f), the Board shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8ffb73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish an escrow account to be used for assessment refunds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffb74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place funds in such account in accordance with subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffb75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refund assessments to persons in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8ffb76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding escrow account","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (f), the Board shall place in such account, from assessments collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2906"},"text":"section 2906 of this title","children":[],"tail":" during the period referred to in subsection (a), an amount equal to the product obtained by multiplying—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8ffb77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of assessments collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2906"},"text":"section 2906 of this title","children":[],"tail":" during such period; by"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffb78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8ffb79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average rate of assessment refunds provided to producers under State beef promotion, research, and consumer information programs financed through producer assessments, as determined by the Board; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8ffb7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8ffb7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demand and receipt of one-time refund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsections (d), (e), and (f) and notwithstanding any other provision of this chapter,","children":[{"tag":"ref","attrib":{"idref":"fn002269"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002269"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" any person shall have the right to demand and receive from the Board a one-time refund of all assessments collected under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2906"},"text":"section 2906 of this title","children":[],"tail":" from such person during the period referred to in subsection (a) if such person—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8ffb7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is responsible for paying such assessment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffb7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not support the program established under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8ffb7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and time period for demand for one-time refund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such demand shall be made in accordance with regulations, on a form, and within a time period prescribed by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8ffb7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of proof for one-time refund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such refund shall be made on submission of proof satisfactory to the Board that the producer, person, or importer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8ffb80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid the assessment for which refund is sought; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffb81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" did not collect such assessment from another producer, person, or importer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8ffb82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insufficiency of funds in escrow account; pro­ration of funds among eligible persons","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8ffb83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the amount in the escrow account required to be established by subsection (a) is not sufficient to refund the total amount of assessments demanded by all eligible persons under this section and the continuation of an order is approved pursuant to the referendum required under section 2906(a) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title, the Board shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8ffb84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to place in such account, from assessments collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2904"},"text":"section 2904 of this title","children":[],"tail":", the amount required under subsection (b), until such time as the Board is able to comply with subparagraph (B); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8ffb85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to all eligible persons the total amount of assessments demanded by all eligible producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffb86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2907/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the amount in the escrow account required to be established by subsection (a) is not sufficient to refund the total amount of assessments demanded by all eligible persons under this section and the continuation of an order is not approved pursuant to the referendum required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2906/a"},"text":"section 2906(a) of this title","children":[],"tail":", the Board shall prorate the amount of such refunds among all eligible persons who demand such refund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8ffb87-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/294/s8"},"text":"Pub. L. 94–294, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-28"},"text":"May 28, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/532"},"text":"90 Stat. 532","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1601/b"},"text":"Pub. L. 99–198, title XVI, § 1601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1604"},"text":"99 Stat. 1604","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8ffb88-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef8ffb89-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef8ffb8a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in provisions preceding par. 1 of subsec. (c), was in the original “this subtitle”, and was translated as reading “this Act” to reflect the probable intent of Congress.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2906/a"},"text":"Section 2906(a) of this title","children":[],"tail":", referred to in subsec. (f)(1), was in the original a reference to "},{"tag":"ref","attrib":{"href":"/us/pl/94/294/s10/a"},"text":"section 10(a) of Pub. L. 94–294","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2909/a"},"text":"section 2909(a) of this title","children":[],"tail":", and was translated as "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2906/a"},"text":"section 2906(a) of this title","children":[],"tail":" as the probable intent of Congress, in view of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2909"},"text":"section 2909 of this title","children":[],"tail":" not containing a subsec. (a) and the subject matter of section 2906(a) which relates to a referendum."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef8ffb8b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" amended section generally, substituting provisions relating to refunds for provisions relating to required terms and conditions in orders."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef8ffb8c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef8ffb8d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1601/c"},"text":"section 1601(c) of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2901"},"text":"section 2901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
