{"tag":"section","attrib":{"id":"idf0216620-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7785"},"text":null,"children":[{"tag":"num","attrib":{"value":"7785"},"text":"§ 7785.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Funds under this Act (other than those made available for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7784/f"},"text":"section 7784(f) of this title","children":[],"tail":") are intended to supplement, not replace, assistance available to weed management entities, areas, and districts for control or eradication of noxious weeds on Federal lands and non-Federal lands. The provision of funds to a weed management entity under this Act (other than those made available for "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7784/f"},"text":"section 7784(f) of this title","children":[],"tail":") shall have no effect on the amount of any payment received by a county from the Federal Government under chapter 69 of title 31."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf0216621-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tIV/s456"},"text":"Pub. L. 106–224, title IV, § 456","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/412/s1"},"text":"Pub. L. 108–412, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2324"},"text":"118 Stat. 2324","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0216622-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0216623-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0216624-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, probably means the Noxious Weed Control and Eradication Act of 2004, subtitle E (§§ 451–457) of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224"},"text":"Pub. L. 106–224","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/108/412/s1"},"text":"Pub. L. 108–412, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2320"},"text":"118 Stat. 2320","children":[],"tail":", which enacted this subchapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7701"},"text":"section 7701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
