idf026208c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7932/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of dry peas, United States feed peas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf026208d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7932/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of lentils, United States number 3 lentils; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf026208e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7932/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of small chickpeas, United States number 3 small chickpeas that drop below a 20/64 screen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf026208f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1202"},"text":"Pub. L. 107–171, title I, § 1202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/155"},"text":"116 Stat. 155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dA/tVII/s763/b"},"text":"Pub. L. 108–7, div. A, title VII, § 763(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/46"},"text":"117 Stat. 46","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0262090-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","top