{"tag":"section","attrib":{"id":"idede50a3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s65"},"text":null,"children":[{"tag":"num","attrib":{"value":"65"},"text":"§ 65.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter or the application thereof to any person or circumstances is held invalid, the validity of the remainder of the chapter and the application of such provision to other persons and circumstances shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idede50a3e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1923-03-04/ch288/s13"},"text":"Mar. 4, 1923, ch. 288, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1520"},"text":"42 Stat. 1520","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
