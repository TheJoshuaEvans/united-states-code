{"tag":"section","attrib":{"id":"idf0451a60-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8913"},"text":null,"children":[{"tag":"num","attrib":{"value":"8913"},"text":"§ 8913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to build local capacity in agricultural biosecurity planning, preparedness, and response","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0451a61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8913/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced training programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451a62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8913/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a competitive grant program to support the development and expansion of advanced training programs in agricultural biosecurity planning and response for food science professionals and veterinarians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8913/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451a64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8913/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2008 through 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8913/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0451a66-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8913/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of response capability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451a67-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8913/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant and loan assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a competitive grant and low-interest loan assistance program to assist States in assessing agricultural disease response capability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a68-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8913/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451a69-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8913/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for each of fiscal years 2008 through 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a6a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8913/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0451a6b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14113"},"text":"Pub. L. 110–234, title XIV, § 14113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1455"},"text":"122 Stat. 1455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14113, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2217; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7502"},"text":"Pub. L. 113–79, title VII, § 7502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/900"},"text":"128 Stat. 900","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7402"},"text":"Pub. L. 115–334, title VII, § 7402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"