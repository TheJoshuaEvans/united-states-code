{"tag":"section","attrib":{"id":"idef8ffbf0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3101"},"text":null,"children":[{"tag":"num","attrib":{"value":"3101"},"text":"§ 3101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes of agricultural research, extension, and education","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of federally supported agricultural research, extension, and education are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8ffbf1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the competitiveness of the United States agriculture and food industry in an increasingly competitive world environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffbf2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the long-term productivity of the United States agriculture and food industry while maintaining and enhancing the natural resource base on which rural America and the United States agricultural economy depend;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffbf3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop new uses and new products for agricultural commodities, such as alternative fuels, and develop new crops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffbf4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support agricultural research and extension to promote economic opportunity in rural communities and to meet the increasing demand for information and technology transfer throughout the United States agriculture industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffbf5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve risk management in the United States agriculture industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffbf6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3101/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the safe production and processing of, and adding of value to, United States food and fiber resources using methods that maintain the balance between yield and environmental soundness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffbf7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3101/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support higher education in agriculture to give the next generation of Americans the knowledge, technology, and applications necessary to enhance the competitiveness of United States agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffbf8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3101/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain an adequate, nutritious, and safe supply of food to meet human nutritional needs and requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffbf9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3101/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support international collaboration that leverages resources and advances priority food and agricultural interests of the United States, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8ffbfa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3101/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" addressing emerging plant and animal diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8ffbfb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3101/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving crop varieties and animal breeds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8ffbfc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3101/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing safe, efficient, and nutritious food systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8ffbfd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1402"},"text":"Pub. L. 95–113, title XIV, § 1402","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1602/a"},"text":"Pub. L. 101–624, title XVI, § 1602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"ta