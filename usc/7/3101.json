te","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1294"},"text":"95 Stat. 1294","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/98/tXIV/s1401"},"text":"“This title [enacting sections 2271, 2661 to 2667, 3124a, 3223, 3317 to 3319, 3321 to 3324, and 3331 to 3336 of this title, amending this section and sections 322, 361c, 390c, 3102, 3103, 3121 to 3124, 3125 to 3128, 3151 to 3154, 3157, 3175, 3177, 3191, 3192, 3194 to 3196, 3221, 3222, 3263, 3282, 3291, 3311, and 3312 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of Title 5","children":[],"tail":", Government Organization and Employees, sections 582a, 582a–1, and 582a–3 to 582a–5 of Title 16, Conservation, section 483 of former Title 40, Public Buildings, Property, and Works, and sections 6651 and 8852 of Title 42, The Public Health and Welfare, repealing sections 2670 and 3176 of this title, omitting "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2668"},"text":"section 2668 of this title","children":[],"tail":", and enacting provisions set out as notes under sections 2281 and 3176 of this title] may be cited as the ‘National Agricultural Research, Extension, and Teaching Policy Act Amendments of 1981’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idef8ffc07-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1935 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1935-06-29/ch338"},"text":"Act June 29, 1935, ch. 338","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/436"},"text":"49 Stat. 436","children":[],"tail":" (see Tables for classification), is popularly known as the “Agricultural Research Act” and also as the “Bankhead-Jones Act”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idef8ffc08-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1401"},"text":"Pub. L. 95–113, title XIV, § 1401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/981"},"text":"91 Stat. 981","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/113/tXIV/s1401"},"text":"“This title [enacting this chapter and sections 2669 and 2670 of this title, amending sections 341, 342, 343, 361c, 390 to 390j, 1923, 1942, 2662, 2663, 2667, 3104, and 3157 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6651"},"text":"section 6651 of Title 42","children":[],"tail":", The Public Health and Welfare, and repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s390k"},"text":"section 390k of this title","children":[],"tail":"] may be cited as the ‘National Agricultural Research, Extension, and Teaching Policy Act of 1977’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef8ffc09-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Review of Agricultural Research Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7404"},"text":"Pub. L. 107–171, title VII, § 7404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/457"},"text":"116 Stat. 457","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/11/tII/s2101/b"},"text":"Pub. L. 108–11, title