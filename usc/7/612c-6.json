{"tag":"section","attrib":{"id":"idee5076b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"612c–6"},"text":"§ 612c–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic food assistance programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee5076b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of section 32","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “section 32” means ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-24/s32"},"text":"section 32 of the Act of August 24, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"7 U.S.C. 612c","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee5076b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer to Food and Nutrition Service","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee5076b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts made available for a fiscal year to carry out section 32 in excess of the maximum amount calculated under paragraph (2) shall be transferred to the Secretary, acting through the Administrator of the Food and Nutrition Service, to be used to carry out the Richard B. Russell National School Lunch Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"42 U.S.C. 1751","children":[],"tail":" et seq.) "},{"tag":"ref","attrib":{"idref":"fn002117"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002117"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" except section 21 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1769b–1"},"text":"42 U.S.C. 1769b–1","children":[],"tail":"], and the Child Nutrition Act of 1966 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1771"},"text":"42 U.S.C. 1771","children":[],"tail":" et seq.), except sections 17 and 21 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1786"},"text":"42 U.S.C. 1786","children":[],"tail":", 1790]”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5076b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The maximum amount calculated under this paragraph for a fiscal year is the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee5076b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee5076b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of fiscal year 2009, $1,173,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee5076ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of fiscal year 2010, $1,199,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee5076bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of fiscal year 2011, $1,215,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee5076bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of fiscal year 2012, $1,231,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee5076bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of fiscal year 2013, $1,248,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee5076be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of fiscal year 2014, $1,266,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee5076bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of fiscal year 2015, $1,284,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee5076c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of fiscal year 2016, $1,303,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee5076c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b/2/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of fiscal year 2017, $1,322,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee5076c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b/2/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2018 and each fiscal year thereafter, the amount made available for the preceding fiscal year, as adjusted to reflect changes for the 12-month period ending on the preceding November 30 in the Consumer Price Index for All Urban Consumers published by the Bureau of Labor Statistics of the Department of Labor; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee5076c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any transfers for the fiscal year from section 32 to the Department of Commerce under the Fish and Wildlife Act of 1956 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s742a"},"text":"16 U.S.C. 742a","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee5076c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fresh fruit and vegetable program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of amounts made available to carry out section 32 under subsection (b)(2)(A), the Secretary shall transfer for use to carry out the fresh fruit and vegetable program under section 19 of the Richard B. Russell National School Lunch Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1769a"},"text":"42 U.S.C. 1769a","children":[],"tail":"] the amounts specified in subsection (i) of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee5076c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Whole grain products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of amounts made available to carry out section 32 under subsection (b)(2)(A), the Secretary shall use to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1755a"},"text":"section 1755a of title 42","children":[],"tail":" $4,000,000 for fiscal year 2009."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee5076c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–6/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The funding provided under subsections (c) and (d) shall supplement (and not supplant) other Federal funding (including section 32 funding) for programs carried out under—","children":[],"tail":null},{"ta