hort Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7501"},"text":"section 7501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2036"},"text":"Section 2036 of this title","children":[],"tail":", referred to in subsec. (e)(3), was in the original “section 27 of the Food Stamp Act of 1977”, and was translated as meaning "},{"tag":"ref","attrib":{"href":"/us/pl/88/525/s27"},"text":"section 27 of Pub. L. 88–525","children":[],"tail":", the Food and Nutrition Act of 2008, to reflect the probable intent of Congress and the renaming of the Act by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIV/s4001/a"},"text":"Pub. L. 110–246, title IV, § 4001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1853"},"text":"122 Stat. 1853","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee5076ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food, Conservation, and Energy Act of 2008, and not as part of the Agricultural Adjustment Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":