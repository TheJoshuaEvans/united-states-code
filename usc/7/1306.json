{"tag":"section","attrib":{"id":"idee742ad1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1306"},"text":null,"children":[{"tag":"num","attrib":{"value":"1306"},"text":"§ 1306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projected yields; determination; base period","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, in the determination of farm yields the Secretary may use projected yields in lieu of normal yields. In the determination of such yields the Secretary shall take into account the actual yield proved by the producer for the base period used in determining the projected yield, and the projected yield shall not be less than such actual yield proved by the producer.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee742ad2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/321/tVII/s708"},"text":"Pub. L. 89–321, title VII, § 708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-03"},"text":"Nov. 3, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1211"},"text":"79 Stat. 1211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/524/tIV/s405/b"},"text":"Pub. L. 91–524, title IV, § 405(b)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/86/s1/12/a"},"text":"Pub. L. 93–86, § 1(12)(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-10"},"text":"Aug. 10, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/229"},"text":"87 Stat. 229","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee742ad3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee742ad4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee742ad5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food and Agriculture Act of 1965, and not as part of the Agricultural Adjustment Act of 1938 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee742ad6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/524/s405/b"},"text":"Pub. L. 91–524, § 405(b)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/93/86"},"text":"Pub. L. 93–86","children":[],"tail":", temporarily inserted “(except that in the case of wheat, if the yield is abnormally low in any one of the calendar years of the base period because of drought, flood, or other natural disaster, the Secretary shall take into account the actual yield proved by the producer in the other four years of such base period)” after “determining the projected yield”. See Effective and Termination Dates of 1973 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee742ad7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee742ad8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/524/tIV/s405/b"},"text":"Pub. L. 91–524, title IV, § 405(b)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/93/86/s1/12/a"},"text":"Pub. L. 93–86, § 1(12)(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-08-10"},"text":"Aug. 10, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/229"},"text":"87 Stat. 229","children":[],"tail":", provided that the amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/91/524"},"text":"Pub. L. 91–524","children":[],"tail":" is effective with respect to the 1974 through 1977 crops."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
