{"tag":"section","attrib":{"id":"idef297122-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009e"},"text":"§ 2009e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef297123-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b) of this section, the State Director ","children":[{"tag":"ref","attrib":{"idref":"fn002229"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002229"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" of any State may, during any fiscal year, transfer from each account specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009d/c"},"text":"section 2009d(c) of this title","children":[],"tail":" a total of not more than 25 percent of the amount in the account that is allocated for the State for the fiscal year to any other account in which amounts are allocated for the State for the fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297124-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (c) of this section, a transfer otherwise authorized by subsection (a) of this section to be made during a fiscal year may not be made to the extent that the sum of the amount to be transferred and all amounts so transferred by State directors under subsection (a) of this section during the fiscal year exceeds 10 percent of the total amount made available to carry out the authorities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009d/d"},"text":"section 2009d(d) of this title","children":[],"tail":" for the fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297125-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (a) and (b) shall not apply to a transfer of funds by a State director if the State director certifies to the Secretary that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef297126-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is an approved application for a project in the function category to which the funds are to be transferred but funds are not available for the project in the function category; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef297127-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef297128-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009e/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no such approved application in the function category from which the funds are to be transferred; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef297129-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009e/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the community that would benefit from the project has a smaller population and a lesser per capita income than any community that would benefit from a project in the function category from which the funds are to be transferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef29712a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s381F"},"text":"Pub. L. 87–128, title III, § 381F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s761"},"text":"Pub. L. 104–127, title VII, § 761","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1142"},"text":"110 Stat. 1142","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
