{"tag":"section","attrib":{"id":"idf0130ede-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7612"},"text":null,"children":[{"tag":"num","attrib":{"value":"7612"},"text":"§ 7612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority setting process","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0130edf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3101"},"text":"section 3101 of this title","children":[],"tail":", the Secretary shall establish priorities for agricultural research, extension, and education activities conducted or funded by the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0130ee0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing priorities for agricultural research, extension, and education activities conducted or funded by the Department, the Secretary shall solicit and consider input and recommendations from persons who conduct or use agricultural research, extension, or education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0130ee1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of 1862, 1890, and 1994 Institutions and Hispanic-serving agricultural colleges and universities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0130ee2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7612/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":", to obtain agricultural research, extension, or education formula funds from the Secretary, each 1862 Institution, 1890 Institution, 1994 Institution, and Hispanic-serving agricultural college and university shall establish and implement a process for obtaining input from persons who conduct or use agricultural research, extension, or education concerning the use of the funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130ee3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7612/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall promulgate regulations that prescribe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0130ee4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7612/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements for an institution referred to in paragraph (1) to comply with paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130ee5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7612/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the consequences for an institution of not complying with paragraph (1), which may include the withholding or redistribution of funds to which the institution may be entitled until the institution complies with paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0130ee6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7612/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management principles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the maximum extent practicable, the Secretary shall ensure that federally supported and conducted agricultural research, extension, and education activities are accomplished in a manner that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0130ee7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7612/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrates agricultural research, extension, and education functions to better link research to technology transfer and information dissemination activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130ee8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7612/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourages regional and multistate programs to address relevant issues of common concern and to better leverage scarce resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130ee9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7612/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieves agricultural research, extension, and education objectives through multi-institutional and multifunctional approaches and by conducting research at facilities and institutions best equipped to achieve those objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0130eea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tI/s102"},"text":"Pub. L. 105–185, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/526"},"text":"112 Stat. 526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7129/c/2"},"text":"Pub. L. 110–234, title VII, § 7129(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1227"},"text":"122 Stat. 1227","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7129(c)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1988.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0130eeb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0130eec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf0130eed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf0130eee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7129/c/2"},"text":"Pub. L. 110–246, § 7129(c)(2)","children":[],"tail":", inserted “and Hispanic-serving agricultural colleges and universities” after “Institutions” in heading and substituted “1994 Institution, and Hispanic-serving agricultural college and university” for “and 1994 Institution” in par. (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0130eef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf0130ef0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
