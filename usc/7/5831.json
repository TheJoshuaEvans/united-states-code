{"tag":"section","attrib":{"id":"idefcdef5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5831"},"text":null,"children":[{"tag":"num","attrib":{"value":"5831"},"text":"§ 5831.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical guides and handbooks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcdef5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5831/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than two years after ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", the Secretary shall develop and make available handbooks and technical guides, and any other educational materials that are appropriate for describing sustainable agriculture production systems and practices, as researched and developed under this subchapter, chapter 86 of this title,"},{"tag":"ref","attrib":{"idref":"fn002310"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002310"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and other appropriate research programs of the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdef5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5831/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop the handbooks, technical guides, and educational materials in consultation with the Natural Resources Conservation Service and any other appropriate entities designated by the Secretary. The Secretary shall coordinate activities conducted under this section with those conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3861"},"text":"section 3861 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdef5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5831/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Topics of handbooks and guides","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The handbooks and guides, and other educational materials, shall include detailed information on the selection of crops and crop-plant varieties, rotation practices, soil building practices, tillage systems, nutrient management, integrated pest management practices, habitat protection, pest, weed, and disease management, livestock management, soil, water, and energy conservation, and any other practices in accordance with or in furtherance of the purpose of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdef5f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5831/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization and contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The handbooks and guides, and other educational materials, shall provide practical instructions and be organized in such a manner as to enable agricultural producers desiring to implement the practices and systems developed under this subchapter, chapter 86 of this title,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and other appropriate research programs of the Department to address site-specific, environmental and resource management problems and to sustain farm profitability, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdef60-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5831/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing and maintaining the fertility, productivity, and conservation of farmland and ranch soils, ranges, pastures, and wildlife;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5831/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizing the efficient and effective use of agricultural inputs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5831/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting or enhancing the quality of water resources; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5831/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" optimizing the use of on-farm and nonrenewable resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdef64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5831/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that handbooks and technical guides, and other educational materials are made available to the agricultural community and the public through colleges and universities, the State Cooperative Extension Service, the Soil Conservation Service, other State and Federal agencies, and any other appropriate entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcdef65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5831/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcdef66-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5831/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for fiscal year 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcdef67-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5831/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcdef68-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1628"},"text":"Pub. L. 101–624, title XVI, § 1628","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3740"},"text":"104 Stat. 3740","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIV/s407/3"},"text":"Pub. L. 102–237, title IV, § 407(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1864"},"text":"105 Stat. 1864","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII"},"text":"Pub. L. 104–127, title VIII","children":[],"tail":", §§ 860(c)(3), 862(b)(3), "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1174"},"text":"110 Stat. 1174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7203"},"text":"Pub. L. 113–79, title VII, § 7203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/880"},"text":"128 Stat. 880","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7203"},"text":"Pub. L. 115–334, title VII, § 7203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4803"},"text":"132 Stat. 4803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefcdef69-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefcdef6a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefcdef6b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (a), (c), and (d), was in the original “this subtitle”, meaning subtitle B (§§ 1619–1629) of title XVI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3733"},"text":"104 Stat. 3733","children":[],"tail":", which enacted this subchapter, repealed sections 4701 to 4710 of this title, and repealed provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4701"},"text":"section 4701 of this title","children":[],"tail":". For complete classification of subtitle B to the Code, see Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Chapter 86 of this title, referred to in subsecs. (a) and (d), was in the original “subtitle G of title XIV”, meaning subtitle G (§§ 1481–1485) of title XIV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", which was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tIII/s302/c"},"text":"Pub. L. 105–185, title III, § 302(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/563"},"text":"112 Stat. 563","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefcdef6c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" amended subsec. (f) generally. Prior to amendment, text read as follows: “There are authorized to be appropriated such sums as may be necessary to carry out the provisions of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s862/b/3"},"text":"Pub. L. 104–127, § 862(b)(3)","children":[],"tail":", struck out “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5881"},"text":"section 5881 of this title","children":[],"tail":",” before “and other appropriate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s860/c/3"},"text":"Pub. L. 104–127, § 860(c)(3)","children":[],"tail":", substituted “Natural Resources Conservation Service” for “Advisory Council, the Soil Conservation Service,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s862/b/3"},"text":"Pub. L. 104–127, § 862(b)(3)","children":[],"tail":", struck out “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5881"},"text":"section 5881 of this title","children":[],"tail":",” before “and other appropriate” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “educational” for “education”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
