{"tag":"section","attrib":{"id":"ideed13f88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1586"},"text":null,"children":[{"tag":"num","attrib":{"value":"1586"},"text":"§ 1586.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain acts prohibited","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for any person—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideed13f89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1586/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To sell or offer for sale—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideed13f8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1586/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any seed for seeding purposes if imported under this subchapter for other than seeding purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideed13f8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1586/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any screenings of any seeds for seeding purposes if imported under this subchapter for other than seeding purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideed13f8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1586/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any seed which is prohibited entry under the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideed13f8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1586/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To make any false or misleading representation with respect to any seed subject to this subchapter being imported into the United States or offered for import: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That this subsection shall not be deemed violated by any person if the false or misleading representation is the name of a variety indistinguishable in appearance from the seed being imported or offered for import and the records and other pertinent facts reveal that such person relied in good faith upon representations with respect to the name of the indistinguishable variety made by the shipper of the seed."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideed13f8e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-09/ch615"},"text":"Aug. 9, 1939, ch. 615","children":[],"tail":", title III, § 304, formerly § 306, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1285"},"text":"53 Stat. 1285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/581/s15"},"text":"Pub. L. 85–581, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-01"},"text":"Aug. 1, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/479"},"text":"72 Stat. 479","children":[],"tail":"; renumbered § 304, "},{"tag":"ref","attrib":{"href":"/us/pl/97/439/s5/b/4"},"text":"Pub. L. 97–439, § 5(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-08"},"text":"Jan. 8, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2288"},"text":"96 Stat. 2288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/tIV/s441/4"},"text":"Pub. L. 103–465, title IV, § 441(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-12-08"},"text":"Dec. 8, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4973"},"text":"108 Stat. 4973","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideed13f8f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideed13f90-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideed13f91-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(4) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s441/4/A"},"text":"Pub. L. 103–465, § 441(4)(A)","children":[],"tail":", struck out pars. (4) to (7) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) any seed which has been stained to resemble seed stained in accordance with the provisions of this chapter and the rules and regulations made and promulgated thereunder;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) any seed stained under the provisions of this chapter and the rules and regulations made and promulgated thereunder, when mixed with seed of the same kind produced in the United States;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) any seed stained with different colors;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) any seed stained under the provisions of this chapter, the labeling of which states that such seed is adapted.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465/s441/4/B"},"text":"Pub. L. 103–465, § 441(4)(B)","children":[],"tail":", (C), redesignated subsec. (c) as (b) and struck out former subsec. (b) which read as follows: “To change the proportion of seeds stained under the provisions of this chapter and the rules and regulations made and promulgated thereunder or to alter, modify, conceal, or remove in any manner or by any means the color of such stained seeds.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/581"},"text":"Pub. L. 85–581","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideed13f92-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideed13f93-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/465"},"text":"Pub. L. 103–465","children":[],"tail":" effective on the date of entry into force of the WTO Agreement with respect to the United States ("},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":"), except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/465/s451"},"text":"section 451 of Pub. L. 103–465","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3601"},"text":"section 3601 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideed13f94-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1610"},"text":"section 1610 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
