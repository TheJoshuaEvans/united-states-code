{"tag":"section","attrib":{"id":"idef8414fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2501"},"text":null,"children":[{"tag":"num","attrib":{"value":"2501"},"text":"§ 2501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reexamination after issue","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8414fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any person may, within five years after the issuance of a certificate of plant variety protection, notify the Secretary in writing of facts which may have a bearing on the protectability of the variety, and the Secretary may cause such plant variety protection to be reexamined in the light thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8414fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reexamination of plant variety protection under this section and appeals shall be pursuant to the same procedures and with the same rights as for original examinations. Abandonment of the procedure while subject to a ruling against the retention of the certificate shall result in cancellation of the plant variety certificate thereon and notice thereof shall be endorsed on copies of the description of the protected plant variety thereafter distributed by the Plant Variety Protection Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8414ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a person acting under subsection (a) makes a prima facie showing of facts needing proof, the Secretary may direct that the reexamination include such interparty proceedings as the Secretary shall establish.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef841500-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tII/s91"},"text":"Pub. L. 91–577, title II, § 91","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1552"},"text":"84 Stat. 1552","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/574/s17"},"text":"Pub. L. 96–574, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3351"},"text":"94 Stat. 3351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s13"},"text":"Pub. L. 103–349, § 13","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3144"},"text":"108 Stat. 3144","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef841501-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef841502-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef841503-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/349"},"text":"Pub. L. 103–349","children":[],"tail":" substituted “the Secretary” for “he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/574"},"text":"Pub. L. 96–574","children":[],"tail":" substituted “description” for “specification”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef841504-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef841505-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/349"},"text":"Pub. L. 103–349","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s15"},"text":"section 15 of Pub. L. 103–349","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2401"},"text":"section 2401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
