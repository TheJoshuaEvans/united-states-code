{"tag":"section","attrib":{"id":"idefaa39df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i"},"text":null,"children":[{"tag":"num","attrib":{"value":"3319i"},"text":"§ 3319i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity building grants for NLGCA Institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefaa39e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefaa39e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make competitive grants to NLGCA Institutions to assist the NLGCA Institutions in maintaining and expanding the capacity of the NLGCA Institutions to conduct education, research, and outreach activities relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefaa39e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa39e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" renewable resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa39e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other similar disciplines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaa39e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An NLGCA Institution that receives a grant under paragraph (1) may use the funds made available through the grant to maintain and expand the capacity of the NLGCA Institution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefaa39e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to successfully compete for funds from Federal grants and other sources to carry out educational, research, and outreach activities that address priority concerns of national, regional, State, and local interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa39e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to disseminate information relating to priority concerns to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefaa39e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interested members of the agriculture, renewable resources, and other relevant communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefaa39e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefaa39ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other interested entity;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa39eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage members of the agriculture, renewable resources, and other relevant communities to participate in priority education, research, and outreach activities by providing matching funding to leverage grant funds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa39ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" through—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefaa39ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase or other acquisition of equipment and other infrastructure (not including alteration, repair, renovation, or construction of buildings);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefaa39ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the professional growth and development of the faculty of the NLGCA Institution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefaa39ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of graduate assistantships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefaa39f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as are necessary for each of fiscal years 2008 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefaa39f1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1473F"},"text":"Pub. L. 95–113, title XIV, § 1473F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7138"},"text":"Pub. L. 110–234, title VII, § 7138","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1230"},"text":"122 Stat. 1230","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7138, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008