{"tag":"section","attrib":{"id":"idefd05fa4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842"},"text":null,"children":[{"tag":"num","attrib":{"value":"5842"},"text":"§ 5842.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and authority of Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd05fa5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be at the head of the program an official to be known as the Director of the National Genetic Resources Program who shall be appointed by the Secretary. The Director shall perform such duties as are assigned to the Director by this subchapter and such other duties as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fa6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subchapter, the Secretary, acting through the Director—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd05fa7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be responsible for the overall direction of the program and for the establishment and implementation of general policies respecting the management and operation of activities within the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fa8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may secure for the program consultation services and advice of persons from the United States and abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fa9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accept voluntary and uncompensated services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05faa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may perform such other administrative functions as the Secretary determines are needed to effectively carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd05fac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise participants on the program activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate, review and facilitate the systematic identification and evaluation of, relevant information generated under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the effective transfer of the information described in paragraph (2) to the agriculture and food production community and to entities that require such information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05faf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the effectiveness of the activities described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall prepare and transmit to the Secretary and to the Congress a biennial report containing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd05fb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities carried out by and through the program and the policies of the program, and such recommendations respecting such activities and policies as the Director considers to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the necessity for, and progress achieved toward providing, additional programs and activities designed to include the range of genetic resources described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5841/d/5"},"text":"section 5841(d)(5) of this title","children":[],"tail":" in the activities of the program; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of events and activities occurring internationally as they relate to the activities and policies of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", the Director shall transmit to the Secretary and to the Congress a report—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd05fb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing the projected needs over a 10-year period in each of the areas of genetic resources described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5841/d/5"},"text":"section 5841(d)(5) of this title","children":[],"tail":", including the identification of existing components of a comprehensive program, policies and activities needed to coordinate those components, and additional elements not in existence which are required for the development of a comprehensive genetic resources program as described in such section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the international efforts and activities related to the program, and their effect upon and coordination with the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05fb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the potential effect of various national laws, including national quarantine requirements, as well as treaties, agreements, and the activities of international organizations on the development of a comprehensive international system for the collection and maintenance of genetic resources of importance to agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05fb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5842/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On completion of the development of the plan described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5841/d/6"},"text":"section 5841(d)(6) of this title","children":[],"tail":", the Secretary shall make the plan available to the public."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd05fb9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1633"},"text":"Pub. L. 101–624, title XVI, § 1633","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3744"},"text":"104 Stat. 3744","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIV/s404/a/2"},"text":"Pub. L. 102–237, title IV, § 404(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1864"},"text":"105 Stat. 1864","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7205/b"},"text":"Pub. L. 115–334, title VII, § 7205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4803"},"text":"132 Stat. 4803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefd05fba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefd05fbb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefd05fbc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “Resources Program” for “Resources program”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefd05fbd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefd05fbe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions in subsec. (d) of this section relating to biennial reports to Congress, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 49 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
