{"tag":"section","attrib":{"id":"idefa09cdc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3199"},"text":null,"children":[{"tag":"num","attrib":{"value":"3199"},"text":"§ 3199.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"With respect to research projects on problems of animal health and disease to be performed at eligible institutions and supported with funds allocated to the States under subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3195"},"text":"section 3195 of this title","children":[],"tail":" to carry out subsection (a) of such section, the dean or director of each eligible institution shall cause to be prepared and shall review proposals for such research projects, which contain data showing compliance with the purpose in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3191"},"text":"section 3191 of this title","children":[],"tail":" and the provisions for use of funds specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3195/a"},"text":"section 3195(a) of this title","children":[],"tail":", and with general guidelines for project eligibility to be provided by the Secretary. Such research proposals that are approved by the dean or director shall be submitted to the Secretary prior to assignment of funds thereto with a brief summary showing compliance with the provisions of this subtitle and the Secretary’s general guidelines."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefa09cdd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1437"},"text":"Pub. L. 95–113, title XIV, § 1437","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1004"},"text":"91 Stat. 1004","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s606/d/4"},"text":"Pub. L. 105–185, title VI, § 606(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/604"},"text":"112 Stat. 604","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7111/b/3/D"},"text":"Pub. L. 113–79, title VII, § 7111(b)(3)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/874"},"text":"128 Stat. 874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa09cde-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa09cdf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefa09ce0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “States under subsection (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3195"},"text":"section 3195 of this title","children":[],"tail":" to carry out subsection (a) of such section” for “States under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3195"},"text":"section 3195 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185"},"text":"Pub. L. 105–185","children":[],"tail":" struck out “with the advice, when available, of the Board” after “by the Secretary” in first sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefa09ce1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefa09ce2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
