{"tag":"section","attrib":{"id":"idee553183-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s627"},"text":null,"children":[{"tag":"num","attrib":{"value":"627"},"text":"§ 627.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dairy forward pricing pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee553184-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s627/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1999-11-29"},"text":"November 29, 1999","children":[],"tail":", the Secretary of Agriculture shall establish a temporary pilot program under which milk producers and cooperatives are authorized to voluntarily enter into forward price contracts with milk handlers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee553185-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s627/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum milk price requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payments made by milk handlers to milk producers and cooperatives, and prices received by milk producers and cooperatives, under the forward contracts shall be deemed to satisfy—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee553186-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s627/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all regulated minimum milk price requirements of paragraphs (B) and (F) of subsection (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s608c"},"text":"section 608c of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee553187-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s627/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement of paragraph (C) of such subsection regarding total payments by each handler.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee553188-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s627/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Milk covered by pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee553189-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s627/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered milk","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The pilot program shall apply only with respect to the marketing of federally regulated milk that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee55318a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s627/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not classified as Class I milk or otherwise intended for fluid use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee55318b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s627/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the current of interstate or foreign commerce or directly burdens, obstructs, or affects interstate or foreign commerce in federally regulated milk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee55318c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s627/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to Class I milk","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist milk handlers in complying with the limitation in paragraph (1)(A) without having to segregate or otherwise individually track the source and disposition of milk, a milk handler may allocate milk receipts from producers, cooperatives, and other sources that are not subject to a forward contract to satisfy the handler’s obligations with regard to Class I milk usage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee55318d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s627/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Secretary of Agriculture to carry out the pilot program shall terminate on ","children":[{"tag":"date","attrib":{"date":"2004-12-31"},"text":"December 31, 2004","children":[],"tail":". No forward price contract entered into under the program may extend beyond that date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee55318e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s627/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report on effect of pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee55318f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s627/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall conduct a study on forward contracting between milk producers and cooperatives and milk handlers to determine the impact on milk prices paid to producers in the United States. To obtain information for the study, the Secretary may use the authorities available to the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s608d"},"text":"section 608d of this title","children":[],"tail":", subject to the confidentiality requirements of subsection (2) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee553190-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s627/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2002-04-30"},"text":"April 30, 2002","children":[],"tail":", the Secretary shall submit to the Committee on Agriculture, Nutrition and Forestry of the Senate and the Committee on Agriculture of the House of Representatives a report containing the results of the study."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee553191-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-12/ch25"},"text":"May 12, 1933, ch. 25","children":[],"tail":", title I, § 23, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/8/s3"},"text":"Pub. L. 106–113, div. B, § 1000(a)(8) [§ 3]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–519.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee553192-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee553193-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee553194-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 23 of act ","children":[{"tag":"date","attrib":{"date":"1933-05-12"},"text":"May 12, 1933","children":[],"tail":" amended former "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s781"},"text":"section 781 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
