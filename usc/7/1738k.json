{"tag":"section","attrib":{"id":"ideef9aea0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738k"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738k"},"text":"§ 1738k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible activities and grantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef9aea1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities eligible to receive assistance through the framework agreements entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738f"},"text":"section 1738f of this title","children":[],"tail":", shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef9aea2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities of the type described in the Global Environmental Protection Assistance Act of 1989 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2281"},"text":"22 U.S.C. 2281","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9aea3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agriculture-related activities, including those that provide for the biological prevention and control of animal and plant pests and diseases, to benefit the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9aea4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local community initiatives that promote conservation and sustainable use of the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aea5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All activities of the type referred to in subsection (a) shall, where appropriate, include initiatives that link conservation of natural resources with local community development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aea6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Setting of priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Appropriate activities and priorities relating to the use of an Environmental Fund shall be set by local nongovernmental organizations within the appropriate eligible country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aea7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants may be made by the body referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738f/c"},"text":"section 1738f(c) of this title","children":[],"tail":" from the Environmental Fund for environmental purposes to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef9aea8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738k/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" host country nongovernmental environmental, conservation, development, educational, and indigenous peoples organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9aea9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738k/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate local or regional entities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9aeaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738k/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in exceptional circumstances, the government of the eligible country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9aeab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738k/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing assistance from an Environmental Fund, the body established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738f/c"},"text":"section 1738f(c) of this title","children":[],"tail":" within the eligible country shall give priority to projects that are run by nongovernmental organizations and other private entities, and that involve local communities in their planning and execution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef9aeac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title VI, § 612, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3661"},"text":"104 Stat. 3661","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s306"},"text":"Pub. L. 102–237, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1856"},"text":"105 Stat. 1856","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef9aead-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef9aeae-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideef9aeaf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Global Environmental Protection Assistance Act of 1989, referred to in subsec. (a)(1), is title VII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/240"},"text":"Pub. L. 101–240","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-19"},"text":"Dec. 19, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2521"},"text":"103 Stat. 2521","children":[],"tail":", which is classified generally to part VII (§ 2281 et seq.) of subchapter I of chapter 32 and chapter 86 (§ 7901 et seq.) of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title of 1989 Amendments note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideef9aeb0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “2281 et seq.);” for “462), and—”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
