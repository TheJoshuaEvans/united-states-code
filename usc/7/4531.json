{"tag":"section","attrib":{"id":"idefb86aec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4531"},"text":null,"children":[{"tag":"num","attrib":{"value":"4531"},"text":"§ 4531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefb86aed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4531/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “board” means the board of trustees of the Institute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb86aee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4531/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Department” means the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb86aef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4531/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “dairy products” means manufactured products that are derived from the processing of milk, and includes fluid milk products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb86af0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4531/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “fluid milk products” means those milk products normally consumed in liquid form as a beverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb86af1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4531/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Fund” means the Dairy Research Trust Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4536"},"text":"section 4536 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb86af2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4531/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Institute” means the National Dairy Research Endowment Institute established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4532"},"text":"section 4532 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb86af3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4531/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “milk” means any class of cow’s milk marketed in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb86af4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4531/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” means any individual, group of individuals, partnership, corporation, association, cooperative, or any other entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb86af5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4531/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “producer” means any person engaged in the production of milk for commercial use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb86af6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4531/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “research” means studies testing the effectiveness of market development and promotion efforts, studies relating to the nutritional value of milk and dairy products, and other related efforts to expand demand for milk and dairy products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb86af7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4531/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Agriculture unless the context specifies otherwise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb86af8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4531/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “United States”, when used in a geographical sense, means all of the States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb86af9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/180/tI/s130"},"text":"Pub. L. 98–180, title I, § 130","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tI/s121"},"text":"Pub. L. 99–198, title I, § 121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1367"},"text":"99 Stat. 1367","children":[],"tail":"; amended "},{"tag":"ref","attrib":{