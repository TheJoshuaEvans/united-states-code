{"tag":"section","attrib":{"id":"idee932434-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1379i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1379i"},"text":"§ 1379i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee932435-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1379i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeitures; amount; civil action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who knowingly violates or attempts to violate or who knowingly participates or aids in the violation of any of the provisions of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1379d"},"text":"section 1379d of this title","children":[],"tail":" shall forfeit to the United States a sum equal to two times the face value of the marketing certif­icates involved in such violation. Such forfeiture shall be recoverable in a civil action brought in the name of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee932436-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1379i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misdemeanors; punishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person, except a producer in his capacity as a producer, who knowingly violates or attempts to violate or who knowingly participates or aids in the violation of any provision of this part, or of any regulation, governing the acquisition, disposition, or handling of marketing certificates or who knowingly fails to make any report or keep any record as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1379h"},"text":"section 1379h of this title","children":[],"tail":" shall be deemed guilty of a misdemeanor and upon conviction thereof shall be subject to a fine of not more than $5,000 for each violation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee932437-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1379i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forfeiture of right to receive certificates; payment of face value","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who, in his capacity as a producer, knowingly violates or attempts to violate or participates or aids in the violation of any provision of this part, or of any regulation, governing the acquisition, disposition, or handling of marketing certificates or fails to make any report or keep any record as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1379h"},"text":"section 1379h of this title","children":[],"tail":" shall, (i) forfeit any right to receive marketing certificates, in whole or in part as the Secretary may determine, with respect to the farm or farms and for the marketing year with respect to which any such act or default is committed, or (ii), if such marketing certificates have already been issued, pay to the Secretary, upon demand, the amount of the face value of such certificates, or such part thereof as the Secretary may determine. Such determination by the Secretary with respect to the amount of such marketing certificates to be forfeited or the amount to be paid by such producer shall take into consideration the circumstances relating to the act or default committed and the seriousness of such act or default."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee932438-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1379i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Felonies; punishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who falsely makes, issues, alters, forges, or counterfeits any marketing certificate, or with fraudulent intent possesses, transfers, or uses any such falsely made, issued, altered, forged, or counterfeited marketing certificate, shall be deemed guilty of a felony and upon conviction thereof shall be subject to a fine of not more than $10,000 or imprisonment of not more than ten years, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee932439-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 379i, as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/703/tIII/s324/2"},"text":"Pub. L. 87–703, title III, § 324(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-09-27"},"text":"Sept. 27, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/629"},"text":"76 Stat. 629","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/89/321/tV/s510/b"},"text":"Pub. L. 89–321, title V, § 510(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-11-03"},"text":"Nov. 3, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1205"},"text":"79 Stat. 1205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee93243a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee93243b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":