{"tag":"section","attrib":{"id":"idf0289180-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953"},"text":null,"children":[{"tag":"num","attrib":{"value":"7953"},"text":"§ 7953.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of direct payments for peanuts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0289181-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0289182-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2002 crop year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the 2002 crop year, the Secretary shall make direct payments under this section to historic peanut producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0289183-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent crop years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of the 2003 through 2007 crop years for peanuts, the Secretary shall make direct payments to the producers on a farm to which a payment yield and base acres for peanuts are assigned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7952"},"text":"section 7952 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0289184-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The payment rate used to make direct payments with respect to peanuts for a crop year shall be equal to $36 per ton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0289185-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment amount for 2002 crop year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the direct payment to be paid to an historic peanut producer for the 2002 crop of peanuts shall be equal to the product of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0289186-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment rate specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0289187-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment acres of the historic peanut producer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0289188-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average peanut yield determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7952/a/1"},"text":"section 7952(a)(1) of this title","children":[],"tail":" for the historic peanut producer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0289189-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment amount for subsequent crop years","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of the direct payment to be paid to the producers on a farm for the 2003 through 2007 crops of peanuts shall be equal to the product of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf028918a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment rate specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf028918b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment acres on the farm.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf028918c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment yield for the farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf028918d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for payment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf028918e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make direct payments—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf028918f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the 2002 crop year, as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0289190-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of each of the 2003 through 2007 crop years, not later than September 30 of the calendar year in which the crop is harvested.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0289191-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the option of the producers on a farm, up to 50 percent of the direct payment for any of the 2003 through 2005 crop years, up to 40 percent of the direct payment for the 2006 crop year, and up to 22 percent of the direct payment for the 2007 crop year, shall be paid to the producers in advance. The producers shall select the month within which the advance payment for a crop year will be made. The month selected may be any month during the period beginning on December 1 of the calendar year before the calendar year in which the crop is harvested through the month within which the direct payment would otherwise be made. The producers may change the selected month for a subsequent advance payment by providing advance notice to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0289192-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7953/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of advance payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a producer on a farm that receives an advance direct payment for a crop year ceases to be a producer on that farm, or the extent to which the producer shares in the risk of producing a crop changes, before the date the remainder of the direct payment is made, the producer shall be responsible for repaying the Secretary the applicable amount of the advance payment, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0289193-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1303"},"text":"Pub. L. 107–171, title I, § 1303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/170"},"text":"116 Stat. 170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tI/s1102/b"},"text":"Pub. L. 109–171, title I, § 1102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/5"},"text":"120 Stat. 5","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0289194-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0289195-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf0289196-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171"},"text":"Pub. L. 109–171","children":[],"tail":" substituted “2005 crop years, up to 40 percent of the direct payment for the 2006 crop year, and up to 22 percent of the direct payment for the 2007 crop year,” for “2007 crop years”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
