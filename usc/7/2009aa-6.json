{"tag":"section","attrib":{"id":"idef2bbb47-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009aa–6"},"text":"§ 2009aa–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development planning process","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef2bbb48-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State development plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with policies established by the Authority, each State member shall submit a development plan for the area of the region represented by the State member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2bbb49-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State development plan submitted under subsection (a) shall reflect the goals, objectives, and priorities identified in the regional development plan developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009aa–1/d/2"},"text":"section 2009aa–1(d)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2bbb4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with interested local parties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the development planning process (including the selection of programs and projects for assistance), a State may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2bbb4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–6/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2bbb4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–6/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local development districts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2bbb4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–6/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local units of government; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbb4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–6/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration the goals, objectives, priorities, and recommendations of the entities described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2bbb4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2bbb50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–6/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority and applicable State and local development districts shall encourage and assist, to the maximum extent practicable, public participation in the development, revision, and implementation of all plans and programs under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbb51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–6/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall develop guidelines for providing public participation described in paragraph (1), including public hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef2bbb52-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s382G"},"text":"Pub. L. 87–128, title III, § 382G","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tV/s503"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title V, § 503]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–278.)"}],"tail":"\n"}],"tail":null}
