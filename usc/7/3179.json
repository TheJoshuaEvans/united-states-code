{"tag":"section","attrib":{"id":"idef9e2c34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179"},"text":null,"children":[{"tag":"num","attrib":{"value":"3179"},"text":"§ 3179.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research on strategies to promote the selection and consumption of healthy foods","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9e2c35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Health and Human Services, shall establish a research, demonstration, and technical assistance program to promote healthy eating and reduce the prevalence of obesity, among all population groups but especially among children, by applying the principles and insights of behavioral economics research in schools, child care programs, and other settings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9e2c36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9e2c37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and assess the impacts of specific presentation, placement, and other strategies for structuring choices on selection and consumption of healthful foods in a variety of settings, consistent with the most recent version of the Dietary Guidelines for Americans published under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5341"},"text":"section 5341 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate and rigorously evaluate behavioral economics-related interventions that hold promise to improve diets and promote health, including through demonstration projects that may include evaluation of the use of portion size, labeling, convenience, and other strategies to encourage healthy choices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage adoption of the most effective strategies through outreach and technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9e2c3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program under subsection (a), the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9e2c3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into competitively awarded contracts or cooperative agreements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide grants to States or public or private agencies or organizations, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9e2c3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to enter into a contract or cooperative agreement or receive a grant under this section, a State or public or private agency or organization shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9e2c3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The solicitation and evaluation of contracts, cooperative agreements, and grant proposals considered under this section shall be coordinated with the Food and Nutrition Service as appropriate to ensure that funded projects are consistent with the operations of Federally supported nutrition assistance programs and related laws (including regulations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9e2c3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the end of each fiscal year, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that includes a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9e2c40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the policies, priorities, and operations of the program carried out by the Secretary under this section during the fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of any evaluations completed during the fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts undertaken to disseminate successful practices through outreach and technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9e2c43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9e2c44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as are necessary for each of fiscal years 2011 through 2015.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3179/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use up to 5 percent of the funds made available under paragraph (1) for Federal administrative expenses incurred in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9e2c46-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/296/tII/s244"},"text":"Pub. L. 111–296, title II, § 244","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-13"},"text":"Dec. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3239"},"text":"124 Stat. 3239","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9e2c47-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef9e2c48-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef9e2c49-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Healthy, Hunger-Free Kids Act of 2010, and not as part of the National Agricultural Research, Extension, and Teaching Policy Act of 1977 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef9e2c4a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef9e2c4b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2010-10-01"},"text":"Oct. 1, 2010","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/296/s445"},"text":"section 445 of Pub. L. 111–296","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idef9e2c4c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of Secretary","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/296/s2"},"text":"Pub. L. 111–296, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-13"},"text":"Dec. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3185"},"text":"124 Stat. 3185","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/296/s2"},"text":"“In this Act [see Short Title of 2010 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1751"},"text":"section 1751 of Title 42","children":[],"tail":", The Public Health and Welfare], the term ‘Secretary’ means the Secretary of Agriculture.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
