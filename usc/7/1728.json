{"tag":"section","attrib":{"id":"ideeedc7f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1728"},"text":null,"children":[{"tag":"num","attrib":{"value":"1728"},"text":"§ 1728.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings regarding emergency food assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeedc7f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1728/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acute food crises continue to cause loss of life, severe malnutrition, and general human suffering in many areas of the Third World, especially in sub-Saharan Africa;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1728/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States continues to respond to these needs, as a reflection of its humanitarian concern for the people of the Third World, with emergency food and other necessary assistance to alleviate the suffering of those affected by severe food shortages;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1728/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the timely provision of food and other necessary assistance to those in need is of paramount importance if the worst effects of such food crises are to be mitigated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1728/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the United States to provide food and other necessary assistance on a timely basis, and to ensure that such assistance is distributed to those in need, should be enhanced in order to better enable the United States to help those affected by severe food shortages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeedc7f8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tIII/s302"},"text":"Pub. L. 98–473, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2194"},"text":"98 Stat. 2194","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeedc7f9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeedc7fa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideeedc7fb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the President’s Emergency Food Assistance Act of 1984, and not as part of the Food for Peace Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeedc7fc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"ideeedc7fd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tIII/s301"},"text":"Pub. L. 98–473, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2194"},"text":"98 Stat. 2194","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/473/tIII/s301"},"text":"“This title [enacting this subchapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1723"},"text":"section 1723 of this title","children":[],"tail":"] may be cited as the ‘President’s Emergency Food Assistance Act of 1984’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
