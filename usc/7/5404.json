{"tag":"section","attrib":{"id":"idefc6c30b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5404"},"text":null,"children":[{"tag":"num","attrib":{"value":"5404"},"text":"§ 5404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Good Neighbor Environmental Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefc6c30c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish an advisory board to be known as the Good Neighbor Environmental Board (hereinafter in this section referred to as the “Board”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc6c30d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Board shall be to advise the President and the Congress on the need for implementation of environmental and infrastructure projects (including projects that affect agriculture, rural development, and human nutrition) within the States of the United States contiguous to Mexico in order to improve the quality of life of persons residing on the United States side of the border.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc6c30e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc6c30f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5404/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from the United States Government, including a representative from the Department of Agriculture and representatives from other appropriate agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c310-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5404/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from the governments of the States of Arizona, California, New Mexico, and Texas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c311-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5404/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from private organizations, including community development, academic, health, environmental, and other nongovernmental entities with experience and expertise on environmental and infrastructure problems along the southwest border.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc6c312-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5404/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports to President and Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc6c313-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5404/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall submit to the President and the Congress of the United States an annual report on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc6c314-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5404/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the environmental and infrastructure projects referred to in subsection (a) that have been implemented, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc6c315-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5404/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for the implementation of additional environmental and infrastructure projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c316-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5404/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission of copies to Board members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc6c317-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5404/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit to each member of the Board a copy of any report to be submitted pursuant to paragraph (1) at least 14 days before its submission, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc6c318-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5404/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow each member of the Board to have 14 days within which to prepare and submit supplemental views with respect to the recommendations of the Board for inclusion in such report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc6c319-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/532/s6"},"text":"Pub. L. 102–532, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-27"},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3513"},"text":"106 Stat. 3513","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefc6c31a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefc6c31b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefc6c31c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Enterprise for the Americas Initiative Act of 1992, and not as part of subtitle F (§ 1471 et seq.) of title XIV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefc6c31d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefc6c31e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Boards","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory boards established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of the 2-year period beginning on the date of their establishment, unless, in the case of a board established by the President or an officer of the Federal Government, such board is renewed by appropriate action prior to the expiration of such 2-year period, or in the case of a board established by Congress, its duration is otherwise provided by law. See sections 1001(2) and 1013 of Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idefc6c31f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefc6c320-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Authority","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority of President under this section delegated to Administrator of Environmental Protection Agency by section 10 of Ex. Ord. No. 12916, ","children":[{"tag":"date","attrib":{"date":"1994-05-13"},"text":"May 13, 1994","children":[],"tail":", 59 F.R. 25780, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3473"},"text":"section 3473 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
