{"tag":"section","attrib":{"id":"idee684398-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"950aaa–2"},"text":"§ 950aaa–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telemedicine and distance learning services in rural areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee684399-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services to rural areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide financial assistance for the purpose of financing the construction of facilities and systems to provide telemedicine services and distance learning services in rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee68439a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee68439b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Financial assistance shall consist of grants or cost of money loans, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee68439c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine the portion of the financial assistance provided to a recipient that consists of grants and the portion that consists of cost of money loans so as to result in the maximum feasible repayment to the Federal Government of the financial assistance, based on the ability to repay of the recipient and full utilization of funds made available to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee68439d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recipients","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee68439e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide financial assistance under this chapter to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee68439f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities using telemedicine services or distance learning services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee6843a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entities providing or proposing to provide telemedicine service or distance learning service to other persons at rates calculated to ensure that the benefit of the financial assistance is passed through to the other persons; ","children":[{"tag":"ref","attrib":{"idref":"fn002130"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002130"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “and”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee6843a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" libraries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electric or telecommunications borrowers","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee6843a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans to borrowers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), the Secretary may provide a cost of money loan under this chapter to a borrower of an electric or telecommunications loan under the Rural Electrification Act of 1936 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s901"},"text":"7 U.S.C. 901","children":[],"tail":" et seq.). A borrower receiving a cost of money loan under this paragraph shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"idee6843a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the funds provided available to entities that qualify under paragraph (1) for projects satisfying the requirements of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee6843a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the funds provided to acquire, install, improve, or extend a system referred to in subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee6843a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the funds provided to install, improve, or extend a facility referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee6843a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A borrower of an electric or telecommunications loan under the Rural Electrification Act of 1936 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s901"},"text":"7 U.S.C. 901","children":[],"tail":" et seq.] shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"idee6843a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a system or facility funded under subparagraph (A) available to entities that qualify under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee6843a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neither retain from the proceeds of a loan provided under subparagraph (A), nor assess a qualifying entity under paragraph (1), any amount except as may be required to pay the actual costs incurred in administering the loan or making the system or facility available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary rejects the application of a borrower who applies for a cost of money loan or grant under this section, the borrower may appeal the decision to the Secretary not later than 10 days after the borrower is notified of the rejection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to provide or improve services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Financial assistance may be provided under this chapter for a facility regardless of the location of the facility if the Secretary determines that the assistance is necessary to provide or improve telemedicine services or distance learning services in a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6843ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish procedures to prioritize financial assistance under this chapter considering—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee6843ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need for the assistance in the affected rural area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial need of the applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population sparsity of the affected rural area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local involvement in the project serving the affected rural area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic diversity among the recipients of financial assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the utilization of the telecommunications facilities of any telecommunications provider serving the affected rural area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the portion of total project financing provided by the applicant from the funds of the applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the portion of project financing provided by the applicant with funds obtained from non-Federal sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the joint utilization of facilities financed by other financial assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of the proposed project with regional projects or networks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service to the greatest practical number of persons within the general geographic area covered by the financial assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conformity with the State strategic plan as prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009c"},"text":"section 2009c of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/d/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6843ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount of assistance to individual recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish the maximum amount of financial assistance to be made available to an individual recipient for each fiscal year under this chapter, by publishing notice of the maximum amount in the Federal Register not more than 45 days after funds are made available for the fiscal year to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6843bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Financial assistance provided under this chapter shall be used for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee6843bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and acquisition of instructional programming;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and acquisition, through lease or purchase, of computer hardware and software, audio and visual equipment, computer network components, telecommunications terminal equipment, telecommunications transmission facilities, data terminal equipment, or interactive video equipment, or other facilities that would further telemedicine services or distance learning services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing technical assistance and instruction for the development or use of the programming, equipment, or facilities referred to in paragraphs (1) and (2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other uses that are consistent with this chapter, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6843c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Salaries and expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (f), financial assistance provided under this chapter shall not be used for paying salaries or administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6843c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expediting coordinated telephone loans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee6843c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish and carry out procedures to ensure that expedited consideration and determination is given to applications for loans and advances of funds submitted by local exchange carriers under this chapter and the Rural Electrification Act of 1936 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s901"},"text":"7 U.S.C. 901","children":[],"tail":" et seq.) to enable the exchange carriers to provide advanced telecommunications services in rural areas in conjunction with any other projects carried out under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline imposed on Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 45 days after the receipt of a completed application for an expedited telephone loan under paragraph (1), the Secretary shall notify the applicant in writing of the decision of the Secretary regarding the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6843c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of local exchange carrier","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee6843c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each applicant for a grant for a telemedicine or distance learning project established under this chapter shall notify the appropriate local telephone exchange carrier regarding the application filed with the Secretary for the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee6843c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee6843c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish notice of applications received for grants under this chapter for telemedicine or distance learning projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee6843c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–2/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the applications available for inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee6843c9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2333"},"text":"Pub. L. 101–624, title XXIII, § 2333","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s704"},"text":"Pub. L. 104–127, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":