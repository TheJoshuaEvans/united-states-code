{"tag":"section","attrib":{"id":"idef8d8ac8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814"},"text":null,"children":[{"tag":"num","attrib":{"value":"2814"},"text":"§ 2814.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management of undesirable plants on Federal lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8d8ac9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of agencies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Federal agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8d8aca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate an office or person adequately trained in the management of undesirable plant species to develop and coordinate an undesirable plants management program for control of undesirable plants on Federal lands under the agency’s jurisdiction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8acb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and adequately fund an undesirable plants management program through the agency’s budgetary process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8acc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete and implement cooperative agreements with State agencies regarding the management of undesirable plant species on Federal lands under the agency’s jurisdiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8acd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish integrated management systems to control or contain undesirable plant species targeted under cooperative agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8d8ace-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental impact statements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event an environmental assessment or environmental impact statement is required under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) to implement plant control agreements, Federal agencies shall complete such assessments or statements within 1 year after the requirement for such assessment or statement is ascertained."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8d8acf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements with State agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8d8ad0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal agencies, as appropriate, shall enter into cooperative agreements with State agencies to coordinate the management of undesirable plant species on Federal lands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8ad1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A cooperative agreement entered into pursuant to paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8d8ad2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize and target undesirable plant species or group of species to be controlled or contained within a specific geographic area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8ad3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the integrated management system to be used to control or contain the targeted undesirable plant species or group of species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8ad4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detail the means of implementing the integrated management system, define the duties of the Federal agency and the State agency in prosecuting that method, and establish a timeframe for the initiation and completion of the tasks specified in the integrated management system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8d8ad5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal agency is not required under this section to carry out programs on Federal lands unless similar programs are being implemented generally on State or private lands in the same area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8d8ad6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8d8ad7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cooperative agreement” means a written agreement between a Federal agency and a State agency entered into pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8ad8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal agency” means a department, agency, or bureau of the Federal Government responsible for administering or managing Federal lands under its jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8ad9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal lands","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal lands” means lands managed by or under the jurisdiction of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8ada-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated management system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “integrated management systems” means a system for the planning and implementation of a program, using an interdisciplinary approach, to select a method for containing or controlling an undesirable plant species or group of species using all available methods, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8d8adb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8adc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventive measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8add-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical or mechanical methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8ade-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biological agents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8adf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" herbicide methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8ae0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cultural methods; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8ae1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general land management practices such as manipulation of livestock or wildlife grazing strategies or improving wildlife or livestock habitat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8ae2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interdisciplinary approach","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “interdisciplinary approach” means an approach to making decisions regarding the containment or control of an undesirable plant species or group of species, which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8d8ae3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes participation by personnel of Federal or State agencies with experience in areas including weed science, range science, wildlife biology, land management, and forestry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8ae4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes consideration of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef8d8ae5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most efficient and effective method of containing or controlling the undesirable plant species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef8d8ae6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific evidence and current technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef8d8ae7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/5/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the physiology and habitat of a plant species; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef8d8ae8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/5/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic, social, and ecological consequences of implementing the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8ae9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State agency” means a State department of agriculture, or other State agency or political subdivision thereof, responsible for the administration or implementation of undesirable plants laws of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8aea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Undesirable plant species","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “undesirable plants” means plant species that are classified as undesirable, noxious, harmful, exotic, injurious, or poisonous, pursuant to State or Federal law. Species listed as endangered by the Endangered Species Act of 1973 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"16 U.S.C. 1531","children":[],"tail":" et seq.] shall not be designated as undesirable plants under this section and shall not include plants indigenous to an area where control measures are to be taken under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8d8aeb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8d8aec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture and the Secretary of the Interior shall take such actions as may be necessary to coordinate Federal agency programs for control, research, and educational efforts associated with Federal, State, and locally designated noxious weeds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8aed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of the Interior, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8d8aee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify regional priorities for noxious weed control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8aef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate into existing technical guides regionally appropriate technical information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8af0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate such technical information to interested State, local, and private entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8af1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide cost share assistance to State and local agencies to manage noxious weeds in an area if a majority of landowners in that area agree to participate in a noxious weed management program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8d8af2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2814/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated such sums as may be necessary in each of fiscal years 1991 through 1995 to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8d8af3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/629/s15"},"text":"Pub. L. 93–629, § 15","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIV/s1453"},"text":"Pub. L. 101–624, title XIV, § 1453","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3611"},"text":"104 Stat. 3611","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8d8af4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef8d8af5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef8d8af6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Endangered Species Act of 1973, referred to in subsec. (e)(7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/205"},"text":"Pub. L. 93–205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-28"},"text":"Dec. 28, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/884"},"text":"87 Stat. 884","children":[],"tail":", which is classified generally to chapter 35 (§ 1531 et seq.) of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1531"},"text":"section 1531 of Title 16","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
