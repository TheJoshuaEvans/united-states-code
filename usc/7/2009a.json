{"tag":"section","attrib":{"id":"idef2970e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009a"},"text":"§ 2009a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a rural community advancement program to provide grants, loans, loan guarantees, and other assistance to meet the rural development needs of local communities in States and federally recognized Indian tribes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef2970e4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s381B"},"text":"Pub. L. 87–128, title III, § 381B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s761"},"text":"Pub. L. 104–127, title VII, § 761","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1139"},"text":"110 Stat. 1139","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
