{"tag":"section","attrib":{"id":"idefe5bc20-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6507"},"text":null,"children":[{"tag":"num","attrib":{"value":"6507"},"text":"§ 6507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State organic certification program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe5bc21-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The governing State official may prepare and submit a plan for the establishment of a State organic certification program to the Secretary for approval. A State organic certification program must meet the requirements of this chapter to be approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc22-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc23-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6507/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State organic certification program established under subsection (a) may contain more restrictive requirements governing the organic certification of farms and handling operations and the production and handling of agricultural products that are to be sold or labeled as organically produced under this chapter than are contained in the program established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc24-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6507/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any additional requirements established under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bc25-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6507/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6507/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be inconsistent with this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6507/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be discriminatory towards agricultural commodities organically produced in other States in accordance with this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6507/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not become effective until approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and other determinations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6507/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review State organic certification programs not less than once during each 5-year period following the date of the approval of such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6507/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Changes in program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The governing State official, prior to implementing any substantive change to programs approved under this subsection, shall submit such change to the Secretary for approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6507/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make a determination concerning any plan, proposed change to a program, or a review of a program not later than 6 months after receipt of such plan, such proposed change, or the initiation of such review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe5bc2d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2108"},"text":"Pub. L. 101–624, title XXI, § 2108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3939"},"text":"104 Stat. 3939","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
