{"tag":"section","attrib":{"id":"idefc479a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5316"},"text":null,"children":[{"tag":"num","attrib":{"value":"5316"},"text":"§ 5316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual budget submission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefc479a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President, at the same time as the submission of the annual budget to the Congress, shall submit a report to the Committees on Agriculture and Science, Space, and Technology of the House of Representatives and to the Committees on Agriculture, Nutrition, and Forestry and Governmental Affairs of the Senate on expenditures required for carrying out the coordinated program and implementing the comprehensive plan. The report shall detail, for each of the agencies that are allocated responsibilities under the coordinated program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc479a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5316/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts spent on the coordinated program during the fiscal year most recently ended;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc479a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5316/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts expected to be spent during the current fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c294-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5316/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts requested in the annual budget for the fiscal year for which the budget is being submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc6c295-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing authority not affected","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter is intended to either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc6c296-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5316/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the appropriation or require the expenditure of any funds in excess of the amount of funds that would be authorized or expended for the same purposes in the absence of the coordinated program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c297-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5316/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the authority of any of the participating agencies to request and receive funds for such purposes (for use in the coordinated program) under other laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc6c298-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/445/tI/s106"},"text":"Pub. L. 101–445, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-22"},"text":"Oct. 22, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1040"},"text":"104 Stat. 1040","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefc6c299-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefc6c29a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idefc6c29b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Governmental Affairs of Senate changed to Committee on Homeland Security and Governmental Affairs of Senate, effective ","children":[{"tag":"date","attrib":{"date":"2005-01-04"},"text":"Jan. 4, 2005","children":[],"tail":", by Senate Resolution No. 445, One Hundred Eighth Congress, "},{"tag":"date","attrib":{"date":"2004-10-09"},"text":"Oct. 9, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefc6c29c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which the report required by subsec. (a) of this section is listed on page 31), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, and section 1(a)(4) [div. A, § 1402] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":", set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
