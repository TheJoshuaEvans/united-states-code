{"tag":"section","attrib":{"id":"idefc6c35b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602"},"text":null,"children":[{"tag":"num","attrib":{"value":"5602"},"text":"§ 5602.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc6c35c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural commodity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agricultural commodity” means any agricultural commodity, food, feed, fiber, or livestock (including livestock as it is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1471/2"},"text":"section 1471(2) of this title","children":[],"tail":" and insects), and any product thereof."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c35d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Developing country","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “developing country” means a country that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc6c35e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a shortage of foreign exchange earnings and has difficulty accessing sufficient commercial credit to meet all of its food needs, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc6c35f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the potential to become a commercial market for agricultural commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c360-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c361-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Service” means the Foreign Agricultural Service of the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c362-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unfair trade practice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc6c363-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B), the term “unfair trade practice” means any act, policy, or practice of a foreign country that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefc6c364-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violates, or is inconsistent with, the provisions of, or otherwise denies benefits to the United States under, any trade agreement to which the United States is a party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc6c365-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a monopolistic state trading enterprise engaged in the export sale of an agricultural commodity, implements a pricing practice that is inconsistent with sound commercial practice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc6c366-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides a subsidy that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefc6c367-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/5/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decreases market opportunities for United States exports; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefc6c368-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/5/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unfairly distorts an agricultural market to the detriment of United States exporters;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc6c369-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" imposes an unfair technical barrier to trade, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefc6c36a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/5/A/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a trade restriction or commercial requirement (such as a labeling requirement) that adversely affects a new technology (including biotechnology); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefc6c36b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/5/A/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unjustified sanitary or phytosanitary restriction (including any restriction that, in violation of the Uruguay Round Agreements, is not based on scientific principles; ","children":[{"tag":"ref","attrib":{"idref":"fn002305"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002305"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. There probably should be a closing parenthesis."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc6c36c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/5/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposes a rule that unfairly restricts imports of United States agricultural commodities in the administration of tariff rate quotas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc6c36d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/5/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to adhere to, or circumvents any obligation under, any provision of a trade agreement with the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc6c36e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency with 1974 Trade Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter may be construed to authorize the Secretary to make any determination regarding an unfair trade practice that is inconsistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2411"},"text":"section 2411 of title 19","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c36f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” includes each of the States, the District of Columbia, Puerto Rico, and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c370-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States agricultural commodity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “United States agricultural commodity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc6c371-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agricultural commodity or product entirely produced in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc6c372-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a product of an agricultural commodity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefc6c373-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent or more of the agricultural components of which by weight, excluding packaging and added water, is entirely produced in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc6c374-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Secretary determines to be a high value agricultural product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"For purposes of this paragraph, fish entirely produced in the United States include fish harvested by a documented fishing vessel as defined in title 46 in waters that are not waters (including the territorial sea) of a foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c375-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5602/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent states of the former Soviet Union","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “independent states of the former Soviet Union” means the following: Armenia, Azerbaijan, Belarus, Georgia, Kazakhstan, Kyrgyzstan, Moldova, Russia, Tajikistan, Turkmenistan, Ukraine, and Uzbekistan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc6c376-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tI/s102"},"text":"Pub. L. 95–501, title I, § 102","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3669"},"text":"104 Stat. 3669","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/511/tVII/s702"},"text":"Pub. L. 102–511, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3349"},"text":"106 Stat. 3349","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s243/c"},"text":"Pub. L. 104–127, title II, § 243(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/967"},"text":"110 Stat. 967","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIII/s3104/b"},"text":"Pub. L. 107–171, title III, § 3104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/290"},"text":"116 Stat. 290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefc6c377-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefc6c378-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefc6c379-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Par. (5)(A)(ii) to (vi). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" added cls. (ii) to (vi) and struck out former cl. (ii) which read as follows: “is unjustifiable, unreasonable, or discriminatory and burdens or restricts United States commerce.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" added subpars. (A) and (B) and struck out former subpars. (A) and (B) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) with respect to any agricultural commodity other than a product of an agricultural commodity, an agricultural commodity entirely produced in the United States; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) with respect to a product of an agricultural commodity—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) a product all of the agricultural components of which are entirely produced in the United States; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) any other product the Secretary may designate that contains any agricultural component that is not entirely produced in the United States if—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(I) such component is an added, de minimis component,","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(II) such component is not commercially produced in the United States, and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(III) there is no acceptable substitute for such component that is commercially produced in the United States.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/s702/a"},"text":"Pub. L. 102–511, § 702(a)","children":[],"tail":", substituted “feed, fiber, or livestock (including livestock as it is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1471/2"},"text":"section 1471(2) of this title","children":[],"tail":" and insects)” for “feed, or fiber”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/s702/b"},"text":"Pub. L. 102–511, § 702(b)","children":[],"tail":", added par. (8)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
