{"tag":"section","attrib":{"id":"idef2e2d38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009cc–1"},"text":"§ 2009cc–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the Rural Business Investment Program established under this subchapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2e2d39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–1/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote economic development and the creation of wealth and job opportunities in rural areas and among individuals living in those areas by encouraging developmental capital investments in smaller enterprises primarily located in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–1/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to establish a developmental capital program, with the mission of addressing the unmet equity investment needs of small enterprises located in rural areas, by authorizing the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2e2d3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–1/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into participation agreements with rural business investment companies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2d3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–1/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to guarantee debentures of rural business investment companies to enable each rural business investment company to make developmental capital investments in smaller enterprises in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2d3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–1/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make grants to rural business investment companies, and to other entities, for the purpose of providing operational assistance to smaller enterprises financed, or expected to be financed, by rural business investment companies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef2e2d3e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s384B"},"text":"Pub. L. 87–128, title III, § 384B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6029"},"text":"Pub. L. 107–171, title VI, § 6029","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/391"},"text":"116 Stat. 391","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6426/b"},"text":"Pub. L. 115–334, title VI, § 6426(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4770"},"text":"132 Stat. 4770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef2e2d3f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef2e2d40-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef2e2d41-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6426/b/1"},"text":"Pub. L. 115–334, § 6426(b)(1)","children":[],"tail":", struck out “venture” before “capital investments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6426/b/2/A"},"text":"Pub. L. 115–334, § 6426(b)(2)(A)","children":[],"tail":", struck out “venture” before “capital program” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6426/b/2/B"},"text":"Pub. L. 115–334, § 6426(b)(2)(B)","children":[],"tail":", struck out “venture” before “capital investments”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
