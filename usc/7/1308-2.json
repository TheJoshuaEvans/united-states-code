{"tag":"section","attrib":{"id":"idee769c78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"1308–2"},"text":"§ 1308–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial of program benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee769c79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2-year denial of program benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person or legal entity shall be ineligible to receive payments specified in subsections (b) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308"},"text":"section 1308 of this title","children":[],"tail":" for the crop year, and the succeeding crop year, in which the Secretary determines that the person or legal entity—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idee769c7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failed to comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308–1/b"},"text":"section 1308–1(b) of this title","children":[],"tail":" and adopted or participated in adopting a scheme or device to evade the application of section 1308, 1308–1, or 1308–3 of this title; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee769c7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intentionally concealed the interest of the person or legal entity in any farm or legal entity engaged in farming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee769c7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extended ineligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that a person or legal entity, for the benefit of the person or legal entity or the benefit of any other person or legal entity, has knowingly engaged in, or aided in the creation of a fraudulent document, failed to disclose material information relevant to the administration of sections 1308 through 1308–5 of this title, or committed other equally serious actions (as identified in regulations issued by the Secretary), the Secretary may for a period not to exceed 5 crop years deny the issuance of payments to the person or legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee769c7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pro rata denial","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee769c7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–2/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments otherwise owed to a person or legal entity described in subsections (a) or (b) shall be denied in a pro rata manner based on the ownership interest of the person or legal entity in a farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee769c7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–2/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash rent tenant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments otherwise payable to a person or legal entity shall be denied in a pro rata manner if the person or legal entity is a cash rent tenant on a farm owned or under the control of a person or legal entity with respect to which a determination has been made under subsection (a) or (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee769c80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint and several liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any legal entity (including qualified pass-through entities) and any member of any legal entity determined to have knowingly participated in a scheme or device to evade, or that has the purpose of evading, sections 1308, 1308–1, or 1308–3 of this title shall be jointly and severally liable for any amounts that are payable to the Secretary as the result of the scheme or device (including amounts necessary to recover those amounts).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee769c81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1308–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may partially or fully release from liability any person or legal entity who cooperates with the Secretary in enforcing sections 1308, 1308–1, and 1308–3 of this title, and this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee769c82-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tX/s1001B"},"text":"Pub. L. 99–198, title X, § 1001B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/203/tI/s1304/b"},"text":"Pub. L. 100–203, title I, § 1304(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-17"},"text":"101 Stat. 1330–17","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1603/c/2"},"text":"Pub. L. 107–171, title I, § 1603(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/215"},"text":"116 Stat. 215","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1603/e"},"text":"Pub. L. 110–234, title I, § 1603(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1010"},"text":"122 Stat. 1010","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1603(e), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1738; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10306/d"},"text":"Pub. L. 119–21, title I, § 10306(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/91"},"text":"139 Stat. 91","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee769c83-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee769c84-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee769c85-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food Security Act of 1985, and not as part of the Agricultural Adjustment Act of 1938 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee769c86-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “qualified pass-through entities” for “partnerships and joint ventures”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603/e"},"text":"Pub. L. 110–246, § 1603(e)","children":[],"tail":", amended section generally. Prior to amendment, text read as follows: “If the Secretary of Agriculture determines that any person has adopted a scheme or device to evade, or that has the purpose of evading, section 1308, 1308–1, or 1308–3 of this title, such person shall be ineligible to receive farm program payments (as described in subsections (b), (c), and (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308"},"text":"section 1308 of this title","children":[],"tail":" as being subject to limitation) applicable to the crop year for which such scheme or device was adopted and the succeeding crop year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" substituted “as described in subsections (b), (c), and (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308"},"text":"section 1308 of this title","children":[],"tail":"” for “as described in paragraphs (1) and (2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308"},"text":"section 1308 of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee769c87-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee769c88-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee769c89-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tI/s1304/b"},"text":"Pub. L. 100–203, title I, § 1304(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-17"},"text":"101 Stat. 1330–17","children":[],"tail":", provided that this section is effective beginning with the 1989 crops."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee769c8a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section, as in effect on ","children":[{"tag":"date","attrib":{"date":"2007-09-30"},"text":"Sept. 30, 2007","children":[],"tail":", to continue to apply with respect to the 2007 and 2008 crops of any covered commodity or peanuts, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603/h"},"text":"section 1603(h) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308"},"text":"section 1308 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
