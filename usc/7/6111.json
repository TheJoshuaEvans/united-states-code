{"tag":"section","attrib":{"id":"idefdc478a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6111"},"text":null,"children":[{"tag":"num","attrib":{"value":"6111"},"text":"§ 6111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefdc478b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for each fiscal year such sums as are necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc478c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funds so appropriated shall not be available for payment of the expenses or expenditures of the Council in administering any provision of an order issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefdc478d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1932"},"text":"Pub. L. 101–624, title XIX, § 1932","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3865"},"text":"104 Stat. 3865","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
