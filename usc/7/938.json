{"tag":"section","attrib":{"id":"idee61183f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s938"},"text":null,"children":[{"tag":"num","attrib":{"value":"938"},"text":"§ 938.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any contract of insurance or guarantee executed by the Secretary under this subchapter shall be an obligation supported by the full faith and credit of the United States and incontestable except for fraud or misrepresentation of which the holder had actual knowledge at the time it became a holder.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee611840-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title III, § 308, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/32/s2"},"text":"Pub. L. 93–32, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-11"},"text":"May 11, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/70"},"text":"87 Stat. 70","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/124/s2"},"text":"Pub. L. 94–124, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-04"},"text":"Nov. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/677"},"text":"89 Stat. 677","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/13"},"text":"Pub. L. 103–354, title II, § 235(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee611841-3a6