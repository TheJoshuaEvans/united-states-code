{"tag":"section","attrib":{"id":"idefe373b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6417"},"text":null,"children":[{"tag":"num","attrib":{"value":"6417"},"text":"§ 6417.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe373b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6417/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for each fiscal year such funds as are necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe373b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6417/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funds so appropriated shall not be available for payment of the expenses or expenditures of the Board in administering any provision of any order issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe373b7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1999R"},"text":"Pub. L. 101–624, title XIX, § 1999R","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3926"},"text":"104 Stat. 3926","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
