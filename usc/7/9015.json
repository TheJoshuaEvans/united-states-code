{"tag":"section","attrib":{"id":"idf049fc12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015"},"text":null,"children":[{"tag":"num","attrib":{"value":"9015"},"text":"§ 9015.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer election","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf049fc13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the 2014 through 2018 crop years (except as provided in subsection (g)) and for the 2019 through 2031 crop years (subject to subsection (h)), all of the producers on a farm shall make a 1-time, irrevocable election to obtain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fc14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" price loss coverage under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9016"},"text":"section 9016 of this title","children":[],"tail":" on a covered commodity-by-covered-commodity basis; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fc15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agriculture risk coverage under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9017"},"text":"section 9017 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage options","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the election under subsection (a) or (h), as applicable, the producers on a farm that elect to obtain agriculture risk coverage shall unanimously select whether to receive agriculture risk coverage payments based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fc17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" county coverage applicable on a covered commodity-by-covered-commodity basis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fc18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individual coverage applicable to all of the covered commodities on the farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of failure to make unanimous election","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If all the producers on a farm fail to make a unanimous election under subsection (a) for the 2014 crop year, the 2019 crop year, or the 2026 crop year, as applicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fc1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall not make any payments with respect to the farm for the 2014 crop year, the 2019 crop year, or the 2026 crop year, as applicable, under section 9016 or 9017 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fc1b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to subsection (h), the producers on the farm shall be deemed to have elected, as applicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf049fc1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" price loss coverage for all covered commodities on the farm for the 2015 through 2018 crop years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf049fc1d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the same coverage for each covered commodity on the farm for the 2020 through 2023 crop years as was applicable for the 2015 through 2018 crop years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf049fc1e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the same coverage for each covered commodity on the farm for the 2027 through 2031 crop years as was applicable for the 2025 crop year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc1f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of selection of county coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If all the producers on a farm select county coverage for a covered commodity under subsection (b)(1), the Secretary may not make price loss coverage payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9016"},"text":"section 9016 of this title","children":[],"tail":" to the producers on the farm with respect to that covered commodity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc20-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of selection of individual coverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If all the producers on a farm select individual coverage under subsection (b)(2), in addition to the selection and election under this section applying to each producer on the farm, the Secretary shall consider, for purposes of making the calculations required by subsections (b)(2) and (c)(3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9017"},"text":"section 9017 of this title","children":[],"tail":", the producer’s share of all farms in the same State—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fc21-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in which the producer has an interest; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fc22-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which individual coverage has been selected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc23-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on reconstitution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that producers on a farm do not reconstitute the farm to void or change an election or selection made under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc24-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fc25-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of acres allocated to seed cotton on a farm, for the 2018 crop year, all of the producers on the farm shall be given the opportunity to make a new 1-time election under subsection (a) to reflect the designation of seed cotton as a covered commodity for that crop year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9011/6/B"},"text":"section 9011(6)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fc26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of failure to make unanimous election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If all the producers on a farm fail to make a unanimous election under paragraph (1), the producers on the farm shall be deemed to have elected price loss coverage under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9016"},"text":"section 9016 of this title","children":[],"tail":" for acres allocated on the farm to seed cotton."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Option to change election","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fc28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the 2021 crop year and each crop year thereafter, all of the producers on a farm may change the election under subsection (a), subsection (c), or this subsection, as applicable, to price loss coverage or agriculture risk coverage, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fc29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An election change under paragraph (1) shall apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf049fc2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the crop year for which the election change is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf049fc2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each crop year thereafter until another election change is made under that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9015/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Higher of price loss coverage payments and agriculture risk coverage payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the 2025 crop year, the Secretary shall, on a covered commodity-by-covered commodity basis, make the higher of price loss coverage payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9016"},"text":"section 9016 of this title","children":[],"tail":" and agriculture risk coverage county coverage payments under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9017"},"text":"section 9017 of this title","children":[],"tail":" to the producers on a farm for the payment acres for each covered commodity on the farm."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf049fc2d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1115"},"text":"Pub. L. 113–79, title I, § 1115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/667"},"text":"128 Stat. 667","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dF/s60101/a/7"},"text":"Pub. L. 115–123, div. F, § 60101(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/309"},"text":"132 Stat. 309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1105"},"text":"Pub. L. 115–334, title I, § 1105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4503"},"text":"132 Stat. 4503","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10303/a"},"text":"Pub. L. 119–21, title I, § 10303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/89"},"text":"139 Stat. 89","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf049fc2e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf049fc2f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf049fc30-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of law applicable to a covered commodity for the 2023 crop year pursuant to title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" applicable to the 2024 crop year for that covered commodity, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/c/1"},"text":"section 102(c)(1) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf049fc31-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10303/a/1"},"text":"Pub. L. 119–21, § 10303(a)(1)","children":[],"tail":", substituted “2031” for “2023” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10303/a/2/A"},"text":"Pub. L. 119–21, § 10303(a)(2)(A)","children":[],"tail":", in introductory provisions, substituted “crop year,” for “crop year or” and inserted “or the 2026 crop year,” after “2019 crop year,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10303/a/2/B"},"text":"Pub. L. 119–21, § 10303(a)(2)(B)","children":[],"tail":", substituted “crop year,” for “crop year or” and inserted “or the 2026 crop year,” after “2019 crop year,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10303/a/2/C"},"text":"Pub. L. 119–21, § 10303(a)(2)(C)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10303/a/3"},"text":"Pub. L. 119–21, § 10303(a)(3)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1105/1"},"text":"Pub. L. 115–334, § 1105(1)","children":[],"tail":", substituted “For the 2014 through 2018 crop years (except as provided in subsection (g)) and for the 2019 through 2023 crop years (subject to subsection (h))” for “Except as provided in subsection (g), for the 2014 through 2018 crop years” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/a/7/A"},"text":"Pub. L. 115–123, § 60101(a)(7)(A)","children":[],"tail":", substituted “Except as provided in subsection (g), for” for “For” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1105/2"},"text":"Pub. L. 115–334, § 1105(2)","children":[],"tail":", substituted “In the election under subsection (a) or (h), as applicable, the producers on a farm that elect to obtain agriculture risk coverage” for “In the election under subsection (a), the producers on a farm that elect under paragraph (2) of such subsection to obtain agriculture risk coverage under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9017"},"text":"section 9017 of this title","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1105/3/A"},"text":"Pub. L. 115–334, § 1105(3)(A)","children":[],"tail":", inserted “or the 2019 crop year, as applicable” after “the 2014 crop year” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1105/3/B"},"text":"Pub. L. 115–334, § 1105(3)(B)","children":[],"tail":", inserted “or the 2019 crop year, as applicable,” after “the 2014 crop year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1105/3/C"},"text":"Pub. L. 115–334, § 1105(3)(C)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “the producers on the farm shall be deemed to have elected price loss coverage under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9016"},"text":"section 9016 of this title","children":[],"tail":" for all covered commodities on the farm for the 2015 through 2018 crop years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/a/7/B"},"text":"Pub. L. 115–123, § 60101(a)(7)(B)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1105/4"},"text":"Pub. L. 115–334, § 1105(4)","children":[],"tail":", inserted “for the 2018 crop year,” after “allocated to seed cotton on a farm,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1105/5"},"text":"Pub. L. 115–334, § 1105(5)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf049fc32-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf049fc33-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" applicable beginning with the 2018 crop year, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/a/13"},"text":"section 60101(a)(13) of Pub. L. 115–123","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9011"},"text":"section 9011 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
