{"tag":"section","attrib":{"id":"idefac8498-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3406"},"text":null,"children":[{"tag":"num","attrib":{"value":"3406"},"text":"§ 3406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for retail bakers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any end product manufacturer who is a retail baker shall be exempt from the provisions of this chapter. For the purposes of this section, the term “retail baker” shall be deemed to include all end product manufacturers who sell end products directly to the ultimate consumer: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such term shall not include any end product manufacturer who derives less than 10 per centum of gross end product sales revenues from sales to ultimate consumers or who derives 10 per centum or more of gross food or food products sales revenues from the sale of such products manufactured or produced by others."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefac8499-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXVII/s1707"},"text":"Pub. L. 95–113, title XVII, § 1707","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1036"},"text":"91 Stat. 1036","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefac849a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefac849b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefac849c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
