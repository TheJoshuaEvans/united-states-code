{"tag":"section","attrib":{"id":"ideeedc7cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1727e"},"text":"§ 1727e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of local currency proceeds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeedc7ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The local currency proceeds of sales pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1727c/2"},"text":"section 1727c(2) of this title","children":[],"tail":" shall be used in the recipient country for specific economic development purposes, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeedc7cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promotion of specific policy reforms to improve food security and agricultural development within the country and to promote broad-based, equitable, and sustainable development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of development programs, projects, and activities that promote food security, alleviate hunger, improve nutrition, and promote family planning, maternal and child health care, oral rehydration therapy, and other child survival objectives consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151b/c/2"},"text":"section 2151b(c)(2) of title 22","children":[],"tail":", relating to the Child Survival Fund;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promotion of increased access to food supplies through the encouragement of specific policies and programs designed to increase employment and incomes within the country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the promotion of free and open markets through specific policies and programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for United States private voluntary organizations and cooperatives and encouragement of the development and utilization of indigenous nongovernmental organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the purchase of agricultural commodities (including transportation and processing costs) produced in the country—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeedc7d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet urgent or extraordinary relief requirements in the country or in neighboring countries; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeedc7d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop emergency food reserves;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purchase of goods and services (other than agricultural commodities and related services) to meet urgent or extraordinary relief requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment, to the extent practicable, of the costs of carrying out the program authorized in subchapter V;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private sector development activities designed to further the policies set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":", including loans to financial intermediaries for use in making loans to private individuals, cooperatives, corporations, or other entities;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities of the Peace Corps that relate to agricultural production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of rural infrastructure such as roads, irrigation systems, and electrification to enhance agricultural production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on malnutrition and its causes, as well as research relating to the identification and application of policies and strategies for targeting resources made available under this section to address the problem of malnutrition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for research (including collaborative research which is mutually beneficial to the United States and the recipient country), education, and extension activities in agricultural sciences.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1306"},"text":"Section 1306 of title 31","children":[],"tail":" shall not apply to the use under this subsection of local currency proceeds that are owned by the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc7de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support of nongovernmental organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, not less than 10 percent of the amounts contained in an account established for a recipient country under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1727d/a"},"text":"section 1727d(a) of this title","children":[],"tail":" shall be used by such country to support the development and utilization of nongovernmental organizations and cooperatives that are active in rural development, agricultural education, sustainable agricultural production, other measures to assist poor people, and environmental protection projects within such country."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc7df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment of local currencies by nongovernmental organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A nongovernmental organization may invest local currencies that accrue to that organization as a result of assistance under subsection (a), and any interest earned on such investment may be used for the purpose for which the assistance was provided to that organization without further appropriation by the Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc7e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for certain educational institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator determines that local currencies deposited in a special account pursuant to this subchapter are not needed for any of the activities prescribed in paragraphs (1) through (13) of subsection (a) or for any other specific economic development purpose in the recipient country, the Administrator may use those currencies to provide support for any institution (other than an institution whose primary purpose is to provide religious education) located in the recipient country that provides education in agricultural sciences or other disciplines for a significant number of United States nationals (who may include members of the United States Armed Forces or the Foreign Service or dependents of such members).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeedc7e1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title III, § 306, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/88/tII/s211/a/2"},"text":"Pub. L. 95–88, title II, § 211(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/551"},"text":"91 Stat. 551","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/tII/s207/a"},"text":"Pub. L. 96–53, title II, § 207(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/369"},"text":"93 Stat. 369","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3643"},"text":"104 Stat. 3643","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s211/a"},"text":"Pub. L. 104–127, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/955"},"text":"110 Stat. 955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeedc7e2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeedc7e3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ideeedc7e4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 306 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469/tIII"},"text":"act July 10, 1954, ch. 469, title III","children":[],"tail":", as added "},{"tag":"date","attrib":{"date":"1959-09-21"},"text":"Sept. 21, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/341/tI/s11"},"text":"Pub. L. 86–341, title I, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/608"},"text":"73 Stat. 608","children":[],"tail":", enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1695"},"text":"section 1695 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s2/D"},"text":"Pub. L. 89–808, § 2(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-11"},"text":"Nov. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1535"},"text":"80 Stat. 1535","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideeedc7e5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" amended heading and struck out “indigenous” before “nongovernmental” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section generally, substituting present provisions for provisions requiring submission of annual report by recipient countries to President on activities and progress of Food for Development Program."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53"},"text":"Pub. L. 96–53","children":[],"tail":" inserted provisions relating to detailed description of the use of the commodities."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeedc7e6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeedc7e7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"Jan. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1513"},"text":"section 1513 of Pub. L. 101–624","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeedc7e8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/53"},"text":"Pub. L. 96–53","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/s512/a"},"text":"section 512(a) of Pub. L. 96–53","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideeedc7e9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/88/s215"},"text":"section 215 of Pub. L. 95–88","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1702"},"text":"section 1702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ideeedc7ea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideeedc7eb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Foreign Currencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Foreign currencies accruing to United States under this subchapter may be used for purposes set forth in this section, see Ex. Ord. No. 12752, § 2(b)(1), ","children":[{"tag":"date","attrib":{"date":"1991-02-25"},"text":"Feb. 25, 1991","children":[],"tail":", 56 F.R. 8255, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
