{"tag":"section","attrib":{"id":"idee0b2fe4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"136w–1"},"text":"§ 136w–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State primary enforcement responsibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee0b2fe5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter, a State shall have primary enforcement responsibility for pesticide use violations during any period for which the Administrator determines that such State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee0b2fe6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has adopted adequate pesticide use laws and regulations, except that the Administrator may not require a State to have pesticide use laws that are more stringent than this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee0b2fe7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has adopted and is implementing adequate procedures for the enforcement of such State laws and regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee0b2fe8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–1/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will keep such records and make such reports showing compliance with paragraphs (1) and (2) of this subsection as the Administrator may require by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee0b2fe9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of subsection (a) of this section, any State that enters into a cooperative agreement with the Administrator under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136u"},"text":"section 136u of this title","children":[],"tail":" for the enforcement of pesticide use restrictions shall have the primary enforcement responsibility for pesticide use violations. Any State that has a plan approved by the Administrator in accordance with the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136i"},"text":"section 136i of this title","children":[],"tail":" that the Administrator determines meets the criteria set out in subsection (a) of this section shall have the primary enforcement responsibility for pesticide use violations. The Administrator shall make such determinations with respect to State plans under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136i"},"text":"section 136i of this title","children":[],"tail":" in effect on "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":", not later than six months after that date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee0b2fea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall have primary enforcement responsibility for those States that do not have primary enforcement responsibility under this subchapter. Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136/e/1"},"text":"section 136(e)(1) of this title","children":[],"tail":", during any period when the Administrator has such enforcement responsibility, "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136f/b"},"text":"section 136f(b) of this title","children":[],"tail":" shall apply to the books and records of commercial applicators and to any applicator who holds or applies pesticides, or uses dilutions of pesticides, only to provide a service of controlling pests without delivering any unapplied pesticide to any person so served, and "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136g/a"},"text":"section 136g(a) of this title","children":[],"tail":" shall apply to the establishment or other place where pesticides or devices are held for application by such persons with respect to pesticides or devices held for such application."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee0b2feb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125/s26"},"text":"June 25, 1947, ch. 125, § 26","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/396/s24/2"},"text":"Pub. L. 95–396, § 24(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/836"},"text":"92 Stat. 836","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/532/tVIII/s801"},"text":"Pub. L. 100–532, title VIII, § 801","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), (q)(1)(D), "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2683"},"text":"102 Stat. 2683","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1006/a/11"},"text":"Pub. L. 102–237, title X, § 1006(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1895"},"text":"105 Stat. 1895","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee0b2fec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee0b2fed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee0b2fee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 26 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125"},"text":"act June 25, 1947, ch. 125","children":[],"tail":", was renumbered section 34 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136x"},"text":"section 136x of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee0b2fef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “uses” for “use”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/532/s801"},"text":"Pub. L. 100–532, § 801","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1), (2), inserted heading and substituted “regulations. The Administrator” for “regulations; "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Administrator” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/532/s801"},"text":"Pub. L. 100–532, § 801","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(3), (q)(1)(D), inserted heading and substituted “136i” for “136b” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/532/s801"},"text":"Pub. L. 100–532, § 801","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(4), inserted heading."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee0b2ff0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee0b2ff1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/532"},"text":"Pub. L. 100–532","children":[],"tail":" effective on expiration of 60 days after "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/532/s901"},"text":"section 901 of Pub. L. 100–532","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"section 136 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
