{"tag":"section","attrib":{"id":"idf039334d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8320"},"text":null,"children":[{"tag":"num","attrib":{"value":"8320"},"text":"§ 8320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of Animal and Plant Health Inspection Service activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf039334e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8320/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture (referred to in this section as the “Secretary”) may utilize existing authorities to give high priority to enhancing and expanding the capacity of the Animal and Plant Health Inspection Service to conduct activities to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf039334f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8320/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the inspection capacity of the Service at international points of origin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0393350-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8320/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve surveillance at ports of entry and customs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0393351-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8320/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance methods of protecting against the introduction of plant and animal disease organisms by terrorists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0393352-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8320/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop new and improve existing strategies and technologies for dealing with intentional outbreaks of plant and animal disease arising from acts of terrorism or from unintentional introduction, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0393353-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8320/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing cooperative agreements among Veterinary Services of the Animal and Plant Health Inspection Service, State animal health commissions and regulatory agencies for livestock and poultry health, and private veterinary practitioners to enhance the preparedness and ability of Veterinary Services and the commissions and agencies to respond to outbreaks of such animal diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0393354-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8320/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" strengthening planning and coordination with State and local agencies, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0393355-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8320/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State animal health commissions and regulatory agencies for livestock and poultry health; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0393356-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8320/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State agriculture departments; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0393357-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8320/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise improve the capacity of the Service to protect against the threat of bioterrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0393358-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8320/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automated recordkeeping system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Animal and Plant Health Inspection Service may implement a central automated recordkeeping system to provide for the reliable tracking of the status of animal and plant shipments, including those shipments on hold at ports of entry and customs. The Secretary shall ensure that such a system shall be fully accessible to or fully integrated with the Food Safety Inspection Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0393359-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8320/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section, $30,000,000 for fiscal year 2002, and such sums as may be necessary for each subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf039335a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/tIII/s331"},"text":"Pub. L. 107–188, title III, § 331","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/678"},"text":"116 Stat. 678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf039335b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf039335c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf039335d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Public Health Security and Bioterrorism Preparedness and Response Act of 2002, and not as part of the Animal Health Protection Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
