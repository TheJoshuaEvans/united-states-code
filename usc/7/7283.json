{"tag":"section","attrib":{"id":"idf0026c6a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7283"},"text":null,"children":[{"tag":"num","attrib":{"value":"7283"},"text":"§ 7283.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity Credit Corporation interest rate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0026c6b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7283/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the monthly Commodity Credit Corporation interest rate applicable to loans provided for agricultural commodities by the Corporation shall be 100 basis points greater than the rate determined under the applicable interest rate formula in effect on ","children":[{"tag":"date","attrib":{"date":"1995-10-01"},"text":"October 1, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0026c6c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7283/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sugar","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, raw cane sugar, refined beet sugar, and in-process sugar eligible for a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272"},"text":"section 7272 of this title","children":[],"tail":" shall not be considered an agricultural commodity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0026c6d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s163"},"text":