{"tag":"section","attrib":{"id":"idefc20852-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4915"},"text":null,"children":[{"tag":"num","attrib":{"value":"4915"},"text":"§ 4915.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter or the application thereof to any person or circumstances is held invalid, the validity of the remainder of this chapter and the application of such provision to other persons and circumstances shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefc20853-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1656"},"text":"Pub. L. 99–198, title XVI, § 1656","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1630"},"text":"99 Stat. 1630","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
