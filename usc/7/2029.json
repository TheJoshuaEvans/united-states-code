{"tag":"section","attrib":{"id":"idef62a9a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029"},"text":null,"children":[{"tag":"num","attrib":{"value":"2029"},"text":"§ 2029.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Workfare","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef62a9a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program plan; guidelines; compliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef62a9a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall permit any political subdivision, in any State, that applies and submits a plan to the Secretary in compliance with guidelines promulgated by the Secretary to operate a workfare program pursuant to which every member of a household participating in the supplemental nutrition assistance program who is not exempt by virtue of the provisions of subsection (b) of this section shall accept an offer from such subdivision to perform work on its behalf, or may seek an offer to perform work, in return for compensation consisting of the allotment to which the household is entitled under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2017/a"},"text":"section 2017(a) of this title","children":[],"tail":", with each hour of such work entitling that household to a portion of its allotment equal in value to 100 per centum of the higher of the applicable State minimum wage or the Federal minimum hourly rate under the Fair Labor Standards Act of 1938 ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"29 U.S.C. 201","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef62a9aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef62a9ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall promulgate guidelines pursuant to paragraph (1) which, to the maximum extent practicable, enable a political subdivision to design and operate a workfare program under this section which is compatible and consistent with similar workfare programs operated by the subdivision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef62a9ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A political subdivision may comply with the requirements of this section by operating any workfare program which the Secretary determines meets the provisions and protections provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef62a9ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt household members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A household member shall be exempt from workfare requirements imposed under this section if such member is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef62a9ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt from ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2015/d/1"},"text":"section 2015(d)(1) of this title","children":[],"tail":" as the result of clause (B), (C), (D), (E), or (F) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2015/d/2"},"text":"section 2015(d)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef62a9af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the option of the operating agency, subject to and currently actively and satisfactorily participating at least 20 hours a week in a work activity required under title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef62a9b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mentally or physically unfit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef62a9b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under sixteen years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef62a9b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sixty years of age or older; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef62a9b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a parent or other caretaker of a child in a household in which another member is subject to the requirements of this section or is employed fulltime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef62a9b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valuation or duration of work","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No operating agency shall require any participating member to work in any workfare position to the extent that such work exceeds in value the allotment to which the household is otherwise entitled or that such work, when added to any other hours worked during such week by such member for compensation (in cash or in kind) in any other capacity, exceeds thirty hours a week.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef62a9b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature, conditions, and costs of work","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The operating agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef62a9b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not provide any work that has the effect of replacing or preventing the employment of an individual not participating in the workfare program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef62a9b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the same benefits and working conditions that are provided at the job site to employees performing comparable work for comparable hours; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef62a9b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimburse participants for actual costs of transportation and other actual costs all of which are reasonably necessary and directly related to participation in the program but not to exceed $25 in the aggregate per month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef62a9b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Job search period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The operating agency may allow a job search period, prior to making workfare assignments, of up to thirty days following a determination of eligibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef62a9ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual or a household may become ineligible under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2015/d/1"},"text":"section 2015(d)(1) of this title","children":[],"tail":" to participate in the supplemental nutrition assistance program for failing to comply with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef62a9bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of administrative expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef62a9bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall pay to each operating agency 50 per centum of all administrative expenses incurred by such agency in operating a workfare program, including reimbursements to participants for work-related expenses as described in subsection (d)(3) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef62a9bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef62a9be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" From 50 per centum of the funds saved from employment related to a workfare program operated under this section, the Secretary shall pay to each operating agency an amount not to exceed the administrative expenses described in paragraph (1) for which no reimbursement is provided under such paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef62a9bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of subparagraph (A), the term “funds saved from employment related to a workfare program operated under this section” means an amount equal to three times the dollar value of the decrease in allotments issued to households, to the extent that such decrease results from wages received by members of such households for the first month of employment beginning after the date such members commence such employment if such employment commences—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef62a9c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while such members are participating for the first time in a workfare program operated under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef62a9c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the thirty-day period beginning on the date such first participation is terminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef62a9c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2029/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may suspend or cancel some or all of these payments, or may withdraw approval from a political subdivision to operate a workfare program, upon a finding that the subdivision has failed to comply with the workfare requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef62a9c3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/525/s20"},"text":"Pub. L. 88–525, § 20","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIII/s1333"},"text":"Pub. L. 97–98, title XIII, § 1333","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1291"},"text":"95 Stat. 1291","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/253/tI"},"text":"Pub. L. 97–253, title I","children":[],"tail":", §§ 185–188, "},{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/786"},"text":"96 Stat. 786","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXV/s1517/d"},"text":"Pub. L. 99–198, title XV, § 1517(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1577"},"text":"99 Stat. 1577","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIX/s941/10"},"text":"Pub. L. 102–237, title IX, § 941(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1893"},"text":"105 Stat. 1893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tI/s109/e"},"text":"Pub. L. 104–193, title I, § 109(e)","children":[],"tail":", title VIII, § 815(b)(2), "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2170"},"text":"110 Stat. 2170","children":[],"tail":", 2317; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIV/s4001/b"},"text":"Pub. L. 110–234, title IV, § 4001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1092"},"text":"122 Stat. 1092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title IV, § 4001(b), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1853.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef62a9c4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef62a9c5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef62a9c6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Fair Labor Standards Act of 1938, referred to in subsec. (a)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch676"},"text":"act June 25, 1938, ch. 676","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1060"},"text":"52 Stat. 1060","children":[],"tail":", which is classified generally to chapter 8 (§ 201 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"section 201 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title IV of the Act is classified generally to subchapter IV (§ 601 et seq.) of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef62a9c7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef62a9c8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsecs. (a)(1), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4001/b"},"text":"Pub. L. 110–246, § 4001(b)","children":[],"tail":", substituted “supplemental nutrition assistance program” for “food stamp program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s109/e/1"},"text":"Pub. L. 104–193, § 109(e)(1)","children":[],"tail":", substituted “operating any” for “operating—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) a workfare program pursuant to title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.); or"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) any other”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s109/e/2"},"text":"Pub. L. 104–193, § 109(e)(2)","children":[],"tail":", struck out “(1)” before “A household member shall be exempt”, redesignated subpars. (A) to (F) as pars. (1) to (6), respectively, in par. (2), substituted “a work activity” for “a work training program”, and struck out former par. (2) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2)(A) Subject to subparagraphs (B) and (C), in the case of a household that is exempt from work requirements imposed under this chapter as the result of participation in a community work experience program established under section 409 of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s609"},"text":"42 U.S.C. 609","children":[],"tail":"), the maximum number of hours in a month for which all members of such household may be required to participate in such program shall equal the result obtained by dividing—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the amount of assistance paid to such household for such month under title IV of such Act, together with the value of the food stamp allotment of such household for such month; by","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) the higher of the Federal or State minimum wage in effect for such month.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) In no event may any such member be required to participate in such program more than 120 hours per month.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) For the purpose of subparagraph (A)(i), the value of the food stamp allotment of a household for a month shall be determined in accordance with regulations governing the issuance of an allotment to a household that contains more members than the number of members in an assistance unit established under title IV of such Act.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/193/s815/b/2"},"text":"Pub. L. 104–193, § 815(b)(2)","children":[],"tail":", added subsec. (f) and struck out former subsec. (f) which read as follows: “In the event that any person fails to comply with the requirements of this section, neither that person nor the household to which that person belongs shall be eligible to participate in the food stamp program for two months, unless that person or another person in the household satisfies all outstanding workfare obligations prior to the end of the two-month disqualification period.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" realigned the margins of subpars. (A) and (B) and cls. (i) and (ii) of subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" in amending subsec. (b) generally, designated existing provisions of subsec. (b) as par. (1), reorganized and expanded provisions of par. (1) as thus designated, lowered minimum age for exempted household members from eighteen years to sixteen years, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/253/s185"},"text":"Pub. L. 97–253, § 185","children":[],"tail":", redesignated existing provisions, formerly undesignated, as par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/253/s186"},"text":"Pub. L. 97–253, § 186","children":[],"tail":", substituted “at the option of the operating agency, subject to and currently actively and satisfactorily participating” for “subject to and currently involved”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/253/s187"},"text":"Pub. L. 97–253, § 187","children":[],"tail":", substituted “, when added to any other hours worked during such week by such member for compensation (in cash or in kind) in any other capacity, exceeds thirty hours a week” for “either exceeds twenty hours a week or would, together with any other hours worked in any other compensated capacity by such member on a regular or predictable part-time basis, exceed thirty hours a week”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/253/s188"},"text":"Pub. L. 97–253, § 188","children":[],"tail":", added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef62a9c9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef62a9ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","