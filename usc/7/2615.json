{"tag":"section","attrib":{"id":"idef865eb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2615"},"text":null,"children":[{"tag":"num","attrib":{"value":"2615"},"text":"§ 2615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding and issuance of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for hearing, the Secretary shall issue a plan if he finds, and sets forth in such plan, upon the evidence introduced at such hearing, that the issuance of such plan and all the terms and conditions thereof will tend to effectuate the declared policy of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef865eb9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/670/tIII/s306"},"text":"Pub. L. 91–670, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-11"},"text":"Jan. 11, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2042"},"text":"84 Stat. 2042","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
