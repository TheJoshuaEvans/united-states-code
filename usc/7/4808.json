{"tag":"section","attrib":{"id":"idefbf96a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808"},"text":null,"children":[{"tag":"num","attrib":{"value":"4808"},"text":"§ 4808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Pork Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbf96a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf96a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The order shall provide for the establishment and appointment by the Secretary of a 15-member National Pork Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf96a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002293"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002293"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Two pars. (2) have been enacted."}],"tail":" The Board shall consist of producers representing at least 12 States and importers appointed by the Secretary from nominations submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4806/g"},"text":"section 4806(g) of this title","children":[],"tail":" ."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf96aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" The Board shall consist of producers or importers appointed by the Secretary from nominations submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4806/g"},"text":"section 4806(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf96ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Board shall serve for a 3-year term, with no such member serving more than two consecutive 3-year terms, except that initial appointments to the Board shall be staggered with an equal number of members appointed, to the maximum extent possible, to 1-year, 2-year, and 3-year terms, except that the term of a member of the Board shall continue until the successor of such member, if any, is appointed in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf96ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall select its President by a majority vote.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf96ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf96ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A majority of the members of the Board shall constitute a quorum at a meeting of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf96af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A majority of votes cast at a meeting at which a quorum is present shall determine a motion or election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf96b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Board shall serve without compensation, but shall be reimbursed by the Board from assessments collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4809"},"text":"section 4809 of this title","children":[],"tail":" for reasonable expenses incurred in performing duties as a member of the Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf96b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf96b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf96b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, at the initiative of the Board or other person, proposals for promotion, research, and consumer information plans and projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf96b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit such plans and projects to the Secretary for approval;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf96b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer the order, in accordance with the order and this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf96b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe such rules as are necessary to carry out such order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf96b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive, investigate, and report to the Secretary complaints of violations of such order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf96b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Secretary with respect to amendments to such order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf96b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ a staff and conduct routine business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf96ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board shall prepare and submit to the Secretary, for the approval of the Secretary, a budget for each fiscal year of anticipated expenses and disbursements of the Board in the administration of the order, including the projected cost of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf96bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any promotion, research or consumer information plan or project to be conducted by the Board directly or by way of contract or agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf96bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the budgets, plans, or projects for which State associations are to receive funds pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4809/c/1"},"text":"section 4809(c)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf96bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No plan, project, or budget referred to in paragraph (1) or (2) may become effective unless approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf96be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf96bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board, with the approval of the Secretary, may enter into contracts or agreements with a person for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf96c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and conduct of activities authorized under an order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf96c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment of the cost thereof with funds collected through assessments under such order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf96c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such contract or agreement shall require that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf96c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contracting party develop and submit to the Board a plan or project, together with a budget or budgets that include the estimated cost to be incurred under such plan or project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf96c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such plan or project become effective on the approval of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf96c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the contracting party—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefbf96c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/4/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keep accurate records of all relevant transactions of the party;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefbf96c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/4/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make periodic reports to the Board of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idefbf96c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/4/B/iii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant activities the party has conducted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idefbf96c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/4/B/iii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accounting for funds received and expended under such contract; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefbf96ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4808/b/4/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such other reports as the Secretary or Board may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbf96cb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1619"},"text":"Pub. L. 99–198, title XVI, § 1619","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1612"},"text":"99 Stat. 1612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbf96cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefbf96cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefbf96ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1631"},"text":"section 1631 of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4801"},"text":"section 4801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
