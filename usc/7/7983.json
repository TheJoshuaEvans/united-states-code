{"tag":"section","attrib":{"id":"idf02adba1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7983"},"text":null,"children":[{"tag":"num","attrib":{"value":"7983"},"text":"§ 7983.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study of national dairy policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02adba2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7983/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall conduct a comprehensive economic evaluation of the potential direct and indirect effects of the various elements of the national dairy policy, including an examination of the effect of the national dairy policy on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adba3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7983/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" farm price stability, farm profitability and viability, and local rural economies in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adba4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7983/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" child, senior, and low-income nutrition programs, including impacts on schools and institutions participating in the programs, on program recipients, and other factors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adba5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7983/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wholesale and retail cost of fluid milk, dairy farms, and milk utilization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adba6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7983/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing the results of the study required by this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adba7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7983/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National dairy policy defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “national dairy policy” means the dairy policy of the United States as evidenced by the following policies and programs:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adba8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7983/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal milk marketing orders issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s608c"},"text":"section 608c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adba9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7983/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interstate dairy compacts (including proposed compacts described in H.R. 1827 and S. 1157, as introduced in the 107th Congress).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adbaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7983/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Over-order premiums and State pricing programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adbab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7983/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Direct payments to milk producers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adbac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7983/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal milk price support program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7981"},"text":"section 7981 of this title","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002352"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002352"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adbad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7983/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Export programs regarding milk and dairy products, such as the dairy export incentive program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s713a–14"},"text":"section 713a–14 of title 15","children":[],"tail":"."},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02adbae-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1507"},"text":"Pub. L. 107–171, title I, § 1507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/210"},"text":"116 Stat. 210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf02adbaf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf02adbb0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf02adbb1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"H.R. 1827, referred to in subsec. (c)(2), which would have granted consent to the Northeast Interstate Dairy Compact, the Southern Dairy Compact, the Pacific Northwest Dairy Compact, and the Intermountain Dairy Compact, was not enacted into law during the 107th Congress.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"S. 1157, referred to in subsec. (c)(2), which would have granted consent to the Northeast Interstate Dairy Compact, the Southern Dairy Compact, the Pacific Northwest Dairy Compact, and the Intermountain Dairy Compact, was not enacted into law during the 107th Congress.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7981"},"text":"Section 7981 of this title","children":[],"tail":", referred to in subsec. (c)(5), was in the original “section 1401”, and was translated as reading “section 1501”, meaning "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1501"},"text":"section 1501 of Pub. L. 107–171","children":[],"tail":" to reflect the probable intent of Congress, because "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1501"},"text":"section 1501 of Pub. L. 107–171","children":[],"tail":" relates to Federal milk price support program. "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1401"},"text":"Section 1401 of Pub. L. 107–171","children":[],"tail":" amended sections 7272 and 7283 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s713a–14"},"text":"Section 713a–14 of title 15","children":[],"tail":", referred to in subsec. (c)(6), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1423/a"},"text":"Pub. L. 113–79, title I, § 1423(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/695"},"text":"128 Stat. 695","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
