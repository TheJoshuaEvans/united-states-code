{"tag":"section","attrib":{"id":"idefdc46b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6012"},"text":null,"children":[{"tag":"num","attrib":{"value":"6012"},"text":"§ 6012.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or termination of plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefdc46b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6012/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory suspension or termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, whenever the Secretary finds that the plan or any provision of the plan obstructs or does not tend to effectuate the declared policy of this chapter, terminate or suspend the operation of such plan or provision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc46b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6012/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, as a result of any referendum conducted under this chapter, the Secretary determines that suspension or termination of a plan is favored by a majority of the growers, grower-shellers, and importers voting in the referendum, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc46b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6012/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 6 months after making such determination, suspend or terminate, as the case may be, collection of assessments under the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6012/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend or terminate, as the case may be, activities under the plan in an orderly manner as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc46ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6012/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The termination or suspension of any plan, or any provision thereof, shall not be considered a plan within the meaning of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefdc46bb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1917"},"text":"Pub. L. 101–624, title XIX, § 1917","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3854"},"text":"104 Stat. 3854","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
