{"tag":"section","attrib":{"id":"idf04c4719-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9038"},"text":null,"children":[{"tag":"num","attrib":{"value":"9038"},"text":"§ 9038.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special competitive provisions for extra long staple cotton","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04c471a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9038/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitiveness program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2032-07-31"},"text":"July 31, 2032","children":[],"tail":", the Secretary shall carry out a program—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c471b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9038/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain and expand the domestic use of extra long staple cotton produced in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c471c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9038/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase exports of extra long staple cotton produced in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c471d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9038/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that extra long staple cotton produced in the United States remains competitive in world markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c471e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9038/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments under program; trigger","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the program, the Secretary shall make payments available under this section whenever—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c471f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9038/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a consecutive 4-week period, the world market price for the lowest priced competing growth of extra long staple cotton (adjusted to United States quality and location and for other factors affecting the competitiveness of such cotton), as determined by the Secretary, is below the prevailing United States price for a competing growth of extra long staple cotton; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4720-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9038/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lowest priced competing growth of extra long staple cotton (adjusted to United States quality and location and for other factors affecting the competitiveness of such cotton), as determined by the Secretary, is less than 113 percent of the loan rate for extra long staple cotton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c4721-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9038/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make payments available under this section to domestic users of extra long staple cotton produced in the United States and exporters of extra long staple cotton produced in the United States that enter into an agreement with the Commodity Credit Corporation to participate in the program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c4722-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9038/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments under this section shall be based on the amount of the difference in the prices referred to in subsection (b)(1) during the fourth week of the consecutive 4-week period multiplied by the amount of documented purchases by domestic users and sales for export by exporters made in the week following such a consecutive 4-week period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04c4723-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1208"},"text":"Pub. L. 113–79, title I, § 1208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/684"},"text":"128 Stat. 684","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1204"},"text":"Pub. L. 115–334, title I, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4510"},"text":"132 Stat. 4510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/158/dD/s4101/c/2"},"text":"Pub. L. 118–158, div. D, § 4101(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-21"},"text":"Dec. 21, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1768"},"text":"138 Stat. 1768","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10309/e"},"text":"Pub. L. 119–21, title I, § 10309(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/94"},"text":"139 Stat. 94","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04c4724-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04c4725-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04c4726-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “2032” for “2026” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/158"},"text":"Pub. L. 118–158","children":[],"tail":" substituted “2026” for “2024” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1204/a"},"text":"Pub. L. 115–334, § 1204(a)","children":[],"tail":", substituted “2024” for “2019” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1204/b"},"text":"Pub. L. 115–334, § 1204(b)","children":[],"tail":", substituted “113 percent” for “134 percent”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf04c4727-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf04c4728-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/158"},"text":"Pub. L. 118–158","children":[],"tail":" to be applied and administered as if enacted on "},{"tag":"date","attrib":{"date":"2024-09-30"},"text":"Sept. 30, 2024","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/158/s4101/g"},"text":"section 4101(g) of Pub. L. 118–158","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
