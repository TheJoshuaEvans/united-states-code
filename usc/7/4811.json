{"tag":"section","attrib":{"id":"idefbf9730-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4811"},"text":null,"children":[{"tag":"num","attrib":{"value":"4811"},"text":"§ 4811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referendum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbf9731-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4811/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of determining whether an order then ","children":[{"tag":"ref","attrib":{"idref":"fn002298"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002298"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “in”."}],"tail":" effect shall be continued during the period beginning not earlier than 24 months after the issuance of the order and ending not later than 30 months after the issuance of the order, the Secretary shall conduct a referendum among persons who have been pork producers and importers during a representative period, as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9732-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4811/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors determining continuation; termination of order","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf9733-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4811/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such order shall be continued only if the Secretary determines that such order has been approved by not less than a majority of the producers and importers voting in the referendum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9734-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4811/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the continuation of such order is not approved by a majority of the producers and importers voting in the referendum, the Secretary shall terminate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf9735-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4811/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collection of assessments under the order not later than 6 months after the date of such determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9736-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4811/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the order in an orderly manner as soon as practicable after the date of such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9737-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4811/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement for cost","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall be reimbursed from assessments collected by the Board for any expenses incurred in connection with a referendum conducted under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4812"},"text":"section 4812 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9738-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4811/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of conducting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A referendum shall be conducted in such manner as prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9739-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4811/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment of initial order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A referendum to amend the initial order shall be conducted pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbf973a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1622"},"text":"Pub. L. 99–198, title XVI, § 1622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1618"},"text":"99 Stat. 1618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbf973b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefbf973c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefbf973d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1631"},"text":"section 1631 of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4801"},"text":"section 4801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
