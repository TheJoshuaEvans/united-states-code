{"tag":"section","attrib":{"id":"idef734bca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2204c"},"text":"§ 2204c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water management for rural areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef734bcb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture is authorized, directly or in coordination with any other Federal agency, entity, corporation, department, unit of State or local government, cooperative, confederation, individual, public or private organization, Indian tribe, or university, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef734bcc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research and demonstration projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734bcd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance and extension services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734bce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make grants, loans, and loan guarantees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734bcf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide other forms of assistance, for the purpose of helping rural areas make better and more efficient use of water resources and to alleviate problems arising in such areas from droughts or lack of water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734bd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to provide assistance under this section for the promotion or establishment of irrigation, watersheds, and other water management and drought management activities, including water transmission, application, and activation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734bd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In implementing this section, the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef734bd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should address the general, special, and unique problems of water management existing in rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734bd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may take action independently or in cooperation with Federal, State, public, or private entities and agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734bd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall cooperate with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef734bd5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperatives, public or private organizations, confederations, authorities, or other entities (including such entities that may be organized under multiple State agreements or compacts and entities created under State law) to carry out projects authorized under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef734bd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water, watershed, and sewer authorities, rural electric cooperatives, Federal agencies, and other State or local governments or agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734bd7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef734bd8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall issue regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734bd9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such regulations shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef734bda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the terms and conditions that the entities described in subsections (a) and (c) must meet in order to participate in programs carried out under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef734bdb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a procedure under which entities described in subsections (a) and (c) may apply for assistance under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef734bdc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster cooperation between such entities and other Federal, State, or local agencies for the purposes of carrying out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734bdd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “University” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this section, the term “university” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef734bde-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a land grant university established under the Act of ","children":[{"tag":"date","attrib":{"date":"1862-07-02"},"text":"July 2, 1862","children":[],"tail":" (known as the “First Morrill Act”; "},{"tag":"ref","attrib":{"href":"/us/stat/12/503"},"text":"12 Stat. 503","children":[],"tail":", chapter 130; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s301"},"text":"7 U.S.C. 301","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734bdf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a land grant university established under the Act of ","children":[{"tag":"date","attrib":{"date":"1890-08-30"},"text":"August 30, 1890","children":[],"tail":" (known as the “Second Morrill Act”; "},{"tag":"ref","attrib":{"href":"/us/stat/26/419"},"text":"26 Stat. 419","children":[],"tail":", chapter 841; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s321"},"text":"7 U.S.C. 321","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734be0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tuskegee Institute; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734be1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other support research organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734be2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef734be3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated each fiscal year such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef734be4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary is authorized to accept funds from non-Federal sources to carry out the activities authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734be5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall authorize the waiver of a cost-share requirement under a program established under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef734be6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/387/tIV/s401"},"text":"Pub. L. 100–387, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-11"},"text":"Aug. 11, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/956"},"text":"102 Stat. 956","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef734be7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef734be8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef734be9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1862-07-02"},"text":"July 2, 1862","children":[],"tail":", referred to in subsec. (e)(1), is "},{"tag":"ref","attrib":{"href":"/us/act/1862-07-02/ch130"},"text":"act July 2, 1862, ch. 130","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/503"},"text":"12 Stat. 503","children":[],"tail":", popularly known as the “Morrill Act” and also as the “First Morrill Act”, which is classified generally to subchapter I (§ 301 et seq.) of chapter 13 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s301"},"text":"section 301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act of ","children":[{"tag":"date","attrib":{"date":"1890-08-30"},"text":"August 30, 1890","children":[],"tail":", referred to in subsec. (e)(2), is "},{"tag":"ref","attrib":{"href":"/us/act/1890-08-30/ch841"},"text":"act Aug. 30, 1890, ch. 841","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/417"},"text":"26 Stat. 417","children":[],"tail":", popularly known as the Agricultural College Act of 1890 and also as the Second Morrill Act, which is classified generally to subchapter II (§ 321 et seq.) of chapter 13 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s321"},"text":"section 321 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
