{"tag":"section","attrib":{"id":"ideed13fa3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1593"},"text":null,"children":[{"tag":"num","attrib":{"value":"1593"},"text":"§ 1593.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards, tests, tolerances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideed13fa4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1593/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The samplings, analyses, tests, or examinations of seeds made in connection with the administration of this chapter shall be made by methods set forth by rules and regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1592"},"text":"section 1592 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideed13fa5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1593/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture is authorized and directed to make and promulgate by rules and regulations, reasonable tolerances as to the percentages and rates of occurrence required to be stated or required by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideed13fa6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1593/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1571/b"},"text":"section 1571(b) of this title","children":[],"tail":", the Secretary of Agriculture is authorized and directed to investigate, determine, establish, and promulgate from time to time such reasonable standards of germination for each kind of vegetable seed as will in his judgment best protect crop production."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideed13fa7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-09/ch615"},"text":"Aug. 9, 1939, ch. 615","children":[],"tail":", title IV, § 403, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1285"},"text":"53 Stat. 1285","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideed13fa8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideed13fa9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideed13faa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1610"},"text":"section 1610 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
