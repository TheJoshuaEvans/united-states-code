{"tag":"section","attrib":{"id":"idee1e4370-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b"},"text":null,"children":[{"tag":"num","attrib":{"value":"217b"},"text":"§ 217b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statutory trust established; dealer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee1e4371-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee1e4372-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All livestock purchased by a dealer in cash sales and all inventories of, or receivables or proceeds from, such livestock shall be held by such dealer in trust for the benefit of all unpaid cash sellers of such livestock until full payment has been received by such unpaid cash sellers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1e4373-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any dealer whose average annual purchases of livestock do not exceed $100,000 shall be exempt from the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1e4374-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of dishonored instruments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of determining full payment under paragraph (1), a payment to an unpaid cash seller shall not be considered to have been made if the unpaid cash seller receives a payment instrument that is dishonored.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1e4375-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of trust","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An unpaid cash seller shall lose the benefit of a trust under subsection (a) if the unpaid cash seller has not preserved the trust by giving written notice to the dealer involved and filing such notice with the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee1e4376-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 30 days of the final date for making a payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s228b"},"text":"section 228b of this title","children":[],"tail":" in the event that a payment instrument has not been received; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1e4377-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 15 business days after the date on which the seller receives notice that the payment instrument promptly presented for payment has been dishonored.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1e4378-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to lien holders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When a dealer receives notice under subsection (b) of the unpaid cash seller’s intent to preserve the benefits of the trust, the dealer shall, within 15 business days, give notice to all persons who have recorded a security interest in, or lien on, the livestock held in such trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1e4379-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cash sales defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this section, a cash sale means a sale in which the seller does not expressly extend credit to the buyer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1e437a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of livestock subject to trust","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee1e437b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person purchasing livestock subject to a dealer trust shall receive good title to the livestock if the person receives the livestock—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee1e437c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in exchange for payment of new value; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee1e437d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in good faith without notice that the transfer is a breach of trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1e437e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dishonored payment instrument","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payment shall not be considered to have been made if a payment instrument given in exchange for the livestock is dishonored.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1e437f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer in satisfaction of antecedent debt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A transfer of livestock subject to a dealer trust is not for value if the transfer is in satisfaction of an antecedent debt or to a secured party pursuant to a security agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1e4380-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the Secretary has reason to believe that a dealer subject to this section has failed to perform the duties required by this section or whenever the Secretary has reason to believe that it will be in the best interest of unpaid cash sellers, the Secretary shall do one or more of the following—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee1e4381-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint an independent trustee to carry out the duties required by this section, preserve trust assets, and enforce the trust;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1e4382-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as independent trustee, preserve trust assets, and enforce the trust; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1e4383-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s217b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file suit in the United States district court for the district in which the dealer resides to enjoin the dealer’s failure to perform the duties required by this section, preserve trust assets, and to enforce the trust. Attorneys employed by the Secretary may, with the approval of the Attorney General, represent the Secretary in any such suit. Nothing herein shall preclude unpaid sellers from filing suit to preserve or enforce the trust.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee1e4384-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title III, § 318, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dN/tVII/s763"},"text":"Pub. L. 116–260, div. N, title VII, § 763","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2114"},"text":"134 Stat. 2114","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
