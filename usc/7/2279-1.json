{"tag":"section","attrib":{"id":"idef7f3262-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279–1"},"text":"§ 2279–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency and accountability for socially disadvantaged farmers and ranchers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7f3263-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to ensure compilation and public disclosure of data to assess and hold the Department of Agriculture accountable for the nondiscriminatory participation of socially disadvantaged farmers and ranchers in programs of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f3264-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of socially disadvantaged farmer or rancher","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “socially disadvantaged farmer or rancher” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2003/e"},"text":"section 2003(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f3265-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compilation of program participation data","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f3266-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each county and State in the United States, the Secretary of Agriculture (referred to in this section as the “Secretary”) shall annually compile program application and participation rate data regarding socially disadvantaged farmers or ranchers by computing for each program of the Department of Agriculture that serves agricultural producers and landowners—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7f3267-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" raw numbers of applicants and participants by race, ethnicity, and gender, subject to appropriate privacy protections, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f3268-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application and participation rate, by race, ethnicity, and gender, as a percentage of the total participation rate of all agricultural producers and landowners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f3269-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to collect data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The heads of the agencies of the Department of Agriculture shall collect and transmit to the Secretary any data, including data on race, gender, and ethnicity, that the Secretary determines to be necessary to carry out paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f326a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using the technologies and systems of the National Agricultural Statistics Service, the Secretary shall compile and present the data compiled under paragraph (1) for each program described in that paragraph in a manner that includes the raw numbers and participation rates for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7f326b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entire United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f326c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7f326d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each county in each State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f326e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability of report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain and make readily available to the public, via website and otherwise in electronic and paper form, the report described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f326f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use of data","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f3270-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy protections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall not disclose the names or individual data of any program participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f3271-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data under this section shall be used exclusively for the purposes described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f3272-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided, the data under this section shall not be used for the evaluation of individual applications for assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f3273-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt for service or denial of service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any case in which a current or prospective producer or landowner, in person or in writing, requests from the Farm Service Agency, the Natural Resources Conservation Service, or an agency of the Rural Development Mission Area any benefit or service offered by the Department to agricultural producers or landowners, the Secretary shall issue, on the date of the request, a receipt to the producer or landowner that contains—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f3274-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date, place, and subject of the request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f3275-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the action taken, not taken, or recommended to the producer or landowner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7f3276-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXV/s2501A"},"text":"Pub. L. 101–624, title XXV, § 2501A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10708/a"},"text":"Pub. L. 107–171, title X, § 10708(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/522"},"text":"116 Stat. 522","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV"},"text":"Pub. L. 110–234, title XIV","children":[],"tail":", §§ 14003, 14006, "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1443"},"text":"122 Stat. 1443","children":[],"tail":", 1445; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, §§ 14003, 14006, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2205, 2207; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tXII/s12204"},"text":"Pub. L. 113–79, title XII, § 12204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/984"},"text":"128 Stat. 984","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7f3277-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7f3278-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef7f3279-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef7f327a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":", in introductory provisions, struck out “and, at the time of the request, also requests a receipt” after “landowners”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s14006"},"text":"Pub. L. 110–246, § 14006","children":[],"tail":", added subsecs. (c) and (d) and struck out former subsec. (c) which related to annual computation of the participation rate of socially disadvantaged farmers and ranchers as a percentage of the total participation of all farmers and ranchers for each Department of Agriculture program and requirement that participation according to race, ethnicity, and gender be included in each report."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s14003"},"text":"Pub. L. 110–246, § 14003","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef7f327b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef7f327c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef7f327d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Oversight and Compliance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14007"},"text":"Pub. L. 110–234, title XIV, § 14007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1446"},"text":"122 Stat. 1446","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14007, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2208, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/246/s4/a"},"text":"“The Secretary [of Agriculture], acting through the Assistant Secretary for Civil Rights of the Department of Agriculture, shall use the reports described in subsection (c) of section 2501A of the Food, Agriculture, Conservation, and Trade Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279–1"},"text":"7 U.S.C. 2279–1","children":[],"tail":"), as amended by section 14006, in the conduct of oversight and evaluation of civil rights compliance.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical provisions. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
