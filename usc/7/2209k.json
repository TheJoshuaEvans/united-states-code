{"tag":"section","attrib":{"id":"idef75bd0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2209k"},"text":null,"children":[{"tag":"num","attrib":{"value":"2209k"},"text":"§ 2209k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on payments to fossil fuel refiners and importers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef75bd0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2209k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture may not use any funds, facilities, or authorities of the Commodity Credit Corporation or the Department of Agriculture—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef75bd0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2209k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a payment to a refiner or importer (as those terms are defined in section 80.2 of title 40, Code of Federal Regulations (or successor regulations)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef75bd0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2209k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to otherwise support, directly or indirectly, a refiner or importer (as so defined) in meeting any requirements under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef75bd0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2209k/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the renewable fuel program under section 7545(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of title 42; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef75bd10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2209k/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provision of law that requires the blending of fossil fuel with renewable fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef75bd11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2209k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The exclusion in (a) shall not apply to any payments or support to producers, refiners, or importers of biofuel (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8101"},"text":"section 8101 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef75bd12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2209k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Moratorium on Authorities Relating to Exchanges of Agricultural Products for Petroleum Products","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authorities under the ninth and tenth sentences of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s714b/h"},"text":"section 714b(h) of title 15","children":[],"tail":" (relating to the availability of agricultural products for the Secretary of Energy to exchange for petroleum products and the terms and conditions of those exchanges, respectively) shall not be used during the 180-day period beginning on "},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"October 1, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef75bd13-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159/dD/tVI/s4604"},"text":"Pub. L. 116–159, div. D, title VI, § 4604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"Oct. 1, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/747"},"text":"134 Stat. 747","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef75bd14-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef75bd15-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef75bd16-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8101"},"text":"Section 8101 of this title","children":[],"tail":", referred to in subsec. (b), was in the original “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8101"},"text":"7 U.S.C. 8101","children":[],"tail":"” but probably should have been a reference to section 9001 of the Farm Security and Rural Investment Act of 2002, "},{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8101"},"text":"section 8101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
