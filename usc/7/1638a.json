{"tag":"section","attrib":{"id":"ideedf7055-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1638a"},"text":"§ 1638a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of country of origin","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedf7056-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf7057-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), a retailer of a covered commodity shall inform consumers, at the final point of sale of the covered commodity to consumers, of the country of origin of the covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7058-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of country of origin for lamb, chicken, goat, and venison meat","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf7059-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States country of origin","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A retailer of a covered commodity that is lamb, chicken, goat, or venison meat may designate the covered commodity as exclusively having a United States country of origin only if the covered commodity is derived from an animal that was—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedf705a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exclusively born, raised, and slaughtered in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf705b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" born and raised in Alaska or Hawaii and transported for a period of not more than 60 days through Canada to the United States and slaughtered in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf705c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present in the United States on or before ","children":[{"tag":"date","attrib":{"date":"2008-07-15"},"text":"July 15, 2008","children":[],"tail":", and once present in the United States, remained continuously in the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf705d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple countries of origin","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedf705e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A retailer of a covered commodity that is lamb, chicken, goat, or venison meat that is derived from an animal that is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideedf705f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not exclusively born, raised, and slaughtered in the United States,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideedf7060-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" born, raised, or slaughtered in the United States, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideedf7061-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not imported into the United States for immediate slaughter,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" may designate the country of origin of such covered commodity as all of the countries in which the animal may have been born, raised, or slaughtered.","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf7062-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to general requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subparagraph alters the mandatory requirement to inform consumers of the country of origin of covered commodities under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7063-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imported for immediate slaughter","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A retailer of a covered commodity that is lamb, chicken, goat, or venison meat that is derived from an animal that is imported into the United States for immediate slaughter shall designate the origin of such covered commodity as—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedf7064-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the country from which the animal was imported; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf7065-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7066-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign country of origin","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A retailer of a covered commodity that is lamb, chicken, goat, or venison meat that is derived from an animal that is not born, raised, or slaughtered in the United States shall designate a country other than the United States as the country of origin of such commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7067-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ground lamb, chicken, goat, and venison","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notice of country of origin for ground lamb, ground chicken, ground goat, or ground venison shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedf7068-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all countries of origin of such ground lamb, ground chicken, ground goat, or ground venison; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf7069-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all reasonably possible countries of origin of such ground lamb, ground chicken, ground goat, or ground venison.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf706a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of country of origin for fish","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf706b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A retailer of a covered commodity that is farm-raised fish or wild fish may designate the covered commodity as having a United States country of origin only if the covered commodity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedf706c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of farm-raised fish, is hatched, raised, harvested, and processed in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf706d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of wild fish, is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideedf706e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" harvested in the United States, a territory of the United States, or a State, or by a vessel that is documented under chapter 121 of title 46 or registered in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideedf706f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processed in the United States, a territory of the United States, or a State, including the waters thereof, or aboard a vessel that is documented under chapter 121 of title 46 or registered in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7070-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of wild fish and farm-raised fish","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The notice of country of origin for wild fish and farm-raised fish shall distinguish between wild fish and farm-raised fish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7071-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of country of origin for perishable agricultural commodities, ginseng, peanuts, pecans, and macadamia nuts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf7072-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A retailer of a covered commodity that is a perishable agricultural commodity, ginseng, peanut, pecan, or macadamia nut may designate the covered commodity as having a United States country of origin only if the covered commodity is exclusively produced in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7073-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State, region, locality of the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a covered commodity that is a perishable agricultural commodity, ginseng, peanut, pecan, or macadamia nut produced exclusively in the United States, designation by a retailer of the State, region, or locality of the United States where such commodity was produced shall be sufficient to identify the United States as the country of origin.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf7074-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for food service establishments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to a covered commodity if the covered commodity is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf7075-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepared or served in a food service establishment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7076-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf7077-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offered for sale or sold at the food service establishment in normal retail quantities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7078-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served to consumers at the food service establishment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf7079-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of notification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf707a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information required by subsection (a) may be provided to consumers by means of a label, stamp, mark, placard, or other clear and visible sign on the covered commodity or on the package, display, holding unit, or bin containing the commodity at the final point of sale to consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf707b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labeled commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the covered commodity is already individually labeled for retail sale regarding country of origin, the retailer shall not be required to provide any additional information to comply with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf707c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit verification system","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf707d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may conduct an audit of any person that prepares, stores, handles, or distributes a covered commodity for retail sale to verify compliance with this subchapter (including the regulations promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1638c/b"},"text":"section 1638c(b) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf707e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Record requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf707f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person subject to an audit under paragraph (1) shall provide the Secretary with verification of the country of origin of covered commodities. Records maintained in the course of the normal conduct of the business of such person, including animal health papers, import or customs documents, or producer affidavits, may serve as such verification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7080-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on requirement of additional records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not require a person that prepares, stores, handles, or distributes a covered commodity to maintain a record of the country of origin of a covered commodity other than those maintained in the course of the normal conduct of the business of such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf7081-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person engaged in the business of supplying a covered commodity to a retailer shall provide information to the retailer indicating the country of origin of the covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf7082-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of origin","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf7083-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory identification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not use a mandatory identification system to verify the country of origin of a covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7084-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing certification programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To certify the country of origin of a covered commodity, the Secretary may use as a model certification programs in existence on ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf7085-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the carcass grading and certification system carried out under this Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7086-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the origin verification system established to carry out the child and adult care food program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1766"},"text":"section 1766 of title 42","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7087-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638a/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the origin verification system established to carry out the market access program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5623/b"},"text":"section 5623(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedf7088-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 282, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10816"},"text":"Pub. L. 107–171, title X, § 10816","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/533"},"text":"116 Stat. 533","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/206/tI/s208"},"text":"Pub. L. 107–206, title I, § 208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-02"},"text":"Aug. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/833"},"text":"116 Stat. 833","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXI/s11002/2"},"text":"Pub. L. 110–234, title XI, § 11002(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1352"},"text":"122 Stat. 1352","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XI, § 11002(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2113; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tXII/s12104/b/2"},"text":"Pub. L. 113–79, title XII, § 12104(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/979"},"text":"128 Stat. 979","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dA/tVII/s759/b"},"text":"Pub. L. 114–113, div. A, title VII, § 759(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2285"},"text":"129 Stat. 2285","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII/s3201/b/1/C"},"text":"Pub. L. 115–334, title III, § 3201(b)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4616"},"text":"132 Stat. 4616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideedf7089-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideedf708a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideedf708b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (f)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"act Aug. 14, 1946, ch. 966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/1082"},"text":"60 Stat. 1082","children":[],"tail":", which enacted this chapter and sections 427h, 427j, and 3105 of this title and amended "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3104"},"text":"section 3104 of this title","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideedf708c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", referred to in subsec. (f)(2), was in the original “the date of enactment of this Act”, which was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", which enacted this subchapter, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideedf708d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “section 5623(b)” for “section 5623”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s759/b/1/A"},"text":"Pub. L. 114–113, § 759(b)(1)(A)","children":[],"tail":", in heading, struck out “beef,” before “lamb,” and “pork,” before “chicken,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s759/b/1/B"},"text":"Pub. L. 114–113, § 759(b)(1)(B)","children":[],"tail":", struck out “beef,” and “pork,” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s759/b/1/C"},"text":"Pub. L. 114–113, § 759(b)(1)(C)","children":[],"tail":", in heading, struck out “beef, pork,” after “Ground” and, in text, struck out “ground beef, ground pork,” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(B) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s759/b/2"},"text":"Pub. L. 114–113, § 759(b)(2)","children":[],"tail":", redesignated subpars. (D) and (E) as (B) and (C), respectively, and struck out former subpars. (B) and (C), which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the voluntary country of origin beef labeling system carried out under this Act;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) voluntary programs established to certify certain premium beef cuts;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s12104/b/2/A"},"text":"Pub. L. 113–79, § 12104(b)(2)(A)","children":[],"tail":", substituted “goat, and venison” for “and goat” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A), (B)(i), (C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s12104/b/2/B"},"text":"Pub. L. 113–79, § 12104(b)(2)(B)","children":[],"tail":", substituted “goat, or venison” for “or goat”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s12104/b/2/C"},"text":"Pub. L. 113–79, § 12104(b)(2)(C)","children":[],"tail":", substituted “goat, and venison” for “and goat” in heading and “ground goat, or ground venison” for “or ground goat” wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s11002/2/A"},"text":"Pub. L. 110–246, § 11002(2)(A)","children":[],"tail":", added pars. (2) to (4) and struck out former pars. (2) and (3) which related to designation of United States as country of origin for beef, lamb, pork, fish, perishable agricultural commodities, and peanuts, and requirement that notice of country of origin for fish shall distinguish between wild and farm-raised fish."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s11002/2/B"},"text":"Pub. L. 110–246, § 11002(2)(B)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows: “The Secretary may require that any person that prepares, stores, handles, or distributes a covered commodity for retail sale maintain a verifiable recordkeeping audit trail that will permit the Secretary to verify compliance with this subchapter (including the regulations promulgated under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1638c/b"},"text":"section 1638c(b) of this title","children":[],"tail":").”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/206"},"text":"Pub. L. 107–206","children":[],"tail":" amended subpar. (D) generally. Prior to amendment, subpar. (D) read as follows: “in the case of wild fish, is—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) harvested in waters of the United States, a territory of the United States, or a State; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) processed in the United States, a territory of the United States, or a State, including the waters thereof; and”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideedf708e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideedf708f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
