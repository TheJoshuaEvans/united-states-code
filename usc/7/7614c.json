{"tag":"section","attrib":{"id":"idf0157f52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c"},"text":null,"children":[{"tag":"num","attrib":{"value":"7614c"},"text":"§ 7614c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget submission and funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0157f53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157f54-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered program” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157f55-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each research program carried out by the Agricultural Research Service or the Economic Research Service for which annual appropriations are requested in the annual budget submission of the President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f56-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each competitive program carried out by the National Institute of Food and Agriculture for which annual appropriations are requested in the annual budget submission of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f57-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request for applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “request for applications” means a funding announcement published by the National Institute of Food and Agriculture that provides detailed information on funding opportunities at the Institute, including the purpose, eligibility, restriction, focus areas, evaluation criteria, regulatory information, and instructions on how to apply for such opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157f58-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall submit to Congress, together with the annual budget submission of the President, a single budget line item reflecting the total amount requested by the President for funding for research, education, and extension activities of the Research, Education, and Economics mission area of the Department for that fiscal year and for the preceding 5 fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157f59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity and infrastructure program request","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds requested for capacity and infrastructure programs in excess of the capacity and infrastructure program critical base funding level, budgetary emphasis should be placed on enhancing funding for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157f5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1890 Institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1994 Institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" NLGCA Institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hispanic-serving agricultural colleges and universities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small 1862 Institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157f5f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive program request","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds requested for competitive programs in excess of the competitive program critical base funding level, budgetary emphasis should be placed on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157f60-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing funding for emerging problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" finding solutions for those problems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157f62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional presidential budget submission requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157f63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each year, the President shall submit to Congress for each funding request for a covered program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157f64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the information described in paragraph (2), such information together with the annual budget submission of the President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any additional information described in paragraph (3), such additional information within a reasonable period that begins after the date of the annual budget submission of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f66-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The information described in this paragraph includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157f67-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" baseline information, including with respect to each covered program—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0157f68-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding level for the program for the fiscal year preceding the year for which the annual budget submission of the President is submitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0157f69-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding level requested in the annual budget submission of the President, including any increase or decrease in the funding level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0157f6a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation justifying any change from the funding level specified in clause (i) to the level specified in clause (ii);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f6b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to each covered program that is carried out by the Economic Research Service or the Agricultural Research Service, the location and staff years of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f6c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the proposed funding levels to be allocated to, and the expected publication date, scope, and allocation level for, each request for applications to be published under or associated with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0157f6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each grant and cooperative agreement awarded under subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279"},"text":"section 2279 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0157f6e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each priority area specified in subsection (b)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3157"},"text":"section 3157 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0157f6f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each research and extension project carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5811/a"},"text":"section 5811(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0157f70-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each grant awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5925b/a"},"text":"section 5925b(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0157f71-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each grant awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7632/d"},"text":"section 7632(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Secretary determines will increase congressional oversight with respect to covered programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional information described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The additional information described in this paragraph is information that the Secretary, after consulting with the Committee on Agriculture of the House of Representatives, the Committee on Agriculture, Nutrition, and Forestry of the Senate, and the Subcommittees on Agriculture, Rural Development, Food and Drug Administration, and Related Agencies of the Committee on Appropriations of the House of Representatives and the Senate, determines is a necessary revision or clarification to the information described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless the President submits the information described in paragraph (2)(C) for a fiscal year, the President may not carry out any program during that fiscal year that is authorized under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157f75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279"},"text":"section 2279 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3157"},"text":"section 3157 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5811"},"text":"section 5811 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5925b"},"text":"section 5925b of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/e/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7632"},"text":"section 7632 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157f7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report of the Secretary of Agriculture","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each year on a date that is not later than the date on which the President submits the annual budget, the Secretary shall submit to Congress a report containing a description of the agricultural research, extension, and education activities carried out by the Federal Government during the fiscal year that immediately precedes the year for which the report is submitted, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157f7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a review of the extent to which those activities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157f7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are duplicative or overlap within the Department of Agriculture; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" are similar to activities carried out by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0157f7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0157f7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the States (including the District of Columbia, the Commonwealth of Puerto Rico and other territories or possessions of the United States);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0157f80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/f/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0157f81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/f/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each report submitted under this section on or after ","children":[{"tag":"date","attrib":{"date":"2014-01-01"},"text":"January 1, 2014","children":[],"tail":", a 5-year projection of national priorities with respect to agricultural research, extension, and education, taking into account domestic needs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157f83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7614c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interchangeability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed so as to limit the authority of the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2257"},"text":"section 2257 of this title","children":[],"tail":", with respect to the reprogramming or transfer of funds."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0157f84-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7506"},"text":"Pub. L. 110–234, title VII, § 7506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1259"},"text":"122 Stat. 1259","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7506, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2020; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7513"},"text":"Pub. L. 113–79, title VII, § 7513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/901"},"text":"128 S