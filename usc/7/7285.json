{"tag":"section","attrib":{"id":"idf0026c81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285"},"text":null,"children":[{"tag":"num","attrib":{"value":"7285"},"text":"§ 7285.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity Credit Corporation sales price restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0026c82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General sales authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation may sell any commodity owned or controlled by the Corporation at any price that the Secretary determines will maximize returns to the Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0026c83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplication of sales price restrictions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0026c84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sale for a new or byproduct use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026c85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sale of peanuts or oilseeds for the extraction of oil;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026c86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sale for seed or feed if the sale will not substantially impair any loan program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026c87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sale of a commodity that has substantially deteriorated in quality or as to which there is a danger of loss or waste through deterioration or spoilage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026c88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sale for the purpose of establishing a claim arising out of a contract or against a person who has committed fraud, misrepresentation, or other wrongful act with respect to the commodity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026c89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sale for export, as determined by the Corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026c8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sale for other than a primary use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0026c8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential disaster areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0026c8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a), on such terms and conditions as the Secretary may consider in the public interest, the Corporation may make available any commodity or product owned or controlled by the Corporation for use in relieving distress—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0026c8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any area in the United States (including the Virgin Islands) declared by the President to be an acute distress area because of unemployment or other economic cause, if the President finds that the use will not displace or interfere with normal marketing of agricultural commodities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0026c8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with any major disaster determined by the President to warrant assistance by the Federal Government under the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026c8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except on a reimbursable basis, the Corporation shall not bear any costs in connection with making a commodity available under paragraph (1) beyond the cost of the commodity to the Corporation incurred in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0026c90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the storage of the commodity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0026c91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the handling and transportation costs in making delivery of the commodity to designated agencies at 1 or more central locations in each State or other area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0026c92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7285/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Efficient operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsection (a) shall not apply to the sale of a commodity the disposition of which is desirable in the interest of the effective and efficient conduct of the operations of the Corporation because of the small quantity of the commodity involved, or because of the age, location, or questionable continued storability of the commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0026c93-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s165"},"text":"Pub. L. 104–127, title I, § 165","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/936"},"text":"110 Stat. 936","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0026c94-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0026c95-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0026c96-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsec. (c)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", which is classified principally to chapter 68 (§ 5121 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
