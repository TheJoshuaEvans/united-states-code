{"tag":"section","attrib":{"id":"ideff413d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934"},"text":null,"children":[{"tag":"num","attrib":{"value":"6934"},"text":"§ 6934.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Partnerships and Public Engagement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff413d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff413d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beginning farmer or rancher","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “beginning farmer or rancher” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1991/a"},"text":"section 1991(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Office” means the Office of Partnerships and Public Engagement established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Socially disadvantaged farmer or rancher","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “socially disadvantaged farmer or rancher” has the meaning given the term in section 2279(e) ","children":[{"tag":"ref","attrib":{"idref":"fn002321"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002321"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff413d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff413d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish within the executive operations of the Department an office to be known as the “Office of Partnerships and Public Engagement”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff413d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve access to programs of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff413da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to improve the viability and profitability of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff413db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small farms and ranches;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff413dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning farmers or ranchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff413dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" socially disadvantaged farmers or ranchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff413de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limited resource producers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff413df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veteran farmers and ranchers; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff413e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote youth outreach.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall be headed by a Director, to be appointed by the Secretary from among the competitive service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff413e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Office shall be to ensure small farms and ranches, beginning farmers or ranchers, veteran farmers and ranchers, and socially disadvantaged farmers or ranchers access to, and equitable participation in, programs and services of the Department by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff413e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and monitoring the goals and objectives of the Department to increase participation in programs of the Department by small, beginning, socially disadvantaged, or veteran farmers or ranchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the effectiveness of Department outreach programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and implementing a plan to coordinate outreach activities and services provided by the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing input to the agencies and offices on programmatic and policy decisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measuring outcomes of the programs and activities of the Department on small farms and ranches, beginning farmers or ranchers, veteran farmers or ranchers, and socially disadvantaged farmers or ranchers programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommending new initiatives and programs to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out any other related duties that the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff413ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Socially disadvantaged farmers group","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff413eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the Office the Socially Disadvantaged Farmers Group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach and assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Socially Disadvantaged Farmers Group—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff413ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279"},"text":"section 2279 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff413ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of activities described in section 2279(a) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title, may conduct such activities through other agencies and offices of the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Socially disadvantaged farmers and farmworkers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Socially Disadvantaged Farmers Group shall oversee the operations of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff413f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Advisory Committee on Minority Farmers established under section 14009 of the Food, Conservation, and Energy Act of 2008; ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff413f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the position of Farmworker Coordinator established under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other duties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff413f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Socially Disadvantaged Farmers Group may carry out other duties to improve access to, and participation in, programs of the Department by socially disadvantaged farmers or ranchers, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff413f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Outreach and Diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Partnerships and Public Engagement shall carry out the functions and duties of the Office of Outreach and Diversity carried out by the Assistant Secretary for Civil Rights as such functions and duties existed immediately before the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff413f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small Farms and Beginning Farmers and Ranchers Group","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff413f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the Office the Small Farms and Beginning Farmers and Ranchers Group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff413f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversee offices","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Small Farms and Beginning Farmers and Ranchers Group shall oversee the operations of the Office of Small Farms Coordination established by Departmental Regulation 9700–1 (","children":[{"tag":"date","attrib":{"date":"2006-08-03"},"text":"August 3, 2006","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff413f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beginning farmer and rancher development program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Small Farms and Beginning Farmers and Ranchers Group shall consult with the National Institute for Food and Agriculture on the administration of the beginning farmer and rancher development grant program established under subsection (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279"},"text":"section 2279 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff413fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee for Beginning Farmers and Ranchers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Small Farms and Beginning Farmers and Ranchers Group shall coordinate the activities of the Group with the Advisory Committee for Beginning Farmers and Ranchers established under section 5(b) of the Agricultural Credit Improvement Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1621"},"text":"7 U.S.C. 1621","children":[],"tail":" "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/102/554"},"text":"Public Law 102–554","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff413fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Small Farms and Beginning Farmers and Ranchers Group may carry out other duties to improve access to, and participation in, programs of the Department by small farms and ranches and beginning farmers or ranchers, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff413fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farmworker Coordinator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff413fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the Office the position of Farmworker Coordinator (referred to in this subsection as the “Coordinator”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall delegate to the Coordinator responsibility for the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff413ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assisting in administering the program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5177a"},"text":"section 5177a of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff41400-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serving as a liaison to community-based nonprofit organizations that represent and have demonstrated experience serving low-income migrant and seasonal farmworkers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff41401-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinating with the Department, other Federal agencies, and State and local governments to ensure that farmworker needs are assessed and met during declared disasters and other emergencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff41402-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consulting within the Office and with other entities to better integrate farmworker perspectives, concerns, and interests into the ongoing programs of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff41403-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consulting with appropriate institutions on research, program improvements, or agricultural education opportunities that assist low-income and migrant seasonal farmworkers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff41404-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assisting farmworkers in becoming agricultural producers or landowners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff41405-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff41406-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2009 through 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff41407-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6934/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff41408-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s226B"},"text":"Pub. L. 103–354, title II, § 226B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14013/a"},"text":"Pub. L. 110–234, title XIV, § 14013(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1450"},"text":"122 Stat. 1450","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14013(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"12