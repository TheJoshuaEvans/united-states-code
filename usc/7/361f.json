{"tag":"section","attrib":{"id":"idee2c9ab1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s361f"},"text":null,"children":[{"tag":"num","attrib":{"value":"361f"},"text":"§ 361f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publications of experiment stations; free mailing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Bulletins, reports, periodicals, reprints of articles, and other publications necessary for the dissemination of results of the researches and experiments, including lists of publications available for distribution by the experiment stations, shall be transmitted in the mails of the United States. Such publications may be mailed from the principal place of business of the station or from an established subunit of said station.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee2c9ab2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1887-03-02/ch314/s6"},"text":"Mar. 2, 1887, ch. 314, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/24/441"},"text":"24 Stat. 441","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-11/ch790/s1"},"text":"Aug. 11, 1955, ch. 790, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/673"},"text":"69 Stat. 673","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s4/a"},"text":"Pub. L. 91–375, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/773"},"text":"84 Stat. 773","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7404/b/1"},"text":"Pub. L. 110–234, title VII, § 7404(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href"