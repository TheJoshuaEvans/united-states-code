{"tag":"section","attrib":{"id":"idee5c5d42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932"},"text":null,"children":[{"tag":"num","attrib":{"value":"932"},"text":"§ 932.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liabilities and uses of Rural Electrification and Telephone Revolving Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee5c5d43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liabilities and obligations of fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The notes of the Secretary to the Secretary of the Treasury to obtain funds for loans under sections 904, 905,","children":[{"tag":"ref","attrib":{"idref":"fn002123"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002123"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and 922 of this title, and all other liabilities against the appropriations or assets in the fund in connection with electrification and telephone loan operations shall be liabilities of the fund, and all other obligations against such appropriations or assets in the fund arising out of electrification and telephone loan operations shall be obligations of the fund."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee5c5d44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of fund assets","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The assets of the fund shall be available only for the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee5c5d45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loans which could be insured under this subchapter, and for advances in connection with such loans and loans previously made, as of ","children":[{"tag":"date","attrib":{"date":"1973-05-11"},"text":"May 11, 1973","children":[],"tail":", under sections 904, 905,"},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" and 922 of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d46-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of principal when due (without interest) on outstanding loans to the Secretary from the Secretary of the Treasury for electrification and telephone purposes and payment of principal and interest when due on loans to the Secretary from the Secretary of the Treasury pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s934/a"},"text":"section 934(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d47-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of amounts to which the holder of notes is entitled on insured loans: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That payments other than final payments need not be remitted to the holder until due or until the next agreed annual, semiannual, or quarterly remittance date;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d48-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment to the holder of insured notes of any defaulted installment or, upon assignment of the note to the Secretary at his request, the entire balance due on the note;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d49-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase of notes in accordance with contracts of insurance entered into by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment in compliance with contracts of guarantee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of taxes, insurance, prior liens, expenses necessary to make fiscal adjustments in connection with the application, and transmittal of collections or necessary to obtain credit reports on applicants or borrowers, expenses for necessary services, including construction inspections, commercial appraisals, loan servicing, consulting business advisory or other commercial and technical services, and other program services, and other expenses and advances authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s907"},"text":"section 907 of this title","children":[],"tail":" in connection with insured loans. Such items may be paid in connection with guaranteed loans after or in connection with the acquisition of such loans or security thereof after default, to the extent determined to be necessary to protect the interest of the Government, or in connection with any other activity authorized in this chapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of the purchase price and any costs and expenses incurred in connection with the purchase, acquisition, or operation of property pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s907"},"text":"section 907 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee5c5d4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separate electric and telephone accounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee5c5d4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall maintain two separate accounts within the fund, which shall be known as the electric account and the telephone account, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee5c5d50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall account for the assets, liabilities, income, expenses, and equity of the fund attributable to electrification loan operations in the electric account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee5c5d51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall account for the assets, liabilities, income, expenses, and equity of the fund attributable to telephone loan operations in the telephone account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee5c5d53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The assets accounted for in the electric account shall be available solely for electrification loan operations under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee5c5d54-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s932/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The assets accounted for in the telephone account shall be available solely for telephone loan operations under this chapter (other than under subchapter IV).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee5c5d55-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title III, § 302, as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/12/s2"},"text":"Pub. L. 92–12, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-05-07"},"text":"May 7, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/30"},"text":"85 Stat. 30","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/32/s2"},"text":"Pub. L. 93–32, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-11"},"text":"May 11, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/66"},"text":"87 Stat. 66","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2359"},"text":"Pub. L. 101–624, title XXIII, § 2359","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4041"},"text":"104 Stat. 4041","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/13"},"text":"Pub. L. 103–354, title II, § 235(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s772/b/2"},"text":"Pub. L. 104–127, title VII, § 772(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1149"},"text":"110 Stat. 1149","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee5c5d56-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee5c5d57-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee5c5d58-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s905"},"text":"Section 905 of this title","children":[],"tail":", referred to in subsecs. (a) and (b)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s774/a"},"text":"Pub. L. 104–127, title VII, § 774(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1150"},"text":"110 Stat. 1150","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee5c5d59-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" struck out “pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s903/a"},"text":"section 903(a) of this title","children":[],"tail":"” after “purposes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a), (b)(2), (4), (5), (c)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/32"},"text":"Pub. L. 93–32","children":[],"tail":" substituted provisions setting out the liabilities of the Rural Electrification and Telephone Revolving Fund and the allowable purposes for which fund assets shall be available, for provisions, that the monies in the rural telephone account should remain on deposit in the Treasury of the United States until disbursed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee5c5d5a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee5c5d5b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1973 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/32"},"text":"Pub. L. 93–32","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1973-05-11"},"text":"May 11, 1973","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/32/s12"},"text":"section 12 of Pub. L. 93–32","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s930"},"text":"section 930 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee5c5d5c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1971-05-07"},"text":"May 7, 1971","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/12/s7"},"text":"section 7 of Pub. L. 92–12","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s931"},"text":"section 931 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
