{"tag":"section","attrib":{"id":"ideffdb10c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7106"},"text":null,"children":[{"tag":"num","attrib":{"value":"7106"},"text":"§ 7106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition and review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffdb10d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffdb10e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person subject to an order issued under this chapter may file with the Secretary a petition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffdb10f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7106/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating that the order, any provision of the order, or any obligation imposed in connection with the order is not established in accordance with law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffdb110-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7106/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requesting a modification of the order or an exemption from the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb111-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The petitioner shall be given an opportunity for a hearing on the petition, in accordance with regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb112-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ruling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the hearing, the Secretary shall make a ruling on the petition. The ruling shall be final if the ruling is in accordance with law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb113-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffdb114-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district court of the United States for any district in which a person who is a petitioner under subsection (a) resides or carries on business shall have jurisdiction to review the ruling on the petition of the person, if a complaint for that purpose is filed not later than 20 days after the date of the entry of the ruling by the Secretary under subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb115-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Service of process in a proceeding may be conducted on the Secretary by delivering a copy of the complaint to the Secretary, under such rules or regulations as are considered necessary by the Secretary to facilitate the service of process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb116-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remands","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the court determines that the ruling is not in accordance with law, the court shall remand the matter to the Secretary with directions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffdb117-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7106/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make such ruling as the court shall determine to be in accordance with law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffdb118-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7106/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take such further action as, in the opinion of the court, the law requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffdb119-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/407/s7"},"text":"Pub. L. 103–407, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4224"},"text":"108 Stat. 4224","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
