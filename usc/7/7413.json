{"tag":"section","attrib":{"id":"idf0072742-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413"},"text":null,"children":[{"tag":"num","attrib":{"value":"7413"},"text":"§ 7413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0072743-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0072744-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To effectuate the purpose of this subchapter, the Secretary may issue, and amend from time to time, orders applicable to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0072745-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the producers of an agricultural commodity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072746-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first handlers of the agricultural commodity and other persons in the marketing chain as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0072747-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importers of the agricultural commodity, if imports of the agricultural commodity are subject to assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7415/f"},"text":"section 7415(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072748-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National scope","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each order issued under this section shall be national in scope.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0072749-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure for issuance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf007274a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development or receipt of proposed order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A proposed order with respect to an agricultural commodity may be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf007274b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepared by the Secretary at any time; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf007274c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submitted to the Secretary by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf007274d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an association of producers of the agricultural commodity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf007274e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person that may be affected by the issuance of an order with respect to the agricultural commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf007274f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of proposed order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that a proposed order is consistent with and will effectuate the purpose of this subchapter, the Secretary shall publish the proposed order in the Federal Register and give due notice and opportunity for public comment on the proposed order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072750-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existence of other orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In deciding whether a proposal for an order is consistent with and will effectuate the purpose of this subchapter, the Secretary may consider the existence of other Federal promotion, research, and information programs or orders issued or developed pursuant to any other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0072751-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preparation of final order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for public comment under paragraph (2) regarding a proposed order, the Secretary shall take into consideration the comments received in preparing a final order. The Secretary shall ensure that the final order is in conformity with the terms, conditions, and requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0072752-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance and effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that the final order developed with respect to an agricultural commodity is consistent with and will effectuate the purpose of this subchapter, the Secretary shall issue the final order. Except in the case of an order for which an initial referendum is conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7417/a"},"text":"section 7417(a) of this title","children":[],"tail":", the final order shall be issued and become effective not later than 270 days after the date of publication of the proposed order that was the basis for the final order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0072753-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7413/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From time to time the Secretary may amend any order, consistent with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7422"},"text":"section 7422 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0072754-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s514"},"text":"Pub. L. 104–127, title V, § 514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1035"},"text":"110 Stat. 1035","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
