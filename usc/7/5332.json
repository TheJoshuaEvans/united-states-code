{"tag":"section","attrib":{"id":"idefc6c2b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5332"},"text":null,"children":[{"tag":"num","attrib":{"value":"5332"},"text":"§ 5332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Council","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc6c2ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5332/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide scientific and technical advice on the development and implementation of all components of the coordinated program and the comprehensive plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c2bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5332/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the scientific and technical quality of the comprehensive plan and the effectiveness of the coordinated program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c2bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5332/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend to the Secretaries, on an annual basis, means of enhancing the comprehensive plan and the coordinated program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc6c2bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5332/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Secretaries annual reports that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc6c2be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5332/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall contain the components specified in paragraphs (2) and (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc6c2bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5332/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be included in full in the biennial reports of the Secretaries to the President for transmittal to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5312/b"},"text":"section 5312(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc6c2c0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/445/tII/s202"},"text":"Pub. L. 101–445, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-22"},"text":"Oct. 22, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1042"},"text":"104 Stat. 1042","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
