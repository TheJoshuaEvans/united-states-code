{"tag":"section","attrib":{"id":"idef9971b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155"},"text":null,"children":[{"tag":"num","attrib":{"value":"3155"},"text":"§ 3155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural and food policy research centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9971b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with this section, the Secretary shall, acting through the Office of the Chief Economist, make competitive grants to, or enter into cooperative agreements with, policy research centers described in subsection (b) to conduct research and education programs that are objective, operationally independent, and external to the Federal Government and that concern the effect of public policies and trade agreements on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9971b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the farm and agricultural sectors (including commodities, livestock, dairy, and specialty crops);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9971b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9971b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural families, households, and economies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9971b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumers, food, and nutrition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9971b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity eligible to apply for funding under subsection (a) is a State agricultural experiment station, college or university, or other public research institution or organization that has a history of providing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9971b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unbiased, nonpartisan economic analysis to Congress on the areas specified in paragraphs (1) through (4) of subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9971ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" objective, scientific information to Federal agencies and the public to support and enhance efficient, accurate implementation of Federal drought preparedness and drought response programs, including interagency thresholds used to determine eligibility for mitigation or emergency assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9971bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making awards under this section, the Secretary shall give a preference to policy research centers that have—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9971bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extensive databases, models, and demonstrated experience in providing Congress with agricultural market projections, rural development analysis, agricultural policy analysis, and baseline projections at the farm, multiregional, national, and international levels; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9971bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information, analysis, and research relating to drought mitigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9971be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under this section, funding may be provided for disciplinary and interdisciplinary research and education concerning policy research activities consistent with this section, including activities that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9971bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantify the implications of public policies and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9971c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop theoretical and applied research methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9971c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect, analyze, and disseminate data for policymakers, analysts, and individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9971c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop programs to train analysts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9971c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3155/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9971c4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1419A"},"text":"Pub. L. 95–113, title XIV, § 1419A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s807"},"text":"Pub. L. 104–127, title VIII, § 807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1162"},"text":"110 Stat. 1162","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tII/s224"},"text":"Pub. L. 105–185, title II, § 224","children":[],"tail":", title III, § 301(a)(3), "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/540"},"text":"112 Stat. 540","children":[],"tail":", 562; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII"},"text":"Pub. L. 107–171, title VII","children":[],"tail":", §§ 7103, 7216, "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/432"},"text":"116 Stat. 432","children":[],"tail":", 449; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7111"},"text":"Pub. L. 110–234, title VII, § 7111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1219"},"text":"122 Stat. 1219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7111, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1980; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7106"},"text":"Pub. L. 113–79, title VII, § 7106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/869"},"text":"128 Stat. 869","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7108"},"text":"Pub. L. 115–334, title VII, § 7108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4783"},"text":"132 Stat. 4783","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9971c5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef9971c6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef9971c7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef9971c8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7106/1"},"text":"Pub. L. 113–79, § 7106(1)","children":[],"tail":", substituted “Agricultural and food policy” for “Policy” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7106/2"},"text":"Pub. L. 113–79, § 7106(2)","children":[],"tail":", substituted “Secretary shall, acting through the Office of the Chief Economist, make competitive grants to, or enter into cooperative agreements with,” for “Secretary may make grants, competitive grants, and special research grants to, and enter into cooperative agreements and other contracting instruments with,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7106/3"},"text":"Pub. L. 113–79, § 7106(3)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “State agricultural experiment stations, colleges and universities, other research institutions and organizations (including the Food Agricultural Policy Research Institute, the Agricultural and Food Policy Center, the Rural Policy Research Institute, and the National Drought Mitigation Center), private organizations, corporations, and individuals shall be eligible to apply for funding under subsection (a) of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7106/5"},"text":"Pub. L. 113–79, § 7106(5)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7106/4"},"text":"Pub. L. 113–79, § 7106(4)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7106/6"},"text":"Pub. L. 113–79, § 7106(6)","children":[],"tail":", inserted “applied” after “theoretical and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7106/7"},"text":"Pub. L. 113–79, § 7106(7)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e). Prior to amendment, text read as follows: “There are authorized to be appropriated such sums as are necessary to carry out this section for each of fiscal years 1996 through 2012.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7106/4"},"text":"Pub. L. 113–79, § 7106(4)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7111/1"},"text":"Pub. L. 110–246, § 7111(1)","children":[],"tail":", inserted “(including commodities, livestock, dairy, and specialty crops)” after “agricultural sectors”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7111/2"},"text":"Pub. L. 110–246, § 7111(2)","children":[],"tail":", inserted “(including the Food Agricultural Policy Research Institute, the Agricultural and Food Policy Center, the Rural Policy Research Institute, and the National Drought Mitigation Center)” after “research institutions and organizations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7111/3"},"text":"Pub. L. 110–246, § 7111(3)","children":[],"tail":", substituted “2012” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7216"},"text":"Pub. L. 107–171, § 7216","children":[],"tail":", substituted “collect, analyze, and disseminate data” for “collect and analyze data”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7103"},"text":"Pub. L. 107–171, § 7103","children":[],"tail":", substituted “2007” for “2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s224"},"text":"Pub. L. 105–185, § 224","children":[],"tail":", inserted “and trade agreements” after “public policies” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s301/a/3"},"text":"Pub. L. 105–185, § 301(a)(3)","children":[],"tail":", substituted “each of fiscal years 1996 through 2002” for “fiscal years 1996 and 1997”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef9971c9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef9971ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
