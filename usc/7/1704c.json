{"tag":"section","attrib":{"id":"ideee90c58-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1704c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1704c"},"text":"§ 1704c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments by Secretary of Defense in liquidation of amount due for foreign currencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall pay to the Commodity Credit Corporation an amount not to exceed $6,000,000 per year until the amount due for foreign currencies used for housing constructed or acquired under title II of the Food for Peace Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1721–172"},"text":"7 U.S.C. 1721–172","children":[],"tail":"6) has been liquidated."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideee90c59-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214/s9/a"},"text":"Pub. L. 97–214, § 9(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-12"},"text":"July 12, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/174"},"text":"96 Stat. 174","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3001/b/1/A"},"text":"Pub. L. 110–246, title III, § 3001(b)(1)(A)","children":[],"tail":", (2)(C), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1820"},"text":"122 Stat. 1820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideee90c5a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideee90c5b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideee90c5c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food for Peace Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1721–172"},"text":"7 U.S.C. 1721–172","children":[],"tail":"6), referred to in text, is "},{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"act July 10, 1954, ch. 469","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/457"},"text":"68 Stat. 457","children":[],"tail":". Title II of the Act is classified generally to subchapter III (§ 1721 et seq.) of chapter 41 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideee90c5d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section consists of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/214/s9/a"},"text":"section 9(a) of Pub. L. 97–214","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/pl/97/214/s9/b"},"text":"Section 9(b) of Pub. L. 97–214","children":[],"tail":" is classified as a note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1594k"},"text":"section 1594k of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Military Construction Codification Act, and not as part of the Food for Peace Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideee90c5e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" substituted “Food for Peace Act” for “Agricultural Trade Development and Assistance Act of 1954”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideee90c5f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideee90c60-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideee90c61-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", and applicable to military construction projects, and to construction and acquisition of military family housing before, on or after such date, see "},{"tag":"ref","attrib":{"href":"/us/pl/97/214/s12/a"},"text":"section 12(a) of Pub. L. 97–214","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2801"},"text":"section 2801 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
