{"tag":"section","attrib":{"id":"idef248f84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2006b"},"text":"§ 2006b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef248f85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall evaluate, in accordance with regulations issued by the Secretary, the farming plan and financial situation of each qualified farmer or rancher applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248f86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating the farming plan and financial situation of an applicant under this section, the Secretary shall determine—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef248f87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount that the applicant will need to borrow to carry out the proposed farming plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248f88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of interest that the applicant would need to be able to cover expenses and build an adequate equity base;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248f89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the goals of the proposed farming plan of the applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248f8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial viability of the plan and any changes that are necessary to make the plan viable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248f8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether assistance is necessary under this chapter and, if so, the amount of the assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248f8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may contract with a third party (including those entities eligible to provide borrower training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2006a/b"},"text":"section 2006a(b) of this title","children":[],"tail":") to conduct loan assessments under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248f8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of loans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef248f8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Loan assessments conducted under this section shall include annual review of direct loans, and periodic review (as determined necessary by the Secretary) of guaranteed loans, made under this chapter to assess the progress of a borrower in meeting the goals for the farm or ranch operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248f8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may contract with an entity that is eligible to provide borrower training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2006a/b"},"text":"section 2006a(b) of this title","children":[],"tail":" to conduct loan reviews under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248f90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Problem assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a borrower is delinquent in payments on a direct or guaranteed loan made under this chapter, the Secretary or the contracting entity shall determine the cause of, and action necessary to correct, the delinquency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248f91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue regulations providing guidelines for loan assessments conducted under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef248f92-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s360"},"text":"Pub. L. 87–128, title III, § 360","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1819"},"text":"Pub. L. 101–624, title XVIII, § 1819","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3830"},"text":"104 Stat. 3830","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tV"},"text":"Pub. L. 107–171, title V","children":[],"tail":", §§ 5317, 5318, "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/348"},"text":"116 Stat. 348","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef248f93-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef248f94-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef248f95-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a), (b)(5), and (d)(1), (3), was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":", known as the Consolidated Farm and Rural Development Act, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef248f96-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s5317"},"text":"Pub. L. 107–171, § 5317","children":[],"tail":", substituted “The Secretary” for “After an applicant is determined eligible for assistance under this chapter by the appropriate county committee established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1982"},"text":"section 1982 of this title","children":[],"tail":", the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s5318"},"text":"Pub. L. 107–171, § 5318","children":[],"tail":", substituted “annual review” for “biannual review”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
