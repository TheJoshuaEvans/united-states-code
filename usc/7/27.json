{"tag":"section","attrib":{"id":"idede2c097-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s27"},"text":null,"children":[{"tag":"num","attrib":{"value":"27"},"text":"§ 27.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idede2c098-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s27/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bank","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In sections 27 to 27f of this title, the term “bank” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idede2c099-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s27/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any depository institution (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/c"},"text":"section 1813(c) of title 12","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede2c09a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s27/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any foreign bank or branch or agency of a foreign bank (each as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s3101"},"text":"section 3101 of title 12","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede2c09b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s27/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal or State credit union (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752"},"text":"section 1752 of title 12","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede2c09c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s27/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corporation organized under section 25A of the Federal Reserve Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s611"},"text":"12 U.S.C. 611","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede2c09d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s27/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any corporation operating under section 25 of the Federal Reserve Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s601"},"text":"12 U.S.C. 601","children":[],"tail":" et seq.];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede2c09e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s27/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any trust company; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede2c09f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s27/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any subsidiary of any entity described in paragraph ","children":[{"tag":"ref","attrib":{"idref":"fn002061"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002061"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “paragraphs”."}],"tail":" (1) through (6) of this subsection, if the subsidiary is regulated as if the subsidiary were part of the entity and is not a broker or dealer (as such terms are defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"section 78c of title 15","children":[],"tail":") or a futures commission merchant (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a"},"text":"section 1a of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idede2c0a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s27/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identified banking product","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In sections 27 to 27f of this title, the term “identified banking product” shall have the same meaning as in paragraphs (1) through (5) of section 206(a) of the Gramm-Leach-Bliley Act, except that in applying such section for purposes of sections 27 to 27f of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idede2c0a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s27/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “bank” shall have the meaning given in subsection (a) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede2c0a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s27/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “qualified investor” means eligible contract participant (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a"},"text":"section 1a of this title","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"December 21, 2000","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idede2c0a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s27/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hybrid instrument","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In sections 27 to 27f of this title, the term “hybrid instrument” means an identified banking product not excluded by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s27a"},"text":"section 27a of this title","children":[],"tail":", offered by a bank, having one or more payments indexed to the value, level, or rate of, or providing for the delivery of, one or more commodities (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a"},"text":"section 1a of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idede2c0a4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tIV/s402"},"text":"Pub. L. 106–554, § 1(a)(5) [title IV, § 402]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–457; "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII"},"text":"Pub. L. 111–203, title VII","children":[],"tail":", §§ 721(e)(9), 725(g)(1)(B), "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1672"},"text":"124 Stat. 1672","children":[],"tail":", 1694.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idede2c0a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idede2c0a6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idede2c0a7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 25A of the Federal Reserve Act, referred to in subsec. (a)(4), is classified to subchapter II (§ 611 et seq.) of chapter 6 of Title 12, Banks and Banking. Section 25 of the Federal Reserve Act, referred to in subsec. (a)(5), is classified to subchapter I (§ 601 et seq.) of chapter 6 of Title 12.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 206 of the Gramm-Leach-Bliley Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/102/s206"},"text":"section 206 of Pub. L. 106–102","children":[],"tail":" which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"section 78c of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idede2c0a8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Legal Certainty for Bank Products Act of 2000, and also as part of the Commodity Futures Modernization Act of 2000, and not as part of the Commodity Exchange Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idede2c0a9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s721/e/9/A"},"text":"Pub. L. 111–203, § 721(e)(9)(A)","children":[],"tail":", substituted “section 1a” for “section 1a(20)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s721/e/9/B"},"text":"Pub. L. 111–203, § 721(e)(9)(B)","children":[],"tail":", substituted “section 1a” for “section 1a(12)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s721/e/9/C"},"text":"Pub. L. 111–203, § 721(e)(9)(C)","children":[],"tail":", substituted “section 1a” for “section 1a(4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203/s725/g/1/B"},"text":"Pub. L. 111–203, § 725(g)(1)(B)","children":[],"tail":", struck out subsec. (d) which defined covered swap agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idede2c0aa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idede2c0ab-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective on the later of 360 days after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", or, to the extent a provision of subtitle A (§§ 711–754) of title VII of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" requires a rulemaking, not less than 60 days after publication of the final rule or regulation implementing such provision of subtitle A, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s754"},"text":"section 754 of Pub. L. 111–203","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a"},"text":"section 1a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idede2c0ac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of sections 27 to 27f of this title as the “Legal Certainty for Bank Products Act of 2000”, see section 1(a)(5) [title IV, § 401] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":", set out as a Short Title of 2000 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"section 1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
