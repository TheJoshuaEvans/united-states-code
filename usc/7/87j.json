{"tag":"section","attrib":{"id":"idedf11898-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87j"},"text":null,"children":[{"tag":"num","attrib":{"value":"87j"},"text":"§ 87j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedf11899-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; number and terms of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ninety days after ","children":[{"tag":"date","attrib":{"date":"1988-10-24"},"text":"October 24, 1988","children":[],"tail":", the Secretary shall establish an advisory committee to provide advice to the Secretary with respect to implementation of this chapter consistent with the declarations of policy in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s74"},"text":"section 74 of this title","children":[],"tail":". The advisory committee shall consist of fifteen members, appointed by the Secretary, who represent the interests of all segments of the grain producing, processing, storing, merchandising, consuming, and exporting industries, including grain inspection and weighing agencies and scientists with expertise in research related to the policies established in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s74"},"text":"section 74 of this title","children":[],"tail":". Members of the advisory committee shall be appointed to three-year terms, except that of the initial fifteen members of the advisory committee first appointed following the enactment of this section, five shall be appointed for terms of one year and five shall be appointed for terms of two years. No member of the advisory committee may serve successively for more than 2 terms."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf1189a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5 as governing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The advisory committee shall be governed by the provisions of chapter 10 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf1189b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clerical assistance and staff personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide the advisory committee with necessary clerical assistance and staff personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf1189c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the advisory committee shall serve without compensation, if not otherwise officers or employees of the United States, except that members shall, while away from their homes or regular places of business in the performance of services under this chapter, be allowed travel expenses, including per diem in lieu of subsistence, as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf1189d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expiration of Secretary’s authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided to the Secretary for the establishment and maintenance of an advisory committee under this section shall expire on ","children":[{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002071"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002071"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See United States Grain Standards Act Extension note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedf1189e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. B, § 21, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/518/s2/5"},"text":"Pub. L. 100–518, § 2(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2586"},"text":"102 Stat. 2586","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/156"},"text":"Pub. L. 103–156","children":[],"tail":", §§ 13(b)(1), 14(c), "},{"tag":"date","attrib":{"date":"1993-11-24"},"text":"Nov. 24, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1529"},"text":"107 Stat. 1529","children":[],"tail":", 1530; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s293/a/7"},"text":"Pub. L. 103–354, title II, § 293(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3237"},"text":"108 Stat. 3237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tI/s109"},"text":"Pub. L. 106–472, title I, § 109","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2060"},"text":"114 Stat. 2060","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/83/s1/a"},"text":"Pub. L. 109–83, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-09-30"},"text":"Sept. 30, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2053"},"text":"119 Stat. 2053","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/54/tIII/s301/g"},"text":"Pub. L. 114–54, title III, § 301(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/520"},"text":"129 Stat. 520","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/216/s7"},"text":"Pub. L. 116–216, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-11"},"text":"Dec. 11, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1050"},"text":"134 Stat. 1050","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/20"},"text":"Pub. L. 117–286, § 4(a)(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4307"},"text":"136 Stat. 4307","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedf1189f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idedf118a0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idedf118a1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The enactment of this section, referred to in subsec. (a), means ","children":[{"tag":"date","attrib":{"date":"1988-10-24"},"text":"Oct. 24, 1988","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/100/518"},"text":"Pub. L. 100–518","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idedf118a2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5.” for “the Federal Advisory Committee Act.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/216/s7/1"},"text":"Pub. L. 116–216, § 7(1)","children":[],"tail":", in last sentence, substituted “successively for more than 2 terms” for “successive terms”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/216/s7/2"},"text":"Pub. L. 116–216, § 7(2)","children":[],"tail":", substituted “2025” for “2020”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/54"},"text":"Pub. L. 114–54","children":[],"tail":" substituted “2020” for “2015”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (e). ","chi