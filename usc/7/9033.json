{"tag":"section","attrib":{"id":"idf04c465b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9033"},"text":null,"children":[{"tag":"num","attrib":{"value":"9033"},"text":"§ 9033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04c465c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9033/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of each loan commodity, a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9031"},"text":"section 9031 of this title","children":[],"tail":" shall have a term of 9 months beginning on the first day of the first month after the month in which the loan is made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c465d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9033/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extensions prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not extend the term of a marketing assistance loan for any loan commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04c465e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1203"},"text":"Pub. L. 113–79, title I, § 1203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/676"},"text":"128 Stat. 676","children":[],"tail":".)"}],"tail":"\n"}],"tail":nul