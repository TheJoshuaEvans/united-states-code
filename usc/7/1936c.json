{"tag":"section","attrib":{"id":"idef0f3313-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1936c"},"text":"§ 1936c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relending program to resolve ownership and succession on farmland","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef0f3314-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make loans to eligible entities described in subsection (b) so that the eligible entities may relend the funds to individuals and entities for the purposes described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f3315-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Entities eligible for loans described in subsection (a) are cooperatives, credit unions, and nonprofit organizations with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0f3316-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certification under section 1805.201 of title 12, Code of Federal Regulations (or successor regulations), to operate as a lender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f3317-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experience assisting socially disadvantaged farmers and ranchers (as defined in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279"},"text":"section 2279 of this title","children":[],"tail":") or limited resource or new and beginning farmers and ranchers, rural businesses, cooperatives, or credit unions, including experience in making and servicing agricultural and commercial loans; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f3318-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to provide adequate assurance of the repayment of a loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f3319-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proceeds from loans made by the Secretary pursuant to subsection (a) shall be re-lent by eligible entities for projects that assist heirs with undivided ownership interests to resolve ownership and succession on farmland that has multiple owners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f331a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making loans under subsection (a), the Secretary shall give preference to eligible entities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0f331b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with not less than 10 years of experience serving socially disadvantaged farmers and ranchers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f331c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in States that have adopted a statute consisting of an enactment or adoption of the Uniform Partition of Heirs Property Act, as approved and recommended for enactment in all States by the National Conference of Commissioners on Uniform State Laws in 2010, that relend to owners of heirs property (as defined in that Act).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f331d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan terms and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following terms and conditions shall apply to loans made under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0f331e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The interest rate at which intermediaries may borrow funds under this section shall be determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f331f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The rates, terms, and payment structure for borrowers to which intermediaries lend shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0f3320-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the intermediary in an amount sufficient to cover the cost of operating and sustaining the revolving loan fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f3321-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clearly and publicly disclosed to qualified ultimate borrowers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f3322-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Borrowers to which intermediaries lend shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0f3323-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required to complete a succession plan as a condition of the loan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f3324-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be offered the opportunity to borrow sufficient funds to cover costs associated with the succession plan under subparagraph (A) and other associated legal and closing costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f3325-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing the operation and outcomes of the program under this section, with recommendations on how to strengthen the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f3326-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef0f3327-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s310I"},"text":"Pub. L. 87–128, title III, § 310I","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5104"},"text":"Pub. L. 115–334, title V, § 5104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4669"},"text":"132 Stat. 4669","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
