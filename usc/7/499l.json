{"tag":"section","attrib":{"id":"idee3881a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s499l"},"text":null,"children":[{"tag":"num","attrib":{"value":"499l"},"text":"§ 499l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations; report to Attorney General; proceedings; costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may report any violation of this chapter for which a civil penalty is provided to the Attorney General of the United States, who shall cause appropriate proceedings to be commenced and prosecuted in the proper courts of the United States without delay. The costs and expenses of such proceedings shall be paid out of the appropriation for the expenses of the courts of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee3881a6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-06-10/ch436/s12"},"text":"June 10, 1930, ch. 436, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/536"},"text":"46 Stat. 536","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee3881a7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee3881a8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee3881a9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s562"},"text":"section 562 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
