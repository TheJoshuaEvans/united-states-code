{"tag":"section","attrib":{"id":"ideeedc7bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1727d"},"text":"§ 1727d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local currency accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeedc7be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention of proceeds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent determined to be appropriate by the Administrator, revenues generated from the sale, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1727c/2"},"text":"section 1727c(2) of this title","children":[],"tail":", of agricultural commodities provided under this subchapter shall be deposited into a separate account (that may be interest bearing) in the recipient country to be disbursed for the benefit of such country in accordance with local currency agreements entered into between the recipient country and the Administrator. The Administrator may determine not to deposit such revenues in a separate account if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeedc7bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" local currencies are to be programmed for specific economic development purposes listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1727e/a"},"text":"section 1727e(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc7c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient country programs an equivalent amount of money for such purposes as specified in an agreement entered into by the Administrator and the recipient country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc7c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ownership and programming of accounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proceeds of sales pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1727c/2"},"text":"section 1727c(2) of this title","children":[],"tail":" shall be the property of the recipient country or the United States, as specified in the applicable agreement. Such proceeds shall be utilized for the benefit of the recipient country, shall be jointly programmed by the Administrator and the government of the recipient country, and shall be disbursed for the benefit of such country in accordance with local currency agreements between the Administrator and that government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc7c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overall development strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall consider the local currency proceeds as an integral part of the overall development strategy of the Agency for International Development and the recipient country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeedc7c3-