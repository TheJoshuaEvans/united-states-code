{"tag":"section","attrib":{"id":"idef64f335-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032"},"text":null,"children":[{"tag":"num","attrib":{"value":"2032"},"text":"§ 2032.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Automated data processing and information retrieval systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef64f336-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards and procedures for reviews","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f337-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial reviews","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef64f338-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", the Secretary shall complete a review of regulations and standards (in effect on "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":") for the approval of an automated data processing and information retrieval system maintained by a State (hereinafter in this section referred to as a “system”) to determine the extent to which the regulations and standards contribute to a more effective and efficient program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f339-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall revise regulations (in effect on ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":") to take into account the findings of the review conducted under subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f33a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation of existing systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations shall require States to incorporate all or part of systems in use elsewhere, unless a State documents that the design and operation of an alternative system would be less costly. The Secretary shall establish standards to define the extent of modification of the systems for which payments will be made under either section 2025(a) or 2025(g) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f33b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Proposed systems shall meet standards established by the Secretary for timely implementation of proper changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f33c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost effectiveness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Criteria for the approval of a system under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2025/g"},"text":"section 2025(g) of this title","children":[],"tail":" shall include the cost effectiveness of the proposed system. On implementation of the approved system, a State shall document the actual cost and benefits of the system."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f33d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational reviews","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct such reviews as are necessary to ensure that systems—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef64f33e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with conditions of initial funding approvals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f33f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequately support program delivery in compliance with this chapter and regulations issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef64f340-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for approval of systems","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f341-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After conducting the review required under subsection (a), the Secretary shall establish standards for approval of systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f342-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall implement the standards established by the Secretary within a reasonable period of time, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f343-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic compliance reviews","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct appropriate periodic reviews of systems to ensure compliance with the standards established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef64f344-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2032/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":", the Secretary shall report to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate on the extent to which State agencies have developed and are operating effective systems that support supplemental nutrition assistance program delivery in compliance with this chapter and regulations issued under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef64f345-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/525/s23"},"text":"Pub. L. 88–525, § 23","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVII/s1763/a"},"text":"Pub. L. 101–624, title XVII, § 1763(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3805"},"text":"104 Stat. 3805","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIV/s4001/b"},"text":"Pub. L. 110–234, title IV, § 4001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1092"},"text":"122 Stat. 1092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title IV, § 4001(b), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1853.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef64f346-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef64f347-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef64f348-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", referred to in subsec. (a)(1)(B), was in the original “the date of enactment of this Act”, which was translated as meaning the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", which enacted this section, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef64f349-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4001/b"},"text":"Pub. L. 110–246, § 4001(b)","children":[],"tail":", substituted “supplemental nutrition assistance program” for “food stamp program”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef64f34a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef64f34b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4001/b"},"text":"section 4001(b) of Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-10-01"},"text":"Oct. 1, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4407"},"text":"section 4407 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1161"},"text":"section 1161 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
