{"tag":"section","attrib":{"id":"idf00be268-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7463"},"text":null,"children":[{"tag":"num","attrib":{"value":"7463"},"text":"§ 7463.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00be269-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7463/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To effectuate the purposes of this subchapter specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7461/b"},"text":"section 7461(b) of this title","children":[],"tail":", the Secretary shall issue an order applicable to producers, handlers, and importers of kiwifruit. Any such order shall be national in scope. Not more than 1 order shall be in effect under this subchapter at any 1 time."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be26a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7463/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be26b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7463/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal for issuance of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person that will be affected by this subchapter may request the issuance of, and submit a proposal for, an order under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be26c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7463/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the receipt of a request and proposal for an order, the Secretary shall publish a proposed order and give due notice and opportunity for public comment on the proposed order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be26d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7463/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for public comment are provided under paragraph (2), the Secretary shall issue an order, taking into consideration the comments received and including in the order provisions necessary to ensure that the order is in conformity with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be26e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7463/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may amend any order issued under this section. The provisions of this subchapter applicable to an order shall be applicable to an amendment to an order, except that an amendment to an order shall not require a referendum to become effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00be26f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s554"},"text":"Pub. L. 104–127, title V, § 554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1065"},"text":"110 Stat. 1065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s603/a"},"text":"Pub. L. 105–185, title VI, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/585"},"text":"112 Stat. 585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf00be270-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf00be271-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf00be272-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185"},"text":"Pub. L. 105–185","children":[],"tail":" inserted “, except that an amendment to an order shall not require a referendum to become effective” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
