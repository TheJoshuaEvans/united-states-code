{"tag":"section","attrib":{"id":"idef81a371-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2285"},"text":null,"children":[{"tag":"num","attrib":{"value":"2285"},"text":"§ 2285.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget prohibitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No advisory committee may expend funds in excess of its estimated annual operating costs by more than 10 per centum or $500, whichever is greater, until it provides the Secretary with an explanation of the need for the additional expenditure and the Secretary approves such additional expenditure.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef81a372-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXVIII/s1805"},"text":"Pub. L. 95–113, title XVIII, § 1805","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1042"},"text":"91 Stat. 1042","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXI/s1116/a"},"text":"Pub. L. 97–98, title XI, § 1116(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1271"},"text":"95 Stat. 1271","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef81a373-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef81a374-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef81a375-3a6e-11f1-addd-bbaf0b3f68e9"},"text"