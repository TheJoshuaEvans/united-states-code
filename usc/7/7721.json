{"tag":"section","attrib":{"id":"idf01caaad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721"},"text":null,"children":[{"tag":"num","attrib":{"value":"7721"},"text":"§ 7721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plant pest and disease management and disaster prevention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf01caaae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01caaaf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early plant pest detection and surveillance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “early plant pest detection and surveillance” means the full range of activities undertaken to find newly introduced plant pests, whether the plant pests are new to the United States or new to certain areas of the United States, before—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01caab0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plant pests become established; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caab1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plant pest infestations become too large and costly to eradicate or control.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caab2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specialty crop","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “specialty crop” has the meaning given the term in section 3 of the Specialty Crops Competitiveness Act of 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1621"},"text":"7 U.S.C. 1621","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/108/465"},"text":"Public Law 108–465","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caab3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State department of agriculture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State department of agriculture” means an agency of a State that has a legal responsibility to perform early plant pest detection and surveillance activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01caab4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early plant pest detection and surveillance improvement program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01caab5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into a cooperative agreement with each State department of agriculture that agrees to conduct early plant pest detection and surveillance activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caab6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subsection, the Secretary shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01caab7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Plant Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caab8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other interested parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caab9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 10 of title 5","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 shall not apply to consultations under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caaba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01caabb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State department of agriculture seeking to enter into a cooperative agreement under this subsection shall submit to the Secretary an application containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caabc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall notify applicants of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf01caabd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements to be imposed on a State department of agriculture for auditing of, and reporting on, the use of any funds provided by the Secretary under the cooperative agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf01caabe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the criteria to be used to ensure that early pest detection and surveillance activities supported under the cooperative agreement are based on sound scientific data or thorough risk assessments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf01caabf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the means of identifying pathways of pest introductions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caac0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01caac1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plant pest detection and surveillance activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State department of agriculture that receives funds under this subsection shall use the funds to carry out early plant pest detection and surveillance activities approved by the Secretary to prevent the introduction or spread of a plant pest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caac2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subagreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection prevents a State department of agriculture from using funds received under paragraph (4) to enter into subagreements with political subdivisions of the State that have legal responsibilities relating to agricultural plant pest and disease surveillance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caac3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The non-Federal share of the cost of carrying out a cooperative agreement under this section may be provided in-kind, including through provision of such indirect costs of the cooperative agreement as the Secretary considers to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caac4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ability to provide funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not take the ability to provide non-Federal costs to carry out a cooperative agreement entered into under subparagraph (A) into consideration when deciding whether to enter into a cooperative agreement with a State department of agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caac5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special funding considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide funds to a State department of agriculture if the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01caac6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State department of agriculture is in a State that has a high risk of being affected by 1 or more plant pests or diseases, taking into consideration—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf01caac7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of international ports of entry in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf01caac8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the volume of international passenger and cargo entry into the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf01caac9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic location of the State and if the location or types of agricultural commodities produced in the State are conducive to agricultural pest and disease establishment due to the climate, crop diversity, or natural resources (including unique plant species) of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf01caaca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the Secretary has determined that an agricultural pest or disease in the State is a Federal concern; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caacb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the early plant pest detection and surveillance activities supported with the funds will likely—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf01caacc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent the introduction and establishment of plant pests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf01caacd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a comprehensive approach to compliment Federal detection efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caace-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date of completion of an early plant pest detection and surveillance activity conducted by a State department of agriculture using funds provided under this section, the State department of agriculture shall submit to the Secretary a report that describes the purposes and results of the activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01caacf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threat identification and mitigation program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01caad0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a threat identification and mitigation program to determine and address threats to the domestic production of crops.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caad1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the program established under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01caad2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop risk assessments of the potential threat to the agricultural industry of the United States from foreign sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caad3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with the National Plant Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caad4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement action plans for high consequence plant pest and diseases to assist in preventing the introduction and widespread dissemination of new plant pest and disease threats in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caad5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date of enactment of this paragraph, and annually thereafter, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report on the action plans described in paragraph (2), including an accounting of funds expended on the action plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01caad6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specialty crop certification and risk management systems","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide funds and technical assistance to specialty crop growers, organizations representing specialty crop growers, and State and local agencies working with specialty crop growers and organizations for the development and implementation of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01caad7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" audit-based certification systems, such as best management practices—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01caad8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address plant pests; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caad9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to mitigate the risk of plant pests in the movement of plants and plant products; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caada-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" nursery plant pest risk management systems, in collaboration with the nursery industry, research institutions, and other appropriate entities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01caadb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable growers to identify and prioritize nursery plant pests and diseases of regulatory significance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caadc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent the introduction, establishment, and spread of those plant pests and diseases; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caadd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the risk of and mitigate those plant pests and diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01caade-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Clean Plant Network","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01caadf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program to be known as the “National Clean Plant Network” (referred to in this subsection as the “Program”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caae0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the Program, the Secretary shall establish a network of clean plant centers for diagnostic and pathogen elimination services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01caae1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to produce clean propagative plant material; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caae2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain blocks of pathogen-tested plant material in sites located throughout the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caae3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of clean plant source material","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Clean plant source material may be made available to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01caae4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State for a certified plant program of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caae5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private nurseries and producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caae6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation and collaboration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Program, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01caae7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf01caae8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/e/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State departments of agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf01caae9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/e/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land-grant colleges and universities and NLGCA Institutions (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01caaea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable and with input from the appropriate State officials and industry representatives, use existing Federal or State facilities to serve as clean plant centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caaeb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for fiscal year 2013","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out the Program $5,000,000 for fiscal year 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01caaec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall make available to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01caaed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $12,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caaee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $45,000,000 for fiscal year 2010;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caaef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2011;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caaf0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2012;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caaf1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $62,500,000 for each of fiscal years 2014 through 2017;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caaf2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $75,000,000 for each of fiscal years 2018 through 2025; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caaf3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $90,000,000 for fiscal year 2026 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01caaf4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds for clean plant network","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds made available under subsection (f) to carry out this section for a fiscal year, not less than $5,000,000 shall be available to carry out the National Clean Plant Network under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01caaf5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on indirect costs for the consolidation of plant pest and disease management and disaster prevention programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Indirect costs charged against a cooperative agreement under this section shall not exceed the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01caaf6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15 percent of the total Federal funds provided under the cooperative agreement, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01caaf7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7721/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the indirect cost rate applicable to the recipient as otherwise established by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf01caaf8-3a6e-11f1-addd-bbaf0b3f68e9"},"te