{"tag":"section","attrib":{"id":"idef7a7803-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2266a"},"text":"§ 2266a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Century Farms program","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program under which the Secretary recognizes any farm that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7a7804-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State department of agriculture or similar statewide agricultural organization recognizes as a Century Farm; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7a7805-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7a7806-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is defined as a farm or ranch under section 4284.902 of title 7, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7a7807-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been in continuous operation for at least 100 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7a7808-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been owned by the same family for at least 100 consecutive years, as verified through deeds, wills, abstracts, tax statements, or other similar legal documents considered appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7a7809-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12508"},"text":"Pub. L. 115–334, title XII, § 12508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4990"},"text":"132 Stat. 4990","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7a780a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef7a780b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idef7a780c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” means the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2"},"text":"section 2 of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
