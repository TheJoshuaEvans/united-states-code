{"tag":"section","attrib":{"id":"ideff68504-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953"},"text":null,"children":[{"tag":"num","attrib":{"value":"6953"},"text":"§ 6953.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Healthy food financing initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff68505-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to enhance the authorities of the Secretary to support efforts to provide access to healthy food by establishing an initiative to improve access to healthy foods in underserved areas, to create and preserve quality jobs, and to revitalize low-income communities by providing loans and grants to eligible fresh, healthy food retailers and enterprises to overcome the higher costs and initial barriers to entry in underserved areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff68506-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff68507-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community development financial institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community development financial institution” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s4702"},"text":"section 4702 of title 12","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff68508-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Initiative” means the Healthy Food Financing Initiative established under subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff68509-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National fund manager","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “national fund manager” means a community development financial institution that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff6850a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in existence on the date of enactment of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff6850b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" certified by the Community Development Financial Institution Fund of the Department of Treasury to manage the Initiative for purposes of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff6850c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" raising private capital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff6850d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing financial and technical assistance to partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff6850e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding eligible projects to attract fresh, healthy food retailers and enterprises to underserved areas, in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff6850f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “partnership” means a regional, State, or local public-private partnership that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff68510-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is organized to improve access to fresh, healthy foods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff68511-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides financial and technical assistance to eligible projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff68512-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other criteria as the Secretary may establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff68513-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Perishable food","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “perishable food” means a staple food that is fresh, refrigerated, or frozen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff68514-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quality job","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “quality job” means a job that provides wages and other benefits comparable to, or better than, similar positions in existing businesses of similar size in similar local economies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff68515-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staple food","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff68516-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “staple food” means food that is a basic dietary item.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff68517-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “staple food” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff68518-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bread or cereal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff68519-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flour;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff6851a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fruits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff6851b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/7/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vegetables;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff6851c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/7/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meat; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff6851d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/b/7/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dairy products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff6851e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff6851f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an initiative to achieve the purpose described in subsection (a) in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff68520-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff68521-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff68522-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the Initiative, the Secretary shall provide funding to entities with eligible projects, as described in subparagraph (B), subject to the priorities described in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff68523-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds provided to an entity pursuant to clause (i) shall be used—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideff68524-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to create revolving loan pools of capital or other products to provide loans to finance eligible projects or partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideff68525-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide grants for eligible projects or partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideff68526-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide technical assistance to funded projects and entities seeking Initiative funding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideff68527-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cover administrative expenses of the national fund manager in an amount not to exceed 10 percent of the Federal funds provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff68528-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the approval of the Secretary, the national fund manager shall establish eligibility criteria for projects under the Initiative, which shall include the existence or planned execution of agreements—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff68529-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expand or preserve the availability of staple foods in underserved areas with moderate- and low-income populations by maintaining or increasing the number of retail outlets that offer an assortment of perishable food and staple food items, as determined by the Secretary, in those areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff6852a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as applicable, to accept benefits under the supplemental nutrition assistance program established under the Food and Nutrition Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff6852b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the Initiative, priority shall be given to projects that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff6852c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are located in severely distressed low-income communities, as defined by the Community Development Financial Institutions Fund of the Department of Treasury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff6852d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include 1 or more of the following characteristics:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideff6852e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project will create or retain quality jobs for low-income residents in the community.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideff6852f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project supports regional food systems and locally grown foods, to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideff68530-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In areas served by public transit, the project is accessible by public transit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideff68531-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/C/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project involves women- or minority-owned businesses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideff68532-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/C/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project receives funding from other sources, including other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideff68533-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/c/2/C/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The project otherwise advances the purpose of this section, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff68534-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6953/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $125,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff68535-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s243"},"text":"Pub. L. 103–354, title II, § 243","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIV/s4206"},"text":"Pub. L. 113–79, title IV, § 4206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/824"},"text":"128 Stat. 824","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIV/s4204"},"text":"Pub. L. 115–334, title IV, § 4204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4656"},"text":"132 Stat. 4656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff68536-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff68537-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideff68538-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food and Nutrition Act of 2008, referred to in subsec. (c)(2)(B)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/525"},"text":"Pub. L. 88–525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-31"},"text":"Aug. 31, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/703"},"text":"78 Stat. 703","children":[],"tail":", which is classified generally to chapter 51 (§ 2011 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"section 2011 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideff68539-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (a), (b)(3)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s4204/1"},"text":"Pub. L. 115–334, § 4204(1)","children":[],"tail":", (2), inserted “and enterprises” after “retailers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s4204/3"},"text":"Pub. L. 115–334, § 4204(3)","children":[],"tail":", inserted “as applicable,” before “to accept”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
