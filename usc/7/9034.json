{"tag":"section","attrib":{"id":"idf04c465f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034"},"text":null,"children":[{"tag":"num","attrib":{"value":"9034"},"text":"§ 9034.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04c4660-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall permit the producers on a farm to repay a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9031"},"text":"section 9031 of this title","children":[],"tail":" for a loan commodity (other than upland cotton, long grain rice, medium grain rice, extra long staple cotton, peanuts and confectionery and each other kind of sunflower seed (other than oil sunflower seed)) at a rate that is the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c4661-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9032"},"text":"section 9032 of this title","children":[],"tail":", plus interest (determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7283"},"text":"section 7283 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4662-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a rate (as determined by the Secretary) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c4663-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is calculated based on average market prices for the loan commodity during the preceding 30-day period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4664-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will minimize discrepancies in marketing loan benefits across State boundaries and across county boundaries; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4665-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a rate that the Secretary may develop using alternative methods for calculating a repayment rate for a loan commodity that the Secretary determines will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c4666-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize potential loan forfeitures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4667-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the accumulation of stocks of the commodity by the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4668-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the cost incurred by the Federal Government in storing the commodity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4669-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the commodity produced in the United States to be marketed freely and competitively, both domestically and internationally; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c466a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize discrepancies in marketing loan benefits across State boundaries and across county boundaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c466b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rates for upland cotton, long grain rice, and medium grain rice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c466c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall permit producers to repay a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9031"},"text":"section 9031 of this title","children":[],"tail":" for upland cotton, long grain rice, and medium grain rice at a rate that is the lesser of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c466d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9032"},"text":"section 9032 of this title","children":[],"tail":", plus interest (determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7283"},"text":"section 7283 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c466e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf04c466f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of long grain rice and medium grain rice, the prevailing world market price for the commodity, as determined and adjusted by the Secretary in accordance with this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c4670-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of upland cotton, the prevailing world market price for the commodity, as determined and adjusted by the Secretary in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4671-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund for upland cotton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a repayment for a marketing assistance loan for upland cotton at a rate described in paragraph (1)(B)(ii), the Secretary shall provide to the producer a refund (if any) in an amount equal to the difference between the lowest prevailing world market price, as determined and adjusted by the Secretary in accordance with this section, during the 30-day period following the date on which the producer repays the marketing assistance loan and the repayment rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c4672-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rates for extra long staple cotton","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Repayment of a marketing assistance loan for extra long staple cotton shall be at a rate that is the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c4673-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9032"},"text":"section 9032 of this title","children":[],"tail":", plus interest (determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7283"},"text":"section 7283 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4674-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevailing world market price for the commodity, as determined and adjusted by the Secretary in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c4675-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevailing world market price","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c4676-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9037"},"text":"section 9037 of this title","children":[],"tail":", the Secretary shall prescribe by regulation—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c4677-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a formula to determine the prevailing world market price for each of upland cotton, long grain rice, medium grain rice, and extra long staple cotton; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4678-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mechanism by which the Secretary shall announce periodically those prevailing world market prices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4679-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Upland cotton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of upland cotton, for any period when price quotations for Middling (M) 1","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"32","children":[],"tail":"-inch cotton are available, the formula under paragraph (1)(A) shall be based on the average of the 3 lowest-priced growths that are quoted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c467a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of prevailing world market price for upland cotton, extra long staple cotton, long grain rice, and medium grain rice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c467b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prevailing world market price for long grain rice and medium grain rice determined under subsection (d) shall be adjusted to United States quality and location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c467c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Upland cotton","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prevailing world market price for upland cotton determined under subsection (d)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c467d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be adjusted to United States quality and location, with the adjustment to include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf04c467e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduction equal to any United States Premium Factor for upland cotton of a quality higher than Middling (M) 1","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"32","children":[],"tail":"-inch; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c467f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average costs to market the commodity, including average transportation costs, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4680-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be further adjusted, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2032-07-31"},"text":"July 31, 2032","children":[],"tail":", if the Secretary determines the adjustment is necessary—"}],"tail":null},{"tag":"clause","attrib":{"id":"idf04c4681-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to minimize potential loan forfeitures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c4682-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to minimize the accumulation of stocks of upland cotton by the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c4683-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that upland cotton produced in the United States can be marketed freely and competitively, both domestically and internationally; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c4684-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to ensure an appropriate transition between current-crop and forward-crop price quotations, except that the Secretary may use forward-crop price quotations prior to July 31 of a marketing year only if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf04c4685-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are insufficient current-crop price quotations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf04c4686-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the forward-crop price quotation is the lowest such quotation available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4687-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extra long staple cotton","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prevailing world market price for extra long staple cotton determined under subsection (d)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c4688-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be adjusted to United States quality and location, with the adjustment to include the average costs to market the commodity, including average transportation costs, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4689-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be further adjusted, during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"2032-07-31"},"text":"July 31, 2032","children":[],"tail":", if the Secretary determines the adjustment is necessary—"}],"tail":null},{"tag":"clause","attrib":{"id":"idf04c468a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to minimize potential loan forfeitures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c468b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to minimize the accumulation of stocks of extra long staple cotton by the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c468c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that extra long staple cotton produced in the United States can be marketed freely and competitively; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c468d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to ensure an appropriate transition between current-crop and forward-crop price quotations, except that the Secretary may use forward-crop price quotations prior to July 31 of a marketing year only if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf04c468e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/3/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are insufficient current-crop price quotations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf04c468f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/3/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the forward-crop price quotation is the lowest such quotation available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4690-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines for additional adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making adjustments under this subsection, the Secretary shall establish a mechanism for determining and announcing the adjustments in order to avoid undue disruption in the United States market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c4691-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rates for confectionery and other kinds of sunflower seeds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall permit the producers on a farm to repay a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9031"},"text":"section 9031 of this title","children":[],"tail":" for confectionery and each other kind of sunflower seed (other than oil sunflower seed) at a rate that is the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c4692-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9032"},"text":"section 9032 of this title","children":[],"tail":", plus interest (determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7283"},"text":"section 7283 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4693-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the repayment rate established for oil sunflower seed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c4694-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of cotton storage costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c4695-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crop years 2014 through 2025","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective for each of the 2014 through 2025 crop years, the Secretary shall make cotton storage payments available in the same manner, and at the same rates as the Secretary provided storage payments for the 2006 crop of cotton, except that the rates shall be reduced by 10 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4696-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of cotton storage costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective for each of the 2026 through 2031 crop years, the Secretary shall make cotton storage payments for upland cotton and extra long staple cotton available in the same manner as the Secretary provided storage payments for the 2006 crop of upland cotton, except that the payment rate shall be equal to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c4697-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the submitted storage charge for the current marketing year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4698-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of storage in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf04c4699-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" California or Arizona, a payment rate of $4.90; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c469a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other State, a payment rate of $3.00.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c469b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rate for peanuts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall permit producers on a farm to repay a marketing assistance loan for peanuts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9031"},"text":"section 9031 of this title","children":[],"tail":" at a rate that is the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c469c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established for peanuts under subsection (a)(20) or (b)(20), as applicable, of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9032"},"text":"section 9032 of this title","children":[],"tail":", plus interest (determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7283"},"text":"section 7283 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c469d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a rate that the Secretary determines will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c469e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize potential loan forfeitures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c469f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the accumulation of stocks of peanuts by the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the cost incurred by the Federal Government in storing peanuts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c46a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow peanuts produced in the United States to be marketed freely and competitively, both domestically and internationally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c46a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to temporarily adjust repayment rates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c46a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of a severe disruption to marketing, transportation, or related infrastructure, the Secretary may modify the repayment rate otherwise applicable under this section for marketing assistance loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9031"},"text":"section 9031 of this title","children":[],"tail":" for a loan commodity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c46a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9034/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any adjustment made under paragraph (1) in the repayment rate for marketing assistance loans for a loan commodity shall be in effect on a short-term and temporary basis, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04c46a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1204"},"text":"Pub. L. 113–79, title I, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/676"},"text":"128 Stat. 676","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI"},"text":"Pub. L. 115–334, title I","children":[],"tail":", §§ 1201(b), 1202(b), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4509"},"text":"132 Stat. 4509","children":[],"tail":", 4510; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI"},"text":"Pub. L. 119–21, title I","children":[],"tail":", §§ 10309(c), 10310, "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/94"},"text":"139 Stat. 94","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04c46a6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04c46a7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf04c46a8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of law applicable to a loan commodity for the 2023 crop year pursuant to title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" applicable to the 2024 crop year for that loan commodity, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/c/1"},"text":"section 102(c)(1) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04c46a9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10310/1"},"text":"Pub. L. 119–21, § 10310(1)","children":[],"tail":", designated introductory provisions as par. (1) and inserted heading, redesignated former par. (1) as subpar. (A) of par. (1) and realigned margins, added subpar. (B) of par. (1) and par. (2), and struck out former par. (2) which read as follows: “the prevailing world market price for the commodity, as determined and adjusted by the Secretary in accordance with this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10310/2"},"text":"Pub. L. 119–21, § 10310(2)","children":[],"tail":", substituted “shall be at a rate that is the lesser of—” for “shall be at”, inserted par. (1) designation before “the loan rate”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10310/3"},"text":"Pub. L. 119–21, § 10310(3)","children":[],"tail":", designated introductory provisions as par. (1) and inserted heading, redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1) and realigned margins, substituted “medium grain rice, and extra long staple cotton” for “and medium grain rice” in subpar. (A), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10310/4/A"},"text":"Pub. L. 119–21, § 10310(4)(A)","children":[],"tail":", inserted “extra long staple cotton,” after “upland cotton,” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10310/4/B/i"},"text":"Pub. L. 119–21, § 10310(4)(B)(i)","children":[],"tail":", inserted “Upland” before “cotton” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10310/4/B/ii"},"text":"Pub. L. 119–21, § 10310(4)(B)(ii)","children":[],"tail":", substituted “2032” for “2024” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10310/4/C"},"text":"Pub. L. 119–21, § 10310(4)(C)","children":[],"tail":", (D), added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s10309/c"},"text":"Pub. L. 119–21, § 10309(c)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and substituted “2025” for “2023”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (e)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1201/b/1"},"text":"Pub. L. 115–334, § 1201(b)(1)","children":[],"tail":", substituted “2024” for “2019” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1201/b/2"},"text":"Pub. L. 115–334, § 1201(b)(2)","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1202/b"},"text":"Pub. L. 115–334, § 1202(b)","children":[],"tail":", substituted “subsection (a)(20) or (b)(20), as applicable, of section 9032” for “section 9032(a)(20)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
