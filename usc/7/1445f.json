{"tag":"section","attrib":{"id":"ideead637b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1445f"},"text":"§ 1445f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Emergency Food Reserve","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President is encouraged to enter into negotiations with other nations to develop an international system of food reserves to provide for humanitarian food relief needs and to establish and maintain a food reserve, as a contribution of the United States toward the development of such a system, to be made available in the event of food emergencies in foreign countries. The reserves shall be known as the International Emergency Food Reserve.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideead637c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"Oct. 31, 1949, ch. 792","children":[],"tail":", title I, § 111, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXI/s1102"},"text":"Pub. L. 95–113, title XI, § 1102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/953"},"text":"91 Stat. 953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideead637d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideead637e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideead637f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
