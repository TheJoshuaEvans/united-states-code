{"tag":"section","attrib":{"id":"idefa558d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295"},"text":null,"children":[{"tag":"num","attrib":{"value":"3295"},"text":"§ 3295.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International Agricultural Education Fellowship Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa558d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship program establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a fellowship program to be known as the International Agricultural Education Fellowship Program to provide fellowships to citizens of the United States to assist eligible countries in developing school-based agricultural education and youth extension programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa558d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible country described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, an eligible country is a developing country, as determined by the Secretary using a gross national income per capita test selected by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa558d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of fellowships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of providing a fellowship under this section are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa558d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop globally minded United States agriculturists with experience living abroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focus on meeting the food and fiber needs of the domestic population of eligible countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen and enhance trade linkages between eligible countries and the United States agricultural industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa558dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible candidates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide fellowships to citizens of the United States who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa558dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold at least a bachelors degree in an agricultural related field of study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have an understanding of United States school-based agricultural education and youth extension programs, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa558df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Candidate identification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the National FFA Organization, the National 4–H Council, and other entities as the Secretary determines are appropriate to identify candidates for fellowships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa558e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the management, coordination, evaluation, and monitoring of the Fellowship Program, except that the Secretary may contract out the management of the fellowship program to an outside organization with experience in implementing fellowship programs focused on building capacity for school-based agricultural education and youth extension programs in developing countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa558e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa558e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $5,000,000 to carry out this section for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa558e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3295/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds made available under this subsection shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa558e4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII/s3307"},"text":"Pub. L. 115–334, title III, § 3307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4620"},"text":"132 Stat. 4620","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa558e5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa558e6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefa558e7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agriculture Improvement Act of 2018, and not as part of the National Agricultural Research, Extension, and Teaching Policy Act of 1977 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefa558e8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idefa558e9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” as meaning the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2"},"text":"section 2 of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
