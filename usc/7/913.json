"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee59ec76-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this paragraph, referred to in par. (3)(B), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee59ec77-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee59ec78-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6104"},"text":"Pub. L. 110–246, § 6104","children":[],"tail":", amended section generally. Prior to amendment, text read as follows: “As used in this chapter the term ‘rural area’, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s924/b"},"text":"section 924(b) of this title","children":[],"tail":", shall be deemed to mean any area of the United States not included within the boundaries of any urban area, as defined by the Bureau of the Census, and such term shall be deemed to include both the farm and nonfarm population thereof; the term ‘farm’ shall be deemed to mean a farm as defined in the publications of the Bureau of the Census; the term ‘person’ shall be deemed to mean any natural person, firm, corporation, or association; the term ‘Territory’ shall be deemed to include any insular possession of the United States; and the term ‘Secretary’ shall be deemed to mean the Secretary of Agriculture.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" inserted before period at end “; and the term ‘Secretary’ shall be deemed to mean the Secretary of Agriculture”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/129"},"text":"Pub. L. 103–129","children":[],"tail":" inserted “, except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s924/b"},"text":"section 924(b) of this title","children":[],"tail":",” before “shall be deemed to mean” and substituted “urban area, as defined by the Bureau of the Census” for “city, village, or borough having a population in excess of fifteen hundred inhabitants,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-10-28"},"text":"Oct. 28, 1949","children":[],"tail":", inserted “title I,” in credit of act "},{"tag":"date","attrib":{"date":"1936-05-20"},"text":"May 20, 1936","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee59ec79-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"t