{"tag":"section","attrib":{"id":"idee59ec6b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s913"},"text":null,"children":[{"tag":"num","attrib":{"value":"913"},"text":"§ 913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee59ec6c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s913/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “farm” means a farm, as defined by the Bureau of the Census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ec6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s913/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ec6e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s913/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided otherwise in this chapter, the term “rural area” means the farm and nonfarm population of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee59ec6f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s913/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any area described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1991/a/13/C"},"text":"section 1991(a)(13)(C) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee59ec70-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s913/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any area within a service area of a borrower for which a borrower has an outstanding loan made under subchapters I through V as of the date of enactment of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ec71-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s913/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “territory” includes any insular possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ec72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s913/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee59ec73-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May