{"tag":"section","attrib":{"id":"idf02620bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935"},"text":null,"children":[{"tag":"num","attrib":{"value":"7935"},"text":"§ 7935.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan deficiency payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02620c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of loan deficiency payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02620c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (d), the Secretary may make loan deficiency payments available to producers on a farm that, although eligible to obtain a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7931"},"text":"section 7931 of this title","children":[],"tail":" with respect to a loan commodity, agree to forgo obtaining the loan for the commodity in return for loan deficiency payments under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02620c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unshorn pelts, hay, and silage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nongraded wool in the form of unshorn pelts and hay and silage derived from a loan commodity are not eligible for a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7931"},"text":"section 7931 of this title","children":[],"tail":". However, effective for the 2002 through 2007 crop years, the Secretary may make loan deficiency payments available under this section to producers on a farm that produce unshorn pelts or hay and silage derived from a loan commodity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02620c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A loan deficiency payment for a loan commodity or commodity referred to in subsection (a)(2) shall be computed by multiplying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02620c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment rate determined under subsection (c) for the commodity; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02620c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of the commodity produced by the eligible producers, excluding any quantity for which the producers obtain a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7931"},"text":"section 7931 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02620c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment rate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02620c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a loan commodity, the payment rate shall be the amount by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02620c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7932"},"text":"section 7932 of this title","children":[],"tail":" for the loan commodity; exceeds"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate at which a marketing assistance loan for the loan commodity may be repaid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7934"},"text":"section 7934 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02620ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unshorn pelts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of unshorn pelts, the payment rate shall be the amount by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02620cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7932"},"text":"section 7932 of this title","children":[],"tail":" for ungraded wool; exceeds"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate at which a marketing assistance loan for ungraded wool may be repaid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7934"},"text":"section 7934 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02620cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hay and silage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of hay or silage derived from a loan commodity, the payment rate shall be the amount by which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02620ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7932"},"text":"section 7932 of this title","children":[],"tail":" for the loan commodity from which the hay or silage is derived; exceeds"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate at which a marketing assistance loan for the loan commodity may be repaid under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7934"},"text":"section 7934 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02620d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for extra long staple cotton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply with respect to extra long staple cotton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02620d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date for payment rate determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine the amount of the loan deficiency payment to be made under this section to the producers on a farm with respect to a quantity of a loan commodity or commodity referred to in subsection (a)(2) using the payment rate in effect under subsection (c) as of the date the producers request the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02620d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special loan deficiency payment rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02620d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First-time loan commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the 2002 crop of wool, mohair, honey, dry peas, lentils and small chickpeas, in the case of producers of such a crop that would be eligible for a loan deficiency payment under this section except for the fact that the producers lost beneficial interest in the crop prior to the date of publication of the regulations implementing this section, the producers shall be eligible for a loan deficiency payment as of the date producers marketed or otherwise lost beneficial interest in the crop, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02620d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7935/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02620d5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1205"},"text":"Pub. L. 107–171, title I, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/158"},"text":"116 Stat. 158","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf02620d6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf02620d7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf02620d8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1205"},"text":"section 1205 of Pub. L. 107–171","children":[],"tail":". Subsec. (f)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1205"},"text":"section 1205 of Pub. L. 107–171","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7235"},"text":"section 7235 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
