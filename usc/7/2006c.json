{"tag":"section","attrib":{"id":"idef248f97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2006c"},"text":"§ 2006c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervised credit","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide adequate training to employees of the Farmers Home Administration on credit analysis and financial and farm management to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef248f98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" better acquaint the employees with what constitutes adequate financial data on which to base a direct or guaranteed loan approval decision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248f99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure proper supervision of farmer program loans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef248f9a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s361"},"text":"Pub. L. 87–128, title III, § 361","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1820"},"text":"Pub. L. 101–624, title XVIII, § 1820","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3830"},"text":"104 Stat. 3830","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
