{"tag":"section","attrib":{"id":"ideef764e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"1736dd"},"text":"§ 1736dd.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International food security technical assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef764e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736dd/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of international food security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “international food security” means access by any person at any time to food and nutrition that is sufficient for a healthy and productive life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef764e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736dd/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture (referred to in this section as the “Secretary”) shall compile information from appropriate mission areas of the Department of Agriculture (including the Food, Nutrition, and Consumer Services mission area) relating to the improvement of international food security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef764e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736dd/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public availability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To benefit programs for the improvement of international food security, the Secretary shall organize the information described in subsection (b) and make the information available in a format suitable for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef764e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736dd/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef764e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736dd/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" use by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef764e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736dd/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal, State, or local agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef764e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736dd/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency or instrumentality of the government of a foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef764e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736dd/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a domestic or international organization, including a domestic or international nongovernmental organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef764ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736dd/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intergovernmental organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef764eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736dd/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request by an entity described in subsection (c)(2), the Secretary may provide technical assistance to the entity to implement a program for the improvement of international food security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef764ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736dd/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall give priority to programs relating to the development of food and nutrition safety net systems with a focus on food insecure countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef764ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736dd/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef764ee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1543B"},"text":"Pub. L. 101–624, title XV, § 1543B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII/s3308"},"text":"Pub. L. 115–334, title III, § 3308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4621"},"text":"132 Stat. 4621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef764ef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef764f0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideef764f1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food, Agriculture, Conservation, and Trade Act of 1990, and not as part of the Food for Peace Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
