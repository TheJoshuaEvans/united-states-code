{"tag":"section","attrib":{"id":"ideef28316-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1736f"},"text":"§ 1736f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef28317-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef28318-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2008 and each fiscal year thereafter, $2,500,000,000 to carry out the emergency and nonemergency food assistance programs under subchapter III; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef28319-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such sums as are necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef2831a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the concessional credit sales program established under subchapter II;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef2831b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the grant program established under subchapter III–A; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef2831c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make payments to the Commodity Credit Corporation to the extent the Commodity Credit Corporation is not reimbursed under the programs under this chapter for the actual costs incurred or to be incurred by the Commodity Credit Corporation in carrying out such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef2831d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef2831e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2) and notwithstanding any other provision of law, the President may direct that up to 15 percent of the funds available for any fiscal year for carrying out any subchapter of this chapter be used to carry out any other subchapter of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef2831f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subchapter III–A funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President may direct that up to 50 percent of the funds available for any fiscal year for carrying out subchapter III–A be used to carry out subchapter III.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef28320-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In presenting the Budget of the United States, the President shall classify expenditures under this chapter as expenditures for international affairs and finance rather than for agriculture and agricultural resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef28321-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value of commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, in determining the reimbursement due the Commodity Credit Corporation for all expenses incurred under this chapter, commodities from the inventory of the Commodity Credit Corporation that were acquired under dairy price support operations shall be valued at a price not greater than the export market price for such commodities, as determined by the Secretary, as of the time such commodity is made available under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef28322-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum level of nonemergency food assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef28323-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of fiscal years 2019 through 2023, not less than $365,000,000 of the amounts made available to carry out emergency and nonemergency food assistance programs under subchapter II, nor more than 30 percent of such amounts, shall be expended for nonemergency food assistance programs under such subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef28324-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community development funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated each year to carry out part I of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.) that are made available through grants or cooperative agreements to strengthen food security in developing countries and that are consistent with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1722/e/1/C"},"text":"section 1722(e)(1)(C) of this title","children":[],"tail":" may be considered amounts expended for nonemergency food assistance programs for purposes of paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef28325-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1736f/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farmer-to-farmer program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the amount expended for a fiscal year for nonemergency food assistance programs under paragraph (1), amounts expended for that year to carry out programs under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1737"},"text":"section 1737 of this title","children":[],"tail":" may be considered amounts expended for nonemergency food assistance programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef28326-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title IV, § 412, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/tII/s212"},"text":"Pub. L. 94–161, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/855"},"text":"89 Stat. 855","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3655"},"text":"104 Stat. 3655","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s220"},"text":"Pub. L. 104–127, title II, § 220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/958"},"text":"110 Stat. 958","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tVII/s768"},"text":"Pub. L. 106–387, § 1(a) [title VII, § 768]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–45; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII"},"text":"Pub. L. 110–246, title III","children":[],"tail":", §§ 3020, 3021, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1829"},"text":"122 Stat. 1829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIII/s3012"},"text":"Pub. L. 113–79, title III, § 3012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/777"},"text":"128 Stat. 777","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII/s3114"},"text":"Pub. L. 115–334, title III, § 3114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4607"},"text":"132 Stat. 4607","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef28327-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef28328-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideef28329-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Part I of the Act is classified generally to subchapter I (§ 2151 et seq.) of chapter 32 of Title 22, Foreign Relations and Intercourse. For provisions deeming references to subchapter I to include parts IV (§ 2346 et seq.), VI (§ 2348 et seq.), and VIII (§ 2349aa et seq.) of subchapter II of chapter 32, see "},{"tag":"ref","attrib":{"href":"/us/pl/92/226/s202/b"},"text":"section 202(b) of Pub. L. 92–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2346"},"text":"section 2346 of Title 22","children":[],"tail":", and sections 2348c and 2349aa–5 of Title 22. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideef2832a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" amended subsec. (e) generally. Prior to amendment, subsec. (e) related to minimum level of nonemergency food assistance for each of fiscal years 2014 through 2018."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" amended subsec. (e) generally. Prior to amendment, subsec. (e) specified minimum amounts to be expended for nonemergency food assistance programs under subchapter III for fiscal years 2009 to 2012, provided an exception allowing the President to use less than the amount specified, and required notification to Congress if the President determined that there was an urgent need for additional emergency food assistance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3020"},"text":"Pub. L. 110–246, § 3020","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which authorized appropriations for programs under subchapters II, III, and III–A of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3021"},"text":"Pub. L. 110–246, § 3021","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387"},"text":"Pub. L. 106–387","children":[],"tail":" substituted “dairy price support operations” for “title I of the Agricultural Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"7 U.S.C. 1421","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s220/1"},"text":"Pub. L. 104–127, § 220(1)","children":[],"tail":", added subsec. (b) and struck out heading and text of former subsec. (b). Text read as follows: “Of the amounts made available in each fiscal year to carry out subchapters II and III–A of this chapter, not less than—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 40 percent shall be made available to carry out the credit sales program established under subchapter II of this chapter; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) 40 percent shall be made available to carry out the grant program established under subchapter III–A of this chapter.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s220"},"text":"Pub. L. 104–127, § 220","children":[],"tail":", redesignated subsecs. (d) and (e) as (c) and (d), respectively, and struck out heading and text of former subsec. (c). Text read as follows: “Notwithstanding any other provision of law and except as provided in subsection (b) of this section, if the President determines it to be necessary for purposes of this chapter, the President may direct that not in excess of 15 percent of the funds available in any fiscal year for carrying out any subchapter of this chapter be used to carry out any other subchapter of this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section generally, substituting present provisions for provisions authorizing President to seek agreement for international food reserve, with costs to be shared equitably among nations, and with safeguards against price disruptions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideef2832b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideef2832c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideef2832d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"Jan. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1513"},"text":"section 1513 of Pub. L. 101–624","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideef2832e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97/tVII/s722"},"text":"Pub. L. 109–97, title VII, § 722","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-10"},"text":"Nov. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2152"},"text":"119 Stat. 2152","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3001/c"},"text":"Pub. L. 110–246, title III, § 3001(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1821"},"text":"122 Stat. 1821","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/246/tIII/s3001/c"},"text":"“Hereafter, notwithstanding section 412 of the Food for Peace Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1736f"},"text":"7 U.S.C. 1736f","children":[],"tail":"), any balances available to carry out title III of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1727"},"text":"7 U.S.C. 1727","children":[],"tail":" et seq.] as of the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2005-11-10"},"text":"Nov. 10, 2005","children":[],"tail":"], and any recoveries and reimbursements that become available to carry out title III of such Act, may be used to carry out title II of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1721"},"text":"7 U.S.C. 1721","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dA/tVII/s724"},"text":"Pub. L. 108–447, div. A, title VII, § 724","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2841"},"text":"118 Stat. 2841","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dA/tVII/s724"},"text":"Pub. L. 108–199, div. A, title VII, § 724","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/34"},"text":"118 Stat. 34","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dA/tVII/s727"},"text":"Pub. L. 108–7, div. A, title VII, § 727","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/42"},"text":"117 Stat. 42","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/76/tVII/s730"},"text":"Pub. L. 107–76, title VII, § 730","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-28"},"text":"Nov. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/736"},"text":"115 Stat. 736","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ideef2832f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"ideef28330-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under subsec. (b) of this section delegated to Director of the Office of Management and Budget by section 4(e) of Ex. Ord. No. 12752, ","children":[{"tag":"date","attrib":{"date":"1991-02-25"},"text":"Feb. 25, 1991","children":[],"tail":", 56 F.R. 8256, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
