{"tag":"section","attrib":{"id":"idefea9e10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6615"},"text":null,"children":[{"tag":"num","attrib":{"value":"6615"},"text":"§ 6615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and education","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefea9e11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6615/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In furtherance of an action plan, the Secretary may use the National Institute of Food and Agriculture and other appropriate agencies of the Department of Agriculture to develop and conduct education programs that assist businesses, elected or appointed officials, and individuals in rural communities to deal with the effects of a transition from being economically disadvantaged to economic diversification. These programs may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefea9e12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6615/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community economic analysis and strategic planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6615/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods for improving and retooling enterprises now dependent on National Forest System land resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6615/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods for expanding enterprises and creating new economic opportunities by emphasizing economic opportunities in other industries or services not dependent on National Forest System land resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6615/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in the evaluation, counseling, and enhancement of vocational skills, training in basic and remedial literacy skills, assistance in job seeking skills, and training in starting or operating a business enterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefea9e16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6615/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing educational and training programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Insofar as practicable, the Secretary shall use existing Federal, State, and private education resources in carrying out these programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefea9e17-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2377"},"text":"Pub. L. 101–624, title XXIII, § 2377","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4048"},"text":"104 Stat. 4048","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/3/tIII/s345/e"},"text":"Pub. L. 106–113, div. B, § 1000(a