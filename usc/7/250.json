{"tag":"section","attrib":{"id":"idee2324d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250"},"text":null,"children":[{"tag":"num","attrib":{"value":"250"},"text":"§ 250.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warehouse receipts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee2324d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of the depositor of an agricultural product stored or handled in a warehouse licensed under this chapter, the warehouse operator shall issue a receipt to the depositor as prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2324d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actual storage required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A receipt may not be issued under this section for an agricultural product unless the agricultural product is actually stored in the warehouse at the time of the issuance of the receipt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2324d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each receipt issued for an agricultural product stored or handled in a warehouse licensed under this chapter shall contain such information, for each agricultural product covered by the receipt, as the Secretary may require by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2324d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on additional receipts or other documents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee2324d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"While a receipt issued under this chapter is outstanding and uncanceled by the warehouse operator, an additional receipt may not be issued for the same agricultural product (or any portion of the same agricultural product) represented by the outstanding receipt, except as authorized by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a document is transferred under this section, no duplicate document in any form may be transferred by any person with respect to the same agricultural product represented by the document, except as authorized by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2324d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic receipts and electronic documents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s242/h/2"},"text":"section 242(h)(2) of this title","children":[],"tail":", notwithstanding any other provision of Federal or State law:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idee2324da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may promulgate regulations that authorize the issuance, recording, and transfer of electronic receipts, and the transfer of other electronic documents, in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic receipt or electronic document systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Electronic receipts may be issued, recorded, and transferred, and electronic documents may be transferred, under this subsection with respect to an agricultural product under, a system or systems maintained in one or more locations and approved by the Secretary in accordance with regulations issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of holder","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person designated as the holder of an electronic receipt or other electronic document issued or transferred under this chapter shall, for the purpose of perfecting the security interest of the person under Federal or State law and for all other purposes, be considered to be in possession of the receipt or other electronic document.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An electronic receipt issued, or other electronic document transferred, in accordance with this chapter shall not be denied legal effect, validity, or enforceability on the ground that the information is generated, sent, received, or stored by electronic or similar means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security interests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If more than one security interest exists in the agricultural product that is the subject of an electronic receipt or other electronic document under this chapter, the priority of the security interest shall be determined by the applicable Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No electronic receipt required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person shall not be required to issue in electronic form a receipt or document with respect to an agricultural product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Option for non-federally licensed warehouse operators","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, a warehouse operator not licensed under this chapter may, at the option of the warehouse operator and in accordance with regulations established by the Secretary, issue electronic receipts and transfer other electronic documents in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to State-licensed warehouse operators","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall not apply to a warehouse operator that is licensed under State law to store agricultural commodities in a warehouse in the State if the warehouse operator elects—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee2324e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/e/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to issue electronic receipts authorized under this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee2324e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s250/e/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to issue electronic receipts authorized under State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee2324e4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 11, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tII/s201"},"text":"Pub. L. 106–472, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2065"},"text":"114 Stat. 2065","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2324e5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee2324e6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee2324e7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 250, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 8, "},{"tag":"ref","attrib":{"href":"/us/stat/39/487"},"text":"39 Stat. 487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1931-03-02/ch366/s3"},"text":"Mar. 2, 1931, ch. 366, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1463"},"text":"46 Stat. 1463","children":[],"tail":", authorized designation as bonded warehouse upon filing of bond and approval by Secretary, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 11 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s252"},"text":"section 252 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
