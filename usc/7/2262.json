{"tag":"section","attrib":{"id":"idef7a77e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2262"},"text":null,"children":[{"tag":"num","attrib":{"value":"2262"},"text":"§ 2262.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee liability insurance on motor vehicles in foreign countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized to obtain insurance to cover the liability of any employee of the Department of Agriculture for damage to or loss of property or personal injury or death caused by the act or omission of any such employee while acting within the scope of his office or employment and while operating a motor vehicle belonging to the United States in a foreign country.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef7a77e5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/106/s3"},"text":"Pub. L. 89–106, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-08-04"},"text":"Aug. 4, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/431"},"text":"79 Stat. 431","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7a77e6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7a77e7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef7a77e8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"