tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1821"},"text":"122 Stat. 1821","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/246/tIII/s3001/c"},"text":"“Section 207 of the Food for Peace Act (as added by subsection (a)) [this section] shall apply with respect to agreements entered into after ","children":[{"tag":"date","attrib":{"date":"1985-12-31"},"text":"December 31, 1985","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
