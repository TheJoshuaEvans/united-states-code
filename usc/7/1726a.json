{"tag":"section","attrib":{"id":"ideeeb56f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1726a"},"text":"§ 1726a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeeb56fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb56fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recipient countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A proposal to enter into a nonemergency food assistance agreement under this subchapter shall identify the recipient country or countries that are the subject of the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb56fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after the date of receipt by the Administrator of a proposal submitted by an eligible organization under this subchapter, the Administrator shall determine whether to accept the proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb56fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a proposal under paragraph (1) is denied, the response shall specify the reasons for denial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb56fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and comment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days prior to the issuance of a final guideline or annual policy guidance to carry out this subchapter, the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb56ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide notice of the existence of a proposed guideline or annual policy guidance, and that such guideline or annual policy guidance is available for review and comment, to eligible organizations that participate in programs under this subchapter, and to other interested persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb5700-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the proposed guideline or annual policy guidance available, on request, to the eligible organizations and other persons referred to in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb5701-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take any comments received into consideration prior to the issuance of the final guideline or annual policy guidance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb5702-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and guidance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb5703-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall promptly issue all necessary regulations and make revisions to agency guidelines with respect to changes in the operation or implementation of the program established under this subchapter. Not later than 270 days after the date of the enactment of the Agriculture Improvement Act of 2018, the Administrator shall issue all regulations and revisions to agency guidance necessary to implement the amendments made to this subchapter by such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb5704-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall develop regulations and guidance with the intent of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeeb5705-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" simplifying procedures for participation in the programs established under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5706-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing paperwork requirements under such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5707-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing reasonable and realistic accountability standards to be applied to eligible organizations participating in the programs established under this subchapter, taking into consideration the problems associated with carrying out programs in developing countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5708-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing flexibility for carrying out programs under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb5709-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely provision of commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in consultation with the Secretary, shall develop procedures that ensure expedited processing of commodity call forwards in order to provide commodities overseas in a timely manner and to the extent feasible, according to planned delivery schedules.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb570a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timely approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator is encouraged to finalize program agreements and resource requests for programs under this section before the beginning of each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb570b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program oversight, monitoring, and evaluation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb570c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Administrator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, in consultation with the Secretary, shall establish systems and carry out activities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeeb570d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine the need for assistance provided under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb570e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve, monitor, and evaluate the effectiveness and efficiency of the assistance provided under this subchapter to maximize the impact of the assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb570f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements of systems and activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The systems and activities described in paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeeb5710-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program monitors in countries that receive assistance under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5711-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" country and regional food aid impact evaluations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5712-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification and implementation of best practices for food aid programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5713-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the evaluation of monetization programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5714-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" early warning assessments and systems to help prevent famines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5715-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintenance of information technology systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb5716-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeeb5717-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraphs (B) and (C), in carrying out administrative and management activities relating to each activity carried out by the Administrator under paragraph (1), the Administrator may enter into contracts with 1 or more individuals for personal service to be performed in recipient countries or neighboring countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5718-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual who enters into a contract with the Administrator under subparagraph (A) shall not be considered to be an employee of the Federal Government for the purpose of any law (including regulations) administered by the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb5719-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraph (A) does not limit the ability of the Administrator to enter into a contract with any individual for personal service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1722/a"},"text":"section 1722(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb571a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideeeb571b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1722/h/3"},"text":"section 1722(h)(3) of this title","children":[],"tail":", in addition to other funds made available to the Administrator to carry out the monitoring of emergency food assistance, the Administrator may implement this subsection using up to 1.5 percent, but not less than $17,000,000, of the funds made available under this subchapter for each of fiscal years 2014 through 2023, except for paragraph (2)(F), for which not more than $500,000 shall be made available for each of the fiscal years 2014 through 2023."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideeeb571c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideeeb571d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to clause (ii), of the funds made available under subparagraph (A), for each of fiscal years 2009 through 2023, not more than $8,000,000 may be used by the Administrator to carry out paragraph (2)(E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideeeb571e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/f/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No funds shall be made available under subparagraph (A), in accordance with clause (i), unless not less than $8,000,000 is made available under the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.) for such purposes for such fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeeb571f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeeb5720-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In submitting project reports to the Administrator, a private voluntary organization or cooperative shall provide a copy of the report in such form as is necessary for the report to be displayed for public use on the website of the United States Agency for International Development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeeb5721-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1726a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidential information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An organization or cooperative described in paragraph (1) may omit any confidential information from the copy of the report submitted for public display under that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeeb5722-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title II, § 207, as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXI/s1104/a"},"text":"Pub. L. 99–198, title XI, § 1104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1466"},"text":"99 Stat. 1466","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s14"},"text":"Pub. L. 100–202, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-449"},"text":"101 Stat. 1329–449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3640"},"text":"104 Stat. 3640","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s207/b"},"text":"Pub. L. 104–127, title II, § 207(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/954"},"text":"110 Stat. 954","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIII/s3007"},"text":"Pub. L. 107–171, title III, § 3007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/282"},"text":"116 Stat. 282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII"},"text":"Pub. L. 110–246, title III","children":[],"tail":", §§ 3012, 3018(b), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1824"},"text":"122 Stat. 1824","children":[],"tail":", 1828; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIII/s3006/a"},"text":"Pub. L. 113–79, title III, § 3006(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/774"},"text":"128 Stat. 774","children":[],"tail":", 775; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII"},"text":"Pub. L. 115–334, title III","children":[],"tail":", §§ 3106, 3107, "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4604"},"text":"132 Stat. 4604","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeeb5723-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeeb5724-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideeeb5725-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Agriculture Improvement Act of 2018 and such Act, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4490"},"text":"132 Stat. 4490","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2018 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (f)(4)(B)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":", which is classified principally to chapter 32 (§ 2151 et seq.) of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideeeb5726-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3106"},"text":"Pub. L. 115–334, § 3106","children":[],"tail":", substituted “the Agriculture Improvement Act of 2018” for “the Agricultural Act of 2014”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3107/1"},"text":"Pub. L. 115–334, § 3107(1)","children":[],"tail":", substituted “1.5 percent, but not less than $17,000,000,” for “$17,000,000” and “2023” for “2018” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(4)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3107/2/A"},"text":"Pub. L. 115–334, § 3107(2)(A)","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(4)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3107/2/B"},"text":"Pub. L. 115–334, § 3107(2)(B)","children":[],"tail":", struck out “chapter 1 of part I of” before “the Foreign Assistance Act of 1961”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3006/a/1"},"text":"Pub. L. 113–79, § 3006(a)(1)","children":[],"tail":", inserted “and guidance” after “Regulations” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3006/a/2"},"text":"Pub. L. 113–79, § 3006(a)(2)","children":[],"tail":", inserted at end “Not later than 270 days after the date of the enactment of the Agricultural Act of 2014, the Administrator shall issue all regulations and revisions to agency guidance necessary to implement the amendments made to this subchapter by such Act.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3006/a/3"},"text":"Pub. L. 113–79, § 3006(a)(3)","children":[],"tail":", inserted “and guidance” after “develop regulations” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3006/b/1"},"text":"Pub. L. 113–79, § 3006(b)(1)","children":[],"tail":", substituted “maintenance of” for “upgraded”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3006/b/2"},"text":"Pub. L. 113–79, § 3006(b)(2)","children":[],"tail":", (3), redesignated pars. (5) and (6) as (3) and (4), respectively, and struck out former pars. (3) and (4) which related to reports to be submitted by the Administrator and the Comptroller General."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3006/b/4/A"},"text":"Pub. L. 113–79, § 3006(b)(4)(A)","children":[],"tail":", substituted “$17,000,000 of the funds made available under this subchapter for each of fiscal years 2014 through 2018, except for paragraph (2)(F), for which not more than $500,000 shall be made available for each of the fiscal years 2014 through 2018.” for “$22,000,000 of the funds made available under this subchapter for each of fiscal years 2009 through 2012, except for paragraph (2)(F), for which only $2,500,000 shall be made available during fiscal year 2009.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(4)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3006/b/4/B"},"text":"Pub. L. 113–79, § 3006(b)(4)(B)","children":[],"tail":", substituted “2018” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s3006/b/3"},"text":"Pub. L. 113–79, § 3006(b)(3)","children":[],"tail":", redesignated pars. (5) and (6) as (3) and (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3012/1"},"text":"Pub. L. 110–246, § 3012(1)","children":[],"tail":", struck out “and the conditions that must be met for the approval of such proposal” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3012/2"},"text":"Pub. L. 110–246, § 3012(2)","children":[],"tail":", struck out par. (3). Prior to amendment, text read as follows: “Handbooks developed by the Administrator to assist in carrying out the program under this subchapter shall be designed to foster the development of programs under this subchapter by eligible organizations.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3012/3"},"text":"Pub. L. 110–246, § 3012(3)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows: “Not later than 15 days after receipt from a United States field mission of a call forward for agricultural commodities for programs that meet the requirements of this subchapter, the order for the purchase or the supply, from inventory, of such commodities or products shall be transmitted to the Commodity Credit Corporation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3018/b"},"text":"Pub. L. 110–246, § 3018(b)","children":[],"tail":", struck out par. (1) designation and struck out par. (2). Prior to amendment, text read as follows: “Not later than December 1 of each year, the Administrator shall submit to the Committee on Agriculture and the Committee on International Relations of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that contains—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) a list of programs, countries, and commodities approved to date for assistance under this section; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) a statement of the total amount of funds approved to date for transportation and administrative costs under this section.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3012/4"},"text":"Pub. L. 110–246, § 3012(4)","children":[],"tail":", added subsecs. (f) and (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3007/1"},"text":"Pub. L. 107–171, § 3007(1)","children":[],"tail":", added pars. (1) and (2), redesignated former par. (2) as (3), and struck out heading and text of former par. (1). Text read as follows: “Not later than 45 days after the receipt by the Administrator of a proposal submitted—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) by an eligible organization, with the concurrence of the appropriate United States field mission, for commodities; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) by a United States field mission to make commodities available to an eligible organization;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"under this subchapter, the Administrator shall make a decision concerning such proposal.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3007/2"},"text":"Pub. L. 107–171, § 3007(2)","children":[],"tail":", substituted “guideline or annual policy guidance” for “guideline” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s3007/3"},"text":"Pub. L. 107–171, § 3007(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1)(A), (B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s207/b/1"},"text":"Pub. L. 104–127, § 207(b)(1)","children":[],"tail":", substituted “an eligible organization” for “a private voluntary organization or cooperative”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s207/b/2/A"},"text":"Pub. L. 104–127, § 207(b)(2)(A)","children":[],"tail":", substituted “eligible organizations” for “private voluntary organizations and cooperatives”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s207/b/2/B"},"text":"Pub. L. 104–127, § 207(b)(2)(B)","children":[],"tail":", substituted “eligible organizations” for “organizations, cooperatives,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section generally, substituting present provisions for provisions relating to requests by nonprofit voluntary agency or cooperative for nonemergency food assistance agreements, and uses of foreign currency proceeds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s14/1"},"text":"Pub. L. 100–202, § 14(1)","children":[],"tail":", inserted “or cooperative” after “agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s14/2"},"text":"Pub. L. 100–202, § 14(2)","children":[],"tail":", substituted “10 percent” for “5 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s14/3"},"text":"Pub. L. 100–202, § 14(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeeb5727-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeeb5728-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tai