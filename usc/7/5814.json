{"tag":"section","attrib":{"id":"idefcdef3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5814"},"text":null,"children":[{"tag":"num","attrib":{"value":"5814"},"text":"§ 5814.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this part $40,000,000 for each of fiscal years 2013 through 2023. Of amounts appropriated to carry out this part for a fiscal year, not less than $15,000,000, or not less than two thirds of any such appropriation, whichever is greater, shall be used to carry out sections 5811 and 5812 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefcdef3b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1624"},"text":"Pub. L. 101–624, title XVI, § 1624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3739"},"text":"104 Stat. 3739","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIV/s408"},"text":"Pub. L. 102–237, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1865"},"text":"105 Stat. 1865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7201"},"text":"Pub. L. 113–79, title VII, § 7201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/880"},"text":"128 Stat. 880","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7201"},"text":"Pub. L. 115–334, title VII, § 7201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4803"},"text":"132 Stat. 4803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefcdef3c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefcdef3d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefcdef3e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":", in first sentence, struck out “$40,000,000 for each fiscal year” after “appropriated” and inserted “$40,000,000 for each of fiscal years 2013 through 2018” after “part”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “and 5812” for “and 5813”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
