{"tag":"section","attrib":{"id":"idef94b652-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3124a"},"text":"§ 3124a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal-State partnership and coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef94b653-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered programs; statement of purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A unique partnership arrangement exists in food and agricultural research, extension, and teaching between the Federal Government and the governments of the several States whereby the States have accepted and have supported, through legislation and appropriations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef94b654-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" research programs under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef94b655-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1887-03-02"},"text":"March 2, 1887","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s361a"},"text":"7 U.S.C. 361a","children":[],"tail":" et seq.), commonly known as the Hatch Act of 1887;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b656-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1962-10-10"},"text":"October 10, 1962","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s582a"},"text":"16 U.S.C. 582a","children":[],"tail":" et seq.), commonly known as the McIntire-Stennis Act of 1962;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b657-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter V of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b658-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter VI of this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b659-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extension programs under subchapter VI of this chapter and the Act of ","children":[{"tag":"date","attrib":{"date":"1914-05-08"},"text":"May 8, 1914","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s341"},"text":"7 U.S.C. 341","children":[],"tail":" et seq.), commonly known as the Smith-Lever Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b65a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" teaching programs under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef94b65b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1862-07-02"},"text":"July 2, 1862","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s301"},"text":"7 U.S.C. 301","children":[],"tail":" et seq.), commonly known as the First Morrill Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b65c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1890-08-30"},"text":"August 30, 1890","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s321"},"text":"7 U.S.C. 321","children":[],"tail":" et seq.), commonly known as the Second Morrill Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b65d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1935-06-29"},"text":"June 29, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s329"},"text":"7 U.S.C. 329","children":[],"tail":"), commonly known as the Bankhead-Jones Act; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b65e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international agricultural programs under title XII of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2220a"},"text":"22 U.S.C. 2220a","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This partnership in publicly supported agricultural research, extension, and teaching involving the programs of Federal agencies and the programs of the States has played a major role in the outstanding successes achieved in meeting the varied, dispersed, and in many cases, site-specific needs of American agriculture. This partnership must be preserved and enhanced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef94b65f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment, etc., of cooperative centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to promote research and education in food and human nutrition, the Secretary may establish cooperative human nutrition centers to focus resources, facilities, and scientific expertise on particular high priority nutrition problems identified by the Department. Such centers shall be established at State cooperative institutions; and at other colleges and universities, having a demonstrable capacity to carry out human nutrition research and education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef94b660-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of State cooperative institutions; reports; research grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef94b661-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To promote research for purposes of developing agricultural policy alternatives, the Secretary is encouraged—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef94b662-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to designate at least one State cooperative institution to conduct research in an interdisciplinary fashion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b663-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to report on a regular basis with respect to the effect of emerging technological, economic, sociological, and environmental developments on the structure of agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b664-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Support for this effort should include grants to examine the role of various food production, processing, and distribution systems that may primarily benefit small- and medium-sized family farms, such as diversified farm plans, energy, water, and soil conservation technologies, direct and cooperative marketing, production and processing cooperatives, and rural community resource management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef94b665-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of State agricultural experiment stations and Agricultural Research Service facilities; pilot projects; additional research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To address more effectively the critical need for reducing farm input costs, improving soil, water, and energy conservation on farms and in rural areas, using sustainable agricultural methods, adopting alternative processing and marketing systems, and encouraging rural resources management, the Secretary is encouraged to designate at least one State agricultural experiment station and one Agricultural Research Service facility to examine these issues in an integrated and comprehensive manner, while conducting ongoing pilot projects contributing additional research through the Federal-State partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef94b666-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef94b667-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All meetings of any entity described in paragraph (3) shall be publicly announced in advance and shall be open to the public. Detailed minutes of meetings and other appropriate records of the activities of such an entity shall be kept and made available to the public on request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b668-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 and title XVIII of this Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2281"},"text":"7 U.S.C. 2281","children":[],"tail":" et seq.] shall not apply to any entity described in paragraph (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef94b669-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall apply to any committee, board, commission, panel, or task force, or similar entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef94b66a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is created for the purpose of cooperative efforts in agricultural research, extension, or teaching; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef94b66b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consists entirely of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef94b66c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full-time Federal employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef94b66d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" one or more individuals who are employed by, or are officials of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef94b66e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/e/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State cooperative institution or State cooperative agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef94b66f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3124a/e/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public college or university or other postsecondary institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef94b670-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1409A"},"text":"Pub. L. 95–113, title XIV, § 1409A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1410/a"},"text":"Pub. L. 97–98, title XIV, § 1410(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1301"},"text":"95 Stat. 1301","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXIV/s1407"},"text":"Pub. L. 99–