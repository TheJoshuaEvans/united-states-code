{"tag":"section","attrib":{"id":"ideffdb1a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213"},"text":null,"children":[{"tag":"num","attrib":{"value":"7213"},"text":"§ 7213.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts available for contract payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffdb1a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, to the maximum extent practicable, expend the following amounts to satisfy the obligations of the Secretary under all contracts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffdb1a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 1996, $5,570,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 1997, $5,385,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 1998, $5,800,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 1999, $5,603,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2000, $5,130,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2001, $4,130,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2002, $4,008,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb1a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount made available for a fiscal year under subsection (a) shall be allocated as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffdb1aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For wheat, 26.26 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For corn, 46.22 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For grain sorghum, 5.11 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For barley, 2.16 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For oats, 0.15 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For upland cotton, 11.63 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For rice, 8.47 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb1b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall adjust the amounts allocated for each contract commodity under subsection (b) for a particular fiscal year by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffdb1b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adding an amount equal to the sum of all repayments of deficiency payments required under section 114(a)(2) of the Agricultural Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1445j/a/2"},"text":"7 U.S.C. 1445j(a)(2)","children":[],"tail":") for the commodity;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adding an amount equal to the sum of all refunds of contract payments received during the preceding fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7216"},"text":"section 7216 of this title","children":[],"tail":" for the commodity; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subtracting an amount equal to the amount, if any, necessary during that fiscal year to satisfy payment requirements for the commodity under sections 103B, 105B, or 107B of the Agricultural Act of 1949 for the 1994 and 1995 crop years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb1b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional rice allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the adjustments required under subsection (c), the amount allocated under subsection (b) for rice contract payments shall be increased by $8,500,000 for each of fiscal years 1997 through 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb1b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of certain amounts from contract payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amount added pursuant to paragraphs (1) and (2) of subsection (c) to the amount available under subsection (a) for a fiscal year and paid to owners and producers under a contract shall not be treated as a contract payment for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7215"},"text":"section 7215 of this title","children":[],"tail":" or section 1308(1) "},{"tag":"ref","attrib":{"idref":"fn002329"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002329"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in text note below."}],"tail":" of this title. However, the amount of a payment covered by this subsection may not exceed $50,000 per person."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb1b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7213/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of payment limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount available under subsection (a) for a fiscal year shall be reduced by an amount equal to the total amount of contract payments for the fiscal year that owners and producers forgo as a result of operation of the payment limitation under section 1308(1) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffdb1b8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s113"},"text":"Pub. L. 104–127, title I, § 113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/900"},"text":"110 Stat. 900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideffdb1b9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideffdb1ba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideffdb1bb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 103B, 105B, and 107B of the Agricultural Act of 1949, referred to in subsec. (c)(3), were classified to sections 1444–2, 1444f, and 1445b–3a, respectively, of this title prior to repeal by section 7301(b)(2)(A)–(D) of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308/1"},"text":"Section 1308(1) of this title","children":[],"tail":", referred to in subsecs. (e), (f), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1603/a"},"text":"Pub. L. 107–171, title I, § 1603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/213"},"text":"116 Stat. 213","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
