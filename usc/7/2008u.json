{"tag":"section","attrib":{"id":"idef27010b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008u"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008u"},"text":"§ 2008u.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef27010c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008u/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to address the continued unmet health needs in the Delta region through cooperation among health care professionals, institutions of higher education, research institutions, and other individuals and entities in the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef27010d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008u/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “eligible entity” means a consortium of regional institutions of higher education, academic health and research institutes, and economic development entities located in the Delta region that have experience in addressing the health care issues in the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef27010e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008u/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out the purpose described in subsection (a), the Secretary may award a grant to an eligible entity for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef27010f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008u/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the development of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef270110-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008u/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270111-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008u/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health education programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef270112-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008u/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care job training programs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef270113-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008u/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and expansion of public health-related facilities in the Delta region to address longstanding and unmet health needs of the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef270114-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008u/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of the receipt of the grant, the eligible entity shall use the grant to fund projects and activities described in subsection (c), based on input solicited from local governments, public health care providers, and other entities in the Delta region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef270115-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008u/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section, $3,000,000 for each of fiscal years 2008 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef270116-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s379G"},"text":"Pub. L. 87–128, title III, § 379G","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6024"},"text":"Pub. L. 110–234, title VI, § 6024","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1176"},"text":"122 Stat. 1176","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6024, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "}