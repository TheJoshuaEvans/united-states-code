{"tag":"section","attrib":{"id":"idee232509-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s254"},"text":null,"children":[{"tag":"num","attrib":{"value":"254"},"text":"§ 254.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for noncompliance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If a person fails to comply with any requirement of this chapter (including regulations promulgated under this chapter), the Secretary may assess, on the record after an opportunity for a hearing, a civil penalty—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee23250a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s254/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of not more than $25,000 per violation, if an agricultural product is not involved in the violation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee23250b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s254/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of not more than 100 percent of the value of the agricultural product, if an agricultural product is involved in the violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee23250c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 15, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tII/s201"},"text":"Pub. L. 106–472, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2068"},"text":"114 Stat. 2068","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee23250d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee23250e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee23250f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 254, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 13, "},{"tag":"ref","attrib":{"href":"/us/stat/39/488"},"text":"39 Stat. 488","children":[],"tail":", prohibited discrimination by warehousemen, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s247"},"text":"section 247 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 15 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s256"},"text":"section 256 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
