{"tag":"section","attrib":{"id":"idf00e53b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7488"},"text":null,"children":[{"tag":"num","attrib":{"value":"7488"},"text":"§ 7488.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations and power to subpoena","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00e53b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7488/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make such investigations as the Secretary considers necessary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e53b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7488/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the effective administration of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7488/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to determine whether any person subject to this subchapter has engaged, or is about to engage, in an act that constitutes or will constitute a violation of this subchapter or of an order or regulation issued under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e53b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7488/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oaths, affirmations, and subpoenas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of an investigation under subsection (a), the Secretary may administer oaths and affirmations, subpoena witnesses, compel the attendance of witnesses, take evidence, and require the production of any records that are relevant to the inquiry. The attendance of witnesses and the production of records may be required from any place in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e53ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7488/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aid of courts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e53bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7488/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of contumacy by, or refusal to obey a subpoena issued to, any person, the Secretary may request the aid of any court of the United States within the jurisdiction of which the investigation or proceeding is carried on, or where the person resides or carries on business, in requiring the attendance and testimony of the person and the production of records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7488/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement order of the court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court may issue an enforcement order requiring the person to appear before the Secretary to produce records or to give testimony concerning the matter under investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7488/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contempt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A failure to obey an enforcement order of the court under paragraph (2) may be punished by the court as a contempt of the court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7488/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Process in a case under this subsection may be served in the judicial district in which the person resides or carries on business or wherever the person may be found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00e53bf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s579"},"text":"Pub. L. 104–127, title V, § 579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1083"},"text":"110 Stat. 1083","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
