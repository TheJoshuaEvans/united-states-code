{"tag":"section","attrib":{"id":"idee5ea722-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f"},"text":null,"children":[{"tag":"num","attrib":{"value":"936f"},"text":"§ 936f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantially underserved trust areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee5ea723-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee5ea724-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible program” means a program administered by the Rural Utilities Service and authorized in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee5ea725-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee5ea726-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1), (2), (14), (22), or (24) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926/a"},"text":"section 1926(a) of this title","children":[],"tail":" or section 1926a, 1926c, 1926d, or 1926e of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5ea727-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantially underserved trust area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “substantially underserved trust area” means a community in “trust land” (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s3765"},"text":"section 3765 of title 38","children":[],"tail":") with respect to which the Secretary determines has a high need for the benefits of an eligible program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee5ea728-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with local governments and Federal agencies, may implement an initiative to identify and improve the availability of eligible programs in communities in substantially underserved trust areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee5ea729-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (b), the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee5ea72a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make available from loan or loan guarantee programs administered by the Rural Utilities Service to qualified utilities or applicants financing with an interest rate as low as 2 percent, and with extended repayment terms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5ea72b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may waive nonduplication restrictions, matching fund requirements, or credit support requirements from any loan or grant program administered by the Rural Utilities Service to facilitate the construction, acquisition, or improvement of infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5ea72c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may give the highest funding priority to designated projects in substantially underserved trust areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5ea72d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall only make loans or loan guarantees that are found to be financially feasible and that provide eligible program benefits to substantially underserved trust areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee5ea72e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this section and annually thereafter, the Secretary shall submit to Congress a report that describes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee5ea72f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of the initiative implemented under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee611830-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s936f/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for any regulatory or legislative changes that would be appropriate to improve services to substantially underserved trust areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee611831-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title III, § 306F, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6105"},"text":"Pub. L. 110–234, title VI, § 6105","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1196"},"text":"122 Stat. 1196","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6105, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1957.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee611832-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee611833-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee611834-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee611835-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee611836-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee611837-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
