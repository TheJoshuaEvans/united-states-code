{"tag":"section","attrib":{"id":"idee14ccea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138g"},"text":null,"children":[{"tag":"num","attrib":{"value":"138g"},"text":"§ 138g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The results of the evaluations of laboratories conducted by the Secretary under this chapter shall be made available to the Secretary of Health and Human Services and to the public on request.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee14cceb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIII/s1328"},"text":"Pub. L. 101–624, title XIII, § 1328","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3565"},"text":"104 Stat. 3565","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
