{"tag":"section","attrib":{"id":"idefe5bca0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515"},"text":null,"children":[{"tag":"num","attrib":{"value":"6515"},"text":"§ 6515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements of certifying agents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe5bca1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ability to implement requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be accredited as a certifying agent under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6514"},"text":"section 6514 of this title","children":[],"tail":", a governing State official or a person shall be able to fully implement the applicable organic certification program established under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bca2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspectors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any certifying agent shall employ a sufficient number of inspectors to implement the applicable organic certification program established under this chapter, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bca3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any certifying agent shall enter into an agreement with the Secretary under which such agent shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bca4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to carry out the provisions of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bca5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to such other terms and conditions as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bca6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private certifying agent agreement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any certifying agent that is a private person shall, in addition to the agreement required in subsection (c)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bca7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to hold the Secretary harmless for any failure on the part of the certifying agent to carry out the provisions of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bca8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish reasonable security, in an amount determined by the Secretary, for the purpose of protecting the rights of participants in the applicable organic certification program established under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bca9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any certifying agent shall fully comply with the terms and conditions of the applicable organic certification program implemented under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bcaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6506/a/9"},"text":"section 6506(a)(9) of this title","children":[],"tail":", any certifying agent shall maintain strict confidentiality with respect to its clients under the applicable organic certification program and may not disclose to third parties (with the exception of the Secretary or the applicable governing State official) any business related information concerning such client obtained while implementing this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bcab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any certifying agent shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bcac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out any inspections of any operation in which such certifying agent, or employee of such certifying agent has, or has had, a commercial interest, including the provision of consultancy services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bcad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept payment, gifts, or favors of any kind from the business inspected other than prescribed fees; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bcae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice concerning organic practices or techniques for a fee, other than fees established under such program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bcaf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A certifying agent that is a private person shall nominate the individual who controls the day-to-day operation of the agent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bcb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss of accreditation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bcb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary or the governing State official (if applicable) determines that a certifying agent or an entity acting as an agent of the certifying agent is not properly adhering to the provisions of this chapter, the Secretary or such governing State official may suspend such certifying agent’s accreditation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bcb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight of certifying offices and foreign operations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bcb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that an office of a certifying agent or entity described in paragraph (1) is not complying with the provisions of this chapter, the Secretary may suspend the operations of the certifying agent or the noncompliant office, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe5bcb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/i/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an office operating in a foreign country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bcb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/i/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an office operating in the United States, including an office acting on behalf of a foreign-domiciled entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bcb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process for resuming operations following suspension","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for a process that is otherwise consistent with this section that authorizes a suspended office to resume operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bcb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on certified operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the accreditation of a certifying agent is suspended under paragraph (1), the Secretary or the governing State official (if applicable) shall promptly determine whether farming or handling operations certified by such certifying agent may retain their organic certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bcb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6515/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date on which a new certifying office performing certification activities opens, an accredited certifying agent shall notify the Secretary of the opening.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe5bcb9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2116"},"text":"Pub. L. 101–624, title XXI, § 2116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3944"},"text":"104 Stat. 3944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1001/5"},"text":"Pub. L. 102–237, title X, § 1001(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1893"},"text":"105 Stat. 1893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tX/s10005/b/1"},"text":"Pub. L. 113–79, title X, § 10005(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/944"},"text":"128 Stat. 944","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10104/d"},"text":"Pub. L. 115–334, title X, § 10104(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4900"},"text":"132 Stat. 4900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe5bcba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe5bcbb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe5bcbc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (i)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10104/d/1/A"},"text":"Pub. L. 115–334, § 10104(d)(1)(A)","children":[],"tail":", inserted “or an entity acting as an agent of the certifying agent” after “a certifying agent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10104/d/1/B"},"text":"Pub. L. 115–334, § 10104(d)(1)(B)","children":[],"tail":", (C), added par. (2) and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10104/d/2"},"text":"Pub. L. 115–334, § 10104(d)(2)","children":[],"tail":", added subsec. (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsecs. (c) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" redesignated subsecs. (d) to (j) as (c) to (i), respectively, substituted “subsection (c)” for “subsection (d)” in introductory provisions of subsec. (d), and struck out former subsec. (c) which related to maintenance of, access to, and transference of records of certifying agents."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (j)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “such certifying” for “certifying such”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
