{"tag":"section","attrib":{"id":"ideedd258d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e"},"text":null,"children":[{"tag":"num","attrib":{"value":"1635e"},"text":"§ 1635e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory reporting for live cattle","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedd258e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program of live cattle price information reporting that will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedd258f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide timely, accurate, and reliable market information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2590-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate more informed marketing decisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2591-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote competition in the cattle slaughtering industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedd2592-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General reporting provisions applicable to packers and the Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedd2593-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Whenever the prices or quantities of cattle are required to be reported or published under this section, the prices or quantities shall be categorized so as to clearly delineate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedd2594-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prices or quantities, as applicable, of the cattle purchased in the domestic market; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd2595-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prices or quantities, as applicable, of imported cattle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2596-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Packer-owned cattle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information required under this section for packer-owned cattle shall include quantity and carcass characteristics, but not price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedd2597-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Daily reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedd2598-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporate officers or officially designated representatives of each packer processing plant shall report to the Secretary at least twice each reporting day (including once not later than 10:00 a.m. Central Time and once not later than 2:00 p.m. Central Time) the following information for each cattle type:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedd2599-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The prices for cattle (per hundredweight) established on that day, categorized by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedd259a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" type of purchase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedd259b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of cattle purchased on a live weight basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedd259c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of cattle purchased on a dressed weight basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedd259d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a range of the estimated live weights of the cattle purchased;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedd259e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the percentage of the cattle purchased that were of a quality grade of choice or better; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedd259f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any premiums or discounts associated with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideedd25a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/A/vi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" weight, grade, or yield; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideedd25a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/A/vi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any type of purchase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The quantity of cattle delivered to the packer (quoted in numbers of head) on that day, categorized by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedd25a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" type of purchase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedd25a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of cattle delivered on a live weight basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedd25a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of cattle delivered on a dressed weight basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The quantity of cattle committed to the packer (quoted in numbers of head) as of that day, categorized by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedd25a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" type of purchase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedd25a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of cattle committed on a live weight basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedd25a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of cattle committed on a dressed weight basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms of trade regarding the cattle, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd25ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make the information available to the public not less frequently than three times each reporting day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedd25ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Weekly reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedd25ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporate officers or officially designated representatives of each packer processing plant shall report to the Secretary, on the first reporting day of each week, not later than 9:00 a.m. Central Time, the following information applicable to the prior slaughter week:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedd25ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The quantity of cattle purchased through a forward contract that were slaughtered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The quantity of cattle delivered under a formula marketing arrangement that were slaughtered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The quantity and carcass characteristics of packer-owned cattle that were slaughtered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The quantity, basis level, and delivery month for all cattle purchased through forward contracts that were agreed to by the parties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The range and average of intended premiums and discounts that are expected to be in effect for the current slaughter week.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd25b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula purchases","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporate officers or officially designated representatives of each packer processing plant shall report to the Secretary, on the first reporting day of each week, not later than 9:00 a.m. Central Time, the following information for cattle purchased through a formula marketing arrangement and slaughtered during the prior slaughter week:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedd25b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The quantity (quoted in both numbers of head and hundredweights) of cattle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The weighted average price paid for a carcass, including applicable premiums and discounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The range of premiums and discounts paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The weighted average of premiums and discounts paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The range of prices paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate weighted average price paid for a carcass.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd25ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms of trade regarding the cattle, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd25bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available to the public the information obtained under paragraphs (1) and (2) on the first reporting day of the current slaughter week, not later than 10:00 a.m. Central Time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedd25bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional reporting of cattle types","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedd25bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine whether adequate data can be obtained on a regional basis for fed Holsteins and other fed dairy steers and heifers, cows, and bulls based on the number of packers required to report under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd25be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"1999-10-22"},"text":"October 22, 1999","children":[],"tail":", the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report on the determination of the Secretary under paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedd25bf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 222, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX/s911/2"},"text":"Pub. L. 106–78, title IX, § 911(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1191"},"text":"113 Stat. 1191","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
