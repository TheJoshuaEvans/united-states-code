4/s1171"},"text":"section 1171 of Pub. L. 101–624","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee769c74-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1987 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tI/s1302"},"text":"Pub. L. 100–203, title I, § 1302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-14"},"text":"101 Stat. 1330–14","children":[],"tail":", provided that the amendment made by that section is effective beginning with the 1989 crops."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee769c75-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203/tI/s1301/a"},"text":"Pub. L. 100–203, title I, § 1301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1330-12"},"text":"101 Stat. 1330–12","children":[],"tail":", provided that this section is effective beginning with the 1989 crops."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee769c76-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section, as in effect on ","children":[{"tag":"date","attrib":{"date":"2007-09-30"},"text":"Sept. 30, 2007","children":[],"tail":", to continue to apply with respect to the 2007 and 2008 crops of any covered commodity or peanuts, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1603/h"},"text":"section 1603(h) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308"},"text":"section 1308 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee769c77-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rulemaking Related to Significant Contribution for Active Personal Management","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1604"},"text":"Pub. L. 113–79, title I, § 1604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/706"},"text":"128 Stat. 706","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/79/tI/s1604"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":"], the Secretary shall promulgate, with an opportunity for notice and comment, regulations—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to define the term ‘significant contribution of active personal management’ for purposes of section 1001A of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308–1"},"text":"7 U.S.C. 1308–1","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines it is appropriate, to establish limits for varying types of farming operations on the number of individuals who may be considered to be actively engaged in farming with respect to the farming operation when a significant contribution of active personal management is the basis used to meet the requirement of being actively engaged in farming under section 1001A of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308–1"},"text":"7 U.S.C. 1308–1","children":[],"tail":") by an individual or entity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In promulgating the regulations required under subsection (a), the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size, nature, and management requirements of each type of farming operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the changing nature of active personal management due to advancements of farming operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which the regulations promulgated pursuant to subsection (a) will adversely impact the long-term viability of the farming operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Family Farms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not apply the regulations promulgated pursuant to subsection (a) to individuals or entities comprised solely of family members (as that term is defined in section 1001(a)(2) of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308/a/2"},"text":"7 U.S.C. 1308(a)(2)","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations promulgated pursuant to subsection (a) shall include a plan for monitoring the status of compliance reviews for whether a person or entity is in compliance with the regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Paperwork Reduction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order to conserve Federal resources and prevent unnecessary paperwork burdens, the Secretary shall ensure that any additional paperwork required as a result of the regulations promulgated pursuant to subsection (a) be limited to those persons who are subject to such regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relation to Other Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to authorize the Secretary to alter, directly or indirectly, existing regulations for other requirements in section 1001A of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308–1"},"text":"7 U.S.C. 1308–1","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements of any regulation promulgated pursuant to this section shall apply beginning with the 2015 crop year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
