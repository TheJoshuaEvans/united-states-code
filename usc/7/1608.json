{"tag":"section","attrib":{"id":"ideed3890f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1608"},"text":null,"children":[{"tag":"num","attrib":{"value":"1608"},"text":"§ 1608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter, or the application thereof to any person or circumstance, is held invalid, the remainder of the chapter, and the application of such provisions to other persons or circumstances, shall not be affected thereby.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideed38910-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-09/ch615"},"text":"Aug. 9, 1939, ch. 615","children":[],"tail":", title IV, § 418, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1290"},"text":"53 Stat. 1290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideed38911-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideed38912-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideed38913-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1610"},"text":"section 1610 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
