{"tag":"section","attrib":{"id":"idef0a777c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1928"},"text":null,"children":[{"tag":"num","attrib":{"value":"1928"},"text":"§ 1928.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Full faith and credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef0a777d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1928/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A contract of insurance or guarantee executed by the Secretary under this chapter shall be an obligation supported by the full faith and credit of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0a777e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1928/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contestability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contract of insurance or guarantee executed by the Secretary under this chapter shall be incontestable except for fraud or misrepresentation that the lender or any holder—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0a777f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1928/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has actual knowledge of at the time the contract or guarantee is executed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0a7780-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1928/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participates in or condones.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef0a7781-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s308"},"text":"Pub. L. 87–128, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/308"},"text":"75 Stat. 308","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/798"},"text":"Pub. L. 87–798","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-11"},"text":"Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/908"},"text":"76 Stat. 908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/240/s2/a"},"text":"Pub. L. 89–240, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1965-10-07"},"text":"Oct. 7, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/932"},"text":"79 Stat. 932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/488/s6"},"text":"Pub. L. 90–488, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-15"},"text":"Aug. 15, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/770"},"text":"82 Stat. 770","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/133"},"text":"Pub. L. 92–133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-10-05"},"text":"Oct. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/364"},"text":"85 Stat. 364","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2388/a"},"text":"Pub. L. 101–624, title XXIII, § 2388(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4052"},"text":"104 Stat. 4052","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVI/s605"},"text":"Pub. L. 104–127, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1086"},"text":"110 Stat. 1086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef0a7782-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef0a7783-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef0a7784-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":", known as the Consolidated Farm and Rural Development Act, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef0a7785-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Loans under this subchapter may be insured by the Secretary whenever funds are advanced or a loan is purchased by a lender other than the United States. In connection with insurance of loans, the Secretary—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) is authorized to make agreements with respect to the servicing of loans insured hereunder and to purchase such loans on such terms and conditions as he may prescribe; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) may retain out of payments by the borrower a charge at a rate specified in the insurance agreement applicable to the loan.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any contract of insurance executed by the Secretary under this subchapter shall be an obligation supported by the full faith and credit of the United States and incontestable except for fraud or misrepresentation of which the holder has actual knowledge.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" redesignated pars. (a) and (b) as pars. (1) and (2), respectively, and in par. (1), substituted “prescribe;” for “prescribe,;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/133"},"text":"Pub. L. 92–133","children":[],"tail":" eliminated "},{"tag":"date","attrib":{"date":"1971-10-01"},"text":"October 1, 1971","children":[],"tail":", as time limitation for insurance of loans."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/488"},"text":"Pub. L. 90–488","children":[],"tail":" authorized insurance of loans until "},{"tag":"date","attrib":{"date":"1971-10-01"},"text":"Oct. 1, 1971","children":[],"tail":", without the $450,000,000 limitation on aggregate amount in any one year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/240"},"text":"Pub. L. 89–240","children":[],"tail":" substituted “$450,000,000” for “$200,000,000”, “may retain” for “shall retain”, and “specified in the insurance agreement applicable to the loan” for “determined by the Secretary from time to time equivalent to not less than one-half of 1 per centum per annum on the principal unpaid balance of the loan”, and struck out “except that no agreement shall provide for purchase by the Secretary at a date sooner than three years from the date of the note” after “he may prescribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/798"},"text":"Pub. L. 87–798","children":[],"tail":" increased aggregate amount of loans that may be insured in any one year from $150,000,000 to $200,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
