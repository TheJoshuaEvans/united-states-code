{"tag":"section","attrib":{"id":"idee23252b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s282"},"text":null,"children":[{"tag":"num","attrib":{"value":"282"},"text":"§ 282.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Punishment for unlawful importation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person who violates any provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s281"},"text":"section 281 of this title","children":[],"tail":" or any regulation issued under it is guilty of an offense against the United States and shall, upon conviction, be fined not more than $1,000, or imprisoned for not more than one year, or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee23252c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-08-31/ch301/s2"},"text":"Aug. 31, 1922, ch. 301, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/834"},"text":"42 Stat. 834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/319/s2"},"text":"Pub. L. 94–319, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-25"},"text":"June 25, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/709"},"text":"90 Stat. 709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee23252d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee23252e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee23252f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/319"},"text":"Pub. L. 94–319","children":[],"tail":" inserted reference to regulations, substituted characterization of violation as offense against the United States for characterization as a misdemeanor, increased maximum fine to $1,000 from $500 and struck out provision relating to discretion of the court."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
