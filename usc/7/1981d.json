{"tag":"section","attrib":{"id":"idef165e9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1981d"},"text":"§ 1981d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of loan service programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef165ea0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide notice by certified mail to each borrower who is at least 90 days past due on the payment of principal or interest on a loan made or insured under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef165ea1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notice required under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef165ea2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a summary of all primary loan service programs, preservation loan service programs, debt settlement programs, and appeal procedures, including the eligibility criteria, and terms and conditions of such programs and procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef165ea3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a summary of the manner in which the borrower may apply, and be considered, for all such programs, except that the Secretary shall not require the borrower to select among such programs or waive any right in order to be considered for any program carried out by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef165ea4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the borrower regarding all filing requirements and any deadlines that must be met for requesting loan servicing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef165ea5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide any relevant forms, including applicable response forms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef165ea6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the borrower that a copy of regulations is available on request; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef165ea7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designed to be readable and understandable by the borrower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef165ea8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contained in regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All notices required by this section shall be contained in the regulations implementing this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef165ea9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The notice described in subsection (b) shall be provided—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef165eaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the time an application is made for participation in a loan service program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef165eab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on written request of the borrower; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef165eac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before the earliest of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef165ead-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiating any liquidation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef165eae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requesting the conveyance of security property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef165eaf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerating the loan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef165eb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repossessing property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef165eb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreclosing on property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef165eb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taking any other collection action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef165eb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1981d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of borrowers for loan service programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consider a farmer program borrower for all loan service programs if, within 60 days after receipt of the notice required in this section or, in extraordinary circumstances as determined by the applicable State director, after the 60-day period, the borrower requests such consideration in writing. In considering a borrower for loan service programs, the Secretary shall place the highest priority on the preservation of the borrower’s farming operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef165eb4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s331D"},"text":"Pub. L. 87–128, title III, § 331D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVI/s605"},"text":"Pub. L. 100–233, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1666"},"text":"101 Stat. 1666","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1807"},"text":"Pub. L. 101–624, title XVIII, § 1807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3819"},"text":"104 Stat. 3819","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/554/s10"},"text":"Pub. L. 102–554, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4151"},"text":"106 Stat. 4151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVI/s633"},"text":"Pub. L. 104–127, title VI, § 633","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1092"},"text":"110 Stat. 1092","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5401/b/1"},"text":"Pub. L. 115–334, title V, § 5401(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4674"},"text":"132 Stat. 4674","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef165eb5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef165eb6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef165eb7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (c), was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":", known as the Consolidated Farm and Rural Development Act, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef165eb8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" inserted “or, in extraordinary circumstances as determined by the applicable State director, after the 60-day period” after “within 60 days after receipt of the notice required in this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" substituted “90 days past due on” for “180 days delinquent in”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/554"},"text":"Pub. L. 102–554","children":[],"tail":", which directed the insertion of “or, in extraordinary circumstances as determined by the applicable State director, after the 60-day period” after “not later than 60 days after receipt of the notice required in this section”, could not be executed because the phrase “not later than 60 days after receipt of the notice required in this section” did not appear in text. Corrected amendment was made by "},{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/102/554"},"text":"Pub. L. 102–554","children":[],"tail":". See 2018 Amendment note above and Effective Date of 2018 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1807/1"},"text":"Pub. L. 101–624, § 1807(1)","children":[],"tail":", inserted “debt settlement programs,” after “preservation loan service programs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1807/2"},"text":"Pub. L. 101–624, § 1807(2)","children":[],"tail":", substituted “60 days” for “45 days”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef165eb9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef165eba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5401/b/2"},"text":"Pub. L. 115–334, title V, § 5401(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4674"},"text":"132 Stat. 4674","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tV/s5401/b/2"},"text":"“The amendment made by this subsection [amending this section] shall take effect as if included in the enactment of section 10 of the Agricultural Credit Improvement Act of 1992 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/554"},"text":"Public Law 102–554","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef165ebb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/s663/b"},"text":"section 663(b) of Pub. L. 104–127","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1922"},"text":"section 1922 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef165ebc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1807/1"},"text":"section 1807(1) of Pub. L. 101–624","children":[],"tail":" effective 120 days after "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1861/b"},"text":"section 1861(b) of Pub. L. 101–624","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2001"},"text":"section 2001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
