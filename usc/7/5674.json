{"tag":"section","attrib":{"id":"idefcb7e0a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5674"},"text":null,"children":[{"tag":"num","attrib":{"value":"5674"},"text":"§ 5674.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trade consultations concerning imports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcb7e0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5674/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation between agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require consultation between the Administrator of the Service and the heads of other appropriate agencies and offices of the Department of Agriculture, including the Administrator of the Animal and Plant Health Inspection Service, prior to relaxing or removing any restriction on the importation of any agricultural commodity into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5674/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Trade Representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the United States Trade Representative prior to relaxing or removing any restriction on the importation of any agricultural commodity or a product thereof into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5674/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring compliance with sanitary and phytosanitary measures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall monitor the compliance of World Trade Organization member countries with the sanitary and phytosanitary measures of the Agreement on Agriculture of the Uruguay Round of Multilateral Trade Negotiations of the General Agreement on Tariffs and Trade. If the Secretary has reason to believe that any country may have failed to meet the commitment on sanitary and phytosanitary measures under the Agreement in a manner that adversely impacts the exports of a United States agricultural commodity, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefcb7e0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5674/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such information to the United States Trade Representative of the circumstances surrounding the matter arising under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefcb7e0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5674/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to any such circumstances that the Secretary considers to have a continuing adverse effect on United States agricultural exports, report to the Committee on Agriculture, and the Committee on Ways and Means, of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry, and the Committee on Finance, of the Senate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefcb7e10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5674/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that a country may have failed to meet the sanitary and phytosanitary commitments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefcb7e11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5674/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any notice given by the Secretary to the United States Trade Representative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcb7e12-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIV/s414"},"text":"Pub. L. 95–501, title IV, § 414","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3685"},"text":"104 Stat. 3685","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s242/b"},"text":"Pub. L. 104–127, title II, § 242(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/965"},"text":"110 Stat. 965","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefcb7e13-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefcb7e14-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefcb7e15-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
