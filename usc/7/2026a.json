{"tag":"section","attrib":{"id":"idef603813-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2026a"},"text":"§ 2026a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Healthy fluid milk incentives projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef603814-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of fluid milk","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section the term “fluid milk” means all varieties of pasteurized cow’s milk that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef603815-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is without flavoring or sweeteners,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef603816-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the most recent dietary recommendations,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef603817-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is packaged in liquid form, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef603818-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains vitamins A and D at levels consistent with the Food and Drug Administration, State, and local standards for fluid milk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef603819-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall carry out, under such terms and conditions as the Secretary considers to be appropriate, healthy fluid milk incentive projects to develop and test methods to increase the purchase and consumption of fluid milk by members of households that receive supplemental nutrition assistance program benefits by providing an incentive for the purchase of fluid milk at the point of purchase to members of households purchasing food with supplemental nutrition assistance program benefits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef60381a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants or cooperative agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef60381b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, the Secretary, on a competitive basis, shall enter into cooperative agreements with, or provide grants to, governmental entities or nonprofit organizations for projects that meet the purpose and selection criteria specified in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef60381c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to enter into a cooperative agreement or receive a grant under this subsection, a government entity or nonprofit organization shall submit to the Secretary an application containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef60381d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Projects proposed in applications shall be evaluated against publicly disseminated criteria that shall incorporate a scientifically based strategy that is designed to improve diet quality and nutritional outcomes through the increased purchase of fluid milk by members of households that participate in the supplemental nutrition assistance program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef60381e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available to carry out this section shall not be used for any project that limits the use of benefits provided under the Food and Nutrition Act of 2008 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"7 U.S.C. 2011","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef60381f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef603820-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef603821-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Independent evaluation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef603822-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for an independent evaluation of projects selected under this section that measures, to the maximum extent practicable, the impact on health and nutrition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef603823-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The independent evaluation under this subparagraph shall use rigorous methodologies, particularly random assignment or other methods that are capable of producing scientifically valid information regarding which activities are effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef603824-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use funds not to exceed 7 percent of the funding provided to carry out this section to pay costs associated with evaluating the outcomes of the healthy fluid milk incentive projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef603825-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than December 31 of 2020, and biennially thereafter, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that includes a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef603826-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of each healthy fluid milk incentives project, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef603827-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the results of any completed evaluation that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef603828-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include, to the maximum extent practicable, the impact of the healthy fluid milk incentive projects on health and nutrition outcomes among households participating in such projects, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef603829-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have not been submitted in a previous report under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef60382a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public dissemination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the reporting requirements under paragraph (2), evaluation results shall be shared publicly to promote wide use of successful strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef60382b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef60382c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $20,000,000 to carry out and evaluate the outcomes of projects under this section, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef60382d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2026a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations in advance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Only funds appropriated under paragraph (1) in advance specifically to carry out this section shall be available to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef60382e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIV/s4208"},"text":"Pub. L. 115–334, title IV, § 4208","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4667"},"text":"132 Stat. 4667","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef60382f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef603830-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef603831-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food and Nutrition Act of 2008, referred to in subsec. (c)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/525"},"text":"Pub. L. 88–525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-08-31"},"text":"Aug. 31, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/703"},"text":"78 Stat. 703","children":[],"tail":", which is classified generally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2011"},"text":"section 2011 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef603832-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agriculture Improvement Act of 2018, and not as part of the Food and Nutrition Act of 2008 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
