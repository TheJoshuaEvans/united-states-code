{"tag":"section","attrib":{"id":"idf010c433-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507"},"text":null,"children":[{"tag":"num","attrib":{"value":"7507"},"text":"§ 7507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local supplementation of commodities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf010c434-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures under which State and local agencies, charitable institutions, or any other persons may supplement the commodities distributed under the program authorized by this chapter for use by emergency feeding organizations with nutritious and wholesome commodities that such entities or persons donate to State agencies and emergency feeding organizations for distribution, in all or part of the State, in addition to the commodities otherwise made available under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c435-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds and facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"States and emergency feeding organizations may use the funds appropriated under this chapter and equipment, structures, vehicles, and all other facilities involved in the storage, handling, or distribution of commodities made available under this chapter, and the personnel, both paid or volunteer, involved in such storage, handling, or distribution, to store, handle or distribute commodities donated for the use of emergency feeding organizations under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c436-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteer workers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"State and emergency feeding organizations shall continue, to the maximum extent practicable, to use volunteer workers and commodities and other foodstuffs donated by charitable and other organizations in the operation of the program authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c437-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Projects to harvest, process, package, or transport donated commodities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf010c438-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “project” means the harvesting, processing, packaging, or transportation of unharvested, unprocessed, or unpackaged commodities donated by agricultural producers, processors, or distributors for use by emergency feeding organizations under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c439-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal funding for projects","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf010c43a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraphs (B) and (C) and paragraph (3), using funds made available under paragraph (5), the Secretary may provide funding to States to pay for the costs of carrying out a project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf010c43b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal share of the cost of a project under subparagraph (A) shall not exceed 50 percent of the total cost of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf010c43c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf010c43d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each fiscal year, the Secretary shall allocate the funds made available under subparagraph (A), based on a formula determined by the Secretary, to States that have submitted a State plan describing a plan of operation for a project under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7503/b/5"},"text":"section 7503(b)(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf010c43e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that a State will not expend all of the funds allocated to the State for a fiscal year under clause (i), the Secretary shall reallocate the unexpended funds to other States that have submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7503/b/5"},"text":"section 7503(b)(5) of this title","children":[],"tail":" a State plan describing a plan of operation for a project during that fiscal year or the subsequent fiscal year, as the Secretary determines appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf010c43f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State to which funds are allocated for a fiscal year under this subparagraph shall, on a regular basis, submit to the Secretary financial reports describing the use of the funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c440-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may only use Federal funds received under paragraph (2) for a project the purposes of which are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf010c441-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce food waste at the agricultural production, processing, or distribution level through the donation of food;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf010c442-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide food to individuals in need; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf010c443-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to build relationships between agricultural producers, processors, and distributors and emergency feeding organizations through the donation of food.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c444-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may encourage a State agency that carries out a project using Federal funds received under paragraph (2) to enter into cooperative agreements with State agencies of other States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7505/d"},"text":"section 7505(d) of this title","children":[],"tail":" to maximize the use of commodities donated under the project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c445-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of funds not otherwise appropriated, the Secretary of the Treasury shall transfer to the Secretary to carry out this subsection $4,000,000 for each of fiscal years 2019 through 2031, to remain available until the end of the subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c446-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food waste","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue guidance outlining best practices to minimize the food waste of the commodities donated under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c447-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food donation standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf010c448-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf010c449-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apparently wholesome food","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “apparently wholesome food” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1791/b"},"text":"section 1791(b) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf010c44a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"section 1002 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf010c44b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified direct donor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified direct donor” means a retail food store, wholesaler, agricultural producer, restaurant, caterer, school food authority, or institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c44c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf010c44d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary shall issue guidance to promote awareness of donations of apparently wholesome food protected under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1791/c"},"text":"section 1791(c) of title 42","children":[],"tail":" by qualified direct donors in compliance with applicable State and local health, food safety, and food handling laws (including regulations)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf010c44e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7507/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall encourage State agencies and emergency feeding organizations to share the guidance issued under subparagraph (A) with qualified direct donors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf010c44f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/8/tII/s203D"},"text":"Pub. L. 98–8, title II, § 203D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/435/tI/s102"},"text":"Pub. L. 100–435, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-19"},"text":"Sept. 19, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1647"},"text":"102 Stat. 1647","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIV"},"text":"Pub. L. 115–334, title IV","children":[],"tail":", §§ 4018(b), (c), 4104, "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4648"},"text":"132 Stat. 4648","children":[],"tail":", 4649, 4655; "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/dB/tI/s102/d/3"},"text":"Pub. L. 118–22, div. B, title I, § 102(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-11-17"},"text":"Nov. 17, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/116"},"text":"137 Stat. 116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10603"},"text":"Pub. L. 119–21, title I, § 10603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/108"},"text":"139 Stat. 108","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf010c450-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf010c451-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf010c452-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “2031” for “2024”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" substituted “2024” for “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s4018/b"},"text":"Pub. L. 115–334, § 4018(b)","children":[],"tail":", (c), added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s4104"},"text":"Pub. L. 115–334, § 4104","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf010c453-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf010c454-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" to be applied and administered as if enacted on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/g"},"text":"section 102(g) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf010c455-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section to be effective and implemented on ","children":[{"tag":"date","attrib":{"date":"1988-10-01"},"text":"Oct. 1, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/435/s701/a"},"text":"section 701(a) of Pub. L. 100–435","children":[],"tail":", set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2012"},"text":"section 2012 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
