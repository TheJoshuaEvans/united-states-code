{"tag":"section","attrib":{"id":"ideed5f9ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1627a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1627a"},"text":"§ 1627a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sheep production and marketing grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideed5f9ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1627a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture, acting through the Administrator of the Agricultural Marketing Service, shall establish a competitive grant program for the purposes of strengthening and enhancing the production and marketing of sheep and sheep products in the United States, including through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideed5f9ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1627a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the improvement of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideed5f9af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1627a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideed5f9b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1627a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideed5f9b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1627a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resource development; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideed5f9b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1627a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of innovative approaches to solve long-term needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideed5f9b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1627a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants under this section to at least one national entity, the mission of which is consistent with the purpose of the grant program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideed5f9b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1627a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall use to carry out this section $2,000,000 for fiscal year 2019, $400,000 for fiscal year 2024, and $3,000,000 for fiscal year 2026, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideed5f9b5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us