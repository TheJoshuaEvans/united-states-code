{"tag":"section","attrib":{"id":"idf02fbd9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105"},"text":null,"children":[{"tag":"num","attrib":{"value":"8105"},"text":"§ 8105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bioenergy program for advanced biofuels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02fbd9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “eligible producer” means a producer of advanced biofuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbd9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make payments to eligible producers to support and ensure an expanding production of advanced biofuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbda0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive a payment, an eligible producer shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02fbda1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into a contract with the Secretary for production of advanced biofuels; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbda2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary such records as the Secretary may require as evidence of the production of advanced biofuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbda3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basis for payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make payments under this section to eligible producers based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02fbda4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity and duration of production by the eligible producer of an advanced biofuel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbda5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net nonrenewable energy content of the advanced biofuel, if sufficient data is available, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbda6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate factors, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbda7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable distribution","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02fbda8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall limit the amount of payments that may be received by a single eligible producer under this section in order to distribute the total amount of funding available in an equitable manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbda9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feedstock","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of payments made in a fiscal year under this section to one or more eligible producers for the production of advanced biofuels derived from a single eligible commodity, including intermediate ingredients of that single commodity or use of that single commodity and its intermediate ingredients in combination with another commodity, shall not exceed one-third of the total amount of funds made available under subsection (g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbdaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To receive a payment under this section, an eligible producer shall meet any other requirements of Federal and State law (including regulations) applicable to the production of advanced biofuels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbdab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02fbdac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall use to carry out this section, to remain available until expended—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02fbdad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $55,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbdae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $55,000,000 for fiscal year 2010;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbdaf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $85,000,000 for fiscal year 2011;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbdb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $105,000,000 for fiscal year 2012;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbdb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/g/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for each of fiscal years 2014 through 2018; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbdb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/g/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7,000,000 for each of fiscal years 2019 through 2031.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbdb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other funds made available to carry out this section, there is authorized to be appropriated to carry out this section $20,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbdb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8105/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds provided for each fiscal year, not more than 5 percent of the funds shall be made available to eligible producers for production at facilities with a total refining capacity exceeding 150,000,000 gallons per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02fbdb5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIX/s9005"},"text":"Pub. L. 107–171, title IX, § 9005","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIX/s9001/a"},"text":"Pub. L. 110–234, title IX, § 9001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1314"},"text":"122 Stat. 1314","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title IX, § 9001(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2075; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/tVII/s701/f/4"},"text":"Pub. L. 112–240, title VII, § 701(f)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2365"},"t