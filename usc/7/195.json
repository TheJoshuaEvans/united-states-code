{"tag":"section","attrib":{"id":"idee1bf87d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s195"},"text":null,"children":[{"tag":"num","attrib":{"value":"195"},"text":"§ 195.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Punishment for violation of order","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Any packer or swine contractor, or any officer, director, agent, or employee of a packer or swine contractor, who fails to obey any order of the Secretary issued under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s193"},"text":"section 193 of this title","children":[],"tail":", or such order as modified—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idee1bf87e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s195/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the expiration of the time allowed for filing a petition in the court of appeals to set aside or modify such order, if no such petition has been filed within such time; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1bf87f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s195/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the expiration of the time allowed for applying for a writ of certiorari, if such order, or such order as modified, has been sustained by the court of appeals and no such writ has been applied for within such time; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1bf880-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s195/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After such order, or such order as modified, has been sustained by the courts as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s194"},"text":"section 194 of this title","children":[],"tail":"; shall on conviction be fined not less than $500 nor more than $10,000, or imprisoned for not less than six months nor more than five years, or both. Each day during which such failure continues shall be deemed a separate offense."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee1bf881-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title II, § 205, "},{"tag":"ref","attrib":{"href":"/us/stat/42/163"},"text":"42 Stat. 163","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646/s32/a"},"text":"June 25, 1948, ch. 646, § 32(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/991"},"text":"62 Stat. 991","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-05-24/ch139/s127"},"text":"May 24, 1949, ch. 139, § 127","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/107"},"text":"63 Stat. 107","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10502/b/1"},"text":"Pub. L. 107–171, title X, § 10502(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/509"},"text":"116 Stat. 509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee1bf882-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee1bf883-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee1bf884-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" substituted “packer or swine contractor” for “packer” in two places in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee1bf885-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idee1bf886-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Act ","children":[{"tag":"date","attrib":{"date":"1948-06-25"},"text":"June 25, 1948","children":[],"tail":", as amended by act "},{"tag":"date","attrib":{"date":"1949-05-24"},"text":"May 24, 1949","children":[],"tail":", substituted “court of appeals” for “circuit court of appeals”, wherever appearing in this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
