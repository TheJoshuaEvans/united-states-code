{"tag":"section","attrib":{"id":"ideff1a3ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923"},"text":null,"children":[{"tag":"num","attrib":{"value":"6923"},"text":"§ 6923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Urban Agriculture and Innovative Production","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff1a3ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a3ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish in the Department an Office of Urban Agriculture and Innovative Production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a3f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint a senior official to serve as the Director of the Office of Urban Agriculture and Innovative Production (referred to in this section as the “Director”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a3f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The mission of the Office of Urban Agriculture and Innovative Production shall be to encourage and promote urban, indoor, and other emerging agricultural practices, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a3f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community gardens and farms located in urban areas, suburbs, and urban clusters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rooftop farms, outdoor vertical production, and green walls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indoor farms, greenhouses, and high-tech vertical technology farms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydroponic, aeroponic, and aquaponic farm facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other innovations in agricultural production, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a3f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall be responsible for engaging in activities to carry out the mission described in paragraph (3), including by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a3f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" managing programs, including for community gardens, urban farms, rooftop agriculture, and indoor vertical production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating with the agencies and officials of the Department to update relevant programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging in stakeholder relations and developing external partnerships;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying common State and municipal best practices for navigating local policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating networks of community gardens and facilitating connections to local food banks, in partnership with the Food and Nutrition Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/a/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborating with other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a3ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urban Agriculture and Innovative Production Advisory Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a400-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary shall establish an Urban Agriculture and Innovative Production Advisory Committee (referred to in this subsection as the “Committee”) to advise the Secretary on—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a401-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of policies and outreach relating to urban, indoor, and other emerging agricultural production practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a402-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other aspects of the implementation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a403-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a404-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall be composed of 12 members, of whom—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a405-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 4 shall be individuals who are agricultural producers, of whom—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideff1a406-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 individuals shall be agricultural producers located in an urban area or urban cluster; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideff1a407-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 individuals shall be farmers that use innovative technology;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a408-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall be representatives from an institution of higher education or extension program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a409-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be an individual who represents a nonprofit organization, which may include a public health, environmental, or community organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a40a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be an individual who represents business and economic development, which may include a business development entity, a chamber of commerce, a city government, or a planning organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a40b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be an individual with supply chain experience, which may include a food aggregator, wholesale food distributor, food hub, or an individual who has direct-to-consumer market experience;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a40c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be an individual from a financing entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a40d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall be individuals with related experience or expertise in urban, indoor, and other emerging agriculture production practices, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a40e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial appointments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint the members of the Committee not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a40f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of appointment; vacancies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a410-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), a member of the Committee shall be appointed for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a411-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial appointments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the members first appointed to the Committee—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a412-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 of the members, as determined by the Secretary, shall be appointed for a term of 3 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a413-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 of the members, as determined by the Secretary, shall be appointed for a term of 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a414-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 of the members, as determined by the Secretary, shall be appointed for a term of 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a415-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any vacancy in the Committee—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a416-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not affect the powers of the Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a417-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be filled as soon as practicable in the same manner as the original appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a418-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consecutive terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An initial appointee of the committee may serve an additional consecutive term if the member is reappointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a419-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a41a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frequency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall meet not fewer than 3 times per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a41b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date on which the members are appointed under paragraph (2)(B), the Committee shall hold the first meeting of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a41c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a41d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a41e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop recommendations and advise the Director on policies, initiatives, and outreach administered by the Office of Urban Agriculture and Innovative Production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a41f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and review ongoing research and extension activities relating to urban, indoor, and other innovative agricultural practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a420-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify new and existing barriers to successful urban, indoor, and other emerging agricultural production practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a421-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/5/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide additional assistance and advice to the Director as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a422-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date on which the Committee is established, and every 2 years through 2023, the Committee shall submit to the Secretary, the Committee on Agriculture of the House of Representatives, and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing the recommendations developed under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a423-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel matters","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a424-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Committee shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a425-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Committee shall be allowed travel expenses, including per diem in lieu of subsistence, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a426-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a427-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Committee shall terminate on the date that is 5 years after the date on which the members are appointed under paragraph (2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a428-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extensions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the date on which the Committee terminates, the Secretary may renew the Committee for 1 or more 2-year periods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a429-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall award competitive grants to support the development of urban agriculture and innovative production to any of the following eligible entities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a42a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a42b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A unit of local government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a42c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Tribal government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a42d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any school that serves any of grades kindergarten through grade 12.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a42e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a42f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urban and suburban county committees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a430-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary shall establish a pilot program for not fewer than 5 years that establishes 10 county committees in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b/5/B/ii/II"},"text":"section 590h(b)(5)(B)(ii)(II) of title 16","children":[],"tail":" to operate in counties located in urban or suburban areas with a high concentration of urban or suburban farms."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a431-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph requires or precludes the establishment of a Farm Service Agency office in a county in which a county committee is established under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a432-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2019 and each fiscal year thereafter through fiscal year 2023, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing a summary of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a433-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the pilot program under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a434-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meetings and other activities of the committees established under that subparagraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a435-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types and volume of assistance and services provided to farmers in counties in which county committees are established under that subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a436-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increasing community compost and reducing food waste","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a437-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director, shall carry out pilot projects under which the Secretary shall offer to enter into cooperative agreements with local or municipal governments in not fewer than 10 States to develop and test strategies for planning and implementing municipal compost plans and food waste reduction plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a438-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities and purposes of pilot projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under a cooperative agreement entered into under this paragraph, the Secretary shall provide assistance to municipalities, counties, local governments, or city planners, as appropriate, to carry out planning and implementing activities that will—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a439-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generate compost;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a43a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase access to compost for agricultural producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a43b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce reliance on, and limit the use of, fertilizer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a43c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve soil quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a43d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage waste management and permaculture business development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a43e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase rainwater absorption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a43f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce municipal food waste; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a440-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" divert food waste from landfills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a441-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and ranking of applications","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a442-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary shall establish criteria for the selection of pilot projects under this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a443-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting, undertaking, or funding pilot projects under this paragraph, the Secretary shall consider any commonly known significant impact on existing food waste recovery and disposal by commercial, marketing, or business relationships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a444-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting a pilot project under this paragraph, the Secretary shall give priority to an application for a pilot project that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideff1a445-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anticipates or demonstrates economic benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideff1a446-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporates plans to make compost easily accessible to agricultural producers, including community gardeners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideff1a447-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/C/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrates other food waste strategies, including food recovery efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideff1a448-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/C/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for collaboration with multiple partners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a449-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The recipient of assistance for a pilot project under this paragraph shall provide funds, in-kind contributions, or a combination of both from sources other than funds provided through the grant in an amount equal to not less than 25 percent of the amount of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a44a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct an evaluation of the pilot projects funded under this paragraph to assess different solutions for increasing access to compost and reducing municipal food waste, including an evaluation of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a44b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of Federal funds used for each project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a44c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/d/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a measurement of the outcomes of each project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a44d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6923/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section and the amendments made by this section $25,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff1a44e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s222"},"text":"Pub. L. 103–354, title II, § 222","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12302"},"text":"Pub. L. 115–334, title XII, § 12302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4958"},"text":"132 Stat. 4958","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
