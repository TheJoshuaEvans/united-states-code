{"tag":"section","attrib":{"id":"idee2f0b7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390d"},"text":null,"children":[{"tag":"num","attrib":{"value":"390d"},"text":"§ 390d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee2f0b80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (b), (c), and (d), there are authorized to be appropriated such sums as are necessary for each of fiscal years 1996 through 2023 for the study, plan, design, structure, and related costs of agricultural research facilities under this subchapter. Funds appropriated pursuant to the preceding sentence shall be available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2f0b81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowable administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 3 percent of the funds made available for any project for an agricultural research facility shall be available for administration of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2f0b82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 25 percent of the funds made available pursuant to subsections (a) and (e) for any fiscal year shall be used for any single agricultural research facility project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2f0b83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity eligible to receive funds under this subchapter may receive funds for only one project at a time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2f0b84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsections (b), (c), and (d), of the funds of the Commodity Credit Corporation, the Secretary shall make available to carry out the competitive grant program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s390b"},"text":"section 390b of this title","children":[],"tail":" $125,000,000 for fiscal year 2026 and each fiscal year thereafter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee2f0b85-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/74/s6"},"text":"Pub. L. 88–74, § 6","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s884/a"},"text":"Pub. L. 104–127, title VIII, § 884(a)","children":[],"tail":", "},{"