{"tag":"section","attrib":{"id":"idef6c1f6c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2135"},"text":null,"children":[{"tag":"num","attrib":{"value":"2135"},"text":"§ 2135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time period for disposal of dogs or cats by dealers or exhibitors","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No dealer or exhibitor shall sell or otherwise dispose of any dog or cat within a period of five business days after the acquisition of such animal or within such other period as may be specified by the Secretary: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That operators of auction sales subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2142"},"text":"section 2142 of this title","children":[],"tail":" shall not be required to comply with the provisions of this section."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef6c1f6d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/544/s5"},"text":"Pub. L. 89–544, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-08-24"},"text":"Aug. 24, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/351"},"text":"80 Stat. 351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/579/s6"},"text":"Pub. L. 91–579, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1561"},"text":"84 Stat. 1561","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef6c1f6e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef6c1f6f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[