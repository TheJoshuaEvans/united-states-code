{"tag":"section","attrib":{"id":"idf0347846-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8202"},"text":null,"children":[{"tag":"num","attrib":{"value":"8202"},"text":"§ 8202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0347847-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loss","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the Secretary shall provide assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8203"},"text":"section 8203 of this title","children":[],"tail":" to eligible orchardists that planted trees for commercial purposes but lost the trees as a result of a natural disaster, as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0347848-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible orchardist shall qualify for assistance under subsection (a) only if the tree mortality of the eligible orchardist, as a result of damaging weather or related condition, exceeds 15 percent (adjusted for normal mortality).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0347849-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10202"},"text":"Pub. L. 107–171, title X, § 10202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/490"},"text":"116 Stat. 490","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
