{"tag":"section","attrib":{"id":"idf04eb81d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071"},"text":null,"children":[{"tag":"num","attrib":{"value":"9071"},"text":"§ 9071.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Milk donation program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04eb81e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb81f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible dairy organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible dairy organization” means a dairy farmer (either individually or as part of a cooperative), or a dairy processor, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04eb820-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accounts to a Federal milk marketing order marketwide pool; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb821-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incurs qualified expenses under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb822-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible distributor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible distributor” means a public or private nonprofit organization that distributes donated eligible milk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb823-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible milk","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible milk” means Class I fluid milk products produced and processed in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb824-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible partnership” means a partnership between an eligible dairy organization and an eligible distributor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb825-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participating partnership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “participating partnership” means an eligible partnership for which the Secretary has approved a donation and distribution plan for eligible milk under subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb826-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program required; purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary shall establish and administer a milk donation program for the purposes of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb827-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the donation of eligible milk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb828-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing nutrition assistance to individuals in low-income groups; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0512829-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing food waste.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf051282a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Donation and distribution plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf051282b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive reimbursement under subsection (d), an eligible partnership shall submit to the Secretary a donation and distribution plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf051282c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the process that the eligible partnership will use for the donation, processing, transportation, temporary storage, and distribution of eligible milk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf051282d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes an estimate of the quantity of eligible milk that the eligible partnership will donate each year, based on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf051282e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preplanned donations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf051282f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contingency plans to address unanticipated donations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0512830-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the rate at which the eligible partnership will be reimbursed, which shall be based on a percentage of the limitation described in subsection (e)(2), not to exceed 100 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0512831-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and approval","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than annually, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0512832-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review donation and distribution plans submitted under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0512833-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether to approve or disapprove each of those donation and distribution plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0512834-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0512835-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On receipt of appropriate documentation under paragraph (2), the Secretary shall reimburse an eligible dairy organization that is a member of a participating partnership on a regular basis for qualified expenses described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0512836-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documentation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0512837-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible dairy organization shall submit to the Secretary such documentation as the Secretary may require to demonstrate the qualified expenses described in subsection (e) of the eligible dairy organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0512838-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may verify the accuracy of documentation submitted under subparagraph (A) by spot checks and audits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0512839-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retroactive reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing reimbursements under paragraph (1), the Secretary may provide reimbursements for qualified expenses incurred before the date on which the donation and distribution plan for the applicable participating partnership was approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf051283a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified expenses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf051283b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a reimbursement under subsection (d) shall be an amount equal to the product of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf051283c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of eligible milk donated by the eligible dairy organization under a donation and distribution plan approved by the Secretary under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf051283d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the limitation under paragraph (2), the rate described in that donation and distribution plan under subsection (c)(1)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf051283e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Expenses eligible for reimbursement under subsection (d) shall not exceed the value that an eligible dairy organization incurred by accounting to the Federal milk marketing order pool at the difference in the Class I milk value and the lowest classified price for the applicable month (either Class III milk or Class IV milk).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf051283f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preapproval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0512840-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0512841-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a process for an eligible partnership to apply for preapproval of donation and distribution plans under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0512842-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not less frequently than annually, preapprove an amount for qualified expenses described in subsection (e) that the Secretary will allocate for reimbursement under each donation and distribution plan preapproved under subparagraph (A), based on an assessment of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0512843-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0512844-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the plan advances the purposes described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0512845-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In preapproving amounts for reimbursement under paragraph (1)(B), the Secretary shall give preference to eligible partnerships that will provide funding and in-kind contributions in addition to the reimbursements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0512846-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0512847-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall adjust or increase amounts preapproved for reimbursement under paragraph (1)(B) based on performance and demand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0512848-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for increase","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0512849-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/f/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a procedure for a participating partnership to request an increase in the amount preapproved for reimbursement under paragraph (1)(B) based on changes in conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf051284a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/f/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim approval; incremental increase","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide an interim approval of an increase requested under clause (i) and an incremental increase in the amount of reimbursement to the applicable participating partnership to allow time for the Secretary to review the request without interfering with the donation and distribution of eligible milk by the participating partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf051284b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on resale of products","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf051284c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible distributor that receives eligible milk donated under this section may not sell the products back into commercial markets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf051284d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on future participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible distributor that the Secretary determines has violated paragraph (1) shall not be eligible for any future participation in the program established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf051284e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall publicize opportunities to participate in the program established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf051284f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviews","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct appropriate reviews or audits to ensure the integrity of the program established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0512850-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9071/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall use to carry out this section $9,000,000 for fiscal year 2019, and $5,000,000 for each fiscal year thereafter, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0512851-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1431"},"text":"Pub. L. 113–79, title I, § 1431","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1404/b/1"},"text":"Pub. L. 115–334, title I, § 1404(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4519"},"text":"132 Stat. 4519","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0512852-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0512853-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf0512854-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 9071, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1431"},"text":"Pub. L. 113–79, title I, § 1431","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/695"},"text":"128 Stat. 695","children":[],"tail":", related to dairy product donation program, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1404/a"},"text":"Pub. L. 115–334, title I, § 1404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4519"},"text":"132 Stat. 4519","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
