{"tag":"section","attrib":{"id":"idef84154b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2542"},"text":null,"children":[{"tag":"num","attrib":{"value":"2542"},"text":"§ 2542.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grandfather clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall abridge the right of any person, or the successor in interest of the person, to reproduce or sell a variety developed and produced by such person more than one year prior to the effective filing date of an adverse application for a certificate of plant variety protection.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef84154c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tIII/s112"},"text":"Pub. L. 91–577, title III, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1555"},"text":"84 Stat. 1555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s13/r"},"text":"Pub. L. 103–349, § 13(r)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3144"},"text":"108 Stat. 3144","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef84154d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef84154e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef84154f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children"