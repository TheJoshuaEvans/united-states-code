{"tag":"section","attrib":{"id":"idf00be273-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464"},"text":null,"children":[{"tag":"num","attrib":{"value":"7464"},"text":"§ 7464.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Kiwifruit Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00be274-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An order issued by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7463"},"text":"section 7463 of this title","children":[],"tail":" shall provide for the establishment of a National Kiwifruit Board that consists of the following 11 members:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be275-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 members who are producers, exporters, or importers (or their representatives), based on a proportional representation of the level of domestic production and imports of kiwifruit (as determined by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be276-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member appointed from the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be277-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of membership","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the 11-member limit, the Secretary may adjust membership on the Board to accommodate changes in production and import levels of kiwifruit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be278-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and nomination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be279-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint the members of the Board from nominations submitted in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be27a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members who are producers referred to in subsection (a)(1) shall be appointed from individuals nominated by producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be27b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importers and exporters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members who are importers or exporters referred to in subsection (a)(1) shall be appointed from individuals nominated by importers or exporters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be27c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The public representative shall be appointed from nominations submitted by other members of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be27d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to nominate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If producers, importers, and exporters fail to nominate individuals for appointment, the Secretary may appoint members and alternates on a basis provided for in the order. If the Board fails to nominate a public representative, the member and alternate may be appointed by the Secretary without a nomination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be27e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall appoint an alternate for each member of the Board. An alternate shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be27f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed in the same manner as the member for whom the individual is an alternate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be280-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve on the Board if the member is absent from a meeting or is disqualified under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be281-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A member of the Board shall be appointed for a term of 3 years. No member may serve more than 2 consecutive 3-year terms, except that of the members first appointed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be282-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 members shall be appointed for a term of 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be283-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 members shall be appointed for a term of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be284-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a member or alternate of the Board who was appointed as a producer, importer, exporter, or public representative member ceases to belong to the group for which the member was appointed, the member or alternate shall be disqualified from serving on the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be285-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member or alternate of the Board shall serve without pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00be286-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General powers and duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00be287-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer an order issued by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7463"},"text":"section 7463 of this title","children":[],"tail":", and an amendment to the order, in accordance with the order and amendment and this subchapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be288-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe rules and regulations to carry out the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be289-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet, organize, and select from among members of the Board a chairperson, other officers, and committees and subcommittees, as the Board determines appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be28a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive, investigate, and report to the Secretary accounts of violations of the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be28b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Secretary with respect to an amendment that should be made to the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00be28c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7464/h/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ or contract with a manager and staff to assist in administering the order, except that, to reduce administrative costs and increase efficiency, the Board shall seek, to the extent practicable, to employ or contract with personnel who are already associated with organizations involved in promoting kiwifruit that are chartered by a State, the District of Columbia, or the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00be28d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s555"},"text":"Pub. L. 104–127, title V, § 555","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1066"},"text":"110 Stat. 1066","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s603/b"},"text":"Pub. L. 105–185, title VI, § 603(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/585"},"text":"112 Stat. 585","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf00be28e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf00be28f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf00be290-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s603/b/1"},"text":"Pub. L. 105–185, § 603(b)(1)","children":[],"tail":", added pars. (1) and (2) and struck out former pars. (1) to (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) 6 members who are producers (or representatives of producers) and who are not exempt from an assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7465/b"},"text":"section 7465(b) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) 4 members who are importers (or representatives of importers) and who are not exempt from an assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7465/b"},"text":"section 7465(b) of this title","children":[],"tail":" or are exporters (or representatives of exporters)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) 1 member appointed from the general public.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s603/b/2"},"text":"Pub. L. 105–185, § 603(b)(2)","children":[],"tail":", struck out par. (1) designation and heading, struck out “and to paragraph (2)” after “11-member limit”, and struck out heading and text of par. (2). Text read as follows: “Producers shall comprise not less than 51 percent of the membership of the Board.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s603/b/3/A"},"text":"Pub. L. 105–185, § 603(b)(3)(A)","children":[],"tail":", inserted “who are producers” after “members”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s603/b/3/B"},"text":"Pub. L. 105–185, § 603(b)(3)(B)","children":[],"tail":", inserted “who are importers or exporters” after “members” and substituted “(a)(1)” for “(a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s603/b/3/C"},"text":"Pub. L. 105–185, § 603(b)(3)(C)","children":[],"tail":", inserted “and alternate” before “may be appointed” in second sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
