{"tag":"section","attrib":{"id":"idef7a7854-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2272"},"text":null,"children":[{"tag":"num","attrib":{"value":"2272"},"text":"§ 2272.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Volunteers for Department of Agriculture programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7a7855-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2272/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture (hereafter referred to in this section as the “Secretary”) may establish a program to use volunteers in carrying out the programs of the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7a7856-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2272/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of personnel","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may accept, subject to regulations issued by the Office of Personnel Management, voluntary service for the Department of Agriculture for such purpose if the service:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7a7857-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2272/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is to be without compensation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7a7858-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2272/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not be used to displace any employee of the Department of Agriculture including the local, county, and State committees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b"},"text":"section 590h(b) of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7a7859-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2272/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal employee status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any individual who provides voluntary service under this section shall not be considered a Federal employee, except for purposes of chapter 81 of title 5 (relating to compensation for injury), and sections 2671 through 2680 of title 28 (relating to tort claims).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7a785a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXV/s1526"},"text":"Pub. L. 97–98, title XV, § 1526","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1337"},"text":"95 Stat. 1337","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7a785b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef7a785c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef7a785d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef7a785e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXV/s1527"},"text":"Pub. L. 97–98, title XV, § 1527","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1337"},"text":"95 Stat. 1337","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/98/tXV/s1527"},"text":"“There are authorized to be appropriated such sums as may be necessary to carry out the provisions of this subtitle [subtitle G (§§ 1526, 1527) of title XV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":", enacting this section and this note], such sums to remain available until expended.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
