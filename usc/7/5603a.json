{"tag":"section","attrib":{"id":"idefc93395-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5603a"},"text":"§ 5603a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global market strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefc93396-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", and biennially thereafter, the Secretary of Agriculture shall consult with the Committee on Agriculture, and the Committee on International Relations, of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate on the formulation and implementation of a global market strategy for the Department of Agriculture that, to the maximum extent practicable—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc93397-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies opportunities for the growth of agricultural exports to overseas markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc93398-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that the resources, programs, and policies of the Department are coordinated with those of other agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc93399-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remove ","children":[{"tag":"ref","attrib":{"idref":"fn002306"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002306"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “removes”."}],"tail":" barriers to agricultural trade in overseas markets."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc9339a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The consultations under subsection (a) shall include a review of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc9339b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strategic goals of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc9339c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5603a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of the Department in implementing the strategic goals through the global market strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc9339d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIII/s3206"},"text":"Pub. L. 107–171, title III, § 3206","children":[],"t