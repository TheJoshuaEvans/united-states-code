{"tag":"section","attrib":{"id":"idee3af32f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s511h"},"text":null,"children":[{"tag":"num","attrib":{"value":"511h"},"text":"§ 511h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of information relating to tobacco","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to collect, publish, and distribute, by telegraph, mail, or otherwise without cost to the grower, timely information on the market supply and demand, location, disposition, quality, condition, and market prices for tobacco.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee3af330-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch623/s9"},"text":"Aug. 23, 1935, ch. 623, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/733"},"text":"49 Stat. 733","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
