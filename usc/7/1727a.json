{"tag":"section","attrib":{"id":"ideeedc78e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1727a"},"text":"§ 1727a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeedc78f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Least developed countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A country shall be considered to be a least developed country and eligible for the donation of agricultural commodities under this subchapter if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeedc790-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such country meets the poverty criteria established by the International Bank for Reconstruction and Development for Civil Works Preference for providing financial assistance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc791-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such country is a food deficit country and is characterized by high levels of malnutrition among significant numbers of its population, as determined by the Administrator under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc792-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indicators of food deficit countries","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To make a finding under subsection (a)(2) that a country is a food deficit country and is characterized by high levels of malnutrition, the Administrator must determine that the country meets all of the following indicators of national food deficit and malnutrition:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeedc793-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calorie consumption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"That the daily per capita calorie consumption of the country is less than 2300 calories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc794-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food security requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"That the country cannot meet its food security requirements through domestic production or imports due to a shortage of foreign exchange earnings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc795-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child mortality rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"That the mortality rate of children under 5 years of age in the country is in excess of 100 per 1000 births.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc796-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether and to what extent agricultural commodities shall be made available to least developed countries under this subchapter, the Administrator shall give priority to countries that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeedc797-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the greatest need for food;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc798-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the capacity to use food assistance effectively;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc799-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have demonstrated a commitment to policies to promote food security, including policies to reduce measurably hunger and malnutrition through efforts such as establishing and institutionalizing supplemental nutrition programs targeted to reach those who are nutritionally at risk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeedc79a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a long-term plan for broad-based, equitable, and sustainable development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeedc79b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title III, § 302, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/88/tII/s211/a/2"},"text":"Pub. L. 95–88, title II, § 211(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/549"},"text":"91 Stat. 549","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/53/tII/s205"},"text":"Pub. L. 96–53, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/369"},"text":"93 Stat. 369","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/83/tX/s1004/b"},"text":"Pub. L. 99–83, title X, § 1004(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-08-08"},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/271"},"text":"99 Stat. 271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXI/s1108"},"text":"Pub. L. 99–198, title XI, § 1108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1467"},"text":"99 Stat. 1467","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","att