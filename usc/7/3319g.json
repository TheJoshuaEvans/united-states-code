{"tag":"section","attrib":{"id":"idefaa39d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319g"},"text":null,"children":[{"tag":"num","attrib":{"value":"3319g"},"text":"§ 3319g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In fiscal year 2003 and thereafter, the agency is authorized to charge fees, commensurate with the fair market value, for any permit, easement, lease, or other special use authorization for the occupancy or use of land and facilities (including land and facilities at the Beltsville Agricultural Research Center) issued by the agency, as authorized by law, and such fees shall be credited to this account, and shall remain available until expended for authorized purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefaa39d3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dA/tI"},"text":"Pub. L. 108–7, div. A, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/17"},"text":"117 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefaa39d4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefaa39d5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefaa39d6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The agency, referred to in text, means the Agricultural Research Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefaa39d7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agriculture, Rural Development, Food and Drug Administration, and Related Agencies Appropriations Act, 2003, and also as part of the Consolidated Appropriations Resolution, 2003, and not as part of the National Agricultural Research, Extension, and Teaching Policy Act of 1977 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idefaa39d8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/76/tI"},"text":"Pub. L. 107–76, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-29"},"text":"Nov. 29, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/709"},"text":"115 Stat. 709","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tI"},"text":"Pub. L. 106–387, § 1(a) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–6."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78/tI"},"text":"Pub. L. 106–78, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1140"},"text":"113 Stat. 1140","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/a/tI"},"text":"Pub. L. 105–277, div. A, § 101(a) [title I]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681"},"text":"112 Stat. 2681","children":[],"tail":", 2681–5."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
