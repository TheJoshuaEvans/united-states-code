{"tag":"section","attrib":{"id":"idef78072f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2242b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2242b"},"text":"§ 2242b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Translation of publications into foreign languages","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":", funds appropriated to the Department of Agriculture by this Act may be used for translation of publications of the Department of Agriculture into foreign languages when determined by the Secretary to be in the public interest."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef780730-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/142/tVII/s721"},"text":"Pub. L. 102–142, title VII, § 721","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/913"},"text":"105 Stat. 913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef780731-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef780732-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef780733-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/142"},"text":"Pub. L. 102–142","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/878"},"text":"105 Stat. 878","children":[],"tail":", known as the Agriculture, Rural Development, Food and Drug Administration, and Related Agencies Appropriations Act, 1992. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
