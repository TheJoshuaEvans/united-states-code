{"tag":"section","attrib":{"id":"idef7a780d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2266b"},"text":"§ 2266b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for operators on heirs property land to obtain a farm number","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7a780e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7a780f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible documentation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible documentation”, with respect to land for which a farm operator seeks assignment of a farm number under subsection (b)(1), includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7a7810-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in States that have adopted a statute consisting of an enactment or adoption of the Uniform Partition of Heirs Property Act, as approved and recommended for enactment in all States by the National Conference of Commissioners on Uniform State Laws in 2010—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef7a7811-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court order verifying the land meets the definition of heirs property (as defined in that Act); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7a7812-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification from the local recorder of deeds that the recorded owner of the land is deceased and not less than 1 heir of the recorded owner of the land has initiated a procedure to retitle the land in the name of the rightful heir;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7a7813-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a fully executed, unrecorded tenancy-in-common agreement that sets out ownership rights and responsibilities among all of the owners of the land that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef7a7814-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been approved by a majority of the ownership interests in that property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7a7815-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has given a particular owner the right to manage and control any portion or all of the land for purposes of operating a farm or ranch; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef7a7816-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was validly entered into under the authority of the jurisdiction in which the land is located;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7a7817-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the tax return of a farm operator farming a property with undivided interests for each of the 5 years preceding the date on which the farm operator submits the tax returns as eligible documentation under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7a7818-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" self-certification that the farm operator has control of the land for purposes of operating a farm or ranch; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7a7819-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other documentation identified by the Secretary under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7a781a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “farm number” has the meaning given the term in section 718.2 of title 7, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7a781b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm number","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7a781c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the assignment of a farm number to any farm operator who provides any form of eligible documentation for purposes of demonstrating that the farm operator has control of the land for purposes of defining that land as a farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7a781d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any farm number provided under paragraph (1) shall be sufficient to satisfy any requirement of the Secretary to have a farm number to participate in a program of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7a781e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2266b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible documentation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall identify alternative forms of eligible documentation that a farm operator may provide in seeking the assignment of a farm number under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7a781f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12615"},"text":"Pub. L. 115–334, title XII, § 12615","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5014"},"text":"132 Stat. 5014","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7a7820-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef7a7821-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idef7a7822-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” means the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2"},"text":"section 2 of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
