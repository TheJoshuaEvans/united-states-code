{"tag":"section","attrib":{"id":"idefac8429-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362"},"text":null,"children":[{"tag":"num","attrib":{"value":"3362"},"text":"§ 3362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distance education grants for insular areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefac842a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make competitive grants to eligible institutions in insular areas to strengthen the capacity of such institutions to carry out distance food and agricultural education programs using digital network technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac842b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made under this section shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefac842c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire the equipment, instrumentation, networking capability, hardware and software, digital network technology, and infrastructure necessary to teach students and teachers about technology in the classroom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac842d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and provide educational services (including faculty development) to prepare students or faculty seeking a degree or certificate that is approved by the State or a regional accrediting body recognized by the Secretary of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac842e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide teacher education, library and media specialist training, and preschool and teacher aid certification to individuals who seek to acquire or enhance technology skills in order to use technology in the classroom or instructional process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac842f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement a joint project to provide education regarding technology in the classroom with a local educational agency, community-based organization, national nonprofit organization, or business; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac8430-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide leadership development to administrators, board members, and faculty of eligible institutions with institutional responsibility for technology education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8431-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of grant funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided under this section shall not be used for the planning, acquisition, construction, rehabilitation, or repair of a building or facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8432-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may carry out this section in a manner that recognizes the different needs and opportunities for eligible institutions in the Atlantic and Pacific Oceans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8433-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefac8434-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish a requirement that an eligible institution receiving a grant under this section shall provide matching funds from non-Federal sources in an amount equal to not less than 50 percent of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac8435-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary establishes a matching requirement under paragraph (1), the Secretary shall retain an option to waive the requirement for an eligible institution for any fiscal year if the Secretary determines that the institution will be unlikely to meet the matching requirement for the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8436-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefac8437-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2002 through 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac8438-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3362/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefac8439-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1490"},"text":"Pub. L. 95–113, title XIV, § 1490","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7503"},"text":"Pub. L. 107–171, title VII, § 7503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/464"},"text":"116 Stat. 464","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7143/a"},"text":"Pub. L. 110–234, title VII, § 7143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1232"},"text":"122 Stat. 1232","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7143(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1994; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7127/a"},"text":"Pub. L. 113–79, title VII, § 7127(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/877"},"text":"128 Stat. 877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7136/a"},"text":"Pub. L. 115–334, title VII, § 7136(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4802"},"text":"132 Stat. 4802","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefac843a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n"