{"tag":"section","attrib":{"id":"idefc207da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4905"},"text":null,"children":[{"tag":"num","attrib":{"value":"4905"},"text":"§ 4905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may issue such regulations as may be necessary to carry out the provisions of this chapter and the powers vested in the Secretary under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefc207db-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1646"},"text":"Pub. L. 99–198, title XVI, § 1646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1624"},"text":"99 Stat. 1624","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
