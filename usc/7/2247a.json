{"tag":"section","attrib":{"id":"idef78074f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2247a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2247a"},"text":"§ 2247a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm or food products; sale of samples, practical forms, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized to sell samples, illustrations, practical forms, or sets of the grades recommended or promulgated by him for farm or food products, under such rules and regulations as he may prescribe, and the receipts therefrom shall be deposited in the Treasury to the credit of miscellaneous receipts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef780750-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-09-21/ch412"},"text":"Sept. 21, 1944, ch. 412","children":[],"tail":", title IV, § 401(a), "},{"tag":"ref","attrib":{"href":"/us/stat/58/738"},"text":"58 Stat. 738","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef780751-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef780752-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef780753-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s415e"},"text":"section 415e of this title","children":[],"tail":" prior to editorial reclassification and renumberin