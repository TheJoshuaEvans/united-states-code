{"tag":"section","attrib":{"id":"idefef5a55-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6918"},"text":null,"children":[{"tag":"num","attrib":{"value":"6918"},"text":"§ 6918.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Secretaries of Agriculture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefef5a56-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6918/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to establish in the Department the positions of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefef5a57-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6918/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistant Secretary of Agriculture for Congressional Relations and Intergovernmental Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefef5a58-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6918/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistant Secretary of Agriculture for Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefef5a59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6918/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistant Secretary of Agriculture for Civil Rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefef5a5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6918/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confirmation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary establishes any position of Assistant Secretary authorized under paragraph (1) or (3) of subsection (a), the Assistant Secretary shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefef5a5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6918/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Assistant Secretary of Agriculture for Civil Rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may delegate to the Assistant Secretary for Civil Rights responsibility for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefef5a5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6918/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring compliance with all civil rights and related laws by all agencies and under all programs of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefef5a5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6918/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating administration of civil rights laws (including regulations) within the Department for employees of, and participants in, programs of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefef5a5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6918/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that necessary and appropriate civil rights components are properly incorporated into all strategic planning initiatives of the Department and agencies of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefef5a5f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s218"},"text":"Pub. L. 103–354, title II, § 218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3212"},"text":"108 Stat. 3212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/a/tX/s1001/1"},"text":"Pub. L. 105–277, div. A, § 101(a) [title X, § 1001(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681"},"text":"112 Stat. 2681","children":[],"tail":", 2681–41; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10704/a"},"text":"Pub. L. 107–171, title X, § 10704(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/518"},"text":"116 Stat. 518","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/a/1"},"text":"Pub. L. 112–166, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1283"},"text":"126 Stat. 1283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII"},"text":"Pub. L. 115–334, title XII","children":[],"tail":", §§ 12401(a), 12415(b)(1), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4971"},"text":"132 Stat. 4971","children":[],"tail":", 4981.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefef5a60-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefef5a61-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefef5a62-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12401/a"},"text":"Pub. L. 115–334, § 12401(a)","children":[],"tail":", substituted “Relations and Intergovernmental Affairs” for “Relations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12415/b/1"},"text":"Pub. L. 115–334, § 12415(b)(1)","children":[],"tail":", amended this section, as in effect on the day before the effective date of the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/a/1"},"text":"section 2(a)(1) of Pub. L. 112–166","children":[],"tail":", by redesignating subsec. (d) as (c) and striking out former subsec. (c). Prior to amendment, text of subsec. (c) read as follows: “Any official who is serving as Assistant Secretary of Agriculture for Administration or Assistant Secretary of Agriculture for Congressional Relations on "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":", and who was appointed as such Assistant Secretary by the President, by and with the advice and consent of the Senate, shall not be required to be reappointed under subsection (b) of this section to the successor position authorized under subsection (a) of this section if the Secretary establishes the position, and the official occupies the new position, within 180 days after "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":" (or such later date set by the Secretary if litigation delays rapid succession).” See 2012 Amendment note and Effective Date of 2012 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/a/1/A"},"text":"Pub. L. 112–166, § 2(a)(1)(A)","children":[],"tail":", substituted “paragraph (1) or (3) of subsection (a)” for “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166/s2/a/1/B"},"text":"Pub. L. 112–166, § 2(a)(1)(B)","children":[],"tail":", (C), which directed that subsec. (b) be amended by striking out subsec. (c) and redesignating subsec. (d) as (c), was executed by making the amendment to the entire section, striking out subsec. (c) and redesignating subsec. (d) as (c), to reflect the probable intent of Congress. Prior to amendment, text of subsec. (c) read as follows: “Any official who is serving as Assistant Secretary of Agriculture for Administration or Assistant Secretary of Agriculture for Congressional Relations on "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":", and who was appointed as such Assistant Secretary by the President, by and with the advice and consent of the Senate, shall not be required to be reappointed under subsection (b) of this section to the successor position authorized under subsection (a) of this section if the Secretary establishes the position, and the official occupies the new position, within 180 days after "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":" (or such later date set by the Secretary if litigation delays rapid succession).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s10704/a/1"},"text":"Pub. L. 107–171, § 10704(a)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s10704/a/2"},"text":"Pub. L. 107–171, § 10704(a)(2)","children":[],"tail":", added subsec. (d) and struck out former subsecs. (d) and (e), which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of Title 5","children":[],"tail":", Government Organization and Employees, and "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3128"},"text":"section 3128 of this title","children":[],"tail":" and repealed sections 2212 to 2212c of this title and section 2 of Reorg. Plan No. 2 of 1953, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" inserted “and” at end of par. (1), substituted a period for “; and” at end of par. (2), and struck out par. (3) which read as follows: “Assistant Secretary of Agriculture for Marketing and Regulatory Programs.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideff1a353-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideff1a354-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12415/b/2"},"text":"Pub. L. 115–334, title XII, § 12415(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4981"},"text":"132 Stat. 4981","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tXII/s12415/b/2"},"text":"“The amendments made by paragraph (1) [amending this section] take effect on the effective date described in section 6(a) of the Presidential Appointment Efficiency and Streamlining Act of 2011 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Public Law 112–166","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/126/1295"},"text":"126 Stat. 1295","children":[],"tail":") [see Effective Date of 2012 Amendment note below].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideff1a355-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/166"},"text":"Pub. L. 112–166","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2012-08-10"},"text":"Aug. 10, 2012","children":[],"tail":", and applicable to appointments made on and after that effective date, including any nomination pending in the Senate on that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/166/s6/a"},"text":"section 6(a) of Pub. L. 112–166","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s113"},"text":"section 113 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideff1a356-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Succession of Assistant Secretary of Agriculture for Congressional Relations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12401/b"},"text":"Pub. L. 115–334, title XII, § 12401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4971"},"text":"132 Stat. 4971","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tXII/s12401/b"},"text":"“Any official who is serving as the Assistant Secretary of Agriculture for Congressional Relations on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":"] and who was appointed by the President, by and with the advice and consent of the Senate, shall not be required to be reappointed as a result of the change made to the name of that position under the amendment made by subsection (a) [amending this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
