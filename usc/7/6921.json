{"tag":"section","attrib":{"id":"ideff1a397-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921"},"text":null,"children":[{"tag":"num","attrib":{"value":"6921"},"text":"§ 6921.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Tribal Relations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff1a398-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall maintain in the Office of the Secretary an Office of Tribal Relations, which shall advise the Secretary on policies related to Indian tribes and carry out such other functions as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a399-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal Advisory Committee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a39a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a39b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a39c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevant committees of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “relevant committees of Congress” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a39d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a39e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a39f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Indian Affairs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal organization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tribal organization” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a3a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of committee","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a3a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an advisory committee, to be known as the Tribal Advisory Committee (referred to in this subsection as the “Committee”) to provide advice and guidance to the Secretary on matters relating to Tribal and Indian affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facilitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall facilitate, but not supplant, government-to-government consultation between the Department of Agriculture (referred to in this subsection as the “Department”) and Indian tribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a3a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a3a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall be composed of 11 members, of whom—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a3a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 shall be appointed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the chairperson of the Committee on Indian Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the ranking member of the Committee on Indian Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the chairperson of the Committee on Agriculture, Nutrition, and Forestry of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be appointed by the ranking member of the Committee on Agriculture, Nutrition, and Forestry of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall be appointed by the chairperson of the Committee on Agriculture of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 shall be appointed by the ranking member of the Committee on Agriculture of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nominations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall accept nominations for members of the Committee from any of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a3ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A tribal organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A national or regional organization with expertise in issues relating to the duties of the Committee described in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent feasible, the Secretary shall ensure that the members of the Committee represent a diverse set of expertise on issues relating to geographic regions, Indian tribes, and the agricultural industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No member of the Committee shall be an officer or employee of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of appointment; vacancies","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a3b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each member of the Committee—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideff1a3b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/E/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to clause (ii), shall be appointed to a 3-year term; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideff1a3b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/E/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be reappointed to not more than 3 consecutive terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial staggering","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The first 3 appointments by the Secretary under paragraph (3)(A)(i) shall be for a 2-year term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any vacancy in the Committee shall be filled in the same manner as the original appointment not more than 90 days after the date on which the position becomes vacant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a3ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Committee shall meet in person not less than twice each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Tribal Relations representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not fewer than 1 representative from the Office of Tribal Relations of the Department shall be present at each meeting of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Interior representative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary for Indian Affairs of the Department of the Interior (or a designee) shall be present at each meeting of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/3/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonvoting representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The individuals described in clauses (ii) and (iii) shall be nonvoting representatives at meetings of the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a3be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Committee","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a3bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify evolving issues of relevance to Indian tribes relating to programs of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicate to the Secretary the issues identified under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Secretary recommendations for, and solutions to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a3c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issues identified under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issues raised at the Tribal, regional, or national level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issues relating to any Tribal consultation carried out by the Department;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discuss issues and proposals for changes to the regulations, policies, and procedures of the Department that impact Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify priorities and provide advice on appropriate strategies for Tribal consultation on issues at the Tribal, regional, or national level regarding the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that pertinent issues of the Department are brought to the attention of an Indian tribe in a timely manner so that timely feedback from an Indian tribe can be obtained; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and propose solutions to any interdepartmental barrier between the Department and other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a3c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff1a3ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than once each year, the Committee shall submit to the Secretary and the relevant committees of Congress a report that describes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a3cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities of the Committee during the previous year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for legislative or administrative action for the following year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff1a3cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response from Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not more than 45 days after the date on which the Secretary receives a report under subparagraph (A), the Secretary shall submit a written response to that report to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff1a3ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff1a3cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevant committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a3d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Members of the Committee shall be compensated at a rate equal to the daily equivalent of the annual rate of basic pay prescribed for level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":" for each day (including travel time) during which the member is engaged in the performance of the duties of the Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a3d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6921/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Advisory Committee Act exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Section 14 of the Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"ref","attrib":{"idref":"fn002318"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002318"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall not apply to the Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff1a3d2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tIII/s309"},"text":"Pub. L. 103–354, title III, § 309","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tXII/s12303"},"text":"Pub. L. 113–79, title XII, § 12303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/985"},"text":"128 Stat. 985","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12303"},"text":"Pub. L. 115–334, title XII, § 12303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4962"},"text":"132 Stat. 4962","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff1a3d3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff1a3d4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideff1a3d5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 14 of the Federal Advisory Committee Act, referred to in subsec. (b)(7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463/s14"},"text":"section 14 of Pub. L. 92–463","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4204"},"text":"136 Stat. 4204","children":[],"tail":", 4361."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideff1a3d6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Federal Crop Insurance Reform and Department of Agriculture Reorganization Act of 1994, and not as part of the Department of Agriculture Reorganization Act of 1994 which in part comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideff1a3d7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
