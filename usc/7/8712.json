{"tag":"section","attrib":{"id":"idf03dee72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8712"},"text":null,"children":[{"tag":"num","attrib":{"value":"8712"},"text":"§ 8712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment yields","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf03dee73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of making direct payments and counter-cyclical payments under this subchapter, the Secretary shall provide for the establishment of a yield for each farm for any designated oilseed or eligible pulse crop for which a payment yield was not established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7912"},"text":"section 7912 of this title","children":[],"tail":" in accordance with this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03dee74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment yields for designated oilseeds and eligible pulse crops","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03dee75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8712/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of average yield","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of designated oilseeds and eligible pulse crops, the Secretary shall determine the average yield per planted acre for the designated oilseed or pulse crop on a farm for the 1998 through 2001 crop years, excluding any crop year in which the acreage planted to the designated oilseed or pulse crop was zero.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8712/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment for payment yield","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03dee77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8712/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The payment yield for a farm for a designated oilseed or eligible pulse crop shall be equal to the product of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03dee78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8712/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average yield for the designated oilseed or pulse crop determined under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03dee79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8712/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The ratio resulting from dividing the national average yield for the designated oilseed or pulse crop for the 1981 through 1985 crops by the national average yield for the designated oilseed or pulse crop for the 1998 through 2001 crops.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03dee7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8712/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No national average yield information available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that national average yield information for a designated oilseed or pulse crop is not available, the Secretary shall use such information as the Secretary determines to be fair and equitable to establish a national average yield under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8712/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of partial county average yield","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the yield per planted acre for a crop of a designated oilseed or pulse crop for a farm for any of the 1998 through 2001 crop years was less than 75 percent of the county yield for that designated oilseed or pulse crop, the Secretary shall assign a yield for that crop year equal to 75 percent of the county yield for the purpose of determining the average under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8712/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No historic yield data available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of establishing yields for designated oilseeds and eligible pulse crops, if historic yield data is not available, the Secretary shall use the ratio for dry peas calculated under paragraph (2)(A)(ii) in determining the yields for designated oilseeds and eligible pulse crops, as determined to be fair and equitable by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf03dee7d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1102"},"text":"Pub. L. 110–234, title I, § 1102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/940"},"text":"122 Stat. 940","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1102, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1669.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf03dee7e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf03dee7f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf03dee80-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf03dee81-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf03dee82-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
