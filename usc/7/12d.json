{"tag":"section","attrib":{"id":"idedd468ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s12d"},"text":null,"children":[{"tag":"num","attrib":{"value":"12d"},"text":"§ 12d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission action for noncompliance with export sales reporting requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Commission may, in accordance with the procedures provided for in this chapter, refuse to register, register conditionally, or suspend, place restrictions upon, or revoke the registration of, any person, and may bar for any period as it deems appropriate any person from using or participating in any manner in any market regulated by the Commission, if such person is subject to a final decision or order of any court of competent jurisdiction or agency of the United States finding such person to have knowingly violated any provision of the export sales reporting requirements of section 612c–3 ","children":[{"tag":"ref","attrib":{"idref":"fn002043"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002043"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, or of any regulation issued thereunder."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idedd468cf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s8d"},"text":"Sept. 21, 1922, ch. 369, § 8d","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/444/tII/s226"},"text":"Pub. L. 97–444, title II, § 226","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-11"},"text":"Jan. 11, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2316"},"text":"96 Stat. 2316","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attr