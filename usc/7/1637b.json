{"tag":"section","attrib":{"id":"ideedf7000-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1637b"},"text":"§ 1637b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory reporting for dairy products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedf7001-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a program of mandatory dairy product information reporting that will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf7002-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide timely, accurate, and reliable market information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7003-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate more informed marketing decisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7004-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote competition in the dairy product manufacturing industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf7005-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf7006-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing the program, the Secretary shall only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf7007-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedf7008-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the conditions described in paragraph (2), require each manufacturer to report to the Secretary information concerning the price, quantity, and moisture content of dairy products sold by the manufacturer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf7009-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modify the format used to provide the information on the day before ","children":[{"tag":"date","attrib":{"date":"2000-11-22"},"text":"November 22, 2000","children":[],"tail":", to ensure that the information can be readily understood by market participants; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf700a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require each manufacturer and other person storing dairy products to report to the Secretary, at a periodic interval determined by the Secretary, information on the quantity of dairy products stored.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf700b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The conditions referred to in paragraph (1)(A)(i) are that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf700c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information referred to in paragraph (1)(A)(i) is required only with respect to those package sizes actually used to establish minimum prices for Class III or Class IV milk under a Federal milk marketing order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf700d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information referred to in paragraph (1)(A)(i) is required only to the extent that the information is actually used to establish minimum prices for Class III or Class IV milk under a Federal milk marketing order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf700e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency of the required reporting under paragraph (1)(A)(i) does not exceed the frequency used to establish minimum prices for Class III or Class IV milk under a Federal milk marketing order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf700f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may exempt from all reporting requirements any manufacturer that processes and markets less than 1,000,000 pounds of dairy products per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf7010-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf7011-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate such regulations as are necessary to ensure compliance with, and otherwise carry out, this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7012-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf7013-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise directed by the Secretary or the Attorney General for enforcement purposes, no officer, employee, or agent of the United States shall make available to the public information, statistics, or documents obtained from or submitted by any person under this subchapter other than in a manner that ensures that confidentiality is preserved regarding the identity of persons, including parties to a contract, and proprietary business information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7014-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no facts or information obtained under this subchapter shall be disclosed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7015-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf7016-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take such actions as the Secretary considers necessary to verify the accuracy of the information submitted or reported under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7017-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall quarterly conduct an audit of information submitted or reported under this subchapter and compare such information with other related dairy market statistics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7018-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf7019-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful and a violation of this subchapter for any person subject to this subchapter to willfully fail or refuse to provide, or delay the timely reporting of, accurate information to the Secretary in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf701a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After providing notice and an opportunity for a hearing to affected persons, the Secretary may issue an order against any person to cease and desist from continuing any violation of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf701b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeal","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedf701c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order of the Secretary under subparagraph (B) shall be final and conclusive unless an affected person files an appeal of the order of the Secretary in United States district court not later than 30 days after the date of the issuance of the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf701d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A finding of the Secretary under this paragraph shall be set aside only if the finding is found to be unsupported by substantial evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf701e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance with order","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedf701f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a person subject to this subchapter fails to obey an order issued under this paragraph after the order has become final and unappealable, or after the appropriate United States district court has entered a final judgment in favor of the Secretary, the United States may apply to the appropriate United States district court for enforcement of the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf7020-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the court determines that the order was lawfully made and duly served and that the person violated the order, the court shall enforce the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf7021-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/4/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the court finds that the person violated the order, the person shall be subject to a civil penalty of not more than $10,000 for each offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7022-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall not charge or assess a user fee, transaction fee, service charge, assessment, reimbursement fee, or any other fee under this subchapter for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf7023-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the submission or reporting of information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7024-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the receipt or availability of, or access to, published reports or information; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf7025-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activity required under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7026-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each person required to report information to the Secretary under this subchapter shall maintain, and make available to the Secretary, on request, original contracts, agreements, receipts, and other records associated with the sale or storage of any dairy products during the 2-year period beginning on the date of the creation of the records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf7027-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf7028-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic reporting system required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an electronic reporting system to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf7029-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3:00 p.m. Eastern Time on the Wednesday of each week, the Secretary shall publish a report containing the information obtained under this section for the preceding week.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf702a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1637b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedf702b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 273, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/532/s2"},"text":"Pub. L. 106–532, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2542"},"text":"114 Stat. 2542","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1510"},"text":"Pub. L. 110–234, title I, § 1510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/999"},"text":"122 Stat. 999","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1510, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1728; "},{"tag":"ref","attrib":{"href":"/us/pl/111/239/s3/a"},"text":"Pub. L. 111–239, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2502"},"text":"124 Stat. 2502","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideedf702c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideedf702d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideedf702e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideedf702f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/239"},"text":"Pub. L. 111–239","children":[],"tail":" amended subsec. (d) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—Subject to the availability of funds under paragraph (3), the Secretary shall establish an electronic reporting system to carry out this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Frequency of reports","children":[],"tail":".—After the establishment of the electronic reporting system in accordance with paragraph (1), the Secretary shall increase the frequency of the reports required under this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) ","children":[{"tag":"inline","attrib":{},"text":"Authorization of appropriations","children":[],"tail":".—There are authorized to be appropriated such sums as are necessary to carry out this subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1510/b"},"text":"Pub. L. 110–246, § 1510(b)","children":[],"tail":", added par. (3) and struck out former par. (3). Prior to amendment, text read as follows: “The Secretary shall take such actions as the Secretary considers necessary to verify the accuracy of the information submitted or reported under this subchapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s1510/a"},"text":"Pub. L. 110–246, § 1510(a)","children":[],"tail":", added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideedf7030-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideedf7031-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideedf7032-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of Electronic Reporting System","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/239/s3/b"},"text":"Pub. L. 111–239, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2502"},"text":"124 Stat. 2502","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/239/s3/b"},"text":"“Not later than one year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2010-09-27"},"text":"Sept. 27, 2010","children":[],"tail":"], the Secretary of Agriculture shall implement the electronic reporting system required by subsection (d) of section 273 of the Agricultural Marketing Act of 1946 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1637b"},"text":"7 U.S.C. 1637b","children":[],"tail":"), as amended by subsection (a). Until the electronic reporting system is implemented, the Secretary shall continue to conduct mandatory dairy product information reporting under the authority of such section, as in effect on the day before the date of enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
