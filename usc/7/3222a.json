,"children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefa30d95-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/d/5/A/i"},"text":"Pub. L. 118–22, § 102(d)(5)(A)(i)","children":[],"tail":", substituted “4 succeeding” for “three succeeding”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/d/5/A/ii"},"text":"Pub. L. 118–22, § 102(d)(5)(A)(ii)","children":[],"tail":", designated existing provisions as subpar. (A), inserted heading, and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
