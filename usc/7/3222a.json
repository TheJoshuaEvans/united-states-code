{"tag":"section","attrib":{"id":"idefa30d78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3222a"},"text":"§ 3222a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarships for students at 1890 Institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa30d79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa30d7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scholarship grant program established","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make grants to each college or university eligible to receive funds under the Act of ","children":[{"tag":"date","attrib":{"date":"1890-08-30"},"text":"August 30, 1890","children":[],"tail":" (commonly known as the Second Morrill Act; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s322"},"text":"7 U.S.C. 322","children":[],"tail":" [321] et seq.), including Tuskegee University, for purposes of awarding scholarships to individuals who—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa30d7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been accepted for admission at such college or university;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa30d7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be enrolled at such college or university not later than one year after the date of such acceptance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa30d7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" intend to pursue a career in the food and agricultural sciences, including a career in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefa30d7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agribusiness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefa30d7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy and renewable fuels; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefa30d80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30d81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may only award a grant under this subsection to a college or university described in paragraph (1) if the Secretary determines that such college or university has established a competitive scholarship awards process for the award of scholarships to individuals described in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30d82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds made available under subsection (b)(1), the Secretary may use not more than $10,000,000 to award grants under this subsection for the academic year beginning on ","children":[{"tag":"date","attrib":{"date":"2020-07-01"},"text":"July 1, 2020","children":[],"tail":", and each of the 4 succeeding academic years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30d83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each grant made under this section shall be in an amount of not less than $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30d84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa30d85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa30d86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall make available to carry out this section $40,000,000 not later than ","children":[{"tag":"date","attrib":{"date":"2019-10-01"},"text":"October 1, 2019","children":[],"tail":", to remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa30d87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2023-11-17"},"text":"November 17, 2023","children":[],"tail":", of the funds of the Commodity Credit Corporation, the Secretary shall make available to carry out this section $10,000,000, to remain available until expended."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa30d88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Further funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall make available to carry out this section $60,000,000 for fiscal year 2026, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30d89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts made available under paragraph (1), there is authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2020 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30d8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Of the funds made available under paragraphs (1) and (2) to carry out this section for a fiscal year, not more than 4 percent may be used for expenses related to administering the program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30d8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning on the date that is two years after the date on which the first grant is awarded under subsection (a), and every two years thereafter, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report detailing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa30d8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds provided to each eligible college or university under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30d8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of scholarships awarded under each grant each fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30d8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of each such scholarship.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa30d8f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1446"},"text":"Pub. L. 95–113, title XIV, § 1446","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7117"},"text":"Pub. L. 115–334, title VII, § 7117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4789"},"text":"132 Stat. 4789","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/dB/tI/s102/d/5/A"},"text":"Pub. L. 118–22, div. B, title I, § 102(d)(5)(A)","children":