{"tag":"section","attrib":{"id":"idee59ec21-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s906a"},"text":null,"children":[{"tag":"num","attrib":{"value":"906a"},"text":"§ 906a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds outside the United States or its territories prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No funds provided under the Rural Electrification Act of 1936, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s901"},"text":"7 U.S.C. 901","children":[],"tail":" et seq.], shall be used outside the United States or any of its territories."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee59ec22-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/32/s10"},"text":"Pub. L. 93–32, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-11"},"text":"May 11, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/71"},"text":"87 Stat. 71","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee59ec23-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee59ec24-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee59ec25-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Rural Electrification Act of 1936, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"act May 20, 1936, ch. 432","children":[],"tail":", "},{"tag":"ref","attrib"