{"tag":"section","attrib":{"id":"idee65d321-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"950bb–6"},"text":"§ 950bb–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal broadband program coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee65d322-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation between USDA and NTIA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Assistant Secretary to assist in the verification of eligibility of the broadband loan and grant programs of the Department of Agriculture. In providing assistance under the preceding sentence, the Assistant Secretary shall make available the broadband assessment and mapping capabilities of the National Telecommunications and Information Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d323-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation between USDA and FCC","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d324-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By USDA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Commission before providing broadband assistance for a project to serve an area with respect to which another entity is receiving Connect America Fund or Mobility Fund support under the Federal universal service support mechanisms established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s254"},"text":"section 254 of title 47","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d325-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" By FCC","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall consult with the Secretary before offering or providing Connect America Fund or Mobility Fund support under the Federal universal service support mechanisms established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s254"},"text":"section 254 of title 47","children":[],"tail":" to serve an area with respect to which another entity has received broadband assistance under a loan or grant program of the Department of Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d326-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary, the Commission, and the Assistant Secretary shall submit to the Committee on Agriculture and the Committee on Energy and Commerce of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry and the Committee on Commerce, Science, and Transportation of the Senate a report on how best to coordinate federally supported broadband programs and activities in order to achieve the following objectives:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d327-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promote high-quality broadband service that meets the long-term needs of rural residents and businesses, by evaluating the broadband service needs in rural areas for each decade through 2050.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d328-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Support the long-term viability, sustainability, and utility of federally supported rural broadband infrastructure, by analyzing the technical capabilities of the technologies currently available and reasonably expected to be available by 2035 to meet the broadband service needs of rural residents identified under paragraph (1), including by analyzing the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d329-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The real-world performance of such technologies, including data rates, latency, data usage restrictions, and other aspects of service quality, as defined by the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d32a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The suitability of each such technology for residential, agricultural, educational, healthcare, commercial, and industrial purposes in rural areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d32b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost to deploy and support such technologies in several rural geographies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d32c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The costs associated with online platforms, specifically the resulting constraints on rural network bandwidth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d32d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Identify and quantify the availability of broadband service and ongoing broadband deployment in rural areas, including ways to do the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d32e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Harmonize broadband notification and reporting requirements and develop common verification procedures across all federally supported broadband programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d32f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consolidate and utilize the existing broadband service data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d330-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Collect and share data on those projects in rural areas where Federal programs are currently supporting broadband deployment, including areas with respect to which an entity is receiving—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee65d331-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support under a broadband assistance program of the Department of Agriculture; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee65d332-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Connect America Fund or Mobility Fund support under the Federal universal service support mechanisms established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s254"},"text":"section 254 of title 47","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d333-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leverage support technologies and services from online platforms for providers of broadband service in rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d334-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d335-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Assistant Secretary” means the Assistant Secretary of Commerce for Communications and Information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d336-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commission” means the Federal Communications Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d337-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–6/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rural area” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s950bb/b/3"},"text":"section 950bb(b)(3) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee65d338-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6212"},"text":"Pub. L. 115–334, title VI, § 6212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4744"},"text":"132 Stat. 4744","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee65d339-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee65d33a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee65d33b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agriculture Improvement Act of 2018, and not as part of the Rural Electrification Act of 1936 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee65d33c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idee65d33d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” means the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2"},"text":"section 2 of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
