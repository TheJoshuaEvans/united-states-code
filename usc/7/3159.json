{"tag":"section","attrib":{"id":"idef9be2a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3159"},"text":null,"children":[{"tag":"num","attrib":{"value":"3159"},"text":"§ 3159.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land-grant designation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9be2a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3159/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on designation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9be2a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3159/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law and except as provided in paragraphs (2) and (3), beginning on ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", no additional entity may be designated as eligible to receive funds under a covered program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9be2a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3159/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1994 institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prohibition under paragraph (1) with respect to the designation of an entity eligible to receive funds under a covered program shall not apply in the case of the certification of a 1994 Institution under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/788/s2"},"text":"section 2 of Public Law 87–788","children":[],"tail":" (commonly known as the “McIntire-Stennis Cooperative Forestry Act”) ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s582a–1"},"text":"16 U.S.C. 582a–1","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9be2a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3159/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extraordinary circumstances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of extraordinary circumstances or a situation that would lead to an inequitable result, as determined by the Secretary, the Secretary may determine that an entity designated after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", is eligible to receive funds under a covered program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9be2a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3159/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State shall receive an increase in funding under a covered program as a result of the State’s designation of additional entities as eligible to receive such funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9be2a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3159/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered program defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “covered program” means agricultural research, extension, education, and related programs or grants established or available under any of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9be2a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3159/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (b), (c), and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s343"},"text":"section 343 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9be2a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3159/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Hatch Act of 1887 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s361a"},"text":"7 U.S.C. 361a","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9be2aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3159/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 3221, 3222, and 3222b of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9be2ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3159/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/788"},"text":"Public Law 87–788","children":[],"tail":" (commonly known as the McIntire-Stennis Cooperative Forestry Act; "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s582a"},"text":"16 U.S.C. 582a","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail"