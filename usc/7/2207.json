{"tag":"section","attrib":{"id":"idef75bc88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207"},"text":null,"children":[{"tag":"num","attrib":{"value":"2207"},"text":"§ 2207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall annually make a general report in writing of his acts to the President, in which he may recommend the publication of papers forming parts of or accompanying his report. He shall also make special reports on particular subjects whenever required to do so by the President or either House of Congress, or when he shall think the subject in his charge requires it.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef75bc89-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(R.S. §§ 528, 529; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1889-02-09/ch122"},"text":"Feb. 9, 1889, ch. 122","children":[],"tail":", §§ 1, 4, "},{"tag":"ref","attrib":{"href":"/us/stat/25/659"},"text":"25 Stat. 659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1928-05-29/ch901/s1/101"},"text":"May 29, 1928, ch. 901, § 1(101)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/993"},"text":"45 Stat. 993","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1076/s1/6"},"text":"Aug. 30, 1954, ch. 1076, § 1(6)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/966"},"text":"68 Stat. 966","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef75bc8a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef75bc8b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef75bc8c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. §§ 528 and 529 derived from the following acts: ","children":[{"tag":"ref","attrib":{"href":"/us/act/1862-05-15/ch72/s3"},"text":"May 15, 1862, ch. 72, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/387"},"text":"12 Stat. 387","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1867-03-02"},"text":"Mar. 2, 1867","children":[],"tail":", § 1, "},{"tag":"ref","attrib":{"href":"/us/stat/14/440"},"text":"14 Stat. 440","children":[],"tail":", 445."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s557"},"text":"section 557 of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef75bc8d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-08-30"},"text":"Aug. 30, 1954","children":[],"tail":", struck out provision in first sentence which required that the annual report should contain an account of all moneys received and expended by the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1928—Act ","children":[{"tag":"date","attrib":{"date":"1928-05-29"},"text":"May 29, 1928","children":[],"tail":", struck out requirement that there be included a statement of expenditures from contingent appropriations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef75bc8e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idef75bc8f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary of Agriculture” substituted in text for “Commissioner of Agriculture” pursuant to sections 1 and 4 of act ","children":[{"tag":"date","attrib":{"date":"1889-02-09"},"text":"Feb. 9, 1889","children":[],"tail":", which are classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2202"},"text":"section 2202 of this title","children":[],"tail":". See, also, "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2205"},"text":"section 2205 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef75bc90-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Unavailability of Department Funds To Produce Part 2 of Annual Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/111/tI"},"text":"Pub. L. 103–111, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-21"},"text":"Oct. 21, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1048"},"text":"107 Stat. 1048","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/111/tI"},"text":"“That hereafter, none of the funds available to the Department of Agriculture may be used to produce part 2 of the annual report of the Secretary (known as the Yearbook of Agriculture).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idef75bc91-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idef75bc92-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of all officers, agencies, and employees of Department of Agriculture transferred, with certain exceptions, to Secretary of Agriculture by 1953 Reorg. Plan No. 2, § 1, eff. ","children":[{"tag":"date","attrib":{"date":"1953-06-04"},"text":"June 4, 1953","children":[],"tail":", 18 F.R. 3219, "},{"tag":"ref","attrib":{"href":"/us/stat/67/633"},"text":"67 Stat. 633","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
