{"tag":"section","attrib":{"id":"ideee1e179-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r"},"text":null,"children":[{"tag":"num","attrib":{"value":"1639r"},"text":"§ 1639r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and guidelines; effect on other law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideee1e17a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of regulations and guidelines; report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e17b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations and guidelines","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e17c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations and guidelines to implement this subchapter as expeditiously as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e17d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Attorney General on the promulgation of regulations and guidelines under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e17e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall annually submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report containing updates on the implementation of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e17f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (c)(3)(B), the Secretary shall have sole authority to promulgate Federal regulations and guidelines that relate to the production of hemp, including Federal regulations and guidelines that relate to the implementation of sections 1639p and 1639q of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e180-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other law","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall affect or modify—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e181-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e182-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e183-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the authority of the Commissioner of Food and Drugs and the Secretary of Health and Human Services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e184-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee1e185-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Food, Drug, and Cosmetic Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e186-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s262"},"text":"section 262 of title 42","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e187-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639r/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promulgate Federal regulations and guidelines that relate to the production of hemp under the Act described in subparagraph (A)(i) or the section described in subparagraph (A)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideee1e188-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 297D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10113"},"text":"Pub. L. 115–334, title X, § 10113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4913"},"text":"132 Stat. 4913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideee1e189-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideee1e18a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideee1e18b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Food, Drug, and Cosmetic Act, referred to in subsec. (c)(1), (3)(A)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1040"},"text":"52 Stat. 1040","children":[],"tail":", which is classified generally to chapter 9 (§ 301 et seq.) of Title 21, Food and Drugs. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
