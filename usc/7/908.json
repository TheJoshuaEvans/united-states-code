{"tag":"section","attrib":{"id":"idee59ec2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s908"},"text":null,"children":[{"tag":"num","attrib":{"value":"908"},"text":"§ 908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use of assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee59ec2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsections (b) and (c) of this section, the Secretary may allow a recipient of a grant, loan, or loan guarantee under this subchapter to set aside not more than 10 percent of the amount so received to provide retail broadband service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee59ec30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A recipient who sets aside funds under subsection (a) of this section may use the funds only in an area that is not being provided with the minimum acceptable level of broadband service established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s950bb/e"},"text":"section 950bb(e) of this title","children":[],"tail":", unless the recipient meets the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s950bb/d"},"text":"section 950bb(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee59ec31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed to limit the ability of any borrower to finance or deploy services authorized under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee59ec32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s908/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall not provide funding under subsection (a) if the funding would result in competitive harm to any grant, loan, or loan guarantee referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee59ec33-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title I, § 8, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6210/b"},"text":"Pub. L. 115–334, title VI, § 6210(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4744"},"text":"132 Stat. 4744","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee59ec34-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee59ec35-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee59ec36-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 908, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title I, § 8, "},{"tag":"ref","attrib":{"href":"/us/stat/49/1366"},"text":"49 Stat. 1366","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch776/s2"},"text":"Oct. 28, 1949, ch. 776, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/948"},"text":"63 Stat. 948","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/4"},"text":"Pub. L. 103–354, title II, § 235(a)(4)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":", related to transfer of functions of Rural Electrification Administration created by Executive Order No. 7037, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s776"},"text":"Pub. L. 104–127, title VII, § 776","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1150"},"text":"110 Stat. 1150","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
