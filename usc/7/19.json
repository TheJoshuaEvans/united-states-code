{"tag":"section","attrib":{"id":"ideddb94ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"§ 19.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of costs and benefits and antitrust laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideddb94ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s19/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs and benefits","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideddb94ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s19/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before promulgating a regulation under this chapter or issuing an order (except as provided in paragraph (3)), the Commission shall consider the costs and benefits of the action of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideddb94ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s19/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The costs and benefits of the proposed Commission action shall be evaluated in light of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideddb94f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s19/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considerations of protection of market participants and the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideddb94f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s19/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considerations of the efficiency, competitiveness, and financial integrity of futures markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideddb94f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s19/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considerations of price discovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideddb94f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s19/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considerations of sound risk management practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideddb94f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s19/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other public interest considerations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideddb94f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s19/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection does not apply to the following actions of the Commission:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideddb94f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s19/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An order that initiates, is part of, or is the result of an adjudicatory or investigative process of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideddb94f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s19/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An emergency action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideddb94f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s19/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A finding of fact regarding compliance with a requirement of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideddb94f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s19/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall take into consideration the public interest to be protected by the antitrust laws and endeavor to take the least anticompetitive means of achieving the objectives of this chapter, as well as the policies and purposes of this chapter, in issuing any order or adopting any Commission rule or regulation (including any exemption under section 6(c) or 6c(b) of this title), or in requiring or approving any bylaw, rule, or regulation of a contract market or registered futures association established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s21"},"text":"section 21 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideddb94fa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s15"},"text":"Sept. 21, 1922, ch. 369, § 15","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/463/tI/s107"},"text":"Pub. L. 93–463, title I, § 107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-23"},"text":"Oct. 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1395"},"text":"88 Stat. 1395","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/546/tV/s502/b"},"text":"Pub. L. 102–546, title V, § 502(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3631"},"text":"106 Stat. 3631","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s119"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 119]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–403.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideddb94fb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideddb94fc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideddb94fd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" inserted section catchline, added subsec. (a), designated existing provisions as subsec. (b), and inserted subsec. (b) heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/546"},"text":"Pub. L. 102–546","children":[],"tail":" substituted “regulation (including any exemption under section 6(c) or 6c(b) of this title)” for “regulation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideddb94fe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideddb94ff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/463/s418"},"text":"section 418 of Pub. L. 93–463","children":[],"tail":", set out as an Effective Date of 1974 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
