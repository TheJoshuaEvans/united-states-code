{"tag":"section","attrib":{"id":"idef8d8a6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2711"},"text":null,"children":[{"tag":"num","attrib":{"value":"2711"},"text":"§ 2711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempted egg producers and breeding hen flocks; conditions and procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8d8a6e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following shall be exempt from the specific provisions of this chapter under such conditions and procedures as may be prescribed in the order or rules and regulations issued thereunder:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8d8a6f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2711/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any egg producer whose aggregate number of laying hens at any time during a 3-consecutive-month period immediately prior to the date assessments are due and payable has not exceeded 75,000 laying hens, as determined under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8a70-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2711/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any flock of breeding hens whose production of eggs is primarily utilized for the hatching of baby chicks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8d8a71-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of laying hens","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8d8a72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2711/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a)(1), the aggregate number of laying hens owned by an egg producer shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8d8a73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2711/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cases in which the producer is an individual, laying hens owned by such producer or members of such producer’s family that are effectively under the control of such producer, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8a74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2711/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cases in which the producer is a general partnership or similar entity, laying hens owned by the entity and all partners or equity participants in the entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8a75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2711/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cases in which the producer holds 50 percent or more of the stock or other beneficial interest in a corporation, joint stock company, association, cooperative, limited partnership, or other similar entity, laying hens owned by the entity.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Ownership of laying hens by a trust or similar entity shall be considered ownership by the beneficiaries of the trust or other entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8d8a76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2711/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stock or beneficial interests","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1)(C), stock or other beneficial interest in an entity that is held by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef8d8a77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2711/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the producer’s family described in paragraph (1)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8a78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2711/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general partnership or similar entity in which the producer is a partner or equity participant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8a79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2711/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the partners or equity participants in an entity of the type described in subparagraph (B); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef8d8a7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2711/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation, joint stock company, association, cooperative, limited partnership, or other similar entity in which the producer holds 50 percent or more of the stock or other beneficial interests,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be considered as held by the producer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8d8a7b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/428/s12"},"text":"Pub. L. 93–428, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-01"},"text":"Oct. 1, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1176"},"text":"88 Stat. 1176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/220/s3/a"},"text":"Pub. L. 101–220, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1877"},"text":"103 Stat. 1877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/188/s4"},"text":"Pub. L. 103–188, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2257"},"text":"107 Stat. 2257","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8d8a7c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef8d8a7d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef8d8a7e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/188"},"text":"Pub. L. 103–188","children":[],"tail":" substituted “75,000” for “30,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/220"},"text":"Pub. L. 101–220","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The following may be exempt from specific provisions of this chapter under such conditions and procedures as may be prescribed in the order or rules and regulations issued thereunder:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) Any egg producer whose aggregate number of laying hens at any time during a three-consecutive-month period immediately prior to the date assessments are due and payable has not exceeded three thousand laying hens.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) Any flock of breeding hens whose production of eggs is primarily utilized for the hatching of baby chicks.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef8d8a7f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef8d8a80-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Egg Promotion and Research Order","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/220/s3/b"},"text":"Pub. L. 101–220, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1878"},"text":"103 Stat. 1878","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/220/s3/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amendment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Agriculture shall issue an amendment to the egg promotion and research order issued under the Egg Research and Consumer Information Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2701"},"text":"7 U.S.C. 2701","children":[],"tail":" et seq.) to implement the amendments made by this section [amending this section]. Such amendment shall be issued after public notice and opportunity for comment in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", United States Code, and without regard to sections 556 and 557 of such title. The Secretary shall issue a proposed amendment to such order not later than 30 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1989-12-12"},"text":"Dec. 12, 1989","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment to the egg promotion and research order required by paragraph (1) shall become effective no later than ","children":[{"tag":"date","attrib":{"date":"1990-03-01"},"text":"March 1, 1990","children":[],"tail":", and shall not be subject to a referendum under the Egg Research and Consumer Information Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2701"},"text":"7 U.S.C. 2701","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
