{"tag":"section","attrib":{"id":"ideff8cf96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7007"},"text":null,"children":[{"tag":"num","attrib":{"value":"7007"},"text":"§ 7007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary of Agriculture for Trade and Foreign Agricultural Affairs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff8cf97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Department the position of Under Secretary of Agriculture for Trade and Foreign Agricultural Affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cf98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary of Agriculture for Trade and Foreign Agricultural Affairs shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cf99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7007/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff8cf9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7007/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall delegate to the Under Secretary of Agriculture for Trade and Foreign Agricultural Affairs those functions and duties under the jurisdiction of the Department that are related to trade and foreign agricultural affairs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cf9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7007/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary of Agriculture for Trade and Foreign Agricultural Affairs shall perform such other functions and duties as may be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff8cf9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7007/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required by law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cf9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7007/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff8cf9e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s287"},"text":"Pub. L. 103–354, title II, § 287","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12413/2"},"text":"Pub. L. 115–334, title XII, § 12413(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4980"},"text":"132 Stat. 4980","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
