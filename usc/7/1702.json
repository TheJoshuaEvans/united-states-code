{"tag":"section","attrib":{"id":"ideee45214-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1702"},"text":null,"children":[{"tag":"num","attrib":{"value":"1702"},"text":"§ 1702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements regarding eligible countries and private entities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideee45215-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting agreements to be entered into under this subchapter, the Secretary shall give priority to agreements providing for the export of agricultural commodities to developing countries that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee45216-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are undertaking measures for economic development purposes to improve food security and agricultural development, alleviate poverty, and promote broad-based equitable and sustainable development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee45217-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate the greatest need for food.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee45218-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agreement entered into under this subchapter with a private entity shall require such security, or such other provisions as the Secretary determines necessary, to provide reasonable and adequate assurance of repayment of the financing extended to the private entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideee45219-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title I, § 102, "},{"tag":"ref","attrib":{"href":"/us/stat/68/455"},"text":"68 Stat. 455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-04-25/ch27"},"text":"Apr. 25, 1955, ch. 27","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/44"},"text":"69 Stat. 44","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/88/638/s1/3"},"text":"Pub. L. 88–638, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1964-10-08"},"text":"Oct. 8, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/1035"},"text":"78 Stat. 1035","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s2/B"},"text":"Pub. L. 89–808, § 2(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-11-11"},"text":"Nov. 11, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/1526"},"text":"80 Stat. 1526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/436/s9"},"text":"Pub. L. 90–436, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-07-29"},"text":"July 29, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/451"},"text":"82 Stat. 451","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/88/tII/s201/a"},"text":"Pub. L. 95–88, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/545"},"text":"91 Stat. 545","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXII/s1201"},"text":"Pub. L. 95–113, title XII, § 1201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/955"},"text":"91 Stat. 955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3634"},"text":"104 Stat. 3634","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s203"},"text":"Pub. L. 104–127, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/951"},"text":"110 Stat. 951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3005"},"text":"Pub. L. 110–246, title III, § 3005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1822"},"text":"122 Stat. 1822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideee69c0a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideee69c0b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideee69c0c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3005/1"},"text":"Pub. L. 110–246, § 3005(1)","children":[],"tail":", redesignated pars. (2) and (3) as (1) and (2), respectively, and struck out former par. (1) which read as follows: “have the demonstrated potential to become commercial markets for competitively priced United States agricultural commodities;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s3005/2"},"text":"Pub. L. 110–246, § 3005(2)","children":[],"tail":", struck out subsec. (c) which related to agricultural market development plan pursuant to which a developing country could demonstrate potential to become a commercial market for competitively priced United States agricultural commodities for the purpose of being granted a priority under former subsec. (a)(1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" amended section generally, substituting present provisions for provisions outlining eligibility of developing countries for assistance under this subchapter and factors in determining priority for assistance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section generally, substituting present provisions for provisions authorizing Commodity Credit Corporation to finance sales from its own and private stocks, and allowing it, upon request, to serve as purchasing and/or shipping agent."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113"},"text":"Pub. L. 95–113","children":[],"tail":" inserted provisions authorizing the Corporation, when requested by the purchaser of commodities, to serve as the purchasing or shipping agent, or both, in arranging the purchasing or shipping of the commodities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88"},"text":"Pub. L. 95–88","children":[],"tail":" struck out proviso prohibiting the financing by the Commodity Credit Corporation of the sale and export of agricultural commodities where the exporter had engaged in any sales, trade, or commerce with North Vietnam, or with any resident thereof, or which owned or controlled any company so engaged either directly or indirectly, and struck out an additional proviso requiring that financing applications be accompanied by statements in which were listed the branches, etc., in which the applicant had a controlling interest and the companies which had a controlling interest in the applicant company."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/436"},"text":"Pub. L. 90–436","children":[],"tail":" inserted proviso that the Commodity Credit Corporation should not finance the sale and export of any agricultural commodities where the exporter has engaged in any sales, trade or commerce with North Vietnam, or with any resident thereof, or which owns or controls any company so engaged, or which is owned or controlled by any company or person so engaged either directly or indirectly, and the further proviso that the financing application be accompanied by a statement in which are listed the branches, etc., in which the applicant has a controlling interest and the companies which have a controlling interest in the applicant company."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/808"},"text":"Pub. L. 89–808","children":[],"tail":" incorporated provisions formerly constituting subsec. (a)(2), and struck out other provisions of subsec. (a) and (a)(1) relating to availability of stocks acquired in price support operations and ocean freight charges, such charges now covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1708"},"text":"section 1708 of this title","children":[],"tail":", and subsec. (b) for letters of commitment against funds or guaranties and establishment of accounts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1964—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/638"},"text":"Pub. L. 88–638","children":[],"tail":" authorized Commodity Credit Corporation to finance ocean freight charges incurred under agreements entered into after "},{"tag":"date","attrib":{"date":"1964-12-31"},"text":"Dec. 31, 1964","children":[],"tail":", to extent such charges are higher because of requirement that commodities be shipped in United States flag vessels, and provided that such agreements require balance of such charges to be paid in dollars."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1955—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1955-04-25"},"text":"Apr. 25, 1955","children":[],"tail":", struck out requirement that exporters of privately owned stocks acquire an equivalent quantity of Commodity Credit Corporation stocks."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideee69c0d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideee69c0e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideee69c0f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"Jan. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1513"},"text":"section 1513 of Pub. L. 101–624","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideee69c10-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113"},"text":"Pub. L. 95–113","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/88/tII/s215"},"text":"Pub. L. 95–88, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-03"},"text":"Aug. 3, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/552"},"text":"91 Stat. 552","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/88/tII/s215"},"text":"“The provisions of this title [enacting sections 1712 to 1714 and 1727 to 1727f of this title, amending this section and sections 1427, 1431, 1692, 1703, 1706, 1711, 1721, 1722, 1723, 1726, 1731, and 1736b of this title, and enacting provisions set out as notes under sections 1708 and 1722 of this title] shall become effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideee69c11-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/808"},"text":"Pub. L. 89–808","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1967-01-01"},"text":"Jan. 1, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/89/808/s5"},"text":"section 5 of Pub. L. 89–808","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
