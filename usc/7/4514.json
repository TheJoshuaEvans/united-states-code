{"tag":"section","attrib":{"id":"idefb86ada-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4514"},"text":null,"children":[{"tag":"num","attrib":{"value":"4514"},"text":"§ 4514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dairy reports","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall submit to the House Committee on Agriculture and the Senate Committee on Agriculture, Nutrition, and Forestry the following reports:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefb86adb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4514/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1984-07-01"},"text":"July 1, 1984","children":[],"tail":", a report on the effect of applying, nationally, standards similar to the current California standards for fluid milk products in their final consumer form, as they would relate to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefb86adc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4514/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumer acceptance, overall consumer consumption trends, and total per capita consumption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefb86add-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4514/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nutritional augmentation, particularly for young and older Americans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefb86ade-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4514/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing improved interagency enforcement of minimum standards to prevent consumer fraud and deception;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefb86adf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4514/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiple component pricing for producer milk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefb86ae0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4514/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduced Commodity Credit Corporation purchases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefb86ae1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4514/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistency of product quality throughout the year and between marketing regions of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefb86ae2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4514/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumer prices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb86ae3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4514/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":", a report on (A) recommendations for changes in the application of the parity formula to milk so as to make the formula more consistent with modern production methods and with special attention to the cost of producing milk as a result of changes in productivity, and (B) the feasibility of imposing a limitation on the total amount of payments and other assistance a producer of milk may receive during a year under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1446/d"},"text":"section 1446(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb86ae4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4514/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1985-04-15"},"text":"April 15, 1985","children":[],"tail":", a report on the effectiveness of the paid diversion program carried out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1446/d"},"text":"section 1446(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefb86ae5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4514/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1985-07-01"},"text":"July 1, 1985","children":[],"tail":", and July 1 of each year after the date of enactment of this title,"},{"tag":"ref","attrib":{"idref":"fn002288"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002288"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" an annual report describing activities conducted under the dairy products promotion and research order issued under subtitle B of title I of this Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4501"},"text":"7 U.S.C. 4501","children":[],"tail":" et seq.], and accounting for the receipt and disbursement of all funds received by the National Dairy Promotion and Research Board under such order including an independent analysis of the effectiveness of the program."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb86ae6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/180/tIII/s301"},"text":"Pub. L. 98–180, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-29"},"text":"Nov. 29, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1150"},"text":"97 Stat. 1150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb86ae7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefb86ae8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefb86ae9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this title, referred to in par. (4), means the date of enactment of title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/180"},"text":"Pub. L. 98–180","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1983-11-29"},"text":"Nov. 29, 1983","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subtitle B of title I of this Act, referred to in par. (4), is subtitle B (§§ 110–122) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/180"},"text":"Pub. L. 98–180","children":[],"tail":", which is classified generally to this subchapter. For complete classification of subtitle B to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefb86aea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/180"},"text":"Pub. L. 98–180","children":[],"tail":", known as the Dairy and Tobacco Adjustment Act of 1983, and not as part of title I of "},{"tag":"ref","attrib":{"href":"/us/pl/98/180"},"text":"Pub. L. 98–180","children":[],"tail":", known as the Dairy Production Stabilization Act of 1983, subtitle B of which comprises this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
