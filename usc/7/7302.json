{"tag":"section","attrib":{"id":"idf004b5d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7302"},"text":null,"children":[{"tag":"num","attrib":{"value":"7302"},"text":"§ 7302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of chapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf004b5d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on prior crops","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided in this chapter and notwithstanding any other provision of law, this chapter and the amendments made by this chapter shall not affect the authority of the Secretary to carry out a price support or production adjustment program for any of the 1991 through 1995 crops of an agricultural commodity established under a provision of law in effect immediately before ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b5da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A provision of this chapter or an amendment made by this chapter shall not affect the liability of any person under any provision of law as in effect before ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf004b5db-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s172"},"text":"Pub. L. 104–127, title I, § 172","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/938"},"text":"110 Stat. 938","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf004b5dc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf004b5dd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf004b5de-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in text, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7201"},"text":"section 7201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
