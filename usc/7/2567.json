{"tag":"section","attrib":{"id":"idef865e6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2567"},"text":null,"children":[{"tag":"num","attrib":{"value":"2567"},"text":"§ 2567.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of damages; marking and notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Owners may give notice to the public by physically associating with or affixing to the container of seed of a variety or by fixing to the variety, a label containing either the words “Unauthorized Propagation Prohibited” or the words “Unauthorized Seed Multiplication Prohibited” and after the certificate issues, such additional words as “U.S. Protected Variety”. In the event the variety is distributed by authorization of the owner and is received by the infringer without such marking, no damages shall be recovered against such infringer by the owner in any action for infringement, unless the infringer has actual notice or knowledge that propagation is prohibited or that the variety is a protected variety, in which event damages may be recovered only for infringement occurring after such notice. As to both damages and injunction, a court shall have discretion to be lenient as to disposal of materials acquired in good faith by acts prior to such notice.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef865e6e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tIII/s127"},"text":"Pub. L. 91–577, title III, § 127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1557"},"text":"84 Stat. 1557","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/574/s19/b"},"text":"Pub. L. 96–574, § 19(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3351"},"text":"94 Stat. 3351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s11"},"text":"Pub. L. 103–349, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3142"},"text":"108 Stat. 3142","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef865e6f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef865e70-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef865e71-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/349"},"text":"Pub. L. 103–349","children":[],"tail":" in first sentence struck out “novel” before “variety or” and before “variety, a”, and in second sentence struck out “novel” before “variety is distributed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/574"},"text":"Pub. L. 96–574","children":[],"tail":" substituted “either the words ‘Unauthorized Propagation Prohibited’ or the words ‘Unauthorized Seed Multiplication Prohibited’ ” for “the words ‘Propagation Prohibited’ ”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef865e72-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef865e73-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/349"},"text":"Pub. L. 103–349","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s15"},"text":"section 15 of Pub. L. 103–349","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2401"},"text":"section 2401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
