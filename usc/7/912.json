{"tag":"section","attrib":{"id":"idee59ec48-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912"},"text":null,"children":[{"tag":"num","attrib":{"value":"912"},"text":"§ 912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of time for repayment of loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee59ec49-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized and empowered to extend the time of payment of interest or principal of any loans made by the Secretary pursuant to this chapter, except that, with respect to any loan made under section 904 or 922 of this title, the payment of interest or principal shall not be extended more than five years after such payment shall have become due.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee59ec4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of deferment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee59ec4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to limitations established in appropriations Acts, the Secretary shall permit any borrower to defer the payment of principal and interest on any insured or direct loan made under this chapter under circumstances described in this subsection, notwithstanding any limitation contained in subsection (a), except that such deferment shall not be permitted based on the determination of the Secretary of the financial hardship of the borrower.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ec4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee59ec4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of deferments made to enable the borrower to provide financing to local businesses, the deferment shall be repaid in equal installments, without the accrual of interest, over the 60-month period beginning on the date of the deferment, and the total amount of such payments shall be equal to the amount of the payment deferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee59ec4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of deferments made to enable the borrower to provide community development assistance, technical assistance to businesses, and for other community, business, or economic development projects not included under subparagraph (A), the deferment shall be repaid in equal installments, without the accrual of interest, over the 120-month period beginning on the date of the deferment, and the total amount of such payments shall be equal to the amount of the payment deferred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ec4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee59ec50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A borrower may defer its debt service payments only in an amount equal to an investment made by such borrower as described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee59ec51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the deferment shall not exceed 50 percent of the total cost of a community or economic development project for which a deferment is provided under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee59ec52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount of deferments under this subsection during each of the fiscal years 1990 through 1993 shall not exceed 3 percent of the total payments due during such fiscal year from all borrowers on direct and insured loans made under this chapter and shall not exceed 5 percent of such total payments due in each subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee59ec53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the time of a deferment, the borrower shall make a payment to a cushion of credit account established and maintained pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s940c"},"text":"section 940c of this title","children":[],"tail":" in an amount equal to the amount of the payment deferred. The balance of such account shall not be reduced by the borrower below the level of the unpaid balance of the payment deferred. Subject to limitations established in annual appropriations Acts, such cushion of credit amounts and any other cushion of credit and advance payments of any borrower shall be included in the interest differential calculation under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s940c/b/2"},"text":"section 940c(b)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ec54-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall undertake all reasonable efforts to permit the full amount of deferments authorized by this subsection during each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee59ec55-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferment of payments on loans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee59ec56-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall allow borrowers to defer payment of principal and interest on any direct loan made under this chapter to enable the borrower to make loans to residential, commercial, and industrial consumers—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee59ec57-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct energy efficiency and use audits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee59ec58-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to install energy efficient measures or devices that reduce the demand on electric systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ec59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of a deferment under this subsection shall not exceed the sum of the principal and interest on the loans made to a customer of the borrower, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ec5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s912/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of a deferment under this subsection shall not exceed 60 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee59ec5b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title I, § 12, "},{"tag":"ref","attrib":{"href":"/us/stat/49/1366"},"text":"49 Stat. 1366","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch776"},"text":"Oct. 28, 1949, ch. 776","children":[],"tail":", §§ 2, 4(f), "},{"tag":"ref","attrib":{"href":"/us/stat/63/948"},"text":"63 Stat. 948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2344"},"text":"Pub. L. 101–624, title XXIII, § 2344","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4028"},"text":"104 Stat. 4028","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/13"},"text":"Pub. L. 103–354, title II, § 235(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s774/b"},"text":"Pub. L. 104–127, title VII, § 774(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1150"},"text":"110 Stat. 1150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6103"},"text":"Pub. L. 110–234, title VI, § 6103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1195"},"text":"122 Stat. 1195","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6103, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1956; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6504/a"},"text":"Pub. L. 115–334, title VI, § 6504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4773"},"text":"132 Stat. 4773","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee59ec5c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee59ec5d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee59ec5e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee59ec5f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “940c(b)(2) of this title” for “940c(b)(2)(A) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6103"},"text":"Pub. L. 110–246, § 6103","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" substituted “, except that, with respect to any loan” for “: "},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That with respect to any loan” and struck out “, and with respect to any loan made under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s905"},"text":"section 905 of this title","children":[],"tail":", the payment of principal or interest shall not be extended more than two years after such payment shall have become due: "},{"tag":"i","attrib":{},"text":"And provided further","children":[],"tail":", That the provisions of this section shall not apply to any obligations or the security therefor which may be held by the Reconstruction Finance Corporation under the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s903"},"text":"section 903 of this title","children":[],"tail":"” after “such payment shall have become due”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a), (b)(1), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-10-28"},"text":"Oct. 28, 1949","children":[],"tail":", inserted “or section 922” after “904” in first proviso, and inserted “title I,” in credit of act "},{"tag":"date","attrib":{"date":"1936-05-20"},"text":"May 20, 1936","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee59ec60-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee59ec61-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
