{"tag":"section","attrib":{"id":"idee6cfed9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1038"},"text":null,"children":[{"tag":"num","attrib":{"value":"1038"},"text":"§ 1038.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; delegations of authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may make such rules and regulations and such delegations of authority as he may deem necessary to carry out the provisions of sections 1033 to 1039 of this title.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee6cfeda-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-06/ch897/s6"},"text":"Sept. 6, 1950, ch. 897, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/770"},"text":"64 Stat. 770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee6cfedb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee6cfedc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee6cfedd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Bankhead-Jones Farm Tenant Act which constitutes a major part of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
