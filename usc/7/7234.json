{"tag":"section","attrib":{"id":"ideffffb0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234"},"text":null,"children":[{"tag":"num","attrib":{"value":"7234"},"text":"§ 7234.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffffb10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rates for wheat, feed grains, and oilseeds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall permit a producer to repay a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7231"},"text":"section 7231 of this title","children":[],"tail":" for wheat, corn, grain sorghum, barley, oats, and oilseeds at a rate that is the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffb11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7232"},"text":"section 7232 of this title","children":[],"tail":", plus interest (as determined by the Secretary); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a rate that the Secretary determines will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffffb13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize potential loan forfeitures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffffb14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the accumulation of stocks of the commodity by the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffffb15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the cost incurred by the Federal Government in storing the commodity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffffb16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the commodity produced in the United States to be marketed freely and competitively, both domestically and internationally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rates for upland cotton and rice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall permit producers to repay a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7231"},"text":"section 7231 of this title","children":[],"tail":" for upland cotton and rice at a rate that is the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffb18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7232"},"text":"section 7232 of this title","children":[],"tail":", plus interest (as determined by the Secretary); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevailing world market price for the commodity (adjusted to United States quality and location), as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rates for extra long staple cotton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Repayment of a marketing assistance loan for extra long staple cotton shall be at the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7232"},"text":"section 7232 of this title","children":[],"tail":", plus interest (as determined by the Secretary)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb1b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevailing world market price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7236"},"text":"section 7236 of this title","children":[],"tail":", the Secretary shall prescribe by regulation—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffb1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a formula to determine the prevailing world market price for each loan commodity, adjusted to United States quality and location; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb1d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mechanism by which the Secretary shall announce periodically the prevailing world market price for each loan commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb1e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of prevailing world market price for upland cotton","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffb1f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the period ending ","children":[{"tag":"date","attrib":{"date":"2003-07-31"},"text":"July 31, 2003","children":[],"tail":", the prevailing world market price for upland cotton (adjusted to United States quality and location) established under subsection (d) shall be further adjusted if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffffb20-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjusted prevailing world market price is less than 115 percent of the loan rate for upland cotton established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7232"},"text":"section 7232 of this title","children":[],"tail":", as determined by the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffffb21-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Friday through Thursday average price quotation for the lowest-priced United States growth as quoted for Middling (M) 1","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"32","children":[],"tail":"-inch cotton delivered C.I.F. Northern Europe is greater than the Friday through Thursday average price of the 5 lowest-priced growths of upland cotton, as quoted for Middling (M) 1"},{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"32","children":[],"tail":"-inch cotton, delivered C.I.F. Northern Europe (referred to in this section as the “Northern Europe price”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb22-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Further adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (3), the adjusted prevailing world market price for upland cotton shall be further adjusted on the basis of some or all of the following data, as available:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffffb23-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States share of world exports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffffb24-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The current level of cotton export sales and cotton export shipments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffffb25-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other data determined by the Secretary to be relevant in establishing an accurate prevailing world market price for upland cotton (adjusted to United States quality and location).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on further adjustment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The adjustment under paragraph (2) may not exceed the difference between—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffffb27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Friday through Thursday average price for the lowest-priced United States growth as quoted for Middling 1","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"32","children":[],"tail":"-inch cotton delivered C.I.F. Northern Europe; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffffb28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7234/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Northern Europe price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffffb29-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s134"},"text":"Pub. L. 104–127, title I, § 134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/908"},"text":"110 Stat. 908","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
