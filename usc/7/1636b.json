{"tag":"section","attrib":{"id":"ideedf6fa4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1636b"},"text":"§ 1636b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedf6fa5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6fa6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any packer or other person that violates this subchapter may be assessed a civil penalty by the Secretary of not more than $10,000 for each violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fa7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each day during which a violation continues shall be considered to be a separate violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fa8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the amount of a civil penalty to be assessed under paragraph (1), the Secretary shall consider the gravity of the offense, the size of the business involved, and the effect of the penalty on the ability of the person that has committed the violation to continue in business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fa9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining whether to assess a civil penalty under paragraph (1), the Secretary shall consider whether a packer or other person subject to this subchapter has engaged in a pattern of errors, delays, or omissions in violation of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6faa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cease and desist","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to, or in lieu of, a civil penalty under subsection (a), the Secretary may issue an order to cease and desist from continuing any violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6fab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty shall be assessed, or cease and desist order issued, by the Secretary under this section unless the person against which the penalty is assessed or to which the order is issued is given notice and opportunity for a hearing before the Secretary with respect to the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6fac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality and judicial review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6fad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order of the Secretary assessing a civil penalty or issuing a cease and desist order under this section shall be final and conclusive unless the affected person files an appeal of the order of the Secretary in United States district court not later than 30 days after the date of the issuance of the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard of review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A finding of the Secretary under this section shall be set aside only if the finding is found to be unsupported by substantial evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6faf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6fb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after the lapse of the period allowed for appeal or after the affirmance of a penalty assessed under this section, the person against which the civil penalty is assessed fails to pay the penalty, the Secretary may refer the matter to the Attorney General who may recover the penalty by an action in United States district court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the action, the final order of the Secretary shall not be subject to review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6fb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunction or restraining order","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6fb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary has reason to believe that any person subject to this subchapter has failed or refused to provide the Secretary information required to be reported pursuant to this subchapter, and that it would be in the public interest to enjoin the person from further failure to comply with the reporting requirements, the Secretary may notify the Attorney General of the failure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Attorney General may apply to the appropriate district court of the United States for a temporary or permanent injunction or restraining order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When needed to carry out this subchapter, the court shall, on a proper showing, issue a temporary injunction or restraining order without bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6fb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to obey orders","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6fb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a person subject to this subchapter fails to obey a cease and desist or civil penalty order issued under this subsection after the order has become final and unappealable, or after the appropriate United States district court has entered a final judgment in favor of the Secretary, the United States may apply to the appropriate district court for enforcement of the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the court determines that the order was lawfully made and duly served and that the person violated the order, the court shall enforce the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fb9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636b/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the court finds that the person violated the cease and desist provisions of the order, the person shall be subject to a civil penalty of not more than $10,000 for each offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedf6fba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 253, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX/s911/2"},"text":"Pub. L. 106–78, title IX, § 911(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1202"},"text":"113 Stat. 1202","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
