{"tag":"section","attrib":{"id":"idef224541-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2002"},"text":null,"children":[{"tag":"num","attrib":{"value":"2002"},"text":"§ 2002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of inventory lands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef224542-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b), the Secretary may transfer to any Federal or State agency, for conservation purposes any real property, or interest therein, administered by the Secretary under this Act—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef224543-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2002/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to which the rights of all prior owners and operators have expired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef224544-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2002/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is eligible to be disposed of in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1985"},"text":"section 1985 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef224545-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2002/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef224546-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2002/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has marginal value for agricultural production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef224547-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2002/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is environmentally sensitive; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef224548-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2002/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has special management importance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef224549-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not transfer any property or interest in property under subsection (a) unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef22454a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2002/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 2 public notices are given of the transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef22454b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2002/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if requested, at least 1 public meeting is held prior to the transfer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef22454c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2002/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Governor and at least 1 elected county official of the State and county where the property is located are consulted prior to the transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef22454d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s354"},"text":"Pub. L. 87–128, title III, § 354","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVI/s616"},"text":"Pub. L. 100–233, title VI, § 616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1682"},"text":"101 Stat. 1682","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVI/s646"},"text":"Pub. L. 104–127, title VI, § 646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1103"},"text":"110 Stat. 1103","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef22454e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef22454f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef224550-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (a), refers to the Agricultural Act of 1961, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/294"},"text":"75 Stat. 294","children":[],"tail":". For classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1911"},"text":"section 1911 of this title","children":[],"tail":" and Tables. However, the reference was probably intended to be “this title” meaning the Consolidated Farm and Rural Development Act, title III of "},{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", as amended, which is classified principally to this chapter. For classification of this title to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef224551-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, substituted “Subject to subsection (b), the Secretary” for “The Secretary, without reimbursement,” in introductory provisions, added par. (2) and struck out former par. (2) which read as follows: “that is determined by the Secretary to be suitable or surplus; and”, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
