{"tag":"section","attrib":{"id":"idefa5586b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292"},"text":null,"children":[{"tag":"num","attrib":{"value":"3292"},"text":"§ 3292.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships to build capacity in international agricultural research, extension, and teaching","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa5586c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa5586d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1862 Institution; 1890 Institution; 1994 Institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “1862 Institution”, “1890 Institution”, and “1994 Institution” have the meanings given the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7601"},"text":"section 7601 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa5586e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered Institution","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered Institution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa5586f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an 1862 Institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa55870-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an 1890 Institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa55871-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 1994 Institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa55872-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an NLGCA Institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa55873-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Hispanic-serving agricultural college or university; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa55874-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cooperating forestry school.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55875-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Developing country","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “developing country” means a country, as determined by the Secretary using a gross national income per capita test selected by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55876-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International partner institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “international partner institution” means an agricultural higher education institution in a developing country that is performing, or desiring to perform, activities similar to agricultural research, extension, and teaching activities carried out through covered Institutions in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa55877-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may promote cooperation and coordination between covered Institutions and international partner institutions through—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa55878-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improving extension by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa55879-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the exchange of research materials and results between covered Institutions and international partner institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa5587a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the broad dissemination of agricultural research through extension; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa5587b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting with efforts to plan and initiate extension services in developing countries;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa5587c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improving agricultural research by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa5587d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in partnership with international partner institutions, encouraging research that addresses problems affecting food production and security, human nutrition, agriculture, forestry, livestock, and fisheries, including local challenges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa5587e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting and strengthening national agricultural research systems in developing countries;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa5587f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the participation of covered Institutions in programs of international organizations, such as the United Nations, the World Bank, regional development banks, and international agricultural research centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55880-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improving agricultural teaching and education by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa55881-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in partnership with international partner institutions, supporting education and teaching relating to food and agricultural sciences, including technical assistance, degree training, research collaborations, classroom instruction, workforce training, and education programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa55882-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting with efforts to increase student capacity, including to encourage equitable access for women and other underserved populations, at international partner institutions by promoting partnerships with, and improving the capacity of, covered Institutions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55883-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting covered Institutions in strengthening their capacity for food, agricultural, and related research, extension, and teaching programs relevant to agricultural development activities in developing countries to promote the application of new technology to improve education delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55884-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing support for the internationalization of resident instruction programs of covered Institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55885-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a program, to be coordinated by the Director of the National Institute of Food and Agriculture and the Administrator of the Foreign Agricultural Service, to place interns from covered Institutions in, or in service to benefit, developing countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55886-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a program to provide fellowships to students at covered Institutions to study at foreign agricultural colleges and universities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa55887-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhancing linkages","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall enhance the linkages among covered Institutions, the Federal Government, international research centers, counterpart research, extension, and teaching agencies and institutions in developed countries and developing countries—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa55888-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the activities described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa55889-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make a substantial contribution to the cause of improved food and agricultural progress throughout the world.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa5588a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa5588b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1458A"},"text":"Pub. L. 95–113, title XIV, § 1458A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7123"},"text":"Pub. L. 115–334, title VII, § 7123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4792"},"text":"132 Stat. 4792","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa5588c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa5588d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idefa5588e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3292, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1458A"},"text":"Pub. L. 95–113, title XIV, § 1458A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXIV/s1419/a"},"text":"Pub. L. 99–198, title XIV, § 1419(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1550"},"text":"99 Stat. 1550","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1613/c"},"text":"Pub. L. 101–624, title XVI, § 1613(c)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3726"},"text":"104 Stat. 3726","children":[],"tail":", related to grants to States for international trade development centers, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s856"},"text":"Pub. L. 104–127, title VIII, § 856","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1172"},"text":"110 Stat. 1172","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
