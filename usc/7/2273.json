{"tag":"section","attrib":{"id":"idef7ce864-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2273"},"text":null,"children":[{"tag":"num","attrib":{"value":"2273"},"text":"§ 2273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local search and rescue operations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may assist, through the use of Soil Conservation Service personnel, vehicles, communication equipment, and other equipment or materials available to the Secretary, in local search and rescue operations when requested by responsible local public authorities. Such assistance may be provided in emergencies caused by tornadoes, fires, floods, snowstorms, earthquakes, and similar disasters.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef7ce865-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXV/s1550"},"text":"Pub. L. 97–98, title XV, § 1550","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1344"},"text":"95 Stat. 1344","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7ce866-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef7ce867-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef7ce868-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
