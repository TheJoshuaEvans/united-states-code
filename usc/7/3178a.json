{"tag":"section","attrib":{"id":"idef9e2c2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3178a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3178a"},"text":"§ 3178a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nutrition monitoring","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9e2c2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3178a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conducting the Department of Agriculture’s continuing survey of food intakes of individuals and any nationwide food consumption survey, include a sample that is representative of low-income individuals and, to the extent practicable, the collection of information on food purchases and other household expenditures by such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3178a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, continue to maintain the nutrient data base established by the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3178a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage research by public and private entities relating to effective standards, methodologies, and technologies for accurate assessment of the nutritional and dietary status of individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9e2c30-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXV/s1589"},"text":"Pub. L. 99–198, title XV, § 1589","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1597"},"text":"99 Stat. 1597","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9e2c31-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef9e2c32-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef9e2c33-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food Security Act of 1985, and not as part of the National Agricultural Research, Extension, and Teaching Policy Act of 1977 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
