{"tag":"section","attrib":{"id":"ideefc1f1d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748"},"text":null,"children":[{"tag":"num","attrib":{"value":"1748"},"text":"§ 1748.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports by agricultural attachés","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideefc1f1e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require appropriate officers and employees of the Department of Agriculture, including those stationed in foreign countries, to prepare and submit annually to the Secretary detailed reports that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideefc1f1f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" document the nature and extent of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideefc1f20-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs in such countries that provide direct or indirect government support for the export of agricultural commodities and the products thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideefc1f21-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other trade practices that may impede the entry of United States agricultural commodities and the products thereof into such countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideefc1f22-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where practicable, the average prices and costs of production in such countries for like commodities exported from the United States to such countries; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideefc1f23-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify opportunities for the export of United States agricultural commodities and the products thereof to such countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideefc1f24-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideefc1f25-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" annually compile the information contained in reports prepared under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideefc1f26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a country by country basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideefc1f27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a commodity by commodity basis for exports of United States agricultural commodities, as determined appropriate by the Secretary, the export of which is hampered by an unfair trade practice. Where practicable, the report shall include a comparison of the average prices and costs of production for such commodities in the United States and in the importing countries for the previous crop year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideefc1f28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the agricultural technical advisory committees established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2155/c"},"text":"section 2155(c) of title 19","children":[],"tail":", include in the compilation a priority ranking of those trade barriers identified in subsection (a) by commodity group;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideefc1f29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in the compilation a list of actions undertaken to reduce or eliminate such trade barriers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideefc1f2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than January 15 of each year, make the compilation available to Congress, the agricultural policy advisory committee, and other interested parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideefc1f2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meeting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary and the United States Trade Representative shall convene a meeting, at least once each year, of the Agricultural Policy Advisory Committee and the agricultural technical advisory committees to develop specific recommendations for actions to be taken by the Federal Government and private industry to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideefc1f2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce or eliminate trade barriers or distortions identified in the annual reports required to be submitted under subsections (a) and (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideefc1f2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1748/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand United States agricultural export opportunities identified in such annual reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideefc1f2e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041"},"text":"Aug. 28, 1954, ch. 1041","children":[],"tail":", title I, § 108, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1532"},"text":"Pub. L. 101–624, title XV, § 1532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3689"},"text":"104 Stat. 3689","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII"},"text":"Pub. L. 102–237, title III","children":[],"tail":", §§ 316–318, "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1856"},"text":"105 Stat. 1856","children":[],"tail":", 1857; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s272"},"text":"Pub. L. 104–127, title II, § 272","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/976"},"text":"110 Stat. 976","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideefc1f2f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideefc1f30-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideefc1f31-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" struck out “including fruits, vegetables, legumes, popcorn and ducks” after “agricultural commodities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s316"},"text":"Pub. L. 102–237, § 316","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1532"},"text":"Pub. L. 101–624, § 1532","children":[],"tail":", which enacted this section, resulting in no change in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s317"},"text":"Pub. L. 102–237, § 317","children":[],"tail":", substituted a semicolon for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s318"},"text":"Pub. L. 102–237, § 318","children":[],"tail":", struck out “the trade assistance office authorized under section 504 of the Agricultural Trade Act of 1978 (as amended by section 201),” after “available to Congress,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
