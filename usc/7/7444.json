{"tag":"section","attrib":{"id":"idf0099871-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444"},"text":null,"children":[{"tag":"num","attrib":{"value":"7444"},"text":"§ 7444.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required terms in orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0099872-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An order issued under this subchapter shall contain the terms and conditions specified in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0099873-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and membership of National Canola and Rapeseed Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0099874-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide for the establishment of, and appointment of members to, a National Canola and Rapeseed Board to administer the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099875-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service to entire industry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall carry out programs and projects that will provide maximum benefit to the canola and rapeseed industry in all parts of the United States and only promote canola, rapeseed, or canola or rapeseed products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099876-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall consist of 15 members, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0099877-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 11 members who are producers, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0099878-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member from each of the 6 geographic regions comprised of States where canola or rapeseed is produced, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0099879-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 members from the geographic regions referred to in clause (i), allocated according to the production in each region; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf009987a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 4 members who are industry members, including at least—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf009987b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member who represents manufacturers of canola or rapeseed end products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf009987c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 member who represents persons who commercially buy or sell canola or rapeseed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf009987d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on State residence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be no more than 4 producer members of the Board from any 1 State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf009987e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modifying Board membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with regulations approved by the Secretary, at least once each 3 years and not more than once each 2 years, the Board shall review the geographic distribution of canola and rapeseed production throughout the United States and, if warranted, recommend to the Secretary that the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf009987f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reapportion regions in order to reflect the geographic distribution of canola and rapeseed production; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0099880-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reapportion the seats on the Board to reflect the production in each region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099881-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of organizations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0099882-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7445"},"text":"section 7445 of this title","children":[],"tail":", the eligibility of any State organization to represent producers shall be certified by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0099883-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall certify any State organization that the Secretary determines has a history of stability and permanency and meets at least 1 of the following criteria:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0099884-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Majority representation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total paid membership of the organization—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf0099885-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/6/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is comprised of at least a majority of canola or rapeseed producers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0099886-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/6/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represents at least a majority of the canola or rapeseed producers in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0099887-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantial number of producers represented","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The organization represents a substantial number of producers that produce a substantial quantity of canola or rapeseed in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0099888-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The organization is a general farm or agricultural organization that has as a stated objective the promotion and development of the United States canola or rapeseed industry and the economic welfare of United States canola or rapeseed producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0099889-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make a certification under this paragraph on the basis of a factual report submitted by the State organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf009988a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of office","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf009988b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board shall serve for a term of 3 years, except that the members appointed to the initial Board shall serve, proportionately, for terms of 1, 2, and 3 years, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf009988c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No individual may serve more than 2 consecutive 3-year terms as a member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf009988d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (B), each member shall continue to serve until a successor is appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf009988e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Board shall serve without compensation, but shall be reimbursed for necessary and reasonable expenses incurred in the performance of duties for and approved by the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf009988f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and duties of Board","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The order shall define the powers and duties of the Board, which shall include the power and duty—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0099890-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer the order in accordance with the terms and conditions of the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099891-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to issue regulations to effectuate the terms and conditions of the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099892-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet, organize, and select from among members of the Board a chairperson, other officers, and committees and subcommittees, as the Board determines appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099893-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish working committees of persons other than Board members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099894-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to employ such persons, other than Board members, as the Board considers necessary, and to determine the compensation and define the duties of the persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099895-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prepare and submit for the approval of the Secretary, when appropriate or necessary, a recommended rate of assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7445"},"text":"section 7445 of this title","children":[],"tail":", and a fiscal period budget of the anticipated expenses in the administration of the order, including the probable costs of all programs and projects;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099896-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop programs and projects, subject to subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099897-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into contracts or agreements, subject to subsection (e), to develop and carry out programs or projects of research, promotion, industry information, and consumer information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099898-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out research, promotion, industry information, and consumer information projects, and to pay the costs of the projects with assessments collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7445"},"text":"section 7445 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099899-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to keep minutes, books, and records that reflect the actions and transactions of the Board, and promptly report minutes of each Board meeting to the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf009989a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to appoint and convene, from time to time, working committees comprised of producers, industry members, and the public to assist in the development of research, promotion, industry information, and consumer information programs for canola, rapeseed, and canola and rapeseed products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf009989b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to invest, pending disbursement under a program or project, funds collected through assessments authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7445"},"text":"section 7445 of this title","children":[],"tail":", or funds earned from investments, only in—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf009989c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obligations of the United States or an agency of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf009989d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" general obligations of a State or a political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf009989e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an interest-bearing account or certificate of deposit of a bank that is a member of the Federal Reserve System; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf009989f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/12/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obligations fully guaranteed as to principal and interest by the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive, investigate, and report to the Secretary complaints of violations of the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to furnish the Secretary with such information as the Secretary may request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recommend to the Secretary amendments to the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and recommend to the Secretary for approval such regulations as may be necessary for the development and execution of programs or projects, or as may otherwise be necessary, to carry out the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/c/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide the Secretary with advance notice of meetings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00998a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs and budgets","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00998a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that the Board shall submit to the Secretary for approval any program or project of research, promotion, consumer information, or industry information. No program or project shall be implemented prior to approval by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budgets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall require the Board, prior to the beginning of each fiscal year, or as may be necessary after the beginning of a fiscal year, to submit to the Secretary for approval budgets of anticipated expenses and disbursements in the implementation of the order, including projected costs of research, promotion, consumer information, and industry information programs and projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incurring expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board may incur such expenses for programs or projects of research, promotion, consumer information, or industry information, and other expenses for the administration, maintenance, and functioning of the Board as may be authorized by the Secretary, including any implementation, administrative, and referendum costs incurred by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paying expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funds to cover the expenses referred to in paragraph (3) shall be paid by the Board from assessments collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7445"},"text":"section 7445 of this title","children":[],"tail":" or funds borrowed pursuant to paragraph (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to borrow","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To meet the expenses referred to in paragraph (3), the Board shall have the authority to borrow funds, as approved by the Secretary, for capital outlays and startup costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00998ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts and agreements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00998ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure efficient use of funds, the order shall provide that the Board may enter into a contract or agreement for the implementation and carrying out of a program or project of canola, rapeseed, or canola or rapeseed products research, promotion, consumer information, or industry information, including a contract with a producer organization, and for the payment of the costs with funds received by the Board under the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contract or agreement under paragraph (1) shall provide that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00998ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contracting party shall develop and submit to the Board a program or project together with a budget that shall show the estimated costs to be incurred for the program or project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the program or project shall become effective on the approval of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contracting party shall keep accurate records of all transactions, account for funds received and expended, make periodic reports to the Board of activities conducted, and make such other reports as the Board or the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that the Board may contract with a producer organization for any services required in addition to the services described in paragraph (1). The contract shall include provisions comparable to the provisions required by paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00998b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Books and records of Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00998b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The order shall require the Board to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00998b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain such books and records (which shall be available to the Secretary for inspection and audit) as the Secretary may prescribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and submit to the Secretary, from time to time, such reports as the Secretary may prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" account for the receipt and disbursement of all funds entrusted to the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall cause the books and records of the Board to be audited by an independent auditor at the end of each fiscal year, and a report of the audit to be submitted to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00998b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00998b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the Board shall not engage in any action to, nor shall any funds received by the Board under this subchapter be used to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00998ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" influence legislation or governmental action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in an action that would be a conflict of interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in advertising that is false or misleading; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in promotion that would disparage other commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action permitted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) does not preclude—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00998bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and recommendation of amendments to the order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the communication to appropriate government officials of information relating to the conduct, implementation, or results of promotion, research, consumer information, or industry information activities under the order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any action designed to market canola or rapeseed products directly to a foreign government or political subdivision of a foreign government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00998c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Books and records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00998c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The order shall require that each producer, first purchaser, or industry member shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00998c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain and submit to the Board any reports considered necessary by the Secretary to ensure compliance with this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available during normal business hours, for inspection by employees of the Board or Secretary, such books and records as are necessary to carry out this subchapter, including such records as are necessary to verify any required reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00998c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this subchapter, all information obtained from books, records, or reports required to be maintained under paragraph (1) shall be kept confidential, and shall not be disclosed to the public by any person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information referred to in subparagraph (A) may be disclosed to the public if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf00998c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary considers the information relevant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00998ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information is revealed in a suit or administrative hearing brought at the direction or on the request of the Secretary or to which the Secretary or any officer of the Department is a party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00998cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information relates to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misconduct","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A knowing disclosure of confidential information in violation of subparagraph (A) by an officer or employee of the Board or Department, except as required by other law or allowed under subparagraph (B) or (D), shall be considered a violation of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00998cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General statements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this paragraph prohibits—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf00998ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of general statements based on the reports of a number of persons subject to an order or statistical data collected from the reports, if the statements do not identify the information furnished by any person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf00998cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the publication, by direction of the Secretary, of the name of a person violating the order, together with a statement of the particular provisions of the order violated by the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information for law enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information obtained under this subchapter may be made available to another agency of the Federal Government for a civil or criminal law enforcement activity if the activity is authorized by law and if the head of the agency has made a written request to the Secretary specifying the particular information desired and the law enforcement activity for which the information is sought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person knowingly violating this subsection, on conviction, shall be subject to a fine of not more than $1,000 or to imprisonment for not more than 1 year, or both, and if an officer or employee of the Board or the Department, shall be removed from office or terminated from employment, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00998d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter authorizes the withholding of information from Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00998d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that the assessments collected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7445"},"text":"section 7445 of this title","children":[],"tail":" shall be used for payment of the expenses in implementing and administering this subchapter, with provision for a reasonable reserve, and to cover administrative costs incurred by the Secretary in implementing and administering this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00998d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7444/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall contain such other terms and conditions, not inconsistent with this subchapter, as are determined necessary by the Secretary to effectuate this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00998d5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s535"},"text":"Pub. L. 104–127, title V, § 535","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1051"},"text":"110 Stat. 1051","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
