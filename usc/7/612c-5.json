{"tag":"section","attrib":{"id":"idee5076a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–5"},"text":null,"children":[{"tag":"num","attrib":{"value":"612c–5"},"text":"§ 612c–5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Section 612c funds for purchase of fruits, vegetables, and nuts to support domestic nutrition assistance programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee5076a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for additional purchases of fruits, vegetables, and nuts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the purchases of fruits, vegetables, and nuts required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c–4"},"text":"section 612c–4 of this title","children":[],"tail":", the Secretary of Agriculture shall purchase fruits, vegetables, and nuts for the purpose of providing nutritious foods for use in domestic nutrition assistance programs, using, of the funds made available under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"section 612c of this title","children":[],"tail":", the following amounts:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idee5076a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $190,000,000 for fiscal year 2008.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5076a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $193,000,000 for fiscal year 2009.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5076a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–5/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $199,000,000 for fiscal year 2010.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5076aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–5/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $203,000,000 for fiscal year 2011.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5076ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–5/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $206,000,000 for fiscal year 2012 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee5076ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s612c–5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of purchases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fruits, vegetables, and nuts may be purchased under this section in the form of frozen, canned, dried, or fresh fruits, vegetables, and nuts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee5076ad-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIV/s4404"},"text":"Pub. L. 110–234, title IV, § 4404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1137"},"text":"122