{"tag":"section","attrib":{"id":"idef81a40d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2355"},"text":null,"children":[{"tag":"num","attrib":{"value":"2355"},"text":"§ 2355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of defective execution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any document to be filed in the Plant Variety Protection Office and which is required by any law or regulation to be executed in a specified manner may be provisionally accepted by the Secretary despite a defective execution, provided a properly executed document is submitted within such time as may be prescribed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef81a40e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tI/s25"},"text":"Pub. L. 91–577, title I, § 25","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1545"},"text":"84 Stat. 1545","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
