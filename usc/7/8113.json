{"tag":"section","attrib":{"id":"idf03208ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113"},"text":null,"children":[{"tag":"num","attrib":{"value":"8113"},"text":"§ 8113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community Wood Energy and Wood Innovation Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf03208af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03208b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community wood energy system","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03208b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “community wood energy system” means an energy system that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03208b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produces thermal energy or combined thermal energy and electricity where thermal is the primary energy output;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03208b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services public facilities owned or operated by State or local governments (including schools, town halls, libraries, and other public buildings) or private or nonprofit facilities (including commercial and business facilities, such as hospitals, office buildings, apartment buildings, and manufacturing and industrial buildings); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03208b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" uses woody biomass, including residuals—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf03208b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that have not been adulterated with glue or other chemical treatments from wood processing facilities, as the primary fuel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf03208b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the use of that biomass for energy production does not cause conversion of forests to nonforest use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “community wood energy system” includes single-facility central heating, district heating systems serving multiple buildings, combined heat and electric systems where thermal energy is the primary energy output, and other related biomass energy systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative wood product facility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “innovative wood product facility” means a manufacturing or processing plant or mill that produces—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03208b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building components or systems that use large panelized wood construction, including mass timber;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wood products derived from nanotechnology or other new technology processes, as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other innovative wood products that use low-value, low-quality wood, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mass timber","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “mass timber” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03208bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cross-laminated timber;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nail-laminated timber;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" glue-laminated timber;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laminated strand lumber; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laminated veneer lumber.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Program” means the Community Wood Energy and Wood Innovation Program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03208c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grant program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Chief of the Forest Service, shall establish a competitive grant program to be known as the “Community Wood Energy and Wood Innovation Program”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03208c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03208c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under the Program, the Secretary shall make grants to cover not more than 35 percent of the capital cost for installing a community wood energy system or building an innovative wood product facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special circumstances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish special circumstances, such as in the case of a community wood energy system project or innovative wood product facility project involving a school or hospital in a low-income community, under which grants under the Program may cover up to 50 percent of the capital cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Matching funds required pursuant to this subsection from a grant recipient shall be derived from non-Federal funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03208c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project cap","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total amount of grants under the Program for a community wood energy system project or innovative wood product facility project may not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03208c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of grants under the general authority provided under subsection (c)(1), $1,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of grants for which the special circumstances apply under subsection (c)(2), $1,500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03208cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting applicants for grants under the Program, the Secretary shall consider the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03208cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The energy efficiency of the proposed community wood energy system or innovative wood product facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost effectiveness of the proposed community wood energy system or innovative wood product facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the proposed community wood energy system or innovative wood product facility represents the best available commercial technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the proposed community wood energy system uses the most stringent control technology that has been required or achieved in practice for a wood-fired boiler of similar size and type.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03208d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the proposed community wood energy system will displace conventional fossil fuel generation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether the proposed community wood energy system minimizes emission increases to the greatest extent possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the proposed community wood energy system will increase delivered thermal efficiency of the systems replaced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which the applicant has demonstrated a high likelihood of project success by completing detailed engineering and design work in advance of the grant application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other technical, economic, conservation, and environmental criteria that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03208d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting applicants for grants under the Program, the Secretary shall give priority to proposals that use the most stringent control technology that has been required or achieved in practice for a wood-fired boiler and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03208d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be carried out in a location where markets are needed for the low-value, low-quality wood;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be carried out in a location with limited access to natural gas pipelines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would include the use or retrofitting (or both) of existing sawmill facilities located in a location where the average annual unemployment rate exceeded the national average unemployment rate by more than 1 percent during the previous calendar year; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be carried out in a location where the project will aid with forest restoration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03208db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03208dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity of community wood energy systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A community wood energy system acquired with grant funds under the Program shall not exceed nameplate capacity of 5 megawatts of thermal energy or combined thermal and electric energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for innovative wood product facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 25 percent of funds provided as grants under the Program for a fiscal year may go to applicants proposing innovative wood product facilities, unless the Secretary has received an insufficient number of qualified proposals for community wood energy systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03208de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8113/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out the Program $25,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf03208df-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/