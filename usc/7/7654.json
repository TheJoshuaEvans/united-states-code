{"tag":"section","attrib":{"id":"idf017ca0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7654"},"text":null,"children":[{"tag":"num","attrib":{"value":"7654"},"text":"§ 7654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food Safety Research Information Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf017ca0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7654/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall establish a Food Safety Research Information Office at the National Agricultural Library.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017ca10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7654/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office shall provide to the research community and the general public information on publicly funded, and to the maximum extent practicable, privately funded food safety research initiatives for the purpose of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf017ca11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7654/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing unintended duplication of food safety research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017ca12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7654/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting the executive and legislative branches of the Federal Government and private research entities to assess food safety research needs and priorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017ca13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7654/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office shall carry out this section in cooperation with the National Institutes of Health, the Food and Drug Administration, the Centers for Disease Control and Prevention, public institutions, and, on a voluntary basis, private research entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf017ca14-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s615"},"text":"Pub. L. 105–185, title VI, § 615","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/606"},"text":"112 Stat. 606","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7301/a"},"text":"Pub. L. 107–171, title VII, § 7301(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/454"},"text":"116 Stat. 454","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf017ca15-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf017ca16-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf017ca17-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" struck out “and national conference” after “Information Office” in section catchline, struck out subsec. (a) designation and heading, redesignated pars. (1) to (3) of former subsec. (a) as subsecs. (a) to (c), respectively, and subpars. (A) and (B) of former par. (2) as pars. (1) and (2) of subsec. (b), respectively, realigned margins, substituted “this section” for “this subsection” in subsec. (c), and struck out former subsecs. (b) and (c) which related to national conference and annual workshops and food safety report, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
