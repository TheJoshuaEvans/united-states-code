{"tag":"section","attrib":{"id":"idef2bbae5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009aa–2"},"text":"§ 2009aa–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Economic and community development grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef2bbae6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Authority may approve grants to States, Indian Tribes, and public and nonprofit entities for projects, approved in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009aa–8"},"text":"section 2009aa–8 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2bbae7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop the transportation infrastructure of the region for the purpose of facilitating economic development in the region (except that grants for this purpose may only be made to a State, Tribal, or local government);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbae8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist the region in obtaining the job training, employment-related education, and business development (with an emphasis on entrepreneurship) that are needed to build and maintain strong local economies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbae9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance to severely distressed and underdeveloped areas that lack financial resources for improving basic public services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbaea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance to severely distressed and underdeveloped areas that lack financial resources for equipping industrial parks and related facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbaeb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to otherwise achieve the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2bbaec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2bbaed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds for grants under subsection (a) may be provided—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2bbaee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entirely from appropriations to carry out this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2bbaef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in combination with funds available under another Federal or Federal grant program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2bbaf0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from any other source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbaf1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority of funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To best build the foundations for long-term economic development and to complement other Federal and State resources in the region, Federal funds available under this subchapter shall be focused on the activities in the following order or priority:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2bbaf2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Basic public infrastructure in distressed counties and isolated areas of distress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2bbaf3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation infrastructure for the purpose of facilitating economic development in the region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2bbaf4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Business development, with emphasis on entrepreneurship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2bbaf5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–2/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Job training or employment-related education, with emphasis on use of existing public educational institutions located in the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef2bbaf6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s382C"},"text":"Pub. L. 87–128, title III, § 382C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tV/s503"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title V, § 503]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–274; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6027/c"},"text":"Pub. L. 107–171, title VI, § 6027(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/373"},"text":"116 Stat. 373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/272/dB/tII/s2253/e"},"text":"Pub. L. 118–272, div. B, title II, § 2253(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/3213"},"text":"138 Stat. 3213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef2bbaf7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef2bbaf8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef2bbaf9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2253/e/1"},"text":"Pub. L. 118–272, § 2253(e)(1)","children":[],"tail":", inserted “, Indian Tribes,” after “States” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/272/s2253/e/2"},"text":"Pub. L. 118–272, § 2253(e)(2)","children":[],"tail":", inserted “, Tribal,” after “State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" struck out heading and text of par. (3). Text read as follows: “Notwithstanding any provision of law limiting the Federal share in any grant program, funds appropriated to carry out this section may be used to increase a Federal share in a grant program, as the Authority determines appropriate.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
