{"tag":"section","attrib":{"id":"ideff8cef8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991"},"text":null,"children":[{"tag":"num","attrib":{"value":"6991"},"text":"§ 6991.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff8cef9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adverse decision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “adverse decision” means an administrative decision made by an officer, employee, or committee of an agency that is adverse to a participant. The term includes a denial of equitable relief by an agency or the failure of an agency to issue a decision or otherwise act on the request or right of the participant. The term does not include a decision over which the Board of Contract Appeals has jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cefa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “agency” means any agency of the Department designated by the Secretary or a successor agency of the Department, except that the term shall include the following (and any successor to the following):","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff8cefb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Farm Service Agency (or other office, agency, or administrative unit of the Department assigned the functions authorized for the Farm Service Agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6932"},"text":"section 6932 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cefc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commodity Credit Corporation, with respect to domestic programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cefd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Farmers Home Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cefe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Crop Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8ceff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Rural Development Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cf00-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Natural Resources Conservation Service (or other office, agency, or administrative unit of the Department assigned the functions authorized for the Natural Resources Conservation Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6936/b"},"text":"section 6936(b) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cf01-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State, county, or area committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b/5"},"text":"section 590h(b)(5) of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cf02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appellant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appellant” means a participant who appeals an adverse decision in accordance with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cf03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Case record","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “case record” means all the materials maintained by the Secretary related to an adverse decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cf04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cf05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Division","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Division” means the National Appeals Division established by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cf06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “hearing officer” means an individual employed by the Division who hears and determines appeals of adverse decisions by any agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cf07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “implement” refers to those actions necessary to effectuate fully and promptly a final determination of the Division not later than 30 calendar days after the effective date of the final determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cf08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6991/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “participant” shall have the meaning given that term by the Secretary by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff8cf09-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s271"},"text":"Pub. L. 103–354, title II, § 271","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3228"},"text":"108 Stat. 3228","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII"},"text":"Pub. L. 115–334, title XII","children":[],"tail":", §§ 12404(b)(2), 12410(c)(2)(B), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4975"},"text":"132 Stat. 4975","children":[],"tail":", 4978.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff8cf0a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff8cf0b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideff8cf0c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this subtitle”, meaning subtitle H (§§ 271–283) of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3228"},"text":"108 Stat. 3228","children":[],"tail":", which enacted this subchapter, amended sections 2006 and 5101 to 5106 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s2202e"},"text":"section 2202e of Title 12","children":[],"tail":", Banks and Banking, and repealed sections 1433e and 1983b of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in par. (6), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3209"},"text":"108 Stat. 3209","children":[],"tail":", known as the Department of Agriculture Reorganization Act of 1994. For complete classification of title II to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6901"},"text":"section 6901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideff8cf0d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12404/b/2"},"text":"Pub. L. 115–334, § 12404(b)(2)","children":[],"tail":", substituted “Farm” for “Consolidated Farm” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12410/c/2/B"},"text":"Pub. L. 115–334, § 12410(c)(2)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6936/b"},"text":"section 6936(b) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6962/b"},"text":"section 6962(b) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
