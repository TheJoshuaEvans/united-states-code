{"tag":"section","attrib":{"id":"idf04eb784-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9053"},"text":null,"children":[{"tag":"num","attrib":{"value":"9053"},"text":"§ 9053.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dairy margin coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04eb785-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9053/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall continue to administer a dairy margin coverage program for dairy producers under which participating dairy operations are paid a dairy margin coverage payment when actual dairy production margins are less than the threshold levels for a dairy margin coverage payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb786-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9053/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subpart A of part 1430 of title 7, Code of Federal Regulations (as in effect on ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":"), shall remain in effect for dairy margin coverage beginning with the 2019 calendar year, except to the extent that the regulations are inconsistent with any provision of this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04eb787-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1403"},"text":"Pub. L. 113–79, title I, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/689"},"text":"128 Stat. 689","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1401/k/4"},"text":"Pub. L. 115–334, title I, § 1401(k)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4516"},"text":"132 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04eb788-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04eb789-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf04eb78a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/649"},"text":"128 Stat. 649","children":[],"tail":", known as the Agricultural Act of 2014. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04eb78b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/4/B"},"text":"Pub. L. 115–334, § 1401(k)(4)(B)","children":[],"tail":"–(D), designated existing provisions as subsec. (a), inserted heading, substituted “The Secretary shall continue to administer a dairy margin coverage program” for “Not later than "},{"tag":"date","attrib":{"date":"2014-09-01"},"text":"September 1, 2014","children":[],"tail":", the Secretary shall establish and administer a margin protection program”, substituted “dairy margin coverage payment” for “margin protection payment” in two places, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/4/A"},"text":"Pub. L. 115–334, § 1401(k)(4)(A)","children":[],"tail":", substituted “Dairy margin coverage” for “Establishment of margin protection program for dairy producers” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf04eb78c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf04eb78d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/m"},"text":"section 1401(m) of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag"