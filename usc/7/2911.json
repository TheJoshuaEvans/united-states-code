{"tag":"section","attrib":{"id":"idef8ffbaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2911"},"text":null,"children":[{"tag":"num","attrib":{"value":"2911"},"text":"§ 2911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this chapter. Sums appropriated to carry out this chapter shall not be available for payment of the expenses or expenditures of the Board or the Committee in administering any provisions of the order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2903/b"},"text":"section 2903(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef8ffbab-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/294/s12"},"text":"Pub. L. 94–294, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-28"},"text":"May 28, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/535"},"text":"90 Stat. 535","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1601/b"},"text":"Pub. L. 99–198, title XVI, § 1601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1606"},"text":"99 Stat. 1606","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8ffbac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef8ffbad-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"