{"tag":"section","attrib":{"id":"ideec2e7d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1510"},"text":null,"children":[{"tag":"num","attrib":{"value":"1510"},"text":"§ 1510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit and investment of funds; Federal Reserve banks as fiscal agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All money of the Corporation not otherwise employed may be deposited with the Treasurer of the United States or in any bank approved by the Secretary of the Treasury, subject to withdrawal by the Corporation at any time, or with the approval of the Secretary of the Treasury may be invested in obligations of the United States or in obligations guaranteed as to principal and interest by the United States. Subject to the approval of the Secretary of the Treasury, the Federal Reserve banks are hereby authorized and directed to act as depositories, custodians, and fiscal agents for the Corporation in the performance of its powers conferred by this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideec2e7d1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title V, § 510, "},{"tag":"ref","attrib":{"href":"/us/stat/52/75"},"text":"52 Stat. 75","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXII/s12033/c/2/B"},"text":"Pub. L. 110–234, title XII, § 12033(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1405"},"text":"122 Stat. 1405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XII, § 12033(c)(2)(B), "},{"tag":"date","attrib":{"date":"2008-06-18"},"