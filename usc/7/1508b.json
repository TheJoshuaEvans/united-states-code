{"tag":"section","attrib":{"id":"ideec2e79c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1508b"},"text":"§ 1508b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stacked Income Protection Plan for producers of upland cotton","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideec2e79d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning not later than the 2015 crop of upland cotton, the Corporation shall make available to producers of upland cotton an additional policy (to be known as the “Stacked Income Protection Plan”), which shall provide coverage consistent with the Group Risk Income Protection Plan (and the associated Harvest Revenue Option Endorsement) offered by the Corporation for the 2011 crop year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideec2e79e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Corporation may modify the Stacked Income Protection Plan on a program-wide basis, except that the Stacked Income Protection Plan shall comply with the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideec2e79f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide coverage for revenue loss of not less than 10 percent and not more than 30 percent of expected county revenue, specified in increments of 5 percent. The deductible shall be the minimum percent of revenue loss at which indemnities are triggered under the plan, not to be less than 10 percent of the expected county revenue.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e7a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Be offered to producers of upland cotton in all counties with upland cotton production—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideec2e7a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a county-wide level to the fullest extent practicable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec2e7a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in counties that lack sufficient data, on the basis of such larger geographical area as the Corporation determines to provide sufficient data for purposes of providing the coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e7a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Be purchased in addition to any other individual or area coverage in effect on the producer’s acreage or as a stand-alone policy, except that if a producer has an individual or area coverage for the same acreage, the maximum coverage available under the Stacked Income Protection Plan shall not exceed the deductible for the individual or area coverage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e7a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Establish coverage based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideec2e7a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected price established under existing Group Risk Income Protection or area wide policy offered by the Corporation for the applicable county (or area) and crop year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec2e7a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an expected county yield that is the higher of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideec2e7a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expected county yield established for the existing area-wide plans offered by the Corporation for the applicable county (or area) and crop year (or, in geographic areas where area-wide plans are not offered, an expected yield determined in a manner consistent with those of area-wide plans); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideec2e7a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average of the applicable yield data for the county (or area) for the most recent 5 years, excluding the highest and lowest observations, from the Risk Management Agency or the National Agricultural Statistics Service (or both) or, if sufficient county data is not available, such other data considered appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e7a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use a multiplier factor to establish maximum protection per acre (referred to as a “protection factor”) of not less than the higher of the level established on a program wide basis or 120 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e7aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pay an indemnity based on the amount that the expected county revenue exceeds the actual county revenue, as applied to the individual coverage of the producer. Indemnities under the Stacked Income Protection Plan shall not include or overlap the amount of the deductible selected under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e7ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In all counties for which data are available, establish separate coverage levels for irrigated and nonirrigated practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideec2e7ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1508/d"},"text":"section 1508(d) of this title","children":[],"tail":", the premium for the Stacked Income Protection Plan shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideec2e7ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be sufficient to cover anticipated losses and a reasonable reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e7ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an amount for operating and administrative expenses established in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1508/k/4/F"},"text":"section 1508(k)(4)(F) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideec2e7af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of portion of premium by corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1508/e/4"},"text":"section 1508(e)(4) of this title","children":[],"tail":", the amount of premium paid by the Corporation for all qualifying coverage levels of the Stacked Income Protection Plan shall be—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideec2e7b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent of the amount of the premium established under subsection (c) for the coverage level selected; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e7b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount determined under subsection (c)(2), subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1508/k/4/F"},"text":"section 1508(k)(4)(F) of this title","children":[],"tail":", for the coverage to cover administrative and operating expenses."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideec2e7b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other coverages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Stacked Income Protection Plan is in addition to all other coverages available to producers of upland cotton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideec2e7b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective beginning with the 2019 crop year, a farm shall not be eligible for the Stacked Income Protection Plan for upland cotton for a crop year for which the farm is enrolled in coverage for seed cotton under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideec2e7b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" price loss coverage under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9016"},"text":"section 9016 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e7b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agriculture risk coverage under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9017"},"text":"section 9017 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideec2e7b6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title V, § 508B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tXI/s11017/a"},"text":"Pub. L. 113–79, title XI, § 11017(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/964"},"text":"128 Stat. 964","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dF/s60101/a/10"},"text":"Pub. L. 115–123, div. F, § 60101(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/310"},"text":"132 Stat. 310","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideec2e7b7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideec2e7b8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideec2e7b9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
