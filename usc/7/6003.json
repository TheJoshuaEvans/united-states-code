{"tag":"section","attrib":{"id":"idefd9d5c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6003"},"text":null,"children":[{"tag":"num","attrib":{"value":"6003"},"text":"§ 6003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd9d5c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To effectuate the declared policy of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6001/b"},"text":"section 6001(b) of this title","children":[],"tail":", the Secretary shall, subject to this chapter, issue and from time to time amend, plans applicable to growers, grower-shellers, shellers, first handlers, and importers of pecans. Any such plan shall be national in scope. Not more than one plan shall be in effect under this chapter at any one time."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd9d5c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd9d5c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6003/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposal for issuance of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may propose the issuance of a plan under this chapter, or an association of pecan growers or grower-shellers or any other person that will be affected by this chapter may request the issuance of, and submit a proposal for, such a plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6003/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proposed plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the receipt of a request and proposal by an interested person for a plan, or when the Secretary determines to propose a plan, the Secretary shall publish a proposed plan and give due notice and opportunity for public comment on the proposed plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6003/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for public comment are given, as provided in paragraph (2), the Secretary shall issue a plan, taking into consideration the comments received and including in the plan provisions necessary to ensure that the plan is in conformity with the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6003/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such plan shall be issued and become effective not later than 150 days following publication of the proposed plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd9d5cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6003/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, from time to time, may amend any plan issued under this section. The provisions of this chapter applicable to a plan shall be applicable to amendments to a plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd9d5cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1908"},"text":"Pub. L. 101–624, title XIX, § 1908","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3841"},"text":"104 Stat. 3841","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
