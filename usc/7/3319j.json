{"tag":"section","attrib":{"id":"idefaa39f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j"},"text":null,"children":[{"tag":"num","attrib":{"value":"3319j"},"text":"§ 3319j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Borlaug International Agricultural Science and Technology Fellowship Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefaa39f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefaa39fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a fellowship program, to be known as the “Borlaug International Agricultural Science and Technology Fellowship Program,” to provide fellowships for scientific training and study in the United States to individuals from eligible countries (as described in subsection (b)) who specialize in agricultural education, research, and extension.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaa39fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out the fellowship program by implementing 3 programs designed to assist individual fellowship recipients, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefaa39fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a graduate studies program in agriculture to assist individuals who participate in graduate agricultural degree training at a United States institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa39fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual career improvement program to assist agricultural scientists from developing countries in upgrading skills and understanding in agricultural science and technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa39fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Borlaug agricultural policy executive leadership course to assist senior agricultural policy makers from eligible countries, with an initial focus on individuals from sub-Saharan Africa and the independent states of the former Soviet Union.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefaa39ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible country is a developing country, as determined by the Secretary using a gross national income per capita test selected by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefaa3a00-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of fellowships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A fellowship provided under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefaa3a01-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promote food security and economic growth in eligible countries by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefaa3a02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educating a new generation of agricultural scientists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa3a03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing scientific knowledge and collaborative research to improve agricultural productivity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa3a04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extending that knowledge to users and intermediaries in the marketplace; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaa3a05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefaa3a06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and collaborative research opportunities through exchanges for entry level international agricultural research scientists, faculty, and policymakers from eligible countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa3a07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborative research to improve agricultural productivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa3a08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transfer of new science and agricultural technologies to strengthen agricultural practice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa3a09-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction of barriers to technology adoption; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa3a0a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development of agricultural extension services in eligible countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefaa3a0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fellowship recipients","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefaa3a0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible candidates","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may provide fellowships under this section to individuals from eligible countries who specialize or have experience in agricultural education, research, extension, or related fields, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefaa3a0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals from the public and private sectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefaa3a0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private agricultural producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaa3a0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Candidate identification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use the expertise of United States land-grant colleges and universities and similar universities, international organizations working in agricultural research and outreach, and national agricultural research organizations to help identify program candidates for fellowships under this section from the public and private sectors of eligible countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefaa3a10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fellowships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A fellowship provided under this section shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefaa3a11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote collaborative programs among agricultural professionals of eligible countries, agricultural professionals of the United States, the international agricultural research system, and, as appropriate, United States entities conducting research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaa3a12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support fellowship recipients through programs described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefaa3a13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program implementation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefaa3a14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the management, coordination, evaluation, and monitoring of the Borlaug International Agricultural Science and Technology Fellowship Program and for the individual programs described in subsection (a)(2), except that the Secretary may contract out to 1 or more collaborating universities the management of 1 or more of the fellowship programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaa3a15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leveraging alumni engagement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the purposes and programs under this section, the Secretary shall encourage ongoing engagement with fellowship recipients who have completed training under the program to provide advice regarding, and participate in, new or ongoing agricultural development projects, with a priority for capacity-building projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefaa3a16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3319j/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefaa3a17-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1473G"},"text":"Pub. L. 95–113, title XIV, § 1473G","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7139"},"text":"Pub. L. 110–234, title VII, § 7139","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1231"},"text":"122 Stat. 1231","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7139, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1992; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIII/s3306"},"text":"Pub. L. 115–334, title III, § 3306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4620"},"text":"132 Stat. 4620","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefaa3a18-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefaa3a19-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefaa3a1a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefaa3a1b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3306/1/A"},"text":"Pub. L. 115–334, § 3306(1)(A)","children":[],"tail":", struck out “shall” before “support—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3306/1/B"},"text":"Pub. L. 115–334, § 3306(1)(B)","children":[],"tail":"–(D), added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s3306/2"},"text":"Pub. L. 115–334, § 3306(2)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefaa3a1c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefaa3a1d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
