{"tag":"section","attrib":{"id":"ideef9ae6c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738f"},"text":"§ 1738f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Environmental framework agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef9ae6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President is authorized to enter into an environmental framework agreement with each country eligible for benefits from the Facility concerning the operation and use of an Enterprise for the Americas Environmental Fund (hereafter referred to in this subchapter as the “Environmental Fund”) established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738g"},"text":"section 1738g of this title","children":[],"tail":" for that country. The President shall consult with the Board established under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738i"},"text":"section 1738i of this title","children":[],"tail":" when entering into such agreements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9ae6e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An environmental framework agreement entered into under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef9ae6f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the eligible country to establish an Environmental Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae70-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the eligible country to make interest payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738g/a"},"text":"section 1738g(a) of this title","children":[],"tail":" into the Environmental Fund;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae71-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the eligible country to make prompt disbursements from the Environmental Fund to the body described in subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where appropriate, seek to maintain the value of the local currency resources deposited into the appropriate Environmental Fund in terms of United States dollars;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738k"},"text":"section 1738k of this title","children":[],"tail":", the purposes for which the Environmental Fund may be used; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain reasonable provisions for the enforcement of the terms of the agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9ae75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administering body","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds disbursed from the Environmental Fund in an eligible country shall be administered by a body constituted under the laws of the country. Such body shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideef9ae76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideef9ae77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more representatives appointed by the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef9ae78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more representatives appointed by the eligible country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideef9ae79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives from a broad range of environmental and local community development nongovernmental organizations of the host country;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the majority of which shall be local representatives from nongovernmental organizations, and scientific or academic bodies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive proposals for grant assistance from local organizations, and make grants to such organizations in accordance with the priorities agreed upon in the framework agreement and consistent with the overall purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738k"},"text":"section 1738k of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for the management of the program and oversight of grant activities funded from resources of the Environmental Fund;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to fiscal audits by an independent auditor on an annual basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present an annual program for review by the Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738i"},"text":"section 1738i of this title","children":[],"tail":" each year;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present an annual report on the activities undertaken during the previous year to the Chairman of the Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738i"},"text":"section 1738i of this title","children":[],"tail":", and the government of the eligible country each year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideef9ae7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738f/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have any grant over $100,000 be subject to veto by the United States and the government of the eligible country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef9ae80-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title VI, § 607, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3659"},"text":"104 Stat. 3659","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s305"},"text":"Pub. L. 102–237, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1855"},"text":"105 Stat. 1855","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideef9ae81-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideef9ae82-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideef9ae83-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" moved closing quotation marks in parenthetical phrase from after “Environmental” to after “Fund”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"ideef9ae84-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"ideef9ae85-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For delegation of functions of President under this section, see section 2 of Ex. Ord. No. 13345, ","children":[{"tag":"date","attrib":{"date":"2004-07-08"},"text":"July 8, 2004","children":[],"tail":", 69 F.R. 41901, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738"},"text":"section 1738 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
