{"tag":"section","attrib":{"id":"idef1fd40f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1993"},"text":null,"children":[{"tag":"num","attrib":{"value":"1993"},"text":"§ 1993.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transition to private commercial or other sources of credit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef1fd410-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1993/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making or insuring a farm loan under subchapter I or II, the Secretary shall establish a plan and promulgate regulations (including performance criteria) that promote the goal of transitioning borrowers to private commercial credit and other sources of credit in the shortest period of time practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef1fd411-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1993/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall integrate and coordinate the transition policy described in subsection (a) with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef1fd412-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1993/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the borrower training program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2006a"},"text":"section 2006a of this title","children":[],"tail":";"}],"tail":"\n"}],"t