{"tag":"section","attrib":{"id":"idef841499-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2426"},"text":null,"children":[{"tag":"num","attrib":{"value":"2426"},"text":"§ 2426.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidential status of application","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Applications for plant variety protection and their contents shall be kept in confidence by the Plant Variety Protection Office, by the Board, and by the offices in the Department of Agriculture to which access may be given under regulations. No information concerning the same shall be given without the authority of the owner, unless necessary under special circumstances as may be determined by the Secretary, except that the Secretary may publish the variety names designated in applications, stating the kind to which each applies, the name of the applicant, and whether the applicant specified that the variety is to be sold by variety name only as a class of certified seed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef84149a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tII/s56"},"text":"Pub. L. 91–577, title II, § 56","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1549"},"text":"84 Stat. 1549","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/574/s12"},"text":"Pub. L. 96–574, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3350"},"text":"94 Stat. 3350","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef84149b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef84149c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef84149d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/574"},"text":"Pub. L. 96–574","children":[],"tail":" inserted provisions relating to name of applicant and sale of the variety."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
