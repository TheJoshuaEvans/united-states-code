{"tag":"section","attrib":{"id":"ideee1e11d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p"},"text":null,"children":[{"tag":"num","attrib":{"value":"1639p"},"text":"§ 1639p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and tribal plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideee1e11e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e11f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or Indian tribe desiring to have primary regulatory authority over the production of hemp in the State or territory of the Indian tribe shall submit to the Secretary, through the State department of agriculture (in consultation with the Governor and chief law enforcement officer of the State) or the Tribal government, as applicable, a plan under which the State or Indian tribe monitors and regulates that production as described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e120-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State or Tribal plan referred to in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e121-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall only be required to include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee1e122-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a practice to maintain relevant information regarding land on which hemp is produced in the State or territory of the Indian tribe, including a legal description of the land, for a period of not less than 3 calendar years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e123-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a procedure for testing, using post-decarboxylation or other similarly reliable methods, delta-9 tetrahydrocannabinol concentration levels of hemp produced in the State or territory of the Indian tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e124-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a procedure for the effective disposal of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideee1e125-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plants, whether growing or not, that are produced in violation of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideee1e126-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" products derived from those plants;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e127-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a procedure to comply with the enforcement procedures under subsection (e);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e128-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a procedure for conducting annual inspections of, at a minimum, a random sample of hemp producers to verify that hemp is not produced in violation of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e129-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a procedure for submitting the information described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1639q/d/2"},"text":"section 1639q(d)(2) of this title","children":[],"tail":", as applicable, to the Secretary not more than 30 days after the date on which the information is received; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e12a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the State or Indian tribe has the resources and personnel to carry out the practices and procedures described in clauses (i) through (vi); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e12b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include any other practice or procedure established by a State or Indian tribe, as applicable, to the extent that the practice or procedure is consistent with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e12c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to State and tribal law","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e12d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No preemption","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection preempts or limits any law of a State or Indian tribe that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee1e12e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulates the production of hemp; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e12f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is more stringent than this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e130-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References in plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State or Tribal plan referred to in paragraph (1) may include a reference to a law of the State or Indian tribe regulating the production of hemp, to the extent that law is consistent with this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e131-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e132-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after receipt of a State or Tribal plan under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e133-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve the State or Tribal plan if the State or Tribal plan complies with subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e134-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disapprove the State or Tribal plan only if the State or Tribal plan does not comply with subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e135-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amended plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary disapproves a State or Tribal plan under paragraph (1)(B), the State, through the State department of agriculture (in consultation with the Governor and chief law enforcement officer of the State) or the Tribal government, as applicable, may submit to the Secretary an amended State or Tribal plan that complies with subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e136-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Attorney General in carrying out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e137-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit of State compliance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e138-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may conduct an audit of the compliance of a State or Indian tribe with a State or Tribal plan approved under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e139-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines under an audit conducted under paragraph (1) that a State or Indian tribe is not materially in compliance with a State or Tribal plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e13a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall collaborate with the State or Indian tribe to develop a corrective action plan in the case of a first instance of noncompliance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e13b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may revoke approval of the State or Tribal plan in the case of a second or subsequent instance of noncompliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e13c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance to a State or Indian tribe in the development of a State or Tribal plan under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e13d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e13e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A violation of a State or Tribal plan approved under subsection (b) shall be subject to enforcement solely in accordance with this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e13f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Negligent violation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e140-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A hemp producer in a State or the territory of an Indian tribe for which a State or Tribal plan is approved under subsection (b) shall be subject to subparagraph (B) of this paragraph if the State department of agriculture or Tribal government, as applicable, determines that the hemp producer has negligently violated the State or Tribal plan, including by negligently—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee1e141-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failing to provide a legal description of land on which the producer produces hemp;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e142-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failing to obtain a license or other required authorization from the State department of agriculture or Tribal government, as applicable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e143-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" producing Cannabis sativa L. with a delta-9 tetrahydrocannabinol concentration of more than 0.3 percent on a dry weight basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e144-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corrective action plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A hemp producer described in subparagraph (A) shall comply with a plan established by the State department of agriculture or Tribal government, as applicable, to correct the negligent violation, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee1e145-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable date by which the hemp producer shall correct the negligent violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e146-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that the hemp producer shall periodically report to the State department of agriculture or Tribal government, as applicable, on the compliance of the hemp producer with the State or Tribal plan for a period of not less than the next 2 calendar years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e147-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Result of negligent violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A hemp producer that negligently violates a State or Tribal plan under subparagraph (A) shall not as a result of that violation be subject to any criminal enforcement action by the Federal Government or any State government, Tribal government, or local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e148-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeat violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A hemp producer that negligently violates a State or Tribal plan under subparagraph (A) 3 times in a 5-year period shall be ineligible to produce hemp for a period of 5 years beginning on the date of the third violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e149-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other violations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee1e14a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the State department of agriculture or Tribal government in a State or the territory of an Indian tribe for which a State or Tribal plan is approved under subsection (b), as applicable, determines that a hemp producer in the State or territory has violated the State or Tribal plan with a culpable mental state greater than negligence—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee1e14b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the State department of agriculture or Tribal government, as applicable, shall immediately report the hemp producer to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"ideee1e14c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideee1e14d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chief law enforcement officer of the State or Indian tribe, as applicable; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e14e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1) of this subsection shall not apply to the violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e14f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Felony","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee1e150-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in clause (ii), any person convicted of a felony relating to a controlled substance under State or Federal law before, on, or after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", shall be ineligible, during the 10-year period following the date of the conviction—"}],"tail":null},{"tag":"subclause","attrib":{"id":"ideee1e151-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to participate in the program established under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1639q"},"text":"section 1639q of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"ideee1e152-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to produce hemp under any regulations or guidelines issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1639r/a"},"text":"section 1639r(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee1e153-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i) shall not apply to any person growing hemp lawfully with a license, registration, or authorization under a pilot program authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5940"},"text":"section 5940 of this title","children":[],"tail":" before "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee1e154-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False statement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who materially falsifies any information contained in an application to participate in the program established under this section shall be ineligible to participate in that program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e155-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section prohibits the production of hemp in a State or the territory of an Indian tribe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee1e156-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which a State or Tribal plan is not approved under this section, if the production of hemp is in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1639q"},"text":"section 1639q of this title","children":[],"tail":" or other Federal laws (including regulations); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee1e157-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639p/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the production of hemp is not otherwise prohibited by the State or Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideee1e158-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 297B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10113"},"text":"Pub. L. 115–334, title X, § 10113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4909"},"text":"132 Stat. 4909","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
