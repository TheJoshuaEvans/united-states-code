{"tag":"section","attrib":{"id":"idefc933ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5607"},"text":null,"children":[{"tag":"num","attrib":{"value":"5607"},"text":"§ 5607.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exporter assistance initiative","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To provide a comprehensive source of information to facilitate exports of United States agricultural commodities, the Secretary shall maintain on a website on the Internet information to assist exporters and potential exporters of United States agricultural commodities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefc933ac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tI/s107"},"text":"Pub. L. 95–501, title I, § 107","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIII/s3101"},"text":"Pub. L. 107–171, title III, § 3101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/288"},"text":"116 Stat. 288","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
