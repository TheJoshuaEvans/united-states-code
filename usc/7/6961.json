{"tag":"section","attrib":{"id":"ideff6853b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6961"},"text":null,"children":[{"tag":"num","attrib":{"value":"6961"},"text":"§ 6961.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Under Secretary of Agriculture for Natural Resources and Environment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff6853c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6961/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish in the Department the position of Under Secretary of Agriculture for Natural Resources and Environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff6853d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6961/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confirmation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary establishes the position of Under Secretary of Agriculture for Natural Resources and Environment authorized under subsection (a), the Under Secretary shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff6853e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6961/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Under Secretary","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff6853f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6961/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon establishment, the Secretary shall delegate to the Under Secretary of Agriculture for Natural Resources and Environment those functions under the jurisdiction of the Department that are related to natural resources and environment (except to the extent those functions are delegated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6932"},"text":"section 6932 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff68540-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6961/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary of Agriculture for Natural Resources and Environment shall perform such other functions and duties as may be required by law or prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff68541-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6961/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Succession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any official who is serving as Assistant Secretary of Agriculture for Natural Resources and Environment on ","children":[{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":", and who was appointed by the President, by and with the advice and consent of the Senate, shall not be required to be reappointed under subsection (b) to the successor position authorized under subsection (a) if the Secretary establishes the position, and the official occupies the new position, within 180 days after "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"October 13, 1994","children":[],"tail":" (or such later date set by the Secretary if litigation delays rapid succession)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff68542-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s245"},"text":"Pub. L. 103–354, title II, § 245","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3223"},"text":"108 Stat. 3223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff68543-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff68544-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideff68545-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s245"},"text":"section 245 of Pub. L. 103–354","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/s245"},"text":"section 245 of Pub. L. 103–354","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
