{"tag":"section","attrib":{"id":"idef734bea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204d"},"text":null,"children":[{"tag":"num","attrib":{"value":"2204d"},"text":"§ 2204d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouragement of private contracting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef734beb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of promoting local job creation and private sector investment in rural communities, the Secretary of Agriculture is encouraged, where appropriate and feasible, to use private enterprise concerns located in rural areas, rather than government employees or government enterprises, to provide commercial activities or products to carry out the purposes of this title.","children":[{"tag":"ref","attrib":{"idref":"fn002253"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002253"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734bec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and implement a plan that will result in increasing the use of contracts awarded to private firms by the Department of Agriculture, and maximizing the use of grant, loan, or other financial assistance made for the purpose of rural development to provide the goods and services purchased to carry out the purposes of this title.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef734bed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2394"},"text":"Pub. L. 101–624, title XXIII, § 2394","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4057"},"text":"104 Stat. 4057","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef734bee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef734bef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef734bf0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in text, is title XXIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3979"},"text":"104 Stat. 3979","children":[],"tail":", known as the Rural Economic Development Act of 1990. For complete classification of this Act to the Code, see Short Title of 1990 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
