{"tag":"section","attrib":{"id":"idf02adc34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7998"},"text":null,"children":[{"tag":"num","attrib":{"value":"7998"},"text":"§ 7998.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimates of net farm income","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In each issuance of projections of net farm income, the Secretary shall include (as determined by the Secretary)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adc35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7998/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the net farm income earned by commercial producers in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adc36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7998/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an estimate of the net farm income attributable to commercial producers of each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02adc37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7998/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Livestock.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7998/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Loan commodities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02adc39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7998/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Agricultural commodities other than loan commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02adc3a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1615"},"text":"Pub. L. 107–171, title I, § 1615","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/222"},"text":"116 Stat. 222","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
