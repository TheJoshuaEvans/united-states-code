{"tag":"section","attrib":{"id":"idf00e532c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482"},"text":null,"children":[{"tag":"num","attrib":{"value":"7482"},"text":"§ 7482.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter (unless the context otherwise requires):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e532d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Popcorn Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7484/b"},"text":"section 7484(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e532e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commerce” means interstate, foreign, or intrastate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e532f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumer information” means information and programs that will assist consumers and other persons in making evaluations and decisions regarding the purchase, preparation, and use of popcorn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5330-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5331-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “industry information” means information or a program that will lead to the development of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00e5332-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new markets, new marketing strategies, or increased efficiency for the popcorn industry; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e5333-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities to enhance the image of the popcorn industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5334-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marketing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “marketing” means the sale or other disposition of unpopped popcorn for human consumption in a channel of commerce, but does not include a sale or disposition to or between processors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5335-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “order” means an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7483"},"text":"section 7483 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5336-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means an individual, group of individuals, partnership, corporation, association, or cooperative, or any other legal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5337-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Popcorn","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “popcorn” means unpopped popcorn (Zea Mays L) that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00e5338-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commercially grown;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e5339-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processed in the United States by shelling, cleaning, or drying; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e533a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" introduced into a channel of commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e533b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “process” means to shell, clean, dry, and prepare popcorn for the market, but does not include packaging popcorn for the market without also engaging in another activity described in this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e533c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “processor” means a person engaged in the preparation of unpopped popcorn for the market who owns or shares the ownership and risk of loss of the popcorn and who processes and distributes over 4,000,000 pounds of popcorn in the market per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e533d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “promotion” means an action, including paid advertising, to enhance the image or desirability of popcorn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e533e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “research” means any type of study to advance the image, desirability, marketability, production, product development, quality, or nutritional value of popcorn.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e533f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5340-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the 50 States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5341-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7482/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means all of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00e5342-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s573"},"text":"Pub. L. 104–127, title V, § 573","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1075"},"text":"110 Stat. 1075","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
