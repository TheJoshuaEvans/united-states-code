{"tag":"section","attrib":{"id":"idefd51abd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c"},"text":null,"children":[{"tag":"num","attrib":{"value":"5925c"},"text":"§ 5925c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organic production and market data initiatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd51abe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall collect and report data on the production and marketing of organic agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51abf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a), the Secretary shall, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd51ac0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect and distribute comprehensive reporting of prices relating to organically produced agricultural products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51ac1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct surveys and analysis and publish reports relating to organic production, handling, distribution, retail, and trend studies (including consumer purchasing patterns); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51ac2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop surveys and report statistical analysis on organically produced agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51ac3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of this subsection and annually thereafter, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd51ac4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the progress that has been made in implementing this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51ac5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how data collection agencies (such as the Agricultural Marketing Service and the National Agricultural Statistics Service) are coordinating with data user agencies (such as the Risk Management Agency) to ensure that data collected under this section can be used by data user agencies, including by the Risk Management Agency to offer price elections for all organic crops; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51ac6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies any additional production and marketing data needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51ac7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd51ac8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall use to carry out this section, to remain available until expended—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd51ac9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for each of the periods of fiscal years 2008 through 2012 and 2014 through 2018;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51aca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for the period of fiscal years 2019 through 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51acb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000 for fiscal year 2024; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51acc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for the period of fiscal years 2026 through 2031.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51acd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to funds made available under paragraph (1), there are authorized to be appropriated to carry out this section not more than $5,000,000 for each of fiscal years 2008 through 2023, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd51ace-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7407"},"text":"Pub. L. 107–171, title VII, § 7407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/461"},"text":"116 Stat. 461","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tX/s10302"},"text":"Pub. L. 110–234, title X, § 10302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1347"},"text":"122 Stat. 1347","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title X, § 10302, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2108; "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/tVII/s701/g/4"},"text":"Pub. L. 112–240, title VII, § 701(g)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2366"},"text":"126 Stat. 2366","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tX/s10004/a"},"text":"Pub. L. 113–79, title X, § 10004(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/941"},"text":"128 Stat. 941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10103"},"text":"Pub. L. 115–334, title X, § 10103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4898"},"text":"132 Stat. 4898","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/dB/tI/s102/d/7/A"},"text":"Pub. L. 118–22, div. B, title I, § 102(d)(7)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-11-17"},"text":"Nov. 17, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/118"},"text":"137 Stat. 118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10606/c"},"text":"Pub. L. 119–21, title I, § 10606(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/110"},"text":"139 Stat. 110","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefd51acf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefd51ad0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefd51ad1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this subsection, referred to in subsec. (c), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefd51ad2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Farm Security and Rural Investment Act of 2002, and not as part of subtitle H of title XVI of the Food, Agriculture, Conservation, and Trade Act of 1990 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefd51ad3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10103/1"},"text":"Pub. L. 115–334, § 10103(1)","children":[],"tail":", struck out “through fiscal year 2012” after “funding” in heading, substituted “, to remain available until expended—” for “$5,000,000, to remain available until expended.”, and added subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10103/2"},"text":"Pub. L. 115–334, § 10103(2)","children":[],"tail":"–(4), redesignated par. (3) as (2), substituted “paragraph (1)” for “paragraphs (1) and (2)” and “2023” for “2018”, and struck out former par. (2) which related to mandatory funding."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s10004/a/1"},"text":"Pub. L. 113–79, § 10004(a)(1)","children":[],"tail":", inserted “and annually thereafter” after “this subsection” in introductory provisions, added par. (2), and redesignated former par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s10004/a/2"},"text":"Pub. L. 113–79, § 10004(a)(2)","children":[],"tail":", added par. (2), redesignated former par. (2) as (3), struck out “for fiscal years 2008 through 2012” after “Discretionary funding” in heading and substituted “paragraphs (1) and (2)” for “paragraph (1)” and “2018” for “2012” in text, and struck out former par. (3). Prior to amendment, text read as follows: “There is authorized to be appropriated to carry out this section $5,000,000, to remain available until expended.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240/s701/g/4/A"},"text":"Pub. L. 112–240, § 701(g)(4)(A)","children":[],"tail":", substituted “Mandatory funding through fiscal year 2012” for “In general” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240/s701/g/4/B"},"text":"Pub. L. 112–240, § 701(g)(4)(B)","children":[],"tail":", substituted “Discretionary funding for fiscal years 2008 through 2012” for “Additional funding” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240/s701/g/4/C"},"text":"Pub. L. 112–240, § 701(g)(4)(C)","children":[],"tail":", added par. (3)"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s10302"},"text":"Pub. L. 110–246, § 10302","children":[],"tail":", amended section generally. Prior to amendment, text read as follows: “The Secretary shall ensure that segregated data on the production and marketing of organic agricultural products is included in the ongoing baseline of data collection regarding agricultural production and marketing.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefd51ad4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefd51ad5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" to be applied and administered as if enacted on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/g"},"text":"section 102(g) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefd51ad6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/240"},"text":"Pub. L. 112–240","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-09-30"},"text":"Sept. 30, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/s701/j"},"text":"section 701(j) of Pub. L. 112–240","children":[],"tail":", set out in a 1-Year Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefd51ad7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idefd51ad8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7401/1"},"text":"section 7401(1) of Pub. L. 107–171","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3319b"},"text":"section 3319b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
