{"tag":"section","attrib":{"id":"idef2970e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009b"},"text":"§ 2009b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National objectives","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The national objectives of the program established under this subchapter shall be to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2970e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote strategic development activities and collaborative efforts by State and local communities, and federally recognized Indian tribes, to maximize the impact of Federal assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2970e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" optimize the use of resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2970e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide assistance in a manner that reflects the complexity of rural needs, including the needs for business development, health care, education, infrastructure, cultural resources, the environment, and housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2970e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance activities that empower, and build the capacity of, State and local communities to design unique responses to the special needs of the State and local communities, and federally recognized Indian tribes, for rural development assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2970ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt flexible and innovative approaches to solving rural development problems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef2970eb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s381C"},"text":"Pub. L. 87–128, title III, § 381C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s761"},"text":"Pub. L. 104–127, title VII, § 761","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1139"},"text":"110 Stat. 1139","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
