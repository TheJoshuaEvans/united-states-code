{"tag":"section","attrib":{"id":"idede04f9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a"},"text":null,"children":[{"tag":"num","attrib":{"value":"24a"},"text":"§ 24a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Swap data repositories","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idede04f9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idede04f9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement; authority of derivatives clearing organization","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idede04fa0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person, unless registered with the Commission, directly or indirectly to make use of the mails or any means or instrumentality of interstate commerce to perform the functions of a swap data repository.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fa1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of derivatives clearing organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A derivatives clearing organization may register as a swap data repository.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fa2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection and examination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each registered swap data repository shall be subject to inspection and examination by any representative of the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fa3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with core principles","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idede04fa4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be registered, and maintain registration, as a swap data repository, the swap data repository shall comply with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idede04fa5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements and core principles described in this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idede04fa6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any requirement that the Commission may impose by rule or regulation pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s12a/5"},"text":"section 12a(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fa7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reasonable discretion of swap data repository","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise determined by the Commission by rule or regulation, a swap data repository described in subparagraph (A) shall have reasonable discretion in establishing the manner in which the swap data repository complies with the core principles described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idede04fa8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standard setting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idede04fa9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data identification","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idede04faa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with subparagraph (B), the Commission shall prescribe standards that specify the data elements for each swap that shall be collected and maintained by each registered swap data repository.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subparagraph (A), the Commission shall prescribe consistent data element standards applicable to registered entities and reporting counterparties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data collection and maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall prescribe data collection and data maintenance standards for swap data repositories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The standards prescribed by the Commission under this subsection shall be comparable to the data standards imposed by the Commission on derivatives clearing organizations in connection with their clearing of swaps.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idede04fae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A swap data repository shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idede04faf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept data prescribed by the Commission for each swap under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confirm with both counterparties to the swap the accuracy of the data that was submitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the data described in paragraph (1) in such form, in such manner, and for such period as may be required by the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idede04fb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide direct electronic access to the Commission (or any designee of the Commission, including another registered entity); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the information described in paragraph (1) in such form and at such frequency as the Commission may require to comply with the public reporting requirements contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2/a/13"},"text":"section 2(a)(13) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the direction of the Commission, establish automated systems for monitoring, screening, and analyzing swap data, including compliance and frequency of end user clearing exemption claims by individual and affiliated entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the privacy of any and all swap transaction information that the swap data repository receives from a swap dealer, counterparty, or any other registered entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on a confidential basis pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s12"},"text":"section 12 of this title","children":[],"tail":", upon request, and after notifying the Commission of the request, make available swap data obtained by the swap data repository, including individual counterparty trade and position data, to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idede04fb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each appropriate prudential regulator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fb9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Financial Stability Oversight Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Securities and Exchange Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fbb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Justice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fbc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any other person that the Commission determines to be appropriate, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idede04fbd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/7/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign financial supervisors (including foreign futures authorities);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idede04fbe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/7/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign central banks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idede04fbf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/7/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign ministries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idede04fc0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/7/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other foreign authorities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fc1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain emergency procedures, backup facilities, and a plan for disaster recovery that allows for the timely recovery and resumption of operations and the fulfillment of the responsibilities and obligations of the organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idede04fc2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the swap data repository may share information with any entity described in subsection (c)(7), the swap data repository shall receive a written agreement from each entity stating that the entity shall abide by the confidentiality requirements described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s12"},"text":"section 12 of this title","children":[],"tail":" relating to the information on swap transactions that is provided."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idede04fc3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of chief compliance officer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idede04fc4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each swap data repository shall designate an individual to serve as a chief compliance officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fc5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The chief compliance officer shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idede04fc6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report directly to the board or to the senior officer of the swap data repository;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the compliance of the swap data repository with respect to the requirements and core principles described in this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fc8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the board of the swap data repository, a body performing a function similar to the board of the swap data repository, or the senior officer of the swap data repository, resolve any conflicts of interest that may arise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fc9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for administering each policy and procedure that is required to be established pursuant to this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure compliance with this chapter (including regulations) relating to agreements, contracts, or transactions, including each rule prescribed by the Commission under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fcb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish procedures for the remediation of noncompliance issues identified by the chief compliance officer through any—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idede04fcc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance office review;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idede04fcd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" look-back;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idede04fce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/2/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" internal or external audit finding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idede04fcf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/2/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" self-reported error; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idede04fd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/2/F/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" validated complaint; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and follow appropriate procedures for the handling, management response, remediation, retesting, and closing of noncompliance issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idede04fd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with rules prescribed by the Commission, the chief compliance officer shall annually prepare and sign a report that contains a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idede04fd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compliance of the swap data repository of the chief compliance officer with respect to this chapter (including regulations); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idede04fd5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each policy and procedure of the swap data repository of the chief compliance officer (including the code of ethics and conflict of interest policies of the swap data repository).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A compliance report under subparagraph (A) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idede04fd7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accompany each appropriate financial report of the swap data repository that is required to be furnished to the Commission pursuant to this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idede04fd8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/e/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a certification that, under penalty of law, the compliance report is accurate and complete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idede04fd9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Core principles applicable to swap data repositories","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idede04fda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless necessary or appropriate to achieve the purposes of this chapter, a swap data repository shall not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idede04fdb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt any rule or take any action that results in any unreasonable restraint of trade; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fdc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose any material anticompetitive burden on the trading, clearing, or reporting of transactions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fdd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governance arrangements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each swap data repository shall establish governance arrangements that are transparent—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idede04fde-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fulfill public interest requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fdf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the objectives of the Federal Government, owners, and participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fe0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflicts of interest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each swap data repository shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idede04fe1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and enforce rules to minimize conflicts of interest in the decision-making process of the swap data repository; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fe2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a process for resolving conflicts of interest described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idede04fe3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional duties developed by Commission","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idede04fe4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission may develop 1 or more additional duties applicable to swap data repositories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fe5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of evolving standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing additional duties under subparagraph (A), the Commission may take into consideration any evolving standard of the United States or the international community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idede04fe6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/f/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional duties for Commission designees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall establish additional duties for any registrant described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a/48"},"text":"section 1a(48) of this title","children":[],"tail":" in order to minimize conflicts of interest, protect data, ensure compliance, and guarantee the safety and security of the swap data repository."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idede04fe7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required registration for swap data repositories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person that is required to be registered as a swap data repository under this section shall register with the Commission regardless of whether that person is also licensed as a bank or registered with the Securities and Exchange Commission as a swap data repository.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idede04fe8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s24a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commission shall adopt rules governing persons that are registered under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idede04fe9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s21"},"text":"Sept. 21, 1922, ch. 369, § 21","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tVII/s728"},"text":"Pub. L. 111–203, title VII, § 728","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1697"},"text":"124 Stat. 1697","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dG/tLXXXVI/s86001/b"},"text":"Pub. L. 114–94, div. G, title LXXXVI, § 86001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1797"},"text":"129 Stat. 1797","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idede04fea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idede04feb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idede04fec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 21 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369"},"text":"act Sept. 21, 1922, ch. 369","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/96/276/s7"},"text":"Pub. L. 96–276, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-17"},"text":"June 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/542"},"text":"94 Stat. 542","children":[],"tail":", related to silver markets activity and was set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4a"},"text":"section 4a of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/102/546/tIV/s402/13"},"text":"Pub. L. 102–546, title IV, § 402(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3625"},"text":"106 Stat. 3625","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idede04fed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s86001/b/1/A"},"text":"Pub. L. 114–94, § 86001(b)(1)(A)","children":[],"tail":", substituted “swap” for “all” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7)(E)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s86001/b/1/B"},"text":"Pub. L. 114–94, § 86001(b)(1)(B)","children":[],"tail":", added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s86001/b/2"},"text":"Pub. L. 114–94, § 86001(b)(2)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d) which related to confidentiality and indemnification agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idede04fee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idede04fef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective as if enacted as part of the Dodd-Frank Wall Street Reform and Consumer Protection Act, "},{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s86001/d"},"text":"section 86001(d) of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7a–1"},"text":"section 7a–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idede04ff0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the later of 360 days after ","children":[{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", or, to the extent a provision of subtitle A (§§ 711–754) of title VII of "},{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" requires a rulemaking, not less than 60 days after publication of the final rule or regulation implementing such provision of subtitle A, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s754"},"text":"section 754 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1a"},"text":"section 1a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
