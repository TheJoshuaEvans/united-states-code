{"tag":"section","attrib":{"id":"idf04c4729-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039"},"text":null,"children":[{"tag":"num","attrib":{"value":"9039"},"text":"§ 9039.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of recourse loans for high moisture feed grains and seed cotton","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04c472a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High moisture feed grains","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c472b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of high moisture state","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “high moisture state” means corn or grain sorghum having a moisture content in excess of Commodity Credit Corporation standards for marketing assistance loans made by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9031"},"text":"section 9031 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c472c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recourse loans available","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of the 2014 through 2031 crops of corn and grain sorghum, the Secretary shall make available recourse loans, as determined by the Secretary, to producers on a farm that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c472d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" normally harvest all or a portion of their crop of corn or grain sorghum in a high moisture state;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c472e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" present—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf04c472f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified scale tickets from an inspected, certified commercial scale, including a licensed warehouse, feedlot, feed mill, distillery, or other similar entity approved by the Secretary, pursuant to regulations issued by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c4730-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" field or other physical measurements of the standing or stored crop in regions of the United States, as determined by the Secretary, that do not have certified commercial scales from which certified scale tickets may be obtained within reasonable proximity of harvest operation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4731-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that the producers on the farm were the owners of the feed grain at the time of delivery to, and that the quantity to be placed under loan under this subsection was in fact harvested on the farm and delivered to, a feedlot, feed mill, or commercial or on-farm high-moisture storage facility, or to a facility maintained by the users of corn and grain sorghum in a high moisture state; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4732-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with deadlines established by the Secretary for harvesting the corn or grain sorghum and submit applications for loans under this subsection within deadlines established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4733-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of acquired feed grains","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A loan under this subsection shall be made on a quantity of corn or grain sorghum of the same crop acquired by the producer equivalent to a quantity determined by multiplying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04c4734-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acreage of the corn or grain sorghum in a high moisture state harvested on the farm of the producer; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04c4735-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lower of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf04c4736-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment yield in effect for the calculation of price loss coverage under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9015"},"text":"section 9015 of this title","children":[],"tail":", or the payment yield deemed to be in effect or established under subclause (II) or (III) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9036/b/1/B/ii"},"text":"section 9036(b)(1)(B)(ii) of this title","children":[],"tail":", with respect to corn or grain sorghum on a field that is similar to the field from which the corn or grain sorghum referred to in subparagraph (A) was obtained; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04c4737-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual yield of corn or grain sorghum on a field, as determined by the Secretary, that is similar to the field from which the corn or grain sorghum referred to in subparagraph (A) was obtained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c4738-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recourse loans available for seed cotton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of the 2014 through 2031 crops of upland cotton and extra long staple cotton, the Secretary shall make available recourse seed cotton loans, as determined by the Secretary, on any production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c4739-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recourse loans available for contaminated commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a loan commodity that is ineligible for 100 percent of the nonrecourse marketing loan rate in the county due to a determination that the commodity is contaminated yet still merchantable, for each of the 2019 through 2031 crops of such loan commodity, the Secretary shall make available recourse commodity loans, at the rate provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9032"},"text":"section 9032 of this title","children":[],"tail":", on any production."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb73a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9039/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Repayment of a recourse loan made under this section shall be at the loan rate established for the commodity by the Secretary, plus interest (determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7283"},"text":"section 7283 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04eb73b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1209"},"text":"Pub. L. 113–79, title I, § 1209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/685"},"text":"128 Stat. 685","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1205"},"text":"Pub. L. 115–334, title I, § 1205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4510"},"text":"132 Stat. 4510","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10309/f"},"text":"Pub. L. 119–21, title I, § 10309(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/94"},"text":"139 Stat. 94","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04eb73c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04eb73d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf04eb73e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions of law applicable to a loan commodity for the 2023 crop year pursuant to title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" applicable to the 2024 crop year for that loan commodity, see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/c/1"},"text":"section 102(c)(1) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04eb73f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsecs. (a)(2), (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “2031” for “2023”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsecs. (a)(2), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1205/a"},"text":"Pub. L. 115–334, § 1205(a)","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1205/b"},"text":"Pub. L. 115–334, § 1205(b)","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
