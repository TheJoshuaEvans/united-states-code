{"tag":"section","attrib":{"id":"idee1e439f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s223"},"text":null,"children":[{"tag":"num","attrib":{"value":"223"},"text":"§ 223.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility of principal for act or omission of agent","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When construing and enforcing the provisions of this chapter, the act, omission, or failure of any agent, officer, or other person acting for or employed by any packer, any swine contractor, and any live poultry dealer, stockyard owner, market agency, or dealer, within the scope of his employment or office, shall in every case also be deemed the act, omission, or failure of such packer, any swine contractor, and any live poultry dealer, stockyard owner, market agency, or dealer, as well as that of such agent, officer, or other person.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee1e43a0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title IV, § 403, "},{"tag":"ref","attrib":{"href":"/us/stat/42/168"},"text":"42 Stat. 168","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title V, § 503, as added "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch532"},"text":"Aug. 14, 1935, ch. 532","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/649"},"text":"49 Stat. 649","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/173/s6"},"text":"Pub. L. 100–173, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-23"},"text":"Nov. 23, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/918"},"text":"101 Stat. 918","children":[],"tail":"; "},{"