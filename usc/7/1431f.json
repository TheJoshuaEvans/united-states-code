{"tag":"section","attrib":{"id":"idee9f0b61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1431f"},"text":null,"children":[{"tag":"num","attrib":{"value":"1431f"},"text":"§ 1431f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to foreign countries to mitigate effects of HIV and AIDS","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"2005-11-10"},"text":"November 10, 2005","children":[],"tail":", of any shipments of commodities made pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1431/b"},"text":"section 1431(b) of this title","children":[],"tail":", the Secretary of Agriculture shall, to the extent practicable, direct that tonnage equal in value to not more than $25,000,000 shall be made available to foreign countries to assist in mitigating the effects of the Human Immunodeficiency Virus and Acquired Immune Deficiency Syndrome on communities, including the provision of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idee9f0b62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1431f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" agricultural commodities to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee9f0b63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1431f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals with Human Immunodeficiency Virus or Acquired Immune Deficiency Syndrome in the communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee9f0b64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1431f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" households in 