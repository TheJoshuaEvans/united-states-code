{"tag":"section","attrib":{"id":"idefe82d5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6521a"},"text":"§ 6521a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organic agricultural product imports interagency working group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe82d5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82d5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Secretary of Homeland Security shall jointly establish a working group to facilitate coordination and information sharing between the Department of Agriculture and U.S. Customs and Border Protection relating to imports of organically produced agricultural products (referred to in this section as the “working group”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d5f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The working group—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82d60-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe82d61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary (or a designee); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe82d62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Homeland Security (or a designee); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not include any non-Federal officer or employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The working group shall facilitate coordination and information sharing between the Department of Agriculture and U.S. Customs and Border Protection for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82d65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying imports of organically produced agricultural products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d66-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verifying the authenticity of organically produced agricultural product import documentation, such as national organic program import certificates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d67-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring imported agricultural products represented as organically produced meet the requirements under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d68-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting and organizing quantitative data on imports of organically produced agricultural products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d69-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requesting feedback from stakeholders on how to improve the oversight of imports of organically produced agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d6a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated employees and officials","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employee or official designated to carry out the duties of the Secretary or the Secretary of Homeland Security on the working group under subparagraph (A) or (B) of paragraph (2) shall be an employee or official compensated at a rate of pay not less than the minimum annual rate of basic pay for GS–12 under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe82d6b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On an annual basis, the working group shall submit to Congress and make publicly available on the websites of the Department of Agriculture and U.S. Customs and Border Protection the following reports:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe82d6c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organic trade enforcement interagency coordination report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82d6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifying existing barriers to cooperation between the agencies involved in agricultural product import inspection, trade data collection and organization, and organically produced agricultural product trade enforcement, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe82d6e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" U.S. Customs and Border Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe82d6f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agricultural Marketing Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe82d70-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Animal and Plant Health Inspection Service;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d71-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assessing progress toward integrating organic trade enforcement into import inspection procedures of U.S. Customs and Border Protection and the Animal and Plant Health Inspection Service, including an assessment of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe82d72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the status of the development of systems for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefe82d73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tracking the fumigation of imports of organically produced agricultural products into the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefe82d74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electronically verifying national organic program import certificate authenticity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe82d75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" training of U.S. Customs and Border Protection personnel on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefe82d76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of the systems described in clause (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefe82d77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements and protocols under this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing methodology for ensuring imports of agricultural products represented as organically produced meet the requirements under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommending steps to improve the documentation and traceability of imported organically produced agricultural products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommending and describing steps for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe82d7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving compliance with the requirements of this chapter for all agricultural products imported into the United States and represented as organically produced; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe82d7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring accurate labeling and marketing of imported agricultural products represented as organically produced by the exporter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describing staffing needs and additional resources at U.S. Customs and Border Protection and the Department of Agriculture needed to ensure compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe82d7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on enforcement actions taken on organic imports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe82d7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing detailed quantitative data (broken down by agricultural product, quantity, value, month, and origin) on imports of agricultural products represented as organically produced found to be fraudulent or lacking any documentation required under this chapter at the port of entry during the report year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing data on domestic enforcement actions taken on imported agricultural products represented as organically produced, including the number and type of actions taken by United States officials at ports of entry in response to violations of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing data on fumigation of agricultural products represented as organically produced at ports of entry and notifications of fumigation actions to shipment owners, broken down by product variety and country of origin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe82d82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing information on enforcement activities under this chapter involving overseas investigations and compliance actions taken within that year, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe82d83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of investigations by country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe82d84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6521a/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a descriptive summary of compliance actions taken by certifying agents in each country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe82d85-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2122A"},"text":"Pub. L. 101–624, title XXI, § 2122A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10104/i"},"text":"Pub. L. 115–334, title X, § 10104(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4902"},"text":"132 Stat. 4902","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe82d86-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefe82d87-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefe82d88-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Trade Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10104/k"},"text":"Pub. L. 115–334, title X, § 10104(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4905"},"text":"132 Stat. 4905","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tX/s10104/k"},"text":"“The amendments made by subsection (i) [enacting this section] shall be carried out in a manner consistent with United States obligations under international agreements.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
