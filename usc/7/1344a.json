{"tag":"section","attrib":{"id":"idee873d67-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1344a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1344a"},"text":"§ 1344a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of 1949 acreage in computation of future allotments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of title III of the Agricultural Adjustment Act of 1938, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1301"},"text":"7 U.S.C. 1301","children":[],"tail":" et seq.], or of any other law, State, county, and farm acreage allotments and yields for cotton for any year after 1949 shall be computed without regard to yields or to the acreage planted to cotton in 1949."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee873d68-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-03-29/ch38"},"text":"Mar. 29, 1949, ch. 38","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/17"},"text":"63 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee873d69-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee873d6a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee873d6b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Agricultural Adjustment Act of 1938, referred to in text, is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"act Feb. 16, 1938, ch. 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/31"},"text":"52 Stat. 31","children":[],"tail":". Title III of the Act is classified generally to subchapter II (§ 1301 et seq.) of this chapter. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee873d6c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Agriculture Adjustment Act of 1938 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
