{"tag":"section","attrib":{"id":"idef64f393-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035"},"text":null,"children":[{"tag":"num","attrib":{"value":"2035"},"text":"§ 2035.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simplified supplemental nutrition assistance program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef64f394-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Federal costs” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “Federal costs” does not include any Federal costs incurred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2026"},"text":"section 2026 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef64f395-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (d), a State may elect to carry out a simplified supplemental nutrition assistance program (referred to in this section as a “Program”), statewide or in a political subdivision of the State, in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef64f396-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of Program","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a State elects to carry out a Program, within the State or a political subdivision of the State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f397-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a household in which no members receive assistance under a State program funded under part A of title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.) may not participate in the Program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f398-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a household in which all members receive assistance under a State program funded under part A of title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.) shall automatically be eligible to participate in the Program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f399-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if approved by the Secretary, a household in which 1 or more members but not all members receive assistance under a State program funded under part A of title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.) may be eligible to participate in the Program; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f39a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to subsection (f), benefits under the Program shall be determined under rules and procedures established by the State under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef64f39b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State program funded under part A of title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f39c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supplemental nutrition assistance program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f39d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a combination of a State program funded under part A of title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.) and the supplemental nutrition assistance program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef64f39e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of Program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f39f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State agency may not operate a Program unless the Secretary approves a State plan for the operation of the Program under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f3a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall approve any State plan to carry out a Program if the Secretary determines that the plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef64f3a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f3a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains sufficient documentation that the plan will not increase Federal costs for any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef64f3a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased Federal costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f3a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef64f3a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine whether a Program being carried out by a State agency is increasing Federal costs under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f3a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No excluded households","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making a determination under subparagraph (A), the Secretary shall not require the State agency to collect or report any information on households not included in the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f3a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative accounting periods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may approve the request of a State agency to apply alternative accounting periods to determine if Federal costs do not exceed the Federal costs had the State agency not elected to carry out the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f3a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that the Program has increased Federal costs under this chapter for any fiscal year or any portion of any fiscal year, the Secretary shall notify the State not later than 30 days after the Secretary makes the determination under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f3a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef64f3aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Corrective action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date of a notification under paragraph (2), the State shall submit a plan for approval by the Secretary for prompt corrective action that is designed to prevent the Program from increasing Federal costs under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f3ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the State does not submit a plan under subparagraph (A) or carry out a plan approved by the Secretary, the Secretary shall terminate the approval of the State agency operating the Program and the State agency shall be ineligible to operate a future Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef64f3ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f3ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In operating a Program, a State or political subdivision of a State may follow the rules and procedures established by the State or political subdivision under a State program funded under part A of title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.) or under the supplemental nutrition assistance program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f3ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standardized deductions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In operating a Program, a State or political subdivision of a State may standardize the deductions provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2014/e"},"text":"section 2014(e) of this title","children":[],"tail":". In developing the standardized deduction, the State shall consider the work expenses, dependent care costs, and shelter costs of participating households."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f3af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In operating a Program, a State or political subdivision shall comply with the requirements of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef64f3b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (a) through (f) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2016"},"text":"section 2016 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f3b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2017/a"},"text":"section 2017(a) of this title","children":[],"tail":" (except that the income of a household may be determined under a State program funded under part A of title IV of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.));"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f3b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (b) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2017"},"text":"section 2017 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f3b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsections (a), (c), (d), and (n) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2020"},"text":"section 2020 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f3b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/f/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraphs (8), (12), (15), (17), (18), (22), and (23) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2020/e"},"text":"section 2020(e) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f3b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/f/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2020/e/10"},"text":"section 2020(e)(10) of this title","children":[],"tail":" (or a comparable requirement established by the State under a State program funded under part A of title IV of the Social Security Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.)); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef64f3b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/f/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2025"},"text":"section 2025 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f3b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2035/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this section, a household may not receive benefits under this section as a result of the eligibility of the household under a State program funded under part A of title IV of the Social Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s601"},"text":"42 U.S.C. 601","children":[],"tail":" et seq.), unless the Secretary determines that any household with income above 130 percent of the poverty guidelines is not eligible for the program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef64f3b8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/525/s26"},"text":"Pub. L. 88–525, § 26","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVIII/s854/a"},"text":"Pub. L. 104–193, title VIII, § 854(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2340"},"text":"110 Stat. 2340","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIV"},"text":"Pub. L. 110–234, title IV","children":[],"tail":", §§ 4001(b), 4002(a)(12), 4115(b)(16), "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1092"},"text":"122 Stat. 1092","children":[],"tail":", 1095, 1109; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title IV, §§ 4001(b), 4002(a)(12), 4115(b)(16), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1853, 1857, 1870; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIV/s4030"},"text":"Pub. L. 113–79, title IV, § 4030","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/814"},"text":"128 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIV/s4022/9"},"text":"Pub. L. 115–334, title IV, § 4022(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4654"},"text":"132 Stat. 4654","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef64f3b9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef64f3ba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":