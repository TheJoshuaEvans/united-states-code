ag":"paragraph","attrib":{"id":"idf04c464b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9032/c/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of graded wool, $1.60 per pound.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c464c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9032/c/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of nongraded wool, $0.55 per pound.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c464d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9032/c/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of mohair, $5.00 per pound.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c464e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9032/c/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of honey, $1.50 per pound.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c464f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9032/c/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of peanuts, $390 per ton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c4650-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9032/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Single county loan rate for other oilseeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a single loan rate in each county for each kind of other oilseeds described in subsections (a)(11), (b)(11), and (c)(11).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04c4651-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9032/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seed cotton","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04c4652-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9032/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of section 9016 (b)(2) of this title and paragraphs (1)(B)(ii) and (2)(A)(ii)(II) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9017/b"},"text":"section 9017(b) of this title","children":[],"tail":", the loan rate for seed cotton shall be deemed to be equal to $0.30 per pound."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04c4653-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9032/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection authorizes any nonrecourse marketing assistance loan under this subchapter for seed cotton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04c4654-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib"