{"tag":"section","attrib":{"id":"idee6cfee3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1040"},"text":null,"children":[{"tag":"num","attrib":{"value":"1040"},"text":"§ 1040.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farmers’ Home Administration funds account","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When authorized by appropriation or other law, funds of the Farmers’ Home Administration available for administrative expenses may be placed in a single account.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee6cfee4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-03/ch950/s9/b"},"text":"Aug. 3, 1956, ch. 950, § 9(b)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/1034"},"text":"70 Stat. 1034","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee6cfee5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee6cfee6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee6cfee7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of Agriculture Organic Act of 1956, and not as part of the Bankhead-Jones Farm Tenant Act which constitutes a major part of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
