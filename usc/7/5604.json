{"tag":"section","attrib":{"id":"idefc933a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5604"},"text":null,"children":[{"tag":"num","attrib":{"value":"5604"},"text":"§ 5604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of traditional markets","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall, in implementing programs of the Department of Agriculture intended to encourage or assist exports of agricultural commodities, seek to preserve traditional markets for United States agricultural commodities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefc933a4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tI/s104"},"text":"Pub. L. 95–501, title I, § 104","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3672"},"text":"104 Stat. 3672","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
