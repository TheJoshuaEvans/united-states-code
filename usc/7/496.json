{"tag":"section","attrib":{"id":"idee33c6ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s496"},"text":null,"children":[{"tag":"num","attrib":{"value":"496"},"text":"§ 496.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Validity of other statutes dealing with same subject","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall not abrogate nor nullify any other statute, whether State or Federal, dealing with the same subjects as this chapter, but it is intended that all such statutes shall remain in full force and effect, except insofar only as they are inconsistent herewith or repugnant hereto.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee33c700-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-03/ch309/s3"},"text":"Mar. 3, 1927, ch. 309, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1355"},"text":"44 Stat. 1355","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee33c701-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee33c702-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee33c703-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section constitutes part of section 3 of act ","children":[{"tag":"date","attrib":{"date":"1927-03-03"},"text":"Mar. 3, 1927","children":[],"tail":". Remainder of section 3 is classified to sections 494 and 495 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
