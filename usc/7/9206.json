{"tag":"section","attrib":{"id":"idf05372f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9206"},"text":null,"children":[{"tag":"num","attrib":{"value":"9206"},"text":"§ 9206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter affects the authority of the Secretary of Agriculture or the Secretary of Homeland Security under any other provision of law or program relating to the protection of food supplies, agriculture, or public health.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf05372fa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dP/s7"},"text":"Pub. L. 116–260, div. P, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2162"},"text":"134 Stat. 2162","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
