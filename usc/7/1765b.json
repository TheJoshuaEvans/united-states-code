{"tag":"section","attrib":{"id":"ideefc1f77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1765b"},"text":"§ 1765b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The functions of each United States Agricultural Trade Office shall be to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideefc1f78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the effectiveness of agricultural export promotion efforts through consolidation of activities, providing services and facilities for foreign buyers and United States trade representatives, and coordination of market development activities sponsored by the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideefc1f79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish goals by nation or region and agricultural commodity for developing, expanding, and maintaining markets for United States agricultural commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideefc1f7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiate programs to achieve the export marketing goals approved by the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideefc1f7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain facilities for use by nonresident cooperators, private trade groups, and other individuals engaged in the import and export of United States agricultural commodities where the use of such facilities would aid in the conduct of market development activities, and cooperate, to the maximum extent practicable, with such cooperators, groups, and individuals to expand the level of United States agricultural exports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideefc1f7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and maintain a current listing of trade, government, and other appropriate organizations for each agricultural commodity area and make such listing available to persons with a bona fide interest in exporting or importing United States agricultural commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideefc1f7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" originate and provide assistance for exhibits, sales teams, and other functions for the promotion of United States agricultural commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideefc1f7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide practical assistance for the use of the programs under the Food for Peace Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"7 U.S.C. 1691","children":[],"tail":" et seq.], the export credit sales program, the export incentives program, and related programs of the United States Government where use of such programs will serve as a market development tool for United States agriculture;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideefc1f7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervise project agreements with United States cooperators, coordinate the activities of the United States Agricultural Trade Office with those of the cooperators, and submit annual recommendations to the Secretary of Agriculture on the efficacy of cooperator programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideefc1f80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicize the services offered by the United States Agricultural Trade Office through advertisements in trade journals or by other appropriate means; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideefc1f81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1765b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other functions as the Secretary of Agriculture, in consultation with the Secretary of State, determines to be necessary and proper for achieving the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideefc1f82-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-08-28/ch1041"},"text":"Aug. 28, 1954, ch. 1041","children":[],"tail":", title VI, § 605B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIV/s401/1"},"text":"Pub. L. 95–501, title IV, § 401(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-21"},"text":"Oct. 21, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1689"},"text":"92 Stat. 1689","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3001/b/1/A"},"text":"Pub. L. 110–246, title III, § 3001(b)(1)(A)","children":[],"tail":", (2)(H), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1820"},"text":"122 Stat. 1820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideefc1f83-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideefc1f84-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideefc1f85-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food for Peace Act, referred to in par. (7), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"act July 10, 1954, ch. 469","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/454"},"text":"68 Stat. 454","children":[],"tail":", which is classified principally to chapter 41 (§ 1691 et seq.) of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideefc1f86-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" substituted “Food for Peace Act” for “Agricultural Trade Development and Assistance Act of 1954”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideefc1f87-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideefc1f88-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
