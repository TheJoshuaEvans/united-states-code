{"tag":"section","attrib":{"id":"idefc20854-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4916"},"text":null,"children":[{"tag":"num","attrib":{"value":"4916"},"text":"§ 4916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out the provisions of this chapter, except that the funds so appropriated shall not be available for the payment of any expenses or expenditures of the Board in administering any provision of any plan issued under authority of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefc20855-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1657"},"text":"Pub. L. 99–198, title XVI, § 1657","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1630"},"text":"99 Stat. 1630","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
