{"tag":"section","attrib":{"id":"idf00e5390-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485"},"text":null,"children":[{"tag":"num","attrib":{"value":"7485"},"text":"§ 7485.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referenda","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00e5391-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial referendum","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e5392-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the 60-day period immediately preceding the effective date of an order, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7483/b/3"},"text":"section 7483(b)(3) of this title","children":[],"tail":", the Secretary shall conduct a referendum among processors who, during a representative period as determined by the Secretary, have been engaged in processing, for the purpose of ascertaining whether the order shall go into effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5393-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall become effective, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7483/b"},"text":"section 7483(b) of this title","children":[],"tail":", only if the Secretary determines that the order has been approved by not less than a majority of the processors voting in the referendum and if the majority processed more than 50 percent of the popcorn certified as having been processed, during the representative period, by the processors voting."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e5394-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional referenda","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e5395-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not earlier than 3 years after the effective date of an order approved under subsection (a), on the request of the Board or a representative group of processors, as described in paragraph (2), the Secretary may conduct additional referenda to determine whether processors favor the suspension or termination of the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5396-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representative group of processors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An additional referendum on an order shall be conducted if the referendum is requested by 30 percent or more of the number of processors who, during a representative period as determined by the Secretary, have been engaged in processing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5397-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval of order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines, in a referendum conducted under paragraph (1), that suspension or termination of the order is favored by at least ⅔ of the processors voting in the referendum, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00e5398-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend or terminate, as appropriate, collection of assessments under the order not later than 180 days after the date of determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e5399-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend or terminate the order, as appropriate, in an orderly manner as soon as practicable after the date of determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e539a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of referendum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall be reimbursed from assessments collected by the Board for any expenses incurred by the Secretary in connection with the conduct of any referendum under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e539b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of conducting referendum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to this section, a referendum conducted under this section shall be conducted in such manner as is determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e539c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of ballots and other information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e539d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The ballots and other information or reports that reveal or tend to reveal the vote of any processor, or any business operation of a processor, shall be considered to be strictly confidential and shall not be disclosed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e539e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7485/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An officer or employee of the Department who knowingly violates paragraph (1) shall be subject to the penalties described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7484/i/3/C/ii"},"text":"section 7484(i)(3)(C)(ii) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00e539f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s576"},"text":"Pub. L. 104–127, title V, § 576","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1081"},"text":"110 Stat. 1081","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
