{"tag":"section","attrib":{"id":"ideffdb156-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202"},"text":null,"children":[{"tag":"num","attrib":{"value":"7202"},"text":"§ 7202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffdb157-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural Act of 1949","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7301"},"text":"section 7301 of this title","children":[],"tail":", the term “Agricultural Act of 1949” means the Agricultural Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"7 U.S.C. 1421","children":[],"tail":" et seq.), as in effect prior to the suspensions under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7301/b/1"},"text":"section 7301(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb158-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considered planted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “considered planted” means acreage that is considered planted under title V of the Agricultural Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1461"},"text":"7 U.S.C. 1461","children":[],"tail":" et seq.) and such other acreage as the Secretary considers fair and equitable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb159-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “contract” and “production flexibility contract” mean a production flexibility contract entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7211"},"text":"section 7211 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb15a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract acreage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contract acreage” means 1 or more crop acreage bases established for contract commodities under title V of the Agricultural Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1461"},"text":"7 U.S.C. 1461","children":[],"tail":" et seq.) that would have been in effect for the 1996 crop (but for suspension under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7301/b/1"},"text":"section 7301(b)(1) of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb15b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract commodity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contract commodity” means wheat, corn, grain sorghum, barley, oats, upland cotton, and rice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb15c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “contract payment” means a payment made under this subchapter ","children":[{"tag":"ref","attrib":{"idref":"fn002328"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002328"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “chapter”."}],"tail":" pursuant to a contract."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb15d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb15e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extra long staple cotton","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “extra long staple cotton” means cotton that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffdb15f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is produced from pure strain varieties of the Barbadense species or any hybrid thereof, or other similar types of extra long staple cotton, designated by the Secretary, having characteristics needed for various end uses for which United States upland cotton is not suitable and grown in irrigated cotton-growing regions of the United States designated by the Secretary or other areas designated by the Secretary as suitable for the production of the varieties or types; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffdb160-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is ginned on a roller-type gin or, if authorized by the Secretary, ginned on another type gin for experimental purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb161-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm program payment yield","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “farm program payment yield” means the farm program payment yield established for the 1995 crop of a contract commodity under section 505 of the Agricultural Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1465"},"text":"7 U.S.C. 1465","children":[],"tail":"). The Secretary shall adjust the farm program payment yield for the 1995 crop of a contract commodity to account for any additional yield payments made with respect to that crop under subsection (b)(2) of the section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb162-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan commodity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “loan commodity” means each contract commodity, extra long staple cotton, and oilseed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb163-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oilseed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “oilseed” means a crop of soybeans, sunflower seed, rapeseed, canola, safflower, flaxseed, mustard seed, or, if designated by the Secretary, other oilseeds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb164-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” means an owner, operator, landlord, tenant, or sharecropper who shares in the risk of producing a crop and who is entitled to share in the crop available for marketing from the farm, or would have shared had the crop been produced. In determining whether a grower of hybrid seed is a producer, the Secretary shall not take into consideration the existence of a hybrid seed contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb165-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb166-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb167-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7202/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States”, when used in a geographical sense, means all of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffdb168-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s102"},"text":"Pub. L. 104–127, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/897"},"text":"110 Stat. 897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideffdb169-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideffdb16a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideffdb16b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in text, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7201"},"text":"section 7201 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Agricultural Act of 1949, referred to in pars. (1), (2), and (4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"act Oct. 31, 1949, ch. 792","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/1051"},"text":"63 Stat. 1051","children":[],"tail":", which is classified principally to chapter 35A (§ 1421 et seq.) of this title. Title V of the Act, which was classified generally to subchapter IV (§ 1461 et seq.) of chapter 35A of this title, was omitted from the Code. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 505 of the Agricultural Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1465"},"text":"7 U.S.C. 1465","children":[],"tail":"), referred to in par. (9), was omitted from the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
