{"tag":"section","attrib":{"id":"idedf11854-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"87f–2"},"text":"§ 87f–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedf11855-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requirements; annual report to Congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On December 1 of each year, the Secretary shall submit a report to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate regarding the effectiveness of the official inspection and weighing system under this chapter for the prior fiscal year, with recommendations for any legislative changes necessary to accomplish the objectives stated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s74"},"text":"section 74 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf11856-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of Congressional committees of complaints regarding faulty grain deliveries and cancellation of export contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate (1) of any complaint regarding faulty grain delivery made to the Department of Agriculture by a foreign purchaser of United States grain, within thirty days after a determination by the Secretary that there is reasonable cause to believe that the grain delivery was in fact faulty, and (2) notwithstanding the provisions of section 612c–3 ","children":[{"tag":"ref","attrib":{"idref":"fn002068"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002068"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, within thirty days after receipt by the Secretary or the Secretary "},{"tag":"ref","attrib":{"idref":"fn002069"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002069"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The words “or the Secretary” probably should not appear."}],"tail":" of notice of the cancellation of any contract for the export of more than one hundred thousand metric tons of grain."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf11857-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congressional committees of annual summary of complaints from foreign purchasers and prospective purchasers of grain","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On December 1 of each year, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a summary of all other complaints received by the Department of Agriculture during the prior fiscal year from foreign purchasers and prospective purchasers of United States grain and other foreign purchasers interested in the trade of grain, and the resolution thereof: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the summary shall not include a complaint unless reasonable cause exists to believe that the complaint is valid, as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf11858-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhancement of current reporting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedf11859-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased frequency of inspection program data reporting","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedf1185a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-11"},"text":"December 11, 2020","children":[],"tail":", the Secretary shall publish quarterly reports describing data from the tests and inspections for intrinsic quality factors (including protein, oil, and starch) and food safety factors, as reported, in the aggregate, for fiscal years 2014 through 2018 in the tables in section V (relating to providing official grain inspection and weighing services) of the 2016 through 2018 annual reports to Congress by the Federal Grain Inspection Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedf1185b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delineation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The data from the tests and inspections under subparagraph (A) shall be delineated to reflect whether the tests and inspections were requested of or performed by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedf1185c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedf1185d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State agency delegated authority under section 79 or 79a of this title or an official agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedf1185e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions and waivers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-11"},"text":"December 11, 2020","children":[],"tail":", the Secretary shall publish quarterly reports describing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedf1185f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of exceptions requested under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s79/f/2/B"},"text":"section 79(f)(2)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedf11860-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of exceptions granted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s79/f/2/B"},"text":"section 79(f)(2)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedf11861-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of waivers requested under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s77/a/1"},"text":"section 77(a)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedf11862-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of waivers granted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s77/a/1"},"text":"section 77(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf11863-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional reporting; consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may, to the extent determined appropriate by the Secretary, in consultation with State agencies delegated authority under sections 79 and 79a of this title, official agencies, and the grain industries described in the second sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s87j/a"},"text":"section 87j(a) of this title","children":[],"tail":", publish—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idedf11864-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data relating to testing for other intrinsic quality or food safety factors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedf11865-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other data collected from inspection and weighing activities conducted under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf11866-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87f–2/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of confidential business information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any trade secrets or information described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":" that is provided to or collected by the Secretary in carrying out subsection (d) or (e) shall not be included in a report under subsection (d) or (e) or otherwise publicly disclosed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedf11867-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. B, § 17B, as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/582/s22"},"text":"Pub. L. 94–582, § 22","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2888"},"text":"90 Stat. 2888","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXVI"},"text":"Pub. L. 95–113, title XVI","children":[],"tail":", §§ 1604(m), 1606(i), (j), "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1029"},"text":"91 Stat. 1029","children":[],"tail":", 1030; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1007/3"},"text":"Pub. L. 102–237, title X, § 1007(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1897"},"text":"105 Stat. 1897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s293/a/7"},"text":"Pub. L. 103–354, title II, § 293(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3237"},"text":"108 Stat. 3237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/216/s5"},"text":"Pub. L. 116–216, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-11"},"text":"Dec. 11, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1048"},"text":"134 Stat. 1048","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedf11868-3a6e-11f1-addd-bbaf0b3f68