{"tag":"section","attrib":{"id":"idee6a8e6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1012"},"text":null,"children":[{"tag":"num","attrib":{"value":"1012"},"text":"§ 1012.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to counties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the end of each calendar year, the Secretary shall pay to the county in which any land is held by the Secretary under this subchapter, 25 per centum of the net revenues received by the Secretary from the use of the land during such year. In case the land is situated in more than one county, the amount to be paid shall be divided equitably among the respective counties. Payments to counties under this section shall be made on the condition that they are used for school or road purposes, or both. This section shall not be construed to apply to amounts received from the sale of land.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee6a8e6e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1937-07-22/ch517"},"text":"July 22, 1937, ch. 517","children":[],"tail":", title III, § 33, "},{"tag":"ref","attrib":{"href":"/us/stat/50/526"},"text":"50 Stat. 526","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee6a8e6f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee6a8e70-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee6a8e71-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal; Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This section is section 33 of act ","children":[{"tag":"date","attrib":{"date":"1937-07-22"},"text":"July 22, 1937","children":[],"tail":". Section is being treated as repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/tVII/s706/a"},"text":"Pub. L. 94–579, title VII, § 706(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2793"},"text":"90 Stat. 2793","children":[],"tail":", effective on and after "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", insofar as applicable to the issuance of rights-of-way over, upon, under, and through the public lands and lands in the National Forest System. The table of repealed laws contained in "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/s706/a"},"text":"section 706(a) of Pub. L. 94–579","children":[],"tail":" did not list section 33 of act "},{"tag":"date","attrib":{"date":"1937-07-22"},"text":"July 22, 1937","children":[],"tail":", but did list "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1012"},"text":"section 1012 of Title 7","children":[],"tail":". Such repeal not to be construed as terminating any valid lease, permit, patent, etc., existing on "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/579/s701"},"text":"section 701 of Pub. L. 94–579","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee6a8e72-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Existing Rights-of-Way","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/579/s706/a"},"text":"section 706(a) of Pub. L. 94–579","children":[],"tail":", except as pertaining to rights-of-way, not to be construed as affecting the authority of the Secretary of Agriculture under this section, see note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1701"},"text":"section 1701 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
