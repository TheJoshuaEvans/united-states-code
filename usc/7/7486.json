{"tag":"section","attrib":{"id":"idf00e53a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486"},"text":null,"children":[{"tag":"num","attrib":{"value":"7486"},"text":"§ 7486.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition and review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00e53a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e53a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person subject to an order may file with the Secretary a petition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00e53a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating that the order, a provision of the order, or an obligation imposed in connection with the order is not established in accordance with law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e53a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requesting a modification of the order or obligation or an exemption from the order or obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statute of limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A petition under paragraph (1) concerning an obligation may be filed not later than 2 years after the date of imposition of the obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The petitioner shall be given the opportunity for a hearing on a petition filed under paragraph (1), in accordance with regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ruling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After a hearing under paragraph (3), the Secretary shall issue a ruling on the petition that is the subject of the hearing, which shall be final if the ruling is in accordance with applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e53a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e53a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district court of the United States for any district in which a person who is a petitioner under subsection (a) resides or carries on business shall have jurisdiction to review a ruling on the petition, if the person files a complaint not later than 20 days after the date of issuance of the ruling under subsection (a)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Service of process in a proceeding under paragraph (1) may be made on the Secretary by delivering a copy of the complaint to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e53ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remands","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the court determines, under paragraph (1), that a ruling issued under subsection (a)(4) is not in accordance with applicable law, the court shall remand the matter to the Secretary with directions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00e53ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make such ruling as the court shall determine to be in accordance with law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e53ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take such further proceedings as, in the opinion of the court, the law requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e53ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7486/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The pendency of proceedings instituted under subsection (a) may not impede, hinder, or delay the Secretary or the Attorney General from taking action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7487"},"text":"section 7487 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00e53af-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s577"},"text":"Pub. L. 104–127, title V, § 577","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1082"},"text":"110 Stat. 1082","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
