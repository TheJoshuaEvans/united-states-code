pplicable in any marketing year to any farm on which the normal production of the acreage planted to wheat of the current crop is less than 200 bushels."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1957—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/203"},"text":"Pub. L. 85–203","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1954-08-28"},"text":"Aug. 28, 1954","children":[],"tail":", § 309(a), substituted “May 15” for “July 1”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). Act ","children":[{"tag":"date","attrib":{"date":"1954-08-28"},"text":"Aug. 28, 1954","children":[],"tail":", § 309(b), added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1948—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1948-07-03"},"text":"July 3, 1948","children":[],"tail":", changed conditions which must be determined by the Secretary to exist before marketing quotas can be imposed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1940—Subsec. (d). Act ","children":[{"tag":"date","attrib":{"date":"1940-06-06"},"text":"June 6, 1940","children":[],"tail":", substituted “two hundred” for “one hundred”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee8011b2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee8011b3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tIII/s305"},"text":"Pub. L. 99–198, title I