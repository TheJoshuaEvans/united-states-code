{"tag":"section","attrib":{"id":"ideffffb0a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7233"},"text":null,"children":[{"tag":"num","attrib":{"value":"7233"},"text":"§ 7233.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffffb0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7233/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of each loan commodity (other than upland cotton or extra long staple cotton), a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7231"},"text":"section 7231 of this title","children":[],"tail":" shall have a term of 9 months beginning on the first day of the first month after the month in which the loan is made."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7233/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for cotton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A marketing assistance loan for upland cotton or extra long staple cotton shall have a term of 10 months beginning on the first day of the month in which the loan is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7233/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extensions prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not extend the term of a marketing assistance loan for any loan commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffffb0e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s133"},"text":"Pub. L. 104–127, title I, § 133","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/907"},"text":"110 Stat. 907","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
