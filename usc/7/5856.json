{"tag":"section","attrib":{"id":"idefd0604c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856"},"text":null,"children":[{"tag":"num","attrib":{"value":"5856"},"text":"§ 5856.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvements to United States Drought Monitor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd0604d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate with the Director of the National Drought Mitigation Center and the Administrator of the National Oceanic and Atmospheric Administration to enhance the collection of data to improve the accuracy of the United States Drought Monitor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd0604e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Utilization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall utilize a consistent source or sources of data for programs that are based on drought or precipitation indices, such as the livestock forage disaster program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9081/c"},"text":"section 9081(c) of this title","children":[],"tail":" or policies or plans of insurance established under the Federal Crop Insurance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd0604f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary shall conduct a review of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd06050-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of data currently utilized by the United States Drought Monitor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd06051-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic coverage and density of existing data collection sites; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd06052-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other meteorological or climatological data that is being collected by other Federal agencies, State and local governments, and non-Federal entities that could be utilized by the United States Drought Monitor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd06053-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd06054-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the completion of the review prescribed in subsection (c), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd06055-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to expand the collection of relevant data in States or geographic areas where coverage is currently lacking as compared to other States or geographic areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd06056-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to the maximum extent practicable, develop standards to allow the integration of meteorological or climatological data into the United States Drought Monitor derived from—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefd06057-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in-situ soil moisture profile measuring devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefd06058-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" citizen science (as defined in the Crowdsourcing and Citizen Science Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3724"},"text":"15 U.S.C. 3724","children":[],"tail":")), including data from the Cooperative Observer Program of the National Weather Service; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefd06059-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal agencies, State and local governments, and non-Federal entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd0605a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5856/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is to be authorized to be appropriated to the Secretary to carry out this subsection $5,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd0605b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12512"},"text":"Pub. L. 115–334, title XII, § 12512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4995"},"text":"132 Stat. 4995","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefd0605c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefd0605d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefd0605e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Crop Insurance Act, referred to in subsec. (b), is subtitle A of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"act Feb. 16, 1938, ch. 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/72"},"text":"52 Stat. 72","children":[],"tail":", which is classified generally to subchapter I (§ 1501 et seq.) of chapter 36 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"section 1501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefd0605f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agriculture Improvement Act of 2018, and not as part of subtitle C of title XVI of the Food, Agriculture, Conservation, and Trade Act of 1990 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefd06060-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idefd06061-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” means the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2"},"text":"section 2 of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
