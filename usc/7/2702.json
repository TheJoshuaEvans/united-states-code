{"tag":"section","attrib":{"id":"idef8b1918-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702"},"text":null,"children":[{"tag":"num","attrib":{"value":"2702"},"text":"§ 2702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8b1919-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Agriculture or any other officer or employee of the Department of Agriculture to whom there has heretofore been delegated, or to whom there may hereafter be delegated, the authority to act in his stead.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b191a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means any individual, group of individuals, partnership, corporation, association, cooperative, or any other entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b191b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":" (c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “commercial eggs” or “eggs” means eggs from domesticated chickens which are sold for human consumption either in shell egg form or for further processing into egg products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b191c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “hen” or “laying hen” means a domesticated female chicken twenty weeks of age or over, raised primarily for the production of commercial eggs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b191d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “egg producer” means the person owning laying hens engaged in the production of commercial eggs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b191e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “case” means a standard shipping package containing thirty dozen eggs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b191f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “hatching eggs” means eggs intended for use by hatcheries for the production of baby chicks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b1920-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States” means the forty-eight contiguous States of the United States of America and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b1921-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “promotion” means any action, including paid advertising, to advance the image or desirability of eggs, egg products, spent fowl, or products of spent fowl.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b1922-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “research” means any type of research to advance the image, desirability, marketability, production, or quality of eggs, egg products, spent fowl, or products of spent fowl.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b1923-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “consumer education” means any action to advance the image or desirability of eggs, egg products, spent fowl, or products of spent fowl.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b1924-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “marketing” means the sale or other disposition of commercial eggs, egg products, spent fowl, or products of spent fowl, in any channel of commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b1925-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “commerce” means interstate, foreign, or intrastate commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b1926-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “egg products” means products produced, in whole or in part, from eggs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b1927-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “spent fowl” means hens which have been in production of commercial eggs and have been removed from such production for slaughter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b1928-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/p"},"text":null,"children":[{"tag":"num","attrib":{"value":"p"},"text":"(p)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “products of spent fowl” means commercial products produced from spent fowl.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b1929-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/q"},"text":null,"children":[{"tag":"num","attrib":{"value":"q"},"text":"(q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “hatchery operator” means any person engaged in the production of egg-type baby chicks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b192a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/r"},"text":null,"children":[{"tag":"num","attrib":{"value":"r"},"text":"(r)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “started pullet” means a hen less than twenty weeks of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b192b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/s"},"text":null,"children":[{"tag":"num","attrib":{"value":"s"},"text":"(s)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “started pullet dealer” means any person engaged in the sale of started pullets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b192c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2702/t"},"text":null,"children":[{"tag":"num","attrib":{"value":"t"},"text":"(t)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “handler” means any person, specified in the order or the rules and regulations issued thereunder, who receives or otherwise acquires eggs from an egg producer, and processes, prepares for marketing, or markets, such eggs, including eggs of his own production.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8b192d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/428/s3"},"text":"Pub. L. 93–428, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-01"},"text":"Oct. 1, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1172"},"text":"88 Stat. 1172","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
