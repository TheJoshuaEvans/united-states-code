{"tag":"section","attrib":{"id":"idef248fe9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008c"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008c"},"text":"§ 2008c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural Business-Cooperative Service programs technical assistance and training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef248fea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to public bodies, private nonprofit corporations, economic development authorities, institutions of higher education, federally recognized Indian Tribes, and rural cooperatives for the purpose of providing or obtaining technical assistance and training to support funding applications for programs carried out by the Secretary, acting through the Administrator of the Rural Business-Cooperative Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248feb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under subsection (a) may be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef248fec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist communities in identifying and planning for business and economic development needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify public and private resources to finance business and small and emerging business needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prepare reports and surveys necessary to request financial assistance for businesses in rural communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prepare applications for financial assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248ff0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting recipients of grants under this section, the Secretary shall give priority to grants serving persistent poverty counties and high poverty communities, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248ff1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef248ff2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2019 through 2023, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248ff3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts authorized to be appropriated under paragraph (1) for any fiscal year that are not appropriated for that fiscal year may be appropriated for the immediately succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef248ff4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s368"},"text":"Pub. L. 87–128, title III, § 368","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6419"},"text":"Pub. L. 115–334, title VI, § 6419","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4764"},"text":"132 Stat. 4764","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef248ff5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef248ff6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idef248ff7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2008c, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s368"},"text":"Pub. L. 87–128, title III, § 368","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2317"},"text":"Pub. L. 101–624, title XXIII, § 2317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4009"},"text":"104 Stat. 4009","children":[],"tail":", related to allocation and transfer of loan guarantee authority, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s756"},"text":"Pub. L. 104–127, title VII, § 756","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1131"},"text":"110 Stat. 1131","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
