{"tag":"section","attrib":{"id":"idf0130ef1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613"},"text":null,"children":[{"tag":"num","attrib":{"value":"7613"},"text":"§ 7613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevance and merit of agricultural research, extension, and education funded by the Department","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0130ef2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of National Institute of Food and Agriculture","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0130ef3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review of research grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures that provide for scientific peer review of each agricultural research grant administered, on a competitive basis, by the National Institute of Food and Agriculture of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130ef4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relevance and merit review of research, extension, and education grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0130ef5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures that provide for relevance and merit review of each agricultural research, extension, or education grant administered, on a competitive basis, by the National Institute of Food and Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130ef6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with Advisory Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the Advisory Board in establishing the merit review procedures on a continuous basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130ef7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Peer and merit review procedures established under paragraphs (1) and (2) shall not take the offer or availability of matching funds into consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0130ef8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Board review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On an annual basis, the Advisory Board shall review—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0130ef9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevance to the priorities established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7612/a"},"text":"section 7612(a) of this title","children":[],"tail":" of the funding of all agricultural research, extension, or education activities conducted or funded by the Department; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130efa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of the funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0130efb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for proposals","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0130efc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the review is conducted under subsection (b) for a fiscal year, the Secretary shall consider the results of the review when formulating each request for proposals, and evaluating proposals, involving an agricultural research, extension, or education activity funded, on a competitive basis, by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130efd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Input","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In formulating a request for proposals described in paragraph (1) for a fiscal year, the Secretary shall solicit and consider input from persons who conduct or use agricultural research, extension, or education regarding the prior year’s request for proposals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0130efe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientific peer review of agricultural research","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0130eff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer review procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures that ensure scientific peer review of all research activities conducted by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130f00-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review panel required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the procedures established under paragraph (1), a review panel shall verify, at least once every 5 years, that each research activity of the Department and research conducted under each research program of the Department has scientific merit and relevance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130f01-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the research activity or program to be reviewed is included in the research, educational, and economics mission area of the Department, the review panel shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0130f02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scientific merit and relevance of the activity or research in light of the priorities established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7612"},"text":"section 7612 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130f03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national or multistate significance of the activity or research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130f04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition of review panel","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0130f05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A review panel shall be composed of individuals with scientific expertise, a majority of whom are not employees of the agency whose research is being reviewed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0130f06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Scientists from colleges and universities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall use scientists from colleges and universities to serve on the review panels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130f07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The results of the panel reviews shall be submitted to the Advisory Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0130f08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Merit review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0130f09-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1862 and 1890 Institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":", to be eligible to obtain agricultural research or extension funds from the Secretary for an activity, each 1862 Institution and 1890 Institution shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157f0a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a process for merit review of the activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the activity in accordance with the process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 1994 Institutions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective ","children":[{"tag":"date","attrib":{"date":"1999-10-01"},"text":"October 1, 1999","children":[],"tail":", to be eligible to obtain agricultural extension funds from the Secretary for an activity, each 1994 Institution shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157f0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a process for merit review of the activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the activity in accordance with the process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157f0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hispanic-serving agricultural colleges and universities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to obtain agricultural extension funds from the Secretary for an activity, each Hispanic-serving agricultural college and university shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157f10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a process for merit review of the activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157f11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7613/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the activity in accordance with such process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0157f12-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tI/s103"},"text":"Pub. L. 105–185, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/527"},"text":"112 Stat. 527","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII"},"text":"Pub. L. 110–234, title VII","children":[],"tail":", §§ 7129(c)(3), 7301, 7511(c)(30), "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1227"},"text":"122 Stat. 1227","children":[],"tail":", 1242, 1270; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, §§ 7129(c)(3), 7301, 7511(c)(30), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1988, 2003, 2031; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7301"},"text":"Pub. L. 113–79, title VII, § 7301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/887"},"text":"128 Stat. 887","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0157f13-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0157f14-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf0157f15-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s103"},"text":"section 103 of Pub. L. 105–185","children":[],"tail":". Subsec. (f) of "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/s103"},"text":"section 103 of Pub. L. 105–185","children":[],"tail":" amended sections 361g, 3221, and 3222 of this title and repealed sections 346 and 3314 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf0157f16-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7301/1"},"text":"Pub. L. 113–79, § 7301(1)","children":[],"tail":", substituted “Relevance and merit review of research, extension,” for “Merit review of extension” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7301/2"},"text":"Pub. L. 113–79, § 7301(2)","children":[],"tail":", inserted “relevance and” before “merit” and substituted “research, extension, or education” for “extension or education”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7301/3"},"text":"Pub. L. 113–79, § 7301(3)","children":[],"tail":", inserted “on a continuous basis” after “procedures”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/30"},"text":"Pub. L. 110–246, § 7511(c)(30)","children":[],"tail":", substituted “National Institute of Food and Agriculture” for “Cooperative State Research, Education, and Extension Service” in heading and “the National Institute of Food and Agriculture” for “the Cooperative State Research, Education, and Extension Service” in text of pars. (1) and (2)(A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7301"},"text":"Pub. L. 110–246, § 7301","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7129/c/3"},"text":"Pub. L. 110–246, § 7129(c)(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0157f17-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf0157f18-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/30"},"text":"section 7511(c)(30) of Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c"},"text":"section 7511(c) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
