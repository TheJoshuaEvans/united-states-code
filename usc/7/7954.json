{"tag":"section","attrib":{"id":"idf0289197-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954"},"text":null,"children":[{"tag":"num","attrib":{"value":"7954"},"text":"§ 7954.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of counter-cyclical payments for peanuts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0289198-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0289199-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the 2002 through 2007 crop years for peanuts, the Secretary shall make counter-cyclical payments under this section with respect to peanuts if the Secretary determines that the effective price for peanuts is less than the target price for peanuts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf028919a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2002 crop year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If counter-cyclical payments are required for the 2002 crop year, the Secretary shall make the payments to historic peanut producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf028919b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent crop years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If counter-cyclical payments are required for any of the 2003 through 2007 crop years for peanuts, the Secretary shall make the payments to the producers on a farm to which a payment yield and base acres for peanuts are assigned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7952"},"text":"section 7952 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf028919c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subsection (a), the effective price for peanuts is equal to the sum of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf028919d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The higher of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf028919e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The national average market price for peanuts received by producers during the 12-month marketing year for peanuts, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf028919f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The national average loan rate for a marketing assistance loan for peanuts in effect for the applicable period under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02891a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment rate in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7953"},"text":"section 7953 of this title","children":[],"tail":" for the purpose of making direct payments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02891a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of subsection (a), the target price for peanuts shall be equal to $495 per ton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02891a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The payment rate used to make counter-cyclical payments for a crop year shall be equal to the difference between—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02891a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the target price; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02891a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective price determined under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02891a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment amount for 2002 crop year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If counter-cyclical payments are required to be paid for the 2002 crop of peanuts, the amount of the counter-cyclical payment to be paid to an historic peanut producer for that crop year shall be equal to the product of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02891a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment rate specified in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02891a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment acres of the historic peanut producer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02891a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average peanut yield determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7952/a/1"},"text":"section 7952(a)(1) of this title","children":[],"tail":" for the historic peanut producer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02891a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment amount for subsequent crop years","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If counter-cyclical payments are required to be paid for any of the 2003 through 2007 crops of peanuts, the amount of the counter-cyclical payment to be paid to the producers on a farm for that crop year shall be equal to the product of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02891aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment rate specified in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02891ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment acres on the farm.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02891ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment yield for the farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02891ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for payments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02891ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines under subsection (a) that counter-cyclical payments are required to be made under this section for a crop year, the Secretary shall make the counter-cyclical payments as soon as practicable after the end of the 12-month marketing year for the crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02891af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of partial payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, before the end of the 12-month marketing year, the Secretary estimates that counter-cyclical payments will be required under this section for a crop year, the Secretary shall give producers on a farm (or, in the case of the 2002 crop year, historic peanut producers) the option to receive partial payments of the counter-cyclical payment projected to be made for that crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02891b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for partial payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02891b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2002 through 2006 crop years","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When the Secretary makes partial payments available under paragraph (2) for any of the 2002 through 2006 crop years—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02891b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first partial payment for the crop year shall be made not earlier than October 1, and, to the maximum extent practicable, not later than October 31, of the calendar year in which the crop is harvested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02891b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the second partial payment shall be made not earlier than February 1 of the next calendar year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02891b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final partial payment shall be made as soon as practicable after the end of the 12-month marketing year for that crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02891b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2007 crop year","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When the Secretary makes partial payments available for the 2007 crop year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02891b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first partial payment shall be made after completion of the first 6 months of the marketing year for that crop; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02891b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final partial payment shall be made as soon as practicable after the end of the 12-month marketing year for that crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02891b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of partial payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02891b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2002 crop year","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02891ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First partial payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of the 2002 crop year, the first partial payment under paragraph (3) to an historic peanut producer may not exceed 35 percent of the projected counter-cyclical payment for the crop year, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02891bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second partial payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The second partial payment may not exceed the difference between—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf02891bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70 percent of the projected counter-cyclical payment (including any revision thereof) for the 2002 crop year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf02891bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the payment made under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02891be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The final payment shall be equal to the difference between—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf02891bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual counter-cyclical payment to be made to the historic peanut producer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf02891c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the partial payments made to the historic peanut producer under clauses (i) and (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02891c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2003 through 2006 crop years","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02891c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First partial payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of the 2003 through 2006 crop years, the first partial payment under paragraph (3) to the producers on a farm may not exceed 35 percent of the projected counter-cyclical payment for the crop year, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02891c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second partial payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The second partial payment for a crop year may not exceed the difference between—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf02891c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70 percent of the projected counter-cyclical payment (including any revision thereof) for the crop year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf02891c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the payment made under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02891c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The final payment for a crop year shall be equal to the difference between—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf02891c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual counter-cyclical payment to be made to the producers for that crop year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf02891c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the partial payments made to the producers under clauses (i) and (ii) for that crop year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02891c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2007 crop year","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02891ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First partial payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the 2007 crop year, the first partial payment under paragraph (3) to the producers on a farm may not exceed 40 percent of the projected counter-cyclical payment for the crop year, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02891cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final payment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The final payment for the 2007 crop year shall be equal to the difference between—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf02891cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual counter-cyclical payment to be made to the producers for that crop year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf02891cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/4/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the partial payment made to the producers under clause (i).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02891ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7954/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The producers on a farm (or, in the case of the 2002 crop year, historic peanut producers) that receive a partial payment under this subsection for a crop year shall repay to the Secretary the amount, if any, by which the total of the partial payments exceed the actual counter-cyclical payment to be made for that crop year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02891cf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1304"},"text":"Pub. L. 107–171, title I, § 1304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/171"},"text":"116 Stat. 171","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf02891d0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf02891d1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf02891d2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsecs. (b)(1)(B), was in the original “this subtitle”, meaning subtitle C (§§ 1301–1310) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI"},"text":"Pub. L. 107–171, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/166"},"text":"116 Stat. 166","children":[],"tail":", which is classified principally to this subchapter. For complete classification of subtitle C to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7951"},"text":"section 7951 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
