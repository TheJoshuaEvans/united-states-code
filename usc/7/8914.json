{"tag":"section","attrib":{"id":"idf0451a73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914"},"text":null,"children":[{"tag":"num","attrib":{"value":"8914"},"text":"§ 8914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agriculture and food defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0451a74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451a75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Animal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “animal” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8302"},"text":"section 8302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disease or pest of concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “disease or pest of concern” means a plant or animal disease or pest that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451a77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0451a78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transboundary disease; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0451a79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an established disease; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is likely to pose a significant risk to the food and agriculture critical infrastructure sector that warrants efforts at prevention, protection, mitigation, response, and recovery.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Established disease","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “established disease” means a plant or animal disease or pest that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451a7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0451a7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if it becomes established, poses an imminent threat to agriculture in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0451a7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has become established, as defined by the Secretary, within the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-consequence plant transboundary disease","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “high-consequence plant transboundary disease” means a transboundary disease that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451a81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0451a82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plant disease; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0451a83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plant pest; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of high consequence, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pest","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “pest”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451a86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a plant, has the meaning given the term “plant pest” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7702"},"text":"section 7702 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to an animal, has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8302"},"text":"section 8302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “plant” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7702"},"text":"section 7702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plant health management strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “plant health management strategy” means a strategy to timely control and eradicate a plant disease or plant pest outbreak, including through mitigation (such as chemical control), surveillance, the use of diagnostic products and procedures, and the use of existing resistant seed stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transboundary disease","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451a8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “transboundary disease” means a plant or animal disease or pest that is within 1 or more countries outside of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “transboundary disease” includes a plant or animal disease or pest described in subparagraph (A) that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0451a8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has emerged within the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0451a8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been introduced within the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterinary countermeasure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “veterinary countermeasure” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8302"},"text":"section 8302 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0451a90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disease or Pest of Concern Response Planning","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451a91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451a92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a list of diseases or pests of concern by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0451a93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing a process to solicit and receive expert opinion and evidence relating to the diseases or pests of concern entered on the list; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0451a94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing all available evidence relating to the diseases or pests of concern entered on the list, including classified information; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically update the list established under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response plans","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451a97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive strategic response plan or plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop, in collaboration with appropriate Federal, State, regional, and local officials, a comprehensive strategic response plan or plans, as appropriate, for the diseases or pests of concern that are entered on the list established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State or region response plan or plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide information to a State or region to assist in producing a response plan or plans that shall include a concept of operations for a disease or pest of concern or a platform concept of operations for responses to similar diseases or pests of concern that are determined to be a priority to the State or region that shall, as appropriate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0451a99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe the appropriate interactions among, and roles of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf0451a9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, Tribal, and units of local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0451a9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plant or animal industry partners;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0451a9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a decision matrix or dynamic decision modeling tools that, as appropriate, include—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf0451a9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and timing requirements necessary for the use of veterinary countermeasures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0451a9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plant health management strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0451a9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deployment of other key materials and resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0451aa0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" parameters for transitioning from outbreak response to disease management;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0451aa1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify key response performance metrics to establish—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf0451aa2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benchmarking to provide assessments of capabilities, capacity, and readiness to achieve response goals and objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0451aa3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progressive exercise evaluation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0451aa4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" continuing improvement of a response plan, including by providing for—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idf0451aa5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/iii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ongoing exercises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idf0451aa6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/iii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvement planning and the implementation of corrective actions to enhance a response plan over time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idf0451aa7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/iii/III/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategic information to guide investment in any appropriate research to mitigate the risk of a disease or pest of concern; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0451aa8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be updated periodically, including in response to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf0451aa9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an exercise evaluation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0451aaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new risk information becoming available regarding a disease or pest of concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451aab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6922/d/6"},"text":"section 6922(d)(6) of this title","children":[],"tail":", as added by section 12202, the Secretary shall, as appropriate, assist in coordinating with other appropriate Federal, State, regional, or local officials in the exercising of the plans developed under paragraph (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0451aac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Plant Diagnostic Network","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451aad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish in the Department of Agriculture a National Plant Diagnostic Network to monitor and surveil through diagnostics threats to plant health from diseases or pests of concern in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451aae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Plant Diagnostic Network established under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451aaf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for increased awareness, surveillance, early identification, rapid communication, warning, and diagnosis of a threat to plant health from a disease or pest of concern to protect natural and agricultural plant resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451ab0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and collaborate with agencies of the Department of Agriculture and State agencies and authorities involved in plant health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451ab1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish diagnostic laboratory standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451ab2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish regional hubs throughout the United States that provide expertise, leadership, and support to diagnostic labs relating to the agricultural crops and plants in the covered regions of those hubs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451ab3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a national repository for records of endemic or emergent diseases and pests of concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451ab4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Head of network","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451ab5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institute of Food and Agriculture shall serve as the head of the National Plant Diagnostic Network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451ab6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of the National Plant Diagnostic Network shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0451ab7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and collaborate with land-grant colleges and universities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":") in carrying out the requirements under paragraph (2), including through cooperative agreements described in paragraph (4);"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0451ab8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partner with the Administrator of the Animal and Plant Health Inspection Service for assistance with plant health regulation and inspection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0451ab9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with other Federal agencies, as appropriate, in carrying out activities relating to the National Plant Diagnostic Network, including the sharing of biosurveillance information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451aba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collaboration with land-grant colleges and universities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall seek to establish cooperative agreements with land-grant colleges and universities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":") that have the appropriate level of skill, experience, and competence with plant diseases or pests of concern."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451abb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the amount authorized to carry out this subtitle under section 12205,","children":[{"tag":"ref","attrib":{"idref":"fn002385"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002385"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" there is authorized to be appropriated to carry out this subsection $15,000,000 for each of fiscal years 2019 through 2023."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0451abc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Plant Disease Recovery System","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451abd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery System","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish in the Department of Agriculture a National Plant Disease Recovery System to engage in strategic long-range planning to recover from high-consequence plant transboundary diseases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451abe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Plant Disease Recovery System established under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451abf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with disease or pest of concern concept of operations response plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451ac0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make long-range plans for the initiation of future research projects relating to high-consequence plant transboundary diseases;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451ac1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish research plans for long-term recovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451ac2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan for the identification and use of specific genotypes, cultivars, breeding lines, and other disease-resistant materials necessary for crop stabilization or improvement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451ac3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8914/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a watch list of high-consequence plant transboundary diseases for the purpose of making long-range plans under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0451ac4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12203"},"text":"Pub. L. 115–334, title XII, § 12203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4946"},"text":"132 Stat. 4946","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0451ac5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0451ac6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0451ac7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 12202, referred to in subsec. (b)(3), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12202"},"text":"section 12202 of Pub. L. 115–334","children":[],"tail":", title XII, "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4944"},"text":"132 Stat. 4944","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6922"},"text":"section 6922 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The amount authorized to carry out this subtitle under section 12205, referred to in subsec. (c)(5), means the amount authorized to carry out subtitle B (§§ 12201–12205) of title XII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4944"},"text":"132 Stat. 4944","children":[],"tail":", which enacted sections 6922 and 8914 of this title, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8401"},"text":"section 8401 of this title","children":[],"tail":", and repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8911"},"text":"section 8911 of this title","children":[],"tail":", under section 12205 of such Act, which was not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf0451ac8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agriculture Improvement Act of 2018, and not as part of the Department of Agriculture Reorganization Act of 1994 which in part comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0451ac9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idf0451aca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” means the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2"},"text":"section 2 of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
