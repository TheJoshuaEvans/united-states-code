{"tag":"section","attrib":{"id":"idf02adbb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7984"},"text":null,"children":[{"tag":"num","attrib":{"value":"7984"},"text":"§ 7984.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies of effects of changes in approach to national dairy policy and fluid milk identity standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02adbb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7984/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal dairy policy changes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall conduct a study of the effects of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02adbb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7984/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminating all Federal programs relating to price support and supply management for milk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02adbb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7984/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" granting the consent of Congress to cooperative efforts by States to manage milk prices and supply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adbb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7984/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fluid milk identity standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a study of the effects of including in the standard of identity for fluid milk a required minimum protein content that is commensurate with the average nonfat solids content of bovine milk produced in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02adbb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7984/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing the results of the studies required by this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02adbb8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1508"},"text":"Pub. L. 107–171, title I, § 1508","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/211"},"text":"116 Stat. 211","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
