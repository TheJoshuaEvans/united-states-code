{"tag":"section","attrib":{"id":"ideec2e76c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1508a"},"text":"§ 1508a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Double insurance and prevented planting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideec2e76d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideec2e76e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First crop","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “first crop” means the first crop of the first agricultural commodity planted for harvest, or prevented from being planted, on specific acreage during a crop year and insured under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e76f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second crop","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “second crop” means a second crop of the same agricultural commodity as the first crop, or a crop of a different agricultural commodity following the first crop, planted on the same acreage as the first crop for harvest in the same crop year, except the term does not include a replanted crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e770-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Replanted crop","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “replanted crop” means any agricultural commodity replanted on the same acreage as the first crop for harvest in the same crop year if the replanting is required by the terms of the policy of insurance covering the first crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideec2e771-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Double insurance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideec2e772-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Options on loss to first crop","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsections (d) and (e), if a first crop insured under this subchapter in a crop year has a total or partial insurable loss, the producer of the first crop may elect one of the following options:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideec2e773-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No second crop planted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The producer may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideec2e774-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elect to not plant a second crop on the same acreage for harvest in the same crop year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideec2e775-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect an indemnity payment that is equal to 100 percent of the insurable loss for the first crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec2e776-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second crop planted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The producer may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideec2e777-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plant a second crop on the same acreage for harvest in the same crop year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideec2e778-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collect an indemnity payment established by the Corporation for the first crop, but not to exceed 35 percent of the insurable loss for the first crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e779-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of no loss to second crop","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a producer makes an election under paragraph (1)(B) and the producer does not suffer an insurable loss to the second crop, the producer may collect an indemnity payment for the first crop that is equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideec2e77a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent of the insurable loss for the first crop; less","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec2e77b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount previously collected under paragraph (1)(B)(ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e77c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium for first crop if second crop planted","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideec2e77d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial premium","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a producer makes an election under paragraph (1)(B), the producer shall be responsible for a premium for the first crop that is commensurate with the indemnity paid under paragraph (1)(B)(ii). The Corporation shall adjust the total premium for the first crop to reflect the reduced indemnity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec2e77e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of no loss to second crop","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the producer makes an election under paragraph (1)(B) and the producer does not suffer an insurable loss to the second crop, the producer shall be responsible for a premium for the first crop that is equal to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideec2e77f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the full premium owed by the producer for the first crop; less","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideec2e780-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of premium previously paid under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideec2e781-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevented planting coverage","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideec2e782-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Options on loss to first crop","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsections (d) and (e), if a first crop insured under this subchapter in a crop year is prevented from being planted, the producer of the first crop may elect one of the following options:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideec2e783-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No second crop planted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The producer may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideec2e784-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elect to not plant a second crop on the same acreage for harvest in the same crop year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideec2e785-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (4), collect an indemnity payment that is equal to 100 percent of the prevented planting guarantee for the acreage for the first crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec2e786-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second crop planted","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The producer may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideec2e787-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plant a second crop on the same acreage for harvest in the same crop year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideec2e788-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraphs (4) and (5), collect an indemnity payment established by the Corporation for the first crop, but not to exceed 35 percent of the prevented planting guarantee for the acreage for the first crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e789-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Premium for first crop if second planted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the producer makes an election under paragraph (1)(B), the producer shall pay a premium for the first crop that is commensurate with the indemnity paid under paragraph (1)(B)(ii). The Corporation shall adjust the total premium for the first crop to reflect the reduced indemnity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e78a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on actual production history","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in the case of double cropping described in subsection (d), if a producer make an election under paragraph (1)(B) for a crop year, the Corporation shall assign the producer a recorded yield for that crop year for the first crop equal to 60 percent of the producer’s actual production history for the agricultural commodity involved, for purposes of determining the producer’s actual production history for subsequent crop years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e78b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Area conditions required for payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Corporation shall limit prevented planting payments for producers to those situations in which other producers, in the area where a first crop is prevented from being planted is located, are also generally affected by the conditions that prevented the first crop from being planted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e78c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planting date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a producer plants the second crop before the latest planting date established by the Corporation for the first crop, the Corporation shall not make a prevented planting payment with regard to the first crop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideec2e78d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for established double cropping practices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A producer may receive full indemnity payments on two or more crops planted for harvest in the same crop year and insured under this subchapter if each of the following conditions are met:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideec2e78e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is an established practice of planting two or more crops for harvest in the same crop year in the area, as determined by the Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e78f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An additional coverage policy or plan of insurance is offered with respect to the agricultural commodities planted on the same acreage for harvest in the same crop year in the area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e790-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The producer has a history of planting two or more crops for harvest in the same crop year or the applicable acreage has historically had two or more crops planted for harvest in the same crop year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e791-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The second or more crops are customarily planted after the first crop for harvest on the same acreage in the same year in the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideec2e792-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent crops","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except in the case of double cropping described in subsection (d), if a producer elects to plant a crop (other than a replanted crop) subsequent to a second crop on the same acreage as the first crop and second crop for harvest in the same crop year, the producer shall not be eligible for insurance under this subchapter, or noninsured crop assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7333"},"text":"section 7333 of this title","children":[],"tail":", for the subsequent crop."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideec2e793-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title V, § 508A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/224/tI/s108"},"text":"Pub. L. 106–224, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/368"},"text":"114 Stat. 368","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXII/s12033/c/2/B"},"text":"Pub. L. 110–234, title XII, § 12033(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1405"},"text":"122 Stat. 1405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XII, § 12033(c)(2)(B), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2167.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideec2e794-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideec2e795-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideec2e796-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of P