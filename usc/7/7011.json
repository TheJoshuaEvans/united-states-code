{"tag":"section","attrib":{"id":"ideff8cfa3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011"},"text":null,"children":[{"tag":"num","attrib":{"value":"7011"},"text":"§ 7011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Successorship provisions relating to bargaining units and exclusive representatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff8cfa4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff8cfa5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the exercise of the Secretary’s authority under this chapter results in changes to an existing bargaining unit that has been certified under chapter 71 of title 5, the affected parties shall attempt to reach a voluntary agreement on a new bargaining unit and an exclusive representative for such unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cfa6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the requirements of this subsection, the affected parties shall use criteria set forth in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff8cfa7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 7103(a)(4), 7111(e), 7111(f)(1), and 7120 of title 5, relating to determining an exclusive representative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cfa8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7112"},"text":"section 7112 of title 5","children":[],"tail":" (disregarding subsections (b)(5) and (d) thereof), relating to determining appropriate units."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cfa9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of an agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff8cfaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the affected parties reach agreement on the appropriate unit and the exclusive representative for such unit under subsection (a), the Federal Labor Relations Authority shall certify the terms of such agreement, subject to paragraph (2)(A). Nothing in this subsection shall be considered to require the holding of any hearing or election as a condition for certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cfab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff8cfac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions requiring noncertification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Labor Relations Authority may not certify the terms of an agreement under paragraph (1) if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideff8cfad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it determines that any of the criteria referred to in subsection (a)(2) (disregarding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7112/a"},"text":"section 7112(a) of title 5","children":[],"tail":") have not been met; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideff8cfae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the Secretary’s exercise of authority and before certification under this section, a valid election under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7111/b"},"text":"section 7111(b) of title 5","children":[],"tail":" is held covering any employees who would be included in the unit proposed for certification."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cfaf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary waiver of provision that would bar an election after a collective bargaining agreement is reached","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7111/f/3"},"text":"section 7111(f)(3) of title 5","children":[],"tail":" shall prevent the holding of an election under section 7111(b) of such title that covers employees within a unit certified under paragraph (1), or giving effect to the results of such an election (including a decision not to be represented by any labor organization), if the election is held before the end of the 12-month period beginning on the date such unit is so certified."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cfb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The certification of a unit under paragraph (1) shall not, for purposes of the last sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7111/b"},"text":"section 7111(b) of title 5","children":[],"tail":" or section 7111(f)(4) of such title, be treated as if it had occurred pursuant to an election."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cfb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideff8cfb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Labor Relations Authority may delegate to any regional director (as referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7105/e"},"text":"section 7105(e) of title 5","children":[],"tail":") its authority under the preceding provisions of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideff8cfb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any action taken by a regional director under subparagraph (A) shall be subject to review under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7105/f"},"text":"section 7105(f) of title 5","children":[],"tail":" in the same manner as if such action had been taken under section 7105(e) of such title, except that in the case of a decision not to certify, such review shall be required if application therefor is filed by an affected party within the time specified in such provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cfb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Affected party” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term “affected party” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff8cfb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to an exercise of authority by the Secretary under this chapter, any labor organization affected thereby; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff8cfb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7011/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff8cfb7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s291"},"text":"Pub. L. 103–354, title II, § 291","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3235"},"text":"108 Stat. 3235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff8cfb8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff8cfb9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideff8cfba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a)(1) and (c)(1), was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3209"},"text":"108 Stat. 3209","children":[],"tail":", known as the Department of Agriculture Reorganization Act of 1994. For complete classification of title II to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6901"},"text":"section 6901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
