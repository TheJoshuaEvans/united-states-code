{"tag":"section","attrib":{"id":"idf0130dba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7516"},"text":null,"children":[{"tag":"num","attrib":{"value":"7516"},"text":"§ 7516.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement and adjustment of claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0130dbb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7516/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or a designee of the Secretary shall have the authority to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0130dbc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7516/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the amount of, settle, and adjust any claim arising under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0130dbd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7516/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waive such a claim if the Secretary determines that to do so will serve the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0130dbe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7516/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Litigation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing contained in this section shall be construed to diminish the authority of the Attorney General of the United States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s516"},"text":"section 516 of title 28","children":[],"tail":" to conduct litigation on behalf of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0130dbf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/8/tII/s215"},"text":"Pub. L. 98–8, title II, § 215","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIX/s922/b"},"text":"Pub. L. 102–237, title IX, § 922(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1888"},"text":"105 Stat. 1888","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0130dc0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0130dc1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf0130dc2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective and to be implemented no later than ","children":[{"tag":"date","attrib":{"date":"1992-02-01"},"text":"Feb. 1, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/s1101/d/1"},"text":"section 1101(d)(1) of Pub. L. 102–237","children":[],"tail":", set out as an Effective Date of 1991 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"t