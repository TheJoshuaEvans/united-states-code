{"tag":"section","attrib":{"id":"idee0674d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m"},"text":null,"children":[{"tag":"num","attrib":{"value":"136m"},"text":"§ 136m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee0674d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General indemnification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee0674da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee0674db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator notifies a registrant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136d/c/1"},"text":"section 136d(c)(1) of this title","children":[],"tail":" that the Administrator intends to suspend a registration or that an emergency order of suspension of a registration under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136d/c/3"},"text":"section 136d(c)(3) of this title","children":[],"tail":" has been issued;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0674dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the registration in question is suspended under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136d/c"},"text":"section 136d(c) of this title","children":[],"tail":", and thereafter is canceled under section 136d(b), 136d(d), or 136d(f) of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0674dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who owned any quantity of the pesticide immediately before the notice to the registrant under subparagraph (A) suffered losses by reason of suspension or cancellation of the registration;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Administrator shall make an indemnity payment to the person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee0674de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not apply if the Administrator finds that the person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee0674df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had knowledge of facts that, in themselves, would have shown that the pesticide did not meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136a/c/5"},"text":"section 136a(c)(5) of this title","children":[],"tail":" for registration; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0674e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continued thereafter to produce the pesticide without giving timely notice of such facts to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee0674e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Administrator takes an action under paragraph (1) that requires the payment of indemnification, the Administrator shall report to the Committee on Agriculture of the House of Representatives, the Committee on Agriculture, Nutrition, and Forestry of the Senate, and the Committees on Appropriations of the House of Representatives and the Senate on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee0674e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the action taken that requires the payment of indemnification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0674e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons for taking the action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0674e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated cost of the payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0674e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request for the appropriation of funds for the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee0674e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may not make a payment of indemnification under paragraph (1) unless a specific line item appropriation of funds has been made in advance for the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee0674e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indemnification of end users, dealers, and distributors","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee0674e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" End users","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee0674e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator notifies a registrant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136d/c/1"},"text":"section 136d(c)(1) of this title","children":[],"tail":" that the Administrator intends to suspend a registration or that an emergency order of suspension of a registration under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136d/c/3"},"text":"section 136d(c)(3) of this title","children":[],"tail":" has been issued;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0674ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the registration in question is suspended under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136d/c"},"text":"section 136d(c) of this title","children":[],"tail":", and thereafter is canceled under section 136d(b), 136d(d), or 136d(f) of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0674eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who, immediately before the notice to the registrant under subparagraph (A), owned any quantity of the pesticide for purposes of applying or using the pesticide as an end user, rather than for purposes of distributing or selling it or further processing it for distribution or sale, suffered a loss by reason of the suspension or cancellation of the pesticide;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the person shall be entitled to an indemnity payment under this subsection for such quantity of the pesticide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee0674ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dealers and distributors","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee0674ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any registrant, wholesaler, dealer, or other distributor (hereinafter in this paragraph referred to as a “seller”) of a registered pesticide who distributes or sells the pesticide directly to any person not described as an end user in paragraph (1)(C) shall, with respect to any quantity of the pesticide that such person cannot use or resell as a result of the suspension or cancellation of the pesticide, reimburse such person for the cost of first acquiring the pesticide from the seller (other than the cost of transportation, if any), unless the seller provided to the person at the time of distribution or sale a notice, in writing, that the pesticide is not subject to reimbursement by the seller.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0674ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee0674ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator notifies a registrant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136d/c/1"},"text":"section 136d(c)(1) of this title","children":[],"tail":" that the Administrator intends to suspend a registration or that an emergency order of suspension of a registration under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136d/c/3"},"text":"section 136d(c)(3) of this title","children":[],"tail":" has been issued;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee0674f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the registration in question is suspended under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136d/c"},"text":"section 136d(c) of this title","children":[],"tail":", and thereafter is canceled under section 136d(b), 136d(d), or 136d(f) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee0674f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any person who, immediately before the notice to the registrant under clause (i)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idee0674f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had not been notified in writing by the seller, as provided under subparagraph (A), that any quantity of the pesticide owned by such person is not subject to reimbursement by the seller in the event of suspension or cancellation of the pesticide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idee0674f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" owned any quantity of the pesticide for purposes of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idee0674f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/2/B/iii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributing or selling it; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idee0674f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/2/B/iii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further processing it for distribution or sale directly to an end user;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"suffered a loss by reason of the suspension or cancellation of the pesticide; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee0674f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Administrator determines on the basis of a claim of loss submitted to the Administrator by the person, that the seller—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idee0674f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" did not provide the notice specified in subparagraph (A) to such person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idee0674f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is and will continue to be unable to provide reimbursement to such person, as provided under subparagraph (A), for the loss referred to in clause (iii), as a result of the insolvency or bankruptcy of the seller and the seller’s resulting inability to provide such reimbursement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the person shall be entitled to an indemnity payment under this subsection for such quantity of the pesticide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee0674f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an indemnity payment is made by the United States under this paragraph, the United States shall be subrogated to any right that would otherwise be held under this paragraph by a seller who is unable to make a reimbursement in accordance with this paragraph with regard to reimbursements that otherwise would have been made by the seller.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee0674fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any payment required to be made under paragraph (1) or (2) shall be made from the appropriation provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee0674fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative settlement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An administrative settlement of a claim for such indemnity may be made in accordance with the third paragraph of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2414"},"text":"section 2414 of title 28","children":[],"tail":" and shall be regarded as if it were made under that section for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee0674fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of payment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee0674fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of an indemnity payment under subsection (a) or (b) to any person shall be determined on the basis of the cost of the pesticide owned by the person (other than the cost of transportation, if any) immediately before the issuance of the notice to the registrant referred to in subsection (a)(1)(A), (b)(1)(A), or (b)(2)(B)(i), except that in no event shall an indemnity payment to any person exceed the fair market value of the pesticide owned by the person immediately before the issuance of the notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee0674fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136m/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this subchapter, the Administrator may provide a reasonable time for use or other disposal of the pesticide. In determining the quantity of any pesticide for which indemnity shall be paid under this section, proper adjustment shall be made for any pesticide used or otherwise disposed of by the owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee0674ff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125/s15"},"text":"June 25, 1947, ch. 125, § 15","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/516/s2"},"text":"Pub. L. 92–516, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/993"},"text":"86 Stat. 993","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/532/tV/s501/a"},"text":"Pub. L. 100–532, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2674"},"text":"102 Stat. 2674","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee067500-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee067501-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee067502-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/532"},"text":"Pub. L. 100–532","children":[],"tail":" amended section generally, in subsec. (a), substituting provisions relating to general indemnification for provisions relating to requirements for payment, adding subsec. (b), and redesignating provisions of former subsec. (b), with further amendment, as subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee067503-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee067504-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/532/tV/s501/a"},"text":"Pub. L. 100–532, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2674"},"text":"102 Stat. 2674","children":[],"tail":", provided that amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/100/532"},"text":"Pub. L. 100–532","children":[],"tail":" is effective 180 days after "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee067505-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/516/s4"},"text":"section 4 of Pub. L. 92–516","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"section 136 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee067506-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Interim Payments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/532/tV/s501/b"},"text":"Pub. L. 100–532, title V, § 501(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2676"},"text":"102 Stat. 2676","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/532/tV/s501/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Source","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any obligation of the Administrator to pay an indemnity arising under section 15 [this section], as it existed prior to the effective date of the amendment made by this section [see Effective Date of 1988 Amendment note above], shall be made from the appropriation provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative settlement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An administrative settlement of a claim for such indemnity may be made in accordance with the third paragraph of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2414"},"text":"section 2414 of title 28","children":[],"tail":", United States Code, and shall be regarded as if it were made under that section for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1304"},"text":"section 1304 of title 31","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
