{"tag":"section","attrib":{"id":"idedf118a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87k"},"text":null,"children":[{"tag":"num","attrib":{"value":"87k"},"text":"§ 87k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standardizing commercial inspections","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedf118a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87k/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing equipment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To promote greater uniformity in commercial grain inspection results, the Secretary may work in conjunction with the National Institute for Standards and Technology, the National Conference on Weights and Measures, or other appropriate governmental, scientific, or technical organizations to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedf118a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87k/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify inspection instruments requiring standardization under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedf118aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87k/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish performance criteria for commercial grain inspection instruments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedf118ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87k/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a national program to approve grain inspection instruments for commercial inspection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedf118ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87k/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop standard reference materials or other means necessary for calibration or testing of approved instruments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf118ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87k/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General inspection procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure that producers are treated uniformly in delivering grain, the Secretary shall develop practical and cost-effective procedures for conducting commercial inspections of grain with respect to the application of quality factors, that result in premiums and discounts. The procedures shall be made available to country elevators and others making first-point-of-delivery inspections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf118ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87k/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection services and information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To encourage the use of equipment and procedures developed in accordance with subsections (a) and (b), the Secretary shall provide for official inspection services by the Secretary, States, and official inspection agencies and provide information on the proper use of sampling and inspection equipment, application of the grain standards, and availability of official inspection services, including appeals under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf118af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87k/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standardized aflatoxin equipment and procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedf118b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87k/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish uniform standards for testing equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedf118b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87k/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish uniform testing procedures and sampling techniques;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that may be used by processors, refiners, operators of grain elevators and terminals, and others to accurately detect the level of aflatoxin contamination of corn in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedf118b2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. B, § 22, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXX/s2009"},"text":"Pub. L. 101–624, title XX, § 2009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3931"},"text":"104 Stat. 3931","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/156"},"text":"Pub. L. 103–156","children":[],"tail":", §§ 11, 13(b)(2), "},{"tag":"date","attrib":{"date":"1993-11-24"},"text":"Nov. 24, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1528"},"text":"107 Stat. 1528","children":[],"tail":", 1529; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s293/a/7"},"text":"Pub. L. 103–354, title II, § 293(a)(7)","children":[],"tail":", (8), "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3237"},"text":"108 Stat. 3237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedf118b3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idedf118b4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idedf118b5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c), was in the original “this Act” and was translated as reading “this part”, meaning part B of act ","children":[{"tag":"date","attrib":{"date":"1916-08-11"},"text":"Aug. 11, 1916","children":[],"tail":", known as the United States Grain Standards Act, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idedf118b6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing and “Secretary” for “Service” in subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/156/s11"},"text":"Pub. L. 103–156, § 11","children":[],"tail":", substituted “, the National Conference on Weights and Measures, or other appropriate governmental, scientific, or technical organizations” for “and the National Conference on Weights and Measures” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/156/s13/b/2"},"text":"Pub. L. 103–156, § 13(b)(2)","children":[],"tail":", substituted “subsections (a) and (b)” for “subsection (a) and (b)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
