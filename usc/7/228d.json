{"tag":"section","attrib":{"id":"idee20b41f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s228d"},"text":null,"children":[{"tag":"num","attrib":{"value":"228d"},"text":"§ 228d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual assessment of cattle and hog industries","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than March 1 of each year, the Secretary shall submit to Congress and make publicly available a report that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee20b420-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s228d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the general economic state of the cattle and hog industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b421-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s228d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes changing business practices in those industries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee20b422-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s228d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies market operations or activities in those industries that appear to raise concerns under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee20b423-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title IV, § 415, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tIII/s312/e/2"},"text":"Pub. L. 106–472, title III, § 312(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2077"},"text":"114 Stat. 2077","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee20b424-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee20b425-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee20b426-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 415 of act ","children":[{"tag":"date","attrib":{"date":"1921-08-15"},"text":"Aug. 15, 1921","children":[],"tail":", was renumbered section 417 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s229c"},"text":"section 229c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
