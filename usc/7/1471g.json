{"tag":"section","attrib":{"id":"ideeb48f28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1471g"},"text":"§ 1471g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeb48f29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total amount of benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of benefits that a person shall be entitled to receive annually under one or more of the programs established under this subchapter may not exceed $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb48f2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideeb48f2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defining the term “person”, which shall conform, to the extent practicable, to the regulations defining the term “person” issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308"},"text":"section 1308 of this title","children":[],"tail":" (before the amendment made by section 1603(a) "},{"tag":"ref","attrib":{"idref":"fn002165"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002165"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Food, Conservation, and Energy Act of 2008), or successor statute;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribing such rules as the Secretary determines necessary to ensure a fair and reasonable application of the limitation established under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideeb48f2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471g/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing that the term “person” shall include, in the case of any cooperative association of producers, each member of the association with respect to benefits due to such member of the association.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb48f2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt of other disaster payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person may receive benefits under this subchapter attributable to lost production of a feed commodity due to a natural disaster in 1988 to the extent that such person receives a disaster payment under the Disaster Assistance Act of 1988 on such lost production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeb48f2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1471g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total combined payment and benefits limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each person otherwise eligible for a livestock emergency benefit under this subchapter in 1988 shall be subject to the combined payment and benefits limitation established under section 211(c) of the Disaster Assistance Act of 1988.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeb48f30-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"Oct. 31, 1949, ch. 792","children":[],"tail":", title VI, § 609, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/387/tI/s101/a"},"text":"Pub. L. 100–387, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-11"},"text":"Aug. 11, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/930"},"text":"102 Stat. 930","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1603/g/2"},"text":"Pub. L. 110–234, title I, § 1603(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1011"},"text":"122 Stat. 1011","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1603(g)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1739; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1609/b/1"},"text":"Pub. L. 113–79, title I, § 1609(b)(1)","children":[],