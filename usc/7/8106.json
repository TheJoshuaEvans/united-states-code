{"tag":"section","attrib":{"id":"idf02fbdbf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8106"},"text":null,"children":[{"tag":"num","attrib":{"value":"8106"},"text":"§ 8106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biodiesel fuel education program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02fbdc0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, under such terms and conditions as the Secretary determines to be appropriate, make competitive grants to eligible entities to educate governmental and private entities that operate vehicle fleets, other interested entities (as determined by the Secretary), and the public about the benefits of biodiesel fuel use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbdc1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive a grant under subsection (b), an entity shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02fbdc2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a nonprofit organization or institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbdc3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have demonstrated knowledge of biodiesel fuel production, use, or distribution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbdc4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have demonstrated the ability to conduct educational and technical support programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbdc5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall consult with the Secretary of Energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbdc6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $2,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02fbdc7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIX/s9006"},"text":"Pub. L. 107–171, title IX, § 9006","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIX/s900