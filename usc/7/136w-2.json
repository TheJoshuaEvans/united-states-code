{"tag":"section","attrib":{"id":"idee0b2ff2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"136w–2"},"text":"§ 136w–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure by the State to assure enforcement of State pesticide use regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee0b2ff3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon receipt of any complaint or other information alleging or indicating a significant violation of the pesticide use provisions of this subchapter, the Administrator shall refer the matter to the appropriate State officials for their investigation of the matter consistent with the requirements of this subchapter. If, within thirty days, the State has not commenced appropriate enforcement action, the Administrator may act upon the complaint or information to the extent authorized under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee0b2ff4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Administrator determines that a State having primary enforcement responsibility for pesticide use violations is not carrying out (or cannot carry out due to the lack of adequate legal authority) such responsibility, the Administrator shall notify the State. Such notice shall specify those aspects of the administration of the State program that are determined to be inadequate. The State shall have ninety days after receipt of the notice to correct any deficiencies. If after that time the Administrator determines that the State program remains inadequate, the Administrator may rescind, in whole or in part, the State’s primary enforcement responsibility for pesticide use violations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee0b2ff5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136w–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Neither ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136w–1"},"text":"section 136w–1 of this title","children":[],"tail":" nor this section shall limit the authority of the Administrator to enforce this subchapter, where the Administrator determines that emergency conditions exist that require immediate action on the part of the Administrator and the State authority is unwilling or unable adequately to respond to the emergency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee0b2ff6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125/s27"},"text":"June 25, 1947, ch. 125, § 27","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/396/s24/2"},"text":"Pub. L. 95–396, § 24(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/837"},"text":"92 Stat. 837","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/532/tVIII/s801/p"},"text":"Pub. L. 100–532, title VIII, § 801(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2683"},"text":"102 Stat. 2683","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee0b2ff7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee0b2ff8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee0b2ff9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 27 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125"},"text":"act June 25, 1947, ch. 125","children":[],"tail":", was renumbered section 35 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136y"},"text":"section 136y of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee0b2ffa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/532"},"text":"Pub. L. 100–532","children":[],"tail":" inserted headings for subsecs. (a) to (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee0b2ffb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee0b2ffc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/532"},"text":"Pub. L. 100–532","children":[],"tail":" effective on expiration of 60 days after "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/532/s901"},"text":"section 901 of Pub. L. 100–532","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"section 136 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
