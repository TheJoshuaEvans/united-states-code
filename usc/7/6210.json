{"tag":"section","attrib":{"id":"idefde915a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6210"},"text":null,"children":[{"tag":"num","attrib":{"value":"6210"},"text":"§ 6210.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension and termination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefde915b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6210/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary finds that an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6203/a"},"text":"section 6203(a) of this title","children":[],"tail":", or a provision of such order, obstructs or does not tend to effectuate the purposes of this chapter, the Secretary shall terminate or suspend the operation of such order or provision."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde915c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6210/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic referenda","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may periodically conduct a referendum to determine if lime producers, producer-handlers, and importers favor the continuation, termination, or suspension of any order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6203/a"},"text":"section 6203(a) of this title","children":[],"tail":" and in effect at the time of such referendum."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde915d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6210/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required referenda","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall hold a referendum under subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefde915e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6210/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of the Board; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde915f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6210/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if not less than 10 percent of the lime producers, producer-handlers, and importers subject to assessment under this chapter submit a petition requesting such a referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde9160-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6210/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The termination or suspension of any order, or any provision thereof, shall not be considered an order within the meaning of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde9161-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6210/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vote","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall suspend or terminate the order at the end of the marketing year if the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefde9162-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6210/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the suspension or termination of the order is favored by not less than a majority of those persons voting in a referendum under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9163-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6210/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the producers, producer-handlers, and importers comprising this majority produce and import more than 50 percent of the volume of limes produced and imported by those voting in the referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefde9164-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1961"},"text":"Pub. L. 101–624, title XIX, § 1961","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3880"},"text":"104 Stat. 3880","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
