{"tag":"section","attrib":{"id":"idee8e696a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1363"},"text":null,"children":[{"tag":"num","attrib":{"value":"1363"},"text":"§ 1363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of quota; review committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any farmer who is dissatisfied with his farm marketing quota may, within fifteen days after mailing to him of notice as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1362"},"text":"section 1362 of this title","children":[],"tail":", have such quota reviewed by a local review committee composed of three farmers from the same or nearby counties appointed by the Secretary. Such committee shall not include any member of the local committee which determined the farm acreage allotment, the normal yield, or the farm marketing quota for such farm. Unless application for review is made within such period, the original determination of the farm marketing quota shall be final."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee8e696b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 363, "},{"tag":"ref","attrib":{"href":"/us/stat/52/63"},"text":"52 Stat. 63","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-04-12/ch28/s3"},"text":"Apr. 12, 1951, ch. 28, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/31"},"text":"65 Stat. 31","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee8e696c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee8e696d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee8e696e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-04-12"},"text":"Apr. 12, 1951","children":[],"tail":", provided that the Secretary appoint a local review committee composed of 3 farmers from the same or nearby counties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee8e696f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee8e6970-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Review of 1950 Cotton Farm Acreage Allotment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-03-31/ch81/s2"},"text":"Act Mar. 31, 1950, ch. 81, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/41"},"text":"64 Stat. 41","children":[],"tail":", provided that any farmer dissatisfied with his farm acreage allotment for the 1950 cotton crop could have such allotment reviewed in accordance with the provisions of this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
