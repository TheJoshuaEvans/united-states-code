{"tag":"section","attrib":{"id":"idf02fbe24-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8107a"},"text":"§ 8107a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural energy savings program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02fbe25-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to help rural families and small businesses achieve cost savings by providing loans to qualified consumers to implement durable cost-effective energy efficiency measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbe26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02fbe27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02fbe28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any public power district, public utility district, or similar entity, or any electric cooperative described in section 501(c)(12) or 1381(a)(2) of title 26, that borrowed and repaid, prepaid, or is paying an electric loan made or guaranteed by the Rural Utilities Service (or any predecessor agency);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbe29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any entity primarily owned or controlled by 1 or more entities described in subparagraph (A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbe2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other entity that is an eligible borrower of the Rural Utilities Service, as determined under section 1710.101 of title 7, Code of Federal Regulations (or a successor regulation).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Energy efficiency measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “energy efficiency measures” means, for or at property served by an eligible entity, structural improvements and investments in cost-effective, commercial technologies to increase energy efficiency (including cost-effective on- or off-grid renewable energy or energy storage systems).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified consumer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified consumer” means a consumer served by an eligible entity that has the ability to repay a loan made under subsection (d), as determined by the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture, acting through the Administrator of the Rural Utilities Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbe2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans to eligible entities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02fbe2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary shall make loans to eligible entities that agree to use the loan funds to make loans to qualified consumers for the purpose of implementing energy efficiency measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02fbe31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition of receiving a loan under this subsection, an eligible entity shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02fbe32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a list of energy efficiency measures that is expected to decrease energy use or costs of qualified consumers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02fbe33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare an implementation plan for use of the loan funds, including use of any interest to be received pursuant to subsection (d)(1)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02fbe34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for appropriate measurement and verification to ensure—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf02fbe35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the energy efficiency loans made by the eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf02fbe36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that there is no conflict of interest in carrying out this section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02fbe37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate expertise in effective use of energy efficiency measures at an appropriate scale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbe38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revision of list of energy efficiency measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the approval of the Secretary, an eligible entity may update the list required under subparagraph (A)(i) to account for newly available efficiency technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbe39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing energy efficiency programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that, at any time before the date that is 60 days after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", has established an energy efficiency program for qualified consumers may use an existing list of energy efficiency measures, implementation plan, or measurement and verification system of that program to satisfy the requirements of subparagraph (A) if the Secretary determines the list, plan, or systems are consistent with the purposes of this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan under this subsection shall bear no interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for other loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not include any debt incurred by a borrower under this section in the calculation of the debt-equity ratio of the borrower for purposes of eligibility for loans under the Rural Electrification Act of 1936 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s901"},"text":"7 U.S.C. 901","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a loan under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02fbe3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term shall not exceed 20 years from the date on which the loan is closed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbe3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in paragraph (7), the repayment of each advance shall be amortized for a period not to exceed 10 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of advances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any advance of loan funds to an eligible entity in any single year shall not exceed 50 percent of the approved loan amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special advance for start-up activities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02fbe41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to assist an eligible entity in defraying the appropriate start-up costs (as determined by the Secretary) of establishing new programs or modifying existing programs to carry out subsection (d), the Secretary shall allow an eligible entity to request a special advance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbe42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No eligible entity may receive a special advance under this paragraph for an amount that is greater than 4 percent of the loan amount received by the eligible entity under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbe43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Repayment of the special advance—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02fbe44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be required during the 10-year period beginning on the date on which the special advance is made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02fbe45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the election of the eligible entity, may be deferred to the end of the 10-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe46-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All special advances shall be made under a loan described in paragraph (1) during the first 10 years of the term of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe47-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accounting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take appropriate steps to streamline the accounting requirements on borrowers under this section while maintaining adequate assurances of the repayment of the loans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbe48-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans to qualified consumers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02fbe49-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of loans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Loans made by an eligible entity to qualified consumers using loan funds provided by the Secretary under subsection (c)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02fbe4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may bear interest, not to exceed 5 percent, to be used for purposes that include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02fbe4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish a loan loss reserve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02fbe4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to offset personnel and program costs of eligible entities to provide the loans;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbe4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall finance energy efficiency measures for the purpose of decreasing energy usage or costs of the qualified consumer by an amount that ensures, to the maximum extent practicable, that a loan term of not more than 10 years will not pose an undue financial burden on the qualified consumer, as determined by the eligible entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbe4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be used to fund purchases of, or modifications to, personal property unless the personal property is or becomes attached to real property (including a manufactured home) as a fixture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbe4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be repaid through charges added to the recurring service bill for the property for, or at which, energy efficiency measures are or will be implemented, on the condition that this requirement does not prohibit—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02fbe50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/d/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the voluntary prepayment of a loan by the owner of the property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02fbe51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/d/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the use of any additional repayment mechanisms that are—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf02fbe52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/d/1/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrated to have appropriate risk mitigation features, as determined by the eligible entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf02fbe53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/d/1/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required if the qualified consumer is no longer a customer of the eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbe54-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require an energy audit by an eligible entity to determine the impact of proposed energy efficiency measures on the energy costs and consumption of the qualified consumer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe55-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contractors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other qualified general contractor, eligible entities may serve as general contractors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbe56-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract for measurement and verification, training, and technical assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02fbe57-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", the Secretary—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02fbe58-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish a plan for measurement and verification, training, and technical assistance of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02fbe59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may enter into 1 or more contracts with a qualified entity for the purposes of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf02fbe5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing measurement and verification activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf02fbe5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing a program to provide technical assistance and training to the employees of eligible entities to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of subcontractors authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A qualified entity that enters into a contract under paragraph (1) may use subcontractors to assist the qualified entity in carrying out the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbe5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority provided in this section is in addition to any other authority of the Secretary to offer loans under any other law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbe5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of funds and except as otherwise provided in this section, the loans and other expenditures required to be made under this section shall be available until expended, with the Secretary authorized to make new loans as loans are repaid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbe5f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after the end of each fiscal year, the Secretary shall publish a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02fbe60-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applications received under this section for that fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of loans made to eligible entities under this section for that fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02fbe62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipients of the loans described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02fbe63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8107a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $75,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf02fbe64-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6407"},"text":"Pub. L. 107–171, title VI, § 6407","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVI/s6205"},"text":"Pub. L. 113–79, title VI, § 6205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/857"},"text":"128 Stat. 857","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6303"},"text":"Pub. L. 115–334, title VI, § 6303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4749"},"text":"132 Stat. 4749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf02fbe65-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf02fbe66-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf02fbe67-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Rural Electrification Act of 1936, referred to in subsec. (c)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"act May 20, 1936, ch. 432","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1363"},"text":"49 Stat. 1363","children":[],"tail":", which is classified generally to chapter 31 (§ 901 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s901"},"text":"section 901 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf02fbe68-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", which comprises this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf02fbe69-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6303/1"},"text":"Pub. L. 115–334, § 6303(1)","children":[],"tail":", substituted “efficiency (including cost-effective on- or off-grid renewable energy or energy storage systems).” for “efficiency.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6303/2/B"},"text":"Pub. L. 115–334, § 6303(2)(B)","children":[],"tail":", added par. (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6303/2/A"},"text":"Pub. L. 115–334, § 6303(2)(A)","children":[],"tail":", redesignated par. (4) as (5). Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6303/2/C"},"text":"Pub. L. 115–334, § 6303(2)(C)","children":[],"tail":", substituted “(7)” for “(6)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6303/2/A"},"text":"Pub. L. 115–334, § 6303(2)(A)","children":[],"tail":", redesignated pars. (5) to (7) as (6) to (8), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6303/2/D"},"text":"Pub. L. 115–334, § 6303(2)(D)","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6303/3/A"},"text":"Pub. L. 115–334, § 6303(3)(A)","children":[],"tail":", substituted “5 percent” for “3 percent” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6303/3/B"},"text":"Pub. L. 115–334, § 6303(3)(B)","children":[],"tail":", substituted “recurring service” for “electric” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6303/5"},"text":"Pub. L. 115–334, § 6303(5)","children":[],"tail":", added subsec. (h). Former subsec. (h) redesignated (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6303/4"},"text":"Pub. L. 115–334, § 6303(4)","children":[],"tail":", (6), redesignated subsec. (h) as (i) and substituted “2023” for “2018”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
