{"tag":"section","attrib":{"id":"idee01ba11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136e"},"text":null,"children":[{"tag":"num","attrib":{"value":"136e"},"text":"§ 136e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of establishments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee01ba12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall produce any pesticide subject to this subchapter or active ingredient used in producing a pesticide subject to this subchapter in any State unless the establishment in which it is produced is registered with the Administrator. The application for registration of any establishment shall include the name and address of the establishment and of the producer who operates such establishment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee01ba13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever the Administrator receives an application under subsection (a), the Administrator shall register the establishment and assign it an establishment number.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee01ba14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee01ba15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any producer operating an establishment registered under this section shall inform the Administrator within 30 days after it is registered of the types and amounts of pesticides and, if applicable, active ingredients used in producing pesticides—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee01ba16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136e/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which the producer is currently producing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee01ba17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136e/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which the producer has produced during the past year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee01ba18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136e/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which the producer has sold or distributed during the past year.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The information required by this paragraph shall be kept current and submitted to the Administrator annually as required under such regulations as the Administrator may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee01ba19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any such producer shall, upon the request of the Administrator for the purpose of issuing a stop sale order pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136k"},"text":"section 136k of this title","children":[],"tail":", inform the Administrator of the name and address of any recipient of any pesticide produced in any registered establishment which the producer operates."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee01ba1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidential records and information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any information submitted to the Administrator pursuant to subsection (c) other than the names of the pesticides or active ingredients used in producing pesticides produced, sold, or distributed at an establishment shall be considered confidential and shall be subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136h"},"text":"section 136h of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee01ba1b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125/s7"},"text":"June 25, 1947, ch. 125, § 7","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/516/s2"},"text":"Pub. L. 92–516, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/987"},"text":"86 Stat. 987","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/396/s13"},"text":"Pub. L. 95–396, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/829"},"text":"92 Stat. 829","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1006/b/1"},"text":"Pub. L. 102–237, title X, § 1006(b)(1)","children":[],"tail":", (3)(F), (G), "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1895"},"text":"105 Stat. 1895","children":[],"tail":", 1896.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee01ba1c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee01ba1d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee01ba1e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7 of act ","children":[{"tag":"date","attrib":{"date":"1947-06-25"},"text":"June 25, 1947","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s135e"},"text":"section 135e of this title","children":[],"tail":" prior to amendment of act "},{"tag":"date","attrib":{"date":"1947-06-25"},"text":"June 25, 1947","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/92/516"},"text":"Pub. L. 92–516","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee01ba1f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s1006/b/1"},"text":"Pub. L. 102–237, § 1006(b)(1)","children":[],"tail":", substituted “the Administrator” for “he” before “shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A) to (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s1006/b/3/F"},"text":"Pub. L. 102–237, § 1006(b)(3)(F)","children":[],"tail":", substituted “the producer” for “he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237/s1006/b/3/G"},"text":"Pub. L. 102–237, § 1006(b)(3)(G)","children":[],"tail":", substituted “the Administrator” for “him” after “inform” and “the producer” for “he”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/396/s13/1"},"text":"Pub. L. 95–396, § 13(1)","children":[],"tail":", made requirement of registration applicable to production of active ingredient used in producing a pesticide subject to this subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/396/s13/2"},"text":"Pub. L. 95–396, § 13(2)","children":[],"tail":", required information pertaining to types and amounts of active ingredients used in producing pesticides where applicable."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/396/s13/3"},"text":"Pub. L. 95–396, § 13(3)","children":[],"tail":", considered names of pesticides or active ingredients used in producing pesticides produced, sold, or distributed at an establishment as not being confidential information."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee01ba20-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee01ba21-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/516/s4"},"text":"section 4 of Pub. L. 92–516","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"section 136 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
