{"tag":"section","attrib":{"id":"idf01ef43d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7736"},"text":null,"children":[{"tag":"num","attrib":{"value":"7736"},"text":"§ 7736.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court jurisdiction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf01ef43e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7736/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The United States district courts, the District Court of Guam, the District Court of the Virgin Islands, the highest court of American Samoa, and the United States courts of other territories and possessions are vested with jurisdiction in all cases arising under this chapter. Any action arising under this chapter may be brought, and process may be served, in the judicial district where a violation or interference occurred or is about to occur, or where the person charged with the violation, interference, impending violation, impending interference, or failure to pay resides, is found, transacts business, is licensed to do business, or is incorporated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01ef43f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7736/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section does not apply to the imposition of civil penalties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7734/b"},"text":"section 7734(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf01ef440-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tIV/s426"},"text":"Pub. L. 106–224, title IV, § 426","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/451"},"text":"114 Stat. 451","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf01ef441-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf01ef442-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf01ef443-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a), was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224"},"text":"Pub. L. 106–224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/438"},"text":"114 Stat. 438","children":[],"tail":", known as the Plant Protection Act, which is classified principally to this chapter. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7701"},"text":"section 7701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
