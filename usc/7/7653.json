{"tag":"section","attrib":{"id":"idf017c9f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7653"},"text":null,"children":[{"tag":"num","attrib":{"value":"7653"},"text":"§ 7653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Pest Management Policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf017c9fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7653/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to establish an Office of Pest Management Policy to provide for the effective coordination of agricultural policies and activities within the Department of Agriculture related to pesticides and of the development and use of pest management tools, while taking into account the effects of regulatory actions of other government agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017c9fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7653/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Office; principal responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall establish in the Department an Office of Pest Management Policy, which shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf017c9fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7653/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and coordination of Department policy on pest management and pesticides;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017c9fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7653/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of activities and services of the Department, including research, extension, and education activities, regarding the development, availability, and use of economically and environmentally sound pest management tools and practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017c9fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7653/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting other agencies of the Department in fulfilling their responsibilities related to pest management or pesticides under the Food Quality Protection Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/170"},"text":"Public Law 104–170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/1489"},"text":"110 Stat. 1489","children":[],"tail":"), the Federal Insecticide, Fungicide, and Rodenticide Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"7 U.S.C. 136","children":[],"tail":" et seq.), the Federal Food, Drug, and Cosmetic Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"21 U.S.C. 301","children":[],"tail":" et seq.), and other applicable laws; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017c9ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7653/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing such other functions as may be required by law or prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017ca00-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7653/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In support of its responsibilities under subsection (b), the Office of Pest Management Policy shall provide leadership to ensure coordination of interagency activities with the Environmental Protection Agency, the Food and Drug Administration, and other Federal and State agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017ca01-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7653/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Pest Management Policy shall consult with agricultural producers that may be affected by pest management or pesticide-related activities or actions of the Department or other agencies as necessary in carrying out the Office’s responsibilities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017ca02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7653/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Pest Management Policy shall be under the direction of a Director appointed by the Secretary, who shall report directly to the Secretary or a designee of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017ca03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7653/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf017ca04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7653/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 1999 through 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017ca05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7653/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf017ca06-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s614"},"text":"Pub. L. 105–185, title VI, § 614","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/605"},"text":"112 Stat. 605","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7132"},"text":"Pub. L. 107–171, title VII, § 7132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/435"},"text":"116 Stat. 435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7313"},"text":"Pub. L. 110–234, title VII, § 7313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1245"},"text":"122 Stat. 1245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7313, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2006; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7309"},"text":"Pub. L. 113–79, title VII, § 7309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/891"},"text":"128 Stat. 891","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7307"},"text":"Pub. L. 115–334, title VII, § 7307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4816"},"text":"132 Stat. 4816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf017ca07-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf017ca08-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf017ca09-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food Quality Protection Act of 1996, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/170"},"text":"Pub. L. 104–170","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-03"},"text":"Aug. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1489"},"text":"110 Stat. 1489","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1996 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"section 136 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Insecticide, Fungicide, and Rodenticide Act, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125"},"text":"act June 25, 1947, ch. 125","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/92/516"},"text":"Pub. L. 92–516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/973"},"text":"86 Stat. 973","children":[],"tail":", which is classified generally to subchapter II (§ 136 et seq.) of chapter 6 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"section 136 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Food, Drug, and Cosmetic Act, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch675"},"text":"act June 25, 1938, ch. 675","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1040"},"text":"52 Stat. 1040","children":[],"tail":", which is classified generally to chapter 9 (§ 301 et seq.) of Title 21, Food and Drugs. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s301"},"text":"section 301 of Title 21","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf017ca0a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf017ca0b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" struck out “such sums as are necessary” after “appropriated”, substituted “section—” for “section for each of fiscal years 1999 through 2012.”, and added pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7313"},"text":"Pub. L. 110–246, § 7313","children":[],"tail":", substituted “2012” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" substituted “2007” for “2002”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf017ca0c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf017ca0d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
