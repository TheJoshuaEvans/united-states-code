{"tag":"section","attrib":{"id":"ideed5f96c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1622a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1622a"},"text":"§ 1622a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to assist farmers and elevator operators","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may provide technical assistance (including information on such financial assistance as may be available) to grain producers and elevator operators to assist such producers and operators in installing or improving grain cleaning, drying or storage equipment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideed5f96d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXX/s2014"},"text":"Pub. L. 101–624, title XX, § 2014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3933"},"text":"104 Stat. 3933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideed5f96e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideed5f96f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideed5f970-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Grain Quality Incentives Act of 1990, and also as part of the Food, Agriculture, Conservation, and Trade Act of 1990, and not as part of the Agricultural Marketing Act of 1946 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
