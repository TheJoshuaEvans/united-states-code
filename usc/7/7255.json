{"tag":"section","attrib":{"id":"ideffffbd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7255"},"text":null,"children":[{"tag":"num","attrib":{"value":"7255"},"text":"§ 7255.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Milk manufacturing marketing adjustment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffffbd7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7255/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum allowances established","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No State shall provide for a manufacturing allowance for the processing of milk in excess of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffbd8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7255/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1.65 per hundredweight of milk for milk manufactured into butter and nonfat dry milk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffbd9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7255/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1.80 per hundredweight of milk for milk manufactured into cheese.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffbda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7255/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Manufacturing allowance” defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “manufacturing allowance” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffbdb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7255/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount by which the product price value of butter and nonfat dry milk manufactured from a hundred pounds of milk containing 3.5 pounds of butterfat and 8.7 pounds of milk solids not fat resulting from a State’s yield and product price formulas exceeds the class price for the milk used to produce those products; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0026bdc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7255/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount by which the product price value of cheese manufactured from a hundred pounds of milk containing 3.5 pounds of butterfat and 8.7 pounds of milk solids not fat resulting from a State’s yield and product price formulas exceeds the class price for the milk used to produce cheese.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0026bdd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7255/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of violation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines following a hearing that a State has in effect a manufacturing allowance that exceeds the manufacturing allowance authorized in subsection (a), the Secretary shall suspend purchases of cheddar cheese, butter, and nonfat dry milk produced in that State until such time as the State complies with such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0026bde-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7255/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date; implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section (other than subsection (e) ","children":[{"tag":"ref","attrib":{"idref":"fn002330"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002330"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Codification note below."}],"tail":") shall be effective during the period beginning on the first day of the first month beginning after "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1999-12-31"},"text":"December 31, 1999","children":[],"tail":". During that period, the Secretary may exercise the authority provided to the Secretary under this section without regard to the issuance of regulations intended to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0026bdf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s145"},"text":"Pub. L. 104–127, title I, § 145","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/917"},"text":"110 Stat. 917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0026be0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0026be1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf0026be2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s145"},"text":"section 145 of Pub. L. 104–127","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/s145"},"text":"section 145 of Pub. L. 104–127","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1446e–1"},"text":"section 1446e–1 of this title","children":[],"tail":" and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1446e–1"},"text":"section 1446e–1 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
