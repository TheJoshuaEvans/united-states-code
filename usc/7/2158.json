{"tag":"section","attrib":{"id":"idef6e9098-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158"},"text":null,"children":[{"tag":"num","attrib":{"value":"2158"},"text":"§ 2158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of pets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef6e9099-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Holding period","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef6e909a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of each dog or cat acquired by an entity described in paragraph (2), such entity shall hold and care for such dog or cat for a period of not less than five days to enable such dog or cat to be recovered by its original owner or adopted by other individuals before such entity sells such dog or cat to a dealer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e909b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entities described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity subject to paragraph (1) is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef6e909c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each State, county, or city owned and operated pound or shelter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef6e909d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each private entity established for the purpose of caring for animals, such as a humane society, or other organization that is under contract with a State, county, or city that operates as a pound or shelter and that releases animals on a voluntary basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef6e909e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each research facility licensed by the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef6e909f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef6e90a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A dealer may not sell, provide, or make available to any individual or entity a random source dog or cat unless such dealer provides the recipient with a valid certification that meets the requirements of paragraph (2) and indicates compliance with subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e90a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A valid certification shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef6e90a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and Department of Agriculture license or registration number (if such number exists) of the dealer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef6e90a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, Department of Agriculture license or registration number (if such number exists), and the signature of the recipient of the dog or cat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef6e90a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the dog or cat being provided that shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef6e90a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the species and breed or type of such;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef6e90a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sex of such;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef6e90a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of birth (if known) of such;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef6e90a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the color and any distinctive marking of such; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef6e90a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information that the Secretary by regulation shall determine to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef6e90aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the person, pound, or shelter from which the dog or cat was purchased or otherwise acquired by the dealer, and an assurance that such person, pound, or shelter was notified that such dog or cat may be used for research or educational purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef6e90ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of the purchase or acquisition referred to in subparagraph (D);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef6e90ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement by the pound or shelter (if the dealer acquired the dog or cat from such) that it satisfied the requirements of subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef6e90ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information that the Secretary of Agriculture by regulation shall determine appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e90ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The original certification required under paragraph (1) shall accompany the shipment of a dog or cat to be sold, provided, or otherwise made available by the dealer, and shall be kept and maintained by the research facility for a period of at least one year for enforcement purposes. The dealer shall retain one copy of the certification provided under this paragraph for a period of at least one year for enforcement purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e90af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In instances where one research facility transfers animals to another research facility a copy of the certificate must accompany such transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e90b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Certification requirements may be modified to reflect technological advances in identification techniques, such as microchip technology, if the Secretary determines that adequate information such as described in this section, will be collected, transferred, and maintained through such technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef6e90b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef6e90b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Dealers who fail to act according to the requirements of this section or who include false information in the certification required under subsection (b), shall be subject to the penalties provided for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2149"},"text":"section 2149 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e90b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any dealer who violates this section more than one time shall be subject to a fine of $5,000 per dog or cat acquired or sold in violation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e90b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent revocations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any dealer who violates this section three or more times shall have such dealers license permanently revoked.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef6e90b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2158/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", the Secretary shall promulgate regulations to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef6e90b6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/544/s28"},"text":"Pub. L. 89–544, § 28","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXV/s2503/2"},"text":"Pub. L. 101–624, title XXV, § 2503(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4066"},"text":"104 Stat. 4066","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1004"},"text":"Pub. L. 102–237, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1894"},"text":"105 Stat. 1894","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef6e90b7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef6e90b8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef6e90b9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “subsection (a)” for “subsection (b)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
