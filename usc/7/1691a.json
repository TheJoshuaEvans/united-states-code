{"tag":"section","attrib":{"id":"ideee451e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1691a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1691a"},"text":"§ 1691a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food aid to developing countries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideee451e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1691a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In light of the Uruguay Round Agreement on Agriculture and the Ministerial Decision on Measures Concerning the Possible Negative Effects of the Reform Program on Least-Developed and Net-Food Importing Developing Countries, the United States reaffirms the commitment of the United States to providing food aid to developing countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee451e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1691a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideee451e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1691a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in negotiations at the Food Aid Convention, the World Trade Organization, the United Nations Food and Agriculture Organization, and other appropriate venues, the President shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideee451e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1691a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek commitments of higher levels of food aid by donors in order to meet the legitimate needs of developing countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee451e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1691a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure, to the maximum extent practicable, that humanitarian nongovernmental organizations, recipient country governments, charitable bodies, and international organizations shall continue—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee451e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1691a/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be eligible to receive resources based on assessments of need conducted by those organizations and entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee451e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1691a/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement food aid programs in agreements with donor countries; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideee451e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1691a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure, to the maximum extent practicable, that options for providing food aid for emergency and nonemergency needs shall not be subject to limitation, including in-kind commodities, provision of funds for agricultural commodity procurement, and monetization of commodities, on the condition that the provision of those commodities or funds—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideee451ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1691a/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is based on assessments of need and intended to benefit the food security of, or otherwise assist, recipients, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideee451eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1691a/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is provided in a manner that avoids disincentives to local agricultural production and marketing and with minimal potential for disruption of commercial markets; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideee451ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1691a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States should increase its contribution of bona fide food assistance to developing countries consistent with the Agreement on Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideee451ed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469/s3"},"text":"July 10, 1954, ch. 469, § 3","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/94/161/tII/s202"},"text":"Pub. L. 94–161, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/851"},"text":"89 Stat. 851","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3633"},"text":"104 Stat. 3633","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s201/a"},"text":"Pub. L. 104–127, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/951"},"text":"110 Stat. 951","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3003"},"text":"Pub. L. 110–246, title III, § 3003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1821"},"text":"122 Stat. 1821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideee451ee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideee451ef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideee451f0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" reenacted introductory provisions without change, added par. (1), and struck out former par. (1) which read as follows: “the President should initiate consultations with other donor nations to consider appropriate levels of food aid commitments to meet the legitimate needs of developing countries; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" substituted “Food aid to developing countries” for “Global food aid needs” in section catchline and amended text generally. Prior to amendment, text read as follows: “In view of the principal findings of the National Research Council of the National Academy of Sciences that doubling food aid above 1990 levels of about 10,000,000 metric tons per year would be necessary to meet projected global food needs throughout the decade of the nineties, it is the sense of Congress that the President should—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) increase the contributions of food aid by the United States, and encourage other donor countries to increase their contributions toward meeting new food aid requirements; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) encourage other advanced nations to make increased food aid contributions to combat world hunger and malnutrition, particularly through the expansion of international food and agricultural assistance programs.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section generally, substituting present provisions for provisions urging President to maintain United States food assistance and encourage other countries to increase their contributions, in order to meet annual goal of World Food Conference of providing 10,000,000 tons of food assistance annually for needy nations."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideee451f1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideee451f2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideee451f3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"Jan. 1, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1513"},"text":"section 1513 of Pub. L. 101–624","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideee451f4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"World Food Conference Recommendations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/161/tII/s213"},"text":"Pub. L. 94–161, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-20"},"text":"Dec. 20, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/855"},"text":"89 Stat. 855","children":[],"tail":", directed the President to strengthen the efforts of the United States to carry out the recommendations of the World Food Conference and to submit a detailed report to the Congress not later than "},{"tag":"date","attrib":{"date":"1976-11-01"},"text":"Nov. 1, 1976","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/113/tVII/s734/a/7"},"text":"Pub. L. 97–113, title VII, § 734(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-29"},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1560"},"text":"95 Stat. 1560","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
