{"tag":"section","attrib":{"id":"idef9e2c82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195"},"text":null,"children":[{"tag":"num","attrib":{"value":"3195"},"text":"§ 3195.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuing animal health and disease, food security, and stewardship research, education, and extension programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9e2c83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity and infrastructure program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9e2c84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In each State with one or more accredited colleges of veterinary medicine, the deans of the accredited college or colleges and the director of the State agricultural experiment station shall develop a comprehensive animal health and disease research program for the State based on the animal health research capacity of each eligible institution in the State, which shall be submitted to the Secretary for approval and shall be used for the allocation of funds available to the State under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible institution allocated funds to carry out animal health and disease research under this section may only use such funds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9e2c86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet the expenses of conducting animal health and disease research, publishing and disseminating the results of such research, and contributing to the retirement of employees subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s331"},"text":"section 331 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9e2c87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for administrative planning and direction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9e2c88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to purchase equipment and supplies necessary for conducting research described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation among eligible institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, to the maximum extent practicable, shall encourage eligible institutions to cooperate in setting research priorities under this section through conducting regular regional and national meetings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9e2c8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grant program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9e2c8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, for purposes of addressing the critical needs of animal agriculture, shall award competitive grants to eligible entities under which such eligible entities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9e2c8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct research—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef9e2c8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to promote food security, such as by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef9e2c8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving feed efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef9e2c8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving energetic efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef9e2c90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" connecting genomics, proteomics, metabolomics and related phenomena to animal production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef9e2c91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/1/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving reproductive efficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef9e2c92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/1/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing pre- and post-harvest food safety systems; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef9e2c93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on the relationship between animal and human health, such as by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef9e2c94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exploring new approaches for vaccine development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef9e2c95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding and controlling zoonosis, including its impact on food safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef9e2c96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/1/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving animal health through feed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef9e2c97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/1/A/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing product quality and nutritive value; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9e2c98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and disseminate to the public tools and information based on the research conducted under subparagraph (A) and sound science.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity eligible to receive a grant under this subsection is any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9e2c9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State cooperative institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9e2c9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An NLGCA Institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2c9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subsection, the Secretary shall establish procedures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9e2c9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to seek and accept proposals for grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9e2c9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to review and determine the relevance and merit of proposals, in consultation with representatives of the animal agriculture industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9e2c9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a scientific peer review of each proposal conducted by a panel of subject matter experts from Federal agencies, academic institutions, State animal health agencies, and the animal agriculture industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9e2ca0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to award competitive grants on the basis of merit, quality, and relevance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9e2ca1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9e2ca2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $25,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2ca3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall reserve not less than $5,000,000 of the funds made available under paragraph (1) to carry out the capacity and infrastructure program under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2ca4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial apportionment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amounts made available under paragraph (1) that are remaining after the reservation of funds under paragraph (2), shall be apportioned as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9e2ca5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15 percent of such amounts shall be used to carry out the capacity and infrastructure program under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9e2ca6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 85 percent of such funds shall be used to carry out the competitive grant program under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2ca7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional apportionment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The funds reserved under paragraph (2) and apportioned under paragraph (3)(A) to carry out the capacity and infrastructure program under subsection (a) shall be apportioned as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9e2ca8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four percent shall be retained by the Department of Agriculture for administration, program assistance to the eligible institutions, and program coordination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9e2ca9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 48 percent shall be distributed among the several States in the proportion that the value of and income to producers from domestic livestock, poultry, and commercial aquaculture species in each State bears to the total value of and income to producers from domestic livestock, poultry, and commercial aquaculture species in all the States. The Secretary shall determine the total value of and income from domestic livestock, poultry, and commercial aquaculture species in all the States and the proportionate value of and income from domestic livestock, poultry, and commercial aquaculture species for each State, based on the most current inventory of all cattle, sheep, swine, horses, poultry, and commercial aquaculture species published by the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9e2caa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 48 percent shall be distributed among the several States in the proportion that the animal health research capacity of the eligible institutions in each State bears to the total animal health research capacity in all the States. The Secretary shall determine the animal health research capacity of the eligible institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9e2cab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rules for apportionment of certain funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to funds reserved under paragraph (2) and apportioned under paragraph (3)(A) to carry out the capacity and infrastructure program under subsection (a), the following shall apply:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9e2cac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the amount available under this section for allotment to any State on the basis of domestic livestock, poultry, and commercial aquaculture species values and incomes exceeds the amount for which the eligible institution or institutions in the State are eligible on the basis of animal health research capacity, the excess may be used, at the discretion of the Secretary, for remodeling of facilities, construction of new facilities, or increase in staffing, proportionate to the need for added research capacity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9e2cad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever a new college of veterinary medicine is established in a State and is accredited, the Secretary, after consultation with the dean of such college and the director of the State agricultural experiment station and where applicable, deans of other accredited colleges in the State, shall provide for the reallocation of funds available to the State pursuant to paragraph (4) between the new college and other eligible institutions in the State, based on the animal health research capacity of each eligible institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9e2cae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3195/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whenever two or more States jointly establish an accredited regional college of veterinary medicine or jointly support an accredited college of veterinary medicine serving the States involved, the Secretary is authorized to make funds which are available to such States pursuant to paragraph (4) available for such college in such amount that reflects the combined relative value of, and income from, domestic livestock, poultry, and commercial aquaculture species in the cooperating States, such amount to be adjusted, as necessary, pursuant to subsection (a)(1) and subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9e2caf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1433"},"text":"Pub. L. 95–113, title XIV, § 1433","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1003"},"text":"91 Stat. 1003","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1429"},"text":"Pu