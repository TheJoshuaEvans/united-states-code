{"tag":"section","attrib":{"id":"idefd0600b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852"},"text":null,"children":[{"tag":"num","attrib":{"value":"5852"},"text":"§ 5852.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural Weather Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd0600c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Office and administration of system","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd0600d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall establish in the Department of Agriculture an Agricultural Weather Office to plan and administer the National Agricultural Weather Information System. The system shall be comprised of the office established under this section and the activities of the State agricultural weather information systems described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5854"},"text":"section 5854 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd0600e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall appoint a Director to manage the activities of the Agricultural Weather Office and to advise the Secretary on scientific and programmatic coordination for climate, weather, and remote sensing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd0600f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Office, may undertake the following activities to carry out this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd06010-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Enter into cooperative projects with the National Weather Service to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd06011-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support operational weather forecasting and observation useful in agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd06012-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sponsor joint workshops to train agriculturalists about the optimum utilization of agricultural weather and climate data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd06013-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jointly develop improved computer models and computing capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd06014-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance the quality and availability of weather and climate information needed by agriculturalists.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd06015-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Obtain standardized weather observation data collected in near real time through State agricultural weather information systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd06016-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Make, through the National Institute of Food and Agriculture, competitive grants under subsection (c) for research in atmospheric sciences and climatology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd06017-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Make grants to eligible States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5854"},"text":"section 5854 of this title","children":[],"tail":" to plan and administer State agricultural weather information systems."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd06018-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinate the activities of the Office with the weather and climate research activities of the National Institute of Food and Agriculture, the National Academy of Sciences, the National Science Foundation Atmospheric Services Program, and the National Climate Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd06019-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Encourage private sector participation in the National Agricultural Weather Information System through mutually beneficial cooperation with the private sector, particularly in generating weather and climatic data useful for site-specific agricultural weather forecasting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd0601a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd0601b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With funds allocated to carry out this subsection, the Secretary of Agriculture may make grants to State agricultural experiment stations, all colleges and universities, other research institutions and organizations, Federal agencies, private organizations and corporations, and individuals to carry out research in all aspects of atmospheric sciences and climatology that can be shown to be important in both a basic and developmental way to understanding, forecasting, and delivering agricultural weather information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd0601c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive basis","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants made under this subsection shall be made on a competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd0601d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting among applications for grants under subsection (c), the Secretary shall give priority to proposals which emphasize—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd0601e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" techniques and processes that relate to weather-induced agricultural losses, and to improving the advisory information on weather extremes such as drought, floods, freezes, and storms well in advance of their actual occurrence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd0601f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement of site-specific weather data collection and forecasting; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd06020-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5852/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of weather on economic and environmental costs in agricultural production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd06021-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1638"},"text":"Pub. L. 101–624, title XVI, § 1638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3748"},"text":"104 Stat. 3748","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIV/s407/6"},"text":"Pub. L. 102–237, title IV, § 407(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1865"},"text":"105 Stat. 1865","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7511/c/18"},"text":"Pub. L. 110–234, title VII, § 7511(c)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1269"},"text":"122 Stat. 1269","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7511(c)(18), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2030.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefd06022-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefd06023-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefd06024-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefd06025-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(3), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/18"},"text":"Pub. L. 110–246, § 7511(c)(18)","children":[],"tail":", substituted “National Institute of Food and Agriculture” for “Cooperative State Research Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “National Science Foundation” for “National Sciences Foundation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefd06026-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefd06027-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c/18"},"text":"section 7511(c)(18) of Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/c"},"text":"section 7511(c) of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1522"},"text":"section 1522 of this title","children":[],"tail":"."}],"tail":"\n"}],"