{"tag":"section","attrib":{"id":"idefbf9769-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815"},"text":null,"children":[{"tag":"num","attrib":{"value":"4815"},"text":"§ 4815.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbf976a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of district court; referral of civil actions to Attorney General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf976b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A district court of the United States shall have jurisdiction specifically to enforce, and to prevent and restrain a person from violating an order, rule, or regulation issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf976c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civil action authorized to be brought under this subsection shall be referred to the Attorney General for appropriate action, except that the Secretary is not required to refer to the Attorney General a violation of this chapter if the Secretary believes that the administration and enforcement of this chapter would be adequately served by providing a suitable written notice or warning to a person who committed such violation or by administrative action under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf976d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for willful violations; issuance of cease-and-desist orders; judicial review of orders; penalty for failure to obey cease-and-desist order","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf976e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf976f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who willfully violates an order, rule, or regulation issued by the Secretary under this chapter may be assessed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf9770-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civil penalty by the Secretary of not more than $1,000 for each such violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf9771-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a willful failure to pay, collect, or remit an assessment as required by an order, an additional penalty equal to the amount of such assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9772-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each such violation shall be a separate offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9773-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to or in lieu of such civil penalty, the Secretary may issue an order requiring such person to cease and desist from violating such order, rule, or regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9774-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No penalty may be assessed or cease-and-desist order issued unless the Secretary gives such person notice and opportunity for a hearing on the record with respect to such violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9775-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An order issued under this paragraph by the Secretary shall be final and conclusive unless such person files an appeal from such order with the appropriate United States court of appeals not later than 30 days after such person receives notice of such order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9776-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf9777-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person against whom an order is issued under paragraph (1) may obtain review of such order in the court of appeals of the United States for the circuit in which such person resides or does business, or in the United States Court of Appeals for the District of Columbia Circuit, by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf9778-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" filing a notice of appeal in such court not later than 30 days after the date of such order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf9779-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" simultaneously sending a copy of such notice by certified mail to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf977a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall file promptly in such court a certified copy of the record on which such violation was found.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf977b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A finding of the Secretary shall be set aside only if the finding is found to be unsupported by substantial evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf977c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf977d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who fails to obey a valid cease-and-desist order issued under paragraph (1) by the Secretary, after an opportunity for a hearing, shall be subject to a civil penalty assessed by the Secretary of not more than $500 for each offense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf977e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each day during which such failure continues shall be considered a separate violation of such order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf977f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf9780-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a person fails to pay a valid civil penalty imposed under this subsection by the Secretary, the Secretary shall refer the matter to the Attorney General for recovery of the amount assessed in an appropriate district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9781-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In such action, the validity and appropriateness of the order imposing such civil penalty shall not be subject to review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9782-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4815/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of additional remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The remedies provided in subsections (a) and (b) shall be in addition to, and not exclusive of, other remedies that may be available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbf9783-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1626"},"text":"Pub. L. 99–198, title XVI, § 1626","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1620"},"text":"99 Stat. 1620","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbf9784-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefbf9785-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefbf9786-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1631"},"text":"section 1631 of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4801"},"text":"section 4801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
