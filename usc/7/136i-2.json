{"tag":"section","attrib":{"id":"idee042b86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136i–2"},"text":null,"children":[{"tag":"num","attrib":{"value":"136i–2"},"text":"§ 136i–2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of pesticide use information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee042b87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136i–2/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall collect data of statewide or regional significance on the use of pesticides to control pests and diseases of major crops and crops of dietary significance, including fruits and vegetables.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee042b88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136i–2/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data shall be collected by surveys of farmers or from other sources offering statistically reliable data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee042b89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136i–2/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall, as appropriate, coordinate with the Administrator of the Environmental Protection Agency in the design of the surveys and make available to the Administrator the aggregate results of the surveys to assist the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee042b8a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/170/tIII/s302"},"text":"Pub. L. 104–170, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-03"},"text":"Aug. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1512"},"text":"110 Stat. 1512","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee042b8b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee042b8c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee042b8d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food Quality Protection Act of 1996, and not as part of the Federal Insecticide, Fungicide, and Rodenticide Act which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee042b8e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee042b8f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pesticide Use Information Study","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/170/tIII/s305"},"text":"Pub. L. 104–170, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-03"},"text":"Aug. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1512"},"text":"110 Stat. 1512","children":[],"tail":", required the Secretary of Agriculture, in consultation with the Administrator of the Environmental Protection Agency, to prepare a report to Congress evaluating the current status and potential improvements in Federal pesticide use information gathering activities and to submit the report not later than 1 year following "},{"tag":"date","attrib":{"date":"1996-08-03"},"text":"Aug. 3, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
