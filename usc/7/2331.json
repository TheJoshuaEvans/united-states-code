{"tag":"section","attrib":{"id":"idef81a3f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2331"},"text":null,"children":[{"tag":"num","attrib":{"value":"2331"},"text":"§ 2331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copies for public libraries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may supply printed copies of descriptions, drawings, and photographs of protected plant varieties to public libraries in the United States which shall maintain such copies for the use of the public.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef81a3f3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tI/s11"},"text":"Pub. L. 91–577, title I, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1544"},"text":"84 Stat. 1544","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/574/s9"},"text":"Pub. L. 96–574, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3350"},"text":"94 Stat. 3350","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef81a3f4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef81a3f5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef81a3f6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/574"},"text":"Pub. L. 96–574","children":[],"tail":" substituted “descriptions” for “specifications”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
