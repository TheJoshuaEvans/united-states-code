{"tag":"section","attrib":{"id":"idef9726ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3129a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3129a"},"text":"§ 3129a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from chapter 10 of title 5 for competitive research, extension, and education programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Chapter 10 of title 5 and title XVIII of this Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2281"},"text":"7 U.S.C. 2281","children":[],"tail":" et seq.] shall not apply to any committee, board, commission, panel, or task force, or similar entity, created solely for the purpose of reviewing applications or proposals requesting funding under any competitive research, extension, or education program carried out by the Secretary."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef9726f0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1413B"},"text":"Pub. L. 95–113, title XIV, § 1413B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s804"},"text":"Pub. L. 104–127, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1160"},"text":"110 Stat. 1160","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/34"},"text":"Pub. L. 117–286, § 4(a)(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4309"},"text":"136 Stat. 4309","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9726f1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef9726f2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef9726f3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title XVIII of this Act, referred to in text, is title XVIII of the Food and Agriculture Act of 1977, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113"},"text":"Pub. L. 95–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1041"},"text":"91 Stat. 1041","children":[],"tail":", which is classified generally to chapter 55A (§ 2281 et seq.) of this title. For complete classification of this Act to the Code, see Short Title of 1977 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef9726f4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Exemption from chapter 10 of title 5” for “Federal Advisory Committee Act exemption” in section catchline and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
