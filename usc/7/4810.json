{"tag":"section","attrib":{"id":"idefbf9715-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810"},"text":null,"children":[{"tag":"num","attrib":{"value":"4810"},"text":"§ 4810.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissive provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbf9716-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping and reporting requirements; incidental and necessary terms and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the recommendation of the Board, and with the approval of the Secretary, an order may contain one or more of the following provisions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf9717-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each person purchasing a porcine animal from a producer for commercial use, and each importer, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf9718-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain and make available for inspection such books and records as may be required by the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9719-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file reports at the time, in the manner, and having the content prescribed by the order,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"including documentation of the State of origin of a purchased porcine animal or the place of origin of an imported porcine animal, pork, or pork product.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf971a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A term or condition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf971b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incidental to, and not inconsistent with, the terms and conditions specified in this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf971c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary to effectuate the other provisions of such order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf971d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of information to Secretary and Board; confidentiality; disclosure; issuance of general statement, statistical data, or name of violator of order","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf971e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information referred to in subsection (a)(1) shall be made available to the Secretary and the Board as is appropriate or necessary for the effectuation, administration, or enforcement of this chapter or an order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf971f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf9720-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraphs (B) and (C), information obtained under subsection (a)(1) shall be kept confidential by officers or employees of the Department of Agriculture or the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9721-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such information may be disclosed only—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf9722-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in a suit or administrative hearing involving the order with respect to which the information was furnished or acquired—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefbf9723-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" brought at the direction or on the request of the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefbf9724-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which the Secretary or an officer of the United States is a party; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf9725-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary considers such information to be relevant to such suit or hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9726-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this section prohibits—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf9727-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of a general statement based on the reports of a number of persons subject to an order, or statistical data collected therefrom, if such statement or data does not identify the information furnished by any person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf9728-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the publication, by direction of the Secretary, of the name of a person violating an order, together with a statement of the particular provisions of the order violated by such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9729-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for willful violations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who willfully violates subsection (a)(1) or (b) shall, on conviction, be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf972a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to a fine of not more than $1,000 or imprisoned for not more than 1 year, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf972b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4810/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if such person is an employee of the Department of Agriculture or the Board, removed from office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbf972c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1621"},"text":"Pub. L. 99–198, title XVI, § 1621","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1617"},"text":"99 Stat. 1617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbf972d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefbf972e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefbf972f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1631"},"text":"section 1631 of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4801"},"text":"section 4801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
