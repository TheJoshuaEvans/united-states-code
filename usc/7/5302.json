{"tag":"section","attrib":{"id":"idefc4792d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302"},"text":null,"children":[{"tag":"num","attrib":{"value":"5302"},"text":"§ 5302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc4792e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “comprehensive plan” means the comprehensive plan prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5313"},"text":"section 5313 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc4792f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “coordinated program” means the National Nutrition Monitoring and Related Research Program established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5311/a"},"text":"section 5311(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc47930-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “Interagency Board for Nutrition Monitoring and Related Research” and “Board” mean the Federal coordinating body established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5311/c"},"text":"section 5311(c) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc47931-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Joint Implementation Plan for a Comprehensive National Nutrition Monitoring System” means the plan of that title dated ","children":[{"tag":"date","attrib":{"date":"1981-08-18"},"text":"August 18, 1981","children":[],"tail":" and submitted by the Department of Agriculture and the Department of Health and Human Services under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3178"},"text":"section 3178 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc47932-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “local government” means a local general unit of government or local educational unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc47933-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “National Nutrition Monitoring Advisory Council” and “Council” mean the advisory body established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5331"},"text":"section 5331 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc47934-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “nutrition monitoring and related research” means the set of activities necessary to provide timely information about the role and status of factors that bear on the contribution that nutrition makes to the health of the people of the United States, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc47935-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dietary, nutritional, and health status measurements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc47936-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food consumption measurements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc47937-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food composition measurements and nutrient data banks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc47938-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dietary knowledge and attitude measurements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc47939-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food supply and demand determinations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc4793a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “nutritional quality” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc4793b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate levels of individual nutrients in the diet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc4793c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate levels between nutrients in the diet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc4793d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bioavailability of nutrients such as absorption, digestion, and utilization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc4793e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nutritional importance of non­nutrient substances such as fiber, phytate, and such substances that are naturally found in the food supply; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc4793f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5302/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretaries” means the Secretary of Agriculture and the Secretary of Health and Human Services, acting jointly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc47940-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/445/s3"},"text":"Pub. L. 101–445, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-10-22"},"text":"Oct. 22, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1035"},"text":"104 Stat. 1035","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
