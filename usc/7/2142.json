{"tag":"section","attrib":{"id":"idef6c1f9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2142"},"text":null,"children":[{"tag":"num","attrib":{"value":"2142"},"text":"§ 2142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Humane standards and recordkeeping requirements at auction sales","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to promulgate humane standards and recordkeeping requirements governing the purchase, handling, or sale of animals, in commerce, by dealers, research facilities, and exhibitors at auction sales and by the operators of such auction sales. The Secretary is also authorized to require the licensing of operators of auction sales where any dogs or cats are sold, in commerce, under such conditions as he may prescribe, and upon payment of such fee as prescribed by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2153"},"text":"section 2153 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef6c1f9e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/544/s12"},"text":"Pub. L. 89–544, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-08-24"},"text":"Aug. 24, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/351"},"text":"80 Stat. 351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/579/s13"},"text":"Pub. L. 91–579, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1562"},"text":"84 Stat. 1562","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/279/s5"},"text":"Pub. L. 94–279, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-22"},"text":"Apr. 22, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/418"},"text":"90 Stat. 418","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef6c1f9f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef6c1fa0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef6c1fa1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/279"},"text":"Pub. L. 94–279","children":[],"tail":" substituted “in commerce” for “affecting commerce” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/579"},"text":"Pub. L. 91–579","children":[],"tail":" extended requirements for recordkeeping and humane standards to exhibitors and operators of auction sales, with such requirements to apply to animals as defined instead of only to cats and dogs when transactions in auction sales are affecting commerce, and required operators of auction sales to obtain a license when he sells cats or dogs and such transactions are affecting commerce, upon payment of fee prescribed by the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef6c1fa2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef6c1fa3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/579"},"text":"Pub. L. 91–579","children":[],"tail":" effective one year after "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/579/s23"},"text":"section 23 of Pub. L. 91–579","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2131"},"text":"section 2131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
