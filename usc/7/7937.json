{"tag":"section","attrib":{"id":"idf02620f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937"},"text":null,"children":[{"tag":"num","attrib":{"value":"7937"},"text":"§ 7937.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special marketing loan provisions for upland cotton","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf02620f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/tI/s1103/a/1"},"text":"Pub. L. 109–171, title I, § 1103(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/5"},"text":"120 Stat. 5","children":[],"tail":null}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf02620f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special import quota","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf02620f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02620f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall carry out an import quota program during the period beginning on ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"2008-07-31"},"text":"July 31, 2008","children":[],"tail":", as provided in this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (C), whenever the Secretary determines and announces that for any consecutive 4-week period, the Friday through Thursday average price quotation for the lowest-priced United States growth, as quoted for Middling (M) 1","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"32","children":[],"tail":"-inch cotton, delivered C.I.F. Northern Europe exceeds the Northern Europe price by more than 1.25 cents per pound, there shall immediately be in effect a special import quota."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tight domestic supply","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During any month for which the Secretary estimates the season-ending United States upland cotton stocks-to-use ratio, as determined under subparagraph (D), to be below 16 percent, the Secretary, in making the determination under subparagraph (B), shall not adjust the Friday through Thursday average price quotation for the lowest-priced United States growth, as quoted for Middling (M) 1","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"32","children":[],"tail":"-inch cotton, delivered C.I.F. Northern Europe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Season-ending United States stocks-to-use ratio","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of making estimates under subparagraph (C), the Secretary shall, on a monthly basis, estimate and report the season-ending United States upland cotton stocks-to-use ratio, excluding projected raw cotton imports but including the quantity of raw cotton that has been imported into the United States during the marketing year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delayed application of threshold","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Through ","children":[{"tag":"date","attrib":{"date":"2006-07-31"},"text":"July 31, 2006","children":[],"tail":", the Secretary shall make the calculation under subparagraph (B) without regard to the 1.25 cent threshold provided under that subparagraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02620f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quantity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The quota shall be equal to one week’s consumption of upland cotton by domestic mills at the seasonally adjusted average rate of the most recent three months for which data are available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02620fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The quota shall apply to upland cotton purchased not later than 90 days after the date of the Secretary’s announcement under paragraph (1) and entered into the United States not later than 180 days after the date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02620fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Overlap","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A special quota period may be established that overlaps any existing quota period if required by paragraph (1), except that a special quota period may not be established under this subsection if a quota period has been established under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf02620fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferential tariff treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The quantity under a special import quota shall be considered to be an in-quota quantity for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf02620fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2703/d"},"text":"section 2703(d) of title 19","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3203"},"text":"section 3203 of title 19","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf02620ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2463/d"},"text":"section 2463(d) of title 19","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0262100-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" General Note 3(a)(iv) to the Harmonized Tariff Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0262101-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “special import quota” means a quantity of imports that is not subject to the over-quota tariff rate of a tariff-rate quota.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0262102-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The quantity of cotton entered into the United States during any marketing year under the special import quota established under this subsection may not exceed the equivalent of 5 week’s consumption of upland cotton by domestic mills at the seasonally adjusted average rate of the 3 months immediately preceding the first special import quota established in any marketing year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0262103-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited global import quota for upland cotton","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0262104-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President shall carry out an import quota program that provides that whenever the Secretary determines and announces that the average price of the base quality of upland cotton, as determined by the Secretary, in the designated spot markets for a month exceeded 130 percent of the average price of such quality of cotton in the markets for the preceding 36 months, notwithstanding any other provision of law, there shall immediately be in effect a limited global import quota subject to the following conditions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0262105-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quantity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The quantity of the quota shall be equal to 21 days of domestic mill consumption of upland cotton at the seasonally adjusted average rate of the most recent 3 months for which data are available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0262106-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quantity if prior quota","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a quota has been established under this subsection during the preceding 12 months, the quantity of the quota next established under this subsection shall be the smaller of 21 days of domestic mill consumption calculated under subparagraph (A) or the quantity required to increase the supply to 130 percent of the demand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0262107-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferential tariff treatment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The quantity under a limited global import quota shall be considered to be an in-quota quantity for purposes of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0262108-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2703/d"},"text":"section 2703(d) of title 19","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0262109-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3203"},"text":"section 3203 of title 19","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf026210a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2463/d"},"text":"section 2463(d) of title 19","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf026210b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" General Note 3(a)(iv) to the Harmonized Tariff Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf026210c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf026210d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supply","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “supply” means, using the latest official data of the Bureau of the Census, the Department of Agriculture, and the Department of the Treasury—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf026210e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the carry-over of upland cotton at the beginning of the marketing year (adjusted to 480-pound bales) in which the quota is established;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf026210f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" production of the current crop; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0262110-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imports to the latest date available during the marketing year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0262111-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demand","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “demand” means—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf0262112-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average seasonally adjusted annual rate of domestic mill consumption during the most recent 3 months for which data are available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0262113-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the larger of—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idf0262114-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/D/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" average exports of upland cotton during the preceding 6 marketing years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idf0262115-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/D/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cumulative exports of upland cotton plus outstanding export sales for the marketing year in which the quota is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0262116-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited global import quota","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “limited global import quota” means a quantity of imports that is not subject to the over-quota tariff rate of a tariff-rate quota.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0262117-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quota entry period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When a quota is established under this subsection, cotton may be entered under the quota during the 90-day period beginning on the date the quota is established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0262118-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7937/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No overlap","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1), a quota period may not be established that overlaps an existing quota period or a special quota period established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0262119-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1207"},"text":"Pub. L. 107–171, title I, § 1207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/161"},"text":"116 Stat. 161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/171/tI/s1103/a"},"text":"Pub. L. 109–171, title I, § 1103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/5"},"text":"120 Stat. 5","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf026211a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf026211b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf026211c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Harmonized Tariff Schedule, referred to in subsecs. (b)(5)(D) and (c)(1)(C)(iv), is not set out in the Code. See Publication of Harmonized Tariff Schedule note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1202"},"text":"section 1202 of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf026211d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s1103/a/1"},"text":"Pub. L. 109–171, § 1103(a)(1)","children":[],"tail":", struck out subsec. (a), which related to cotton user marketing certificates."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s1103/a/2/A"},"text":"Pub. L. 109–171, § 1103(a)(2)(A)","children":[],"tail":", struck out “, adjusted for the value of any certificate issued under subsection (a) of this section,” after “C.I.F. Northern Europe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/s1103/a/2/B"},"text":"Pub. L. 109–171, § 1103(a)(2)(B)","children":[],"tail":", struck out “, for the value of any certificates issued under subsection (a) of this section” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf026211e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf026211f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/171/tI/s1103/b"},"text":"Pub. L. 109–171, title I, § 1103(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-02-08"},"text":"Feb. 8, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/5"},"text":"120 Stat. 5","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/171/tI/s1103/b"},"text":"“The amendments made by this section [amending this section] take effect on ","children":[{"tag":"date","attrib":{"date":"2006-08-01"},"text":"August 1, 2006","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":nu