xt":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preferences and needs of States and distributing agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f3d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preferences of recipients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef64f3d9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/525/s27"},"text":"Pub. L. 88–525, § 27","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/193/tVIII/s871/g"},"text":"Pub. L. 104–193, title VIII, § 871(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-22"},"text":"Aug. 22, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2346"},"text":"110 Stat. 2346","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIV/s4126/a"},"text":"Pub. L. 107–171, title IV, § 4126(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/328"},"text":"116 Stat. 328","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIV/s4201/a"},"text":"Pub. L. 110–234, title IV, § 4201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1120"},"text":"122 Stat. 1120","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title IV, § 4201(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children"