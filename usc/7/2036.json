{"tag":"section","attrib":{"id":"idef64f3c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036"},"text":null,"children":[{"tag":"num","attrib":{"value":"2036"},"text":"§ 2036.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of commodities for emergency food assistance program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef64f3c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase of commodities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef64f3c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available to carry out this chapter, for each of the fiscal years 2014 through 2023, the Secretary shall purchase a dollar amount described in paragraph (2) of a variety of nutritious and useful commodities of the types that the Secretary has the authority to acquire through the Commodity Credit Corporation or under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"section 612c of this title","children":[],"tail":" and distribute the commodities to States for distribution in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7515"},"text":"section 7515 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef64f3c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts","children":[],"tail":null},{"