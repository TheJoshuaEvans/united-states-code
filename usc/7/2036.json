id":"idef64f3c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2015, $50,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef64f3c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2016, $40,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef64f3ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2017, $20,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef64f3cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036/a/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2018, $15,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef64f3cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036/a/2/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2019, $23,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef64f3cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036/a/2/D/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2020, $35,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef64f3ce-3