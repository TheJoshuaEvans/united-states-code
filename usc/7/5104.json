{"tag":"section","attrib":{"id":"idefc478bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5104"},"text":null,"children":[{"tag":"num","attrib":{"value":"5104"},"text":"§ 5104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary and the Farm Credit Administration shall prescribe such regulations as may be necessary to carry out this chapter. The regulations prescribed by the Secretary shall require qualifying States to adequately train mediators to address all of the issues covered by the mediation program of the State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefc478bc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/tV/s504"},"text":"Pub. L. 100–233, title V, § 504","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1664"},"text":"101 Stat. 1664","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s282/c"},"text":"Pub. L. 103–354, title II, § 282(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3235"},"text":"108 Stat. 3235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefc478bd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefc478be-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefc478bf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" in first sentence substituted “The” for “Within 150 days after "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"January 6, 1988","children":[],"tail":", the” and inserted at end “The regulations prescribed by the Secretary shall require qualifying States to adequately train mediators to address all of the issues covered by the mediation program of the State.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
