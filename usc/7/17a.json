{"tag":"section","attrib":{"id":"ideddb94c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s17a"},"text":null,"children":[{"tag":"num","attrib":{"value":"17a"},"text":"§ 17a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability of 1936 amendment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-15/ch545"},"text":"act of June 15, 1936, ch. 545","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1491"},"text":"49 Stat. 1491","children":[],"tail":", which amends this chapter, or the application thereof to any person or circumstances is held invalid, the provisions of the section of this chapter which is amended by such provision of said act shall apply to such person or circumstances. No proceeding shall be abated by reason of any amendment to this chapter made by said act but shall be disposed of pursuant to said act."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideddb94c7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-15/ch545/s12"},"text":"June 15, 1936, ch. 545, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1501"},"text":"49 Stat. 1501","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideddb94c8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideddb94c9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideddb94ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail"