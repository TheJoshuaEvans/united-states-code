{"tag":"section","attrib":{"id":"idef7f32f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279e"},"text":null,"children":[{"tag":"num","attrib":{"value":"2279e"},"text":"§ 2279e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7f32f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person that causes harm to, or interferes with, an animal used for the purposes of official inspections by the Department of Agriculture or the Department of Homeland Security, may, after notice and opportunity for a hearing on the record, be assessed a civil penalty by the Secretary of Agriculture or the Secretary of Homeland Security not to exceed $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors in determining civil penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the amount of a civil penalty, the Secretary concerned shall take into account the nature, circumstance, extent, and gravity of the offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Settlement of civil penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary concerned may compromise, modify, or remit, with or without conditions, any civil penalty that may be assessed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finality of orders","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f32f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order of the Secretary concerned assessing a civil penalty shall be treated as a final order reviewable under chapter 158 of title 28. The validity of the order of the Secretary concerned may not be reviewed in an action to collect the civil penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any civil penalty not paid in full when due under an order assessing the civil penalty shall thereafter accrue interest until paid at the rate of interest applicable to civil judgments of the courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7f32fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary concerned defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279f"},"text":"section 2279f of this title","children":[],"tail":", the term “Secretary concerned” means—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7f32fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279e/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture, with respect to an animal used for purposes of official inspections by the Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7f32fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2279e/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Homeland Security, with respect to an animal used for purposes of official inspections by the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7f32fd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tV/s501"},"text":"Pub. L. 106–224, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/455"},"text":"114 Stat. 455","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s421/h"},"text":"Pub. L. 107–296, title IV, § 421(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2184"},"text":"116 Stat. 2184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7f32fe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7f32ff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef7f3300-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s421/h/1"},"text":"Pub. L. 107–296, § 421(h)(1)","children":[],"tail":", inserted “or the Department of Homeland Security” after “Department of Agriculture” and “or the Secretary of Homeland Security” after “Secretary of Agriculture”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s421/h/2"},"text":"Pub. L. 107–296, § 421(h)(2)","children":[],"tail":", substituted “Secretary concerned” for “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s421/h/3"},"text":"Pub. L. 107–296, § 421(h)(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef7f3301-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef7f3302-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
