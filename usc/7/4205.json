{"tag":"section","attrib":{"id":"idefb3af98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4205"},"text":null,"children":[{"tag":"num","attrib":{"value":"4205"},"text":"§ 4205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farmland resource information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb3af99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, through existing agencies or interagency groups, and in cooperation with the cooperative extension services of the States, shall design and implement educational programs and materials emphasizing the importance of productive farmland to the Nation’s well-being and distribute educational materials through communications media, schools, groups, and other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb3af9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall designate one or more farmland information centers to serve as central depositories and distribution points for information on farmland issues, policies, programs, technical principles, and innovative actions or proposals by local and State governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb3af9b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXV/s1544"},"text":"Pub. L. 97–98, title XV, § 1544","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1343"},"text":"95 Stat. 1343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb3af9c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefb3af9d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefb3af9e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective six months after ","children":[{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1549"},"text":"section 1549 of Pub. L. 97–98","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4201"},"text":"section 4201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
