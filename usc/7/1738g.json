{"tag":"section","attrib":{"id":"ideef9ae86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1738g"},"text":"§ 1738g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enterprise for the Americas environmental funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideef9ae87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible country shall, under the terms of an environmental framework agreement entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738f"},"text":"section 1738f of this title","children":[],"tail":", establish an Environmental Fund to receive payments in local currency pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1738f/b/1"},"text":"section 1738f(b)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideef9ae88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1738g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts deposited into an Environmental Fund shall be invested until disbursed. Notwithstanding any other provision of law, any return on such investment may be retained by the Environmental Fund and need not be deposited to the account of the Commodity Credit Corporation and may be retained without further appropriation by Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideef9ae89-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"July 10, 1954, ch. 469","children":[],"tail":", title VI, § 608, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1512"},"text":"Pub. L. 101–624, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3660"},"text":"104 Stat. 3660","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
