{"tag":"section","attrib":{"id":"idee3af33e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s511k"},"text":null,"children":[{"tag":"num","attrib":{"value":"511k"},"text":"§ 511k.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty for violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any person violating any provision of sections 511d and 511i of this title shall be guilty of a misdemeanor and upon conviction thereof shall be fined not more than $1,000, or imprisoned not more than one year, or both.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee3af33f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-23/ch623/s12"},"text":"Aug. 23, 1935, ch. 623, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/734"},"text":"49 Stat. 734","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
