{"tag":"section","attrib":{"id":"idefe373a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6415"},"text":null,"children":[{"tag":"num","attrib":{"value":"6415"},"text":"§ 6415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe373a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6415/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments to order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the Secretary may issue such amendments to an order as may be necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe373a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6415/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment to assessment rates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe373a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6415/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may conduct at any time a referendum of persons who, during a representative period as determined by the Secretary, have been fluid milk processors on adjusting the assessment rate under the order issued under this chapter then in effect, and shall hold such a referendum on request of the Board or any group of such processors that among them marketed during a representative period, as determined by the Secretary, 10 percent or more of the volume of fluid milk products marketed by all processors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe373a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6415/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment to assessment rate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall adjust the assessment rate under the order whenever the Secretary determines that the adjustment is favored—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe373a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6415/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by at least 50 percent of fluid milk processors voting in the referendum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe373a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6415/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by fluid milk processors that marketed during a representative period, as determined by the Secretary, 60 percent or more of the volume of fluid milk products marketed by all processors;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In no event shall the rate of assessment prescribed by the order exceed 20 cents per hundredweight.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe373aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6415/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The adjusted assessment rate shall be effective on a date, as determined by the Secretary, after the results of the referendum are known, but not later than 30 days after the referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe373ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6415/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs; manner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6413"},"text":"section 6413 of this title","children":[],"tail":" shall apply to a referendum conducted under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe373ac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1999P"},"text":"Pub. L. 101–624, title XIX, § 1999P","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3926"},"text":"104 Stat. 3926","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
