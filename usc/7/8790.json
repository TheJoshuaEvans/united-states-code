{"tag":"section","attrib":{"id":"idf04519dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8790"},"text":null,"children":[{"tag":"num","attrib":{"value":"8790"},"text":"§ 8790.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Signature authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04519de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8790/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this title and title II and amendments made by those titles, if the Secretary approves a document, the Secretary shall not subsequently determine the document is inadequate or invalid because of the lack of authority of any person signing the document on behalf of the applicant or any other individual, entity, general partnership, or joint venture, or the documents relied upon were determined inadequate or invalid, unless the person signing the program document knowingly and willfully falsified the evidence of signature authority or a signature.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04519df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8790/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Affirmation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04519e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8790/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section prohibits the Secretary from asking a proper party to affirm any document that otherwise would be considered approved under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04519e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8790/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No retroactive effect","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A denial of benefits based on a lack of affirmation under paragraph (1) shall not be retroactive with respect to third-party producers who were not the subject of the erroneous representation of authority, if the third-party producers—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04519e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8790/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relied on the prior approval by the Secretary of the documents in good faith; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04519e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8790/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantively complied with all program requirements ","children":[{"tag":"ref","attrib":{"idref":"fn002384"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002384"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04519e4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1617"},"text":"Pu