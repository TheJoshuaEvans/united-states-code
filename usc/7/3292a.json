{"tag":"section","attrib":{"id":"idefa5588f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3292a"},"text":"§ 3292a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States-Mexico joint agricultural research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa55890-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide for an agricultural research and development program with the George E. Brown United States/Mexico Foundation for Science. The program shall focus on binational problems facing agricultural producers and consumers in the 2 countries, in particular pressing problems in the areas of food safety, plant and animal pest control, and the natural resources base on which agriculture depends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa55891-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under the research and development program shall be awarded competitively through the Foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa55892-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The provision of funds to the Foundation by the United States Government shall be subject to the condition that the Government of Mexico match, on at least a dollar-for-dollar basis, any funds provided by the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa55893-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3292a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided under this section may not be used for the planning, repair, rehabilitation, acquisition, or construction of a building or facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa55894-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1459"},"text":"Pub. L. 95–113, title XIV, § 1459","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tII/s228"},"text":"Pub. L. 105–185, title II, § 228","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/545"},"text":"112 Stat. 545","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/74/tIV/s423"},"text":"Pub. L. 106–74, title IV, § 423","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-20"},"text":"Oct. 20, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1095"},"text":"113 Stat. 1095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa55895-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa55896-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idefa55897-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1459"},"text":"section 1459 of Pub. L. 95–113","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3301"},"text":"section 3301 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefa55898-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idefa55899-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“George E. Brown United States/Mexico Foundation for Science” substituted in subsec. (a) for “United States/Mexico Foundation for Science” pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/74/s423"},"text":"section 423 of Pub. L. 106–74","children":[],"tail":", set out below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/74/tIV/s423"},"text":"Pub. L. 106–74, title IV, § 423","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-20"},"text":"Oct. 20, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1095"},"text":"113 Stat. 1095","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/74/tIV/s423"},"text":"“That the United States/Mexico Foundation for Science is renamed the ‘George E. Brown United States/Mexico Foundation for Science’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
