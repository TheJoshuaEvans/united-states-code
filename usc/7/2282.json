{"tag":"section","attrib":{"id":"idef81a358-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2282"},"text":null,"children":[{"tag":"num","attrib":{"value":"2282"},"text":"§ 2282.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef81a359-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2282/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Agriculture of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a35a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2282/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Department of Agriculture” means the United States Department of Agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a35b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2282/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “advisory committee” means any committee, board, commission, council, conference, panel, task force, or other similar group, or any subcommittee or other subgroup thereof that is established or utilized by the Department of Agriculture in the interest of obtaining advice or recommendations for the President or the Department of Agriculture, except that such term excludes any committee which (A) is composed wholly of full-time officers or employees of the Federal Government, (B) is established by statute or reorganization plan, or (C) is established by the President.","children":[],"tail":"\n"}],"tail":"