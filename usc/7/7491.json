{"tag":"section","attrib":{"id":"idf00e53c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7491"},"text":null,"children":[{"tag":"num","attrib":{"value":"7491"},"text":"§ 7491.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this subchapter. Amounts made available under this section or otherwise made available to the Department, and amounts made available under any other marketing or promotion order, may not be used to pay any administrative expense of the Board.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf00e53c5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s582"},"text":"Pub. L. 104–127, title V, § 582","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1083"},"text":"110 Stat. 1083","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
