{"tag":"section","attrib":{"id":"ideee1e102-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639i"},"text":null,"children":[{"tag":"num","attrib":{"value":"1639i"},"text":"§ 1639i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal preemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideee1e103-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of food","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subchapter, the term “food” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s321"},"text":"section 321 of title 21","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideee1e104-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State or a political subdivision of a State may directly or indirectly establish under any authority or continue in effect as to any food or seed in interstate commerce any requirement relating to the labeling of whether a food (including food served in a restaurant or similar establishment) or seed is genetically engineered (which shall include such other similar terms as determined by the Secretary of Agriculture) or was developed or produced using genetic engineering, including any requirement for claims that a food or seed is or contains an ingredient that was developed or produced using genetic engineering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideee1e105-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 295, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/216/s1"},"text":"Pub. L. 114–216, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-29"},"text":"July 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/838"},"text":"130 Stat. 838","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
