{"tag":"section","attrib":{"id":"idee2a5060-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s349"},"text":null,"children":[{"tag":"num","attrib":{"value":"349"},"text":"§ 349.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “State” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The term “State” means the States of the Union, Puerto Rico, the Virgin Islands, Guam and the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee2a5061-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-05-08/ch79/s10"},"text":"May 8, 1914, ch. 79, § 10","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/87/749/s1/i"},"text":"Pub. L. 87–749, § 1(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-10-05"},"text":"Oct. 5, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/745"},"text":"76 Stat. 745","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tV/s506/h"},"text":"Pub. L. 92–318, title V, § 506(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/351"},"text":"86 Stat. 351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/396/s9/f"},"text":"Pub. L. 99–396, § 9(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/840"},"text":"100 Stat. 840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2a5062-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee2a5063-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attr