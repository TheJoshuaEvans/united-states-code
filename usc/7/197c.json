{"tag":"section","attrib":{"id":"idee1bf8b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s197c"},"text":null,"children":[{"tag":"num","attrib":{"value":"197c"},"text":"§ 197c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Arbitration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee1bf8b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s197c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any livestock or poultry contract that contains a provision requiring the use of arbitration to resolve any controversy that may arise under the contract shall contain a provision that allows a producer or grower, prior to entering the contract ","children":[{"tag":"ref","attrib":{"idref":"fn002087"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002087"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. A comma probably should appear."}],"tail":" to decline to be bound by the arbitration provision."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf8b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s197c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any livestock or poultry contract that contains a provision requiring the use of arbitration shall contain terms that conspicuously disclose the right of the contract producer or grower, prior to entering the contract, to decline the requirement to use arbitration to resolve any controversy that may arise under the livestock or poultry contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf8b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s197c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispute resolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any contract producer or grower that declines a requirement of arbitration pursuant to subsection (b) has the right,","children":[{"tag":"ref","attrib":{"idref":"fn002088"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002088"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" to nonetheless seek to resolve any controversy that may arise under the livestock or poultry contract, if, after the controversy arises, both parties consent in writing to use arbitration to settle the controversy."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf8b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s197c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subsections (a) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (b) and (c) shall apply to any contract entered into, amended, altered, modified, renewed, or extended after the date of the enactment of the Food, Conservation, and Energy Act of 2008."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf8b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s197c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful practice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any action by or on behalf of a packer, swine contractor, or live poultry dealer that violates this section (including any action that has the intent or effect of limiting the ability of a producer or grower to freely make a choice described in subsection (b)) is an unlawful practice under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf8b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s197c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall promulgate regulations to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee1bf8b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s197c/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1bf8ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s197c/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish criteria that the Secretary will consider in determining whether the arbitration process provided in a contract provides a meaningful opportunity for the grower or producer to participate fully in the arbitration process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee1bf8bb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title II, § 210, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXI/s11005"},"text":"Pub. L. 110–234, title XI, § 11005","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1357"},"text":"122 Stat. 1357","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XI, § 11005, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2119.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee1bf8bc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee1bf8bd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee1bf8be-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Food, Conservation, and Energy Act of 2008, referred to in subsec. (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee1bf8bf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s11005"},"text":"Section 11005 of Pub. L. 110–246","children":[],"tail":", which directed amendment of title II of the Packers and Stockyards Act, 1921, by adding sections 208 to 210 at the end, was executed by adding the sections at the end of this part, which is subtitle A of title II of the Act, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee1bf8c0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee1bf8c1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"t