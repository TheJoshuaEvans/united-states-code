{"tag":"section","attrib":{"id":"idee5c5d1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s928"},"text":null,"children":[{"tag":"num","attrib":{"value":"928"},"text":"§ 928.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prompt processing of telephone loans","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within ten days after the end of the second and fourth calendar quarters of each year, the Secretary shall submit to the Committee on Agriculture and the Committee on Appropriations of the House of Representatives, and to the Committee on Agriculture, Nutrition, and Forestry and the Committee on Appropriations of the Senate, a report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee5c5d1d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s928/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying each completed application for a telephone loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s935"},"text":"section 935 of this title","children":[],"tail":" or a guarantee of a telephone loan under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s936"},"text":"section 936 of this title","children":[],"tail":" that has not been finally acted upon within ninety days after the date the completed application is submitted; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee5c5d1e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s928/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating the reasons for the failure to finally act upon the completed applications within such ninety-day period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee5c5d1f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title II, § 207, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2358"},"text":"Pub. L. 101–624, title XXIII, § 2358","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4041"},"text":"104 Stat. 4041","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/13"},"text":"Pub. L. 103–354, title II, § 235(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6602/b/6"},"text":"Pub. L. 115–334, title VI, § 6602(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4776"},"text":"132 Stat. 4776","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee5c5d20-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee5c5d21-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee5c5d22-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “935 of this title or” for “935 of this title,” and struck out “, or a loan under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s948"},"text":"section 948 of this title","children":[],"tail":",” after “a telephone loan under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s936"},"text":"section 936 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
