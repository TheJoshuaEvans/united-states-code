{"tag":"section","attrib":{"id":"idee1bf8e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198b"},"text":null,"children":[{"tag":"num","attrib":{"value":"198b"},"text":"§ 198b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on the Secretary’s jurisdiction, power, duties, and authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee1bf8ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of packer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “packer” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s191"},"text":"section 191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf8eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1999-10-22"},"text":"October 22, 1999","children":[],"tail":", the Comptroller General of the United States shall provide to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing the jurisdiction, powers, duties, and authorities of the Secretary that relate to packers and other persons involved in procuring, slaughtering, or processing swine, pork, or pork products that are covered by this Act and other laws, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idee1bf8ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Trade Commission Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s41"},"text":"15 U.S.C. 41","children":[],"tail":" et seq.), especially sections 6, 8, 9, and 10 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s46"},"text":"15 U.S.C. 46","children":[],"tail":", 48, 49, and 50); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1bf8ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agricultural Marketing Act of 1946 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1621"},"text":"7 U.S.C. 1621","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf8ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General shall include in the report an analysis of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee1bf8ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" burdens on and obstructions to commerce in swine, pork, and pork products by packers, and other persons that enter into arrangements with the packers, that are contrary to, or do not protect, the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1bf8f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" noncompetitive pricing arrangements between or among packers, or other persons involved in the processing, distribution, or sale of pork and pork products, including arrangements provided for in contracts for the purchase of swine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1bf8f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective monitoring of contracts entered into between packers and swine producers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1bf8f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" investigations that relate to, and affect, the disclosure of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee1bf8f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198b/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transactions involved in the business conduct and practices of packers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee1bf8f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198b/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pricing of swine paid to producers by packers and the pricing of products in the pork and pork product merchandising chain;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1bf8f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of the authority of the Secretary to prevent a packer from unjustly or arbitrarily refusing to offer a producer, or disqualifying a producer from eligibility for, a particular contract or type of contract for the purchase of swine; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1bf8f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198b/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the Secretary to cooperate with and enhance the enforcement of actions initiated by other Federal departments and agencies, or Federal independent agencies, to protect trade and commerce in the pork and pork product industries against unlawful restraints and monopolies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee1bf8f7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title II, § 223, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX/s934/2"},"text":"Pub. L. 106–78, title IX, § 934(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1209"},"text":"113 Stat. 1209","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee1bf8f8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idee1bf8f9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{