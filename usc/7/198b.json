 out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1621"},"text":"section 1621 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee1bf8fc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"idee1bf8fd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section to terminate ","children":[{"tag":"date","attrib":{"date":"2025-03-14"},"text":"Mar. 14, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/s942"},"text":"section 942 of Pub. L. 106–78","children":[],"tail":", set out in a Livestock Mandatory Reporting note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1635"},"text":"section 1635 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
