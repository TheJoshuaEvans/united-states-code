dren":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no case shall a reference price for a covered commodity exceed 113 percent of the reference price for such covered commodity listed in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0478b3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9011/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0478b40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9011/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seed cotton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “seed cotton” means unginned upland cotton that includes both lint and seed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0478b41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9011/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0478b42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9011/22/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0478b43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9011/22/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0478b44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9011/22/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of Puerto Rico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0478b45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9011/22/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0478b46-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9011/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temperate japonica rice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “temperate japonica rice” means rice that is grown in high altitudes or temperate regions of high latitudes with cooler climate conditions, in the Western United States, as determined by the Secretary, for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0478b47-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9011/23/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reallocation of base acres unde