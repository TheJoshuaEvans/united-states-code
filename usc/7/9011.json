a/2"},"text":"Pub. L. 115–123, § 60101(a)(2)","children":[],"tail":", added subpar. (O)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (19). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1101/1"},"text":"Pub. L. 115–334, § 1101(1)","children":[],"tail":", redesignated par. (18) as (19). Former par. (19) redesignated (20)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (20) to (25). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1101/1"},"text":"Pub. L. 115–334, § 1101(1)","children":[],"tail":", redesignated pars. (19) to (24) as (20) to (25), respectively. Former par. (25) redesignated (26)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/a/3"},"text":"Pub. L. 115–123, § 60101(a)(3)","children":[],"tail":", added par. (20) and redesignated former pars. (20) to (24) as (21) to (25), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (26). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1101/1"},"text":"Pub. L. 115–334, § 1101(1)","children":[],"tail":", redesignated par. (25) as (26)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0478b52-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf0478b53-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/dF/s60101/a/13"},"text":"Pub. L. 115–123, div. F, § 60101(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/311"},"text":"132 Stat. 311","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/123/dF/s60101/a/13"},"text":"“Except as provided in paragraph (10) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1508b"},"text":"section 1508b of this title","children":[],"tail":"], the amendments made by this subsection [amending this section and sections 1508b, 9013 to 9016, and 9032 of this title] shall apply beginning with the 2018 crop year.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf0478b54-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Administration","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/dF/s60101/a/12"},"text":"Pub. L. 115–123, div. F, § 60101(a)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/311"},"text":"132 Stat. 311","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/123/dF/s60101/a/12"},"text":"“The Secretary of Agriculture shall carry out the amendments made by this subsection [amending this section and sections 1508b, 9013 to 9016, and 9032 of this title] in accordance with section 1601 of the Agricultural Act of 2014 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9091"},"text":"7 U.S.C. 9091","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf0478b55-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Popcorn Acreage","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dA/tVII/s767"},"text":"Pub. L. 108–7, div. A, title VII, § 767","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/48"},"text":"117 Stat. 48","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1609/c"},"text":"Pub. L. 113–79, title I, § 1609(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/709"},"text":"128 Stat. 709","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/79/tI/s1609/c"},"text":"“Notwithstanding any other provision of law, for purposes of administering subtitle A of title I of the Agricultural Act of 2014 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9011"},"text":"7 U.S.C. 9011","children":[],"tail":" et seq.], acreage planted to, or prevented from being planted to, popcorn shall be considered as acreage planted to, or prevented from being planted to, corn: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That if a farm program payment yield for corn is otherwise established for a farm under such subtitle, the same yield shall be used for the acreage on the farm planted to, or prevented from being planted to, popcorn: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That with respect to all other farms, the farm program payment yield for such popcorn acreage shall be established by the Secretary on a fair and equitable basis to reflect the farm program payment yields for corn on similar farms in the area.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
