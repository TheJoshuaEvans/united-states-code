{"tag":"section","attrib":{"id":"idee20b3f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s228b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"228b–1"},"text":"§ 228b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final date for making payment to cash seller or poultry grower","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee20b3f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s228b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delivery of full amount due","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each live poultry dealer obtaining live poultry by purchase in a cash sale shall, before the close of the next business day following the purchase of poultry, and each live poultry dealer obtaining live poultry under a poultry growing arrangement shall, before the close of the fifteenth day following the week in which the poultry is slaughtered, deliver, to the cash seller or poultry grower from whom such live poultry dealer obtains the poultry, the full amount due to such cash seller or poultry grower on account of such poultry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee20b3f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s228b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delay or attempt to delay collection of funds as “unfair practice”","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any delay or attempt to delay, by a live poultry dealer which is a party to any such transaction, the collection of funds as herein provided, or otherwise for the purpose of or resulting in extending the normal period of payment for poultry obtained by poultry growing arrangement or purchased in a cash sale, shall be considered an “unfair practice” in violation of this chapter. Nothing in this section shall be deemed to limit the meaning of the term “unfair practice” as used in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee20b3f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s228b–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of cash sale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of this section, a cash sale means a sale in which the seller does not expressly extend credit to the buyer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee20b3f7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title IV, § 410, as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/173/s9/2"},"text":"Pub. L. 100–173, § 9(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-11-23"},"text":"Nov. 23, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/920"},"text":"101 Stat. 920","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee20b3f8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee20b3f9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee20b3fa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 410 of act ","children":[{"tag":"date","attrib":{"date":"1921-08-15"},"text":"Aug. 15, 1921","children":[],"tail":", was renumbered section 414 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s228c"},"text":"section 228c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee20b3fb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee20b3fc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1987-11-23"},"text":"Nov. 23, 1987","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/173/s12"},"text":"section 12 of Pub. L. 100–173","children":[],"tail":", set out as an Effective Date of 1987 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s182"},"text":"section 182 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
