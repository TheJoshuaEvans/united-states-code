{"tag":"section","attrib":{"id":"idefa30d96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3222b"},"text":"§ 3222b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to upgrade agricultural and food sciences facilities at 1890 land-grant colleges, including Tuskegee University","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa30d97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is hereby declared to be the intent of Congress to assist the institutions eligible to receive funds under the Act of ","children":[{"tag":"date","attrib":{"date":"1890-08-30"},"text":"August 30, 1890","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s321"},"text":"7 U.S.C. 321","children":[],"tail":" et seq.], including Tuskegee University (hereafter referred to in this section as “eligible institutions”) in the acquisition and improvement of agricultural and food sciences facilities and equipment, including libraries, so that the eligible institutions may participate fully in the production of human capital."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30d98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary of Agriculture for the purposes of carrying out the provisions of this section, $25,000,000 for each of fiscal years 2002 through 2023, and such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30d99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Four percent of the sums appropriated pursuant to this section shall be available to the Secretary for administration of this grants program. The remaining funds shall be available for grants to eligible institutions for the purpose of assisting them in the purchase of equipment and land, the planning, construction, alteration, or renovation of buildings to strengthen their capacity in the production of human capital in the food and agricultural sciences and can be used at the discretion of the eligible institutions in the areas of research, extension, and resident instruction or any combination thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30d9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Method of awarding grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded pursuant to this section shall be made in such amounts and under such terms and conditions as the Secretary shall determine necessary for carrying out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30d9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of certain uses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal funds provided under this section may not be utilized for the payment of any overhead costs of the eligible institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30d9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may promulgate such rules and regulations as the Secretary may consider necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa30d9d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1447"},"text":"Pub. L. 95–113, title XIV, § 1447","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1612/b"},"text":"Pub. L. 101–624, title XVI, § 1612(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3722"},"text":"104 Stat. 3722","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s813"},"text":"Pub. L. 104–127, title VIII, § 813","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1166"},"text":"110 Stat. 1166","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tIII/s301/a/9"},"text":"Pub. L. 105–185, title III, § 301(a)(