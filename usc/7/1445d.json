{"tag":"section","attrib":{"id":"ideeaaf235-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1445d"},"text":"§ 1445d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special wheat acreage grazing and hay program for 1978 through 1990 crop years","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeaaf236-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for program; acreage designation; payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to administer a special wheat acreage grazing and hay program (hereinafter in this section referred to as the “special program”) in each of the crop years 1978 through 1990. If a special program is implemented, a producer shall be permitted to designate, under such regulations as established by the Secretary, a portion of the acreage on the farm intended to be planted to wheat, feed grains, or upland cotton for harvest, not in excess of 40 per centum thereof, or 50 acres, whichever is greater, which shall be planted to wheat (or some other commodity other than corn or grain sorghum) and used by the producer for grazing purposes or hay rather than for commercial grain production. A producer who elects to participate in the special program shall receive a payment as provided in subsection (c) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeaaf237-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific farm acreage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any producer who elects to participate in the special program under this section shall designate the specific acreage on the farm which is to be used for the purposes set forth in subsection (a) of this section. No crop other than hay may be harvested from acreage included in the special program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeaaf238-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall pay the producer participating in the special program an amount determined by multiplying the farm program payment yield for wheat established for the farm, by the number of acres included in the special program, by a rate of payment determined by the Secretary to be fair and reasonable. The producer shall not be eligible for any other payment or price support on any portion of the acreage for the farm which the producer elects to include in the special program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeaaf239-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other acreage set-aside programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Acreage included in the special program shall be in addition to any acreage included in any acreage set-aside, reduced acreage, or land diversion program otherwise provided for by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeaaf23a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to issue such regulations as the Secretary determines necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeaaf23b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1445d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity Credit Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out the special program through the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeaaf23c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-10-31/ch792"},"text":"Oct. 31, 1949, ch. 792","children":[],"tail":", title I, § 109, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/tX/s1004"},"text":"Pub. L. 95–113, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/950"},"text":"91 Stat. 950","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXI/s1110"},"text":"Pub. L. 97–98, title XI, § 1110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1267"},"text":"95 Stat. 1267","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tX/s1015"},"text":"Pub. L. 99–198, title X, § 1015","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1457"},"text":"99 Stat. 1457","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideeaaf23d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideeaaf23e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideeaaf23f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" substituted “1990” for “1985”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1110/1"},"text":"Pub. L. 97–98, § 1110(1)","children":[],"tail":", (2), substituted “1985” for “1981” and “If a special program is implemented” for “Under the special program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1110/3"},"text":"Pub. L. 97–98, § 1110(3)","children":[],"tail":", inserted “, reduced acreage, or land diversion”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideeaaf240-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideeaaf241-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideeaaf242-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
