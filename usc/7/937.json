{"tag":"section","attrib":{"id":"idee611838-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s937"},"text":null,"children":[{"tag":"num","attrib":{"value":"937"},"text":"§ 937.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans from other credit sources","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When it appears to the Secretary that the loan applicant is able to obtain a loan for part of his credit needs from a responsible cooperative or other credit source at reasonable rates and terms consistent with the loan applicant’s ability to pay and the achievement of this chapter’s objectives, he may request the loan applicant to apply for and accept such a loan concurrently with an insured loan, subject, however, to full use being made by the Secretary of the funds made available hereunder for such insured loans under this subchapter. The Secretary may not request any applicant for an electric loan under this chapter to apply for and accept a loan in an amount exceeding 30 percent of the credit needs of the applicant.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee611839-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title III, § 307, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/32/s2"},"text":"Pub. L. 93–32, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-11"},"text":"May 11, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/70"},"text":"87 Stat. 70","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tI/s165/c"},"text":"Pub. L. 97–35, title I, § 165(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/379"},"text":"95 Stat. 379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/129/s2/c/8"},"text":"Pub. L. 103–129, § 2(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-01"},"text":"Nov. 1, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1365"},"text":"107 Stat. 1365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/13"},"text":"Pub. L. 103–354, title II, § 235(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee61183a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee61183b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee61183c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/129"},"text":"Pub. L. 103–129","children":[],"tail":" inserted at end “The Administrator may not request any applicant for an electric loan under this chapter to apply for and accept a loan in an amount exceeding 30 percent of the credit needs of the applicant.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted “an insured loan” for “a loan insured at the standard rate”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee61183d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee61183e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1973-05-11"},"text":"May 11, 1973","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/32/s12"},"text":"section 12 of Pub. L. 93–32","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s930"},"text":"section 930 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
