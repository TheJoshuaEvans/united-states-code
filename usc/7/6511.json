{"tag":"section","attrib":{"id":"idefe5bc68-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6511"},"text":null,"children":[{"tag":"num","attrib":{"value":"6511"},"text":"§ 6511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional guidelines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe5bc69-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, the applicable governing State official, and the certifying agent shall utilize a system of residue testing to test products sold or labeled as organically produced under this chapter to assist in the enforcement of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc6a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preharvest testing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, the applicable governing State official, or the certifying agent may require preharvest tissue testing of any crop grown on soil suspected of harboring contaminants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bc6b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bc6c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6511/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary, the applicable governing State official, or the certifying agent determines that an agricultural product sold or labeled as organically produced under this chapter contains any detectable pesticide or other non-organic residue or prohibited natural substance the Secretary, the applicable governing State official, or the certifying agent shall conduct an investigation to determine if the organic certification program has been violated, and may require the producer or handler of such product to prove that any prohibited substance was not applied to such product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bc6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6511/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of organic label","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, as determined by the Secretary, the applicable governing State official, or the certifying agent, the investigation conducted under paragraph (1) indicates that the residue is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bc6e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6511/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the result of intentional application of a prohibited substance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bc6f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6511/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present at levels that are greater than unavoidable residual environmental contamination as prescribed by the Secretary or the applicable governing State official in consultation with the appropriate environmental regulatory agencies;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such agricultural product shall not be sold or labeled as organically produced under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe5bc70-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2112"},"text":"Pub. L. 101–624, title XXI, § 2112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3942"},"text":"104 Stat. 3942","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1001/4"},"text":"Pub. L. 102–237, title X, § 1001(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1893"},"text":"105 Stat. 1893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tX/s10005/a"},"text":"Pub. L. 113–79, title X, § 10005(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/944"},"text":"128 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe5bc71-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe5bc72-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe5bc73-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" struck out subsec. (d) which related to recordkeeping requirements for producers who operate a certified organic farm or handling operation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “Preharvest” for “Pre-harvest” in heading."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
