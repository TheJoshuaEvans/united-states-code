{"tag":"section","attrib":{"id":"idee65d2b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"950bb–1"},"text":"§ 950bb–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expansion of middle mile infrastructure into rural areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee65d2b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to encourage the expansion and extension of middle mile broadband infrastructure to connect underserved rural areas to the backbone of the Internet.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d2b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Middle mile infrastructure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of this section, the term “middle mile infrastructure” means any broadband infrastructure that does not connect directly to end-user locations (including anchor institutions) and may include interoffice transport, backhaul, Internet connectivity, data centers, or special access transport to rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d2b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants, loans, and loan guarantees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants, loans, and loan guarantees to eligible applicants described in subsection (d) to provide funds for the construction, improvement, or acquisition of middle mile infrastructure to serve rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d2b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d2b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible applicants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d2b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to obtain assistance under this section, an eligible entity shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee65d2b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee65d2b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree to complete build-out of the middle mile infrastructure described in the application by not later than 5 years after the initial date on which proceeds from the assistance provided under this section are made available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee65d2b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the Secretary a plan to ensure the viability of the project by—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idee65d2ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/d/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" connecting, assisting with connecting, or enabling the connection of retail broadband systems that serve rural areas within the proposed service territory to the middle mile infrastructure project in an affordable and economically competitive manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idee65d2bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/d/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leasing or selling sufficient capacity prior to project approval; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idee65d2bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/d/1/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complying with any other requirements imposed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d2bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional end user broadband programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Entities that receive assistance to construct, improve, or acquire middle mile infrastructure under this section shall be eligible to apply for additional funds under this subchapter to provide for retail broadband service to end users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d2be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible service territories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proceeds of assistance provided under this section may be used to carry out a project in a proposed service territory only if, as of the date the application for assistance under this section is submitted, there is not adequate middle mile infrastructure available to support broadband service for eligible rural communities that would be provided access to the middle mile infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d2bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project shall be eligible for assistance under this section if at the time of the application—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d2c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 75 percent of the interconnection points serve such eligible rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d2c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the proposed middle mile network will be capable of supporting retail broadband service meeting the maximum broadband buildout requirement established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s950bb/e/4"},"text":"section 950bb(e)(4) of this title","children":[],"tail":" for the residents within the proposed service territory."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d2c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d2c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not provide any grant in excess of 20 percent of the total project cost; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d2c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide grants only to those projects which serve rural areas where population density or geographic characteristics make it infeasible to construct middle mile broadband systems without grant assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d2c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms, conditions, and adequacy of security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All loans and loan guarantees provided under this section shall be made subject to such terms, conditions, and adequacy of security requirements as may be imposed by the Secretary. If the middle mile infrastructure would not provide adequate security due to long-term leasing arrangements, the Secretary shall require substitute security in such form and substance as are acceptable to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d2c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–1/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2018 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee65d2c7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title VI, § 602, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6111"},"text":"Pub. L. 110–234, title VI, § 6111","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1203"},"text":"122 Stat. 1203","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6111, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1965; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6202"},"text":"Pub. L. 115–334, title VI, § 6202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4734"},"text":"132 Stat. 4734","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee65d2c8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee65d2c9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee65d2ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee65d2cb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" amended section generally. Prior to amendment, section related to National Center for Rural Telecommunications Assessment."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee65d2cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee65d2cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
