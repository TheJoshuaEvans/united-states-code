{"tag":"section","attrib":{"id":"idefb3af82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4202"},"text":null,"children":[{"tag":"num","attrib":{"value":"4202"},"text":"§ 4202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identifying effects of Federal programs on conversion of farmland to nonagricultural uses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb3af83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of criteria to identify","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of Agriculture, in cooperation with other departments, agencies, independent commissions, and other units of the Federal Government, shall develop criteria for identifying the effects of Federal programs on the conversion of farmland to nonagricultural uses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb3af84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of criteria to identify","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Departments, agencies, independent commissions, and other units of the Federal Government shall use the criteria established under subsection (a) of this section, to identify the quantity of farmland actually converted by Federal programs, and to identify and take into account the adverse effects of Federal programs on the preservation of farmland; consider alternative actions, as appropriate, that could lessen such adverse effects; and assure that such Federal programs, to the extent practicable, are compatible with State, unit of local government, and private programs and policies to protect farmland.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb3af85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of restorative, etc., information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department of Agriculture may make available to States, units of local government, individuals, organizations, and other units of the Federal Government information useful in restoring, maintaining, and improving the quantity and quality of farmland.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb3af86-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXV/s1541"},"text":"Pub. L. 97–98, title XV, § 1541","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1342"},"text":"95 Stat. 1342","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIV/s1454"},"text":"Pub. L. 101–624, title XIV, § 1454","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3614"},"text":"104 Stat. 3614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb3af87-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefb3af88-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefb3af89-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" inserted “to identify the quantity of farmland actually converted by Federal programs, and” after “of this section,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefb3af8a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefb3af8b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective six months after ","children":[{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1549"},"text":"section 1549 of Pub. L. 97–98","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4201"},"text":"section 4201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
