{"tag":"section","attrib":{"id":"idef248f5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2004"},"text":null,"children":[{"tag":"num","attrib":{"value":"2004"},"text":"§ 2004.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited clearing of title to inventory property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Farmers Home Administration may employ local attorneys, on a case-by-case basis, to process all legal procedures necessary to clear the title to foreclosed properties in the inventory of the Farmers Home Administration. Such attorneys shall be compensated at not more than their usual and customary charges for such work.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef248f5b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s356"},"text":"Pub. L. 87–128, title III, § 356","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVI/s618"},"text":"Pub. L. 100–233, title VI, § 618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1683"},"text":"101 Stat. 1683","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
