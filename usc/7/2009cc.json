{"tag":"section","attrib":{"id":"idef2e2cfe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009cc"},"text":"§ 2009cc.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2e2cff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Articles","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “articles” means articles of incorporation for an incorporated body or the functional equivalent or other similar documents specified by the Secretary for other business entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d00-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Developmental capital","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “developmental capital” means capital in the form of equity capital investments in rural business investment companies with an objective of fostering economic development in rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d01-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee welfare benefit plan; pension plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2e2d02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “employee welfare benefit plan” and “pension plan” have the meanings given the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s1002"},"text":"section 1002 of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2d03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms “employee welfare benefit plan” and “pension plan” include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2e2d04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public and private pension or retirement plans subject to this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2e2d05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" similar plans not covered by this subchapter that have been established, and that are maintained, by the Federal Government or any State (including by a political subdivision, agency, or instrumentality of the Federal Government or a State) for the benefit of employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equity capital","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “equity capital” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2e2d07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" common or preferred stock or a similar instrument, including subordinated debt with equity features; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2d08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other type of equity-like financing that might be necessary to facilitate the purposes of this Act, excluding financing such as senior debt or other types of financing that competes with routine loanmaking of commercial lenders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d09-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leverage","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “leverage” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2e2d0a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" debentures purchased or guaranteed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2d0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participating securities purchased or guaranteed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2d0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preferred securities outstanding as of ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" License","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “license” means a license issued by the Secretary as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009cc–3/e"},"text":"section 2009cc–3(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited liability company","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “limited liability company” means a business entity that is organized and operating in accordance with a State limited liability company law approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “member” means, with respect to a rural business investment company that is a limited liability company, a holder of an ownership interest or a person otherwise admitted to membership in the limited liability company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “operational assistance” means management, marketing, and other technical assistance that assists a rural business concern with business development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “participation agreement” means an agreement, between the Secretary and a rural business investment company granted final approval under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009cc–3/e"},"text":"section 2009cc–3(e) of this title","children":[],"tail":", that requires the rural business investment company to make investments in smaller enterprises in rural areas."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private capital","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2e2d13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “private capital” means the total of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2e2d14-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef2e2d15-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the paid-in capital and paid-in surplus of a corporate rural business investment company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef2e2d16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contributed capital of the partners of a partnership rural business investment company; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef2e2d17-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the equity investment of the members of a limited liability company rural business investment company; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2e2d18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" unfunded binding commitments from investors that meet criteria established by the Secretary to contribute capital to the rural business investment company, except that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef2e2d19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unfunded commitments may be counted as private capital for purposes of approval by the Secretary of any request for leverage; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef2e2d1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage shall not be funded based on the commitments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2d1b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “private capital” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2e2d1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any funds borrowed by a rural business investment company from any source;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2e2d1d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any funds obtained through the issuance of leverage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2e2d1e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any funds obtained directly or indirectly from the Federal Government or any State (including by a political subdivision, agency, or instrumentality of the Federal Government or a State), except for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef2e2d1f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds obtained from the business revenues (excluding any governmental appropriation) of any federally chartered or government-sponsored enterprise established prior to ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef2e2d20-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds invested by an employee welfare benefit plan or pension plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef2e2d21-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/11/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any qualified nonprivate funds (if the investors of the qualified nonprivate funds do not control, directly or indirectly, the management, board of directors, general partners, or members of the rural business investment company).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d22-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified nonprivate funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified nonprivate funds” means any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2e2d23-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds directly or indirectly invested in any applicant or rural business investment company on or before ","children":[{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", by any Federal agency, other than the Department of Agriculture, under a provision of law explicitly mandating the inclusion of those funds in the definition of the term “private capital”; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2d24-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds invested in any applicant or rural business investment company by 1 or more entities of any State (including by a political subdivision, agency, or instrumentality of the State and including any guarantee extended by those entities) in an aggregate amount that does not exceed 33 percent of the private capital of the applicant or rural business investment company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d25-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural business concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rural business concern” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2e2d26-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public, private, or cooperative for-profit or nonprofit organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2d27-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a for-profit or nonprofit business controlled by an Indian tribe on a Federal or State reservation or other federally recognized Indian tribal group; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2d28-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other person or entity;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that primarily operates in a rural area, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d29-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural business investment company","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rural business investment company” means a company that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2e2d2a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been granted final approval by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009cc–3/e"},"text":"section 2009cc–3(e) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2d2b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has entered into a participation agreement with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2d2c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Smaller enterprise","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “smaller enterprise” means any rural business concern that, together with its affiliates—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2e2d2d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2e2d2e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/15/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a net financial worth of not more than $6,000,000, as of the date on which assistance is provided under this subchapter to the rural business concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2e2d2f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/15/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an average net income for the 2-year period preceding the date on which assistance is provided under this subchapter to the rural business concern, of not more than $2,000,000, after Federal income taxes (excluding any carryover losses), except that, for purposes of this clause, if the rural business concern is not required by law to pay Federal income taxes at the enterprise level, but is required to pass income through to the shareholders, partners, beneficiaries, or other equitable owners of the business concern, the net income of the business concern shall be determined by allowing a deduction in an amount equal to the total of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef2e2d30-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/15/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the rural business concern is not required by law to pay State (and local, if any) income taxes at the enterprise level, the net income (determined without regard to this clause), multiplied by the marginal State income tax rate (or by the combined State and local income tax rates, as applicable) that would have applied if the business concern were a corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef2e2d31-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/15/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the net income (so determined) less any deduction for State (and local) income taxes calculated under subclause (I), multiplied by the marginal Federal income tax rate that would have applied if the rural business concern were a corporation; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2e2d32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies the standard industrial classification size standards established by the Administrator of the Small Business Administration for the industry in which the rural business concern is primarily engaged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef2e2d33-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s384A"},"text":"Pub. L. 87–128, title III, § 384A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6029"},"text":"Pub. L. 107–171, title VI, § 6029","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/388"},"text":"116 Stat. 388","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6426/a"},"text":"Pub. L. 115–334, title VI, § 6426(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4770"},"text":"132 Stat. 4770","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef2e2d34-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef2e2d35-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef2e2d36-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in par. (4)(B), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/294"},"text":"75 Stat. 294","children":[],"tail":", known as the Agricultural Act of 1961. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1911"},"text":"section 1911 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef2e2d37-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6426/a/1"},"text":"Pub. L. 115–334, § 6426(a)(1)","children":[],"tail":", struck out “venture” after “Developmental” in heading and after “ ‘developmental” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6426/a/2"},"text":"Pub. L. 115–334, § 6426(a)(2)","children":[],"tail":", added par. (4) and struck out former par. (4). Prior to amendment, text read as follows: “The term ‘equity capital’ means common or preferred stock or a similar instrument, including subordinated debt with equity features.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
