{"tag":"section","attrib":{"id":"idefcb7e16-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5675"},"text":null,"children":[{"tag":"num","attrib":{"value":"5675"},"text":"§ 5675.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance in trade negotiations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide technical services to the United States Trade Representative on matters pertaining to agricultural trade and with respect to international negotiations on issues related to agricultural trade.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefcb7e17-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIV/s415"},"text":"Pub. L. 95–501, title IV, § 415","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3685"},"text":"104 Stat. 3685","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
