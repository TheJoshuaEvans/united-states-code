{"tag":"section","attrib":{"id":"idef080617-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1926d"},"text":"§ 1926d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Water systems for rural and Native villages in Alaska","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef080618-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make grants to the State of Alaska, a consortium formed pursuant to section 325 of the Department of the Interior and Related Agencies Appropriations Act, 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83"},"text":"Public Law 105–83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/111/1597"},"text":"111 Stat. 1597","children":[],"tail":"), and Native villages (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"section 1602 of title 43","children":[],"tail":") for the benefit of rural or Native villages in Alaska to provide for the development and construction of water and wastewater systems to improve the health and sanitation conditions in those villages."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef080619-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under subsection (a), the State of Alaska shall provide 25 percent in matching funds from non-Federal sources for any grant awarded under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef08061a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with State of Alaska","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall consult with the State of Alaska on a method of prioritizing the allocation of grants under subsection (a) according to the needs of, and relative health and sanitation conditions in, each village.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef08061b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef08061c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $30,000,000 for each of fiscal years 2008 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef08061d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 2 percent of the amount made available under paragraph (1) for a fiscal year may be used by the State of Alaska, and not more than 2 percent of the amount made available under paragraph (1) for a fiscal year may be used by a consortium formed pursuant to section 325 of the Department of the Interior and Related Agencies Appropriations Act, 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83"},"text":"Public Law 105–83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/111/1597"},"text":"111 Stat. 1597","children":[],"tail":"), for training and technical assistance programs relating to the operation and management of water and waste disposal services in rural and Native villages."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef08061e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1926d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated pursuant to the authorization of appropriations in paragraph (1) shall be available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef08061f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s306D"},"text":"Pub. L. 87–128, title III, § 306D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s757"},"text":"Pub. L. 104–127, title VII, § 757","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1131"},"text":"110 Stat. 1131","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/2