6408"},"text":"Pub. L. 115–334, title VI, § 6408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4761"},"text":"132 Stat. 4761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef080620-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef080621-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef080622-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 325 of the Department of the Interior and Related Agencies Appropriations Act, 1998, referred to in subsecs. (a) and (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83/s325"},"text":"section 325 of Pub. L. 105–83","children":[],"tail":", title III, "},{"tag":"date","attrib":{"date":"1997-11-14"},"text":"Nov. 14, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1597"},"text":"111 Stat. 1597","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef080623-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef080624-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6408/1"},"text":"Pub. L. 115–334, § 6408(1)","children":[],"tail":", substituted “Alaska, a consortium formed pursuant to section 325 of the Department of the Interior and Related Agencies Appropriations Act, 1998 ("},{"tag":"ref","attrib":{"href":"/us/pl/105/83"},"text":"Public Law 105–83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/111/1597"},"text":"111 Stat. 1597","children":[],"tail":"), and Native villages (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1602"},"text":"section 1602 of title 43","children":[],"tail":") for” for “Alaska for”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6408/2"},"text":"Pub. L. 115–334, § 6408(2)","children":[],"tail":", inserted “for any grant awarded under subsection (a)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6408/3/A"},"text":"Pub. L. 115–334, § 6408(3)(A)","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6408/3/B"},"text":"Pub. L. 115–334, § 6408(3)(B)","children":[],"tail":", substituted “Alaska, and not more than 2 percent of the amount made available under paragraph (1) for a fiscal year may be used by a consortium formed pursuant to section 325 of the Department of the Interior and Related Agencies Appropriations Act, 1998 ("},{"tag":"ref","attrib":{"href":"/us/pl/105/83"},"text":"Public Law 105–83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/111/1597"},"text":"111 Stat. 1597","children":[],"tail":"),” for “Alaska”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “2018” for “2012”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s6009/a"},"text":"Pub. L. 110–246, § 6009(a)","children":[],"tail":", substituted “2008 through 2012” for “2001 through 2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" substituted “through 2007” for “and 2002”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224"},"text":"Pub. L. 106–224","children":[],"tail":" added subsec. (d) and struck out heading and text of former subsec. (d). Text read as follows: “There are authorized to be appropriated to carry out this section $20,000,000 for each of fiscal years 1996 through 2002.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “25 percent in matching” for “equal matching”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" substituted “$20,000,000” for “$15,000,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef080625-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef080626-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
