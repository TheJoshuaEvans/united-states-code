{"tag":"section","attrib":{"id":"idf026213e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951"},"text":null,"children":[{"tag":"num","attrib":{"value":"7951"},"text":"§ 7951.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf026213f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base acres for peanuts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “base acres for peanuts” means the number of acres assigned to a farm by historic peanut producers pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7952/b"},"text":"section 7952(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0262140-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counter-cyclical payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “counter-cyclical payment” means a payment made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7954"},"text":"section 7954 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0262141-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “effective price” means the price calculated by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7954"},"text":"section 7954 of this title","children":[],"tail":" for peanuts to determine whether counter-cyclical payments are required to be made under that section for a crop year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0262142-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “direct payment” means a payment made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7953"},"text":"section 7953 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0262143-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historic peanut producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “historic peanut producer” means a producer on a farm in the United States that produced or was prevented from planting peanuts during any or all of the 1998 through 2001 crop years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0262144-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment acres","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “payment acres” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0262145-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the 2002 crop of peanuts, 85 percent of the average acreage determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7952/a/2"},"text":"section 7952(a)(2) of this title","children":[],"tail":" for an historic peanut producer; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0262146-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the 2003 through 2007 crops of peanuts, 85 percent of the base acres for peanuts assigned to a farm under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7952/b"},"text":"section 7952(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0262147-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment yield","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “payment yield” means the yield assigned to a farm by historic peanut producers pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7952/b"},"text":"section 7952(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0262148-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” means an owner, operator, landlord, tenant, or sharecropper that shares in the risk of producing a crop on a farm and is entitled to share in the crop available for marketing from the farm, or would have shared had the crop been produced. In determining whether a grower of hybrid seed is a producer, the Secretary shall not take into consideration the existence of a hybrid seed contract and shall ensure that program requirements do not adversely affect the ability of the grower to receive a payment under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0262149-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf026214a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means each of the several States of the United States, the District of Columbia, the Commonwealth of Puerto Rico, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf026214b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “target price” means the price per ton of peanuts used to determine the payment rate for counter-cyclical payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf026214c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7951/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States”, when used in a geographical sense, means all of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf026214d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1301"},"text":"Pub. L. 107–171, title I, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/166"},"text":"116 Stat. 166","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf026214e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf026214f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0262150-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this subtitle”, meaning subtitle C (§§ 1301–1310) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/166"},"text":"116 Stat. 166","children":[],"tail":", which enacted this subchapter, amended sections 1361, 1371, 1373, 1378, 1428, and 1441 of this title, and repealed sections 1357 to 1359a and 7271 of this title. For complete classification of subtitle C to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
