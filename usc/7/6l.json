{"tag":"section","attrib":{"id":"idedc610c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6l"},"text":null,"children":[{"tag":"num","attrib":{"value":"6l"},"text":"§ 6l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity trading advisors and commodity pool operators; Congressional finding","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is hereby found that the activities of commodity trading advisors and commodity pool operators are affected with a national public interest in that, among other things—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedc610c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" their advice, counsel, publications, writings, analyses, and reports are furnished and distributed, and their contracts, solicitations, subscriptions, agreements, and other arrangements with clients take place and are negotiated and performed by the use of the mails and other means and instrumentalities of interstate commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedc610c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" their advice, counsel, publications, writings, analyses, and reports customarily relate to and their operations are directed toward and cause the purchase and sale of commodities for future delivery on or subject to the rules of contract markets or derivatives transaction execution facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedc610c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the foregoing transactions occur in such volume as to affect substantially transactions on contract markets or derivatives transaction execution facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedc610c9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s4"},"text":"Sept. 21, 1922, ch. 369, § 4","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/463/tII/s205/a"},"text":"Pub. L. 93–463, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-23"},"text":"Oct. 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1397"},"text":"88 Stat. 1397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/5/tI/s123/a/10"},"text":"Pub. L. 106–554, § 1(a)(5) [title I, § 123(a)(10)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–408.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedc610ca-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idedc610cb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idedc610cc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Pars. (2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" inserted “or derivatives transaction execution facilities” after “contract markets”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idedc610cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idedc610ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/463/s418"},"text":"section 418 of Pub. L. 93–463","children":[],"tail":", set out as an Effective Date of 1974 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
