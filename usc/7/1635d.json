{"tag":"section","attrib":{"id":"ideedd256e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1635d"},"text":"§ 1635d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedd256f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cattle committed","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cattle committed” means cattle that are scheduled to be delivered to a packer within the 7-day period beginning on the date of an agreement to sell the cattle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2570-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cattle type","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cattle type” means the following types of cattle purchased for slaughter:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedd2571-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fed steers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd2572-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fed heifers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd2573-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fed Holsteins and other fed dairy steers and heifers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd2574-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cows.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd2575-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Bulls.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2576-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Formula marketing arrangement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “formula marketing arrangement” means the advance commitment of cattle for slaughter by any means other than through a negotiated purchase or a forward contract, using a method for calculating price in which the price is determined at a future date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2577-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forward contract","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “forward contract” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedd2578-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an agreement for the purchase of cattle, executed in advance of slaughter, under which the base price is established by reference to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedd2579-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prices quoted on the Chicago Mercantile Exchange; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedd257a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other comparable publicly available prices; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd257b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other forward contract as the Secretary determines to be applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd257c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Packer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “packer” means any person engaged in the business of buying cattle in commerce for purposes of slaughter, of manufacturing or preparing meats or meat food products from cattle for sale or shipment in commerce, or of marketing meats or meat food products from cattle in an unmanufactured form acting as a wholesale broker, dealer, or distributor in commerce, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedd257d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term includes only a cattle processing plant that is federally inspected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd257e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any calendar year, the term includes only a cattle processing plant that slaughtered an average of at least 125,000 head of cattle per year during the immediately preceding 5 calendar years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd257f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a cattle processing plant that did not slaughter cattle during the immediately preceding 5 calendar years, the Secretary shall consider the plant capacity of the processing plant in determining whether the processing plant should be considered a packer under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2580-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Packer-owned cattle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “packer-owned cattle” means cattle that a packer owns for at least 14 days immediately before slaughter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2581-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of trade","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “terms of trade” includes, with respect to the purchase of cattle for slaughter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedd2582-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether a packer provided any financing agreement or arrangement with regard to the cattle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd2583-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the delivery terms specified the location of the producer or the location of the packer’s plant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd2584-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the producer is able to unilaterally specify the date and time during the business day of the packer that the cattle are to be delivered for slaughter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd2585-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the percentage of cattle purchased by a packer as a negotiated purchase that are delivered to the plant for slaughter more than 7 days, but fewer than 14 days, after the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedd2586-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/7/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the cattle were committed to the packer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedd2587-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/7/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the cattle were purchased by the packer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2588-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type of purchase","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “type of purchase”, with respect to cattle, means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedd2589-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a negotiated purchase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd258a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a formula market arrangement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd258b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1635d/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a forward contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedd258c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 221, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX/s911/2"},"text":"Pub. L. 106–78, title IX, § 911(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1189"},"text":"113 Stat. 1189","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
