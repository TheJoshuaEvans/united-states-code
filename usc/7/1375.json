{"tag":"section","attrib":{"id":"idee8e69be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1375"},"text":null,"children":[{"tag":"num","attrib":{"value":"1375"},"text":"§ 1375.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee8e69bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1375/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide by regulations for the identification, wherever necessary, of corn, wheat, cotton, rice, or peanuts so as to afford aid in discovering and identifying such amounts of the commodities as are subject to and such amounts thereof as are not subject to marketing restrictions in effect under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee8e69c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1375/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe such regulations as are necessary for the enforcement of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee8e69c1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 375, "},{"tag":"ref","attrib":{"href":"/us/stat/52/66"},"text":"52 Stat. 66","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1941-04-03/ch39/s9"},"text":"Apr. 3, 1941, ch. 39, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/92"},"text":"55 Stat. 92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/tVI/s611/k"},"text":"Pub. L. 108–357, title VI, § 611(k)","children":[],"tail":", "},{"tag":"dat