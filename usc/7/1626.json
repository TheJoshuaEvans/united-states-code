{"tag":"section","attrib":{"id":"ideed5f99f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1626"},"text":null,"children":[{"tag":"num","attrib":{"value":"1626"},"text":"§ 1626.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When used in this chapter, the term “agricultural products” includes agricultural, horticultural, viticultural, and dairy products, livestock and poultry, bees, forest products, fish and shellfish, and any products thereof, including processed and manufactured products, and any and all products raised or produced on farms and any processed or manufactured product thereof, and the term “State” when used in this chapter ","children":[{"tag":"ref","attrib":{"idref":"fn002183"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002183"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall include the Virgin Islands and Guam."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideed5f9a0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 207, "},{"tag":"ref","attrib":{"href":"/us/stat/60/1091"},"text":"60 Stat. 1091","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/318/tV/s506/f"},"text":"Pub. L. 92–318, title V, § 506(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-23"},"text":"June 23, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/351"},"text":"86 Stat. 351","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideed5f9a1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editoria