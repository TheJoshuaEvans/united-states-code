[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7210/1/B"},"text":"Pub. L. 115–334, § 7210(1)(B)","children":[],"tail":", inserted “, soil health,” after “conservation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7614/b/2/D"},"text":"Pub. L. 115–334, § 7614(b)(2)(D)","children":[],"tail":", added subsec. (c) and redesignated former subsecs. (c) and (d) as (d) and (e), respectively. Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1)(D) to (G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7210/2/A"},"text":"Pub. L. 115–334, § 7210(2)(A)","children":[],"tail":", added subpars. (D) to (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7210/2/B"},"text":"Pub. L. 115–334, § 7210(2)(B)","children":[],"tail":", in heading, struck out “for fiscal years 2014 through 2018” after “funding”, and in text, substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7614/b/2/D/i"},"text":"Pub. L. 115–334, § 7614(b)(2)(D)(i)","children":[],"tail":", redesignated subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7211/1/A"},"text":"Pub. L. 113–79, § 7211(1)(A)","children":[],"tail":", inserted “, education,” after “support research” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7211/1/B"},"text":"Pub. L. 113–79, § 7211(1)(B)","children":[],"tail":", inserted “and improvement” after “development”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7211/1/C"},"text":"Pub. L. 113–79, § 7211(1)(C)","children