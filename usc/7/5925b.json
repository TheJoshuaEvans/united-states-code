{"tag":"section","attrib":{"id":"idefd51a90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b"},"text":null,"children":[{"tag":"num","attrib":{"value":"5925b"},"text":"§ 5925b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organic agriculture research and extension initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd51a91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive specialized research and extension grants authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In consultation with the National Agricultural Research, Extension, Education, and Economics Advisory Board, using funds made available under subsection (e), the Secretary of Agriculture (referred to in this section as the “Secretary”) may make competitive grants in each of fiscal years 2019 through 2023 to support research, education, and extension activities regarding organically grown and processed agricultural commodities for the purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd51a92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the development and improvement of organic agriculture production, breeding, and processing methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51a93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the potential economic benefits of organic agricultural production and methods to producers, processors, and rural communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51a94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exploring international trade opportunities for organically grown and processed agricultural commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51a95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining desirable traits for organic commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51a96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying marketing and policy constraints on the expansion of organic agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51a97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting advanced on-farm research and development that emphasizes observation of, experimentation with, and innovation for working organic farms, including research relating to production, marketing, food safety, socioeconomic conditions, and farm business management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51a98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examining optimal conservation, soil health, and environmental outcomes relating to organically produced agricultural products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51a99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing new and improved seed varieties that are particularly suited for organic agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51a9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant types and process, prohibition on construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (4), (7), (8), and (11)(B) of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3157"},"text":"section 3157 of this title","children":[],"tail":" shall apply with respect to the making of grants under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51a9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd51a9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), an entity receiving a grant under subsection (a) shall provide non-Federal matching funds (including funds from an agricultural commodity promotion, research, and information program) equal to not less than the amount of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51a9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-kind support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Non-Federal matching funds described in paragraph (1) may include in-kind support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51a9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive the matching funds requirement under paragraph (1) with respect to a research project if the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd51a9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the project are of a particular benefit to a specific agricultural commodity, but those results are likely to be applicable to agricultural commodities generally; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51aa0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefd51aa1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the project—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefd51aa2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/c/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves a minor commodity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefd51aa3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/c/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deals with scientifically important research; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefd51aa4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient is unable to satisfy the matching funds requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51aa5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships encouraged","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Following the completion of a peer review process for grant proposals received under this section, the Secretary may provide a priority to those grant proposals, found in the peer review process to be scientifically meritorious, that involve the cooperation of multiple entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51aa6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On ","children":[{"tag":"date","attrib":{"date":"2003-10-01"},"text":"October 1, 2003","children":[],"tail":", and each October 1 thereafter through "},{"tag":"date","attrib":{"date":"2007-10-01"},"text":"October 1, 2007","children":[],"tail":", out of any funds in the Treasury not otherwise appropriated, the Secretary of the Treasury shall transfer $3,000,000 to the Secretary of Agriculture for this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51aa7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd51aa8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall make available to carry out this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd51aa9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $18,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51aaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for each of fiscal years 2010 through 2012;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51aab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for each of fiscal years 2014 through 2018; and ","children":[{"tag":"ref","attrib":{"idref":"fn002313"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002313"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51aac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $20,000,000 for each of fiscal years 2019 through 2020;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51aad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 2021;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51aae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/f/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30,000,000 for fiscal year 2022; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51aaf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/f/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2023 and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51ab0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretionary funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts made available under paragraph (1), there is authorized to be appropriated to carry out this section $25,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51ab1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925b/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year 2013","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $25,000,000 for fiscal year 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd51ab2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1672B"},"text":"Pub. L. 101–624, title XVI, § 1672B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tII/s244"},"text":"Pub. L. 105–185, title II, § 244","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/555"},"text":"112 Stat. 555","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7218"},"text":"Pub. L. 107–171, title VII, § 7218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/449"},"text":"116 Stat. 449","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII"},"text":"Pub. L. 110–234, title VII","children":[],"tail":", §§ 7206(a), 7406(d)(3), "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1238"},"text":"122 Stat. 1238","children":[],"tail":", 1252; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, §§ 7206(a), 7406(d)(3), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1999, 2013; "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/tVII/s701/e/1"},"text":"Pub. L. 112–240, title VII, § 701(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2364"},"text":"126 Stat. 2364","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII"},"text":"Pub. L. 113–79, title VII","children":[],"tail":", §§ 7128(b)(2)(D), 7211, "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/879"},"text":"128 Stat. 879","children":[],"tail":", 885; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII"},"text":"Pub. L. 115–334, title VII","children":[],"tail":", §§ 7210, 7614(b)(2)(D), "},{"tag":"date","at