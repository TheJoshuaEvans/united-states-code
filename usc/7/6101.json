{"tag":"section","attrib":{"id":"idefdc46c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6101"},"text":null,"children":[{"tag":"num","attrib":{"value":"6101"},"text":"§ 6101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and declaration of policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefdc46c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc46c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mushrooms are an important food that is a valuable part of the human diet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production of mushrooms plays a significant role in the Nation’s economy in that mushrooms are produced by hundreds of mushroom producers, distributed through thousands of wholesale and retail outlets, and consumed by millions of people throughout the United States and foreign countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mushroom production benefits the environment by efficiently using agricultural byproducts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6101/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mushrooms must be high quality, readily available, handled properly, and marketed efficiently to ensure that the benefits of this important product are available to the people of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6101/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the maintenance and expansion of existing markets and uses, and the development of new markets and uses, for mushrooms are vital to the welfare of producers and those concerned with marketing and using mushrooms, as well as to the agricultural economy of the Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6101/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cooperative development, financing, and implementation of a coordinated program of mushroom promotion, research, and consumer information are necessary to maintain and expand existing markets for mushrooms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6101/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mushrooms move in interstate and foreign commerce, and mushrooms that do not move in such channels of commerce directly burden or affect interstate commerce in mushrooms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc46cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is declared to be the policy of Congress that it is in the public interest to authorize the establishment, through the exercise of the powers provided in this chapter, of an orderly procedure for developing, financing through adequate assessments on mushrooms produced domestically or imported into the United States, and carrying out, an effective, continuous, and coordinated program of promotion, research, and consumer and industry information designed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc46cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen the mushroom industry’s position in the marketplace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain and expand existing markets and uses for mushrooms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc46ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6101/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop new markets and uses for mushrooms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc46cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter may be construed to provide for the control of production or otherwise limit the right of individual producers to produce mushrooms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefdc46d0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1922"},"text":"Pub. L. 101–624, title XIX, § 1922","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3855"},"text":"104 Stat. 3855","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefdc46d1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefdc46d2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"constitutionality","id":"idefdc46d3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Constitutionality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For information regarding the constitutionality of subtitle B of title XIX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", which enacted this chapter (sections 6101 et seq.), see the Table of Laws Held Unconstitutional in Whole or in Part by the Supreme Court on the Constitution Annotated website, constitution.congress.gov."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefdc46d4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idefdc46d5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1921"},"text":"Pub. L. 101–624, title XIX, § 1921","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3854"},"text":"104 Stat. 3854","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/624/tXIX/s1921"},"text":"“This subtitle [subtitle B (§§ 1921–1933) of title XIX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", enacting this chapter] may be cited as the ‘Mushroom Promotion, Research, and Consumer Information Act of 1990’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
