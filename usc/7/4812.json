{"tag":"section","attrib":{"id":"idefbf973e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4812"},"text":null,"children":[{"tag":"num","attrib":{"value":"4812"},"text":"§ 4812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension and termination of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbf973f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If after the initial referendum provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4811/a"},"text":"section 4811(a) of this title","children":[],"tail":" the Secretary determines that an order, or a provision of the order, obstructs or does not tend to effectuate the declared policy of this chapter, the Secretary shall terminate or suspend the operation of such order or provision."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9740-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referendum to terminate or suspend; eligible voters; requirements for approval; termination or suspension date; one referendum within 2-year period","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf9741-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4812/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf9742-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4812/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), after the initial referendum provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4811/a"},"text":"section 4811(a) of this title","children":[],"tail":", on the request of a number of persons equal to at least 15 percent of persons who have been producers and importers during a representative period, as determined by the Secretary, the Secretary shall conduct a referendum to determine whether the producers and importers favor the termination or suspension of the order."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9743-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4812/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefbf9744-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4812/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspend or terminate collection of assessments under the order not later than 6 months after the date the Secretary determines that suspension or termination of the order is favored by a majority of the producers and importers voting in the referendum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefbf9745-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4812/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate the order in an orderly manner as soon as practicable after the date of such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9746-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4812/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except with respect to a referendum required to be conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4811"},"text":"section 4811 of this title","children":[],"tail":", the Secretary shall not be required by paragraph (1) to conduct more than one referendum under this chapter in a 2-year period."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9747-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4812/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination or suspension not to be considered an order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The termination or suspension of an order, or a provision of an order, shall not be considered an order within the meaning of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbf9748-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1623"},"text":"Pub. L. 99–198, title XVI, § 1623","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1618"},"text":"99 Stat. 1618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbf9749-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefbf974a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefbf974b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1631"},"text":"section 1631 of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4801"},"text":"section 4801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
