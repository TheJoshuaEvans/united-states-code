{"tag":"section","attrib":{"id":"idf04eb80d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9060"},"text":null,"children":[{"tag":"num","attrib":{"value":"9060"},"text":"§ 9060.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04eb80e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9060/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations to address administrative and enforcement issues involved in carrying out dairy margin coverage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb80f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9060/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reconstitution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations to prohibit a dairy producer from reconstituting a dairy operation for the purpose of the dairy producer receiving dairy margin coverage payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb810-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9060/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative appeals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Using authorities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1308/h"},"text":"section 1308(h) of this title","children":[],"tail":" and subtitle H of the Department of Agriculture Reorganization Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6991"},"text":"7 U.S.C. 6991","children":[],"tail":" et seq.), the Secretary shall promulgate regulations to provide for administrative appeals of decisions of the Secretary that are adverse to participants of dairy margin coverage."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04eb811-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1410"},"text":"Pub. L. 113–79, title I, § 1410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/693"},"text":"128 Stat. 693","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1401/k/10"},"text":"Pub. L. 115–334, title I, § 1401(k)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4518"},"text":"132 Stat. 4518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04eb812-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04eb813-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf04eb814-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Department of Agriculture Reorganization Act, referred to in subsec. (c), probably means the Department of Agriculture Reorganization Act of 1994 which is title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3209"},"text":"108 Stat. 3209","children":[],"tail":". Subtitle H of the Act is classified principally to subchapter VIII (§ 6991 et seq.) of chapter 98 of this title. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf04eb815-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1410"},"text":"section 1410 of Pub. L. 113–79","children":[],"tail":". Subsec. (d) of "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/s1410"},"text":"section 1410 of Pub. L. 113–79","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7253"},"text":"section 7253 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04eb816-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/10/A"},"text":"Pub. L. 115–334, § 1401(k)(10)(A)","children":[],"tail":", substituted “dairy margin coverage” for “the margin protection program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/10/B"},"text":"Pub. L. 115–334, § 1401(k)(10)(B)","children":[],"tail":", substituted “dairy margin coverage payments” for “margin protection payments”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","ch