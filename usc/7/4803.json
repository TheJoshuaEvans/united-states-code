{"tag":"section","attrib":{"id":"idefbf9635-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4803"},"text":null,"children":[{"tag":"num","attrib":{"value":"4803"},"text":"§ 4803.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pork and pork product orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbf9636-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4803/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To carry out this chapter, the Secretary shall, in accordance with this chapter, issue and, from time to time, amend orders applicable to persons engaged in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf9637-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4803/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the production and sale of porcine animals, pork, and pork products in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9638-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4803/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the importation of porcine animals, pork, or pork products into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf9639-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4803/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may issue such regulations as are necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbf963a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"ta