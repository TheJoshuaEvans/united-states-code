{"tag":"section","attrib":{"id":"idefa7c8fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3310a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3310a"},"text":"§ 3310a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research equipment grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa7c8ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3310a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make competitive grants for the acquisition of special purpose scientific research equipment for use in the food and agricultural sciences programs of eligible institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c900-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3310a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant made to an eligible institution under this section may not exceed $500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c901-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3310a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on charge or equipment as indirect costs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The cost of acquisition or depreciation of equipment purchased with a grant under this section shall not be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa7c902-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3310a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charged as an indirect cost against another Federal grant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa7c903-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3310a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" included as part of the indirect cost pool for purposes of calculating the indirect cost rate of an eligible institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c904-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3310a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible institutions defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible institution” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa7c905-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3310a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a college or university; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa7c906-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3310a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State cooperative institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa7c907-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3310a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa7c908-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1462A"},"text":"Pub. L. 95–113, title XIV, § 1462A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7126"},"text":"Pub. L. 115–334, title VII, § 7126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4794"},"text":"132 Stat. 4794","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa7c909-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa7c90a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idefa7c90b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3310a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1462A"},"text":"Pub. L. 95–113, title XIV, § 1462A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7402"},"text":"Pub. L. 107–171, title VII, § 7402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 1