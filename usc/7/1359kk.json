{"tag":"section","attrib":{"id":"idee8bf918-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk"},"text":null,"children":[{"tag":"num","attrib":{"value":"1359kk"},"text":"§ 1359kk.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of tariff rate quotas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee8bf919-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee8bf91a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2) and notwithstanding any other provision of law, at the beginning of the quota year, the Secretary shall establish the tariff-rate quotas for raw cane sugar and refined sugars at the minimum level necessary to comply with obligations under international trade agreements that have been approved by Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee8bf91b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to specialty sugar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee8bf91c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee8bf91d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Before April 1","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before April 1 of each fiscal year, for the sole purpose of responding directly to an emergency shortage of sugar in the United States market that is caused by a war, flood, hurricane, or other natural disaster, or other similar event as determined by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee8bf91e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall take action to increase the supply of sugar in accordance with sections 1359cc(b)(2) and 1359ee(b) of this title, including an increase in the tariff-rate quota for raw cane sugar to accommodate the reassignment to imports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf91f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is still a shortage of sugar in the United States market, and marketing of domestic sugar has been maximized, and domestic raw cane sugar refining capacity has been maximized, the Secretary may increase the tariff-rate quota for refined sugars sufficient to accommodate the supply increase, if the further increase will not threaten to result in the forfeiture of sugar pledged as collateral for a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272"},"text":"section 7272 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee8bf920-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" On or after April 1","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On or after April 1 of each fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee8bf921-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may take action to increase the supply of sugar in accordance with sections 1359cc(b)(2) and 1359ee(b) of this title, including an increase in the tariff-rate quota for raw cane sugar to accommodate the reassignment to imports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf922-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is still a shortage of sugar in the United States market, and marketing of domestic sugar has been maximized, the Secretary may increase the tariff-rate quota for raw cane sugar if the further increase will not threaten to result in the forfeiture of sugar pledged as collateral for a loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272"},"text":"section 7272 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee8bf923-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reallocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee8bf924-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial reallocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (3), following the establishment of the tariff-rate quotas under subsection (a) for a quota year, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee8bf925-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine which countries do not intend to fulfill their allocation for the quota year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf926-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reallocate any forecasted shortfall in the fulfillment of the tariff-rate quotas as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee8bf927-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent reallocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (3), not later than March 1 of a quota year, the Secretary shall reallocate any additional forecasted shortfall in the fulfillment of the tariff-rate quotas for raw cane sugar established under subsection (a)(1) for that quota year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee8bf928-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cessation of effectiveness","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraphs (1) and (2) shall cease to be in effect if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee8bf929-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agreement Suspending the Countervailing Duty Investigation on Sugar from Mexico, signed ","children":[{"tag":"date","attrib":{"date":"2014-12-19"},"text":"December 19, 2014","children":[],"tail":", is terminated; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf92a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no countervailing duty order under subtitle A of title VII of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1671"},"text":"19 U.S.C. 1671","children":[],"tail":" et seq.) is in effect with respect to sugar from Mexico."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee8bf92b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refined sugar","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee8bf92c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of domestic sugar industry","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “domestic sugar industry” means domestic—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee8bf92d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sugar beet producers and processors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf92e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" producers and processors of sugar cane; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf92f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refiners of raw cane sugar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee8bf930-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study required","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee8bf931-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", the Secretary shall conduct a study on whether the establishment of additional terms and conditions with respect to refined sugar imports is necessary and appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf932-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the study under subparagraph (A), the Secretary shall examine the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee8bf933-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The need for—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idee8bf934-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defining “refined sugar” as having a minimum polarization of 99.8 degrees or higher;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idee8bf935-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a standard for color- or reflectance-based units for refined sugar such as those utilized by the International Commission of Uniform Methods of Sugar Analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idee8bf936-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribing specifications for packaging type for refined sugar;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idee8bf937-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2/B/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribing specifications for transportation modes for refined sugar;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idee8bf938-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2/B/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring evidence that sugar imported as refined sugar will not undergo further refining in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idee8bf939-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2/B/i/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribing appropriate terms and conditions to avoid unlawful sugar imports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idee8bf93a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2/B/i/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing other definitions, terms and conditions, or other requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee8bf93b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The potential impact of modifications described in each of subclauses (I) through (VII) of clause (i) on the domestic sugar industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee8bf93c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whether, based on the needs described in clause (i) and the impact described in clause (ii), the establishment of additional terms and conditions is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf93d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting the study under subparagraph (A), the Secretary shall consult with representatives of the domestic sugar industry and users of refined sugar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf93e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that describes the findings of the study conducted under subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee8bf93f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of additional terms and conditions permitted","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee8bf940-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based on the findings in the report submitted under paragraph (2)(D), and after providing notice to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate, the Secretary may issue regulations in accordance with subparagraph (B) to establish additional terms and conditions with respect to refined sugar imports that are necessary and appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee8bf941-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promulgation of regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may issue regulations under subparagraph (A) if the regulations—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee8bf942-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do not have an adverse impact on the domestic sugar industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee8bf943-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359kk/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the requirements of this part, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272"},"text":"section 7272 of this title","children":[],"tail":", and obligations under international trade agreements that have been approved by Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee8bf944-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 359k, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1403/j"},"text":"Pub. L. 110–234, title I, § 1403(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/988"},"text":"122 Stat. 988","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1403(j), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1717; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10312/d"},"text":"Pub. L. 119–21, title I, § 10312(d)","children":[],"tail":