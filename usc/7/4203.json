{"tag":"section","attrib":{"id":"idefb3af8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4203"},"text":null,"children":[{"tag":"num","attrib":{"value":"4203"},"text":"§ 4203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing policies and procedures; review, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefb3af8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each department, agency, independent commission, or other unit of the Federal Government, with the assistance of the Department of Agriculture, shall review current provisions of law, administrative rules and regulations, and policies and procedures applicable to it to determine whether any provision thereof will prevent such unit of the Federal Government from taking appropriate action to comply fully with the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefb3af8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each department, agency, independent commission, or other unit of the Federal Government, with the assistance of the Department of Agriculture, shall, as appropriate, develop proposals for action to bring its programs, authorities, and administrative activities into conformity with the purpose and policy of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefb3af8f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1542"},"text":"Pub. L. 97–98, title XIV, § 1542","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1343"},"text":"95 Stat. 1343","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb3af90-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefb3af91-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefb3af92-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective six months after ","children":[{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1549"},"text":"section 1549 of Pub. L. 97–98","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4201"},"text":"section 4201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
