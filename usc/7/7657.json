{"tag":"section","attrib":{"id":"idf01a397f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657"},"text":null,"children":[{"tag":"num","attrib":{"value":"7657"},"text":"§ 7657.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior Scientific Research Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf01a3980-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Department of Agriculture the Senior Scientific Research Service (referred to in this section as the “Service”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01a3981-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01a3982-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) through (4), the Secretary shall appoint the members of the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3983-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for appointment to the Service, an individual shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a3984-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have conducted outstanding research in the field of agriculture or forestry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a3985-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have earned a doctoral level degree at an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a3986-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet qualification standards prescribed by the Director of the Office of Personnel Management for appointment to a position at level GS–15 of the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3987-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 100 individuals may serve as members of the Service at any 1 time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3988-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a3989-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (B) and subsection (d)(2), the Secretary may appoint and employ a member of the Service without regard to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf01a398a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of title 5 governing appointments in the competitive service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf01a398b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of subchapter I of chapter 35 of title 5 relating to retention preference;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf01a398c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of chapter 43 of title 5 relating to performance appraisal and performance actions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf01a398d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of chapter 51 and subchapter III of chapter 53 of title 5 relating to classification and General Schedule pay rates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf01a398e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b/4/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of chapter 75 of title 5 relating to adverse actions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a398f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Service appointed and employed by the Secretary under subparagraph (A) shall have the same right of appeal to the Merit Systems Protection Board and the same right to file a complaint with the Office of Special Counsel as an employee appointed to a position at level GS–15 of the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01a3990-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance appraisal system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop a performance appraisal system for members of the Service that is designed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01a3991-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the systematic appraisal of the employment performance of the members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3992-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage excellence in employment performance by the members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01a3993-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01a3994-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary shall determine the compensation of members of the Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a3995-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rate of pay for a member of the Service shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a3996-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be less than the minimum rate payable for a position at level GS–15 of the General Schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a3997-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not be more than the rate payable for a position at level I of the Executive Schedule, unless the rate is approved by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5377/d/2"},"text":"section 5377(d)(2) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01a3998-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retirement contributions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01a3999-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the request of a member of the Service who was an employee of an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":") immediately prior to appointment as a member of the Service and who retains the right to continue to make contributions to the retirement system of the institution, the Secretary may contribute an amount not to exceed 10 percent of the basic pay of the member to the retirement system of the institution on behalf of the member."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a399a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal retirement system","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a399b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), a member for whom a contribution is made under paragraph (1) shall not, as a result of serving as a member of the Service, be covered by, or earn service credit under, chapter 83 or 84 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a399c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual leave","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Service of a member of the Service described in subparagraph (A) shall be creditable for determining years of service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6303/a"},"text":"section 6303(a) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf01a399d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Involuntary separation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01a399e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2) and notwithstanding the provisions of title 5 governing appointment in the competitive service, in the case of an individual who is separated from the Service involuntarily and without cause—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a399f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may appoint the individual to a position in the competitive civil service at level GS–15 of the General Schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appointment shall be a career appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01a39a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excepted civil service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of an individual described in paragraph (1) who immediately prior to appointment as a member of the Service was not a career appointee in the civil service or the Senior Executive Service, the appointment of the individual under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf01a39a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be to the excepted civil service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf01a39a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7657/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not exceed a period of 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf01a39a4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s620"},"text":"Pub. L. 105–185, title VI, § 620","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7219"},"text":"Pub. L. 107–171, title VII, § 7219","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/449"},"text":"116 Stat. 449","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf01a39a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf01a39a6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf01a39a7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsecs. (b)(2)(C), (4)(A)(iv), (B), (d)(2)(A), and (f)(1)(A), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Level I of the Executive Schedule, referred to in subsec. (d)(2)(B), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5312"},"text":"section 5312 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
