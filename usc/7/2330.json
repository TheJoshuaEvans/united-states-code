{"tag":"section","attrib":{"id":"idef81a3e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2330"},"text":null,"children":[{"tag":"num","attrib":{"value":"2330"},"text":"§ 2330.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef81a3e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2330/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may publish, or cause to be published, in such format as the Secretary shall determine to be suitable, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef81a3e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2330/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The descriptions of plant varieties protected including drawings and photographs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a3e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2330/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Official Journal of the Plant Variety Protection Office, including annual indices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef81a3e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2330/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Pamphlet copies of the plant variety protection laws and rules of practice and circulars or other publications relating to the business of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef81a3ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2330/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may (1) establish public facilities for the searching of plant variety protection records and materials, and (2) from time to time, as through an information service, disseminate to the public those portions of the technological and other public information available to or within the Plant Variety Protection Office to encourage innovation and promote the progress of plant breeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef81a3eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2330/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may exchange any of the publications specified for publications desirable for the use of the Plant Variety Protection Office. The Secretary may exchange copies of descriptions, drawings, and photographs of United States protected plant varieties for copies of descriptions, drawings, and photographs of applications and protected plant varieties of foreign countries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef81a3ec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tI/s10"},"text":"Pub. L. 91–577, title I, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1543"},"text":"84 Stat. 1543","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/574"},"text":"Pub. L. 96–574","children":[],"tail":", §§ 5–8, "},{"tag":"date","attrib":{"date":"1980-12-22"},"text":"Dec. 22, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3350"},"text":"94 Stat. 3350","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s13/b"},"text":"Pub. L. 103–349, § 13(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3143"},"text":"108 Stat. 3143","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef81a3ed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef81a3ee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef81a3ef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/349"},"text":"Pub. L. 103–349","children":[],"tail":" substituted “the Secretary” for “he” before “shall” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/574/s5"},"text":"Pub. L. 96–574, § 5","children":[],"tail":", substituted provisions respecting descriptions for provisions respecting specifications."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/574"},"text":"Pub. L. 96–574","children":[],"tail":", §§ 6, 7, struck out subsec. (b) which related to photolithography and lithography, redesignated subsec. (c) as (b) and substituted “plant breeding” for “the useful arts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/574"},"text":"Pub. L. 96–574","children":[],"tail":", §§ 7, 8, redesignated subsec. (d) as (c) and substituted “descriptions” for “specifications” in two places. Former subsec. (c) redesignated (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef81a3f0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef81a3f1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/349"},"text":"Pub. L. 103–349","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s15"},"text":"section 15 of Pub. L. 103–349","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2401"},"text":"section 2401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
