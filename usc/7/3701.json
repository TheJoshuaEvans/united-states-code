{"tag":"section","attrib":{"id":"idefaef565-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3701"},"text":null,"children":[{"tag":"num","attrib":{"value":"3701"},"text":"§ 3701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and declarations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds and declares that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefaef566-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an adequate system for the efficient transient storage and movement of bulk agricultural commodities is essential to the overall success of the agricultural industry of the Nation, the development of rural areas of the Nation, and the economic stability of the Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaef567-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movement and storage of bulk agricultural commodities has been seriously and repeatedly impeded by shortages of transient storage facilities, adequate rail rolling stock, and the deterioration of many railroad track beds and rural highways throughout the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaef568-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efficient movement and storage of bulk agricultural commodities may be achieved and facilitated by the joint location at strategic points throughout the United States of transient storage facilities and multimodal terminal facilities constructed especially for the efficient shipment and receipt of agricultural commodities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefaef569-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of such facilities must be carefully planned to assure maximum benefits to producers of agricultural commodities and unprocessed agricultural products and utilization of the most efficient means of transporting bulk agricultural commodities for domestic and export markets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefaef56a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/358/s2"},"text":"Pub. L. 96–358, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-25"},"text":"Sept. 25, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1184"},"text":"94 Stat. 1184","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefaef56b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefaef56c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefaef56d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/358/s6"},"text":"Pub. L. 96–358, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-25"},"text":"Sept. 25, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1189"},"text":"94 Stat. 1189","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/358/s6"},"text":"“The provisions of this Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1932"},"text":"section 1932 of this title","children":[],"tail":"] shall become effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idefaef56e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/358/s1"},"text":"Pub. L. 96–358, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-25"},"text":"Sept. 25, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1184"},"text":"94 Stat. 1184","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/358/s1"},"text":"“That this Act [enacting this chapter and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1932"},"text":"section 1932 of this title","children":[],"tail":"] may be cited as the ‘Agricultural Subterminal Facilities Act of 1980’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
