{"tag":"section","attrib":{"id":"idefac8404-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3353"},"text":null,"children":[{"tag":"num","attrib":{"value":"3353"},"text":"§ 3353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural biosecurity","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefac8405-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security at colleges and universities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefac8406-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3353/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture (referred to in this section as the “Secretary”) may award grants to covered entities to review security standards and practices at their facilities in order to protect against bioterrorist attacks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac8407-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3353/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Covered entities under this subsection are colleges or universities that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefac8408-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3353/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are colleges or universities as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefac8409-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3353/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have programs in food and agricultural sciences, as defined in such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac840a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3353/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each individual covered entity may be awarded one grant under paragraph (1), the amount of which shall not exceed $50,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac840b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3353/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Colleges and universities receiving grants under paragraph (1) may use such grants to enter into contracts with independent private organizations with established and demonstrated security expertise to conduct the security reviews specified in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac840c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines for agricultural biosecurity","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefac840d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3353/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award grants to associations of food producers or consortia of such associations for the development and implementation of educational programs to improve biosecurity on farms in order to ensure the security of farm facilities against potential bioterrorist attacks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac840e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3353/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each individual association eligible under paragraph (1) may be awarded one grant under such paragraph, the amount of which shall not exceed $100,000. Each consortium eligible under paragraph (1) may be awarded one grant under such paragraph, the amount of which shall not exceed $100,000 per association participating in the consortium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac840f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3353/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Associations of food producers receiving grants under paragraph (1) may use such grants to enter into contracts with independent private organizations with established and demonstrated expertise in biosecurity to assist in the development and implementation of educational programs to improve biosecurity specified in such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8410-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as may be necessary for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefac8411-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/188/tIII/s334"},"text":"Pub. L. 107–188, title III, § 334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-12"},"text":"June 12, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/679"},"text":"116 Stat. 679","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefac8412-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefac8413-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefac8414-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Public Health Security and Bioterrorism Preparedness and Response Act of 2002, and not as part of the National Agricultural Research, Extension, and Teaching Policy Act of 1977 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
