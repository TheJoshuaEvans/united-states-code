{"tag":"section","attrib":{"id":"idf0157fc6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625"},"text":null,"children":[{"tag":"num","attrib":{"value":"7625"},"text":"§ 7625.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Food Safety Training, Education, Extension, Outreach, and Technical Assistance Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0157fc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants under this section to carry out the competitive grant program established under section 399c(d) ","children":[{"tag":"ref","attrib":{"idref":"fn002347"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002347"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 21, pursuant to any memoranda of understanding entered into under such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fc8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integrated approach","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The grant program described under subsection (a) shall be carried out under this section in a manner that facilitates the integration of food safety standards and guidance with the variety of agricultural production systems, encompassing conventional, sustainable, organic, and conservation and environmental practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fc9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall give priority to projects that target small and medium-sized farms, beginning farmers, socially disadvantaged farmers, veteran farmers or ranchers (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279/a"},"text":"section 2279(a) of this title","children":[],"tail":"), small processors, or small fresh fruit and vegetable merchant wholesalers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157fcb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate implementation of the grant program under this section with the National Integrated Food Safety Initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157fcc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interaction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157fcd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out the grant program under this section, take into consideration applied research, education, and extension results obtained from the National Integrated Food Safety Initiative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157fce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in determining the applied research agenda for the National Integrated Food Safety Initiative, take into consideration the needs articulated by participants in projects funded by the program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fcf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157fd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall make competitive grants to support training, education, extension, outreach, and technical assistance projects that will help improve public health by increasing the understanding and adoption of established food safety standards, guidance, and protocols.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157fd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouraged features","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall encourage projects carried out using grant funds under this section to include co-management of food safety, conservation systems, and ecological health.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157fd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant under this section shall have a term that is not more than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157fd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a grant under this section, an entity shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157fd5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State cooperative extension service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157fd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal, State, local, or tribal agency, a nonprofit community-based or non-governmental organization, or an organization representing owners and operators of farms, small food processors, or small fruit and vegetable merchant wholesalers that has a commitment to public health and expertise in administering programs that contribute to food safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157fd7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"section 1001(a) of title 20","children":[],"tail":") or a foundation maintained by an institution of higher education;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157fd8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a collaboration of 2 of more eligible entities described in this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157fd9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other appropriate entity, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157fda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multistate partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants under this section may be made for projects involving more than 1 State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fdb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional balance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this section, the Secretary shall, to the maximum extent practicable, ensure—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157fdc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic diversity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157fdd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diversity of types of agricultural production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fde-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technical assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use funds made available under this section to provide technical assistance to grant recipients to further the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fdf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices and model programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Based on evaluations of, and responses arising from, projects funded under this section, the Secretary may issue a set of recommended best practices and models for food safety training programs for agricultural producers, small food processors, and small fresh fruit and vegetable merchant wholesalers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fe0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7625/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purposes of making grants under this section, there is authorized to be appropriated $10,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0157fe1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tIV/s405"},"text":"Pub. L. 105–185, title IV, § 405","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/353/tII/s209/b"},"text":"Pub. L. 111–353, title II, § 209(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3947"},"text":"124 Stat. 3947","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7301"},"text":"Pub. L. 115–334, title VII, § 7301","children":[],"tail":", title XII, § 12306(e), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4815"},"text":"132 Stat. 4815","children":[],"tail":", 4970.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0157fe2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0157fe3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0157fe4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s399c/d"},"text":"Section 399c(d) of title 21","children":[],"tail":", referred to in subsec. (a), was in the original “section 1011(d) of the Federal Food, Drug, and Cosmetic Act” and was translated as meaning section 1011(d) of the Act as added by "},{"tag":"ref","attrib":{"href":"/us/pl/111/353/tII/s209/a"},"text":"Pub. L. 111–353, title II, § 209(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3945"},"text":"124 Stat. 3945","children":[],"tail":", to reflect the probable intent of Congress. "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s399c"},"text":"Section 399c of title 21","children":[],"tail":" was renumbered section 1012 of the Federal Food, Drug, and Cosmetic Act by "},{"tag":"ref","attrib":{"href":"/us/pl/114/255/dA/tIII/s3073/b/2"},"text":"Pub. L. 114–255, div. A, title III, § 3073(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-13"},"text":"Dec. 13, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1137"},"text":"130 Stat. 1137","children":[],"tail":". Another section 1011 of the Federal Food, Drug, and Cosmetic Act as added by "},{"tag":"ref","attrib":{"href":"/us/pl/111/148/tIII/s3509/g"},"text":"Pub. L. 111–148, title III, § 3509(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-03-23"},"text":"Mar. 23, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/536"},"text":"124 Stat. 536","children":[],"tail":" is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s399b"},"text":"section 399b of Title 21","children":[],"tail":", Food and Drugs, but does not contain a subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf0157fe5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7625, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tIV/s405"},"text":"Pub. L. 105–185, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/572"},"text":"112 Stat. 572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII"},"text":"Pub. L. 107–171, title VII","children":[],"tail":", §§ 7130, 7207(b), "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/435"},"text":"116 Stat. 435","children":[],"tail":", 440, related to the Thomas Jefferson Initiative for Crop Diversification, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7305"},"text":"Pub. L. 110–234, title VII, § 7305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1242"},"text":"122 Stat. 1242","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7305, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2003. Repeal of prior section 7625 and repeal of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf0157fe6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12306/e"},"text":"Pub. L. 115–334, § 12306(e)","children":[],"tail":", inserted “veteran farmers or ranchers (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279/a"},"text":"section 2279(a) of this title","children":[],"tail":"),” after “socially disadvantaged farmers,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7301/a"},"text":"Pub. L. 115–334, § 7301(a)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) related to maximum term and size of grant."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7301/b"},"text":"Pub. L. 115–334, § 7301(b)","children":[],"tail":", substituted “there is authorized to be appropriated $10,000,000 for each of fiscal years 2019 through 2023.” for “there are authorized to be appropriated such sums as may be necessary for fiscal years 2011 through 2015.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0157fe7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf0157fe8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in this section to be construed to apply to certain alcohol-related facilities, to alter jurisdiction and authorities established under certain other Acts, or in a manner inconsistent with international agreements to which the United States is a party, see sections 2206, 2251, and 2252 of Title 21, Food and Drugs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
