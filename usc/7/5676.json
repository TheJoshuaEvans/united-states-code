{"tag":"section","attrib":{"id":"idefcb7e18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5676"},"text":null,"children":[{"tag":"num","attrib":{"value":"5676"},"text":"§ 5676.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on use of certain export promotion programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefcb7e19-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5676/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide that a person shall be ineligible for participation in an export program established under title I of the Food for Peace Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1701"},"text":"7 U.S.C. 1701","children":[],"tail":" et seq.], or in any other export credit, credit guarantee, bonus, or other export program carried out through, or administered by, the Commodity Credit Corporation or carried out with funds made available pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s612c"},"text":"section 612c of this title","children":[],"tail":" with respect to the export of any agricultural commodity or product that has been or will be used as the basis for a claim of a refund, as drawback, pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s1313/j/2"},"text":"section 1313(j)(2) of title 19","children":[],"tail":", of any duty, tax, or fee imposed under Federal law on an imported commodity or product."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e1a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5676/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vegetable oil","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person shall be ineligible for participation in any of the export programs referred to in subsection (a) with respect to the export of vegetable oil or a vegetable oil product that has been or will be used as the basis for a claim of a refund, as a drawback, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1313"},"text":"section 1313 of title 19","children":[],"tail":", of any duty, tax, or fee imposed under Federal law on an imported commodity or product."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e1b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5676/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary takes action under the authority granted under subsection (a), a person applying to export any agricultural commodity under the export programs referred to in subsection (a) shall certify that none of the commodity has been or will be used as the basis of a claim for any refund specified in subsection (a), except that regardless of whether the Secretary takes action under the authority granted under subsection (a), a person applying to export any vegetable oil or vegetable oil product under such programs shall certify that none of the vegetable oil or vegetable oil product has been or will be used as the basis of a claim for any refund specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e1c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5676/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefcb7e1d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5676/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to quantities of agricultural commodities and products with respect to which an exporter has entered into a contract, prior to ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":", for an export sale."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefcb7e1e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIV/s416"},"text":"Pub. L. 95–501, title IV, § 416","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3685"},"text":"104 Stat. 3685","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tIII/s313"},"text":"Pub. L. 102–237, title III, § 313","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1856"},"text":"105 Stat. 1856","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3001/b/1/A"},"text":"Pub. L. 110–246, title III, § 3001(b)(1)(A)","children":[],"tail":", (2)(K), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1820"},"text":"122 Stat. 1820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefcb7e1f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefcb7e20-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefcb7e21-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food for Peace Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text":"act July 10, 1954, ch. 469","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/454"},"text":"68 Stat. 454","children":[],"tail":". Title I of the Act is classified generally to subchapter II (§ 1701 et seq.) of chapter 41 of this title. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefcb7e22-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" substituted “Food for Peace Act” for “Agricultural Trade Development and Assistance Act of 1954”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":"” for “the effective date of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefcb7e23-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefcb7e24-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/b"},"text":"section 4(b) of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
