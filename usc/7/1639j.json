{"tag":"section","attrib":{"id":"ideee1e106-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1639j"},"text":null,"children":[{"tag":"num","attrib":{"value":"1639j"},"text":"§ 1639j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion from Federal preemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter, subchapter V, or any regulation, rule, or requirement promulgated in accordance with this subchapter or subchapter V shall be construed to preempt any remedy created by a State or Federal statutory or common law right.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideee1e107-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 296, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/216/s1"},"text":"Pub. L. 114–216, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-29"},"text":"July 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/838"},"text":"130 Stat. 838","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
