{"tag":"section","attrib":{"id":"idf017ca18-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7655"},"text":null,"children":[{"tag":"num","attrib":{"value":"7655"},"text":"§ 7655.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safe food handling education","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall continue to develop a national program of safe food handling education for adults and young people to reduce the risk of food-borne illness. The national program shall be suitable for adoption and implementation through State cooperative extension services and school-based education programs.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idf017ca19-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tVI/s616"},"text":"Pub. L. 105–185, title VI, § 616","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/606"},"text":"112 Stat. 606","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
