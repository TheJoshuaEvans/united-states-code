{"tag":"section","attrib":{"id":"idef710217-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"2204–3"},"text":"§ 2204–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of designated employees; retroactive revocation of delegation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever a delegation is made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2204–2"},"text":"section 2204–2 of this title","children":[],"tail":", all provisions of law shall be construed as if the regulatory function or the part thereof delegated had (to the extent of the delegation) been vested by law in the individual to whom the delegation is made, instead of in the Secretary of Agriculture. A revocation of delegation shall not be retroactive, and each regulatory function or part thereof performed (within the scope of the delegation) by such individual prior to the revocation shall be considered as having been performed by the Secretary."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef710218-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-04-04/ch75/s3"},"text":"Apr. 4, 1940, ch. 75, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/82"},"text":"54 Stat. 82","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef710219-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef71021a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef71021b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s450e"},"text":"section 450e of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section, and to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s516c"},"text":"section 516c of Title 5","children":[],"tail":" prior to the general revision and enactment of Title 5, Government Organization and Employees, by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554/s1"},"text":"Pub. L. 89–554, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/378"},"text":"80 Stat. 378","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
