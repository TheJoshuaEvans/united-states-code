{"tag":"section","attrib":{"id":"ideec2e7ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1508c"},"text":"§ 1508c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peanut revenue crop insurance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideec2e7bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective beginning with the 2015 crop year, the Risk Management Agency and the Corporation shall make available to producers of peanuts a revenue crop insurance program for peanuts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideec2e7bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (c), for purposes of the revenue crop insurance program and the multiperil crop insurance program under this subchapter, the effective price for peanuts shall be equal to the Rotterdam price index for peanuts or other appropriate price as determined by the Secretary, as adjusted to reflect the farmer stock price of peanuts in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideec2e7bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideec2e7be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The effective price for peanuts established under subsection (b) may be adjusted by the Risk Management Agency and the Corporation to correct distortions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideec2e7bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an adjustment is made under paragraph (1), the Risk Management Agency and the Corporation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideec2e7c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the adjustment in an open and transparent manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideec2e7c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that describes the reasons for the adjustment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideec2e7c2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title V, § 508C, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tXI/s11018"},"text":"Pub. L. 113–79, title XI, § 11018","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/966"},"text":"128 Stat. 966","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
