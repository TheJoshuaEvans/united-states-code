{"tag":"section","attrib":{"id":"idf010c49b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7512"},"text":null,"children":[{"tag":"num","attrib":{"value":"7512"},"text":"§ 7512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf010c49c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue regulations within 30 days to implement this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c49d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimization of regulatory requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In administering this chapter, the Secretary shall minimize, to the maximum extent practicable, the regulatory, recordkeeping, and paperwork requirements imposed on eligible recipient agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c49e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7512/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication in Federal Register","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf010c49f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7512/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall as early as feasible but not later than the beginning of each fiscal year, publish in the Federal Register an estimate of the types and quantities of commodities that the Secretary anticipates are likely to be made available under the commodity distribution program under this chapter during the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c4a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7512/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The actual types and quantities of commodities made available by the Secretary under this chapter may differ from the estimates made under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c4a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7512/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards of liability for commodity losses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations issued by the Secretary under this section shall include provisions that set standards with respect to liability for commodity losses under the program under this chapter in situations in which there is no evidence of negligence or fraud, and conditions for payment to cover such losses. Such provisions shall take into consideration the special needs and circumstances of emergency feeding organizations ","children":[{"tag":"ref","attrib":{"idref":"fn002343"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002343"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c4a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7512/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to issue final regulations without first issuing proposed regulations for public comment in order to carry out the provisions of sections 7514 and 7515 of this title. If final regulations are issued without such prior public comment the Secretary shall permit public comment on such regulations, consider pertinent comments, and make modifications of such regulations as appropriate not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1988-09-19"},"text":"September 19, 1988","children":[],"tail":". Such final and modified regulations shall be accompanied by a statement of the basis and purpose for such regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf010c4a3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/8/tII/s210"},"text":"Pub. L. 98–8, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-03-24"},"text":"Mar. 24, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/36"},"text":"97 Stat. 36","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/92/s2/9"},"text":"Pub. L. 98–92, § 2(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-09-02"},"text":"Sept. 2, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/611"},"text":"97 Stat. 611","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXV/s1570"},"text":"Pub. L. 99–198, title XV, § 1570","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", 