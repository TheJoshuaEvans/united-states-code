","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee8e698e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s611/i/1"},"text":"Pub. L. 108–357, § 611(i)(1)","children":[],"tail":", substituted “or rice” for “rice, or tobacco” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357/s611/i/2"},"text":"Pub. L. 108–357, § 611(i)(2)","children":[],"tail":", which directed amendment of first sentence of subsec. (b) by substituting “or rice” for “rice, or tobacco”, was executed by making the substitution for “rice,, or tobacco”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1309/h/2/A"},"text":"Pub. L. 107–171, § 1309(h)(2)(A)","children":[],"tail":", struck out “peanuts,” before “or tobacco” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s1309/h/2/B"},"text":"Pub. L. 107–171, § 1309(h)(2)(B)","children":[],"tail":", struck out “peanuts” before “or tobacco” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1962—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/703/s321/1"},"text":"Pub. L. 87–703, § 321(1)","children":[],"tail":", struck out “corn, wheat,” before “cotton”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/703/s321/2"},"text":"Pub. L. 87–703, § 321(2)","children":[],"tail":", struck out “any national acreage allotment for corn, or” after “export demand,”, “wheat,” before “cotton” and “in order to effect the declared policy of this chapter or” before “to meet such emergency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Subsec. (b). Act ","children":[{"tag":"date","attrib":{"date":"1954-08-28"},"text":"Aug. 28, 1954","children":[],"tail":", § 312(a), inserted proviso relating to national acreage allotment for corn, and struck out corn from national marketing quota provision."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). Act ","children":[{"tag":"date","attrib":{"date":"1954-08-28"},"text":"Aug. 28, 1954","children":[],"tail":", § 312(b), inserted “or acreage allotment” after “marketing quota” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). Act ","children":[{"tag":"date","attrib":{"date":"1954-08-28"},"text":"Aug. 28, 1954","children":[],"tail":", § 312(c), repealed subsec. (d) which related to the adjustment of corn storage regulations on change in marketing quotas."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1941—Subsecs. (a), (b). Act ","children":[{"tag":"date","attrib":{"date":"1941-04-03"},"text":"Apr. 3, 1941","children":[],"tail":", inserted “peanuts,” after “rice,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee8e698f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee8e6990-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" applicable to the 2005 and subsequent crops of tobacco, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s643"},"text":"section 643 of Pub. L. 108–357","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s518"},"text":"section 518 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee8e6991-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1962 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/703"},"text":"Pub. L. 87–703","children":[],"tail":" effective only with respect to programs applicable to the crops planted for harvest in the calendar year 1964 or any subsequent year and the marketing years beginning in the calendar year 1964, or any subsequent year, see "},{"tag":"ref","attrib":{"href":"/us/pl/87/703/s323"},"text":"section 323 of Pub. L. 87–703","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idee8e6992-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by sections 611 to 614 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/357"},"text":"Pub. L. 108–357","children":[],"tail":" not to affect the liability of any person under any provision of law so amended with respect to the 2004 or an earlier crop of tobacco, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/357/s614"},"text":"section 614 of Pub. L. 108–357","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s515"},"text":"section 515 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee8e6993-3a6e-11f1-addd-bbaf0b3f68