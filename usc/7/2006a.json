{"tag":"section","attrib":{"id":"idef248f72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2006a"},"text":"§ 2006a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Borrower training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef248f73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall enter into contracts to provide educational training to all borrowers of farmer program direct loans made under this chapter in financial and farm management concepts associated with commercial farming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248f74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef248f75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may contract with State or private providers of farm management and credit counseling services (including a community college, the extension service of a State, a State department of agriculture, or a nonprofit organization) to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248f76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may consult with the chief executive officer of a State concerning the identity of the contracting organization and the process for contracting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248f77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for loans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef248f78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), to be eligible to obtain a direct loan under this chapter, a borrower must obtain management assistance under this section, appropriate to the management ability of the borrower (as determined by the appropriate county committee during the determination of eligibility for the loan).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248f79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The need of a borrower who satisfies the criteria set out in section 1922(a)(1)(B) or 1941(a)(1)(B) of this title for management assistance under this section shall not be cause for denial of eligibility of the borrower for a direct loan under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248f7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines and curriculum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue regulations establishing guidelines and curriculum for the borrower training program established under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248f7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A borrower shall pay for training received under this section, and may use funds from operating loans made under subchapter II to pay for the training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248f7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef248f7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may waive the requirements of this section for an individual borrower if the Secretary determines that the borrower demonstrates adequate knowledge in areas described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248f7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish criteria providing for the application of paragraph (1) consistently in all counties nationwide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef248f7f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s359"},"text":"Pub. L. 87–128, title III, § 359","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1818/a"},"text":"Pub. L. 101–624, title XVIII, § 1818(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3829"},"text":"104 Stat. 3829","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/a/tVIII/s805/3"},"text":"Pub. L. 105–277, div. A, § 101(a) [title VIII, § 805(3)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681"},"text":"112 Stat. 2681","children":[],"tail":", 2681–39; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tV"},"text":"Pub. L. 107–171, title V","children":[],"tail":", §§ 5316, 5501(c), "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/348"},"text":"116 Stat. 348","children":[],"tail":", 351; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tV/s5306"},"text":"Pub. L. 113–79, title V, § 5306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/840"},"text":"128 Stat. 840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef248f80-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef248f81-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef248f82-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (c), was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":", known as the Consolidated Farm and Rural Development Act, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef248f83-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “section 1922(a)(1)(B) or 1941(a)(1)(B)” for “section 1922(a)(2) or 1941(a)(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s5501/c"},"text":"Pub. L. 107–171, § 5501(c)","children":[],"tail":", struck out “established pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1982"},"text":"section 1982 of this title","children":[],"tail":",” after “appropriate county committee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s5316"},"text":"Pub. L. 107–171, § 5316","children":[],"tail":", added subsec. (f) and struck out heading and text of former subsec. (f). Text read as follows: “The Secretary may waive the requirements of this section for an individual borrower on a determination by the county committee that the borrower demonstrates adequate knowledge in areas described in this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/a/tVIII/s805/3/A"},"text":"Pub. L. 105–277, § 101(a) [title VIII, § 805(3)(A)]","children":[],"tail":", struck out “and guaranteed” after “direct”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/a/tVIII/s805/3/B"},"text":"Pub. L. 105–277, § 101(a) [title VIII, § 805(3)(B)]","children":[],"tail":", struck out “or guaranteed” after “direct” in pars. (1) and (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
