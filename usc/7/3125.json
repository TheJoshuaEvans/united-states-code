{"tag":"section","attrib":{"id":"idef972677-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3125"},"text":null,"children":[{"tag":"num","attrib":{"value":"3125"},"text":"§ 3125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report of Secretary of Agriculture to President and Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to the President and Congress by January 1 of each year a report on the Nation’s agricultural research, extension, and teaching activities, and such report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef972678-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3125/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a review covering the following three categories of activities of the Department of Agriculture with respect to agricultural research, extension, and teaching activities and the relationship of these activities to similar activities of other departments and agencies of the Federal Government, the States, colleges and universities, and the private sector—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef972679-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3125/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a current inventory of such activities organized by statutory authorization and budget outlay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef97267a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3125/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a current inventory of such activities organized by field of basic and applied science; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef97267b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3125/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a current inventory of such activities organized by commodity and product category;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef97267c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3125/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations of the Advisory Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef97267d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3125/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the second and succeeding years, a five-year projection of national priorities with respect to agricultural research, extension, and teaching, taking into account both domestic and international needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef97267e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1410"},"text":"Pub. L. 95–113, title XIV, § 1410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/989"},"text":"91 Stat. 989","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1411"},"text":"Pub. L. 97–98, title XIV, § 1411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1302"},"text":"95 Stat. 1302","children":[],"tail":"; "},{"tag":"re