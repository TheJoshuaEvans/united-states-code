{"tag":"section","attrib":{"id":"idef8ffb58-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2905"},"text":null,"children":[{"tag":"num","attrib":{"value":"2905"},"text":"§ 2905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of organizations to nominate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8ffb59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of State organization certified by Secretary; eligibility criteria","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The eligibility of any State organization to represent producers and to participate in the making of nominations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2904/1"},"text":"section 2904(1) of this title","children":[],"tail":" shall be certified by the Secretary. The Secretary shall certify any State organization that the Secretary determines meets the eligibility criteria established under subsection (b) and such determination as to eligibility shall be final."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8ffb5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State cattle association or State general farm organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State cattle association or State general farm organization may be certified as described in subsection (a) if such association or organization meets all of the following eligibility criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8ffb5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The association or organization’s total paid membership is comprised of at least a majority of cattle producers or the association or organization’s total paid membership represents at least a majority of the cattle producers in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffb5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The association or organization represents a substantial number of producers that produce a substantial number of cattle in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffb5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2905/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The association or organization has a history of stability and permanency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffb5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2905/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A primary or overriding purpose of the association or organization is to promote the economic welfare of cattle producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8ffb5f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factual report basis for certification of State cattle association and State general farm association","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Certification of State cattle associations and State general farm organizations shall be based on a factual report submitted by the association or organization involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8ffb60-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2905/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of more than one State organization; caucus","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If more than one State organization is certified in a State (or in a unit referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2904/1"},"text":"section 2904(1) of this title","children":[],"tail":"), such organizations may caucus to determine any of such State’s (or such unit’s) nominations under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2904/1"},"text":"section 2904(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8ffb61-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/294/s6"},"text":"Pub. L. 94–294, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-05-28"},"text":"May 28, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/531"},"text":"90 Stat. 531","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1601/b"},"text":"Pub. L. 99–198, title XVI, § 1601(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1603"},"text":"99 Stat. 1603","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8ffb62-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef8ffb63-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef8ffb64-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" amended section generally, substituting provisions relating to certification of organizations to nominate for provisions relating to findings and issuance of orders."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef8ffb65-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef8ffb66-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1601/c"},"text":"section 1601(c) of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2901"},"text":"section 2901 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
