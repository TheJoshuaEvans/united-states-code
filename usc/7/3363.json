{"tag":"section","attrib":{"id":"idefac8440-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3363"},"text":null,"children":[{"tag":"num","attrib":{"value":"3363"},"text":"§ 3363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resident instruction grants for insular areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefac8441-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3363/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall make competitive grants to eligible institutions to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefac8442-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3363/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen institutional educational capacities, including libraries, curriculum, faculty, scientific instrumentation, instruction delivery systems, and student recruitment and retention, in order to respond to identified State, regional, national, or international education needs in the food and agricultural sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac8443-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3363/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" attract and support undergraduate and graduate students in order to educate them in identified areas of national need in the food and agriculture sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac8444-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3363/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate cooperative initiatives between two or more insular area eligible institutions, or between those institutions and units of State Government or organizations in the private sector, to maximize the development and use of resources such as faculty, facilities, and equipment to improve food and agricultural sciences teaching programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac8445-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3363/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct undergraduate scholarship programs to assist in meeting national needs for training food and agricultural scientists.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8446-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3363/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefac8447-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3363/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture shall ensure that each eligible institution, prior to receiving grant funds under subsection (a), shall have a significant demonstrable commitment to higher education programs in the food and agricultural sciences and to each specific subject area for which grant funds under this section are to be used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac8448-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3363/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture may require that any grant awarded under this section contain provisions that require funds to be targeted to meet the needs identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3101"},"text":"section 3101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8449-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3363/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefac844a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3363/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2002 through 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefac844b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3363/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefac844c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1491"},"text":"Pub. L. 95–113, title XIV, § 1491","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7503"},"text":"Pub. L. 107–171, title VII, § 7503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/465"},"text":"116 Stat. 465","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7143/b"},"text":"Pub. L. 110–234, title VII, § 7143(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1233"},"text":"122 Stat. 1233","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7143(b), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1994; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7127/b"},"text":"Pub. L. 113–79, title VII, § 7127(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/877"},"text":"128 Stat. 877","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7136/b"},"text":"Pub. L. 115–334, title VII, § 7136(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4802"},"text":"132 Stat. 4802","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefac844d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefac844e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefac844f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefac8450-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “to carry out this section—” for “such sums as are necessary for each of the fiscal years 2002 through 2012 to carry out this section.” and added pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsecs. (c), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7143/b"},"text":"Pub. L. 110–246, § 7143(b)","children":[],"tail":", redesignated subsec. (e) as (c) and substituted “2012” for “2007”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefac8451-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"