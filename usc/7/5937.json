{"tag":"section","attrib":{"id":"idefd78bc8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5937"},"text":null,"children":[{"tag":"num","attrib":{"value":"5937"},"text":"§ 5937.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Natural products research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd78bc9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5937/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the Department a natural products research program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78bca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5937/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the program established under subsection (a), the Secretary shall coordinate research relating to natural products, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd78bcb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5937/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research to improve human health and agricultural productivity through the discovery, development, and commercialization of products and agrichemicals from bioactive natural products, including products from plant, marine, and microbial sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78bcc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5937/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research to characterize the botanical sources, production, chemistry, and biological properties of plant-derived natural products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78bcd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5937/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other research priorities identified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78bce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5937/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer and merit review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd78bcf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5937/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the relevance and merit of research under this section through a system of peer review established by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7613"},"text":"section 7613 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78bd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5937/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve funding for research on the basis of merit, quality, and relevance to advancing the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78bd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5937/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buildings and facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available under this section shall not be used for the construction of a new building or facility or the acquisition, expansion, remodeling, or alteration of an existing building or facility (including site grading and improvement and architect fees).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78bd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5937/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $7,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd78bd3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7525"},"text":"Pub. L. 110–234, title VII, § 7525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1273"},"text":"122 Stat. 1273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7525, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Sta