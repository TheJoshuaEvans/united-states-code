{"tag":"section","attrib":{"id":"idef8ffc0a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3102"},"text":null,"children":[{"tag":"num","attrib":{"value":"3102"},"text":"§ 3102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional purposes of agricultural research and extension","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef8ffc0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish firmly the Department of Agriculture as the lead agency in the Federal Government for the food and agricultural sciences, and to emphasize that agricultural research, extension, and teaching are distinct missions of the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffc0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" undertake the special measures set forth in this chapter to improve the coordination and planning of agricultural research, extension, and teaching programs, identify needs and establish priorities for these programs, assure that national agricultural research, extension, and teaching objectives are fully achieved, and assure that the results of agricultural research are effectively communicated and demonstrated to farmers, processors, handlers, consumers, and all other users who can benefit therefrom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffc0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase cooperation and coordination in the performance of agricultural research by Federal departments and agencies, the States, State agricultural experiment stations, colleges and universities, and user groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffc0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable the Federal Government, the States, colleges and universities, and others to implement needed agricultural research, extension, and teaching programs, through the establishment of new programs and the improvement of existing programs, as provided for in this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffc0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a new program of grants for high-priority agricultural research to be awarded on the basis of competition among research workers and all colleges and universities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffc10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a new program of grants for facilities and instrumentation used in agricultural research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef8ffc11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a new program of education grants and fellowships to strengthen research, extension, and teaching programs in the food and agricultural sciences, to be awarded on the basis of competition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8ffc12-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1403"},"text":"Pub. L. 95–113, title XIV, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/983"},"text":"91 Stat. 983","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1403"},"text":"Pub. L. 97–98, title XIV, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1296"},"text":"95 Stat. 1296","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1602/b"},"text":"Pub. L. 101–624, title XVI, § 1602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3705"},"text":"104 Stat. 3705","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8ffc13-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef8ffc14-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef8ffc15-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original this “title”, meaning title XIV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113"},"text":"Pub. L. 95–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/981"},"text":"91 Stat. 981","children":[],"tail":", which enacted this chapter and sections 2669 and 2670 of this title, amended sections 341, 342, 343, 361c, 390 to 390j, 1923, 1942, 2662, 2663, 2667, 3104, and 3157 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s6651"},"text":"section 6651 of Title 42","children":[],"tail":", The Public Health and Welfare, and repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s390k"},"text":"section 390k of this title","children":[],"tail":". For complete classification of such title to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3101"},"text":"section 3101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef924506-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section catchline generally."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1403/1"},"text":"Pub. L. 97–98, § 1403(1)","children":[],"tail":", inserted “extension, and teaching programs,” and substituted “these programs” for “such research, assure that high priority research is given adequate funding”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1403/2"},"text":"Pub. L. 97–98, § 1403(2)","children":[],"tail":", substituted “programs through” for “programs, including the initiatives specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3101/8"},"text":"section 3101(8) of this title","children":[],"tail":", through”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1403/3"},"text":"Pub. L. 97–98, § 1403(3)","children":[],"tail":", substituted “among research workers” for “among scientific research workers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1403/4"},"text":"Pub. L. 97–98, § 1403(4)","children":[],"tail":", substituted “research, extension, and teaching” for “training and research”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef924507-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef924508-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef924509-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
