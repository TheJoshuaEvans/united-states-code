{"tag":"section","attrib":{"id":"ideffdb1dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7218"},"text":null,"children":[{"tag":"num","attrib":{"value":"7218"},"text":"§ 7218.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planting flexibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffdb1dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7218/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted crops","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), any commodity or crop may be planted on contract acreage on a farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb1de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7218/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations and exceptions regarding fruits and vegetables","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffdb1df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7218/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The planting of fruits and vegetables (other than lentils, mung beans, and dry peas) shall be prohibited on contract acreage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb1e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7218/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall not limit the planting of a fruit or vegetable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffdb1e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7218/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any region in which there is a history of double-cropping of contract commodities with fruits or vegetables, as determined by the Secretary, in which case the double-cropping shall be permitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffdb1e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7218/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a farm that the Secretary determines has a history of planting fruits or vegetables on contract acreage, except that a contract payment shall be reduced by an acre for each acre planted to the fruit or vegetable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffdb1e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7218/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by a producer who the Secretary determines has an established planting history of a specific fruit or vegetable, except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideffdb1e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7218/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity planted may not exceed the producer’s average annual planting history of the fruit or vegetable in the 1991 through 1995 crop years (excluding any crop year in which no plantings were made), as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideffdb1e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7218/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract payment shall be reduced by an acre for each acre planted to the fruit or vegetable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffdb1e6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s118"},"text":"Pub. L. 104–127, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/904"},"text":"110 Stat. 904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideffdb1e7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideffdb1e8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideffdb1e9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Contract Payments for Wild Rice Acreage","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78/tVII/s727"},"text":"Pub. L. 106–78, title VII, § 727","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1164"},"text":"113 Stat. 1164","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/78/tVII/s727"},"text":"“None of the funds appropriated or otherwise available to the Department of Agriculture in fiscal year 2000 or thereafter may be used to administer the provision of contract payments to a producer under the Agricultural Market Transition Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7201"},"text":"7 U.S.C. 7201","children":[],"tail":" et seq.) for contract acreage on which wild rice is planted unless the contract payment is reduced by an acre for each contract acre planted to wild rice.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriations acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/a/tVII/s727"},"text":"Pub. L. 105–277, div. A, § 101(a) [title VII, § 727]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681"},"text":"112 Stat. 2681","children":[],"tail":", 2681–28."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/86/tVII/s734"},"text":"Pub. L. 105–86, title VII, § 734","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2110"},"text":"111 Stat. 2110","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
