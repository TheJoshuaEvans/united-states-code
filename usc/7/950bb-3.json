{"tag":"section","attrib":{"id":"idee65d2e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"950bb–3"},"text":"§ 950bb–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Community Connect Grant Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee65d2e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d2e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible broadband service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible broadband service” means broadband service that has the capability to transmit data at a speed specified by the Secretary, which may not be less than the applicable minimum download and upload speeds established by the Federal Communications Commission in defining the term “advanced telecommunications capability” for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s1302"},"text":"section 1302 of title 47","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d2e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible service area","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible service area” means an area in which broadband service capacity is less than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d2e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 10-Mbps downstream transmission capacity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d2e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a 1-Mbps upstream transmission capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d2e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d2e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means a legally organized entity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee65d2e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idee65d2e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an incorporated organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idee65d2ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe or Tribal organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idee65d2eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/3/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idee65d2ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/3/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idee65d2ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/3/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other legal entity, including a cooperative, a private corporation, or a limited liability company, that is organized on a for-profit or a not-for-profit basis; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee65d2ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the legal capacity and authority to enter into a contract, to comply with applicable Federal laws, and to own and operate broadband facilities, as proposed in the application submitted by the entity for a grant under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d2ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee65d2f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee65d2f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d2f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “rural area” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s950bb/b/3/A"},"text":"section 950bb(b)(3)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d2f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program, to be known as the “Community Connect Grant Program”, to provide grants to eligible entities to finance broadband transmission in rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d2f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under the Program shall use the grant to carry out a project that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d2f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides eligible broadband service to, within the proposed eligible service area described in the application submitted by the eligible entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d2f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each essential community facility as defined pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926/a"},"text":"section 1926(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d2f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any required facilities necessary to offer that eligible broadband service to each residential and business customer within such proposed eligible service area; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d2f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for not less than 2 years—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d2f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnishes free eligible broadband service to a community center described in subsection (d)(1)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d2fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides not fewer than 2 computer access points for that free eligible broadband service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d2fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covers the cost of bandwidth to provide free eligible broadband service to each essential community facility that requests broadband services within the proposed eligible service area described in the application submitted by the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d2fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of grant funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d2fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under the Program may use the grant for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d2fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction, acquisition, or leasing of facilities (including spectrum), land, or buildings to deploy eligible broadband service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d2ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement, expansion, construction, or acquisition of a community center within the proposed eligible service area described in the application submitted by the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d300-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligible uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity that receives a grant under the Program shall not use the grant for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d301-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duplication of any existing eligible broadband service provided by another entity in the eligible service area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d302-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" operating expenses, except as provided in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee65d303-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (c)(2)(C) with respect to free eligible broadband service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee65d304-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1)(A) with respect to spectrum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d305-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Free access for community centers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts provided to an eligible entity under a grant under the Program, the eligible entity shall use to carry out paragraph (1)(B) not greater than the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d306-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d307-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d308-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d309-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An eligible entity that receives a grant under the Program shall provide a cash contribution in an amount that is not less than 15 percent of the amount of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d30a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A cash contribution described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee65d30b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used solely for the project for which the eligible entity receives a grant under the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee65d30c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not include any Federal funds, unless a Federal statute specifically provides that those Federal funds may be considered to be from a non-Federal source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d30d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee65d30e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a grant under the Program, an eligible entity shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee65d30f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An application submitted by an eligible entity under paragraph (1) shall include documentation sufficient to demonstrate the availability of funds to satisfy the requirement of subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee65d310-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950bb–3/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $50,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee65d311-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title VI, § 604, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6204"},"text":"Pub. L. 115–334, title VI, § 6204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4737"},"text":"132 Stat. 4737","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
