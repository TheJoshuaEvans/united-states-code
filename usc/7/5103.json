{"tag":"section","attrib":{"id":"idefc478a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5103"},"text":null,"children":[{"tag":"num","attrib":{"value":"5103"},"text":"§ 5103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation of Federal agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefc478aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Secretary of Agriculture","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc478ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, with respect to each program or agency under the jurisdiction of the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc478ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5103/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall prescribe rules requiring each such program or agency to participate in good faith in any State mediation program certified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5101"},"text":"section 5101 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc478ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5103/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall participate in mediation programs certified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5101"},"text":"section 5101 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc478ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5103/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefc478af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5103/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate in good faith with requests for information or analysis of information made in the course of mediation under any mediation program certified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5101"},"text":"section 5101 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc478b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5103/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, present and explore debt restructuring proposals advanced in the course of such mediation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonbinding on Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not be bound by any determination made in a program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5101"},"text":"section 5101 of this title","children":[],"tail":" if the Secretary has not agreed to such determination."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc478b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Farm Credit Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Farm Credit Administration shall prescribe rules requiring the institutions of the Farm Credit System—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc478b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cooperate in good faith with requests for information or analysis of information made in the course of mediation under any mediation program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5101"},"text":"section 5101 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to present and explore debt restructuring proposals advanced in the course of such mediation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc478b5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/tV/s503"},"text":"Pub. L. 100–233, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1663"},"text":"101 Stat. 1663","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/399/