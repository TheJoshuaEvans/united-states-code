{"tag":"section","attrib":{"id":"idefe37388-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6413"},"text":null,"children":[{"tag":"num","attrib":{"value":"6413"},"text":"§ 6413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement of initial referendum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe37389-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within the 60-day period immediately preceding the effective date of an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6405/a"},"text":"section 6405(a) of this title","children":[],"tail":", the Secretary shall conduct a referendum among fluid milk processors to ascertain whether the order shall go into effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe3738a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, as a result of the referendum conducted under subsection (a), the Secretary determines that implementation of the order is favored—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe3738b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6413/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by at least 50 percent of fluid milk processors voting in the referendum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe3738c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6413/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by fluid milk processors voting in the referendum that marketed during the representative period, as determined by the Secretary, 60 percent or more of the volume of fluid milk products marketed by fluid milk processors voting in the referendum;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the order shall become effective as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6405/b"},"text":"section 6405(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe3738d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6413/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of referendum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall be reimbursed from any assessments collected by the Board for any expenses incurred by the Department in connection with the conduct of any referendum under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe3738e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6413/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe3738f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6413/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Referenda conducted pursuant to this chapter shall be conducted in a manner determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe37390-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6413/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A fluid milk processor who chooses to vote in any referendum conducted under this chapter shall register with the Secretary prior to the voting period, after receiving notice from the Secretary concerning the referendum under paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe37391-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6413/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A fluid milk processor who votes in any referendum conducted under this chapter shall vote in accordance with procedures established by the Secretary. The ballots and other information or reports that reveal or tend to reveal the vote of any processor shall be held strictly confidential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe37392-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6413/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify all processors at least 30 days prior to a referendum conducted under this chapter. The notice shall explain the procedure established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe37393-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1999N"},"text":"Pub. L. 101–624, title XIX, § 1999N","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3924"},"text":"104 Stat. 3924","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s146/d/1"},"text":"Pub. L. 104–127, title I, § 146(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/919"},"text":"110 Stat. 919","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe37394-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe37395-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe37396-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" substituted “fluid milk processors voting in the referendum;” for “all processors;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
