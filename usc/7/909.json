{"tag":"section","attrib":{"id":"idee59ec37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s909"},"text":null,"children":[{"tag":"num","attrib":{"value":"909"},"text":"§ 909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration on nonpolitical basis; dismissal of officers or employees for violating provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall be administered entirely on a nonpartisan basis, and in the appointment of officials, the selection of employees, and in the promotion of any such officials or employees, no political test or qualification shall be permitted or given consideration, but all such appointments and promotions shall be given and made on the basis of merit and efficiency. If the Secretary herein provided for is found by the President of the United States to be guilty of a violation of this section, he shall be removed from office by the President, and any appointee or selection of officials or employees made by the Secretary who is found guilty of a violation of this chapter shall be removed by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee59ec38-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title I, § 9, "},{"tag":"ref","attrib":{"href":"/us/stat/49/1366"},"text":"49 Stat. 1366","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-10-28/ch776/s2"},"text":"Oct. 28, 1949, ch. 776, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/948"},"text":"63 Stat. 948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/13"},"text":"Pub. L. 103–354, title II, § 235(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee59ec39-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee59ec3a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee59ec3b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-10-28"},"text":"Oct. 28, 1949","children":[],"tail":", inserted “title I,” in credit of act "},{"tag":"date","attrib":{"date":"1936-05-20"},"text":"May 20, 1936","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
