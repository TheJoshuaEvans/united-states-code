{"tag":"section","attrib":{"id":"idee256e7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s322"},"text":null,"children":[{"tag":"num","attrib":{"value":"322"},"text":"§ 322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is annually appropriated, out of any money in the Treasury not otherwise appropriated, to be paid as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s324"},"text":"section 324 of this title","children":[],"tail":", to each State and Territory for the more complete endowment and maintenance of colleges for the benefit of agriculture and the mechanic arts established in accordance with the provisions of subchapter I of this chapter, $50,000 to be applied only to instruction in food and agricultural sciences, and to the facilities for such instruction: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That said colleges may use a portion of this money for providing courses for the special preparation of instructors for teaching the elements of food and agricultural sciences."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee256e7c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1890-08-30/ch841/s1"},"text":"Aug. 30, 1890, ch. 841, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/26/417"},"text":"26 Stat. 417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-04/ch2907"},"text":"Mar. 4, 1907, ch. 2907","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1281"},"text":"34 Stat. 1281","children":[],"tail":", 1282; "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1421"},"text":"Pub. L. 97–98, title XIV, § 1421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1306"},"text":"95 Stat. 1306","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee256e7d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee256e7e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee256e7f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on a part of section 1 of act ","children":[{"tag":"date","attrib":{"date":"1890-08-30"},"text":"Aug. 30, 1890","children":[],"tail":", and the tenth and eleventh pars. under the heading “Emergency Appropriations” of act "},{"tag":"date","attrib":{"date":"1907-03-04"},"text":"Mar. 4, 1907","children":[],"tail":". Remainder of section 1 of act "},{"tag":"date","attrib":{"date":"1890-08-30"},"text":"Aug. 30, 1890","children":[],"tail":", is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s323"},"text":"section 323 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee256e80-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" substituted “food and agricultural sciences” for “agriculture, the mechanic arts, the English language, and the various branches of mathematical, physical, natural, and economic science, with special reference to their applications in the industries of life” and “the elements of food and agricultural sciences” for “the elements of agriculture and the mechanic arts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1907—Act ","children":[{"tag":"date","attrib":{"date":"1907-03-04"},"text":"Mar. 4, 1907","children":[],"tail":", substituted “$50,000” for “$25,000”, and inserted proviso."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee256e81-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee256e82-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idee256e83-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions under this section to Secretary of Agriculture, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idee256e84-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Funds for Payments Under This Subchapter","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/330/tVII/s724"},"text":"Pub. L. 103–330, title VII, § 724","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2469"},"text":"108 Stat. 2469","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/330/tVII/s724"},"text":"“No funds shall be available in fiscal year 1995 and thereafter for payments under the Act of ","children":[{"tag":"date","attrib":{"date":"1890-08-30"},"text":"August 30, 1890","children":[],"tail":" and the tenth and eleventh paragraphs under the heading ‘Emergency Appropriations’ of the Act of "},{"tag":"date","attrib":{"date":"1907-03-04"},"text":"March 4, 1907","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s321"},"text":"7 U.S.C. 321","children":[],"tail":" et seq.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
