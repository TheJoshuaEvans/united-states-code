{"tag":"section","attrib":{"id":"idf04eb773-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9052"},"text":null,"children":[{"tag":"num","attrib":{"value":"9052"},"text":"§ 9052.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of average feed cost and actual dairy production margins","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf04eb774-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9052/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of average feed cost","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall calculate the national average feed cost for each month using the following data:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb775-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9052/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The price of corn for a month shall be the price received during that month by farmers in the United States for corn, as reported in the monthly Agricultural Prices report by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb776-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9052/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The price of soybean meal for a month shall be the central Illinois price for soybean meal, as reported in the Market News–Monthly Soybean Meal Price Report by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb777-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9052/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The price of alfalfa hay for a month shall be the price received during that month by farmers in the United States for alfalfa hay, as reported in the monthly Agricultural Prices report by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf04eb778-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9052/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation of actual dairy production margin","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb779-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9052/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For use in dairy margin coverage, the Secretary shall calculate the actual dairy production margin for each month by subtracting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04eb77a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9052/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average feed cost for that month, determined in accordance with subsection (a); from","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb77b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9052/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the all-milk price for that month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb77c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9052/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for calculation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The calculation required by this subsection shall be made as soon as practicable using the full-month price of the applicable reference month.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04eb77d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1402"},"text":"Pub. L. 113–79, title I, § 1402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/689"},"text":"128 Stat. 689","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dF/s60101/b/1/B"},"text":"Pub. L. 115–123, div. F, § 60101(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/311"},"text":"132 Stat. 311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1401/k/3"},"text":"Pub. L. 115–334, title I, § 1401(k)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4516"},"text":"132 Stat. 4516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04eb77e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04eb77f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04eb780-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “dairy margin coverage” for “the margin protection program” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" substituted “month” for “consecutive 2-month period” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf04eb781-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf04eb782-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"2019-01-01"},"text":"Jan. 1, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/m"},"text":"section 1401(m) of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9051"},"text":"section 9051 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" applicable beginning with the 2018 calendar year, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/b/5"},"text":"section 60101(b)(5) of Pub. L. 115–123","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9051"},"text":"section 9051 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf04eb783-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Collection of Alfalfa Hay Data","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1401/c"},"text":"Pub. L. 115–334, title I, § 1401(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4512"},"text":"132 Stat. 4512","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tI/s1401/c"},"text":"“Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":"], the Secretary [of Agriculture], acting through the National Agricultural Statistics Service, shall revise monthly price survey reports to include prices for high-quality alfalfa hay in the top five milk producing States, as measured by volume of milk produced during the previous month.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
