{"tag":"section","attrib":{"id":"idef6c1ff4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2144"},"text":null,"children":[{"tag":"num","attrib":{"value":"2144"},"text":"§ 2144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Humane standards for animals by United States Government facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any department, agency, or instrumentality of the United States having laboratory animal facilities shall comply with the standards and other requirements promulgated by the Secretary for a research facility under sections ","children":[{"tag":"ref","attrib":{"idref":"fn002247"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002247"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section”."}],"tail":" 2143(a), (f), (g), and (h) of this title. Any department, agency, or instrumentality of the United States exhibiting animals shall comply with the standards promulgated by the Secretary under sections "},{"tag":"ref","attrib":{"idref":"fn002247"},"text":"1","children":[],"tail":" 2143(a), (f), (g), and (h) of this title."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef6c1ff5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/544/s14"},"text":"Pub. L. 89–544, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-08-24"},"text":"Aug. 24, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/352"},"text":"80 Stat. 352","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/579/s15"},"text":"Pub. L. 91–579, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1563"},"text":"84 Stat. 1563","children":[],"tail