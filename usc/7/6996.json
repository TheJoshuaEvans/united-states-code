{"tag":"section","attrib":{"id":"ideff8cf40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6996"},"text":null,"children":[{"tag":"num","attrib":{"value":"6996"},"text":"§ 6996.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right of participants to Division hearing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff8cf41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6996/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeal to Division for hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), a participant shall have the right to appeal an adverse decision to the Division for an evidentiary hearing by a hearing officer consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6997"},"text":"section 6997 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff8cf42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6996/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for appeal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be entitled to a hearing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6997"},"text":"section 6997 of this title","children":[],"tail":", a participant shall request the hearing not later than 30 days after the date on which the participant first received notice of the adverse decision."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff8cf43-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s276"},"text":"Pub. L. 103–354, title II, § 276","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3230"},"text":"108 Stat. 3230","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
