{"tag":"section","attrib":{"id":"idef6e902a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148"},"text":null,"children":[{"tag":"num","attrib":{"value":"2148"},"text":"§ 2148.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importation of live dogs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef6e902b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef6e902c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “importer” means any person who, for purposes of resale, transports into the United States puppies from a foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e902d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resale","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “resale” includes any transfer of ownership or control of an imported dog of less than 6 months of age to another person, for more than de minimis consideration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef6e902e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef6e902f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), no person shall import a dog into the United States for purposes of resale unless, as determined by the Secretary, the dog—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef6e9030-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in good health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef6e9031-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has received all necessary vaccinations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef6e9032-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least 6 months of age, if imported for resale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e9033-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef6e9034-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, by regulation, shall provide an exception to any requirement under paragraph (1) in any case in which a dog is imported for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef6e9035-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef6e9036-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterinary treatment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef6e9037-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lawful importation into Hawaii","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1)(C) shall not apply to the lawful importation of a dog into the State of Hawaii from the British Isles, Australia, Guam, or New Zealand in compliance with the applicable regulations of the State of Hawaii and the other requirements of this section, if the dog is not transported out of the State of Hawaii for purposes of resale at less than 6 months of age.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef6e9038-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, the Secretary of Health and Human Services, the Secretary of Commerce, and the Secretary of Homeland Security shall promulgate such regulations as the Secretaries determine to be necessary to implement and enforce this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef6e9039-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An importer that fails to comply with this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef6e903a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to penalties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2149"},"text":"section 2149 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef6e903b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2148/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the care (including appropriate veterinary care), forfeiture, and adoption of each applicable dog, at the expense of the importer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef6e903c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/544/s18"},"text":"Pub. L. 89–544, § 18","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14210/a"},"text":"Pub. L. 110–234, title XIV, § 14210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1464"},"text":"122 Stat. 1464","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14210(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2226.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef6e903d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef6e903e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef6e903f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"