{"tag":"section","attrib":{"id":"ideff1a468-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6925"},"text":null,"children":[{"tag":"num","attrib":{"value":"6925"},"text":"§ 6925.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food Access Liaison","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff1a469-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6925/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish the position of Food Access Liaison to coordinate Department programs to reduce barriers to food access and monitor and evaluate the progress of such programs in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff1a46a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6925/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Food Access Liaison shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff1a46b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6925/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the efforts of the Department, including regional offices, to experiment and consider programs and policies aimed at reducing barriers to food access for consumers, including but not limited to participants in nutrition assistance programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a46c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6925/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide outreach to entities engaged in activities to reduce barriers to food access in accordance with the statutory authorization for each program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a46d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6925/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide outreach to entities engaged in activities to reduce barriers to food access, including retailers, markets, producers, and others involved in food production and distribution, with respect to the availability of, and eligibility for, Department programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a46e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6925/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" raise awareness of food access issues in interactions with employees of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a46f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6925/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Secretary with respect to efforts to reduce barriers to food access; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff1a470-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6925/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress an annual report with respect to the efforts of the Department to reduce barriers to food access.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff1a471-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s225"},"text":"Pub. L. 103–354, title II, § 225","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12614/a"},"text":"Pub. L. 115–334, title XII, § 12614(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5014"},"text":"132 Stat. 5014","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff1a472-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff1a473-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideff1a474-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/s225"},"text":"section 225 of Pub. L. 103–354","children":[],"tail":" is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6931"},"text":"section 6931 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideff1a475-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideff1a476-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Technical Assistance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12614/b"},"text":"Pub. L. 115–334, title XII, § 12614(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5014"},"text":"132 Stat. 5014","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tXII/s12614/b"},"text":"“The Secretary [of Agriculture] shall provide technical assistance to entities that are participants, or seek to participate, in Department of Agriculture programs related to reduction of barriers to food access.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
