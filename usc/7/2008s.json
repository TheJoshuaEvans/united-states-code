{"tag":"section","attrib":{"id":"idef2700c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008s"},"text":"§ 2008s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural microentrepreneur assistance program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef2700c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2700c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2700c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Microentrepreneur","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “microentrepreneur” means an owner and operator, or prospective owner and operator, of a rural microenterprise who is unable to obtain sufficient training, technical assistance, or credit other than under this section, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2700c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Microenterprise development organization","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “microenterprise development organization” means an organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2700ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2700cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2700cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an Indian tribe, the tribal government of which certifies to the Secretary that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef2700cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no microenterprise development organization serves the Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef2700ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no rural microentrepreneur assistance program exists under the jurisdiction of the Indian tribe; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2700cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2700d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides training and technical assistance to rural microentrepreneurs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2700d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitates access to capital or another service described in subsection (b) for rural microenterprises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2700d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a demonstrated record of delivering services to rural microentrepreneurs, or an effective plan to develop a program to deliver services to rural microentrepreneurs, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2700d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Microloan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “microloan” means a business loan of not more than $50,000 that is provided to a rural microenterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2700d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “program” means the rural microentrepreneur assistance program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2700d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural microenterprise","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “rural microenterprise” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2700d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sole proprietorship located in a rural area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2700d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a business entity with not more than 10 full-time-equivalent employees located in a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2700d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural microentrepreneur assistance program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2700d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a rural microentrepreneur assistance program to provide loans and grants to support microentrepreneurs in the development and ongoing success of rural microenterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2700da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the program is to provide microentrepreneurs with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2700db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the skills necessary to establish new rural microenterprises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2700dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing technical and financial assistance related to the successful operation of rural microenterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2700dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2700de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make loans to microenterprise development organizations for the purpose of providing fixed interest rate microloans to microentrepreneurs for startup and growing rural microenterprises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2700df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A loan made by the Secretary to a microenterprise development organization under this paragraph shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2700e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be for a term not to exceed 20 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2700e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bear an annual interest rate of at least 1 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2700e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan loss reserve fund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require each microenterprise development organization that receives a loan under this paragraph to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2700e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a loan loss reserve fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2700e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the reserve fund in an amount equal to at least 5 percent of the outstanding balance of such loans owed by the microenterprise development organization, until all obligations owed to the Secretary under this paragraph are repaid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2700e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferral of interest and principal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may permit the deferral of payments on principal and interest due on a loan to a microenterprise development organization made under this paragraph for a 2-year period beginning on the date the loan is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2700e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2700e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to support rural microenterprise development","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2700e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make grants to microenterprise development organizations to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef2700e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide training, operational support, business planning, and market development assistance, and other related services to rural microentrepreneurs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef2700ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such other projects and activities as the Secretary determines appropriate to further the purposes of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2700eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under clause (i), the Secretary shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef2700ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place an emphasis on microenterprise development organizations that serve microentrepreneurs that are located in rural areas that have suffered significant outward migration, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef2700ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure, to the maximum extent practicable, that grant recipients include microenterprise development organizations—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idef2700ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/A/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of varying sizes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idef2700ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/A/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that serve racially and ethnically diverse populations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2700f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to assist microentrepreneurs","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2700f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make grants to microenterprise development organizations to provide marketing, management, and other technical assistance to microentrepreneurs that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef2700f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received a loan from the microenterprise development organization under paragraph (3); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef2700f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are seeking a loan from the microenterprise development organization under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2700f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount of grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A microenterprise development organization shall be eligible to receive an annual grant under this subparagraph in an amount equal to not less than 20 percent and not more than 25 percent of the total outstanding balance of microloans made by the microenterprise development organization under paragraph (3), as of the date the grant is awarded, subject to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idef2700f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfactory performance by the microenterprise development organization under this section, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef2700f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2700f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 10 percent of a grant received by a microenterprise development organization for a fiscal year under this paragraph may be used to pay administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2700f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2700f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost share","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2700fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), the Federal share of the cost of a project funded under this section shall not exceed 75 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2700fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of any grant made under this subparagraph, the Secretary shall require the microenterprise development organization to match not less than 15 percent of the total amount of the grant in the form of matching funds, indirect costs, or in-kind goods or services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2700fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form of non-Federal share","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The non-Federal share of the cost of a project funded under this section may be provided—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef2700fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cash (including through fees, grants (including community development block grants), and gifts); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2700fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the form of in-kind contributions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2700ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At a minimum, not later than December 1 of each fiscal year, a microenterprise development organization that receives a loan or grant under this section shall provide to the Secretary such information as the Secretary may require to ensure that assistance provided under this section is used for the purposes for which the loan or grant was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef270100-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008s/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section $20,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef270101-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s379E"},"text":"Pub. L. 87–128, title III, § 379E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6022"},"text":"Pub. L. 110–234, title VI, § 6022","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1173"},"text":"122 Stat. 1173","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6022, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1934; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVI/s6023"},"text":"Pub. L. 113–79, title VI, § 6023","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/848"},"text":"128 Stat. 848","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6422"},"text":"Pub. L. 115–334, title VI, § 6422","children":[]