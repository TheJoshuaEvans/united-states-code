{"tag":"section","attrib":{"id":"idee89aee5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"1359aa"},"text":"§ 1359aa.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subpart:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee89aee6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Human consumption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “human consumption”, when used in the context of a reference to sugar (whether in the form of sugar, in-process sugar, syrup, molasses, or in some other form) for human consumption, includes sugar for use in human food, beverages, or similar products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89aee7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mainland State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “mainland State” means a State other than an offshore State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89aee8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Market","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee89aee9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “market” means to sell or otherwise dispose of in commerce in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89aeea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “market” includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee89aeeb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the forfeiture of sugar under the loan program for sugar established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272"},"text":"section 7272 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee89aeec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any integrated processor and refiner, the movement of raw cane sugar into the refining process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee89aeed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of sugar for the production of ethanol or other bioenergy product, if the disposition of the sugar is administered by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8110"},"text":"section 8110 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89aeee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Marketing year","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Forfeited sugar described in subparagraph (B)(i) shall be considered to have been marketed during the crop year for which a loan is made under the loan program described in that subparagraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89aeef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Offshore State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “offshore State” means a sugarcane producing State located outside of the continental United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89aef0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1301"},"text":"section 1301 of this title","children":[],"tail":", the term “State” means—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee89aef1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89aef2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee89aef3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee89aef4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1359aa/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States”, when used in a geographical sense, means all of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee89aef5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 359a, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1403"},"text":"Pub. L. 107–171, title I, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/187"},"text":"116 Stat. 187","children":[],"tail":"; amended "},{"tag