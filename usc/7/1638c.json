{"tag":"section","attrib":{"id":"ideedf709e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638c"},"text":null,"children":[{"tag":"num","attrib":{"value":"1638c"},"text":"§ 1638c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedf709f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2002-09-30"},"text":"September 30, 2002","children":[],"tail":", the Secretary shall issue guidelines for the voluntary country of origin labeling of covered commodities based on the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1638a"},"text":"section 1638a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf70a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2004-09-30"},"text":"September 30, 2004","children":[],"tail":", the Secretary shall promulgate such regulations as are necessary to implement this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf70a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1638c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partnerships with States"