{"tag":"section","attrib":{"id":"idef69d63d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2122"},"text":null,"children":[{"tag":"num","attrib":{"value":"2122"},"text":"§ 2122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations for cotton ginning studies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2121"},"text":"section 2121 of this title","children":[],"tail":" there is authorized to be appropriated, after "},{"tag":"date","attrib":{"date":"1931-06-30"},"text":"June 30, 1931","children":[],"tail":", out of any money in the Treasury not otherwise appropriated, such sums as may be necessary."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef69d63e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-04-19/ch203/s2"},"text":"Apr. 19, 1930, ch. 203, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/248"},"text":"46 Stat. 248","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef69d63f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef69d640-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef69d641-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s425"},"text":"section 425 of this title","children":[],"tail":" prior to editorial reclassification and renumbering as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1930-04-19/ch203"},"text":"act Apr. 19, 1930, ch. 203","children":[],"tail":", and not as part of the Cotton Research and Promotion Act which comprises this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
