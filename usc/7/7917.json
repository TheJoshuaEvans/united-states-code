{"tag":"section","attrib":{"id":"idf0262040-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7917"},"text":null,"children":[{"tag":"num","attrib":{"value":"7917"},"text":"§ 7917.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to remaining payment authority under production flexibility contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0262041-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7917/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of superseded payment authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7213/a/7"},"text":"section 7213(a)(7) of this title","children":[],"tail":" or any other provision of law, the Secretary shall not make payments for fiscal year 2002 after "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", under a production flexibility contract entered into under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7211"},"text":"section 7211 of this title","children":[],"tail":" unless requested by the producer that is a party to the contract."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0262042-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7917/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract payments made before enactment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a producer receives all or any portion of the payment authorized for fiscal year 2002 under a production flexibility contract, the Secretary shall reduce the amount of the direct payment otherwise due the producer for the 2002 crop year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7913"},"text":"section 7913 of this title","children":[],"tail":" by the amount of the fiscal year 2002 payment received by the producer under the production flexibility contract."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0262043-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tI/s1107"},"text":"Pub. L. 107–171, title I, § 1107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/154"},"text":"116 Stat. 154","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
