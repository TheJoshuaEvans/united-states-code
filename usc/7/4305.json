{"tag":"section","attrib":{"id":"idefb3afdc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4305"},"text":null,"children":[{"tag":"num","attrib":{"value":"4305"},"text":"§ 4305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding and issuance of orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for hearing as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4304"},"text":"section 4304 of this title","children":[],"tail":", the Secretary shall issue an order if the Secretary finds, and sets forth in such order, upon the evidence introduced at such hearing, that the issuance of such order and all the terms and conditions thereof will tend to effectuate the declared policy of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefb3afdd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXVII/s1706"},"text":"Pub. L. 97–98, title XVII, § 1706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1350"},"text":"95 Stat. 1350","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
