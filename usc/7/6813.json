{"tag":"section","attrib":{"id":"idefef5a0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6813"},"text":null,"children":[{"tag":"num","attrib":{"value":"6813"},"text":"§ 6813.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may issue such regulations as are necessary to carry out this chapter and the powers vested in the Secretary by this chapter, including regulations relating to the assessment of late payment charges and interest.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefef5a0c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/190/s14"},"text":"Pub. L. 103–190, § 14","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2289"},"text":"107 Stat. 2289","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
