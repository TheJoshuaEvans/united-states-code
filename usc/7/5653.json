{"tag":"section","attrib":{"id":"idefcb7db7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5653"},"text":null,"children":[{"tag":"num","attrib":{"value":"5653"},"text":"§ 5653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable treatment of high-value and value-added United States agricultural commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the case of any program operated by the Secretary or the Commodity Credit Corporation during the fiscal years 1991 through 1995, for the purpose of discouraging unfair trade practices, the Secretary shall establish as an objective to expend annually at least 25 percent of the total funds available (or 25 percent of the value of any commodities employed) for program activities involving the export sales of high-value agricultural commodities and value-added products of United States agricultural commodities.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefcb7db8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tIII/s302"},"text":"Pub. L. 95–501, title III, § 302","children":[],"tail":", formerly § 303, as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3680"},"text":"104 Stat. 3680","children":[],"tail":"; renumbered § 302 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/tIII/s3103/b/2"},"text":"Pub. L. 110–246, title III, § 3103(b)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1832"},"text":"122 Stat. 1832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"t