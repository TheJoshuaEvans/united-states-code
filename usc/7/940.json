{"tag":"section","attrib":{"id":"idee61184d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s940"},"text":null,"children":[{"tag":"num","attrib":{"value":"940"},"text":"§ 940.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refinancing of rural development loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"At the request of the borrower, the Secretary is authorized and directed to refinance with loans which will be insured under this chapter at the interest rates provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s935"},"text":"section 935 of this title","children":[],"tail":" any loans made for rural electric and telephone facilities under any provision of the Consolidated Farm and Rural Development Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"7 U.S.C. 1921","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee61184e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title III, § 310, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/32/s2"},"text":"Pub. L. 93–32, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-11"},"text":"May 11, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/70"},"text":"87 Stat. 70","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/13"},"text":"Pub. L. 103–354, title II, § 235(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee61184f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role