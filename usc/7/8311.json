{"tag":"section","attrib":{"id":"idf036e9c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311"},"text":null,"children":[{"tag":"num","attrib":{"value":"8311"},"text":"§ 8311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursable agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf036e9c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to enter into agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into reimbursable fee agreements with persons for preclearance of animals or articles at locations outside the United States for movement into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf036e9c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds collected for preclearance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds collected for preclearance activities—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036e9c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be collected in advance of the provision of such activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e9c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited as offsetting collections to the currently applicable appropriation, account, or fund of U.S. Customs and Border Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e9c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain available until expended;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e9c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be available for the purposes for which such appropriation, account, or fund is authorized to be used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e9c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be collected and shall be available only to the extent provided in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf036e9c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036e9ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other law, the Secretary may pay an officer or employee of the Department of Agriculture performing services under this chapter relating to imports into and exports from the United States for all overtime, night, or holiday work performed by the officer or employee at a rate of pay determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e9cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf036e9cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require a person for whom the services are performed to reimburse the Secretary for any expenses paid by the Secretary for the services under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e9cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All funds collected under this subsection shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf036e9ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be credited to the account that incurs the costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf036e9cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended, without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf036e9d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Late payment penalties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036e9d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On failure by a person to reimburse the Secretary in accordance with this section, the Secretary may assess a late payment penalty against the person, including interest on overdue funds, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3717"},"text":"section 3717 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e9d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any late payment penalty and any accrued interest shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf036e9d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be credited to the account that incurs the costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf036e9d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8311/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended, without fiscal year limitation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf036e9d5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10412"},"text":"Pub. L. 107–171, title X, § 10412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/503"},"text":"116 Stat. 503","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s818/b"},"text":"Pub. L. 114–125, title VIII, § 818(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/222"},"text":"130 Stat. 222","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf036e9d6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf036e9d7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf036e9d8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (c)(1), was in the original “this subtitle”, meaning subtitle E (§§ 10401–10418) of title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/494"},"text":"116 Stat. 494","children":[],"tail":", which is classified principally to this chapter. For complete classification of subtitle E to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8301"},"text":"section 8301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf036e9d9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125"},"text":"Pub. L. 114–125","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, text read as follows: “Funds collected for preclearance activities shall—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) be credited to accounts that may be established by the Secretary for carrying out this section; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) remain available until expended for the preclearance activities, without fiscal year limitation.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf036e9da-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf036e9db-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of the Secretary of Agriculture relating to agricultural import and entry inspection activities under this chapter to the Secretary of Homeland Security, and for treatment of related references, see sections 231, 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
