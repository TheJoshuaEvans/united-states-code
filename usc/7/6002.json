{"tag":"section","attrib":{"id":"idefd9d5a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002"},"text":null,"children":[{"tag":"num","attrib":{"value":"6002"},"text":"§ 6002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd9d5a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Board” means the Pecan Marketing Board established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6005/b"},"text":"section 6005(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “commerce” means interstate, foreign, or intrastate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5a5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “conflict of interest” means a situation in which a member has a direct or indirect financial interest in a corporation, partnership, sole proprietorship, joint venture, or other business entity dealing directly or indirectly with the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “consumer information” means information and programs that will assist consumers and other persons in making evaluations and decisions regarding the purchase, preparation, and use of pecans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Department” means the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" District","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “district” means a geographical area of the United States, as determined by the Board and approved by the Secretary, in which there is produced approximately one-fourth of the volume of pecans produced in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First handler","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “first handler” means the first person who buys or takes possession of pecans from a grower for marketing. If a grower markets pecans directly to consumers, such grower shall be considered the first handler with respect to pecans grown by such grower.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grower","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “grower” means any person engaged in the production and sale of pecans in the United States who owns, or who shares the ownership and risk of loss of, such pecans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grower-sheller","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “grower-sheller” means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd9d5ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shells pecans, or has pecans shelled for such person, in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd9d5ad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the immediately previous year, grew 50 percent or more of the pecans such person shelled or had shelled for such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5ae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “handle” means receipt of in-shell pecans by a sheller or first handler, including pecans produced by such sheller or first handler.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5af-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “importer” means any person who imports pecans from outside of the United States for sale in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5b0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Industry information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “industry information” means information and programs that will lead to the development of new markets and marketing strategies, increased efficiency, and activities to enhance the image of the pecan industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5b1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In-shell pecan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “in-shell pecan” means a pecan that has a shell that has not been removed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" To market","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “to market” means to sell or offer to dispose of pecans in any channel of commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “member” means a member of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pecan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “pecan” means the nut of the pecan tree carya illinoensis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5b5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Person","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “person” means any individual, group of individuals, partnership, corporation, association, cooperative, or any other entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5b6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “plan” means a plan issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6003"},"text":"section 6003 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5b7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “promotion” means any action taken by the Board, pursuant to this chapter, to present a favorable image of pecans to the public with the express intent of improving the competitive position of pecans in the marketplace and stimulating sales of pecans, including paid advertising.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5b8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “research” means any type of test, study, or analysis designed to advance the image, desirability, usage, marketability, production, product development, or quality of pecans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5b9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shell","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “shell” means to remove the shell from an in-shell pecan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shelled pecan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “shelled pecan” means a pecan kernel, or portion of a kernel, after the pecan shell has been removed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"(24)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sheller","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “sheller” means any person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd9d5bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/24/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shells pecans or has pecans shelled for the account of such person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd9d5be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/24/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the immediately previous year, purchased more than 50 percent of the pecans such person shelled or had shelled for such account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/25"},"text":null,"children":[{"tag":"num","attrib":{"value":"25"},"text":"(25)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “State” means any of the several States, the District of Columbia and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd9d5c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6002/26"},"text":null,"children":[{"tag":"num","attrib":{"value":"26"},"text":"(26)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States” means collectively the several States, the District of Columbia, and the Commonwealth of Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd9d5c1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1907"},"text":"Pub. L. 101–624, title XIX, § 1907","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3839"},"text":"104 Stat. 3839","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tVIII/s802/1"},"text":"Pub. L. 102–237, title VIII, § 802(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1882"},"text":"105 Stat. 1882","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefd9d5c2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefd9d5c3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefd9d5c4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Par. (22). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “in-shell” for “inshell”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
