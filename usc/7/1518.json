h30/tV/s518"},"text":"act Feb. 16, 1938, ch. 30, title V, § 518","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/77"},"text":"52 Stat. 77","children":[],"tail":", was transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1519"},"text":"section 1519 of this title","children":[],"tail":" at the time of the renumbering of such section 518 of act "},{"tag":"date","attrib":{"date":"1938-02-16"},"text":"Feb. 16, 1938","children":[],"tail":", as section 519 by "},{"tag":"ref","attrib":{"href":"/us/act/1941-06-21/ch214/s9"},"text":"act June 21, 1941, ch. 214, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/256"},"text":"55 Stat. 256","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideec7a1a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" inserted “hemp,” before “aquacultural species”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s12033/c/2/B"},"text":"Pub. L. 110–246, § 12033(c)(2)(B)","children":[],"tail":", substituted “this subchapter” for “this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224"},"text":"Pub. L. 106–224","children":[],"tail":" struck out “livestock and” before “stored grain” and “under subsection (a) or (m) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1508"},"text":"section 1508 of this title","children":[],"tail":"” after “by the Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “(m)” for “(k)” after “subsection (a) or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “subsection (a) or (k)” for “subsection (a) or (i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/365"},"text":"Pub. L. 96–365","children":[],"tail":" extended definition of “agricultural commodity” to include tomatoes, grain sorghum, sunflowers, raisins, oranges, sweet corn, dry peas, freezing and canning peas, forage, apples, grapes, nursery crops, and aquacultural species as illustrated but not limited, excluded livestock and stored grain, substituted “sugar cane” for “sugarcane”, and inserted reference to subsec. (i) of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1508"},"text":"section 1508 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1949—Act ","children":[{"tag":"date","attrib":{"date":"1949-08-25"},"text":"Aug. 25, 1949","children":[],"tail":", amended section to correct a clerical error in citation of “subsection (a) of section 1508”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1944—Act ","children":[{"tag":"date","attrib":{"date":"1944-12-23"},"text":"Dec. 23, 1944","children":[],"tail":", increased scope of definition of “agricultural commodity” from “wheat or cotton” to include all crops now set out."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideec7a1a6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideec7a1a7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amen