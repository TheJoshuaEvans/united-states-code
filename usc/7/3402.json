{"tag":"section","attrib":{"id":"idefac8466-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3402"},"text":null,"children":[{"tag":"num","attrib":{"value":"3402"},"text":"§ 3402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefac8467-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “wheat” means all classes of wheat grains grown in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8468-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “processed wheat” means the wheat-derived content of any substance (such as cake mix or flour) produced for use as an ingredient of an end product by changing wheat grown within the United States in form or character by any mechanical, chemical, or other means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8469-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3402/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “end product” means any product which contains processed wheat as an ingredient and which is intended, as produced, for consumption as human food, notwithstanding any additional incidental preparation which may be necessary by the ultimate consumer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac846a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3402/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “wheat producer” means any person who grows wheat within the United States for market.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac846b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3402/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “processor” means any person who commercially produces processed wheat within the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac846c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3402/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “end product manufacturer” means any person who commercially produces an end product within the United States, but such term shall not include such persons to the extent that they produce end products on the premises where such end products are to be consumed by an ultimate consumer, including, but not limited to, hotels, restaurants, and institutions, nor shall such term include persons who produce end products for their own personal, family, or household use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac846d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3402/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “research” means any type of research to advance the nutritional quality, marketability, production, or other qualities of wheat, processed wheat, or end products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac846e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3402/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “nutrition education” means any action to disseminate to the public information resulting from research concerning the economic value or nutritional benefits of wheat, processed wheat, and end products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac846f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3402/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Council” means the Wheat Industry Council established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3405"},"text":"section 3405 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8470-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3402/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Department” means the United States Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8471-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3402/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Agriculture of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8472-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3402/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” means any individual, partnership, corporation, association, or other entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefac8473-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3402/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “United States” means the several States and the District of Columbia, including any territory or possession.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefac8474-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXVII/s1703"},"text":"Pub. L. 95–113, title XVII, § 1703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1032"},"text":"91 Stat. 1032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefac8475-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefac8476-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefac8477-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
