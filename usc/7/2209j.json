{"tag":"section","attrib":{"id":"idef75bd00-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2209j"},"text":null,"children":[{"tag":"num","attrib":{"value":"2209j"},"text":"§ 2209j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent debarment from participation in Department of Agriculture programs for fraud","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef75bd01-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2209j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the Secretary of Agriculture shall permanently debar an individual, organization, corporation, or other entity convicted of a felony for knowingly defrauding the United States in connection with any program administered by the Department of Agriculture from any subsequent participation in Department of Agriculture programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef75bd02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2209j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef75bd03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2209j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may reduce a debarment under subsection (a) to a period of not less than 10 years if the Secretary considers it appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef75bd04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2209j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A debarment under subsection (a) shall not apply with respect to participation in domestic food assistance programs (as defined by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef75bd05-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXIV/s14211"},"text":"Pub. L. 110–234, title XIV, § 14211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1464"},"text":"122 Stat. 1464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XIV, § 14211, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2226.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef75bd06-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef75bd07-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef75bd08-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"