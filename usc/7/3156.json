{"tag":"section","attrib":{"id":"idef9971cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156"},"text":null,"children":[{"tag":"num","attrib":{"value":"3156"},"text":"§ 3156.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education grants to Alaska Native serving institutions and Native Hawaiian serving institutions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9971cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education grants program for Alaska Native serving institutions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9971cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may make competitive grants to Alaska Native serving institutions for the purpose of promoting and strengthening the ability of Alaska Native serving institutions to carry out education, applied research, and related community development programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9971ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made under this section shall be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9971cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the activities of consortia of Alaska Native serving institutions to enhance educational equity for under represented students;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9971d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen institutional educational capacities, including libraries, curriculum, faculty, scientific instrumentation, instruction delivery systems, and student recruitment and retention, in order to respond to identified State, regional, national, or international educational needs in the food and agriculture sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9971d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to attract and support undergraduate and graduate students from under represented groups in order to prepare them for careers related to the food, agricultural, and natural resource systems of the United States, beginning with the mentoring of students at the high school level including by village elders and continuing with the provision of financial support for students through their attainment of a doctoral degree; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9971d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate cooperative initiatives between two or more Alaska Native serving institutions, or between Alaska Native serving institutions and units of State government or the private sector, to maximize the development and use of resources, such as faculty, facilities, and equipment, to improve food and agricultural sciences teaching programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9971d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to make grants under this subsection $10,000,000 in fiscal years 2001 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9971d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education grants program for Native Hawaiian serving institutions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef9971d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may make competitive grants to Native Hawaiian serving institutions for the purpose of promoting and strengthening the ability of Native Hawaiian serving institutions to carry out education, applied research, and related community development programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9971d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grant funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants made under this section shall be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef9971d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the activities of consortia of Native Hawaiian serving institutions to enhance educational equity for under represented students, including permitting consortia to designate fiscal agents for the members of the consortia and to allocate among the members funds made available under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9971d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to strengthen institutional educational capacities, including libraries, curriculum, faculty, scientific instrumentation, instruction delivery systems, and student recruitment and retention, in order to respond to identified State, regional, national, or international educational needs in the food and agriculture sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9971d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to attract and support undergraduate and graduate students from under represented groups in order to prepare them for careers related to the food, agricultural, and natural resource systems of the United States, beginning with the mentoring of students at the high school level and continuing with the provision of financial support for students through their attainment of a doctoral degree; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef9971da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate cooperative initiatives between two or more Native Hawaiian serving institutions, or between Native Hawaiian serving institutions and units of State government or the private sector, to maximize the development and use of resources, such as faculty, facilities, and equipment, to improve food and agricultural sciences teaching programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef9971db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3156/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to make grants under this subsection $10,000,000 for each of fiscal years 2001 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9971dc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1419B"},"text":"Pub. L. 95–113, title XIV, § 1419B","children":[],"tail":", formerly "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tVII/s759"},"text":"Pub. L. 106–78, title VII, § 759","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href