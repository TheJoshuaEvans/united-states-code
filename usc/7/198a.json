{"tag":"section","attrib":{"id":"idee1bf8d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a"},"text":null,"children":[{"tag":"num","attrib":{"value":"198a"},"text":"§ 198a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Swine packer marketing contracts offered to producers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee1bf8d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations to carry out this section, the Secretary shall establish and maintain a library or catalog of each type of contract offered by packers to swine producers for the purchase of all or part of the producers’ production of swine (including swine that are purchased or committed for delivery), including all available noncarcass merit premiums.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf8d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available to swine producers and other interested persons information on the types of contracts described in subsection (a), including notice (on a real-time basis if practicable) of the types of contracts that are being offered by each individual packer to, and are open to acceptance by, producers for the purchase of swine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf8d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The reporting requirements under subsections (a) and (b) shall be subject to the confidentiality protections provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1636"},"text":"section 1636 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf8d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information collection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee1bf8da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee1bf8db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain (by a filing or other procedure required of each individual packer) information indicating what types of contracts for the purchase of swine are available from each packer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee1bf8dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the information available in a monthly report to swine producers and other interested persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee1bf8dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracted swine numbers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each packer shall provide, and the Secretary shall collect and publish in the monthly report required under paragraph (1)(B), information specifying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee1bf8de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of existing contracts for each packer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee1bf8df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions contained in each contract that provide for expansion in the numbers of swine to be delivered under the contract for the following 6-month and 12-month periods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee1bf8e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the total number of swine committed by contract for delivery to all packers within the 6-month and 12-month periods following the date of the report, reported by reporting region and by type of contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee1bf8e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the maximum total number of swine that potentially could be delivered within the 6-month and 12-month periods following the date of the report under the provisions described in subparagraph (B) that are included in existing contracts, reported by reporting region and by type of contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf8e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It shall be unlawful and a violation of this subchapter for any packer to willfully fail or refuse to provide to the Secretary accurate information required under, or to willfully fail or refuse to comply with any requirement of, this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee1bf8e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s198a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee1bf8e4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"Aug. 15, 1921, ch. 64","children":[],"tail":", title II, § 222, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX/s934/2"},"text":"Pub. L. 106–78, title IX, § 934(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1208"},"text":"113 Stat. 1208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee1bf8e5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idee1bf8e6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78/s942"},"text":"section 942 of Pub. L. 106–78","children":[],"tail":", see Livestock Mandatory Reporting note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1635"},"text":"section 1635 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee1bf8e7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"idee1bf8e8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section to terminate ","children":[{"tag":"date","attrib":{"date":"2025-03-14"},"text":"Mar. 14, 2025","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/s942"},"text":"section 942 of Pub. L. 106–78","children":[],"tail":", set out in a Livestock Mandatory Reporting note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1635"},"text":"section 1635 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
