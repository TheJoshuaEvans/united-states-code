{"tag":"section","attrib":{"id":"idf04eb75b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051"},"text":null,"children":[{"tag":"num","attrib":{"value":"9051"},"text":"§ 9051.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf04eb75c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Actual dairy production margin","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “actual dairy production margin” means the difference between the all-milk price and the average feed cost, as calculated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9052"},"text":"section 9052 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb75d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" All-milk price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “all-milk price” means the average price received, per hundredweight of milk, by dairy operations for all milk sold to plants and dealers in the United States, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb75e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Average feed cost","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “average feed cost” means the average cost of feed used by a dairy operation to produce a hundredweight of milk, determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9052"},"text":"section 9052 of this title","children":[],"tail":" using the sum of the following:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04eb75f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The product determined by multiplying 1.0728 by the price of corn per bushel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb760-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The product determined by multiplying 0.00735 by the price of soybean meal per ton.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb761-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The product determined by multiplying 0.0137 by the price of alfalfa hay per ton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb762-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dairy operation","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf04eb763-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “dairy operation” means, as determined by the Secretary, 1 or more dairy producers that produce and market milk as a single dairy operation in which each dairy producer—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf04eb764-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shares in the risk of producing milk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf04eb765-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes contributions (including land, labor, management, equipment, or capital) to the dairy operation of the individual or entity, which are at least commensurate with the individual or entity’s share of the proceeds of the operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf04eb766-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional ownership structures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall determine additional ownership structures to be covered by the definition of dairy operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb767-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dairy margin coverage","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dairy margin coverage” means the dairy margin coverage program required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9053"},"text":"section 9053 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb768-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dairy margin coverage payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dairy margin coverage payment” means a payment made to a participating dairy operation under dairy margin coverage pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9056"},"text":"section 9056 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb769-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participating dairy operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “participating dairy operation” means a dairy operation that registers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9054"},"text":"section 9054 of this title","children":[],"tail":" to participate in dairy margin coverage."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb76a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production history","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “production history” means the production history determined for a participating dairy operation under subsection (a) or (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9055"},"text":"section 9055 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb76b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf04eb76c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9051/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States”, in a geographical sense, means the 50 States, the District of Columbia, American Samoa, Guam, the Commonwealth of the Northern Mariana Islands, the Commonwealth of Puerto Rico, the Virgin Islands of the United States, and any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf04eb76d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1401"},"text":"Pub. L. 113–79, title I, § 1401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/688"},"text":"128 Stat. 688","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dF/s60101/b/1/A"},"text":"Pub. L. 115–123, div. F, § 60101(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/311"},"text":"132 Stat. 311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI"},"text":"Pub. L. 115–334, title I","children":[],"tail":", §§ 1401(k)(2), 1404(b)(2), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4516"},"text":"132 Stat. 4516","children":[],"tail":", 4521; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10313/a/1"},"text":"Pub. L. 119–21, title I, § 10313(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/99"},"text":"139 Stat. 99","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf04eb76e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf04eb76f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf04eb770-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" struck out “when the participating dairy operation first registers to participate in dairy margin coverage” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9055"},"text":"section 9055 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1404/b/2"},"text":"Pub. L. 115–334, § 1404(b)(2)","children":[],"tail":", struck out “and part B” after “this part” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123"},"text":"Pub. L. 115–123","children":[],"tail":" redesignated par. (5) as (4) and struck out former par. (4). Prior to amendment, text read as follows: “The term ‘consecutive 2-month period’ refers to the 2-month period consisting of the months of January and February, March and April, May and June, July and August, September and October, or November and December, respectively.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/2/A"},"text":"Pub. L. 115–334, § 1401(k)(2)(A)","children":[],"tail":", added pars. (5) and (6) and struck out former pars. (5) and (6) which defined the terms “margin protection program” and “margin protection program payment”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/b/1/A/ii"},"text":"Pub. L. 115–123, § 60101(b)(1)(A)(ii)","children":[],"tail":", redesignated pars. (6) and (7) as (5) and (6), respectively. Former par. (5) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s1401/k/2/B"},"text":"Pub. L. 115–334, § 1401(k)(2)(B)","children":[],"tail":", substituted “dairy margin coverage” for “the margin protection program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/b/1/A/ii"},"text":"Pub. L. 115–123, § 60101(b)(1)(A)(ii)","children":[],"tail":", redesignated pars. (8) and (9) as (7) and (8), respectively. Former par. (7) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (9) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/s60101/b/1/A/ii"},"text":"Pub. L. 115–123, § 60101(b)(1)(A)(ii)","children":[],"tail":", redesignated pars. (10) and (11) as (9) and (10), respectively. Former par. (9) redesignated (8)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf04eb771-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf04eb772-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1401/m"},"text":"Pub. L. 115–334, title I, § 1401(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4518"},"text":"132 Stat. 4518","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/334/tI/s1401/m"},"text":"“The amendments made by this section [amending this section and sections 9052 to 9060 of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2019-01-01"},"text":"January 1, 2019","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/123/dF/s60101/b/5"},"text":"Pub. L. 115–123, div. F, § 60101(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/312"},"text":"132 Stat. 312","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/123/dF/s60101/b/5"},"text":"“The amendments made by this subsection [amending this section and sections 9052 and 9054 to 9057 of this title] shall apply beginning with the 2018 calendar year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
