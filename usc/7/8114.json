{"tag":"section","attrib":{"id":"idf03208e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114"},"text":null,"children":[{"tag":"num","attrib":{"value":"8114"},"text":"§ 8114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sun grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf03208e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish and carry out a program to provide grants to the sun grant centers and subcenter specified in subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03208e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enhance national energy security through the development, distribution, and implementation of biobased energy technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote diversification in, and the environmental sustainability of, agricultural production in the United States through biobased energy and product technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote economic diversification in rural areas of the United States through biobased energy and product technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to enhance the efficiency of bioenergy and biomass research and development programs through improved coordination and collaboration among—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03208ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate Federal agencies (as determined by the Secretary); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land-grant colleges and universities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03208f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03208f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall use amounts made available under subsection (g) to provide grants to each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03208f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" North-central center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A north-central sun grant center for the region composed of the States of Illinois, Indiana, Iowa, Minnesota, Montana, Nebraska, North Dakota, South Dakota, Wisconsin, and Wyoming.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Southeastern center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A southeastern sun grant center for the region composed of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03208f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the States of Alabama, Florida, Georgia, Kentucky, Mississippi, North Carolina, South Carolina, Tennessee, and Virginia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03208f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of Puerto Rico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03208f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" South-central center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A south-central sun grant center for the region composed of the States of Arkansas, Colorado, Kansas, Louisiana, Missouri, New Mexico, Oklahoma, and Texas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Western center","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A western sun grant center for the region composed of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03208f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the States of Alaska, Arizona, California, Hawaii, Idaho, Nevada, Oregon, Utah, and Washington; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03208fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insular areas (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":" (other than the insular areas referred to in clauses (ii) and (iii) of subparagraph (B)))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Northeastern center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A northeastern sun grant center for the region composed of the States of Connecticut, Delaware, Massachusetts, Maryland, Maine, Michigan, New Hampshire, New Jersey, New York, Ohio, Pennsylvania, Rhode Island, Vermont, and West Virginia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Western insular Pacific subcenter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A western insular Pacific sun grant subcenter for the region of Alaska, Hawaii, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, the Federated States of Micronesia, the Republic of the Marshall Islands, and the Republic of Palau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03208fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of distribution","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03208fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing any funds made available under subsection (g), the Secretary shall distribute the grants in equal amounts to the sun grant centers described in subparagraphs (A) through (E) of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03208ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subcenter","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sun grant center described in paragraph (1)(D) shall allocate a portion of the funds received under paragraph (1) to the subcenter described in paragraph (1)(F) pursuant to guidance issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0347800-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply with requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary finds on the basis of a review of the annual report required under subsection (f) or on the basis of an audit of a sun grant center or subcenter conducted by the Secretary that the center or subcenter has not complied with the requirements of this section, the sun grant center or subcenter shall be ineligible to receive further grants under this section for such period of time as may be prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0347801-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0347802-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0347803-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A sun grant center or subcenter shall use 75 percent of the funds described in subsection (b) to provide competitive grants to entities that are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0347804-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible to receive grants under subsection (b)(7) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3157"},"text":"section 3157 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0347805-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in the region covered by the sun grant center or subcenter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0347806-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants described in subparagraph (A) shall be used by the grant recipient to conduct, in a manner consistent with the purposes described in subsection (a), multi-institutional and integrated, multistate research, extension, and education programs on technology development and technology implementation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0347807-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0347808-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peer and merit review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making grants under this paragraph, a sun grant center or subcenter shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf0347809-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek and accept proposals for grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf034780a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the relevance and merit of proposals through a system of peer review similar to that established by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7613"},"text":"section 7613 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf034780b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award grants on the basis of merit, quality, and relevance to advancing the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf034780c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A sun grant center or subcenter shall give a higher priority to programs that are consistent with the plan approved by the Secretary under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf034780d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded by a sun grant center or subcenter shall have a term that does not exceed 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf034780e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds required","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf034780f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/C/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subclauses (II) and (III), as a condition of receiving a grant under this paragraph, the sun grant center or subcenter shall require that not less than 20 percent of the cost of an activity described in subparagraph (B) be matched with funds, including in-kind contributions, from a non-Federal source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0347810-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/C/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subclause (I) shall not apply to fundamental research (as defined in subsection (f)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6971"},"text":"section 6971 of this title","children":[],"tail":" (as added by section 7511(a)(4)) "},{"tag":"ref","attrib":{"idref":"fn002359"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002359"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a third closing parenthesis."}],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0347811-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/C/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reduction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sun grant center or subcenter may reduce or eliminate the requirement for non-Federal funds under subclause (I) for applied research (as defined in subsection (f)(1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6971"},"text":"section 6971 of this title","children":[],"tail":" (as added by section 7511(a)(4)) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" if the sun grant center or subcenter determines that the reduction is necessary and appropriate pursuant to guidance issued by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0347812-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buildings and facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds made available for grants shall not be used for the construction of a new building or facility or the acquisition, expansion, remodeling, or alteration of an existing building or facility (including site grading and improvement and architect fees).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0347813-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/1/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on indirect costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A sun grant center or subcenter may not recover the indirect costs of making grants under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0347814-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A sun grant center or subcenter may use up to 4 percent of the funds described in subsection (b) to pay administrative expenses incurred in carrying out paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0347815-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research, extension and educational activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sun grant centers and subcenter shall use the remainder of the funds described in subsection (b) to conduct, in a manner consistent with the purposes described in subsection (a), multi-institutional and multistate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0347816-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research, extension, and educational programs on technology development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0347817-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrated research, extension, and educational programs on technology implementation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0347818-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan for research activities to be funded","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0347819-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of funds under subsection (g), and in cooperation with land-grant colleges and universities and private industry, the sun grant centers and subcenter shall jointly develop and submit to the Secretary for approval a plan for addressing the bioenergy, biomass, and bioproducts research priorities of the Department of Agriculture and other appropriate Federal agencies at the State and regional levels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf034781a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds described in subsection (c)(2) shall be available to carry out planning coordination under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf034781b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sun grant centers and subcenter shall use the plan described in paragraph (1) in making grants under subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf034781c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant Information Analysis Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sun grant centers and subcenter shall maintain a Sun Grant Information Analysis Center at the sun grant center specified in subsection (b)(1)(A) to provide the sun grant centers and subcenter with analysis and data management support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf034781d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the end of each fiscal year, a sun grant center or subcenter receiving a grant under this section shall submit to the Secretary a report that describes the policies, priorities, and operations of the program carried out by the center or subcenter during the fiscal year, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf034781e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of all peer and merit review procedures conducted pursuant to subsection (c)(1)(C)(i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf034781f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of progress made in facilitating the priorities described in subsection (d)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0347820-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8114/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $75,000,000 for each of fiscal years 2008 through 2023, of which not more than $4,000,000 for each fiscal year shall be made available to carry out subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0347821-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7526"},"text":"Pub. L. 110–234, title VII, § 7526","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1274"},"text":"122 Stat. 1274","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7526, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2035; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII"},"text":"Pub. L. 113–79, title VII","children":[],"tail":", §§ 7128(b)(5), 7516, "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/879"},"text":"128 Stat. 879","children":[],"tail":", 903; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII"},"text":"Pub. L. 115–334, title VII","children":[],"tail":", §§ 7414, 7614(b)(4)(A), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4819"},"text":"132 Stat. 4819","children":[],"tail":", 4836.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0347822-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0347823-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0347824-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 7511(a)(4), referred to in subsec. (c)(1)(D)(iv)(II), (III), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7511/a/4"},"text":"section 7511(a)(4) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf0347825-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food, Conservation, and Energy Act of 2008, and not as part of title IX of the Farm Security and Rural Investment Act of 2002 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idf0347826-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8109"},"text":"section 8109 of this title","children":[],"tail":" prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf0347827-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1)(C)(iv)(IV). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7614/b/4/A"},"text":"Pub. L. 115–334, § 7614(b)(4)(A)","children":[],"tail":", struck out subcl. (IV). Text read as follows: “The matching funds requirement under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3371"},"text":"section 3371 of this title","children":[],"tail":" shall not apply in the case of a grant provided by a sun grant center or subcenter under this paragraph.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7414"},"text":"Pub. L. 115–334, § 7414","children":[],"tail":", substituted “2023” for “2018”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7516/a/1"},"text":"Pub. L. 113–79, § 7516(a)(1)","children":[],"tail":", substituted “other appropriate Federal agencies (as determined by the Secretary)” for “the Department of Energy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7516/a/2/A"},"text":"Pub. L. 113–79, § 7516(a)(2)(A)","children":[],"tail":", struck out “at South Dakota State University” after “center”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7516/a/2/B"},"text":"Pub. L. 113–79, § 7516(a)(2)(B)","children":[],"tail":", struck out “at the University of Tennessee at Knoxville” after “center” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7516/a/2/C"},"text":"Pub. L. 113–79, § 7516(a)(2)(C)","children":[],"tail":", struck out “at Oklahoma State University” after “center”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7516/a/2/D"},"text":"Pub. L. 113–79, § 7516(a)(2)(D)","children":[],"tail":", struck out “at Oregon State University” after “center” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7516/a/2/E"},"text":"Pub. L. 113–79, § 7516(a)(2)(E)","children":[],"tail":", struck out “at Cornell University” after “center”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7516/a/2/F"},"text":"Pub. L. 113–79, § 7516(a)(2)(F)","children":[],"tail":", struck out “at the University of Hawaii” after “subcenter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7516/a/3/A"},"text":"Pub. L. 113–79, § 7516(a)(3)(A)","children":[],"tail":", substituted “integrated, multistate research, extension, and education programs on technology development and technology implementation” for “multistate—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) research, extension, and education programs on technology development; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) integrated research, extension, and education programs on technology implementation”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7516/a/3/B"},"text":"Pub. L. 113–79, § 7516(a)(3)(B)","children":[],"tail":", (C), redesignated subpar. (D) as (C) and struck out former subpar. (C) which related to funding allocation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(D)(iv)(IV). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7128/b/5"},"text":"Pub. L. 113–79, § 7128(b)(5)","children":[],"tail":", added subcl. (IV)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7516/a/4/A"},"text":"Pub. L. 113–79, § 7516(a)(4)(A)","children":[],"tail":", struck out “in accordance with paragraph (2)” after “industry” and substituted “bioproducts” for “gasification” and “other appropriate Federal agencies” for “the Department of Energy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7516/a/4/B"},"text":"Pub. L. 113–79, § 7516(a)(4)(B)","children":[],"tail":", (C), redesignated pars. (3) and (4) as (2) and (3), respectively, and struck out former par. (2). Prior to amendment, text read as follows: “With respect to gasification research activity, the sun grant centers and subcenter shall coordinate planning with land-grant colleges and universities in their respective regions that have ongoing research activities in that area.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7516/b"},"text":"Pub. L. 113–79, § 7516(b)","children":[],"tail":", substituted “subsection (c)(1)(C)(i)” for “subsection (c)(1)(D)(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/s7516/a/5"},"text":"Pub. L. 113–79, § 7516(a)(5)","children":[],"tail":", substituted “2018” for “2012”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0347828-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf0347829-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7614/b/4/A"},"text":"section 7614(b)(4)(A) of Pub. L. 115–334","children":[],"tail":" applicable to grants, cooperative agreements, or other awards made after "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", with matching funds r