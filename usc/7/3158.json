{"tag":"section","attrib":{"id":"idef9be29d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3158"},"text":null,"children":[{"tag":"num","attrib":{"value":"3158"},"text":"§ 3158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Next generation agriculture technology challenge","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9be29e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3158/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a next generation agriculture technology challenge competition to provide an incentive for the development of innovative mobile technology that removes barriers to entry in the marketplace for beginning farmers and ranchers (as defined in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2279"},"text":"section 2279 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9be29f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3158/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may award not more than $1,000,000 in the aggregate to 1 or more winners of the competition under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9be2a0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1419C"},"text":"Pub. L. 95–113, title XIV, § 1419C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7110"},"text":"Pub. L. 115–334, title VII, § 7110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4784"},"text":"132 Stat. 4784","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
