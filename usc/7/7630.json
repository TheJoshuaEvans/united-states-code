{"tag":"section","attrib":{"id":"idf017c91d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7630"},"text":null,"children":[{"tag":"num","attrib":{"value":"7630"},"text":"§ 7630.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants for youth organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf017c91e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7630/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Director of the National Institute of Food and Agriculture, shall make grants to the Girl Scouts of the United States of America, the Boy Scouts of America, the National 4–H Council, and the National FFA Organization to establish pilot projects to expand the programs carried out by the organizations in rural areas and small towns (including, with respect to the National 4–H Council, activities provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/19"},"text":"Public Law 107–19","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/115/153"},"text":"115 Stat. 153","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017c91f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7630/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide maximum flexibility in content delivery to each organization receiving funds under this section so as to ensure that the unique goals of each organization, as well as the local community needs, are fully met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017c920-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7630/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Redistribution of funding within organizations authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recipients of funds under this section may redistribute all or part of the funds received to individual councils or local chapters within the councils without further need of approval from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf017c921-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7630/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf017c922-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7630/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for each of fiscal years 2008 through 2013; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf017c923-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7630/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf017c924-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children