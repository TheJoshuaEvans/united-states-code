{"tag":"section","attrib":{"id":"idf03207e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110"},"text":null,"children":[{"tag":"num","attrib":{"value":"8110"},"text":"§ 8110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feedstock flexibility program for bioenergy producers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf03207ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03207eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bioenergy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bioenergy” means fuel grade ethanol and other biofuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03207ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bioenergy producer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “bioenergy producer” means a producer of bioenergy that uses an eligible commodity to produce bioenergy under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03207ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible commodity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible commodity” means a form of raw or refined sugar or in-process sugar that is eligible to be marketed in the United States for human consumption or to be used for the extraction of sugar for human consumption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03207ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible entity” means an entity located in the United States that markets an eligible commodity in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03207ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feedstock flexibility program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03207f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03207f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchases and sales","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of the 2008 through 2026 crops, the Secretary shall purchase eligible commodities from eligible entities and sell such commodities to bioenergy producers for the purpose of producing bioenergy in a manner that ensures that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272"},"text":"section 7272 of this title","children":[],"tail":" is operated at no cost to the Federal Government by avoiding forfeitures to the Commodity Credit Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03207f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the purchases and sales required under subparagraph (A), the Secretary shall, to the maximum extent practicable, use competitive procedures, including the receiving, offering, and accepting of bids, when entering into contracts with eligible entities and bioenergy producers, provided that such procedures are consistent with the purposes of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03207f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purchase and sale of eligible commodities under subparagraph (A) shall only be made in crop years in which such purchases and sales are necessary to ensure that the program authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272"},"text":"section 7272 of this title","children":[],"tail":" is operated at no cost to the Federal Government by avoiding forfeitures to the Commodity Credit Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03207f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03207f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the date of enactment of the Food, Conservation, and Energy Act of 2008 and each September 1 thereafter through ","children":[{"tag":"date","attrib":{"date":"2026-09-01"},"text":"September 1, 2026","children":[],"tail":", the Secretary shall provide notice to eligible entities and bioenergy producers of the quantity of eligible commodities that shall be made available for purchase and sale for the crop year following the date of the notice under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03207f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reestimates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the January 1, April 1, and July 1 of the calendar year following the date of a notice under subparagraph (A), the Secretary shall reestimate the quantity of eligible commodities determined under subparagraph (A), and provide notice and make purchases and sales based on such reestimates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03207f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commodity Credit Corporation inventory","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03207f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispositions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03207f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bioenergy and generally","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in clause (ii), to the extent that an eligible commodity is owned and held in inventory by the Commodity Credit Corporation (accumulated pursuant to the program authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272"},"text":"section 7272 of this title","children":[],"tail":"), the Secretary shall—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idf03207fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sell the eligible commodity to bioenergy producers under this section consistent with paragraph (1)(C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf03207fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dispose of the eligible commodity in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272/f/2"},"text":"section 7272(f)(2) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf03207fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/3/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise dispose of the eligible commodity through the buyback of certificates of quota entry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03207fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of other authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section limits the use of other authorities for the disposition of an eligible commodity held in the inventory of the Commodity Credit Corporation for nonfood use or otherwise in a manner that does not increase the net quantity of sugar available for human consumption in the United States market, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272/f/1"},"text":"section 7272(f)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03207fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency shortages","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), if there is an emergency shortage of sugar for human consumption in the United States market that is caused by a war, flood, hurricane, or other natural disaster, or other similar event, the Secretary may dispose of an eligible commodity that is owned and held in inventory by the Commodity Credit Corporation (accumulated pursuant to the program authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272"},"text":"section 7272 of this title","children":[],"tail":") through disposition as authorized under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272/f"},"text":"section 7272(f) of this title","children":[],"tail":" or through the use of any other authority of the Commodity Credit Corporation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03207ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer rule; storage fees","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0320800-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General transfer rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except with regard to emergency dispositions under paragraph (3)(B) and as provided in subparagraph (C), the Secretary shall ensure that bioenergy producers that purchase eligible commodities pursuant to this section take possession of the eligible commodities within 30 calendar days of the date of such purchase from the Commodity Credit Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0320801-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of storage fees prohibited","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0320802-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the maximum extent practicable, carry out this section in a manner that ensures no storage fees are paid by the Commodity Credit Corporation in the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0320803-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Clause (i) shall not apply with respect to any commodities owned and held in inventory by the Commodity Credit Corporation (accumulated pursuant to the program authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7272"},"text":"section 7272 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0320804-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Option to prevent storage fees","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0320805-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into contracts with bioenergy producers to sell eligible commodities to such producers prior in time to entering into contracts with eligible entities to purchase the eligible commodities to be used to satisfy the contracts entered into with the bioenergy producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0320806-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special transfer rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary makes a sale and purchase referred to in clause (i), the Secretary shall ensure that the bioenergy producer that purchased eligible commodities takes possession of such commodities within 30 calendar days of the date the Commodity Credit Corporation purchases the eligible commodities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0320807-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If sugar that is subject to a marketing allotment under part VII of subtitle B of title III of the Agricultural Adjustment Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1359aa"},"text":"7 U.S.C. 1359aa","children":[],"tail":" et seq.) is the subject of a payment under this section, the sugar shall be considered marketed and shall count against a processor’s allocation of an allotment under such part, as applicable."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0320808-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8110/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use the funds, facilities, and authorities of the Commodity Credit Corporation, including the use of such sums as are necessary, to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0320809-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIX/s9010"},"text":"Pub. L. 107–171, title IX, § 9010","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIX/s9001/a"},"text":"Pub. L. 110–234, title IX, § 9001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1325"},"text":"122 Stat. 1325","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title IX, § 9001(a), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2086; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/240/tVII/s701/f/9"},"text":"Pub. L. 112–240, title VII, § 701(f)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2365"},"text":"126 Stat. 2365","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIX/s9009"},"text":"Pub. L. 113–79, title IX, § 9009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/931"},"text":"128 Stat. 931","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIX/s9009"},"text":"Pub. L. 115–334, title IX, § 9009","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4887"},"text":"132 Stat. 4887","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/dB/tI/s102/d/6/C"},"text":"Pub. L. 118–22, div. B, title I, § 102(d)(6)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-11-17"},"text":"Nov. 17, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/118"},"text":"137 Stat. 118","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/158/dD/s4101/d/3"},"text":"Pub. L. 118–158, div. D, § 4101(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-21"},"text":"Dec. 21, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1769"},"text":"138 Stat. 1769","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/37/dE/s5002/d/3"},"text":"Pub. L. 119–37, div. E, § 5002(d)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/627"},"text":"139 Stat. 627","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf032080a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf032080b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf032080c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Food, Conservation, and Energy Act of 2008, referred to in subsec. (b)(2)(A), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Agricultural Adjustment Act of 1938, referred to in subsec. (b)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"act Feb. 16, 1938, ch. 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/31"},"text":"52 Stat. 31","children":[],"tail":". Part VII of subtitle B of title III of the Act is classified to subpart VII (§ 1359aa et seq.) of part B of subchapter II of chapter 35 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf032080d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L.