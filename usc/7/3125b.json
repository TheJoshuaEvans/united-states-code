{"tag":"section","attrib":{"id":"idef9726a6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3125b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3125b"},"text":"§ 3125b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Rural Information Center Clearinghouse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9726a7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3125b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish, within the National Agricultural Library, in coordination with the National Institute of Food and Agriculture, a National Rural Information Center Clearinghouse (in this section referred to as the “Clearinghouse”) to perform the functions specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9726a8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3125b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Clearinghouse shall provide and distribute information and data to any industry, organization, or Federal, State, or local government entity, on request, about programs and services provided by Federal, State, and local agencies and private nonprofit organizations and institutions under which individuals residing in, or organizations and State and local government entities operating in, a rural area may be eligible for any kind of assistance, including job training, education, health care, and economic development assistance, and emotional and financial counseling. To the extent possible, the National Agricultural Library shall use telecommunications technology to disseminate information to rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9726a9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3125b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On request of the Secretary, the head of a Federal agency shall provide to the Clearinghouse such information as the Secretary may request to enable the Clearinghouse to carry out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9726aa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3125b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State and local agencies and nonprofit organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall request State and local governments and private nonprofit organizations and institutions to provide to the Clearinghouse such information as such agencies and organizations may have about any program or service of such agencies, organizations, and institutions under which individuals residing in a rural area may be eligible for any kind of assistance, including job training, educational, health care, and economic development assistance, and emotional and financial counseling.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9726ab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3125b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out this section, there are authorized to be appropriated $500,000 for each of the fiscal years 1991 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9726ac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2381"},"text":"Pub. L. 101–624, title XXIII, § 2381","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4049"},"text":"104 Stat. 4049","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s842"},"text":"Pub. L. 104–127, title VIII, § 842","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1170"},"text":"110 Stat. 1170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tIII/s301/b/3"},"text":"Pub. L. 105–185, title III, § 301(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/563"},"text":"112 Stat. 563","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII/s7101"},"text":"Pub. L. 107–171, title VII, § 7101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/431"},"text":"116 Stat. 431","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII"},"text":"Pub. L. 110–234, title VII","children":[],"tail":", §§ 7212, 7511(c)(9), "},{"tag":"date","attrib":{"date":"2008-05-22"},"text