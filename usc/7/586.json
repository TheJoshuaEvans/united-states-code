{"tag":"section","attrib":{"id":"idee3fad7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s586"},"text":null,"children":[{"tag":"num","attrib":{"value":"586"},"text":"§ 586.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refusal of certificates for violations of laws; penalties for violations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After opportunity for hearing the Secretary is authorized to refuse the issuance of certificates under this chapter for periods not exceeding ninety days to any person who ships or offers for shipment any apples in foreign commerce in violation of any of the provisions of this chapter. Any person or any common carrier or any transportation agency knowingly violating any of the provisions of this chapter shall be fined not less than $100 nor more than $10,000 by a court of competent jurisdiction.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee3fad7f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-10/ch59/s6"},"text":"June 10, 1933, ch. 59, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/124"},"text":"48 Stat. 124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/96/s1/c/1"},"text":"Pub. L. 106–96, § 1(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1321"},"text":"113 Stat. 1321","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee3fad80-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee3fad81-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee3fad82-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/96"},"text":"Pub. L. 106–96","children":[],"tail":" struck out “and/or pears” after “any apples”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
