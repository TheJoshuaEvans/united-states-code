{"tag":"section","attrib":{"id":"idf0405f6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734"},"text":null,"children":[{"tag":"num","attrib":{"value":"8734"},"text":"§ 8734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of loans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0405f6e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall permit the producers on a farm to repay a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8731"},"text":"section 8731 of this title","children":[],"tail":" for a loan commodity (other than upland cotton, long grain rice, medium grain rice, extra long staple cotton, and confectionery and each other kind of sunflower seed (other than oil sunflower seed)) at a rate that is the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0405f6f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8732"},"text":"section 8732 of this title","children":[],"tail":", plus interest (determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7283"},"text":"section 7283 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0405f70-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a rate (as determined by the Secretary) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0405f71-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is calculated based on average market prices for the loan commodity during the preceding 30-day period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0405f72-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will minimize discrepancies in marketing loan benefits across State boundaries and across county boundaries; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0405f73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a rate that the Secretary may develop using alternative methods for calculating a repayment rate for a loan commodity that the Secretary determines will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0405f74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize potential loan forfeitures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0405f75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the accumulation of stocks of the commodity by the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0405f76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the cost incurred by the Federal Government in storing the commodity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0405f77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the commodity produced in the United States to be marketed freely and competitively, both domestically and internationally; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0405f78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize discrepancies in marketing loan benefits across State boundaries and across county boundaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0405f79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rates for upland cotton, long grain rice, and medium grain rice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall permit producers to repay a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8731"},"text":"section 8731 of this title","children":[],"tail":" for upland cotton, long grain rice, and medium grain rice at a rate that is the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0405f7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8732"},"text":"section 8732 of this title","children":[],"tail":", plus interest (determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7283"},"text":"section 7283 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0405f7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevailing world market price for the commodity, as determined and adjusted by the Secretary in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0405f7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rates for extra long staple cotton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Repayment of a marketing assistance loan for extra long staple cotton shall be at the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8732"},"text":"section 8732 of this title","children":[],"tail":", plus interest (determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7283"},"text":"section 7283 of this title","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0405f7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevailing world market price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8737"},"text":"section 8737 of this title","children":[],"tail":", the Secretary shall prescribe by regulation—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0405f7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a formula to determine the prevailing world market price for each of upland cotton, long grain rice, and medium grain rice; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0405f7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mechanism by which the Secretary shall announce periodically those prevailing world market prices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0405f80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment of prevailing world market price for upland cotton, long grain rice, and medium grain rice","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0405f81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The prevailing world market price for long grain rice and medium grain rice determined under subsection (d) shall be adjusted to United States quality and location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0405f82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cotton","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The prevailing world market price for upland cotton determined under subsection (d)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0405f83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be adjusted to United States quality and location, with the adjustment to include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0405f84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reduction equal to any United States Premium Factor for upland cotton of a quality higher than Middling (M) 1","children":[{"tag":"sup","attrib":{},"text":"3","children":[],"tail":"⁄"},{"tag":"sub","attrib":{},"text":"32","children":[],"tail":"-inch; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0405f85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average costs to market the commodity, including average transportation costs, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0405f86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be further adjusted, during the period beginning on the date of enactment of this Act and ending on ","children":[{"tag":"date","attrib":{"date":"2013-07-31"},"text":"July 31, 2013","children":[],"tail":", if the Secretary determines the adjustment is necessary to—"}],"tail":null},{"tag":"clause","attrib":{"id":"idf0405f87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize potential loan forfeitures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0405f88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the accumulation of stocks of upland cotton by the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0405f89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/e/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that upland cotton produced in the United States can be marketed freely and competitively, both domestically and internationally; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0405f8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/e/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure an appropriate transition between current-crop and forward-crop price quotations, except that the Secretary may use forward-crop price quotations prior to July 31 of a marketing year only if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf0405f8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/e/2/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are insufficient current-crop price quotations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0405f8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/e/2/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the forward-crop price quotation is the lowest such quotation available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0405f8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines for additional adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making adjustments under this subsection, the Secretary shall establish a mechanism for determining and announcing the adjustments in order to avoid undue disruption in the United States market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0405f8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rates for confectionery and other kinds of sunflower seeds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall permit the producers on a farm to repay a marketing assistance loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8731"},"text":"section 8731 of this title","children":[],"tail":" for confectionery and each other kind of sunflower seed (other than oil sunflower seed) at a rate that is the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0405f8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loan rate established for the commodity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8732"},"text":"section 8732 of this title","children":[],"tail":", plus interest (determined in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7283"},"text":"section 7283 of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0405f90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the repayment rate established for oil sunflower seed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0405f91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of cotton storage costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0405f92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2008 through 2011 crop years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Effective for each of the 2008 through 2011 crop years, the Secretary shall provide cotton storage payments in the same manner, and at the same rates as the Secretary provided storage payments for the 2006 crop of cotton, except that the rates shall be reduced by 10 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0405f93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent crop years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning with the 2012 crop year, the Secretary shall provide cotton storage payments in the same manner, and at the same rates as the Secretary provided storage payments for the 2006 crop of cotton, except that the rates shall be reduced by 20 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0405f94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to temporarily adjust repayment rates","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0405f95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustment authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event of a severe disruption to marketing, transportation, or related infrastructure, the Secretary may modify the repayment rate otherwise applicable under this section for marketing assistance loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8731"},"text":"section 8731 of this title","children":[],"tail":" for a loan commodity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0405f96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8734/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any adjustment made under paragraph (1) in the repayment rate for marketing assistance loans for a loan commodity shall be in effect on a short-term and temporary basis, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0405f97-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1204"},"text":"Pub. L. 110–234, title I, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/956"},"text":"122 Stat. 956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1204, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1684.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0405f98-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0405f99-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib"