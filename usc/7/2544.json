{"tag":"section","attrib":{"id":"idef865e4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2544"},"text":null,"children":[{"tag":"num","attrib":{"value":"2544"},"text":"§ 2544.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The use and reproduction of a protected variety for plant breeding or other bona fide research shall not constitute an infringement of the protection provided under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef865e4b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tIII/s114"},"text":"Pub. L. 91–577, title III, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1555"},"text":"84 Stat. 1555","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
