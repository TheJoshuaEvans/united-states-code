{"tag":"section","attrib":{"id":"idee8e6971-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1364"},"text":null,"children":[{"tag":"num","attrib":{"value":"1364"},"text":"§ 1364.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation of review committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The members of the review committee shall receive as compensation for their services the same per diem as that received by the members of the committee utilized for the purposes of chapter 3B of title 16. The members of the review committee shall not be entitled to receive compensation for more than thirty days in any one year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee8e6972-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title III, § 364, "},{"tag":"ref","attrib":{"href":"/us/stat/52/63"},"text":"52 Stat. 63","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee8e6973-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee8e6974-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idee8e6975-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Chapter 3B [§ 590a et seq.] of title 16, referred to in text, was in the original a reference to the Soil Conservation and Domestic Allotment Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
