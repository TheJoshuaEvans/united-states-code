{"tag":"section","attrib":{"id":"idf040604b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751"},"text":null,"children":[{"tag":"num","attrib":{"value":"8751"},"text":"§ 8751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf040604c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Base acres for peanuts","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf040604d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “base acres for peanuts” means the number of acres assigned to a farm pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7952"},"text":"section 7952 of this title","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":", subject to any adjustment under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8752"},"text":"section 8752 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf040604e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered commodities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “base acres”, with respect to a covered commodity, has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8711"},"text":"section 8711 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf040604f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counter-cyclical payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “counter-cyclical payment” means a payment made to producers on a farm under section 8754 ","children":[{"tag":"ref","attrib":{"idref":"fn002379"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002379"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0406050-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “direct payment” means a direct payment made to producers on a farm under section 8753 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0406051-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “effective price” means the price calculated by the Secretary under section 8754 ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this title for peanuts to determine whether counter-cyclical payments are required to be made under that section for a crop year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0406052-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment acres","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “payment acres” means, in the case of direct payments and counter-cyclical payments—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0406053-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in subparagraph (B), 85 percent of the base acres of peanuts on a farm on which direct payments or counter-cyclical payments are made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0406054-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of direct payments for each of the 2009 through 2011 crop years, 83.3 percent of the base acres for peanuts on a farm on which direct payments are made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0406055-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment yield","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “payment yield” means the yield established for direct payments and the yield established for counter-cyclical payments under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7952"},"text":"section 7952 of this title","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":", for a farm for peanuts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0406056-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0406057-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “producer” means an owner, operator, landlord, tenant, or sharecropper that shares in the risk of producing a crop on a farm and is entitled to share in the crop available for marketing from the farm, or would have shared had the crop been produced.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0406058-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hybrid seed","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining whether a grower of hybrid seed is a producer, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0406059-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not take into consideration the existence of a hybrid seed contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf040605a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that program requirements do not adversely affect the ability of the grower to receive a payment under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf040605b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf040605c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf040605d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf040605e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of Puerto Rico; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf040605f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0406060-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target price","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “target price” means the price per ton of peanuts used to determine the payment rate for counter-cyclical payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0406061-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8751/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “United States”, when used in a geographical sense, means all of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0406062-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1301"},"text":"Pub. L. 110–234, title I, § 1301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/966"},"text":"122 Stat. 966","children":[],"tail":"; "},{"tag":"ref