{"tag":"section","attrib":{"id":"idefea9e33-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701"},"text":null,"children":[{"tag":"num","attrib":{"value":"6701"},"text":"§ 6701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global Climate Change Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefea9e34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of having within the Department of Agriculture a focal point for coordinating all issues of climate change, the Secretary of Agriculture (hereafter in this chapter referred to as the “Secretary”) shall establish a Global Climate Change Program (hereafter in this section referred to as the “Program”). The Secretary shall designate a director of the Program who shall be responsible to the Secretary for carrying out the duties specified in subsections (b) and (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefea9e35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefea9e36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate policy analysis, long range planning, research, and response strategies relating to climate change issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide liaison with other Federal agencies, through the Office of Science and Technology Policy, regarding issues of climate change;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform the Department of scientific developments and policy issues relating to the effects of climate change on agriculture and forestry, including broader issues that affect the impact of climate change on the farms and forests of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommend to the Secretary alternative courses of action with which to respond to such scientific developments and policy issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that recognition of the potential for climate change is fully integrated into the research, planning, and decision-making processes of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefea9e3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefea9e3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the global climate change studies required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6702"},"text":"section 6702 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, through such other agencies as the Secretary determines appropriate, competitive grants for research in climatology relating to the potential impact of climate change on agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the participation of the Department in interagency climate-related activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the National Academy of Sciences and private, academic, State, and local groups with respect to climate research and related activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the Department to the Office of Science and Technology Policy and coordinate the activities of the Department in response to requirements of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the Department on the Intergovernmental Panel on Climate Change; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefea9e42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6701/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review all Department budget items relating to climate change issues, including specifically the research budget to be submitted by the Secretary to the Office of Science and Technology Policy and the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefea9e43-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIV/s2402"},"text":"Pub. L. 101–624, title XXIV, § 2402","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4058"},"text":"104 Stat. 4058","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefea9e44-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefea9e45-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefea9e46-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (c)(5), was in the original “this title”, meaning title XXIV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4058"},"text":"104 Stat. 4058","children":[],"tail":", known as the Global Climate Change Prevention Act of 1990, which is classified principally to this chapter. For complete classification of title XXIV to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefea9e47-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idefea9e48-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIV/s2401"},"text":"Pub. L. 101–624, title XXIV, § 2401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4058"},"text":"104 Stat. 4058","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/624/tXXIV/s2401"},"text":"“This title [enacting this chapter and amending sections 1601 and 1602 of Title 16, Conservation] may be cited as the ‘Global Climate Change Prevention Act of 1990’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
