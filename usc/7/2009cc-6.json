{"tag":"section","attrib":{"id":"idef309d99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–6"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009cc–6"},"text":"§ 2009cc–6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef309d9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–6/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may charge such fees as the Secretary considers appropriate, so long as those fees are proportionally equal for each rural business investment company, with respect to any guarantee or grant issued under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef309d9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–6/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trust certificate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (a), the Secretary shall not collect a fee for any guarantee of a trust certificate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009cc–5"},"text":"section 2009cc–5 of this title","children":[],"tail":", except that any agent of the Secretary may collect such fees as the Secretary considers appropriate, so long as those fees are proportionally equal for each rural business investment company, for the functions described in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009cc–5/e/2"},"text":"section 2009cc–5(e)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef309d9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–6/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" License","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef309d9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–6/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), the Secretary may prescribe fees to be paid by each applicant for a license to operate as a rural business investment company under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef309d9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–6/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Fees collected under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef309d9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–6/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be deposited in the account for salaries and expenses of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef309da0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–6/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are authorized to be appropriated as the Secretary considers appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef309da1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–6/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in such amounts as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef309da2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–6/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on collection of certain fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a license described in paragraph (1) that was approved before ","children":[{"tag":"date","attrib":{"date":"2007-07-01"},"text":"July 1, 2007","children":[],"tail":", the Secretary shall not collect any fees due on or after the date of enactment of this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef309da3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s384G"},"text":"Pub. L. 87–128, title III, § 384G","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6029"},"text":"Pub. L. 107–171, title VI, § 6029","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/395"},"text":"116 Stat. 395","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6027/b"},"text":"Pub. L. 110–234, title VI, § 6027(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attri