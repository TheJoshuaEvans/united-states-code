{"tag":"section","attrib":{"id":"idef9726e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3129"},"text":null,"children":[{"tag":"num","attrib":{"value":"3129"},"text":"§ 3129.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9726e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3129/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of information technology systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a comprehensive review of state-of-the-art information technology systems that are available for use in developing the system required by subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9726e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3129/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring and evaluation system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and carry out a system to monitor and evaluate agricultural research and extension activities conducted or supported by the Department of Agriculture that will enable the Secretary to measure the impact and effectiveness of research, extension, and education programs according to priorities, goals, and mandates established by law. In developing the system, the Secretary shall incorporate information transfer technologies to optimize public access to research information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9726e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3129/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency with other requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall develop and implement the system in a manner consistent with the Government Performance and Results Act of 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62"},"text":"Public Law 103–62","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/107/285"},"text":"107 Stat. 285","children":[],"tail":") and amendments made by the Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9726e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3129/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9726ea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1413A"},"text":"Pub. L. 95–113, title XIV, § 1413A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s804"},"text":"Pub. L. 104–127, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1160"},"text":"110 Stat. 1160","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9726eb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef9726ec-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef9726ed-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Government Performance and Results Act of 1993, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62"},"text":"Pub. L. 103–62","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-03"},"text":"Aug. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/285"},"text":"107 Stat. 285","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", Government Organization and Employees, sections 1115 to 1119, 9703, and 9704 of Title 31, Money and Finance, and sections 2801 to 2805 of Title 39, Postal Service, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of Title 31","children":[],"tail":", and enacted provisions set out as notes under sections 1101 and 1115 of Title 31. For complete classification of this Act to the Code, see Short Title of 1993 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1101"},"text":"section 1101 of Title 31","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idef9726ee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3129, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1413A"},"text":"Pub. L. 95–113, title XIV, § 1413A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/96/294/tII/s255/a"},"text":"Pub. L. 96–294, title II, § 255(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-30"},"text":"June 30, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/707"},"text":"94 Stat. 707","children":[],"tail":", provided for biomass energy educational and technical assistance programs, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1601/f/1/C"},"text":"Pub. L. 101–624, title XVI, § 1601(f)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3704"},"text":"104 Stat. 3704","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
