{"tag":"section","attrib":{"id":"idee3fad5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s581"},"text":null,"children":[{"tag":"num","attrib":{"value":"581"},"text":"§ 581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards of export; establishment; shipping without certificate forbidden; hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It shall be unlawful for any person to ship or offer for shipment or for any carrier, or any steamship company, or any person to transport or receive for transportation to any foreign destination, except as provided in this chapter, any apples in packages which are not accompanied by a certificate issued under authority of the Secretary of Agriculture showing that such apples are of a Federal or State grade which meets the minimum of quality established by the Secretary for shipment in export. The Secretary is authorized to prescribe, by regulations, the requirements, other than those of grade, which the fruit must meet before certificates are issued. The Secretary shall provide opportunity, by public hearing or otherwise, for interested persons to examine and make recommendation with respect to any standard of export proposed to be established or designated, or regulation prescribed, by the Secretary for the purposes of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee3fad5e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-10/ch59/s1"},"text":"June 10, 1933, ch. 59, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/123"},"text":"48 Stat. 123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/96/s1/c"},"text":"Pub. L. 106–96, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1321"},"text":"113 Stat. 1321","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee3fad5f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee3fad60-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee3fad61-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/96"},"text":"Pub. L. 106–96","children":[],"tail":" struck out “and/or pears” after “any apples” and “or pears” after “such apples”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee3fad62-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idee3fad63-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-10/ch59/s11"},"text":"Act June 10, 1933, ch. 59, § 11","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/106/96/s1/a"},"text":"Pub. L. 106–96, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1321"},"text":"113 Stat. 1321","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/96/s1/a"},"text":"“This Act [enacting this chapter] may be cited as the ‘Export Apple Act’.”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
