{"tag":"section","attrib":{"id":"idef2bbafa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009aa–3"},"text":"§ 2009aa–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplements to Federal grant programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef2bbafb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that certain States and local communities of the region, including local development districts, may be unable to take maximum advantage of Federal grant programs for which the States and communities are eligible because—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2bbafc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the States or communities lack the economic resources to provide the required matching share; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbafd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are insufficient funds available under the applicable Federal law authorizing the Federal grant program to meet pressing needs of the region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2bbafe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal grant program funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any provision of law limiting the Federal share, the areas eligible for assistance, or the authorizations of appropriations of any Federal grant program, and in accordance with subsection (c), the Authority, with the approval of the Federal cochairperson and with respect to a project to be carried out in the region—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2bbaff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may increase the Federal share of the costs of a project under the Federal grant program to not more than 90 percent (except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009aa–5/b"},"text":"section 2009aa–5(b) of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbb00-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use amounts made available to carry out this subchapter to pay the increased Federal share.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2bbb01-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2bbb02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any project for which all or any portion of the basic Federal share of the costs of the project is proposed to be paid under this section, no Federal contribution shall be made until the Federal official administering the Federal law that authorizes the Federal grant program certifies that the project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2bbb03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets (except as provided in subsection (b)) the applicable requirements of the applicable Federal grant program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2bbb04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could be approved for Federal contribution under the Federal grant program if funds were available under the law for the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2bbb05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification by Authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef2bbb06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The certifications and determinations required to be made by the Authority for approval of projects under this Act in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009aa–8"},"text":"section 2009aa–8 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"idef2bbb07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be controlling; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef2bbb08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be accepted by the Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef2bbb09-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009aa–3/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance by Federal cochairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of any project described in paragraph (1), any finding, report, certification, or documentation required to be submitted with respect to the project to the head of the department, agency, or instrumentality of the Federal Government responsible for the administration of the Federal grant program under which the project is carried out shall be accepted by the Federal cochairperson.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef2bbb0a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s382D"},"text":"Pub. L. 87–128, title III, § 382D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tV/s503"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title V, § 503]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–275; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6027/d"},"text":"Pub. L. 107–171, title VI, § 6027(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/373"},"text":"116 Stat. 373","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef2bbb0b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef2bbb0c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef2bbb0d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c)(2)(A), refers to the Agricultural Act of 1961, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/294"},"text":"75 Stat. 294","children":[],"tail":". For classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1911"},"text":"section 1911 of this title","children":[],"tail":" and Tables. However, the reference was probably intended to be “this title” meaning the Consolidated Farm and Rural Development Act, title III of "},{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", as amended, which is classified principally to this chapter. For classification of this title to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef2bbb0e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" reenacted section catchline without change and amended text generally to clarify provisions relating to supplements to Federal grant programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef2bbb0f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef2bbb10-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Waiver of Requirements Relating to Non-Federal Cost-Share Grants and Cooperative Agreements for the Delta Regional Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dD/tV/s505/a"},"text":"Pub. L. 116–260, div. D, title V, § 505(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1379"},"text":"134 Stat. 1379","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dD/tV/s505/a"},"text":"“Requirements relating to non-Federal cost-share grants and cooperative agreements for the Delta Regional Authority under section 382D of the Agricultural Act of 1961 and Consolidated Farm and Rural Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009aa–3"},"text":"7 U.S.C. 2009aa–3","children":[],"tail":") are waived for grants awarded in fiscal year 2020 and in subsequent years in response to economic distress directly related to the impacts of the Coronavirus Disease (COVID–19).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
