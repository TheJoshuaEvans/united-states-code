{"tag":"section","attrib":{"id":"idefa30dd8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e"},"text":null,"children":[{"tag":"num","attrib":{"value":"3222e"},"text":"§ 3222e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New beginning for tribal students","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefa30dd9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa30dda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002276"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002276"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The closing parenthesis probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30ddb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land-grant college or university","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “land-grant college or university” includes a 1994 Institution (as defined in section 532 of the Equity in Educational Land-Grant Status Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/382"},"text":"Public Law 103–382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s301"},"text":"7 U.S.C. 301","children":[],"tail":" note))."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30ddc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal student","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Tribal student” means a student at a land-grant college or university that is a member of an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30ddd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New beginning initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefa30dde-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make competitive grants to land-grant colleges and universities to provide identifiable support specifically targeted for Tribal students.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30ddf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A land-grant college or university that desires to receive a grant under this section shall submit an application to the Secretary at such time, in such manner, and accompanied by such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30de0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A land-grant college or university that receives a grant under this section shall use the grant funds to support Tribal students through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefa30de1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruiting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa30de2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tuition and related fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa30de3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experiential learning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefa30de4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" student services, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefa30de5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tutoring;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefa30de6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counseling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefa30de7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/b/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" academic advising; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefa30de8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/b/3/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other student services that would increase the retention and graduation rate of Tribal students enrolled at the land-grant college or university, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30de9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A land-grant college or university that receives a grant under this section shall provide matching funds toward the cost of carrying out the activities described in this section in an amount equal to not less than 100 percent of the grant award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefa30dea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount per state","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State shall receive, through grants made under this section to land-grant colleges and universities located in the State, more than $500,000 per year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30deb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry and the Committee on Indian Affairs of the Senate a report that includes an itemized list of grant funds distributed under this section, including the specific form of assistance provided under subsection (b)(3), and the number of Tribal students assisted and the graduation rate of Tribal students at land-grant colleges and universities receiving grants under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefa30dec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3222e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefa30ded-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1450"},"text":"Pub. L. 95–113, title XIV, § 1450","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7120"},"text":"Pub. L. 115–334, title VII, § 7120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4791"},"text":"132 Stat. 4791","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
