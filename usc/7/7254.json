{"tag":"section","attrib":{"id":"ideffffbd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7254"},"text":null,"children":[{"tag":"num","attrib":{"value":"7254"},"text":"§ 7254.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on fluid milk standards in State of California","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this Act or any other provision of law shall be construed to preempt, prohibit, or otherwise limit the authority of the State of California, directly or indirectly, to establish or continue to effect any law, regulation, or requirement regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffbd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7254/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of milk solids or solids not fat in fluid milk products sold at retail or marketed in the State of California; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffbd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7254/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the labeling of such fluid milk products with regard to milk solids or solids not fat.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffffbd5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s144"},"text":"Pub. L. 104–127, title I, § 144","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/917"},"text":"110 Stat. 917","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
