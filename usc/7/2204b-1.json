{"tag":"section","attrib":{"id":"idef734b4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204b–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"2204b–1"},"text":"§ 2204b–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef734b4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204b–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional commitment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Congress commits itself to a sound balance between rural and urban America. The Congress considers this balance so essential to the peace, prosperity, and welfare of all our citizens that the highest priority must be given to the revitalization and development of rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef734b4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2204b–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location of Federal facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress hereby directs the heads of all executive departments and agencies of the Government to establish and maintain departmental policies and procedures giving first priority to the location of new offices and other facilities in rural areas as defined in the private business enterprise exception in section 1926(a)(7) ","children":[{"tag":"ref","attrib":{"idref":"fn002251"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002251"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef734b50-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/524/tIX/s901"},"text":"Pub. L. 91–524, title IX, § 901","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-11-30"},"text":"Nov. 30, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1383"},"text":"84 Stat. 1383","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/419/tVI/s601"},"text":"Pub. L. 92–419, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-30"},"text":"Aug. 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/674"},"text":"86 Stat. 674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/273/s7/3"},"text":"Pub. L. 94–273, § 7(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/378"},"text":"90 Stat. 378","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/355/s6"},"text":"Pub. L. 96–355, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-24"},"text":"Sept. 24, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1174"},"text":"94 Stat. 1174","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef734b51-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef734b52-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef734b53-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926/a/7"},"text":"Section 1926(a)(7) of this title","children":[],"tail":", referred to in subsec. (b), was repealed and a new section 1926(a)(7) was added by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s741/a/2"},"text":"Pub. L. 104–127, title VII, § 741(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1123"},"text":"110 Stat. 1123","children":[],"tail":". As added, "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926/a/7"},"text":"section 1926(a)(7) of this title","children":[],"tail":" defined “rural areas” but no longer contained provisions relating to a private business enterprise exception. Subsequently, section 1926(a)(7) was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6020/b/1"},"text":"Pub. L. 107–171, title VI, § 6020(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/363"},"text":"116 Stat. 363","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idef734b54-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3122"},"text":"section 3122 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef734b55-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/355"},"text":"Pub. L. 96–355","children":[],"tail":" struck out provisions respecting annual report to Congress by the President covering efforts, etc., made for locating all new facilities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/355"},"text":"Pub. L. 96–355","children":[],"tail":" struck out subsec. (c) which related to planning assistance and annual report to Congress respecting such assistance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/355"},"text":"Pub. L. 96–355","children":[],"tail":" struck out subsec. (d) which related to information and technical assistance and annual report to Congress respecting such assistance."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/355"},"text":"Pub. L. 96–355","children":[],"tail":" struck out subsec. (e) which related to provision of government services and annual report to Congress respecting such services."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/355"},"text":"Pub. L. 96–355","children":[],"tail":" struck out subsec. (f) which required report to Congress by "},{"tag":"date","attrib":{"date":"1971-07-01"},"text":"July 1, 1971","children":[],"tail":", relating to implementation of rural financial assistance requirements."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/273"},"text":"Pub. L. 94–273","children":[],"tail":" substituted “December” for “September”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/273"},"text":"Pub. L. 94–273","children":[],"tail":" substituted “December 1 of” for “September 1 of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/419"},"text":"Pub. L. 92–419","children":[],"tail":" struck out “insofar as practicable,” after “maintain” and substituted “policies and procedures giving first priority to the location of new offices and other facilities in rural areas as defined in the private business enterprise exception in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926/a/7"},"text":"section 1926(a)(7) of this title","children":[],"tail":"”, for “policies and procedures with respect to the location of new offices and other facilities in areas or communities of lower population density in preference to areas or communities of high population densities”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef734b56-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef734b57-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/355"},"text":"Pub. L. 96–355","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"Oct. 1, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/355/s10"},"text":"section 10 of Pub. L. 96–355","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2204b"},"text":"section 2204b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idef734b58-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idef734b59-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 11797","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 11797, ","children":[{"tag":"date","attrib":{"date":"1974-07-31"},"text":"July 31, 1974","children":[],"tail":", 39 F.R. 27893, which delegated to the Secretary of Agriculture the President’s authority to prepare and submit to Congress annual reports concerning the location of new Federal facilities in rural areas, was revoked by Ex. Ord. No. 12553, "},{"tag":"date","attrib":{"date":"1986-02-25"},"text":"Feb. 25, 1986","children":[],"tail":", 51 F.R. 7237."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
