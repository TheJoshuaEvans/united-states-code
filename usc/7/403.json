{"tag":"section","attrib":{"id":"idee2f0bdc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s403"},"text":null,"children":[{"tag":"num","attrib":{"value":"403"},"text":"§ 403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of activities of Department of Agriculture to bureau; employment of clerks, etc.","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purpose of enabling the Secretary of Agriculture and the Chief of the Bureau of Dairy Industry to carry out the purposes of this chapter, the Secretary of Agriculture is authorized to transfer to the Bureau of Dairy Industry such activities of the Department of Agriculture as he may designate which relate primarily to the dairy industry, and to employ such additional persons in the city of Washington and elsewhere, as may be necessary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee2f0bdd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1924-05-29/ch208/s3"},"text":"May 29, 1924, ch. 208, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/243"},"text":"43 Stat. 243","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1926-05-11/ch286"},"text":"May 11, 1926, ch. 286","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/499"},"text":"44 Stat. 499","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2f0bde-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee2f0bdf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idee2f0be0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Bureau of Dairying” established by act ","children":[{"tag":"date","attrib":{"date":"1924-05-29"},"text":"May 29, 1924","children":[],"tail":", designated “Bureau of Dairy Industry” by act "},{"tag":"date","attrib":{"date":"1926-05-11"},"text":"May 11, 1926","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idee2f0be1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idee2f0be2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of all officers, agencies, and employees of Department of Agriculture transferred, with certain exceptions, to Secretary of Agriculture by 1953 Reorg. Plan No. 2, § 1, eff. ","children":[{"tag":"date","attrib":{"date":"1953-06-04"},"text":"June 4, 1953","children":[],"tail":", 18 F.R. 3219, "},{"tag":"ref","attrib":{"href":"/us/stat/67/633"},"text":"67 Stat. 633","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Bureau of Dairy Industry transferred to Secretary of Agriculture by 1947 Reorg. Plan No. 1, § 301, eff. ","children":[{"tag":"date","attrib":{"date":"1947-07-01"},"text":"July 1, 1947","children":[],"tail":", 12 F.R. 4534, "},{"tag":"ref","attrib":{"href":"/us/stat/61/952"},"text":"61 Stat. 952","children":[],"tail":". See note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s391"},"text":"section 391 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Bureau of Dairy Industry consolidated with other agencies into Agricultural Research Administration for duration of World War II by Ex. Ord. No. 9069, ","children":[{"tag":"date","attrib":{"date":"1942-02-23"},"text":"Feb. 23, 1942","children":[],"tail":", 7 F.R. 1409."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
