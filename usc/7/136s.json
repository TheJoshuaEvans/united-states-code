{"tag":"section","attrib":{"id":"idee08e5a0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136s"},"text":null,"children":[{"tag":"num","attrib":{"value":"136s"},"text":"§ 136s.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Solicitation of comments; notice of public hearings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee08e5a1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136s/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of Agriculture","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, before publishing regulations under this subchapter, shall solicit the views of the Secretary of Agriculture in accordance with the procedure described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136w/a"},"text":"section 136w(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee08e5a2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136s/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of Health and Human Services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, before publishing regulations under this subchapter for any public health pesticide, shall solicit the views of the Secretary of Health and Human Services in the same manner as the views of the Secretary of Agriculture are solicited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136w/a/2"},"text":"section 136w(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee08e5a3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136s/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Views","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any other authority relating to public hearings and solicitation of views, in connection with the suspension or cancellation of a pesticide registration or any other actions authorized under this subchapter, the Administrator may, at the Administrator’s discretion, solicit the views of all interested persons, either orally or in writing, and seek such advice from scientists, farmers, farm organizations, and other qualified persons as the Administrator deems proper.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee08e5a4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136s/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In connection with all public hearings under this subchapter the Administrator shall publish timely notice of such hearings in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee08e5a5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125/s21"},"text":"June 25, 1947, ch. 125, § 21","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/516/s2"},"text":"Pub. L. 92–516, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/996"},"text":"86 Stat. 996","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/140/s2/b"},"text":"Pub. L. 94–140, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-11-28"},"text":"Nov. 28, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/752"},"text":"89 Stat. 752","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/532/tVIII/s801"},"text":"Pub. L. 100–532, title VIII, § 801","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2682"},"text":"102 Stat. 2682","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1006/b/1"},"text":"Pub. L. 102–237, title X, § 1006(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1895"},"text":"105 Stat. 1895","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/170/tII/s234"},"text":"Pub. L. 104–170, title II, § 234","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-03"},"text":"Aug. 3, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1509"},"text":"110 Stat. 1509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee08e5a6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee08e5a7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee08e5a8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/170"},"text":"Pub. L. 104–170","children":[],"tail":" added subsec. (b) and redesignated former subsecs. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “the Administrator” for “he” before “deems” and “the Administrator’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/532/s801"},"text":"Pub. L. 100–532, § 801","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), inserted headings for subsecs. (a) to (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/140"},"text":"Pub. L. 94–140","children":[],"tail":" inserted “in accordance with the procedure described in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136w/a"},"text":"section 136w(a) of this title","children":[],"tail":"” after “Secretary of Agriculture”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee08e5a9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idee08e5aa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/532"},"text":"Pub. L. 100–532","children":[],"tail":" effective on expiration of 60 days after "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/532/s901"},"text":"section 901 of Pub. L. 100–532","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"section 136 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idee08e5ab-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/516/s4"},"text":"section 4 of Pub. L. 92–516","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s136"},"text":"section 136 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
