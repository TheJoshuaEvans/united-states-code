{"tag":"section","attrib":{"id":"idefc933c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621"},"text":null,"children":[{"tag":"num","attrib":{"value":"5621"},"text":"§ 5621.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct credit sales program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefc933c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short-term program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To promote the sale of agricultural commodities, the Commodity Credit Corporation may finance the commercial export sale of such commodities from privately owned stocks on credit terms for not to exceed a 3-year period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermediate-term program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (c), to promote the sale of agricultural commodities the Commodity Credit Corporation may finance the commercial export sales of agricultural commodities from privately owned stocks on credit terms for a period of not less than 3 years nor in excess of 10 years in a manner that will directly benefit United States agricultural producers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commodity Credit Corporation shall not finance an export sale under subsection (b) unless the Secretary determines that such sale will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc933cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, expand, or maintain the importing country as a foreign market, on a long-term basis, for the commercial sale and export of United States agricultural commodities, without displacing normal commercial sales;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc933cd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the capability of the importing country to purchase and use, on a long-term basis, United States agricultural commodities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc933ce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise promote the export of United States agricultural commodities.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The reference in paragraphs (1) and (2) to “on a long-term basis” shall not apply in the case of determinations with respect to sales to the independent states of the former Soviet Union.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933cf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc933d0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commodity Credit Corporation may use export sales financing authorized under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefc933d1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase exports of agricultural commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to compete against foreign agricultural exports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to assist countries in meeting their food and fiber needs, particularly—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefc933d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefc933d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" countries that are emerging markets that have committed to carry out, or are carrying out, policies that promote economic freedom, private domestic production of food commodities for domestic consumption, and the creation and expansion of efficient domestic markets for the purchase and sale of agricultural commodities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefc933d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for such other purposes as the Secretary determines appropriate consistent with the provisions of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc933d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Export sales financing authorized under this section shall not be used for foreign aid, foreign policy, or debt rescheduling purposes. The provisions of the cargo preference laws shall not apply to export sales financed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of credit assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any contract for the financing of exports by the Commodity Credit Corporation under this section shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc933d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that repayment shall be made in dollars with interest accruing thereon as determined appropriate by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc933da-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement, if the Secretary determines such requirement appropriate to protect the interests of the United States, that an initial payment be made by the purchaser at the time of sale or shipment of the agricultural commodity that is subject to the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefc933db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5621/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commodity Credit Corporation may not make export sales financing authorized under this section available in connection with sales of an agricultural commodity to any country that the Secretary determines cannot adequately service the debt associated with such sale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc933dc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/tII/s201"},"text":"Pub. L. 95–501, title II, § 201","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXV/s1531"},"text":"Pub. L. 101–624, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3672"},"text":"104 Stat. 3672","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/511/tVII/s707/a"},"text":"Pub. L. 102–511, title VII, § 707(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3350"},"text":"106 Stat. 3350","children":[],"tail":", 3351; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s277/c/2"},"text":"Pub. L. 104–127, title II, § 277(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/979"},"text":"110 Stat. 979","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefc933dd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefc933de-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idefc933df-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/501/s201"},"text":"section 201 of Pub. L. 95–501","children":[],"tail":" enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1707b"},"text":"section 1707b of this title","children":[],"tail":" prior to the complete revision of "},{"tag":"ref","attrib":{"href":"/us/pl/95/501"},"text":"Pub. L. 95–501","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefc933e0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(1)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" substituted “emerging markets” for “emerging democracies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/s707/a"},"text":"Pub. L. 102–511, § 707(a)","children":[],"tail":", inserted sentence at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/s707/b"},"text":"Pub. L. 102–511, § 707(b)","children":[],"tail":", amended subpar. (C) generally. Prior to amendment, subpar. (C) read as follows: “to assist countries, particularly developing countries, in meeting their food and fiber needs; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/s707/c"},"text":"Pub. L. 102–511, § 707(c)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefc933e1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefc933e2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/511/tVII/s707/d"},"text":"Pub. L. 102–511, title VII, § 707(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3351"},"text":"106 Stat. 3351","children":[],"tail":", required Secretary of Agriculture to issue final regulations to implement this section not later than 30 days after "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tII/s276"},"text":"Pub. L. 104–127, title II, § 276","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/977"},"text":"110 Stat. 977","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
