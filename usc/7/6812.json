{"tag":"section","attrib":{"id":"idefef5a04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6812"},"text":null,"children":[{"tag":"num","attrib":{"value":"6812"},"text":"§ 6812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefef5a05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination or suspension not an order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The termination or suspension of an order, or a provision of an order, shall not be considered an order under the meaning of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefef5a06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefef5a07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6812/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be construed to provide for control of production or otherwise limit the right of individual cut flowers and cut greens producers to produce cut flowers and cut greens; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefef5a08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6812/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be construed to treat all persons producing cut flowers and cut greens fairly and to implement any order in an equitable manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefef5a09-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6812/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter may be construed to preempt or supersede any other program relating to cut flowers or cut greens promotion and consumer information organized and operated under the laws of the United States or a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefef5a0a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/190/s13"},"text":"Pub. L. 103–190, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2289"},"text":"107 Stat. 2289","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
