{"tag":"section","attrib":{"id":"idefb3afb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4209"},"text":null,"children":[{"tag":"num","attrib":{"value":"4209"},"text":"§ 4209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on maintenance of actions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This chapter shall not be deemed to provide a basis for any action, either legal or equitable, by any person or class of persons challenging a Federal project, program, or other activity that may affect farmland: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Governor of an affected State where a State policy or program exists to protect farmland may bring an action in the Federal district court of the district where a Federal program is proposed to enforce the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4202"},"text":"section 4202 of this title","children":[],"tail":" and regulations issued pursuant thereto."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefb3afb7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXV/s1548"},"text":"Pub. L. 97–98, title XV, § 1548","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1344"},"text":"95 Stat. 1344","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXII/s1255/b"},"text":"Pub. L. 99–198, title XII, § 1255(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1518"},"text":"99 Stat. 1518","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb3afb8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefb3afb9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefb3afba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":" substituted “by any person” for “by any State, local unit of government, or any person” and inserted proviso."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefb3afbb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefb3afbc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective six months after ","children":[{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1549"},"text":"section 1549 of Pub. L. 97–98","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4201"},"text":"section 4201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
