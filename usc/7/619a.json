{"tag":"section","attrib":{"id":"idee55312f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s619a"},"text":null,"children":[{"tag":"num","attrib":{"value":"619a"},"text":"§ 619a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cotton tax, time for payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The processing tax authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s609"},"text":"section 609 of this title","children":[],"tail":", when levied upon cotton, shall be payable ninety days after the filing of the processor’s report: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That, under regulations to be prescribed by the Secretary of the Treasury, the time for payment of such tax upon cotton may be extended, but in no case to exceed six months from the date of the filing of the report."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee553130-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-05-17/ch131"},"text":"May 17, 1935, ch. 131","children":[],"tail":", title I, § 2, "},{"tag":"ref","attrib":{"href":"/us/stat/49/281"},"text":"49 Stat. 281","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee553131-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee553132-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee553133-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was not enacted as part of the Agricultural Adjustment Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"constitutionality","id":"idee553134-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Constitutionality","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Unconstitutionality of processing and floor stock taxes, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s616"},"text":"section 616 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee553135-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"idee553136-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Separability","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Validity of remainder of this chapter as not affected should any of the provisions of this chapter be declared unconstitutional, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s614"},"text":"section 614 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
