{"tag":"section","attrib":{"id":"idef7ce873-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276"},"text":null,"children":[{"tag":"num","attrib":{"value":"2276"},"text":"§ 2276.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef7ce874-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of information furnished under a provision of law referred to in subsection (d), neither the Secretary of Agriculture, any other officer or employee of the Department of Agriculture or agency thereof, nor any other person may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7ce875-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use such information for a purpose other than the development or reporting of aggregate data in a manner such that the identity of the person who supplied such information is not discernible and is not material to the intended uses of such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce876-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclose such information to the public, unless such information has been transformed into a statistical or aggregate form that does not allow the identification of the person who supplied particular information; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce877-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of information collected under the authority described in paragraph (12) or (13) of subsection (d), disclose the information to any person or any Federal, State, local, or tribal agency outside the Department of Agriculture, unless the information has been converted into a statistical or aggregate form that does not allow the identification of the person that supplied particular information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7ce878-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty of Secretary; immunity from disclosure; necessary consent","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7ce879-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out a provision of law referred to in subsection (d), no department, agency, officer, or employee of the Federal Government, other than the Secretary of Agriculture, shall require a person to furnish a copy of statistical information provided to the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce87a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A copy of such information—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef7ce87b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be immune from mandatory disclosure of any type, including legal process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef7ce87c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not, without the consent of such person, be admitted as evidence or used for any purpose in any action, suit, or other judicial or administrative proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7ce87d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violations; penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who shall publish, cause to be published, or otherwise publicly release information collected pursuant to a provision of law referred to in subsection (d), in any manner or for any purpose prohibited in section ","children":[{"tag":"ref","attrib":{"idref":"fn002258"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002258"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" (a), shall be fined not more than $10,000 or imprisoned for not more than 1 year, or both."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7ce87e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions of law references","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a provision of law referred to in this subsection means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef7ce87f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first section of the Act entitled “An Act authorizing the Secretary of Agriculture to collect and publish statistics of the grade and staple length of cotton”, approved ","children":[{"tag":"date","attrib":{"date":"1927-03-03"},"text":"March 3, 1927","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s471"},"text":"7 U.S.C. 471","children":[],"tail":") (commonly referred to as the “Cotton Statistics and Estimates Act”);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce880-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first section of the Act entitled “An Act to provide for the collection and publication of statistics of tobacco by the Department of Agriculture”, approved ","children":[{"tag":"date","attrib":{"date":"1929-01-14"},"text":"January 14, 1929","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s501"},"text":"7 U.S.C. 501","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce881-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first section of the Act entitled “An Act to provide for the collection and publication of statistics of peanuts by the Department of Agriculture”, approved ","children":[{"tag":"date","attrib":{"date":"1936-06-24"},"text":"June 24, 1936","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s951"},"text":"7 U.S.C. 951","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce882-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 203(g) of the Agricultural Marketing Act of 1946 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1622/g"},"text":"7 U.S.C. 1622(g)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce883-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 526(a) of the Revised Statutes (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2204/a"},"text":"7 U.S.C. 2204(a)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce884-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act entitled “An Act providing for the publication of statistics relating to spirits of turpentine and resin”, approved ","children":[{"tag":"date","attrib":{"date":"1935-08-15"},"text":"August 15, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2248"},"text":"7 U.S.C. 2248","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce885-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s42"},"text":"section 42 of title 13","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce886-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 4 of the Act entitled “An Act to establish the Department of Commerce and Labor”, approved ","children":[{"tag":"date","attrib":{"date":"1903-02-14"},"text":"February 14, 1903","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1516"},"text":"15 U.S.C. 1516","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce887-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 2 of the joint resolution entitled “Joint resolution relating to the publication of economic and social statistics for Americans of Spanish origin or descent”, approved ","children":[{"tag":"date","attrib":{"date":"1976-06-16"},"text":"June 16, 1976","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1516a"},"text":"15 U.S.C. 1516a","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce888-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 3(e) of the Forest and Rangeland Renewable Resources Research Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1642/e"},"text":"16 U.S.C. 1642(e)","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce889-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2204g"},"text":"section 2204g of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce88a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 302 of the Rural Development Act of 1972 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1010a"},"text":"7 U.S.C. 1010a","children":[],"tail":") regarding the authority to collect data for the National Resources Inventory; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef7ce88b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/d/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 10109 of the Agriculture Improvement Act of 2018.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef7ce88c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2276/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information provided to Secretary of Commerce","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not prohibit the release of information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2204g/f/2"},"text":"section 2204g(f)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef7ce88d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVII/s1770"},"text":"Pub. L. 99–198, title XVII, § 1770","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1657"},"text":"99 Stat. 1657","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/113/s4/a/2"},"text":"Pub. L. 105–113, § 4(a)(2)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1997-11-21"},"text":"Nov. 21, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2276"},"text":"111 Stat. 2276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/3/tIII/s348"},"text":"Pub. L. 106–113, div. B, § 1000(a)(3) [title III, § 348]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1535"},"text":"113 Stat. 1535","children":[],"tail":", 1501A–207; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tII/s2004/b"},"text":"Pub. L. 107–171, title II, § 2004(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/236"},"text":"116 Stat. 236","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10109/d"},"text":"Pub. L. 115–334, title X, § 10109(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4907"},"text":"132 Stat. 4907","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7ce88e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7ce88f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef7ce890-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 10109 of the Agriculture Improvement Act of 2018, referred to in subsec. (d)(13), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10109"},"text":"section 10109 of Pub. L. 115–334","children":[],"tail":", which relates to a multiple crop and pesticide use survey. Subsecs. (a) to (c) of section 10109 are not classified to the Code. Subsec. (d) of section 10109 amended this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef7ce891-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10109/d/1/A"},"text":"Pub. L. 115–334, § 10109(d)(1)(A)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10109/d/1/B"},"text":"Pub. L. 115–334, § 10109(d)(1)(B)","children":[],"tail":", substituted “paragraph (12) or (13) of subsection (d)” for “subsection (d)(12)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10109/d/2/A"},"text":"Pub. L. 115–334, § 10109(d)(2)(A)","children":[],"tail":", inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s10109/d/2/B"},"text":"Pub. L. 115–334, § 10109(d)(2)(B)","children":[],"tail":"–(D), added par. (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s2004/b/1"},"text":"Pub. L. 107–171, § 2004(b)(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s2004/b/2"},"text":"Pub. L. 107–171, § 2004(b)(2)","children":[],"tail":", added par. (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (d)(10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" added par. (10) and redesignated former par. (10) as (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (d)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/113/s4/a/2"},"text":"Pub. L. 105–113, § 4(a)(2)","children":[],"tail":", added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/113/s4/b"},"text":"Pub. L. 105–113, § 4(b)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
