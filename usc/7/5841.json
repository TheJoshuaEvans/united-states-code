{"tag":"section","attrib":{"id":"idefd05f94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5841"},"text":null,"children":[{"tag":"num","attrib":{"value":"5841"},"text":"§ 5841.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment, purpose, and functions of National Genetic Resources Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd05f95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5841/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall provide for a National Genetic Resources Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05f96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5841/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program is established for the purpose of maintaining and enhancing a program providing for the collection, preservation, and dissemination of genetic material of importance to American food and agriculture production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05f97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5841/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program shall be administered by the Secretary through the Agricultural Research Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd05f98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5841/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the program, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd05f99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5841/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the collection, classification, preservation, and dissemination of genetic material of importance to the food and agriculture sectors of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5841/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research on the genetic materials collected and on methods for storage and preservation of those materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5841/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the activities of the program with similar activities occurring domestically;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5841/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless otherwise prohibited by law, have the right to make available on request, without charge and without regard to the country from which the request originates, the genetic material that the program assembles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5841/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand the types of genetic resources included in the program to develop a comprehensive genetic resources program which includes plants (including silvicultural species), animal, aquatic, insect, microbiological, and other types of genetic resources of importance to food and agriculture, as resources permit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5841/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and implement a national strategic germplasm and cultivar collection assessment and utilization plan that takes into consideration the resources and research necessary to address the significant backlog of characterization and maintenance of existing accessions considered to be critical to preserve the viability of, and public access to, germplasm and cultivars; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd05f9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5841/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in such other activities as the Secretary determines appropriate and as the resources of the program permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd05fa0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1632"},"text":"Pub. L. 101–624, title XVI, § 1632","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3744"},"text":"104 Stat. 3744","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s832/a"},"text":"Pub. L. 104–127, title VIII, § 832(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1168"},"text":"110 Stat. 1168","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7205/a"},"text":"Pub. L. 115–334, title VII, § 7205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4803"},"text":"132 Stat. 4803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefd05fa1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefd05fa2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefd05fa3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" added par. (6) and redesignated former par. (6) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" added par. (4) and struck out former par. (4) which read as follows: “make available upon request, without charge and without regard to the country from which such request originates, the genetic material which the program assembles;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
