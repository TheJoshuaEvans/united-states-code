{"tag":"section","attrib":{"id":"idef6764ac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2104"},"text":null,"children":[{"tag":"num","attrib":{"value":"2104"},"text":"§ 2104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Finding and issuance of orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After notice and opportunity for hearing as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2103"},"text":"section 2103 of this title","children":[],"tail":", the Secretary shall issue an order if he finds, and sets forth in such order, upon the evidence introduced at such hearing, that the issuance of such order and all the terms and conditions thereof will tend to effectuate the declared policy of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef6764ad-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/502/s5"},"text":"Pub. L. 89–502, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-07-13"},"text":"July 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/280"},"text":"80 Stat. 280","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
