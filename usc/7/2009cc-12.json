{"tag":"section","attrib":{"id":"idef309e08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–12"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009cc–12"},"text":"§ 2009cc–12.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Injunctions and other orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef309e09-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–12/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef309e0a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–12/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Whenever, in the judgment of the Secretary, a rural business investment company or any other person has engaged or is about to engage in any act or practice that constitutes or will constitute a violation of a provision of this subchapter (including any rule, regulation, order, or participation agreement under this subchapter), the Secretary may apply to the appropriate district court of the United States for an order enjoining the act or practice, or for an order enforcing compliance with the provision, rule, regulation, order, or participation agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef309e0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–12/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction; relief","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court shall have jurisdiction over the action and, on a showing by the Secretary that the rural business investment company or other person has engaged or is about to engage in an act or practice described in paragraph (1), a permanent or temporary injunction, restraining order, or other order, shall be granted without bond.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef309e0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–12/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef309e0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–12/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In any proceeding under subsection (a), the court as a court of equity may, to such extent as the court considers necessary, take exclusive jurisdiction over the rural business investment company and the assets of the rural business investment company, wherever located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef309e0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–12/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Trustee or receiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The court shall have jurisdiction in any proceeding described in paragraph (1) to appoint a trustee or receiver to hold or administer the assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef309e0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–12/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary as trustee or receiver","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef309e10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–12/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may act as trustee or receiver of a rural business investment company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef309e11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–12/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"On the request of the Secretary, the court shall appoint the Secretary to act as a trustee or receiver of a rural business investment company unless the court considers the appointment inequitable or otherwise inappropriate by reason of any special circumstances involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef309e12-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s384M"},"text":"Pub. L. 87–128, title III, § 384M","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6029"},"text":"Pub. L. 107–171, title VI, § 6029","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/399"},"text":"116 Stat. 399","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
