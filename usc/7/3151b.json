{"tag":"section","attrib":{"id":"idef972733-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b"},"text":null,"children":[{"tag":"num","attrib":{"value":"3151b"},"text":"§ 3151b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterinary services grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef972734-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef972735-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef972736-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a for-profit or nonprofit entity located in the United States that, or an individual who, operates a veterinary clinic providing veterinary services—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef972737-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a rural area, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1991/a"},"text":"section 1991(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef972738-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a veterinarian shortage situation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef972739-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, national, allied, or regional veterinary organization or specialty board recognized by the American Veterinary Medical Association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef97273a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a college or school of veterinary medicine accredited by the American Veterinary Medical Association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef97273b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a university research foundation or veterinary medical foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef97273c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a department of veterinary science or department of comparative medicine accredited by the Department of Education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef97273d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State agricultural experiment station; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef97273e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, local, or tribal government agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef97273f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterinarian shortage situation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “veterinarian shortage situation” means a veterinarian shortage situation as determined by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3151a"},"text":"section 3151a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef972740-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef972741-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall carry out a program to make competitive grants to qualified entities that carry out programs or activities described in paragraph (2) for the purpose of developing, implementing, and sustaining veterinary services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef972742-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A qualified entity shall be eligible to receive a grant described in paragraph (1) if the entity carries out programs or activities that the Secretary determines will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef997133-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially relieve veterinarian shortage situations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef997134-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support or facilitate private veterinary practices engaged in public health activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef997135-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support or facilitate the practices of veterinarians who are providing or have completed providing services under an agreement entered into with the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3151a/a/2"},"text":"section 3151a(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef997136-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award processes and preferences","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef997137-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application, evaluation, and input processes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In administering the grant program established under this section, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef997138-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use an appropriate application and evaluation process, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef997139-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek the input of interested persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef99713a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination preference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting recipients of grants to be used for any of the purposes described in subsection (d)(1), the Secretary shall give a preference to qualified entities that provide documentation of coordination with other qualified entities, with respect to any such purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef99713b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of available funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In selecting recipients of grants to be used for any of the purposes described in subsection (d), the Secretary shall take into consideration the amount of funds available for grants and the purposes for which the grant funds will be used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef99713c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under this section shall be considered to be a competitive research, extension, or education grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef99713d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of grants to relieve veterinarian shortage situations and support veterinary services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef99713e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), a qualified entity may use funds provided by a grant awarded under this section to relieve veterinarian shortage situations and support veterinary services for any of the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef99713f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To promote recruitment (including for programs in secondary schools), placement, and retention of veterinarians, veterinary technicians, students of veterinary medicine, and students of veterinary technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef997140-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To allow veterinary students, veterinary interns, externs, fellows, and residents, and veterinary technician students to cover expenses (other than the types of expenses described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3151a/c/5"},"text":"section 3151a(c)(5) of this title","children":[],"tail":") to attend training programs in food safety or food animal medicine."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef997141-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish or expand accredited veterinary education programs (including faculty recruitment and retention), veterinary residency and fellowship programs, or veterinary internship and externship programs carried out in coordination with accredited colleges of veterinary medicine.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef997142-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide continuing education and extension, including veterinary telemedicine and other distance-based education, for veterinarians, veterinary technicians, and other health professionals needed to strengthen veterinary programs and enhance food safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef997143-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide technical assistance for the preparation of applications submitted to the Secretary for designation as a veterinarian shortage situation under this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3151a"},"text":"section 3151a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef997144-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To expose students in grades 11 and 12 to education and career opportunities in food animal medicine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef997145-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified entities operating veterinary clinics","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A qualified entity described in subsection (a)(1)(A) may only use funds provided by a grant awarded under this section to establish or expand veterinary practices, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef997146-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipping veterinary offices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef997147-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sharing in the reasonable overhead costs of such veterinary practices, as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef997148-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing mobile veterinary facilities in which a portion of the facilities will address education or extension needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef997149-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special requirements for certain grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef99714a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of service requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef99714b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided through a grant made under this section to a qualified entity described in subsection (a)(1)(A) and used by such entity under subsection (d)(2) shall be subject to an agreement between the Secretary and such entity that includes a required term of service for such entity (including a qualified entity operating as an individual), as established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef99714c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing a term of service under subparagraph (A), the Secretary shall consider only—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef99714d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the grant awarded; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef99714e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific purpose of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef99714f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Breach remedies","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef997150-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agreement under paragraph (1) shall provide remedies for any breach of the agreement by the qualified entity referred to in paragraph (1)(A), including repayment or partial repayment of the grant funds, with interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef997151-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may grant a waiver of the repayment obligation for breach of contract if the Secretary determines that such qualified entity demonstrates extreme hardship or extreme need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef997152-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of amounts recovered","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds recovered under this paragraph shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef997153-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/e/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be credited to the account available to carry out this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef997154-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/e/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended without further appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef997155-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on use of grant funds for construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d)(2), funds made available for grants under this section may not be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef997156-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to construct a new building or facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef997157-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire, expand, remodel, or alter an existing building or facility, including site grading and improvement and architect fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef997158-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", the Secretary shall promulgate regulations to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef997159-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef99715a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this section $10,000,000 for fiscal year 2014 and each fiscal year thereafter, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef99715b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3151b/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"From amounts made available for grants under this section, the Secretary shall prioritize grant awards for programs or activities with a focus on the practice of food animal medicine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef99715c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1415B"},"text":"Pub. L. 95–113, title XIV, § 1415B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7104"},"text":"Pub. L. 113–79, title VII, § 7104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/866"},"text":"128 Stat. 866","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7106"},"text":"Pub. L. 115–334, title VII, § 7106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4783"},"text":"132 Stat. 4783","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef99715d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef99715e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef99715f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7106/1"},"text":"Pub. L. 115–334, § 7106(1)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7106/2"},"text":"Pub. L. 115–334, § 7106(2)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
