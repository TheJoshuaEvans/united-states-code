{"tag":"section","attrib":{"id":"idf049fc34-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016"},"text":null,"children":[{"tag":"num","attrib":{"value":"9016"},"text":"§ 9016.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Price loss coverage","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf049fc35-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Price loss coverage payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If all of the producers on a farm make the election under subsection (a) or (h) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9015"},"text":"section 9015 of this title","children":[],"tail":" to obtain price loss coverage or, subject to subsection (c)(1) of such section, are deemed to have made such election under subsection (c)(2) of such section, the Secretary shall make price loss coverage payments to producers on the farm on a covered commodity-by-covered-commodity basis if the Secretary determines that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fc36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for any of the 2014 through 2018 crop years—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf049fc37-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective price for the covered commodity for the crop year; is less than","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf049fc38-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reference price for the covered commodity for the crop year; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fc39-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for any of the 2019 through 2031 crop years—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf049fc3a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective price for the covered commodity for the crop year; is less than","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf049fc3b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective reference price for the covered commodity for the crop year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc3c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective price","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The effective price for a covered commodity for a crop year shall be the higher of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fc3d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national average market price received by producers during the 12-month marketing year for the covered commodity, as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fc3e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national average loan rate for a marketing assistance loan for the covered commodity in effect for such crop year under subchapter II.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc3f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment rate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fc40-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf049fc41-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2014 through 2018 crop years","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the 2014 through 2018 crop years, the payment rate shall be equal to the difference between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf049fc42-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reference price for the covered commodity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf049fc43-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective price determined under subsection (b) for the covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf049fc44-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 2019 through 2031 crop years","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the 2019 through 2031 crop years, the payment rate shall be equal to the difference between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf049fc45-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective reference price for the covered commodity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf049fc46-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective price determined under subsection (b) for the covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fc47-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Announcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the end of each applicable 12-month marketing year for each covered commodity, the Secretary shall publish the payment rate determined under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fc48-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Insufficient data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a covered commodity, such as temperate japonica rice, for which the Secretary cannot determine the payment rate for the most recent 12-month marketing year by the date described in paragraph (2) due to insufficient reporting of timely pricing data by 1 or more nongovernmental entities, including a marketing cooperative for the covered commodity, the Secretary shall publish the payment rate as soon as practicable after the marketing year data are made available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc49-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment amount","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If price loss coverage payments are required to be provided under this section for any of the 2014 through 2031 crop years for a covered commodity, the amount of the price loss coverage payment to be paid to the producers on a farm for the crop year shall be equal to the product obtained by multiplying—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fc4a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment rate for the covered commodity under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fc4b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment yield for the covered commodity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fc4c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment acres for the covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc4d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines under this section that price loss coverage payments are required to be provided for the covered commodity, the payments shall be made beginning October 1, or as soon as practicable thereafter, after the end of the applicable marketing year for the covered commodity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc4e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective price for barley","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining the effective price for barley under subsection (b), the Secretary shall use the all-barley price.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc4f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reference price for temperate japonica rice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to reflect price premiums, the Secretary shall provide a reference price with respect to temperate japonica rice in an amount equal to the amount established under paragraph (19)(A)(vi) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9011"},"text":"section 9011 of this title","children":[],"tail":", as adjusted by paragraph (8) of such section, multiplied by the ratio obtained by dividing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fc50-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the simple average of the marketing year average price of medium grain rice from the 2017 through 2021 crop years; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fc51-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the simple average of the marketing year average price of all rice from the 2017 through 2021 crop years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf049fc52-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective price for seed cotton","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf049fc53-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The effective price for seed cotton under subsection (b) shall be equal to the marketing year average price for seed cotton, as calculated under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf049fc54-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Calculation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The marketing year average price for seed cotton for a crop year shall be equal to the quotient obtained by dividing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf049fc55-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum obtained by adding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf049fc56-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/h/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product obtained by multiplying—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf049fc57-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/h/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the upland cotton lint marketing year average price; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf049fc58-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/h/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total United States upland cotton lint production, measured in pounds; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf049fc59-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/h/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product obtained by multiplying—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf049fc5a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/h/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cottonseed marketing year average price; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf049fc5b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/h/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total United States cottonseed production, measured in pounds; by","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf049fc5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum obtained by adding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf049fc5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/h/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total United States upland cotton lint production, measured in pounds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf049fc5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s9016/h/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total United States cottonseed production, measured in pounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf049fc5f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1116"},"text":"Pub. L. 113–79, title I, § 1116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/668"},"text":"128 Stat. 668","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/123/dF/s60101/a/8"},"text":"Pub. L. 115–123, div. F, § 60101(a)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-09"},"text":"Feb. 9, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/310"},"text":"132 Stat. 310","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tI/s1106"},"text":"Pub. L. 115–334, title I, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4504"},"text":"132 Stat. 4504","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/dB/tI/s102/c/3"},"text":"Pub. L. 118–22, div. B, title I, § 102(c)(3)","children":[],"tail":", "},{"tag":"date",