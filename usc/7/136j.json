{"tag":"section","attrib":{"id":"idee042b90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j"},"text":null,"children":[{"tag":"num","attrib":{"value":"136j"},"text":"§ 136j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee042b91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee042b92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided by subsection (b), it shall be unlawful for any person in any State to distribute or sell to any person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee042b93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any pesticide that is not registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136a"},"text":"section 136a of this title","children":[],"tail":" or whose registration has been canceled or suspended, except to the extent that distribution or sale otherwise has been authorized by the Administrator under this subchapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042b94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any registered pesticide if any claims made for it as a part of its distribution or sale substantially differ from any claims made for it as a part of the statement required in connection with its registration under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136a"},"text":"section 136a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042b95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any registered pesticide the composition of which differs at the time of its distribution or sale from its composition as described in the statement required in connection with its registration under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136a"},"text":"section 136a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042b96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any pesticide which has not been colored or discolored pursuant to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136w/c/5"},"text":"section 136w(c)(5) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042b97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any pesticide which is adulterated or misbranded; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042b98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any device which is misbranded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee042b99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It shall be unlawful for any person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee042b9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to detach, alter, deface, or destroy, in whole or in part, any labeling required under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042b9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to refuse to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee042b9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare, maintain, or submit any records required by or under section 136c, 136e, 136f, 136i, or 136q of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee042b9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit any reports required by or under section 136c, 136d, 136e, 136f, 136i, or 136q of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee042b9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow any entry, inspection, copying of records, or sampling authorized by this subchapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042b9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to give a guaranty or undertaking provided for in subsection (b) which is false in any particular, except that a person who receives and relies upon a guaranty authorized under subsection (b) may give a guaranty to the same effect, which guaranty shall contain, in addition to the person’s own name and address, the name and address of the person residing in the United States from whom the person received the guaranty or undertaking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042ba0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use for the person’s own advantage or to reveal, other than to the Administrator, or officials or employees of the Environmental Protection Agency or other Federal executive agencies, or to the courts, or to physicians, pharmacists, and other qualified persons, needing such information for the performance of their duties, in accordance with such directions as the Administrator may prescribe, any information acquired by authority of this subchapter which is confidential under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042ba1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a registrant, wholesaler, dealer, retailer, or other distributor to advertise a product registered under this subchapter for restricted use without giving the classification of the product assigned to it under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136a"},"text":"section 136a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042ba2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to distribute or sell, or to make available for use, or to use, any registered pesticide classified for restricted use for some or all purposes other than in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136a/d"},"text":"section 136a(d) of this title","children":[],"tail":" and any regulations thereunder, except that it shall not be unlawful to sell, under regulations issued by the Administrator, a restricted use pesticide to a person who is not a certified applicator for application by a certified applicator;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042ba3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use any registered pesticide in a manner inconsistent with its labeling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042ba4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use any pesticide which is under an experimental use permit contrary to the provisions of such permit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042ba5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to violate any order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136k"},"text":"section 136k of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042ba6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to violate any suspension order issued under section 136a(c)(2)(B), 136a–1, or 136d of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042ba7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to violate any cancellation order issued under this subchapter or to fail to submit a notice in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136d/g"},"text":"section 136d(g) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042ba8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a producer to violate any of the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136e"},"text":"section 136e of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042ba9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to knowingly falsify all or part of any application for registration, application for experimental use permit, any information submitted to the Administrator pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s136e"},"text":"section 136e of this title","children":[],"tail":", any records required to be maintained pursuant to this subchapter, any report filed under this subchapter, or any information marked as confidential and submitted to the Administrator under any provision of this subchapter;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042baa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a registrant, wholesaler, dealer, retailer, or other distributor to fail to file reports required by this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042bab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to add any substance to, or take any substance from, any pesticide in a manner that may defeat the purpose of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042bac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use any pesticide in tests on human beings unless such human beings (i) are fully informed of the nature and purposes of the test and of any physical and mental health consequences which are reasonably foreseeable therefrom, and (ii) freely volunteer to participate in the test;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042bad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to falsify all or part of any information relating to the testing of any pesticide (or any ingredient, metabolite, or degradation product thereof), including the nature of any protocol, procedure, substance, organism, or equipment used, observation made, or conclusion or opinion formed, submitted to the Administrator, or that the person knows will be furnished to the Administrator or will become a part of any records required to be maintained by this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042bae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to submit to the Administrator data known to be false in support of a registration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee042baf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/a/2/S"},"text":null,"children":[{"tag":"num","attrib":{"value":"S"},"text":"(S)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to violate any regulation issued under section 136a(a) or 136q of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee042bb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The penalties provided for a violation of paragraph (1) of subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee042bb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who establishes a guaranty signed by, and containing the name and address of, the registrant or person residing in the United States from whom the person purchased or received in good faith the pesticide in the same unbroken package, to the effect that the pesticide was lawfully registered at the time of sale and delivery to the person, and that it complies with the other requirements of this subchapter, and in such case the guarantor shall be subject to the penalties which would otherwise attach to the person holding the guaranty under the provisions of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee042bb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any carrier while lawfully shipping, transporting, or delivering for shipment any pesticide or device, if such carrier upon request of any officer or employee duly designated by the Administrator shall permit such officer or employee to copy all of its records concerning such pesticide or device;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee042bb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any public official while engaged in the performance of the official duties of the public official;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee042bb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person using or possessing any pesticide as provided by an experimental use permit in effect with respect to such pesticide and such use or possession; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee042bb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s136j/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any person who ships a substance or mixture of substances being put through tests in which the purpose is only to determine its value for pesticide purposes or to determine its toxicity or other properties and from which the user does not expect to receive any benefit in pest control from its use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee042bb6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-06-25/ch125/s12"},"text":"June 25, 1947, ch. 125, § 12","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/92/516/s2"},"text":"Pub. L. 92–516, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-21"},"text":"Oct. 21, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/989"},"text":"86 Stat. 989","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/396/s16"},"text":"Pub. L. 95–396, § 16","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/832"},"text":"92 Stat. 832","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/532/tVI"},"text":"Pub. L. 100–532, title VI","children":[],"tail":", §§ 601(b)(2), 603, title VIII, § 801(g), (q)(2)(B), "},{"tag":"date","attrib":{"date":"1988-10-25"},"text":"Oct. 25, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2677"},"text":"102 Stat. 2677","children":[],"tail":", 2678, 2682, 2683; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1006/a/7"},"text":"Pub. L. 102–237, title X, § 1006(a)(7)","children":[],"tail":", (b)(3)(L)–(O), "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1895"},"text":"105 Stat. 1895","children":[],"tail":", 1896.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee042bb7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee042bb8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee042bb9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 12 of act ","children":[{"tag":"date","attrib":{"date":"1947-06-25"},"text":"June 25, 1947","children":[],"tail":", was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s135j"},"text":"section 135j of this title","children":[],"tail":" prior to amendment of act "},{"tag":"date","attrib":{"date":"1947-06-25"},"text":"June 25, 1947","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/pl/92/516"},"text":"Pub. L. 92–516","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee042bba-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(2)(C