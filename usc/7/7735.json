{"tag":"section","attrib":{"id":"idf01ef433-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7735"},"text":null,"children":[{"tag":"num","attrib":{"value":"7735"},"text":"§ 7735.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement actions of Attorney General","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf01ef434-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7735/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prosecute, in the name of the United States, all criminal violations of this chapter that are referred to the Attorney General by the Secretary or are brought to the notice of the Attorney General by any person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01ef435-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7735/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bring an action to enjoin the violation of or to compel compliance with this chapter, or to enjoin any interference by any person with the Secretary in carrying out this chapter, whenever the Secretary has reason to believe that the person has violated, or is about to violate this chapter, or has interfered, or is about to interfere, with the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf01ef436-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7735/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bring an action for the recovery of any unpaid civil penalty, funds under reimbursable agreements, late payment penalty, or interest assessed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf01ef437-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/tIV/s425"},"text":"Pub. L. 106–224, title IV, § 425","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/451"},"text":"114 Stat. 451","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf01ef438-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf01ef439-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf01ef43a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224"},"text":"Pub. L. 106–224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/438"},"text":"114 Stat. 438","children":[],"tail":", known as the Plant Protection Act, which is classified principally to this chapter. For complete classification of title IV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7701"},"text":"section 7701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf01ef43b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf01ef43c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of the Secretary of Agriculture relating to agricultural import and entry inspection activities under this chapter to the Secretary of Homeland Security, and for treatment of related references, see sections 231, 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
