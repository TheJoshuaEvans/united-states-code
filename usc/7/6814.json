{"tag":"section","attrib":{"id":"idefef5a0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6814"},"text":null,"children":[{"tag":"num","attrib":{"value":"6814"},"text":"§ 6814.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefef5a0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6814/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated for each fiscal year such sums as are necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefef5a0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6814/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated under subsection (a) may not be used for the payment of the expenses or expenditures of the PromoFlor Council in administering a provision of an order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefef5a10-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/190/s15"},"text":"Pub. L. 103–190, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2289"},"text":"107 Stat. 2289","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
