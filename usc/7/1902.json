{"tag":"section","attrib":{"id":"idef00da75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1902"},"text":null,"children":[{"tag":"num","attrib":{"value":"1902"},"text":"§ 1902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Humane methods","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No method of slaughtering or handling in connection with slaughtering shall be deemed to comply with the public policy of the United States unless it is humane. Either of the following two methods of slaughtering and handling are hereby found to be humane:","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef00da76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of cattle, calves, horses, mules, sheep, swine, and other livestock, all animals are rendered insensible to pain by a single blow or gunshot or an electrical, chemical or other means that is rapid and effective, before being shackled, hoisted, thrown, cast, or cut; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef00da77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by slaughtering in accordance with the ritual requirements of the Jewish faith or any other religious faith that prescribes a method of slaughter whereby the animal suffers loss of consciousness by anemia of the brain caused by the simultaneous and instantaneous severance of the carotid arteries with a sharp instrument and handling in connection with such slaughtering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef00da78-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/765/s2"},"text":"Pub. L. 85–765, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-27"},"text":"Aug. 27, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/862"},"text":"72 Stat. 862","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/445/s5/a"},"text":"Pub. L. 95–445, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1069"},"text":"92 Stat. 1069","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef00da79-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef00da7a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef00da7b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Par. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/445"},"text":"Pub. L. 95–445","children":[],"tail":" inserted “and handling in connection with such slaughtering” at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef00da7c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef00da7d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/445"},"text":"Pub. L. 95–445","children":[],"tail":" effective one year after "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", and nonapplicability during not to exceed additional 18 months in hardship cases, see sec. 7 of "},{"tag":"ref","attrib":{"href":"/us/pl/95/445"},"text":"Pub. L. 95–445","children":[],"tail":" set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s603"},"text":"section 603 of Title 21","children":[],"tail":", Food and Drugs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
