{"tag":"section","attrib":{"id":"idefa7c926-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3313"},"text":null,"children":[{"tag":"num","attrib":{"value":"3313"},"text":"§ 3313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided elsewhere in this Act or any other Act of Congress, funds available for allotment under this chapter shall be paid to each eligible institution or State at such time and in such amounts as shall be determined by the Secretary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefa7c927-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1467"},"text":"Pub. L. 95–113, title XIV, § 1467","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1018"},"text":"91 Stat. 1018","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefa7c928-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefa7c929-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idefa7c92a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in text, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3102"},"text":"section 3102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note