{"tag":"section","attrib":{"id":"idef1fd45f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997"},"text":null,"children":[{"tag":"num","attrib":{"value":"1997"},"text":"§ 1997.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation easements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef1fd460-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef1fd461-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “governmental entity” means any agency of the United States, a State, or a unit of local government of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef1fd462-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “highly erodible land” and “wetland” have the meanings, respectively, that such terms are given in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3801"},"text":"section 3801 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef1fd463-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “wildlife” means fish or wildlife as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3371"},"text":"section 3371 of title 16","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef1fd464-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “recreational purposes” includes hunting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef1fd465-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts on loan security properties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (c), the Secretary may enter into a contract related to real property for conservation, recreation, or wildlife purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef1fd466-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into a contract under subsection (b) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef1fd467-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such property is wetland, upland, or highly erodible land;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef1fd468-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such property is determined by the Secretary to be suitable for the purposes involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef1fd469-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef1fd46a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such property secures any loan made under any law administered by the Secretary and held by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef1fd46b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such contract better enables a qualified borrower to repay the loan in a timely manner, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef1fd46c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms and conditions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The terms and conditions specified in each such contract shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef1fd46d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify the purposes for which such real property may be used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef1fd46e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the conservation measures to be taken, and the recreational and wildlife uses to be allowed, with respect to such real property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef1fd46f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require such owner to permit the Secretary, and any person or governmental entity designated by the Secretary, to have access to such real property for the purpose of monitoring compliance with such contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef1fd470-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purchase; limitation upon cancellation or prepayment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef1fd471-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2), the Secretary may reduce or forgive the outstanding debt of a borrower—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef1fd472-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a borrower to whom the Secretary has made one or more outstanding loans under laws administered by the Secretary, by canceling that part of the aggregate amount of such outstanding loans that bears the same ratio to such aggregate amount as the number of acres of the real property of the borrower that are subject to the contract bears to the aggregate number of acres securing such loans; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef1fd473-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other case, by treating as prepaid that part of the principal amount of a new loan to the borrower issued and held by the Secretary under a law administered by the Secretary that bears the same ratio to such principal amount as the number of acres of the real property of the borrower that are subject to the contract bears to the aggregate number of acres securing the new loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef1fd474-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amount so canceled or treated as prepaid pursuant to paragraph (1) shall not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef1fd475-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a delinquent loan, the value of the land on which the contract is entered into or the difference between the amount of the outstanding loan secured by the land and the value of the land, whichever is greater; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef1fd476-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a nondelinquent loan, 33 percent of the amount of the loan secured by the land.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef1fd477-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations with Director of Fish and Wildlife Service","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary elects to use the authority provided by this section, the Secretary shall consult with the Director of the Fish and Wildlife Service for purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef1fd478-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selecting real property in which the Secretary may enter into contracts under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef1fd479-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formulating the terms and conditions of such contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef1fd47a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcing such contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef1fd47b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1997/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, and any person or governmental entity designated by the Secretary, may enforce a contract entered into by the Secretary under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef1fd47c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s349"},"text":"Pub. L. 87–128, title III, § 349","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXIII/s1318/a"},"text":"Pub. L. 99–198, title XIII, § 1318(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1530"},"text":"99 Stat. 1530","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/233/tVI/s612"},"text":"Pub. L. 100–233, title VI, § 612","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-06"},"text":"Jan. 6, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1674"},"text":"101 Stat. 1674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVIII/s1815"},"text":"Pub. L. 101–624, title XVIII, § 1815","children":[],"tail":", title XXIII, § 2388(j), "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3825"},"text":"104 Stat. 3825","children":[],"tail":", 4053; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVI/s642"},"text":"Pub. L. 104–127, title VI, § 642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1102"},"text":"110 Stat. 1102","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/243/s2/b/1"},"text":"Pub. L. 117–243, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2336"},"text":"136 Stat. 2336","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef1fd47d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef1fd47e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef1fd47f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/243"},"text":"Pub. L. 117–243","children":[],"tail":" substituted “section 3371” for “section 3371(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s642/1"},"text":"Pub. L. 104–127, § 642(1)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which read as follows: “Subject to subsection (c) of this section, the Secretary may acquire and retain an easement in real property, for a term of not less than 50 years, for conservation, recreational, and wildlife purposes.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s642/2/A"},"text":"Pub. L. 104–127, § 642(2)(A)","children":[],"tail":", inserted heading and substituted “The Secretary may enter into a contract under subsection (b) if” for “Such easement may be acquired or retained for real property if”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s642/2/B"},"text":"Pub. L. 104–127, § 642(2)(B)","children":[],"tail":", inserted “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s642/2/C"},"text":"Pub. L. 104–127, § 642(2)(C)","children":[],"tail":", struck out “(i)” after “(3)(A)”, substituted “administered by the Secretary” for “administered by the Farmers Home Administration”, redesignated cl. (ii) of subpar. (A) as subpar. (B), substituted “such contract” for “such easement” and a period for “; or” at end, and struck out former subpar. (B) which read as follows: “such property is administered under this chapter by the Secretary; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s642/2/D"},"text":"Pub. L. 104–127, § 642(2)(D)","children":[],"tail":", struck out par. (4) which read as follows: “such property was (except in the case of wetland and other wildlife habitat) row cropped each year of the 3-year period ending on "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"December 23, 1985","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s642/3"},"text":"Pub. L. 104–127, § 642(3)","children":[],"tail":", substituted “contract” for “easement” in introductory provisions and par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s642/4"},"text":"Pub. L. 104–127, § 642(4)","children":[],"tail":", in par. (1), substituted “reduce or forgive the outstanding debt of a borrower” for “purchase any such easement from the borrower” in introductory provisions, in subpars. (A) and (B), substituted “administered by the Secretary” for “administered by the Farmers Home Administration” and “contract bears” for “easement bears”, and in par. (2)(A), substituted “contract is entered into” for “easement is acquired”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s642/5"},"text":"Pub. L. 104–127, § 642(5)","children":[],"tail":", in par. (1), substituted “enter into contracts” for “acquire easements” and in pars. (2) and (3), substituted “contracts” for “easements”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s642/6"},"text":"Pub. L. 104–127, § 642(6)","children":[],"tail":", substituted “a contract entered into” for “an easement acquired”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s2388/j"},"text":"Pub. L. 101–624, § 2388(j)","children":[],"tail":", redesignated par. (5) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1815/1/A"},"text":"Pub. L. 101–624, § 1815(1)(A)","children":[],"tail":"–(D), (F), (G), in introductory provision, struck out “such property” after “real property if”, and inserted “such property” after par. (1), (2), (3)(A)(i), (3)(B), and (4) designations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1815/1/E"},"text":"Pub. L. 101–624, § 1815(1)(E)","children":[],"tail":", amended cl. (ii) generally. Prior to amendment, cl. (ii) read as follows: “the borrower of such loan is unable, as determined by the Secretary, to repay such loan in a timely manner; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1815/2"},"text":"Pub. L. 101–624, § 1815(2)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, subsec. (e) read as follows: “Any such easement acquired by the Secretary shall be purchased from the borrower involved by canceling that part of the aggregate amount of such outstanding loans of the borrower held by the Secretary under laws administered by the Farmers Home Administration that bears the same ratio to the aggregate amount of the outstanding loans of such borrower held by the Secretary under all such laws as the number of acres of the real property of such borrower that are subject to such easement bears to the aggregate number of acres securing such loans. In no case shall the amount so cancelled exceed the value of the land on which the easement is acquired or the difference between the amount of the outstanding loan secured by the land and the current value of the land, whichever is greater.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/s1815/9"},"text":"Pub. L. 101–624, § 1815(9)","children":[],"tail":", struck out subsec. (h) which read as follows: “This section shall not apply with respect to the cancellation of any part of any loan that was made after "},{"tag":"date","attrib":{"date":"1985-12-25"},"text":"December 25, 1985","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/s612/1"},"text":"Pub. L. 100–233, § 612(1)","children":[],"tail":", inserted “and other wildlife habitat” after “wetland”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/233/s612/2"},"text":"Pub. L. 100–233, § 612(2)","children":[],"tail":", inserted “or the difference between the amount of the outstanding loan secured by the land and the current value of the land, whichever is greater” at end of second sentence."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef1fd480-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef1fd481-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/s663/b"},"text":"section 663(b) of Pub. L. 104–127","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1922"},"text":"section 1922 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
