{"tag":"section","attrib":{"id":"ideff413c0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6933"},"text":null,"children":[{"tag":"num","attrib":{"value":"6933"},"text":"§ 6933.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Risk Management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideff413c1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6933/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and maintain in the Department an independent Office of Risk Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff413c2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6933/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of Office of Risk Management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Risk Management shall have jurisdiction over the following functions:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff413c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6933/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Supervision of the Federal Crop Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413c4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6933/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Administration and oversight of all aspects, including delivery through local offices of the Department, of all programs authorized under the Federal Crop Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"7 U.S.C. 1501","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413c5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6933/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any pilot or other programs involving revenue insurance, risk management savings accounts, or the use of the futures market to manage risk and support farm income that may be established under the Federal Crop Insurance Act or other law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413c6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6933/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other functions as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff413c7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6933/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff413c8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6933/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Risk Management shall be headed by an Administrator who shall be appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413c9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6933/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manager","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Office of Risk Management shall also serve as Manager of the Federal Crop Insurance Corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideff413ca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6933/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resources","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideff413cb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6933/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functional coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Certain functions of the Office of Risk Management, such as human resources, public affairs, and legislative affairs, may be provided by a consolidation of such functions under the Under Secretary of Agriculture for Farm Production and Conservation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideff413cc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6933/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding paragraph (1) or any other provision of law or order of the Secretary, the Secretary shall provide the Office of Risk Management with human and capital resources sufficient for the Office to carry out its functions in a timely and efficient manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideff413cd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s226A"},"text":"Pub. L. 103–354, title II, § 226A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s194/a"},"text":"Pub. L. 104–127, title I, § 194(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/945"},"text":"110 Stat. 945","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII"},"text":"Pub. L. 115–334, title XII","children":[],"tail":", §§ 12405(a), 12415(a), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4975"},"text":"132 Stat. 4975","children":[],"tail":", 4981.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideff413ce-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideff413cf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideff413d0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Crop Insurance Act, referred to in subsec. (b)(2), (3), is subtitle A of title V of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"act Feb. 16, 1938, ch. 30","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/72"},"text":"52 Stat. 72","children":[],"tail":", which is classified generally to subchapter I (§ 1501 et seq.) of chapter 36 of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"section 1501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideff413d1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12415/a"},"text":"Pub. L. 115–334, § 12415(a)","children":[],"tail":", substituted “The Secretary” for “Subject to subsection (e), the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s12405/a"},"text":"Pub. L. 115–334, § 12405(a)","children":[],"tail":", substituted “Under Secretary of Agriculture for Farm Production and Conservation” for “Under Secretary of Agriculture for Farm and Foreign Agricultural Services”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
