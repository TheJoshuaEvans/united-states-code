{"tag":"section","attrib":{"id":"ideed13f32-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1572"},"text":null,"children":[{"tag":"num","attrib":{"value":"1572"},"text":"§ 1572.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All persons transporting, or delivering for transportation, in interstate commerce, agricultural seeds shall keep for a period of three years a complete record of origin, treatment, germination, and purity of each lot of such agricultural seeds, and all persons transporting, or delivering for transportation, in interstate commerce, vegetable seeds shall keep for a period of three years a complete record of treatment, germination and variety of such vegetable seeds. The Secretary of Agriculture, or his duly authorized agents, shall have the right to inspect such records for the purpose of the effective administration of this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideed13f33-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1939-08-09/ch615"},"text":"Aug. 9, 1939, ch. 615","children":[],"tail":", title II, § 202, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1281"},"text":"53 Stat. 1281","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/85/581/s9"},"text":"Pub. L. 85–581, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-08-01"},"text":"Aug. 1, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/477"},"text":"72 Stat. 477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/89/686/s11"},"text":"Pub. L. 89–686, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/978"},"text":"80 Stat. 978","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideed13f34-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideed13f35-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideed13f36-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1966—","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/686"},"text":"Pub. L. 89–686","children":[],"tail":" required record of treatment of agricultural and vegetable seeds."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1958—","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/581"},"text":"Pub. L. 85–581","children":[],"tail":" required keeping of records of vegetable seeds."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideed13f37-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"ideed13f38-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"See ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1610"},"text":"section 1610 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
