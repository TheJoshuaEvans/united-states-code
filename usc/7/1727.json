{"tag":"section","attrib":{"id":"ideeedc77e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727"},"text":null,"children":[{"tag":"num","attrib":{"value":"1727"},"text":"§ 1727.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bilateral grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideeedc77f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall establish a program under which agricultural commodities are donated in accordance with this subchapter to least developed countries. The revenue generated by the sale of such commodities in the recipient country may be utilized for economic development activities. Such program shall be implemented by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideeedc780-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1727/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out the policies and accomplish the objectives described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1691"},"text":"section 1691 of this title","children":[],"tail":", the Administrator may negotiate and execute agreements with least developed countries to provide commodities to such countries on a grant basis."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideeedc781-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1954-07-10/ch469"},"text"