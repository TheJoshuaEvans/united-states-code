{"tag":"section","attrib":{"id":"idede50a36-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s63"},"text":null,"children":[{"tag":"num","attrib":{"value":"63"},"text":"§ 63.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability of principal for act of agent","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When construing and enforcing the provisions of this chapter, the act, omission, or failure of any agent, officer, or other person acting for or employed by any person, within the scope of his employment or office, shall in every case be deemed also the act, omission, or failure of such person as well as that of such agent, officer, or other person.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idede50a37-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1923-03-04/ch288/s11"},"text":"Mar. 4, 1923, ch. 288, § 11","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1519"},"text":"42 Stat. 1519","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idede50a38-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idede50a39-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idede50a3a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is composed of the second sentence of section 11 of act ","children":[{"tag":"date","attrib":{"date":"1923-03-04"},"text":"Mar. 4, 1923","children":[],"tail":". The first sentence of section 11 is contained in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s62"},"text":"section 62 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
