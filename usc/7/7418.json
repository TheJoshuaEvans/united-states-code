{"tag":"section","attrib":{"id":"idf0099800-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418"},"text":null,"children":[{"tag":"num","attrib":{"value":"7418"},"text":"§ 7418.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition and review of orders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0099801-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0099802-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person subject to an order issued under this subchapter may file with the Secretary a petition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0099803-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating that the order, any provision of the order, or any obligation imposed in connection with the order, is not established in accordance with law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0099804-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requesting a modification of the order or an exemption from the order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099805-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall give the petitioner an opportunity for a hearing on the petition, in accordance with regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099806-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ruling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the hearing, the Secretary shall make a ruling on the petition. The ruling shall be final, subject to review as set forth in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099807-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on petition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any petition filed under this subsection challenging an order, any provision of the order, or any obligation imposed in connection with the order, shall be filed within 2 years after the effective date of the order, provision, or obligation subject to challenge in the petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0099808-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0099809-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement of action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The district court of the United States for any district in which a person who is a petitioner under subsection (a) resides or carries on business shall have jurisdiction to review the final ruling on the petition of the person, if a complaint for that purpose is filed not later than 20 days after the date of the entry of the final ruling by the Secretary under subsection (a)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf009980a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Service of process in a proceeding may be made on the Secretary by delivering a copy of the complaint to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf009980b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remands","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the court determines that the ruling is not in accordance with law, the court shall remand the matter to the Secretary with directions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf009980c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make such ruling as the court determines to be in accordance with law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf009980d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to take such further action as, in the opinion of the court, the law requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf009980e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7418/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on enforcement proceedings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The pendency of a petition filed under subsection (a) or an action commenced under subsection (b) shall not operate as a stay of any action authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7419"},"text":"section 7419 of this title","children":[],"tail":" to be taken to enforce this subchapter, including any rule, order, or penalty in effect under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf009980f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s519"},"text":"Pub. L. 104–127, title V, § 519","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1044"},"text":"110 Stat. 1044","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
