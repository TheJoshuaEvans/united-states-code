{"tag":"section","attrib":{"id":"idefbf9758-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4814"},"text":null,"children":[{"tag":"num","attrib":{"value":"4814"},"text":"§ 4814.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Petition and review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefbf9759-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4814/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf975a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4814/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person subject to an order may file with the Secretary a petition—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf975b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4814/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating that such order, a provision of such order, or an obligation imposed in connection with such order is not in accordance with law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf975c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4814/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requesting a modification of such order or an exemption from such order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf975d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4814/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such person shall be given an opportunity for a hearing on the petition, in accordance with regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf975e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4814/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After such hearing, the Secretary shall make a determination granting or denying such petition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefbf975f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4814/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefbf9760-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4814/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A district court of the United States in the district in which such person resides or does business shall have jurisdiction to review such determination if a complaint for such purpose is filed not later than 20 days after the date such person receives notice of such determination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9761-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4814/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Service of process in such proceeding may be made on the Secretary by delivering a copy of the complaint to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefbf9762-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4814/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a court determines that such determination is not in accordance with law, the court shall remand such proceedings to the Secretary with directions to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefbf9763-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4814/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such ruling as the court shall determine to be in accordance with law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefbf9764-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s4814/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such further proceedings as, in the opinion of the court, the law requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefbf9765-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXVI/s1625"},"text":"Pub. L. 99–198, title XVI, § 1625","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1619"},"text":"99 Stat. 1619","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefbf9766-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefbf9767-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefbf9768-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1986-01-01"},"text":"Jan. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/s1631"},"text":"section 1631 of Pub. L. 99–198","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4801"},"text":"section 4801 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
