{"tag":"section","attrib":{"id":"idee611846-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s939"},"text":null,"children":[{"tag":"num","attrib":{"value":"939"},"text":"§ 939.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Loans made from or insured through the fund shall be for the same purposes and on the same terms and conditions as are provided for loans in subchapters I and II of this chapter except as otherwise provided in sections 933 to 938 inclusive.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee611847-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title III, § 309, as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/32/s2"},"text":"Pub. L. 93–32, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-05-11"},"text":"May 11, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/70"},"text":"87 Stat. 70","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2360"},"text":"Pub. L. 101–624, title XXIII, § 2360","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4042"},"text":"104 Stat. 4042","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/129/s2/b/2"},"text":"Pub. L. 103–129, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-01"},"text":"Nov. 1, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1363"},"text":"107 Stat. 1363","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s779"},"text":"Pub. L. 104–127, title VII, § 779","children":[],"tail":", "},{"tag":"dat