{"tag":"section","attrib":{"id":"idefd78b73-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936"},"text":null,"children":[{"tag":"num","attrib":{"value":"5936"},"text":"§ 5936.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Farm and Ranch Stress Assistance Network","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd78b74-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in coordination with the Secretary of Health and Human Services, shall make competitive grants to eligible entities described in subsection (c) to establish a Farm and Ranch Stress Assistance Network that provides stress assistance programs to individuals who are engaged in farming, ranching, and other agriculture-related occupations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78b75-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants awarded under subsection (a) may be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd78b76-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to initiate, expand, or sustain programs that provide professional agricultural behavioral health counseling and referral for other forms of assistance as necessary through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd78b77-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" farm telephone helplines and websites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78b78-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" training, including training programs and workshops, for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefd78b79-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advocates for individuals who are engaged in farming, ranching, and other occupations relating to agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefd78b7a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other individuals and entities that may assist individuals who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idefd78b7b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are engaged in farming, ranching, and other occupations relating to agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idefd78b7c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are in crisis;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78b7d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support groups; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78b7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach services and activities, including the dissemination of information and materials; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78b7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into contracts, on a multiyear basis, with community-based, direct-service organizations to initiate, expand, or sustain programs described in paragraph (1) and subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78b80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award a grant under this section to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd78b81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian tribe (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78b82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State department of agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78b83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State cooperative extension service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78b84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified nonprofit organization, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78b85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity providing appropriate services, as determined by the Secretary, in 1 or more States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78b86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a partnership carried out by 2 or more entities described in paragraphs (1) through (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78b87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $10,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78b88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd78b89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2018-12-20"},"text":"December 20, 2018","children":[],"tail":", the Secretary, in coordination with the Secretary of Health and Human Services, shall submit to Congress and any other relevant Federal department or agency, and make publicly available, a report describing the state of behavioral and mental health of individuals who are engaged in farming, ranching, and other occupations relating to agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd78b8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd78b8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an inventory and assessment of efforts to support the behavioral and mental health of individuals who are engaged in farming, ranching, and other occupations relating to agriculture by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefd78b8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government, States, and units of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefd78b8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communities comprised of those individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefd78b8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health care providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefd78b8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State cooperative extension services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefd78b90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate entities, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78b91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the challenges faced by individuals who are engaged in farming, ranching, and other occupations relating to agriculture that may impact the behavioral and mental health of farmers and ranchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78b92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the Department of Agriculture can improve coordination and cooperation with Federal health departments and agencies, including the Department of Health and Human Services, the Substance Abuse and Mental Health Services Administration, the Health Resources and Services Administration, the Centers for Disease Control and Prevention, and the National Institutes of Health, to best address the behavioral and mental health of individuals who are engaged in farming, ranching, and other occupations relating to agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78b93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a long-term strategy for responding to the challenges described under subparagraph (B) and recommendations based on best practices for further action to be carried out by appropriate Federal departments or agencies to improve Federal Government response and seek to prevent suicide among individuals who are engaged in farming, ranching, and other occupations relating to agriculture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd78b94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an evaluation of the impact that behavioral and mental health challenges and outcomes (including suicide) among individuals who are engaged in farming, ranching, and other agriculture related occupations have on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefd78b95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agricultural workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefd78b96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefd78b97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rural families and communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefd78b98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/e/2/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" succession planning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd78b99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5936/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “State” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd78b9a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7522"},"text":"Pub. L. 110–234, title VII, § 7522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1272"},"text":"122 Stat. 1272","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7522, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2033; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7412"},"text":"Pub. L. 115–334, title VII, § 7412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4817"},"text":"132 Stat. 4817","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefd78b9b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefd78b9c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idefd78b9d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Food, Conservation, and Energy Act of 2008, and not as part of subtitle H of title XVI of the Food, Agriculture, Conservation, and Trade Act of 1990 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefd78b9e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7412/1"},"text":"Pub. L. 115–334, § 7412(1)","children":[],"tail":", substituted “to eligible entities described in subsection (c)” for “to support cooperative programs between State cooperative extension services and nonprofit organizations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7412/2/B"},"text":"Pub. L. 115–334, § 7412(2)(B)","children":[],"tail":", (F), (G), substituted “be used—” for “be used”, inserted par. (1) designation before “to initiate”, redesignated former pars. (1) to (4) as subpars. (A) to (D), respectively, of par. (1), and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7412/2/C"},"text":"Pub. L. 115–334, § 7412(2)(C)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “community education;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7412/2/D"},"text":"Pub. L. 115–334, § 7412(2)(D)","children":[],"tail":", inserted “and” after semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7412/2/E"},"text":"Pub. L. 115–334, § 7412(2)(E)","children":[],"tail":", substituted “activities, including the dissemination of information and materials; or” for “activities; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7412/2/A"},"text":"Pub. L. 115–334, § 7412(2)(A)","children":[],"tail":", struck out par. (5) which read as follows: “home delivery of assistance, in a case in which a farm resident is homebound.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7412/3"},"text":"Pub. L. 115–334, § 7412(3)","children":[],"tail":", added subsecs. (c) to (f) and struck out former subsecs. (c) and (d) which related to extension services and authorization of appropriations, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefd78b9f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idefd78ba0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idefd78ba1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Farm and Ranch Mental Health","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tC/s10006"},"text":"Pub. L. 116–283, div. H, title C, § 10006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4866"},"text":"134 Stat. 4866","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dH/tC/s10006"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Service Announcement Campaign to Address Farm and Ranch Mental Health.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Agriculture, in consultation with the Secretary of Health and Human Services, shall carry out a public service announcement campaign to address the mental health of farmers and ranchers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The public service announcement campaign under paragraph (1) shall include television, radio, print, outdoor, and digital public service announcements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contractor.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Agriculture may enter into a contract or other agreement with a third party to carry out the public service announcement campaign under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In awarding a contract under subparagraph (A), the Secretary of Agriculture shall use a competitive bidding process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary of Agriculture to carry out this subsection $3,000,000, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee Training Program to Manage Farmer and Rancher Stress.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of enactment of this subsection [","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"], the Secretary of Agriculture shall expand the pilot program carried out by the Secretary of Agriculture in fiscal year 2019 that trained employees of the Farm Service Agency in the management of stress experienced by farmers and ranchers, to train employees of the Farm Service Agency, the Risk Management Agency, and the Natural Resources Conservation Service in the management of stress experienced by farmers and ranchers, including the detection of stress and suicide prevention."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less frequently than once every 2 years, the Secretary of Agriculture shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report describing the implementation of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Task Force for Assessment of Causes of Mental Stress and Best Practices for Response.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall convene a task force of agricultural and rural stakeholders at the national, State, and local levels—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess the causes of mental stress in farmers and ranchers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify best practices for responding to that mental stress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this subsection, the task force convened under paragraph (1) shall submit to the Secretary of Agriculture a report containing the assessment and best practices under subparagraphs (A) and (B), respectively, of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collaboration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this subsection, the task force convened under paragraph (1) shall collaborate with nongovernmental organizations and State and local agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cessation of Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any authorities provided under this section shall cease to be in effect on ","children":[{"tag":"date","attrib":{"date":"2023-10-01"},"text":"October 1, 2023","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idefd78ba2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” as meaning the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
