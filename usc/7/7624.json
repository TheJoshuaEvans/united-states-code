{"tag":"section","attrib":{"id":"idf0157fa1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624"},"text":null,"children":[{"tag":"num","attrib":{"value":"7624"},"text":"§ 7624.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biobased products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0157fa2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Biobased product” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “biobased product” means a product suitable for food or nonfood use that is derived in whole or in part from renewable agricultural and forestry materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fa3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of biobased product activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157fa4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the research, technical expertise, economic information, and market information resources and activities of the Department to develop, commercialize, and promote the use of biobased products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157fa5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit input from private sector persons who produce, or are interested in producing, biobased products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157fa6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a centralized contact point for advice and technical assistance for promising and innovative biobased products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157fa7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit an annual report to Congress describing the coordinated research, marketing, and commercialization activities of the Department relating to biobased products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fa8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements for biobased products","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157fa9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreements authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may enter into cooperative agreements with private entities described in subsection (d), under which the facilities and technical expertise of the Agricultural Research Service and the Forest Service may be made available to operate pilot plants and other large-scale preparation facilities for the purpose of bringing technologies necessary for the development and commercialization of new biobased products to the point of practical application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157faa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Description of cooperative activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Cooperative activities may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157fab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research on potential environmental impacts of a biobased product;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157fac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods to reduce the cost of manufacturing a biobased product; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157fad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other appropriate research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157fae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To carry out a cooperative agreement with a private entity under paragraph (1), the Secretary may rent to the private entity equipment, the title of which is held by the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157faf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible partners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following entities shall be eligible to enter into a cooperative agreement under subsection (c):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157fb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A party that has entered into a cooperative research and development agreement with the Secretary under section 12 of the Stevenson-Wydler Technology Innovation Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3710a"},"text":"15 U.S.C. 3710a","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157fb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A recipient of funding from the Biotechnology Research and Development Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157fb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A recipient of funding from the Secretary under a Small Business Innovation Research Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s638"},"text":"section 638 of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot project","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Agricultural Research Service, may establish and carry out a pilot project under which grants are provided, on a competitive basis, to scientists of the Agricultural Research Service to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157fb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage innovative and collaborative science; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157fb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during each of fiscal years 1999 through 2012, develop biobased products with promising commercial potential.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0157fb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), to carry out this section, the Secretary may use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0157fb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds appropriated to carry out this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0157fb9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds otherwise available for cooperative research and development agreements under the Stevenson-Wydler Technology Innovation Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3701"},"text":"15 U.S.C. 3701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0157fba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not use funds referred to in paragraph (1)(B) to carry out subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fbb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of developed products","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of determining the market potential for new biobased products produced at a pilot plant or other large-scale preparation facility under a cooperative agreement under this section, the Secretary shall authorize the private partner or partners to the agreement to sell the products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0157fbc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7624/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section for each of fiscal years 1999 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0157fbd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tIV/s404"},"text":"Pub. L. 105–185, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/570"},"text":"112 Stat. 570","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6201/d/4"},"text":"Pub. L. 107–171, title VI, § 6201(d)(4)","children":[],"tail":", title VII, § 7124, "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/419"},"text":"116 Stat. 419","children":[],"tail":", 434; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7304"},"text":"Pub. L. 110–234, title VII, § 7304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1242"},"text":"122 Stat. 1242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7304, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2003; "},{"tag":"ref","attrib":{"href":"/us/pl/111/88/dA/tIV/s431"},"text":"Pub. L. 111–88, div. A, title IV, § 431","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-30"},"text":"Oct. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2964"},"text":"123 Stat. 2964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0157fbe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0157fbf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0157fc0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Stevenson-Wydler Technology Innovation Act of 1980, referred to in subsec. (f)(1)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480"},"text":"Pub. L. 96–480","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2311"},"text":"94 Stat. 2311","children":[],"tail":", which is classified generally to chapter 63 (§ 3701 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3701"},"text":"section 3701 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf0157fc1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf0157fc2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/88/s431/1"},"text":"Pub. L. 111–88, § 431(1)","children":[],"tail":", substituted “Agricultural Research Service and the Forest Service” for “Agricultural Research Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/88/s431/2"},"text":"Pub. L. 111–88, § 431(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7304/a"},"text":"Pub. L. 110–246, § 7304(a)","children":[],"tail":", substituted “2012” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7304/b"},"text":"Pub. L. 110–246, § 7304(b)","children":[],"tail":", substituted “2012” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6201/d/4"},"text":"Pub. L. 107–171, § 6201(d)(4)","children":[],"tail":", redesignated pars. (3) and (4) as (2) and (3), respectively, and struck out former par. (2) which read as follows: “A recipient of funding from the Alternative Agricultural Research and Commercialization Corporation established under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s5902"},"text":"section 5902 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7124/a"},"text":"Pub. L. 107–171, § 7124(a)","children":[],"tail":", substituted “2007” for “2001”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7124/b"},"text":"Pub. L. 107–171, § 7124(b)","children":[],"tail":", substituted “2007” for “2002”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0157fc3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf0157fc4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idf0157fc5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Pilot Program on Use of Agricultural Commodities in Construction and Consumer Products","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tV/s70501"},"text":"Pub. L. 117–58, div. G, title V, § 70501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1266"},"text":"135 Stat. 1266","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dG/tV/s70501"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction product","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘construction product’ means any article, or component part thereof, produced or distributed for use during the construction, maintenance, or preservation of a highway, road, street, bridge, building, dam, port, or airport construction project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consumer product","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘consumer product’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any article, or component part thereof, produced or distributed—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for sale to a consumer for use in or around a permanent or temporary household or residence, a school, in recreation, or otherwise; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the personal use, consumption or enjoyment of a consumer in or around a permanent or temporary household or residence, a school, in recreation, or otherwise; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any product or product category described in subparagraphs (A) through (I) of section 3(a)(5) of the Consumer Product Safety Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2052/a/5"},"text":"15 U.S.C. 2052(a)(5)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered agricultural commodity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘covered agricultural commodity’ means any agricultural commodity, food, feed, fiber, livestock, oil, or a derivative thereof, that the Secretary determines to have been used in the production of materials that have demonstrated market viability and benefits (as described in paragraphs (1) through (7) of subsection (b)) as of the date of enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified institution","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘qualified institution’ means a bioproducts research facility that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is funded, in part, by a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located within a reasonable distance, not to exceed 3 miles, of the primary residence hall of an institution of higher education (as defined in section 101(a) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"20 U.S.C. 1001(a)","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides students opportunities to engage in research activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides opportunities for an institution of higher education (as defined in section 101(a) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"20 U.S.C. 1001(a)","children":[],"tail":")) to collaborate with private enterprise."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a pilot program under which the Secretary shall partner with not less than 1 qualified institution to study the benefits of using materials derived from covered agricultural commodities in the production of construction products and consumer products, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost savings relative to other commonly used alternative materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" greenhouse gas emission reductions and other environmental benefits relative to other commonly used alternative materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" life-cycle and longevity-extending characteristics relative to other commonly used alternative materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" life-cycle and longevity-reducing characteristics relative to other commonly used alternative materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" landfill quantity and waste management cost reductions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" product development and production scale-up; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other benefits that the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $2,000,000 for each of fiscal years 2022 through 2023.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
