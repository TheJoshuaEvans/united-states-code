{"tag":"section","attrib":{"id":"idefc478f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5202"},"text":null,"children":[{"tag":"num","attrib":{"value":"5202"},"text":"§ 5202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the policy of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefc478f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5202/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide, through all possible means, agricultural commodities and products for export at competitive prices, with full assurance of quality and reliability of supply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5202/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support the principle of free trade and the promotion of fair trade in agricultural commodities and products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5202/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support fully the negotiating objectives set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2901/b"},"text":"section 2901(b) of title 19","children":[],"tail":" to eliminate or reduce substantially constraints on fair and open trade in agricultural commodities and products;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5202/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use statutory authority to counter unfair foreign trade practices and to use all available means, including export promotion programs, and, if necessary, restrictions on United States imports of agricultural commodities and products, in order to encourage fair and open trade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefc478f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5202/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for increased representation of United States agricultural trade interests in the formulation of national fiscal and monetary policy affecting trade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefc478f6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/418/tIV/s4102"},"text":"Pub. L. 100–418, title IV, § 4102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-23"},"text":"Aug. 23, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1390"},"text":"102 Stat. 1390","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
