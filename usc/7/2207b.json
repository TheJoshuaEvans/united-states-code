{"tag":"section","attrib":{"id":"idef75bc9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2207b"},"text":"§ 2207b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program metrics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef75bc9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall collect data regarding economic activities created through grants and loans, including any technical assistance provided as a component of the grant or loan program, and measure the short- and long-term viability of award recipients and any entities to whom those recipients provide assistance using award funds, under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef75bc9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1627c"},"text":"section 1627c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef75bca0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s940c/b/2"},"text":"section 940c(b)(2) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef75bca1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 310B(c), 310B(e), 310B(g), 310H, or 379E, or subtitle E, of the Consolidated Farm and Rural Development Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1932/c"},"text":"7 U.S.C. 1932(c)","children":[],"tail":", 1932(e), 1932(g), [1936b], 2008s, 2009 et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef75bca2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The data collected under subsection (a) shall include information collected from recipients both during the award period and for a period of time, as determined by the Secretary, which is not less than 2 years after the award period ends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef75bca3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef75bca4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 4 years after ","children":[{"tag":"date","attrib":{"date":"2014-02-07"},"text":"February 7, 2014","children":[],"tail":", and every 2 years thereafter, the Secretary shall submit to the Committee on Agriculture of the House of Representatives and the Committee on Agriculture, Nutrition, and Forestry of the Senate a report that contains the data described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef75bca5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detailed information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall include detailed information regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef75bca6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions taken by the Secretary to use the data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef75bca7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage increase of employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef75bca8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of business starts and clients served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef75bca9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207b/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any benefit, such as an increase in revenue or customer base; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef75bcaa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2207b/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef75bcab-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVI/s6209"},"text":"Pub. L. 113–79, title VI, § 6209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/861"},"text":"128 Stat. 861","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10102/c/4"},"text":"Pub. L. 115–334, title X, § 10102(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4898"},"text":"132 Stat. 4898","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef75bcac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef75bcad-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef75bcae-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Consolidated Farm and Rural Development Act, referred to in subsec. (a)(3), is title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":". Subtitle E of the Act is classified generally to subchapter V (§ 2009 et seq.) of chapter 50 of this title. For complete classification of the Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef75bcaf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" added par. (1) and struck out former par. (1) which read as follows: “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1632a"},"text":"section 1632a of this title","children":[],"tail":";”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef75bcb0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idef75bcb1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” as meaning the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
