{"tag":"section","attrib":{"id":"ideffdb187-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212"},"text":null,"children":[{"tag":"num","attrib":{"value":"7212"},"text":"§ 7212.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffdb188-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for contracting","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffdb189-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commencement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the Secretary shall commence entering into contracts not later than 45 days after ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb18a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), the Secretary may not enter into a contract after ","children":[{"tag":"date","attrib":{"date":"1996-08-01"},"text":"August 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb18b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conservation reserve lands","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffdb18c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the beginning of each fiscal year, the Secretary shall allow an eligible owner or producer on a farm covered by a conservation reserve contract entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3831"},"text":"section 3831 of title 16","children":[],"tail":" that terminates after the date specified in paragraph (2) to enter into or expand a production flexibility contract to cover the contract acreage of the farm that was subject to the former conservation reserve contract."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffdb18d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Contract payments made for contract acreage under this paragraph shall be made at the rate and amount applicable to the annual contract payment level for the applicable crop. For the fiscal year in which the conservation reserve contract is terminated, the owner or producer subject to the production flexibility contract may elect to receive either contract payments or a prorated payment under the conservation reserve contract, but not both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb18e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of contract","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffdb18f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beginning date","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term of a contract shall begin with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffdb190-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 1996 crop of a contract commodity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffdb191-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of acreage that was subject to a conservation reserve contract described in subsection (a)(3), the date the production flexibility contract was entered into or expanded to cover the acreage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb192-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ending date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of a contract shall extend through the 2002 crop, unless earlier terminated by the owner or producer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb193-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Estimation of contract payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the time the Secretary enters into a contract, the Secretary shall provide an estimate of the minimum contract payments anticipated to be made during at least the first fiscal year for which contract payments will be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffdb194-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for payment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffdb195-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An annual contract payment shall be made not later than September 30 of each of fiscal years 1996 through 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb196-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance payments","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffdb197-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal year 1996","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the option of the owner or producer, 50 percent of the contract payment for fiscal year 1996 shall be made not later than 30 days after the date on which the contract is entered into and approved by the Secretary and the owner or producer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffdb198-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent fiscal years","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the option of the owner or producer for fiscal year 1997 and each subsequent fiscal year, 50 percent of the annual contract payment shall be made on December 15 or January 15 of the fiscal year. The owner or producer may change the date selected under this subparagraph for a subsequent fiscal year by providing advance notice to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffdb199-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7212/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding the requirements for making an annual contract payment specified in paragraphs (1) and (2), at the option of the owner or producer, the Secretary shall pay the full amount (or such portion as the owner or producer may specify) of the contract payment required to be paid for any of fiscal years 1999 through 2002 at such time or times during that fiscal year as the owner or producer may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffdb19a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s112"},"text":"Pub. L. 104–127, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/899"},"text":"110 Stat. 899","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/228/s2"},"text":"Pub. L. 105–228, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1516"},"text":"112 Stat. 1516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tVIII/s811"},"text":"Pub. L. 106–78, title VIII, § 811","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1181"},"text":"113 Stat. 1181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideffdb19b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideffdb19c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideffdb19d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78"},"text":"Pub. L. 106–78","children":[],"tail":", in par. heading, struck out “for fiscal year 1999” after “rule” and, in text, substituted “any of fiscal years 1999 through 2002” for “fiscal year 1999”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/228"},"text":"Pub. L. 105–228","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideffdb19e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"ideffdb19f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Production Flexibility Contract Payments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/170/tV/s525"},"text":"Pub. L. 106–170, title V, § 525","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-17"},"text":"Dec. 17, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1928"},"text":"113 Stat. 1928","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/147/tIV/s417/24/A"},"text":"Pub. L. 107–147, title IV, § 417(24)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-09"},"text":"Mar. 9, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/57"},"text":"116 Stat. 57","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/147/tIV/s417/24/A"},"text":"“Any option to accelerate the receipt of any payment under a production flexibility contract which is payable under the Federal Agriculture Improvement and Reform Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7201"},"text":"7 U.S.C. 7201","children":[],"tail":" et seq.), as in effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1999-12-17"},"text":"Dec. 17, 1999","children":[],"tail":"], shall be disregarded in determining the taxable year for which such payment is properly includible in gross income for purposes of the Internal Revenue Code of 1986 ["},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"26 U.S.C. 1","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dJ/tII/s2012"},"text":"Pub. L. 105–277, div. J, title II, § 2012","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-902"},"text":"112 Stat. 2681–902","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dJ/tII/s2012"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The options under paragraphs (2) and (3) of section 112(d) of the Federal Agriculture Improvement and Reform Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7212/d/2"},"text":"7 U.S.C. 7212(d)(2)","children":[],"tail":" and (3)), as in effect on the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":"], shall be disregarded in determining the taxable year for which any payment under a production flexibility contract under subtitle B of title I of such Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7211"},"text":"7 U.S.C. 7211","children":[],"tail":" et seq.] (as so in effect) is properly includible in gross income for purposes of the Internal Revenue Code of 1986 ["},{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"26 U.S.C. 1","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall apply to taxable years ending after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
