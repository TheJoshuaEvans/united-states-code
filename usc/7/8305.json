{"tag":"section","attrib":{"id":"idf03478df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8305"},"text":null,"children":[{"tag":"num","attrib":{"value":"8305"},"text":"§ 8305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate movement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may prohibit or restrict—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03478e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8305/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movement in interstate commerce of any animal, article, or means of conveyance if the Secretary determines that the prohibition or restriction is necessary to prevent the introduction or dissemination of any pest or disease of livestock; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03478e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8305/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of any means of conveyance or facility in connection with the movement in interstate commerce of any animal or article if the Secretary determines that the prohibition or restriction is necessary to prevent the introduction or dissemination of any pest or disease of livestock.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf03478e2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10406"},"text":"Pub. L. 107–171, title X, § 10406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/498"},"text":"116 Stat. 498","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
