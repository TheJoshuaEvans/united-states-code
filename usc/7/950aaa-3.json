{"tag":"section","attrib":{"id":"idee6843d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–3"},"text":null,"children":[{"tag":"num","attrib":{"value":"950aaa–3"},"text":"§ 950aaa–3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee6843d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–3/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that facilities constructed using financial assistance provided under this chapter do not duplicate adequate established telemedicine services or distance learning services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6843d5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–3/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan maturity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The maturities of cost of money loans shall be determined by the Secretary, based on the useful life of the facility being financed, except that the loan shall not be for a period of more than 10 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6843d6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–3/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan security and feasibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make a cost of money loan only if the Secretary determines that the security for the loan is reasonably adequate and that the loan will be repaid within the period of the loan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6843d7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–3/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouraging consortia","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall encourage the development of consortia to provide telemedicine services or distance learning services through telecommunications in rural areas served by a telecommunications provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6843d8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–3/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall coordinate, to the extent practicable, with other Federal and State agencies with similar grant or loan programs to pool resources for funding meritorious proposals in rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee6843d9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s950aaa–3/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Informational efforts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and implement procedures to carry out informational efforts to advise potential end users located in rural areas of each State about the program authorized by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee6843da-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2334"},"text":"Pub. L. 101–624, title XXIII, § 2334","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s704"},"text":"Pub. L. 104–127, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1111"},"text":"110 Stat. 1111","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee6843db-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idee6843dc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/551/s1/b"},"text":"section 1(b) of Pub. L. 102–551","children":[],"tail":", see Termination of Chapter note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s950aaa"},"text":"section 950aaa of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee6843dd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee6843de-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 950aaa–3, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2334"},"text":"Pub. L. 101–624, title XXIII, § 2334","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4019"},"text":"104 Stat. 4019","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/b/4/B"},"text":"Pub. L. 103–354, title II, § 235(b)(4)(B)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":", 3222, contained provisions relevant to telecommunications programs, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
