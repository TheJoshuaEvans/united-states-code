{"tag":"section","attrib":{"id":"idf0158011-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628"},"text":null,"children":[{"tag":"num","attrib":{"value":"7628"},"text":"§ 7628.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Support for research regarding diseases of wheat, triticale, and barley caused by Fusarium graminearum or by Tilletia indica","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0158012-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may make grants to consortia of land-grant colleges and universities to enhance the ability of the consortia to carry out multi-State research projects aimed at understanding and combating diseases of wheat, triticale, and barley caused by Fusarium graminearum and related fungi (referred to in this section as “wheat scab”) or by Tilletia indica and related fungi (referred to in this section as “Karnal bunt”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0158013-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds provided under this section shall be available for the following collaborative, multi-State research activities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0158014-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification and understanding of the epidemiology of wheat scab or of Karnal bunt, and the toxicological properties of vomitoxin, a toxic metabolite commonly occurring in wheat, triticale, and barley infected with wheat scab.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0158015-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of crop management strategies to reduce the risk of wheat scab or Karnal bunt occurrence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0158016-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Development of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0158017-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efficient and accurate methods to monitor wheat, triticale, and barley for the presence of Karnal bunt or of wheat scab and resulting vomitoxin contamination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0158018-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" post-harvest management techniques for wheat, triticale, and barley infected with wheat scab or with Karnal bunt; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0158019-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" milling and food processing techniques to render wheat scab contaminated grain safe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf015801a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strengthening and expansion of plant-breeding activities to enhance the resistance of wheat, triticale, and barley to wheat scab and to Karnal bunt, including the establishment of a regional advanced breeding material evaluation nursery and a germplasm introduction and evaluation system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf015801b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development and deployment of alternative fungicide application systems and formulations to control wheat scab and Karnal bunt and consideration of other chemical control strategies to assist farmers until new more resistant wheat, triticale, and barley varieties are available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf015801c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communications networks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided under this section shall be available for efforts to concentrate, integrate, and disseminate research, extension, and outreach-orientated information regarding wheat scab or Karnal bunt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf015801d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To oversee the use of a grant made under this section, the Secretary may establish a committee composed of the directors of the agricultural experiment stations in the States in which land-grant colleges and universities that are members of the consortium are located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf015801e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf015801f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as may be necessary for each of fiscal years 1999 through 2013;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0158020-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for each of fiscal years 2014 through 2018; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0158021-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0158022-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7628/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on indirect costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of a grant under this section may not use more than 10 percent of the funds provided by the grant for the indirect costs of carrying out the initiatives described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0158023-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/tIV/s408"},"text":"Pub. L. 105–185, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/574"},"text":"112 Stat. 574","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVII"},"text":"Pub. L. 107–171, title VII","children":[],"tail":", §§ 7131, 7207(d)(1)–(4)(A), "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/435"},"text":"116 Stat. 435","children":[],"tail":", 440, 441; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVII/s7307"},"text":"Pub. L. 110–234, title VII, § 7307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1242"},"text":"122 Stat. 1242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VII, § 7307, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2004; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVII/s7303"},"text":"Pub. L. 113–79, title VII, § 7303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/888"},"text":"128 Stat. 888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7303"},"text":"Pub. L. 115–334, title VII, § 7303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4815"},"text":"132 Stat. 4815","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0158024-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0158025-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf0158026-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf017c917-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7303/1"},"text":"Pub. L. 115–334, § 7303(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s7303/2"},"text":"Pub. L. 115–334, § 7303(2)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" amended subsec. (e) generally. Prior to amendment, text read as follows: “There is authorized to be appropriated to carry out this section such sums as may be necessary for each of fiscal years 1999 through 2012.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7307/1"},"text":"Pub. L. 110–246, § 7307(1)","children":[],"tail":", substituted “grants” for “grant” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s7307/2"},"text":"Pub. L. 110–246, § 7307(2)","children":[],"tail":", substituted “2012” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7207/d/4/A"},"text":"Pub. L. 107–171, § 7207(d)(4)(A)","children":[],"tail":", substituted “, triticale, and barley caused by Fusarium graminearum or by Tilletia indica” for “and barley caused by Fusarium graminearum” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7207/d/1"},"text":"Pub. L. 107–171, § 7207(d)(1)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “The Secretary of Agriculture may make a grant to a consortium of land-grant colleges and universities to enhance the ability of the consortium to carry out a multi-State research project aimed at understanding and combating diseases of wheat and barley caused by Fusarium graminearum and related fungi (referred to in this section as ‘wheat scab’).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7207/d/2/A"},"text":"Pub. L. 107–171, § 7207(d)(2)(A)","children":[],"tail":", (B), inserted “or of Karnal bunt,” after “epidemiology of wheat scab” and “, triticale,” after “occurring in wheat”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7207/d/2/C"},"text":"Pub. L. 107–171, § 7207(d)(2)(C)","children":[],"tail":", inserted “or Karnal bunt” after “wheat scab”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7207/d/2/D"},"text":"Pub. L. 107–171, § 7207(d)(2)(D)","children":[],"tail":", substituted “, triticale, and barley for the presence of Karnal bunt or of” for “and barley for the presence of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7207/d/2/E"},"text":"Pub. L. 107–171, § 7207(d)(2)(E)","children":[],"tail":", substituted “, triticale, and barley infected with wheat scab or with Karnal bunt” for “and barley infected with wheat scab”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7207/d/2/F"},"text":"Pub. L. 107–171, § 7207(d)(2)(F)","children":[],"tail":", inserted “wheat scab” after “to render”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7207/d/2/G"},"text":"Pub. L. 107–171, § 7207(d)(2)(G)","children":[],"tail":", substituted “, triticale, and barley to wheat scab and to Karnal bunt” for “and barley to wheat scab”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7207/d/2/H"},"text":"Pub. L. 107–171, § 7207(d)(2)(H)","children":[],"tail":", inserted “and Karnal bunt” after “wheat scab” and “, triticale,” after “resistant wheat”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7207/d/3"},"text":"Pub. L. 107–171, § 7207(d)(3)","children":[],"tail":", inserted “or Karnal bunt” after “wheat scab”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s7131"},"text":"Pub. L. 107–171, § 7131","children":[],"tail":", substituted “such sums as may be necessary” for “$5,200,000” and “2007” for “2002”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf017c918-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf017c919-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
