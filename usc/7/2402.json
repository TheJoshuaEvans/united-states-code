{"tag":"section","attrib":{"id":"idef841449-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402"},"text":null,"children":[{"tag":"num","attrib":{"value":"2402"},"text":"§ 2402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to plant variety protection; plant varieties protectable","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef84144a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The breeder of any sexually reproduced, tuber propagated, or asexually reproduced plant variety (other than fungi or bacteria) who has so reproduced the variety, or the successor in interest of the breeder, shall be entitled to plant variety protection for the variety, subject to the conditions and requirements of this chapter, if the variety is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef84144b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" new, in the sense that, on the date of filing of the application for plant variety protection, propagating or harvested material of the variety has not been sold or otherwise disposed of to other persons, by or with the consent of the breeder, or the successor in interest of the breeder, for purposes of exploitation of the variety—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef84144c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the United States, more than 1 year prior to the date of filing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef84144d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in any area outside of the United States—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef84144e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 4 years prior to the date of filing, except that in the case of a tuber propagated plant variety the Secretary may waive the 4-year limitation for a period ending 1 year after ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef84144f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a tree or vine, more than 6 years prior to the date of filing;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef841450-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distinct, in the sense that the variety is clearly distinguishable from any other variety the existence of which is publicly known or a matter of common knowledge at the time of the filing of the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef841451-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uniform, in the sense that any variations are describable, predictable, and commercially acceptable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef841452-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stable, in the sense that the variety, when reproduced, will remain unchanged with regard to the essential and distinctive characteristics of the variety with a reasonable degree of reliability commensurate with that of varieties of the same category in which the same breeding method is employed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef841453-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple applicants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef841454-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If 2 or more applicants submit applications on the same effective filing date for varieties that cannot be clearly distinguished from one another, but that fulfill all other requirements of subsection (a), the applicant who first complies with all requirements of this chapter shall be entitled to a certificate of plant variety protection, to the exclusion of any other applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef841455-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements completed on same date","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef841456-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), if 2 or more applicants comply with all requirements for protection on the same date, a certificate shall be issued for each variety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef841457-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2402/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Varieties indistinguishable","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the varieties that are the subject of the applications cannot be distinguished in any manner, a single certificate shall be issued jointly to the applicants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef841458-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/577/tII/s42"},"text":"Pub. L. 91–577, title II, § 42","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-24"},"text":"Dec. 24, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1547"},"text":"84 Stat. 1547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s3"},"text":"Pub. L. 103–349, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3138"},"text":"108 Stat. 3138","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIX/s913/a"},"text":"Pub. L. 104–127, title IX, § 913(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1186"},"text":"110 Stat. 1186","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tX/s10108/b"},"text":"Pub. L. 115–334, title X, § 10108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4906"},"text":"132 Stat. 4906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef841459-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef84145a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef84145b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “, tuber propagated, or asexually reproduced” for “or tuber propagated” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":" inserted “, except that in the case of a tuber propagated plant variety the Secretary may waive the 4-year limitation for a period ending 1 year after "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":"” after “filing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/349"},"text":"Pub. L. 103–349","children":[],"tail":" amended section generally, substituting present provisions for substantially similar former provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef84145c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idef84145d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/349"},"text":"Pub. L. 103–349","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1994-10-06"},"text":"Oct. 6, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/349/s15"},"text":"section 15 of Pub. L. 103–349","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2401"},"text":"section 2401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
