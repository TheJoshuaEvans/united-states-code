{"tag":"section","attrib":{"id":"idefd51af5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g"},"text":null,"children":[{"tag":"num","attrib":{"value":"5925g"},"text":"§ 5925g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urban, indoor, and other emerging agricultural production research, education, and extension initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefd51af6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive research and extension grants authorized","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In consultation with the Urban Agriculture and Innovative Production Advisory Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6923/b"},"text":"section 6923(b) of this title","children":[],"tail":", the Secretary may make competitive grants to support research, education, and extension activities for the purposes of facilitating the development of urban, indoor, and other emerging agricultural production, harvesting, transportation, aggregation, packaging, distribution, and markets, including by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd51af7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing and developing strategies to remediate contaminated sites;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51af8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining and developing the best production management and integrated pest management practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51af9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and promoting the horticultural, social, and economic factors that contribute to successful urban, indoor, and other emerging agricultural production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51afa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzing the means by which new agricultural sites are determined, including an evaluation of soil quality, condition of a building, or local community needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51afb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exploring new technologies that minimize energy, lighting systems, water, and other inputs for increased food production;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51afc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examining building material efficiencies and structural upgrades for the purpose of optimizing growth of agricultural products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51afd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing new crop varieties and agricultural products to connect to new markets; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51afe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examining the impacts of crop exposure to urban elements on environmental quality and food safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51aff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant types and process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subparagraphs (A) through (E) of paragraph (4), paragraph (7), and paragraph (11)(B) of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3157"},"text":"section 3157 of this title","children":[],"tail":" shall apply with respect to the making of grants under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51b00-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may give priority to grant proposals that involve—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd51b01-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cooperation of multiple entities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51b02-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States or regions with a high concentration of or significant interest in urban farms, rooftop farms, and indoor production facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefd51b03-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefd51b04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds of the Commodity Credit Corporation, the Secretary shall use to carry out this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefd51b05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2019, to remain available until expended; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefd51b06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for each of fiscal years 2024 through 2031.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefd51b07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s5925g/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to amounts made available under paragraph (1), there is authorized to be appropriated to carry out this section $10,000,000 for each of fiscal years 2019 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefd51b08-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXVI/s1672E"},"text":"Pub. L. 101–624, title XVI, § 1672E","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7212/a"},"text":"Pub. L. 115–334, title VII, § 7212(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4812"},"text":"132 Stat. 4812","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/dB/tI/s102/d/5/B"},"text":"Pub. L. 118–22, div. B, title I, § 102(d)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-11-17"},"text":"Nov. 17, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/117"},"text":"137 Stat. 117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/21/tI/s10604/a"},"text":"Pub. L. 119–21, title I, § 10604(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/109"},"text":"139 Stat. 109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefd51b09-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefd51b0a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefd51b0b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21"},"text":"Pub. L. 119–21","children":[],"tail":" substituted “each of fiscal years 2024 through 2031” for “fiscal year 2024, to remain available until expended”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" inserted dash after “section”, designated remainder of existing provisions as subpar. (A), and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idefd51b0c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idefd51b0d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/22"},"text":"Pub. L. 118–22","children":[],"tail":" to be applied and administered as if enacted on "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/22/s102/g"},"text":"section 102(g) of Pub. L. 118–22","children":[],"tail":", set out in an Extension of Agricultural Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
