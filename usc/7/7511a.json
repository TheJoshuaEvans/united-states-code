{"tag":"section","attrib":{"id":"idf010c481-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a"},"text":null,"children":[{"tag":"num","attrib":{"value":"7511a"},"text":"§ 7511a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency food program infrastructure grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf010c482-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of eligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “eligible entity” means an emergency feeding organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c483-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program authorized","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf010c484-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use funds made available under subsection (d) to make grants to eligible entities to pay the costs of an activity described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c485-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural preference","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall use not less than 50 percent of the funds described in paragraph (1) for a fiscal year to make grants to eligible entities that serve predominantly rural communities for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf010c486-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expanding the capacity and infrastructure of food banks, State-wide food bank associations, and food bank collaboratives that operate in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf010c487-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the capacity of the food banks to procure, receive, store, distribute, track, and deliver time-sensitive or perishable food products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c488-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An eligible entity shall use a grant received under this section for any fiscal year to carry out activities of the eligible entity, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf010c489-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the development and maintenance of a computerized system for the tracking of time-sensitive food products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c48a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital, infrastructure, and operating costs associated with the collection, storage, distribution, and transportation of time-sensitive and perishable food products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c48b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the security and diversity of the emergency food distribution and recovery systems of the United States through the support of small or mid-size farms and ranches, fisheries, and aquaculture, and donations from local food producers and manufacturers to persons in need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c48c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing recovered foods to food banks and similar nonprofit emergency food providers to reduce hunger in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c48d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" improving the identification of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf010c48e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential providers of donated foods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf010c48f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential nonprofit emergency food providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf010c490-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons in need of emergency food assistance in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf010c491-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constructing, expanding, or repairing a facility or equipment to support hunger relief agencies in the community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf010c492-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7511a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $15,000,000 for each of fiscal years 2008 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf01