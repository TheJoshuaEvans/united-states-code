{"tag":"section","attrib":{"id":"idef29712b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009f"},"text":"§ 2009f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef29712c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simple grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef29712d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make a grant to any eligible State for any fiscal year for which the State requests a grant under this section in an amount equal to 5 percent of the total amount allocated for the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009d/f"},"text":"section 2009d(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef29712e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permissive grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before July 15 of each fiscal year, the Secretary may make a grant to any State to defray the cost of any subsidy associated with a guarantee provided by an eligible public entity of the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009g"},"text":"section 2009g of this title","children":[],"tail":" in an amount that does not exceed 5 percent of the total amount allocated for the State under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009d/f"},"text":"section 2009d(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef29712f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make grants to a State under paragraphs (1) and (2) from amounts allocated for the State in the accounts specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009d/c"},"text":"section 2009d(c) of this title","children":[],"tail":", by reducing each such allocated amount by the same percentage."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297130-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef297131-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), the Secretary shall make a grant to any eligible State for any fiscal year for which the State requests a grant under this section in an amount equal to 5 percent of the amount allocated for the State for the fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009d/g"},"text":"section 2009d(g) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef297132-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State shall be eligible for a grant under paragraph (1) if the State makes commitments to the Secretary to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef297133-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expend from non-Federal sources in accordance with subsection (c) an amount that is not less than 200 percent of the amount of the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef297134-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the amounts paid to the State under this subsection and the amount referred to in subparagraph (A) in an account separate from all other State funds until expended in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef297135-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary makes a grant under paragraph (1) before July 15 of the fiscal year, the grant shall be made from amounts allocated for the State in the accounts specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009d/c"},"text":"section 2009d(c) of this title","children":[],"tail":" for the fiscal year, by reducing each allocated amount by the same percentage."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297136-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State to which funds are provided under this section shall use the funds in rural areas for any activity authorized under the authorities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009d/d"},"text":"section 2009d(d) of this title","children":[],"tail":" in accordance with the State strategic plan referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009c"},"text":"section 2009c of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297137-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of effort","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The State shall provide assurances to the Secretary that funds provided to the State under this section will be used only to supplement, not to supplant, the amount of Federal, State, and local funds otherwise expended for rural development assistance in the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297138-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide to a State an opportunity to appeal any action taken with respect to the State under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297139-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal funds shall not be used for any administrative costs incurred by a State in carrying out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef29713a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure of funds by State","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef29713b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Payments to a State from a grant under this section for a fiscal year shall be obligated by the State in the fiscal year or in the succeeding fiscal year. A State shall obligate funds under this section to provide assistance to rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef29713c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to obligate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State fails to obligate payments in accordance with paragraph (1), the Secretary shall make an equal reduction in the amount of payments provided to the State under this section for the immediately succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef29713d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef29713e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall review and monitor State compliance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef29713f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary finds that there has been misuse of grant funds provided under this section, or noncompliance with any of the terms and conditions of a grant, after reasonable notice and opportunity for a hearing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef297140-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/g/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall notify the State of the finding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef297141-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/g/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no further payments to the State shall be made with respect to the programs funded under this section until the Secretary is satisfied that there is no longer any failure to comply or that the noncompliance will be promptly corrected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef297142-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other sanctions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a finding of noncompliance made pursuant to subparagraph (B), the Secretary may, in addition to, or in lieu of, imposing the sanctions described in subparagraph (B), impose other appropriate sanctions, including recoupment of money improperly expended for purposes prohibited or not authorized by this section and disqualification from the receipt of financial assistance under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef297143-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No entitlement to contract, grant, or assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef297144-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entitles any person to assistance or a contract or grant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef297145-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009f/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limits the right of a State to impose additional limitations or conditions on assistance or a contract or grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef297146-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s381G"},"text":"Pub. L. 87–128, title III, § 381G","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s761"},"text":"Pub. L. 104–127, title VII, § 761","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1143"},"text":"110 Stat. 1143","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6026/c"},"text":"Pub. L. 107–171, title VI, § 6026(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/372"},"text":"116 Stat. 372","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef297147-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef297148-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef297149-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6026/c/1"},"text":"Pub. L. 107–171, § 6026(c)(1)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009d/f"},"text":"section 2009d(f) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009d/g"},"text":"section 2009d(g) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/s6026/c/2"},"text":"Pub. L. 107–171, § 6026(c)(2)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009d/g"},"text":"section 2009d(g) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2009d/h"},"text":"section 2009d(h) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
