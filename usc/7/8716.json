{"tag":"section","attrib":{"id":"idf03dee90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716"},"text":null,"children":[{"tag":"num","attrib":{"value":"8716"},"text":"§ 8716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer agreement required as condition of provision of payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf03dee91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with certain requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03dee92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the producers on a farm may receive direct payments, counter-cyclical payments, or average crop revenue election payments with respect to the farm, the producers shall agree, during the crop year for which the payments are made and in exchange for the payments—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03dee93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with applicable conservation requirements under subtitle B of title XII of the Food Security Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3811"},"text":"16 U.S.C. 3811","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03dee94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with applicable wetland protection requirements under subtitle C of title XII of that Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3821"},"text":"16 U.S.C. 3821","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03dee95-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to comply with the planting flexibility requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8717"},"text":"section 8717 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03dee96-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use the land on the farm, in a quantity equal to the attributable base acres for the farm and any base acres for peanuts for the farm under subchapter III, for an agricultural or conserving use, and not for a nonagricultural commercial, industrial, or residential use, as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03dee97-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to effectively control noxious weeds and otherwise maintain the land in accordance with sound agricultural practices, as determined by the Secretary, if the agricultural or conserving use involves the noncultivation of any portion of the land referred to in subparagraph (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee98-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may issue such rules as the Secretary considers necessary to ensure producer compliance with the requirements of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee99-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Modification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of the transferee or owner, the Secretary may modify the requirements of this subsection if the modifications are consistent with the objectives of this subsection, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03dee9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer or change of interest in farm","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03dee9b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03dee9c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), a transfer of (or change in) the interest of the producers on a farm in base acres for which direct payments or counter-cyclical payments are made, or on which average crop revenue election payments are based, shall result in the termination of the direct payments, counter-cyclical payments, or average crop revenue election payments to the extent the payments are made or based on the base acres, unless the transferee or owner of the acreage agrees to assume all obligations under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03dee9d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The termination shall take effect on the date determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03dee9e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a producer entitled to a direct payment, counter-cyclical payment, or average crop revenue election payment dies, becomes incompetent, or is otherwise unable to receive the payment, the Secretary shall make the payment, in accordance with rules issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03dee9f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03deea0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acreage reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition on the receipt of any benefits under this subchapter or subchapter II, the Secretary shall require producers on a farm to submit to the Secretary annual acreage reports with respect to all cropland on the farm.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deea1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Production reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition on the receipt of any benefits under this subchapter or subchapter II, the Secretary shall require producers on a farm that receive payments under section 8715 ","children":[{"tag":"ref","attrib":{"idref":"fn002375"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002375"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title to submit to the Secretary annual production reports with respect to all covered commodities and peanuts produced on the farm."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deea2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No penalty with respect to benefits under this subchapter or subchapter II shall be assessed against the producers on a farm for an inaccurate acreage or production report unless the producers on the farm knowingly and willfully falsified the acreage or production report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03deea3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tenants and sharecroppers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this subchapter, the Secretary shall provide adequate safeguards to protect the interests of tenants and sharecroppers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03deea4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing of payments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the sharing of direct payments, counter-cyclical payments, or average crop revenue election payments among the producers on a farm on a fair and equitable basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03deea5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of 2008 signup","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03deea6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary shall extend the 2008 crop year deadline for the signup for benefits under this subchapter by producers on a farm with base acres of 10 acres or less until the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03deea7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2008-11-14"},"text":"November 14, 2008","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03deea8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the end of the 45-day period beginning on ","children":[{"tag":"date","attrib":{"date":"2008-10-13"},"text":"October 13, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03deea9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8716/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that no penalty with respect to benefits under this subchapter or subchapter II is assessed against producers on a farm described in paragraph (1) for failure to submit reports under this section or timely comply with other program requirements as a result of compliance with the extended signup deadline under that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf03deeaa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1106"},"text":"Pub. L. 110–234, title I, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/949"},"text":"122 Stat. 949","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1106, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1677; "},{"tag":"ref","attrib":{"href":"/us/pl/110/398/s1/b/1"},"text":"Pub. L. 110–398, § 1(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4213"},"text":"122 Stat. 4213","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf03deeab-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf03deeac-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf03deead-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Food Security Act of 1985, referred to in subsec. (a)(1)(A), (B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/198"},"text":"Pub. L. 99–198","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1354"},"text":"99 Stat. 1354","children":[],"tail":". Subtitles B and C of title XII of the Act are classified generally to subchapters II (§ 3811 et seq.) and III (§ 3821 et seq.), respectively, of chapter 58 of Title 16, Conservation. For complete classification of this Act to the Code, see Short Title of 1985 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1281"},"text":"section 1281 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s8715"},"text":"Section 8715 of this title","children":[],"tail":", referred to in subsec. (c)(2), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1103/a"},"text":"Pub. L. 113–79, title I, § 1103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/658"},"text":"128 Stat. 658","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf03deeae-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf03deeaf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/398"},"text":"Pub. L. 110–398","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf03deeb0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf03deeb1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4"},"text":"section 4 of Pub. L. 110–246","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8701"},"text":"section 8701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
