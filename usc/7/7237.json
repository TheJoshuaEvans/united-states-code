{"tag":"section","attrib":{"id":"ideffffb7e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237"},"text":null,"children":[{"tag":"num","attrib":{"value":"7237"},"text":"§ 7237.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of recourse loans for high moisture feed grains and seed cotton and other fibers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffffb7f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High moisture feed grains","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffb80-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recourse loans available","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of the 1996 through 2002 crops of corn and grain sorghum, the Secretary shall make available recourse loans, as determined by the Secretary, to producers on a farm containing eligible cropland covered by a production flexibility contract who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffffb81-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" normally harvest all or a portion of their crop of corn or grain sorghum in a high moisture state;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffffb82-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" present—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideffffb83-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified scale tickets from an inspected, certified commercial scale, including a licensed warehouse, feedlot, feed mill, distillery, or other similar entity approved by the Secretary, pursuant to regulations issued by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideffffb84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" field or other physical measurements of the standing or stored crop in regions of the United States, as determined by the Secretary, that do not have certified commercial scales from which certified scale tickets may be obtained within reasonable proximity of harvest operation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffffb85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that they were the owners of the feed grain at the time of delivery to, and that the quantity to be placed under loan under this subsection was in fact harvested on the farm and delivered to, a feedlot, feed mill, or commercial or on-farm high-moisture storage facility, or to a facility maintained by the users of corn and grain sorghum in a high moisture state; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffffb86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with deadlines established by the Secretary for harvesting the corn or grain sorghum and submit applications for loans under this subsection within deadlines established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility of acquired feed grains","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A loan under this subsection shall be made on a quantity of corn or grain sorghum of the same crop acquired by the producer equivalent to a quantity determined by multiplying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideffffb88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acreage of the corn or grain sorghum in a high moisture state harvested on the producer’s farm; by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideffffb89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lower of the farm program payment yield or the actual yield on a field, as determined by the Secretary, that is similar to the field from which the corn or grain sorghum was obtained.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “High moisture state” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “high moisture state” means corn or grain sorghum having a moisture content in excess of Commodity Credit Corporation standards for marketing assistance loans made by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7231"},"text":"section 7231 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recourse loans available for seed cotton","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffb8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Upland cotton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of the 1996 through 2002 crops of upland cotton, the Secretary shall make available recourse seed cotton loans, as determined by the Secretary, to producers on a farm containing eligible cropland covered by a production flexibility contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extra long staple cotton","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each of the 1996 through 2002 crops of extra long staple cotton, the Secretary shall make available recourse seed cotton loans, as determined by the Secretary, on any production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recourse loans available for mohair","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffffb8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recourse loans available","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, during fiscal year 1999, the Secretary shall make available recourse loans, as determined by the Secretary, to producers of mohair produced during or before that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The loan rate for a loan under paragraph (1) shall be equal to $2.00 per pound.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A loan under paragraph (1) shall have a term of 1 year beginning on the first day of the first month after the month in which the loan is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffffb92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver of interest","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (d), the Secretary shall not charge interest on a loan made under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffffb93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7237/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment rates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Repayment of a recourse loan made under this section shall be at the loan rate established for the commodity by the Secretary, plus interest (as determined by the Secretary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffffb94-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s137"},"text":"Pub. L. 104–127, title I, § 137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/912"},"text":"110 Stat. 912","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/a/tXI/s1126"},"text":"Pub. L. 105–277, div. A, § 101(a) [title XI, § 1126]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681"},"text":"112 Stat. 2681","children":[],"tail":", 2681–46.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideffffb95-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideffffb96-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideffffb97-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/a/tXI/s1126/1"},"text":"Pub. L. 105–277, § 101(a) [title XI, § 1126(1)]","children":[],"tail":", inserted “and other fibers” after “seed cotton” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s101/a/tXI/s1126/2"},"text":"Pub. L. 105–277, § 101(a) [title XI, § 1126(2), (3)]","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
