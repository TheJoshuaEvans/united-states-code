{"tag":"section","attrib":{"id":"ideed13fab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1593a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1593a"},"text":"§ 1593a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seed variety information and survey","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideed13fac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1593a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideed13fad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1593a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grain submitted for public testing shall be evaluated for selected specific agronomic performance characteristics and intrinsic end-use performance characteristics, as determined by the Secretary, with the results of the evaluations made available to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideed13fae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1593a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissemination of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall disseminate varietal performance information obtained under paragraph (1) to plant breeders, producers, and end users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideed13faf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1593a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survey","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall periodically conduct, compile, and publish a survey of grain varieties commercially produced in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideed13fb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1593a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis of variety survey data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall analyze the variety surveys conducted under subsection (b) in conjunction with available applied research information on intrinsic quality characteristics of the varieties, to evaluate general intrinsic crop quality characteristics and trends in production related to intrinsic quality characteristics. This information shall be disseminated as required by subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideed13fb1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXX/s2013"},"text":"Pub. L. 101–624, title XX, § 2013","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3933"},"text":"104 Stat. 3933","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideed13fb2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideed13fb3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideed13fb4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Grain Quality Incentives Act of 1990, and also as part of the Food, Agriculture, Conservation, and Trade Act of 1990, and not as part of the Federal Seed Act which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
