{"tag":"section","attrib":{"id":"idf023d750-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7809"},"text":null,"children":[{"tag":"num","attrib":{"value":"7809"},"text":"§ 7809.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf023d751-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7809/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No information regarding names of voters or how a person voted in a referendum conducted under this chapter shall be made public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf023d752-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7809/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who knowingly violates subsection (a) or the confidentiality terms of an order, as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7804/m/2"},"text":"section 7804(m)(2) of this title","children":[],"tail":", shall be subject to a fine of not less that $1,000 nor more than $10,000 or to imprisonment for not more than 1 year, or both. If the person is an officer or employee of the Department of Agriculture or the Board, the person shall be removed from office."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf023d753-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7809/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No information obtained under this chapter may be made available to any agency or officer of the Federal Government for any purpose other than the implementation of this chapter or an investigatory or enforcement action necessary for the implementation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf023d754-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7809/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding information from Congress prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to authorize the withholding of information from Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf023d755-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/387/s1/a/tXII/s1210"},"text":"Pub. L. 106–387, § 1(a) [title XII, § 1210]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-28"},"text":"Oct. 28, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1549"},"text":"114 Stat. 1549","children":[],"tail":", 1549A–96.)"}],"tail":"\n"}],"tail":null}
