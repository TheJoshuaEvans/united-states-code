{"tag":"section","attrib":{"id":"idef69d5e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2109"},"text":null,"children":[{"tag":"num","attrib":{"value":"2109"},"text":"§ 2109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions applicable to amendments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef69d5e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provisions applicable to amendments to orders","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsection (b), the provisions of this chapter applicable to orders shall be applicable to amendments to orders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef69d5ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of amendments by cotton producers and importers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No amendment to an order issued under this chapter shall be effective unless the Secretary determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef69d5eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to an amendment referred to in subsection (b) or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2107"},"text":"section 2107 of this title","children":[],"tail":", the amendment is approved by producers and importers of cotton as provided in such section; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef69d5ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any other amendment, that the amendment is approved by a majority of cotton producers and importers subject to the order voting in the referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef69d5ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval of any amendment to order not deemed to invalidate such order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The disapproval of any amendment to an order issued under this chapter shall not be deemed to invalidate such order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef69d5ee-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/502/s10"},"text":"Pub. L. 89–502, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-07-13"},"text":"July 13, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/283"},"text":"80 Stat. 283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1995"},"text":"Pub. L. 101–624, title XIX, § 1995","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3912"},"text":"104 Stat. 3912","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tVIII/s808/a/3"},"text":"Pub. L. 102–237, title VIII, § 808(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1883"},"text":"105 Stat. 1883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef69d5ef-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef69d5f0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef69d5f1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “subsection (b) or (c) of section 2107” for “section 2107(b) or 2107(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624"},"text":"Pub. L. 101–624","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “The provisions of this chapter applicable to orders shall be applicable to amendments to orders.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
