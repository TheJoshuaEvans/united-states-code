{"tag":"section","attrib":{"id":"ideedab4f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1632d"},"text":"§ 1632d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dairy business innovation initiatives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedab4f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab4f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dairy business","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “dairy business” means a business that develops, produces, markets, or distributes dairy products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initiative","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “initiative” means a dairy product and business innovation initiative established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab4fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish not less than 3 regionally-located dairy product and business innovation initiatives for the purposes of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab4fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diversifying dairy product markets to reduce risk and develop higher-value uses for dairy products;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting business development that diversifies farmer income through processing and marketing innovation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab4fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the use of regional milk production.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab4ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of initiatives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An initiative—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab500-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be positioned to draw on existing dairy industry resources, including activities conducted by the National Dairy Promotion and Research Board and other dairy promotion entities, research capacity, academic and industry expertise, a density of dairy farms or farmland suitable for dairying, and dairy businesses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab501-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may serve a certain product niche, such as specialty cheese, or serve dairy businesses with dairy products derived from the milk of a specific type of dairy animal, including dairy products made from cow milk, sheep milk, and goat milk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab502-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entities eligible to host initiative","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab503-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), any of the following entities may submit to the Secretary an application to host an initiative:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab504-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State department of agriculture or other State entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab505-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A nonprofit organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab506-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab507-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A cooperative extension service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab508-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capacity of eligible entity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any entity described in subparagraphs (A) through (D) of paragraph (1) shall be eligible to submit an application under that paragraph if the entity has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab509-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a capacity to provide consultation and expertise necessary to advance the purpose and activities of the proposed initiative; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab50a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expertise in grant distribution and tracking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab50b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ineligible entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A dairy promotion program shall not be eligible to host an initiative under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab50c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partners","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab50d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity described in subsection (d)(1) may establish as a partner an organization or entity described in paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab50e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior to the submission of the application under that subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab50f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after approval of the application, in consultation with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab510-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partner described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A partner under paragraph (1) shall be an organization or entity with expertise or experience in dairy, including the marketing, research, education, or promotion of dairy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab511-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities of initiatives","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab512-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct assistance to dairy businesses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An initiative shall provide nonmonetary assistance directly to dairy businesses through private consultation or widely available distribution—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab513-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the entity that hosts the initiative under subsection (d)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab514-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through contracting with industry experts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab515-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through the provision of technical assistance, such as informational websites, webinars, conferences, trainings, plant tours, and field days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab516-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through research institutions, including cooperative extension services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab517-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of assistance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligible forms of assistance include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab518-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business consulting, including business plan development for processed dairy products, strategic planning assistance, and distribution and supply chain innovation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab519-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marketing and branding assistance, including market messaging, packaging innovation, consumer assessments, innovation in emerging market opportunities, and evaluation of regional, national, and international markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab51a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance in product innovation, including the development of value-added products, innovation in byproduct reprocessing and use maximization, and dairy product production training, including in new, rare, or innovative techniques; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab51b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other nonmonetary assistance, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab51c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to dairy businesses","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab51d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An initiative shall provide grants on a competitive basis to new and existing dairy businesses for the purposes of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedab51e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" modernization, specialization, and grazing transition on dairy farms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedab51f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" value chain and commodity innovation and facility and process updates for dairy processors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedab520-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" product development, packaging, and marketing of dairy products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab521-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to certain entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An initiative may provide a grant on a noncompetitive basis to an entity that receives assistance under paragraph (1) to advance the business activities recommended as a result of that assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab522-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants provided under this paragraph shall not exceed $500,000, unless a greater amount is approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab523-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An entity that hosts an initiative shall consult with the National Dairy Promotion and Research Board, the Secretary, and the Administrator of the Agricultural Marketing Service in carrying out the initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab524-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conflict of interest","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab525-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish guidelines and procedures to prevent any conflict of interest or the appearance of a conflict of interest by an initiative (including a partner of the initiative) during the allocation of direct assistance under paragraph (1) or grant funding under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab526-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may suspend or terminate an initiative if the initiative (including a partner of the initiative) is found to be in violation of the guidelines and procedures established under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab527-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedab528-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using the funds made available to carry out this section, the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab529-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide not less than 3 awards to eligible entities described in subsection (d) for the purposes of carrying out the activities under subsection (f); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab52a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is encouraged to award funds under subparagraph (A) in multiyear funding allocations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab52b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than 50 percent of the funds made available under subsection (i) shall be allocated to grants under subsection (f)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab52c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity hosting an initiative shall give priority to the provision of direct assistance under subsection (f)(1) and grants under subsection (f)(3) to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab52d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dairy farms and dairy businesses with limited access to other forms of assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab52e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee-owned dairy businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab52f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab530-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/g/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dairy businesses that seek to create dairy products that add substantial value in processing or marketing, such as specialty cheeses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab531-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Assistance or a grant shall not be made available to a foreign person making direct investment (as those terms are defined in section 801.2 of title 15, Code of Federal Regulations (or successor regulations)) in the United States in the case of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedab532-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct assistance under subsection (f)(1) that is provided to a specific dairy business and is not publicly available, as determined by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedab533-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a grant under subsection (f)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedab534-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the Secretary shall ensure that funds provided to an initiative supplement, and do not duplicate or replace, existing dairy product research, development, and promotion activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab535-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2022-01-31"},"text":"January 31, 2022","children":[],"tail":", the Secretary shall submit to Congress a report on the outcomes of the program under this section and any related activities and opportunities to further increase dairy innovation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedab536-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1632d/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $20,000,000 for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedab537-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXII/s12513"},"text":"Pub. L. 115–334, title XII, § 12513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4996"},"text":"132 Stat. 4996","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideedab538-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideedab539-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideedab53a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Agriculture Improvement Act of 2018, and not as part of the Agricultural Marketing Act of 1946 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideedab53b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"ideedab53c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition of “Secretary”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Secretary” means the Secretary of Agriculture, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s2"},"text":"section 2 of Pub. L. 115–334","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
