{"tag":"section","attrib":{"id":"idefb13edc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3812"},"text":null,"children":[{"tag":"num","attrib":{"value":"3812"},"text":"§ 3812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority in addition to other laws; effect on State laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authority conferred by this chapter shall be in addition to authority conferred by other statutes. Nothing in this chapter shall be construed to repeal or supersede any State law prohibiting the feeding of garbage to swine or to prohibit any State from enforcing requirements relating to the treatment of garbage to be fed to swine or the feeding thereof which are more stringent than those under this chapter or the regulations hereunder.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idefb13edd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/468/s12"},"text":"Pub. L. 96–468, § 12","children":[],"tail":", formerly § 13, "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2233"},"text":"94 Stat. 2233","children":[],"tail":"; renumbered § 12, "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tIX/s914/b/2"},"text":"Pub. L. 104–127, title IX, § 914(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1186"},"text":"110 Stat. 1186","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefb13ede-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefb13edf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idefb13ee0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/468/s12"},"text":"section 12 of Pub. L. 96–468","children":[],"tail":" was renumbered section 11 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s3811"},"text":"section 3811 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
