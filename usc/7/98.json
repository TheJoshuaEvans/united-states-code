{"tag":"section","attrib":{"id":"idedf361d2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s98"},"text":null,"children":[{"tag":"num","attrib":{"value":"98"},"text":"§ 98.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees and charges for naval stores inspection and related services; establishment, collection, etc.; authorization of appropriations; administrative expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedf361d3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s98/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Agriculture shall fix and cause to be collected fees and charges for the establishment of standards under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s93"},"text":"section 93 of this title","children":[],"tail":" and for examinations, analyses, classifications, and other services under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s94"},"text":"section 94 of this title","children":[],"tail":" which shall cover, as nearly as practicable, the costs of providing such services and standards as the Secretary shall deem necessary, including administrative and supervisory costs. Such fees and charges, when collected, shall be credited to the current appropriation account that incurs such costs and shall be available without fiscal year limitation to pay the expenses of the Secretary incident to providing such services and standards under this chapter. Fees and charges shall be assessed and collected from processors and warehousers of naval stores, and inspection and related services shall be suspended or denied to any such proc­essor or warehouser upon failure to timely pay the fees and charges assessed."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf361d4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s98/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are hereby authorized to be appropriated such sums as may be necessary for the enforcement and administration of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedf361d5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1923-03-03/ch217/s8"},"text":"Mar. 3, 1923, ch. 217, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1436"},"text":"42 Stat. 1436","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tI/s159/a/2"},"text":"Pub. L. 97–35, title I, § 159(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/376"},"text":"95 Stat. 376","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedf361d6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idedf361d7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idedf361d8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" added subsec. (a). Former unlettered provisions were designated subsec. (b) and, as so designated, struck out authorization of the Secretary to employ personnel and make administrative expenditures."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idedf361d9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idedf361da-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s159/b"},"text":"section 159(b) of Pub. L. 97–35","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s94"},"text":"section 94 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
