{"tag":"section","attrib":{"id":"idf009983d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7425"},"text":null,"children":[{"tag":"num","attrib":{"value":"7425"},"text":"§ 7425.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf009983e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7425/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf009983f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7425/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on expenditures for administrative expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds appropriated to carry out this subchapter may not be expended for the payment of expenses incurred by a board to administer an order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0099840-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s526"},"text":"Pub. L. 104–127, title V, § 526","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1048"},"text":"110 Stat. 1048","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
