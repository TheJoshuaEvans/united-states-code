{"tag":"section","attrib":{"id":"idee2f0b5c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a"},"text":null,"children":[{"tag":"num","attrib":{"value":"390a"},"text":"§ 390a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review process","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee2f0b5d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each proposal for an agricultural research facility shall be submitted to the Secretary for review. The Secretary shall review the proposals in the order in which the proposals are received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2f0b5e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In consultation with the congressional agriculture committees, the Secretary shall establish an application process for the submission of proposals for agricultural research facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2f0b5f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for approval","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee2f0b60-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to each proposal for an agricultural research facility submitted under subsection (a), the Secretary shall determine whether the proposal meets the criteria set forth in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2f0b61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A proposal for an agricultural research facility shall meet the following criteria:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee2f0b62-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal share","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proposal shall certify the availability of at least a 50 percent non-Federal share of the cost of the facility. The non-Federal share shall be paid in cash and may include funding from private sources or from units of State or local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee2f0b63-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonduplication of facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proposal shall demonstrate how the agricultural research facility would be complementary to, and not duplicative of, facilities of colleges, universities, and nonprofit institutions, and facilities of the Agricultural Research Service, within the State and region.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee2f0b64-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National research priorities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The proposal shall demonstrate how the agricultural research facility would serve—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee2f0b65-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more of the national research policies and priorities set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3101"},"text":"section 3101 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee2f0b66-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national or multistate needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee2f0b67-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-term support","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The proposal shall demonstrate that the recipient entity has the ability and commitment to support the long-term, ongoing operating and maintenance costs of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idee2f0b68-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agricultural research facility after the facility is completed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idee2f0b69-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each program to be based at the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2f0b6a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of proposals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after receiving a proposal under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee2f0b6b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and assess the merits of the proposal, including the extent to which the proposal meets the criteria set forth in subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2f0b6c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the congressional agriculture committees on the results of the evaluation and assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2f0b6d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s390a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National or multistate needs served by ARS facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that each research activity conducted by a facility of the Agricultural Research Service serves a national or multistate need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee2f0b6e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/74/s3"},"text":"Pub. L. 88–74, § 3","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVIII/s884/a"},"text":"Pub. L. 104–127, title VIII, § 884(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1177"},"text":"110 Stat. 1177","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/185/tI/s106/a"},"text":"Pub. L. 105–185, title I, § 106(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1998-06-23"},"text":"June 23, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/530"},"text":"112 Stat. 530","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVII/s7503/a/2"},"text":"Pub. L. 115–334, title VII, § 7503(a)(2)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4821"},"text":"132 Stat. 4821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2f0b6f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee2f0b70-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee2f0b71-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 390a, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/74/s2"},"text":"Pub. L. 88–74, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1963-07-22"},"text":"July 22, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/77/90"},"text":"77 Stat. 90","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1416/3"},"text":"Pub. L. 95–113, title XIV, § 1416(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/996"},"text":"91 Stat. 996","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/198/tXIV/s1411/b"},"text":"Pub. L. 99–198, title XIV, § 1411(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-23"},"text":"Dec. 23, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1547"},"text":"99 Stat. 1547","children":[],"tail":", related to congressional declaration of purpose, prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/74/s3"},"text":"section 3 of Pub. L. 88–74","children":[],"tail":" was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s390b"},"text":"section 390b of this title","children":[],"tail":" prior to the general amendment of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/127"},"text":"Pub. L. 104–127","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee2f0b72-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":", in introductory provisions, substituted “recipient entity” for “recipient college, university, or nonprofit institution” and “operating and maintenance costs” for “operating costs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(2)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s106/a"},"text":"Pub. L. 105–185, § 106(a)","children":[],"tail":", substituted “national or multistate needs” for “regional needs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/185/s106/b"},"text":"Pub. L. 105–185, § 106(b)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
