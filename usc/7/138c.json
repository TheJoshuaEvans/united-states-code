{"tag":"section","attrib":{"id":"idee14ccc3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138c"},"text":null,"children":[{"tag":"num","attrib":{"value":"138c"},"text":"§ 138c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Samples","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee14ccc4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance evaluation samples","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee14ccc5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provided by Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that performance evaluation samples are provided to any laboratory that has applied for accreditation under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee14ccc6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis by laboratory","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A laboratory described in paragraph (1) shall analyze such performance evaluation samples and submit the results of such analysis to the Secretary, as provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s138a"},"text":"section 138a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee14ccc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing methods","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Samples shall be tested by the laboratory according to methods specifically approved for such purpose by alternate methods of demonstrated adequacy or equivalence, as determined in regulations established under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee14ccc8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Results of testing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee14ccc9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The laboratory shall submit the results of the tests conducted under subsection (a) to the Secretary on forms provided by the Secretary, on or before the date determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee14ccca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of tests","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall evaluate the results of such tests achieved by the laboratory and shall determine whether such laboratory is capable of undertaking an accurate analysis of chemical residues in agricultural products.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee14cccb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s138c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of accreditation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that performance evaluation samples for analysis are provided to laboratories accredited under this chapter not less than two times a year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee14cccc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIII/s1324"},"text":"Pub. L. 101–624, title XIII, § 1324","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3564"},"text":"104 Stat. 3564","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
