{"tag":"section","attrib":{"id":"idedf11879-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87h"},"text":null,"children":[{"tag":"num","attrib":{"value":"87h"},"text":"§ 87h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idedf1187a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated $23,000,000 for standardization and compliance activities, monitoring in foreign ports grain officially inspected and weighed under this chapter, and any other expenses necessary to carry out the provisions of this chapter for each of the fiscal years 2021 through 2025,","children":[{"tag":"ref","attrib":{"idref":"fn002070"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002070"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Application of Section note below."}],"tail":" to the extent that financing is not obtained from fees and sales of samples as provided for in sections 79, 79a, 79b, 87e, and 87f–1 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idedf1187b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on uses of user fees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedf1187c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedf1187d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87h/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Official inspection or weighing service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “official inspection or weighing service” means official inspection, official weighing, supervision of weighing, supervision of agency personnel, supervision of the field office personnel of the Secretary, testing of equipment or instruments, other services, or registration, the cost to the Secretary of which is authorized to be covered by the collection of a user fee pursuant to section 79, 79a, 79b, 87e, or 87f–1 of this title, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedf1187e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87h/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" User fee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “user fee” means a fee collected by the Secretary under section 79, 79a, 79b, 87e, or 87f–1 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedf1187f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A user fee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedf11880-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87h/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be used solely to cover—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedf11881-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87h/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost to the Secretary for carrying out official inspection or weighing services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedf11882-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87h/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative costs to the Secretary directly relating to official inspection or weighing services; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedf11883-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87h/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not be used for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idedf11884-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87h/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities relating to the development or maintenance of grain standards; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idedf11885-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s87h/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activity that is not directly related to the performance of official inspection or weighing services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedf11886-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. B, § 19, as added "},{"tag":"ref","attrib":{"href":"/us/pl/90/487/s1"},"text":"Pub. L. 90–487, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-15"},"text":"Aug. 15, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/769"},"text":"82 Stat. 769","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/582/s21"},"text":"Pub. L. 94–582, § 21","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2886"},"text":"90 Stat. 2886","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXVI"},"text":"Pub. L. 95–113, title XVI","children":[],"tail":", §§ 1602(c), 1604(n), "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/1025"},"text":"91 Stat. 1025","children":[],"tail":", 1029; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tI/s155/4"},"text":"Pub. L. 97–35, title I, § 155(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/372"},"text":"95 Stat. 372","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/469/s2/3"},"text":"Pub. L. 98–469, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-11"},"text":"Oct. 11, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1832"},"text":"98 