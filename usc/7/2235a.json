{"tag":"section","attrib":{"id":"idef7806df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2235a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2235a"},"text":"§ 2235a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit and retention of credit card refunds or rebates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"2001-11-28"},"text":"November 28, 2001","children":[],"tail":", refunds or rebates received on an on-going basis from a credit card services provider under the Department of Agriculture’s charge card programs may be deposited to and retained without fiscal year limitation in the Department’s Working Capital Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2235"},"text":"section 2235 of this title","children":[],"tail":" and used to fund management initiatives of general benefit to the Department of Agriculture bureaus and offices as determined by the Secretary of Agriculture or the Secretary’s designee."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef7806e0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/76/tVII/s729"},"text":"Pub. L. 107–76, title VII, § 729","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-28"},"text":"Nov. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/736"},"text":"115 Stat. 736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef7806e1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef7806e2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"no