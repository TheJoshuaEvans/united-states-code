{"tag":"section","attrib":{"id":"idee59ecbc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c"},"text":null,"children":[{"tag":"num","attrib":{"value":"918c"},"text":"§ 918c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural and remote communities electrification grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee59ecbd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee59ecbe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “eligible grantee” means a local government or municipality, peoples’ utility district, irrigation district, and cooperative, nonprofit, or limited-dividend association in a rural area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ecbf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “incremental hydropower” means additional generation achieved from increased efficiency after ","children":[{"tag":"date","attrib":{"date":"2005-01-01"},"text":"January 1, 2005","children":[],"tail":", at a hydroelectric dam that was placed in service before "},{"tag":"date","attrib":{"date":"2005-01-01"},"text":"January 1, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ecc0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “renewable energy” means electricity generated from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee59ecc1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a renewable energy source; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee59ecc2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydrogen, other than hydrogen produced from a fossil fuel, that is produced from a renewable energy source.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ecc3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “renewable energy source” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idee59ecc4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wind;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee59ecc5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ocean waves;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee59ecc6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" biomass;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee59ecc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solar;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee59ecc8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" landfill gas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee59ecc9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incremental hydropower;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee59ecca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" livestock methane; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idee59eccb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geothermal energy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59eccc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “rural area” means a city, town, or unincorporated area that has a population of not more than 10,000 inhabitants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee59eccd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Secretary of Agriculture and the Secretary of the Interior, may provide grants under this section to eligible grantees for the purpose of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee59ecce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing energy efficiency, siting or upgrading transmission and distribution lines serving rural areas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59eccf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing or modernizing electric generation facilities that serve rural areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee59ecd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee59ecd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall make grants under this section based on a determination of cost-effectiveness and the most effective use of the funds to achieve the purposes described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ecd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each fiscal year, the Secretary shall allocate grant funds under this section equally between the purposes described in paragraphs (1) and (2) of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee59ecd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In making grants for the purposes described in subsection (b)(2), the Secretary shall give preference to renewable energy facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee59ecd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s918c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $20,000,000 for each of fiscal years 2006 through 2012.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee59ecd5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/617/tVI/s609"},"text":"Pub. L. 95–617, title VI, § 609","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tII/s209"},"text":"Pub. L. 109–58, title II, § 209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/657"},"text":"119 Stat. 657","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee59ecd6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee59ecd7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idee59ecd8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Public Utility Regulatory Policies Act of 1978, and not as part of the Rural Electrification Act of 1936 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idee59ecd9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idee59ecda-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Secretary means the Secretary of Energy, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s2602/14"},"text":"section 2602(14) of Title 16","children":[],"tail":", Conservation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
