{"tag":"section","attrib":{"id":"idee684406-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s957"},"text":null,"children":[{"tag":"num","attrib":{"value":"957"},"text":"§ 957.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee684407-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s957/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” includes individuals, partnerships, corporations, and associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee684408-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s957/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee684409-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-06-24/ch745/s7"},"text":"June 24, 1936, ch. 745, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1899"},"text":"49 Stat. 1899","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
