{"tag":"section","attrib":{"id":"idefdc4779-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6108"},"text":null,"children":[{"tag":"num","attrib":{"value":"6108"},"text":"§ 6108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations and power to subpoena","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefdc477a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make such investigations as the Secretary considers necessary for the effective administration of this chapter or to determine whether any person subject to this chapter has engaged or is engaging in any act that constitutes a violation of this chapter or of any order, rule, or regulation issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc477b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subpoenas, oaths, and affirmations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefdc477c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of an investigation made under subsection (a), the Secretary may administer oaths and affirmations and issue a subpoena to require the production of any records that are relevant to the inquiry. The production of any such records may be required from any place in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefdc477d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative hearings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For the purpose of an administrative hearing held under section 6106 or 6107 of this title, the presiding officer is authorized to administer oaths and affirmations, subpoena witnesses, compel their attendance, take evidence, and require the production of any records that are relevant to the inquiry. Such attendance of witnesses and the production of any such records may be required from any place in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc477e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aid of courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In case of contumacy by, or refusal to obey a subpoena issued to, any person, the Secretary may invoke the aid of any court of the United States within the jurisdiction of which such investigation or proceeding is carried on, or where such person resides or carries on business, in order to enforce a subpoena issued by the Secretary under subsection (b). The court may issue an order requiring such person to comply with such a subpoena.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc477f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contempt","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any failure to obey such order of the court may be punished by such court as a contempt thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc4780-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6108/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Process in any such case may be served in the judicial district in which such person resides or conducts business or wherever such person may be found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefdc4781-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6108/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hearing site","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The site of any hearings held under section 6106 or 6107 of this title shall be within the judicial district where such person resides or has a principal place of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefdc4782-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1929"},"text":"Pub. L. 101–624, title XIX, § 1929","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3864"},"text":"104 Stat. 3864","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tVIII/s803/3"},"text":"Pub. L. 102–237, title VIII, § 803(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1882"},"text":"105 Stat. 1882","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefdc4783-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefdc4784-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefdc4785-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" struck out “section” after “6106 or”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
