{"tag":"section","attrib":{"id":"idef8b18db-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2666"},"text":null,"children":[{"tag":"num","attrib":{"value":"2666"},"text":"§ 2666.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef8b18dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2666/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “rural development” means the planning, financing, and development of facilities and services in rural areas that contribute to making those areas desirable places in which to live and make private and business investments; the planning, development, and expansion of business and industry in rural areas to provide increased employment and income; the planning, development, conservation, and use of land, water, and other natural resources of rural areas to maintain or improve the quality of the environment for people and business in rural areas; and the building or improvement of institutional, organizational, and leadership capacities of rural citizens and leaders to define and resolve their own community problems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b18dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2666/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means the several States, the Commonwealth of Puerto Rico, Guam, American Samoa, the Virgin Islands of the United States, and the Commonwealth of the Northern Mariana Islands; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef8b18de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2666/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “small farm” means any farm (1) producing family net income from all sources (farm and nonfarm) below the median nonmetropolitan income of the State; (2) operated by a family dependent on farming for a significant though not necessarily a majority of its income; and (3) on which family members provide most of the labor and management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef8b18df-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/419/tV/s506"},"text":"Pub. L. 92–419, title V, § 506","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1444/a"},"text":"Pub. L. 97–98, title XIV, § 1444(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1326"},"text":"95 Stat. 1326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef8b18e0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef8b18e1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idef8b18e2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2666, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/419/tV/s506"},"text":"Pub. L. 92–419, title V, § 506","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-30"},"text":"Aug. 30, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/674"},"text":"86 Stat. 674","children":[],"tail":", related to withholding of funds, the keeping of a separate account in the Treasury, appeal by a State to Congress, covering of moneys into the Treasury, and State money replacement, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/tXIV/s1444/a"},"text":"Pub. L. 97–98, title XIV, § 1444(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/1326"},"text":"95 Stat. 1326","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising this section were contained in former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2667"},"text":"section 2667 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/98"},"text":"Pub. L. 97–98","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef8b18e3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef8b18e4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-12-22"},"text":"Dec. 22, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/98/s1801"},"text":"section 1801 of Pub. L. 97–98","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4301"},"text":"section 4301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
