{"tag":"section","attrib":{"id":"idef9be2b2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3171"},"text":null,"children":[{"tag":"num","attrib":{"value":"3171"},"text":"§ 3171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional findings and declaration of policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef9be2b3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3171/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Congress finds that there is increasing evidence of a relationship between diet and many of the leading causes of death in the United States: that improved nutrition is an integral component of preventive health care; that there is a serious need for research on the chronic effects of diet on degenerative diseases and related disorders; that nutrition and health considerations are important to United States agricultural policy; that there is insufficient knowledge concerning precise human nutritional requirements, the interaction of the various nutritional constituents of food, and differences in nutritional requirements among different population groups such as infants, children, adolescents, elderly men and women, and pregnant women; and that there is a critical need for objective data concerning food safety, the potential of food enrichment, and means to encourage better nutritional practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef9be2b4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s3171/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration of policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is declared to be the policy of the United States that the Department of Agriculture conduct research in the fields of human nutrition and the nutritive value of foods and conduct human nutrition education activities, as provided in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef9be2b5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/113/tXIV/s1421"},"text":"Pub. L. 95–113, title XIV, § 1421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-09-29"},"text":"Sept. 29, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/999"},"text":"91 Stat. 999","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef9be2b6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef9be2b7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idef9be2b8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"Oct. 1, 1977","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/113/s1901"},"text":"section 1901 of Pub. L. 95–113","children":[],"tail":", set out as an Effective Date of 1977 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1307"},"text":"section 1307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef9be2b9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Nutrition Information and Awareness Pilot Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tIV/s4403"},"text":"Pub. L. 107–171, title IV, § 4403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/334"},"text":"116 Stat. 334","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tIV/s4406/c/2"},"text":"Pub. L. 110–234, title IV, § 4406(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1142"},"text":"122 Stat. 1142","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title IV, § 4406(c)(2), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1903, directed the Secretary of Agriculture to establish, in not more than 5 States, for a period not to exceed 4 years for each participating State, a pilot program to increase the domestic consumption of fresh fruits and vegetables, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIV/s4210"},"text":"Pub. L. 113–79, title IV, § 4210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/830"},"text":"128 Stat. 830","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
