{"tag":"section","attrib":{"id":"idef22453c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2001a"},"text":null,"children":[{"tag":"num","attrib":{"value":"2001a"},"text":"§ 2001a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Debt restructuring and loan servicing for community facility loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish and implement a program that is similar to the program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2001"},"text":"section 2001 of this title","children":[],"tail":", except that the debt restructuring and loan servicing procedures shall apply to delinquent community facility program loans (rather than delinquent farmer program loans) made by the Farmers Home Administration to a hospital or health care facility under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1926/a"},"text":"section 1926(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idef22453d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s353A"},"text":"Pub. L. 87–128, title III, § 353A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2384/a"},"text":"Pub. L. 101–624, title XXIII, § 2384(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4050"},"text":"104 Stat. 4050","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef22453e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idef22453f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idef224540-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2384/b"},"text":"Pub. L. 101–624, title XXIII, § 2384(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4050"},"text":"104 Stat. 4050","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/624/tXXIII/s2384/b"},"text":"“Not later than 120 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":"], the Secretary shall promulgate regulations, modeled after those promulgated under such section 353 ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2001"},"text":"7 U.S.C. 2001","children":[],"tail":"], that implement the program established under section 353A of the Consolidated Farm and Rural Development Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2001a"},"text":"7 U.S.C. 2001a","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
