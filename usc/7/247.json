{"tag":"section","attrib":{"id":"idee2324ba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s247"},"text":null,"children":[{"tag":"num","attrib":{"value":"247"},"text":"§ 247.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fair treatment in storage of agricultural products","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idee2324bb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s247/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the capacity of a warehouse, a warehouse operator shall deal, in a fair and reasonable manner, with persons storing, or seeking to store, an agricultural product in the warehouse if the agricultural product—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee2324bc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s247/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of the kind, type, and quality customarily stored or handled in the area in which the warehouse is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324bd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s247/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is tendered to the warehouse operator in a suitable condition for warehousing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee2324be-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s247/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is tendered in a manner that is consistent with the ordinary and usual course of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idee2324bf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s247/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section prohibits a warehouse operator from entering into an agreement with a depositor of an agricultural product to allocate available storage space.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee2324c0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 8, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/472/tII/s201"},"text":"Pub. L. 106–472, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2065"},"text":"114 Stat. 2065","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2324c1-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee2324c2-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idee2324c3-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 247, acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, § 6, "},{"tag":"ref","attrib":{"href":"/us/stat/39/486"},"text":"39 Stat. 486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1919-07-24/ch26"},"text":"July 24, 1919, ch. 26","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/266"},"text":"41 Stat. 266","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1923-02-23/ch106"},"text":"Feb. 23, 1923, ch. 106","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1283"},"text":"42 Stat. 1283","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1931-03-02/ch366/s2"},"text":"Mar. 2, 1931, ch. 366, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/1463"},"text":"46 Stat. 1463","children":[],"tail":", required bond as condition to granting of license and additional bonds if first bond determined to become insufficient, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s245"},"text":"section 245 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 8 of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-08-11/ch313"},"text":"act Aug. 11, 1916, ch. 313","children":[],"tail":", pt. C, was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s250"},"text":"section 250 of this title","children":[],"tail":", prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/472"},"text":"Pub. L. 106–472","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
