{"tag":"section","attrib":{"id":"idefe37341-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6409"},"text":null,"children":[{"tag":"num","attrib":{"value":"6409"},"text":"§ 6409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe37342-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The order shall provide that each fluid milk processor shall pay an assessment on each unit of fluid milk product that such person processes and markets commercially in consumer-type packages in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe37343-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No effect on producer prices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such assessments shall not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe37344-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6409/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the prices paid under the Federal milk marketing orders issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s608c"},"text":"section 608c of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe37345-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6409/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise be deducted from the amounts that handlers must pay to producers for fluid milk products sold to a processor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe37346-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6409/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise be deducted from the price of milk paid to a producer by a handler, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe37347-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6409/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remitting assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe37348-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6409/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Assessments required under subsection (a) shall be remitted by the fluid milk processor directly to the Board in accordance with the order and regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe37349-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6409/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time to remit assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each processor who is responsible for the remittance of an assessment under paragraph (1) shall remit the assessment to the Board not later than the last day of the month following the month that the milk being assessed was marketed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe3734a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6409/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Remittances shall be verified by market administrators and State regulatory officials, and local and State Agricultural Stabilization and Conservation Service offices, as provided by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe3734b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6409/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than one assessment may be assessed under this section for the purposes of this chapter on a processor for any unit of fluid milk product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe3734c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6409/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Producer-handlers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Producer-handlers that are required to pay the assessment imposed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s4504/g"},"text":"section 4504(g) of this title","children":[],"tail":", and that are fluid milk processors, shall also be responsible for the additional assessment imposed by this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe3734d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6409/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Processor assessment rate","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6415/b"},"text":"section 6415(b) of this title","children":[],"tail":", the rate of assessment prescribed by the order shall be 20 cents per hundredweight of fluid milk products marketed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe3734e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1999J"},"text":"Pub. L. 101–624, title XIX, § 1999J","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3921"},"text":"104 Stat. 3921","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/72/s2/b"},"text":"Pub. L. 103–72, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-11"},"text":"Aug. 11, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/717"},"text":"107 Stat. 717","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe3734f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe37350-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe37351-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/72"},"text":"Pub. L. 103–72","children":[],"tail":" inserted “, and that are fluid milk processors,” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t7/s4504/g"},"text":"section 4504(g) of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
