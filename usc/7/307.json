{"tag":"section","attrib":{"id":"idee256e61-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s307"},"text":null,"children":[{"tag":"num","attrib":{"value":"307"},"text":"§ 307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for locating land scrip","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The land officers shall receive the same fees for locating land scrip issued under the provisions of this subchapter as was on ","children":[{"tag":"date","attrib":{"date":"1862-07-02"},"text":"July 2, 1862","children":[],"tail":", allowed for the location of military bounty land warrants under laws existing at that time: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That their maximum compensation shall not be thereby increased."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee256e62-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1862-07-02/ch130/s7"},"text":"July 2, 1862, ch. 130, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/12/505"},"text":"12 Stat. 505","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
