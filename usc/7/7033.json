{"tag":"section","attrib":{"id":"ideffb3ffa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7033"},"text":null,"children":[{"tag":"num","attrib":{"value":"7033"},"text":"§ 7033.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of agency information technology funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideffb3ffb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7033/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reservation of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From funds made available for agencies of the Department specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7031/b"},"text":"section 7031(b) of this title","children":[],"tail":" for information technology or information resource management, the Secretary shall reserve from those agencies’ applicable accounts a total amount equal to not more than the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffb3ffc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7033/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2001, $3,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb3ffd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7033/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For each subsequent fiscal year, $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffb3ffe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7033/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time for reservation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify Congress of the amount to be reserved under subsection (a) for a fiscal year not later than December 1 of that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffb3fff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7033/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideffb4000-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7033/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds reserved under subsection (a) shall be used to establish the Internet-based system required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7031"},"text":"section 7031 of this title","children":[],"tail":" and to expand the system as required by "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s7032"},"text":"section 7032 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideffb4001-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7033/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Once the system is established and operational, reserved amounts shall be used for maintenance and improvement of the system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideffb4002-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7033/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds reserved under subsection (a) and unobligated at the end of the fiscal year shall be returned to the agency from which the funds were reserved, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideffb4003-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/222/s4"},"text":"Pub. L. 106–222, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/354"},"text":"114 Stat. 354","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
