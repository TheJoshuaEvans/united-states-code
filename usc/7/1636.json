{"tag":"section","attrib":{"id":"ideedd2680-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636"},"text":null,"children":[{"tag":"num","attrib":{"value":"1636"},"text":"§ 1636.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedd2681-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make available to the public information, statistics, and documents obtained from, or submitted by, packers, retail entities, and other persons under this subchapter in a manner that ensures that confidentiality is preserved regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedd2682-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of persons, including parties to a contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2683-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proprietary business information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedd2684-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure by Federal Government employees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedd2685-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraph (2), no officer, employee, or agent of the United States shall, without the consent of the packer or other person concerned, divulge or make known in any manner, any facts or information regarding the business of the packer or other person that was acquired through reporting required under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd2686-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information obtained by the Secretary under this subchapter may be disclosed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedd2687-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to agents or employees of the Department of Agriculture in the course of their official duties under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd2688-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as directed by the Secretary or the Attorney General, for enforcement purposes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedd2689-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a court of competent jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd268a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure under Freedom of Information Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, no facts or information obtained under this subchapter shall be disclosed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedd268b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting by packers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A packer shall report all information required under this subchapter on an individual lot basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedd268c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional reporting and aggregation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make information obtained under this subchapter available to the public only in a manner that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedd268d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that the information is published on a national and a regional or statewide basis as the Secretary determines to be appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd268e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures that the identity of a reporting person is not disclosed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedd268f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conforms to aggregation guidelines established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedd2690-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adjustments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Prior to the publication of any information required under this subchapter, the Secretary may make reasonable adjustments in information reported by packers to reflect price aberrations or other unusual or unique occurrences that the Secretary determines would distort the published information to the detriment of producers, packers, or other market participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedd2691-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take such actions as the Secretary considers necessary to verify the accuracy of the information submitted or reported under part B, C, or D of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedd2692-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic reporting and publishing","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedd2693-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the maximum extent practicable, provide for the reporting and publishing of the information required under this subchapter by electronic means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6f84-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvements and education","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"ideedf6f85-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced electronic publishing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop and implement an enhanced system of electronic publishing to disseminate information collected pursuant to this subchapter. Such system shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedf6f86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present information in a format that can be readily understood by producers, packers, and other market participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf6f87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adhere to the publication deadlines in this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf6f88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/g/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present information in charts and graphs, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf6f89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/g/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present comparative information for prior reporting periods, as the Secretary considers appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf6f8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/g/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be updated as soon as practicable after information is reported to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"ideedf6f8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Education","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall carry out a market news education program to educate the public and persons in the livestock and meat industries about—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"ideedf6f8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" usage of the system developed under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"ideedf6f8d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interpreting and understanding information collected and disseminated through such system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6f8e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting of activities on weekends and holidays","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6f8f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Livestock committed to a packer, or purchased, sold, or slaughtered by a packer, on a weekend day or holiday shall be reported by the packer to the Secretary (to the extent required under this subchapter), and reported by the Secretary, on the immediately following reporting day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6f90-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on reporting by packers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A packer shall not be required to report actions under paragraph (1) more than once on the immediately following reporting day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6f91-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter, the Livestock Mandatory Reporting Act of 1999, or amendments made by that Act restricts or modifies the authority of the Secretary to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6f92-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer or enforce the Packers and Stockyards Act, 1921 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s181"},"text":"7 U.S.C. 181","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6f93-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer, enforce, or collect voluntary reports under this chapter or any other law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6f94-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access documentary evidence as provided under sections 49 and 50 of title 15.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedf6f95-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 251, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX/s911/2"},"text":"Pub. L. 106–78, title IX, § 911(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1200"},"text":"113 Stat. 1200","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXI/s11001/a/1"},"text":"Pub. L. 110–234, title XI, § 11001(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1350"},"text":"122 Stat. 1350","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XI, § 11001(a)(1), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2112.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ideedf6f96-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ideedf6f97-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"ideedf6f98-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Livestock Mandatory Reporting Act of 1999, referred to in subsec. (i), is title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/78"},"text":"Pub. L. 106–78","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1188"},"text":"113 Stat. 1188","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1635"},"text":"section 1635 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Packers and Stockyards Act, 1921, referred to in subsec. (i)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1921-08-15/ch64"},"text":"act Aug. 15, 1921, ch. 64","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/159"},"text":"42 Stat. 159","children":[],"tail":", which is classified generally to chapter 9 (§ 181 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s181"},"text":"section 181 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"ideedf6f99-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" made identical amendments to this section. The amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ideedf6f9a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/246/s11001/a/1"},"text":"Pub. L. 110–246, § 11001(a)(1)","children":[],"tail":", amended subsec. (g) generally. Prior to amendment, text read as follows: “The Secretary shall, to the maximum extent practicable, provide for the reporting and publishing of the information required under this subchapter by electronic means.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ideedf6f9b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ideedf6f9c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"