{"tag":"section","attrib":{"id":"idf036e9dc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8312"},"text":null,"children":[{"tag":"num","attrib":{"value":"8312"},"text":"§ 8312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration and claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf036e9dd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out this chapter, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036e9de-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire and maintain real or personal property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e9df-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ a person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e9e0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8312/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e9e1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8312/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding chapter 63 of title 31, enter into a contract, cooperative agreement, memorandum of understanding, or other agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf036e9e2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tort claims","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf036e9e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), the Secretary may pay a tort claim, in the manner authorized by the first paragraph of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2672"},"text":"section 2672 of title 28","children":[],"tail":", if the claim arises outside the United States in connection with an activity authorized under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf036e9e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A claim may not be allowed under this subsection unless the claim is presented in writing to the Secretary not later than 2 years after the date on which the claim arises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf036e9e5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10413"},"text":"Pub. L. 107–171, title X, § 10413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/503"},"text":"116 Stat. 503","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf036e9e6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf036e9e7-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf036e9e8-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (b)(1), was in the original “this subtitle”, meaning subtitle E (§§ 10401–10418) of title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/494"},"text":"116 Stat. 494","children":[],"tail":", which is classified principally to this chapter. For complete classification of subtitle E to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8301"},"text":"section 8301 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf036e9e9-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idf036e9ea-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions of the Secretary of Agriculture relating to agricultural import and entry inspection activities under this chapter to the Secretary of Homeland Security, and for treatment of related references, see sections 231, 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
