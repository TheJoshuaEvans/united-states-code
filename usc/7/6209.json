{"tag":"section","attrib":{"id":"idefde9145-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209"},"text":null,"children":[{"tag":"num","attrib":{"value":"6209"},"text":"§ 6209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial referendum","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefde9146-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 months after the date on which the collection of assessments begins under the order pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6204/d"},"text":"section 6204(d) of this title","children":[],"tail":", the Secretary shall conduct a referendum among producers, producer-handlers, and importers who—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idefde9147-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not exempt from assessment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6204/d/5"},"text":"section 6204(d)(5) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde9148-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produced or imported limes during a representative period as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde9149-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of referendum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The referendum referred to in subsection (a) is for the purpose of determining whether the issuance of the order is approved or favored by not less than a majority of the producers, producer-handlers, and importers voting in the referendum. The order shall continue in effect only with such a majority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde914a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The ballots and other information or reports that reveal, or tend to reveal, the vote of any person under this section, or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s6210"},"text":"section 6210 of this title","children":[],"tail":", shall be held strictly confidential and shall not be disclosed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefde914b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of assessments from escrow account","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefde914c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A portion of the assessments collected from producers, producer-handlers, and importers prior to announcement of the results of the referendum provided for in this section shall be held in an escrow account until the results of the referendum are published by the Secretary. The amount in the escrow account shall be equal to the product obtained by multiplying the total amount of assessments collected during such period by 10 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde914d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of order","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the order is approved by a majority of the producers, producer-handlers, and importers voting in the initial referendum under subsection (a), the funds in the escrow account shall be released to be used for the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefde914e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disapproval of order","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefde914f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefde9150-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount in the escrow account required by paragraph (1) is not sufficient to refund the total amount of assessments demanded by producers, producer-handlers, or importers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefde9151-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan is not approved pursuant to the referendum conducted under subsection (a);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Board shall prorate the amount of such refunds among all eligible producers, producer-handlers, or importers who demand such refund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde9152-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Right to refund","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A producer, producer-handler, or importer shall be eligible to receive a refund—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefde9153-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if demand is made personally, in accordance with regulations and on a form and within a time period prescribed by the Board, but in no event less than 90 days after the date of publication of the results of the referendum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefde9154-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on submission of proof satisfactory to the Board that the person paid the assessment for which refund is sought and did not collect the assessment from another person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefde9155-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6209/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surplus funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any funds not refunded under this paragraph shall be released to be used to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefde9156-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXIX/s1960"},"text":"Pub. L. 101–624, title XIX, § 1960","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3879"},"text":"104 Stat. 3879","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/194/s5"},"text":"Pub. L. 103–194, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-12-14"},"text":"Dec. 14, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/2295"},"text":"107 Stat. 2295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefde9157-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefde9158-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefde9159-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/194"},"text":"Pub. L. 103–194","children":[],"tail":" substituted “Not later than 30 months after the date on which the collection of assessments begins under the order pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s6204/d"},"text":"section 6204(d) of this title","children":[],"tail":",” for “Not later than 2 years after the date on which the Secretary first issues an order under section 6203(a),”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
