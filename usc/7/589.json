{"tag":"section","attrib":{"id":"idee3fad87-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s589"},"text":null,"children":[{"tag":"num","attrib":{"value":"589"},"text":"§ 589.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When used in this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idee3fad88-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s589/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “person” includes individuals, partnerships, corporations, and associations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3fad89-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s589/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary of Agriculture” means the Secretary of Agriculture of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3fad8a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s589/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided herein, the term “foreign commerce” means commerce between any State, or the District of Columbia, and any place outside of the United States or its possessions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3fad8b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s589/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “apples” means fresh whole apples, whether or not the apples have been in storage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idee3fad8c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s589/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “bulk container” means a container that contains a quantity of apples weighing more than 100 pounds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idee3fad8d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-06-10/ch59/s9"},"text":"June 10, 1933, ch. 59, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/124"},"text":"48 Stat. 124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/96/s1/b"},"text":"Pub. L. 106–96, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-12"},"text":"Nov. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1321"},"text":"113 Stat. 1321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tX/s10009/b"},"text":"Pub. L. 113–79, title X, § 10009(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/949"},"text":"128 Stat. 949","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee3fad8e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee3fad8f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee3fad90-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/96"},"text":"Pub. L. 106–96","children":[],"tail":" added par. (4) and struck out former par. (4) which read as follows: “The term ‘apples and/or pears’ means fresh whole apples or pears, whether or not they have been in storage.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
