{"tag":"section","attrib":{"id":"idef249013-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h"},"text":null,"children":[{"tag":"num","attrib":{"value":"2008h"},"text":"§ 2008h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loan and loan servicing limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef249014-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delinquent borrowers prohibited from obtaining direct operating loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not make a direct operating loan under subchapter II to a borrower who is delinquent on any loan made or guaranteed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef249015-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of loans for borrowers that have received debt forgiveness","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef249016-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef249017-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may not make a loan under this chapter to a borrower that has received debt forgiveness on a loan made or guaranteed under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef249018-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary may not guarantee a loan under this chapter to a borrower that has received—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef249019-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" debt forgiveness after ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":", on a loan made or guaranteed under this chapter; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef24901a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received debt forgiveness on more than 3 occasions on or before ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef24901b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef24901c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make a direct or guaranteed farm operating loan for paying annual farm or ranch operating expenses of a borrower who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef24901d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was restructured with a write-down under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2001"},"text":"section 2001 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef24901e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is current on payments under a confirmed reorganization plan under chapters ","children":[{"tag":"ref","attrib":{"idref":"fn002226"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002226"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “chapter”."}],"tail":" 11, 12, or 13 of title 11; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef24901f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" received debt forgiveness on not more than 1 occasion resulting directly and primarily from a major disaster or emergency designated by the President on or after ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":", under the Robert T. Stafford Disaster Relief and Emergency Assistance Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef249020-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency loans","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef249021-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make an emergency loan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1961"},"text":"section 1961 of this title","children":[],"tail":" to a borrower that—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idef249022-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on or before ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":", received not more than 1 debt forgiveness on a loan made or guaranteed under this chapter; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idef249023-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"1996-04-04"},"text":"April 4, 1996","children":[],"tail":", has not received debt forgiveness on a loan made or guaranteed under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef249024-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restructured loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of clause (i), a borrower who was restructured with a write-down or restructuring under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2001"},"text":"section 2001 of this title","children":[],"tail":" shall not be considered to have received debt forgiveness on a loan made or guaranteed under this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef249025-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2008h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No more than 1 debt forgiveness for borrower on direct loan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not provide to a borrower debt forgiveness on a direct loan made under this chapter if the borrower has received debt forgiveness on another direct loan made under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef249026-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s373"},"text":"Pub. L. 87–128, title III, § 373","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVI/s648/b"},"text":"Pub. L. 104–127, title VI, § 648(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1104"},"text":"110 Stat. 1104","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/a/tVIII/s801"},"text":"Pub. L. 105–277, div. A, § 101(a) [title VIII, § 801]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681"},"text":"112 Stat. 2681","children":[],"tail":", 2681–37; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tV/s5319"},"text":"Pub. L. 107–171, title V, § 5319","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/348"},"text":"116 Stat. 348","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tV/s5307"},"text":"Pub. L. 115–334, title V, § 5307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4673"},"text":"132 Stat. 4673","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef249027-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef249028-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef249029-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title III of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128"},"text":"Pub. L. 87–128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-08-08"},"text":"Aug. 8, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/307"},"text":"75 Stat. 307","children":[],"tail":", known as the Consolidated Farm and Rural Development Act, which is classified principally to this chapter. For complete classification of title III to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1921"},"text":"section 1921 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsec. (b)(2)(A)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", which is classified principally to chapter 68 (§ 5121 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef24902a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" designated existing provisions as cl. (i) and inserted heading, redesignated former cls. (i) and (ii) as subcls. (I) and (II), respectively, of cl. (i), and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(2)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":" added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" added subsec. (b) and struck out heading and text of former subsec. (b). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—Except as provided in paragraph (2), the Secretary may not make or guarantee a loan under this chapter to a borrower who received debt forgiveness on a loan made or guaranteed under this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—The Secretary may make a direct or guaranteed farm operating loan for paying annual farm or ranch operating expenses of a borrower who was restructured with a write-down under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2001"},"text":"section 2001 of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
