{"tag":"section","attrib":{"id":"idee59ec86-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s916"},"text":null,"children":[{"tag":"num","attrib":{"value":"916"},"text":"§ 916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for loans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to insure coordination of electric generation and transmission financing under this chapter with the national energy policy, the Secretary in making or guaranteeing loans for the construction, operation, or enlargement of generating plants or electric transmission lines or systems, shall consider such general criteria consistent with the provisions of this chapter as may be published by the Secretary of Energy.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee59ec87-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1936-05-20/ch432"},"text":"May 20, 1936, ch. 432","children":[],"tail":", title I, § 16, as added "},{"tag":"ref","attrib":{"href":"/us/pl/95/91/tVII/s709/f"},"text":"Pub. L. 95–91, title VII, § 709(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-04"},"text":"Aug. 4, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/608"},"text":"91 Stat. 608","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s235/a/13"},"text":"Pub. L. 103–354, title II, § 235(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3221"},"text":"108 Stat. 3221","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee59ec88-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idee59ec89-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idee59ec8a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/354"},"text":"Pub. L. 103–354","children":[],"tail":" substituted “Secretary” for “Administrator” before “in making”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
