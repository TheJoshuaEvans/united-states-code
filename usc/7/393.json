{"tag":"section","attrib":{"id":"idee2f0b9a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s393"},"text":null,"children":[{"tag":"num","attrib":{"value":"393"},"text":"§ 393.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of pathological and zoological specimens; disposition of moneys","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture is authorized to prepare and sell at cost such pathological and zoological specimens as he may deem of scientific or educational value to scientists or others engaged in the work of hygiene and sanitation: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That all moneys received from the sale of such specimens shall be deposited in the Treasury as miscellaneous receipts."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idee2f0b9b-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch145/s1"},"text":"Mar. 4, 1913, ch. 145, § 1","children":[],"tail":" [part], "},{"tag":"ref","attrib":{"href":"/us/stat/37/833"},"text":"37 Stat. 833","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idee2f0b9c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idee2f0b9d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idee2f0b9e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Bureau of Animal Industry transferred to Secretary of Agriculture by 1947 Reorg. Plan No. 1, § 301, eff. ","children":[{"tag":"date","attrib":{"date":"1947-07-01"},"text":"July 1, 1947","children":[],"tail":", 12 F.R. 4534, "},{"tag":"ref","attrib":{"href":"/us/stat/61/952"},"text":"61 Stat. 952","children":[],"tail":". See note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s391"},"text":"section 391 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
