{"tag":"section","attrib":{"id":"idef309dab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–7"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009cc–7"},"text":"§ 2009cc–7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational assistance grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef309dac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–7/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with this section, the Secretary may make grants to rural business investment companies and to other entities, as authorized by this subchapter, to provide operational assistance to smaller enterprises financed, or expected to be financed, by the entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef309dad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–7/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants made under this section shall be made over a multiyear period (not to exceed 10 years) under such terms as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef309dae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–7/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proceeds of a grant made under this section may be used by the rural business investment company receiving the grant only to provide operational assistance in connection with an equity or prospective equity investment in a business located in a rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef309daf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–7/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A rural business investment company shall be eligible for a grant under this section only if the rural business investment company submits to the Secretary, in such form and manner as the Secretary may require, a plan for use of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef309db0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–7/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant amount","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef309db1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–7/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural business investment companies","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount of a grant made under this section to a rural business investment company shall be equal to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef309db2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–7/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of the private capital raised by the rural business investment company; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef309db3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–7/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef309db4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009cc–7/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount of a grant made under this section to any entity other than a rural business investment company shall be equal to the resources (in cash or in kind) raised by the entity in accordance with the requirements applicable to rural business investment companies under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef309db5-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s384H"},"text":"Pub. L. 87–128, title III, § 384H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6029"},"text":"Pub. L. 107–171, title VI, § 6029","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/395"},"text":"116 Stat. 395","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
