{"tag":"section","attrib":{"id":"idef0f32f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b"},"text":null,"children":[{"tag":"num","attrib":{"value":"1936b"},"text":"§ 1936b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermediary relending program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef0f32f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may make or guarantee loans to eligible entities described in subsection (b) so that the eligible entities may relend the funds to individuals and entities for the purposes described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f32f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Entities eligible for loans and loan guarantees described in subsection (a) are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0f32f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit corporations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f32f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The proceeds from loans made or guaranteed by the Secretary pursuant to subsection (a) may be relent by eligible entities for projects that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0f32f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" predominately serve communities in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f32f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as determined by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0f32fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote community development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f32fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish new businesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f32fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and support microlending programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f32fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create or retain employment opportunities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f32fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not make loans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9812/a"},"text":"section 9812(a) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f32ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on loan amounts","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The maximum amount of a loan by an eligible entity described in subsection (b) to individuals and entities for a project under subsection (c), including the unpaid balance of any existing loans, shall be the lesser of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0f3300-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $400,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f3301-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the loan to the eligible entity under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f3302-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0f3303-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive a loan or loan guarantee under subsection (a), an eligible entity described in subsection (b) shall submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f3304-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In evaluating applications submitted under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef0f3305-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idef0f3306-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration the previous performance of an eligible entity in carrying out projects under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idef0f3307-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of satisfactory performance under clause (i), require the eligible entity to contribute less equity for subsequent loans without modifying the priority given to subsequent applications; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef0f3308-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in assigning priorities to applications, require an eligible entity to demonstrate that it has a governing or advisory board made up of business, civic, and community leaders who are representative of the communities of the service area, without limitation to the size of the service area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f3309-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of equity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a schedule that is consistent with the amortization schedules of the portfolio of loans made or guaranteed under subsection (a) for the return of any equity contribution made under this section by an eligible entity described in subsection (b), if the eligible entity is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef0f330a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current on all principal and interest payments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef0f330b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in compliance with loan covenants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f330c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall promulgate regulations and establish procedures reducing the administrative requirements on eligible entities described in subsection (b), including regulations to carry out the amendments made to this section by the Agriculture Improvement Act of 2018.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef0f330d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1936b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this subsection $25,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef0f330e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s310H"},"text":"Pub. L. 87–128, title III, § 310H","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVI/s6017/a"},"text":"Pub. L. 113–79, title VI, § 6017(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/845"},"text":"128 Stat. 845","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tVI/s6416"},"text":"Pub. L. 115–334, title VI, § 6416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4762"},"text":"132 Stat. 4762","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef0f330f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef0f3310-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idef0f3311-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The amendments made to this section by the Agriculture Improvement Act of 2018, referred to in subsec. (h), means the amendments made to this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef0f3312-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (e) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6416/2"},"text":"Pub. L. 115–334, § 6416(2)","children":[],"tail":", added subsecs. (e) to (h). Former subsec. (e) redesignated (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334/s6416/1"},"text":"Pub. L. 115–334, § 6416(1)","children":[],"tail":", (3), redesignated subsec. (e) as (i) and substituted “2023” for “2018”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
