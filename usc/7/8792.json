{"tag":"section","attrib":{"id":"idf0451a04-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792"},"text":null,"children":[{"tag":"num","attrib":{"value":"8792"},"text":"§ 8792.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographically disadvantaged farmers and ranchers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0451a05-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451a06-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agricultural commodity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agricultural commodity” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s5602"},"text":"section 5602 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a07-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geographically disadvantaged farmer or rancher","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “geographically disadvantaged farmer or rancher” has the meaning given the term in section 10906(a) of the Farm Security and Rural Investment Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2204"},"text":"7 U.S.C. 2204","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Public Law 107–171","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0451a08-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of funds under subsection (d), the Secretary may provide geographically disadvantaged farmers or ranchers direct reimbursement payments for activities described in subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0451a09-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0451a0a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to paragraphs (2) and (3), the Secretary may provide direct reimbursement payments to a geographically disadvantaged farmer or rancher to transport an agricultural commodity, or inputs used to produce an agricultural commodity, during a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a0b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proof of eligibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To be eligible to receive assistance under paragraph (1), a geographically disadvantaged farmer or rancher shall demonstrate to the Secretary that transportation of the agricultural commodity or inputs occurred over a distance of more than 30 miles, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0451a0c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0451a0d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), the amount of direct reimbursement payments made to a geographically disadvantaged farmer or rancher under this section for a fiscal year shall equal the product obtained by multiplying—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0451a0e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of costs incurred by the geographically disadvantaged farmer or rancher for transportation of the agricultural commodity or inputs during the fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0451a0f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf0451a10-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/c/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of the allowance for that fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5941"},"text":"section 5941 of title 5","children":[],"tail":" for Federal employees stationed in Alaska and Hawaii; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf0451a11-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/c/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an insular area (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s3103"},"text":"section 3103 of this title","children":[],"tail":"), a comparable percentage of the allowance for the fiscal year, as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0451a12-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The total amount of direct reimbursement payments provided by the Secretary under this section shall not exceed $15,000,000 for a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0451a13-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8792/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section for fiscal year 2009 and each succeeding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0451a14-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234/tI/s1621"},"text":"Pub. L. 110–234, title I, § 1621","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1024"},"text":"122 Stat. 1024","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title I, § 1621, "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1752; "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tI/s1606"},"text":"Pub. L. 113–79, title I, § 1606","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/708"},"text":"128 Stat. 708","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf0451a15-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf0451a16-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf0451a17-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" enacted identical sections. "},{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"section 4(a) of Pub. L. 110–246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf0451a18-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" substituted “fiscal year 2009 and each succeeding fiscal year” for “each of fiscal years 2009 through 2012”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf0451a19-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idf0451a1a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of this section and repeal of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/234"},"text":"Pub. L. 110–234","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/246"},"text":"Pub. L. 110–246","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", the date of e