{"tag":"section","attrib":{"id":"ideec2e7c3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1508d"},"text":null,"children":[{"tag":"num","attrib":{"value":"1508d"},"text":"§ 1508d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coverage for forage and grazing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1508a"},"text":"section 1508a of this title","children":[],"tail":", and in addition to any other available coverage, for crops that can be both grazed and mechanically harvested on the same acres during the same growing season, producers shall be allowed to purchase separate policies for each intended use, as determined by the Corporation, and any indemnity paid under those policies for each intended use shall not be considered to be for the same loss for the purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1508/n"},"text":"section 1508(n) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ideec2e7c4-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-02-16/ch30"},"text":"Feb. 16, 1938, ch. 30","children":[],"tail":", title V, § 508D, as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tXI/s11109/b"},"text":"Pub. L. 115–334, title XI, § 11109(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4923"},"text":"132 Stat. 4923","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
