{"tag":"section","attrib":{"id":"idf004b61d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331"},"text":null,"children":[{"tag":"num","attrib":{"value":"7331"},"text":"§ 7331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Options pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf004b61e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot programs authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Until ","children":[{"tag":"date","attrib":{"date":"2002-12-31"},"text":"December 31, 2002","children":[],"tail":", the Secretary of Agriculture may conduct a pilot program for 1 or more agricultural commodities supported under this chapter to ascertain whether futures and options contracts can provide producers with reasonable protection from the financial risks of fluctuations in price, yield, and income inherent in the production and marketing of the commodities. The pilot program shall be an alternative to other related programs of the Department of Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b61f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of pilot program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each agricultural commodity included in the pilot program, the Secretary may operate the pilot program in not more than 300 counties, except that not more than 25 of the counties may be located in any 1 State. The pilot program for a commodity shall not be operated in any county for more than 3 of the 1996 through 2002 calendar years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b620-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible participants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In operating the pilot program, the Secretary may enter into contract with a producer who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf004b621-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible for a production flexibility contract, a marketing assistance loan, or other assistance under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf004b622-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" volunteers to participate in the pilot program during any calendar year in which a county in which the farm of the producer is located is included in the pilot program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf004b623-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates a farm located in a county selected for the pilot program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf004b624-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such other eligibility requirements as the Secretary may establish.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b625-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to producers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide notice to each producer participating in the pilot program that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf004b626-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participation of the producer is voluntary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf004b627-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neither the United States, the Commodity Credit Corporation, the Federal Crop Insurance Corporation, the Department of Agriculture, nor any other Federal agency is authorized to guarantee that participants in the pilot program will be better or worse off financially as a result of participation in the pilot program than the producer would have been if the producer had not participated in the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b628-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall set forth in each contract under the pilot program the terms and conditions for participation in the pilot program and the notice required by subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b629-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible markets","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Trades for futures and options contracts under the pilot program shall be carried out on commodity futures and options markets designated as contract markets under the Commodity Exchange Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"7 U.S.C. 1","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b62a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A producer participating in the pilot program shall compile, maintain, and submit (or authorize the compilation, maintenance, and submission) of such documentation as the regulations governing the pilot program require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf004b62b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7331/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Commodity Credit Corporation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall fund and operate the pilot program through the Commodity Credit Corporation, except that the amount of Commodity Credit Corporation funds used to carry out this section shall not exceed, to the maximum extent practicable, $9,000,000 for fiscal year 2001, $15,000,000 for fiscal year 2002, and $2,000,000 for fiscal year 2003. To the maximum extent practicable, the Secretary shall operate the pilot program in a budget neutral manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf004b62c-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tI/s191"},"text":"Pub. L. 104–127, title I, § 191","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/941"},"text":"110 Stat. 941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/224/tI/s134"},"text":"Pub. L. 106–224, title I, § 134","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-06-20"},"text":"June 20, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/388"},"text":"114 Stat. 388","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf004b62d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf004b62e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf004b62f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of “this chapter”, referred to in subsecs. (a) and (c)(1), see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7201"},"text":"section 7201 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Commodity Exchange Act, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369"},"text":"act Sept. 21, 1922, ch. 369","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/998"},"text":"42 Stat. 998","children":[],"tail":", which is classified generally to chapter 1 (§ 1 et seq.) of this title. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"section 1 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idf004b630-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/s191"},"text":"section 191 of Pub. L. 104–127","children":[],"tail":". Subsec. (i) of "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/s191"},"text":"section 191 of Pub. L. 104–127","children":[],"tail":" repealed provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1421"},"text":"section 1421 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idf004b631-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/s134/1"},"text":"Pub. L. 106–224, § 134(1)","children":[],"tail":", substituted “300 counties, except that not more than 25” for “100 counties, except that not more than 6” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/s134/2"},"text":"Pub. L. 106–224, § 134(2)","children":[],"tail":", inserted before semicolon at end “during any calendar year in which a county in which the farm of the producer is located is included in the pilot program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224/s134/3"},"text":"Pub. L. 106–224, § 134(3)","children":[],"tail":", inserted before period at end of first sentence “, except that the amount of Commodity Credit Corporation funds used to carry out this section shall not exceed, to the maximum extent practicable, $9,000,000 for fiscal year 2001, $15,000,000 for fiscal year 2002, and $2,000,000 for fiscal year 2003”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idf004b632-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idf004b633-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/224"},"text":"Pub. L. 106–224","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2000-10-01"},"text":"Oct. 1, 2000","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/224/s171/b/1/A"},"text":"section 171(b)(1)(A) of Pub. L. 106–224","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1501"},"text":"section 1501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
