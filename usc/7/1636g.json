{"tag":"section","attrib":{"id":"ideedf6fe1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636g"},"text":null,"children":[{"tag":"num","attrib":{"value":"1636g"},"text":"§ 1636g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension authority regarding specific terms of price reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ideedf6fe2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may suspend any requirement of this subchapter if the Secretary determines that application of the requirement is inconsistent with the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ideedf6fe3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension procedure","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ideedf6fe4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A suspension under subsection (a) shall be for a period of not more than 240 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ideedf6fe5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s1636g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Action by Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an Act of Congress concerning the requirement that is the subject of the suspension under subsection (a) is not enacted by the end of the period of the suspension established under paragraph (1), the Secretary shall implement the requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ideedf6fe6-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-14/ch966"},"text":"Aug. 14, 1946, ch. 966","children":[],"tail":", title II, § 258, as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/78/tIX/s911/2"},"text":"Pub. L. 106–78, title IX, § 911(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-22"},"text":"Oct. 22, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1205"},"text":"113 Stat. 1205","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
