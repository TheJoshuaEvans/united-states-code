{"tag":"section","attrib":{"id":"idf03478e3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306"},"text":null,"children":[{"tag":"num","attrib":{"value":"8306"},"text":"§ 8306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Seizure, quarantine, and disposal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf03478e4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may hold, seize, quarantine, treat, destroy, dispose of, or take other remedial action with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03478e5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any animal or progeny of any animal, article, or means of conveyance that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03478e6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is moving or has been moved in interstate commerce or has been imported and entered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03478e7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has reason to believe may carry, may have carried, or may have been affected with or exposed to any pest or disease of livestock at the time of movement or that is otherwise in violation of this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03478e8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any animal or progeny of any animal, article, or means of conveyance that is moving or is being handled, or has moved or has been handled, in interstate commerce in violation of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03478e9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any animal or progeny of any animal, article, or means of conveyance that has been imported, and is moving or is being handled or has moved or has been handled, in violation of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03478ea-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any animal or progeny of any animal, article, or means of conveyance that the Secretary finds is not being maintained, or has not been maintained, in accordance with any post-importation quarantine, post-importation condition, post-movement quarantine, or post-movement condition in accordance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03478eb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extraordinary emergencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03478ec-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), if the Secretary determines that an extraordinary emergency exists because of the presence in the United States of a pest or disease of livestock and that the presence of the pest or disease threatens the livestock of the United States, the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03478ed-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold, seize, treat, apply other remedial actions to, destroy (including preventative slaughter), or otherwise dispose of, any animal, article, facility, or means of conveyance if the Secretary determines the action is necessary to prevent the dissemination of the pest or disease; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03478ee-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit or restrict the movement or use within a State, or any portion of a State of any animal or article, means of conveyance, or facility if the Secretary determines that the prohibition or restriction is necessary to prevent the dissemination of the pest or disease.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03478ef-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State action","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03478f0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may take action in a State under this subsection only on finding that measures being taken by the State are inadequate to control or eradicate the pest or disease, after review and consultation with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03478f1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002361"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002361"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Opening quotation marks probably should not appear."}],"tail":" the Governor or an appropriate animal health official of the State; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03478f2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" in the case of any animal, article, facility, or means of conveyance under the jurisdiction of an Indian tribe, the head of the Indian tribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03478f3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subparagraph (C), before any action is taken in a State under subparagraph (A), the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf03478f4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Governor, an appropriate animal health official of the State, or head of the Indian tribe of the proposed action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03478f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a public announcement of the proposed action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf03478f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" publish in the Federal Register—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idf03478f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf03478f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the proposed action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idf03478f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/2/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the reasons for the proposed action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03478fa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice after action","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If it is not practicable to publish in the Federal Register the information required under subparagraph (B)(iii) before taking action under subparagraph (A), the Secretary shall publish the information as soon as practicable, but not later than 10 business days, after commencement of the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf03478fb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarantine, disposal, or other remedial action","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf03478fc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in writing, may order the owner of any animal, article, facility, or means of conveyance referred to in subsection (a) or (b) to maintain in quarantine, dispose of, or take other remedial action with respect to the animal, article, facility, or means of conveyance, in a manner determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf03478fd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Failure to comply with orders","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the owner fails to comply with the order of the Secretary, the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf03478fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seize, quarantine, dispose of, or take other remedial action with respect to the animal, article, facility, or means of conveyance under subsection (a) or (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf03478ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recover from the owner the costs of any care, handling, disposal, or other remedial action incurred by the Secretary in connection with the seizure, quarantine, disposal, or other remedial action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0347900-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0347901-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (3), the Secretary shall compensate the owner of any animal, article, facility, or means of conveyance that the Secretary requires to be destroyed under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0347902-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0347903-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraphs (B) and (C), the compensation shall be based on the fair market value, as determined by the Secretary, of the destroyed animal, article, facility, or means of conveyance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0347904-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Compensation paid any owner under this subsection shall not exceed the difference between—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idf0347905-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the destroyed animal, article, facility, or means of conveyance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idf0347906-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any compensation received by the owner from a State or other source for the destroyed animal, article, facility, or means of conveyance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf0347907-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reviewability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The determination by the Secretary of the amount to be paid under this subsection shall be final and not subject to judicial review or review by any officer or employee of the Federal Government other than the Secretary or the designee of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0347908-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No payment shall be made by the Secretary under this subsection for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf0347909-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any animal, article, facility, or means of conveyance that has been moved or handled by the owner in violation of an agreement for the control and eradication of diseases or pests or in violation of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf034790a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any progeny of any animal or article, which animal or article has been moved or handled by the owner of the animal or article in violation of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf034790b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any animal, article, or means of conveyance that is refused entry under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf034790c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s8306/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any animal, article, facility, or means of conveyance that becomes or has become affected with or exposed to any pest or disease of livestock because of a violation of an agreement for the control and eradication of diseases or pests or a violation of this chapter by the owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf034790d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171/tX/s10407"},"text":"Pub. L. 107–171, title X, § 10407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/498"},"text":"116 Stat. 498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tXI/s11011/1"},"text":"Pub. L. 110–234, title XI, § 11011(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1360"},"text":"122 Stat. 1360","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title XI, § 11011(1), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 2121.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idf034790e-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idf034790f-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idf0347910-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsecs. (a) and (d)(3), was in the original “this subtitle”, meaning subtitle E (§§ 10401–10418) of title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Pub. L. 107–171","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"