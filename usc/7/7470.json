{"tag":"section","attrib":{"id":"idf00e52fe-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470"},"text":null,"children":[{"tag":"num","attrib":{"value":"7470"},"text":"§ 7470.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referenda","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf00e52ff-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial referendum","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e5300-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referendum required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During the 60-day period immediately preceding the proposed effective date of an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7463"},"text":"section 7463 of this title","children":[],"tail":", the Secretary shall conduct a referendum among kiwifruit producers and importers who will be subject to assessments under the order, to ascertain whether producers and importers approve the implementation of the order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5301-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of order","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The order shall become effective, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7463"},"text":"section 7463 of this title","children":[],"tail":", if the Secretary determines that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idf00e5302-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the order has been approved by a majority of the producers and importers voting in the referendum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idf00e5303-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the producers and importers favoring approval produce and import more than 50 percent of the total volume of kiwifruit produced and imported by persons voting in the referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e5304-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent referenda","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may periodically conduct a referendum to determine if kiwifruit producers and importers favor the continuation, termination, or suspension of any order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7463"},"text":"section 7463 of this title","children":[],"tail":" that is in effect at the time of the referendum."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e5305-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required referenda","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall hold a referendum under subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e5306-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the end of the 6-year period beginning on the effective date of the order and at the end of each subsequent 6-year period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5307-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the request of the Board; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e5308-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if not less than 30 percent of the kiwifruit producers and importers subject to assessments under the order submit a petition requesting the referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e5309-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vote","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"On completion of a referendum under subsection (b), the Secretary shall suspend or terminate the order that was subject to the referendum at the end of the marketing year if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idf00e530a-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the suspension or termination of the order is favored by not less than a majority of the producers and importers voting in the referendum; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf00e530b-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the producers and importers produce and import more than 50 percent of the total volume of kiwifruit produced and imported by persons voting in the referendum.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf00e530c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7470/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The ballots and other information or reports that reveal, or tend to reveal, the vote of any person under this subchapter and the voting list shall be held strictly confidential and shall not be disclosed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf00e530d-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s561"},"text":"Pub. L. 104–127, title V, § 561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1073"},"text":"110 Stat. 1073","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
