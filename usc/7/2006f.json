{"tag":"section","attrib":{"id":"idef248fa8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f"},"text":null,"children":[{"tag":"num","attrib":{"value":"2006f"},"text":"§ 2006f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural development certified lenders program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef248fa9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified lenders program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef248faa-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish a program under which the Secretary may guarantee a loan for any rural development program that is made by a lender certified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fab-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may certify a lender if the lender meets such criteria as the Secretary may prescribe in regulations, including the ability of the lender to properly make, service, and liquidate the guaranteed loans of the lender.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fac-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition of certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of certification, the Secretary may require the lender to undertake to service the guaranteed loan using standards that are not less stringent than generally accepted banking standards concerning loan servicing that are used by prudent commercial or cooperative lenders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fad-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guarantee","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may guarantee not more than 80 percent of a loan made by a certified lender described in paragraph (1), if the borrower of the loan meets the eligibility requirements and such other criteria for the loan guarantee that are established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fae-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to loans to be guaranteed, the Secretary may permit a certified lender to make appropriate certifications (as provided in regulations issued by the Secretary)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef248faf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relating to issues such as creditworthiness, repayment ability, adequacy of collateral, and feasibility of the operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef248fb0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the borrower is in compliance with all requirements of law, including regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fb1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subsection shall not affect the responsibility of the Secretary to determine eligibility, review financial information, and otherwise assess an application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef248fb2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preferred certified lenders program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef248fb3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may establish a preferred certified lenders program for lenders who establish their—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef248fb4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowledge of, and experience under, the program established under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef248fb5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowledge of the regulations concerning the particular guaranteed loan program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef248fb6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proficiency related to the certified lender program requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fb7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional lending institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may certify any lending institution as a preferred certified lender if the institution meets such additional criteria as the Secretary may prescribe by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fb8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The designation of a lender as a preferred certified lender shall be revoked if the Secretary determines that the lender is not adhering to the rules and regulations applicable to the program or if the loss experiences of the preferred certified lender are greater than other preferred certified lenders, except that the suspension or revocation shall not affect any outstanding guarantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fb9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Condition of certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of the preferred certification, the Secretary shall require the lender to undertake to service the loan guaranteed by the Secretary under this subsection using generally accepted banking standards concerning loan servicing employed by prudent commercial or cooperative lenders. The Secretary shall, at least annually, monitor the performance of each preferred certified lender to ensure that the conditions of the certification are being met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef248fba-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of preferred lender certification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef248fbb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guarantee not more than 80 percent of any approved loan made by a preferred certified lender as described in this subsection, if the borrower meets the eligibility requirements and such other criteria as may be applicable to loans guaranteed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef248fbc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2006f/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit preferred certified lenders to make all decisions, with respect to loans to be guaranteed by the Secretary under this subsection relating to creditworthiness, the closing, monitoring, collection, and liquidation of loans, and to accept appropriate certifications, as provided in regulations issued by the Secretary, that the borrower is in compliance with all requirements of law and regulations issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef248fbd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s364"},"text":"Pub. L. 87–128, title III, § 364","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/127/tVII/s752"},"text":"Pub. L. 104–127, title VII, § 752","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1129"},"text":"110 Stat. 1129","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef248fbe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef248fbf-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idef248fc0-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2006f, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s364"},"text":"Pub. L. 87–128, title III, § 364","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXIII/s2302/a/1"},"text":"Pub. L. 101–624, title XXIII, § 2302(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3979"},"text":"104 Stat. 3979","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tVII/s701/d"},"text":"Pub. L. 102–237, title VII, § 701(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1879"},"text":"105 Stat. 1879","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/129/s4"},"text":"Pub. L. 103–129, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-01"},"text":"Nov. 1, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1366"},"text":"107 Stat. 1366","children":[],"tail":", established Rural Development Administration in Department of Agriculture and provided for the performance of specified functions, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/354/tII/s231/f/3"},"text":"Pub. L. 103–354, title II, § 231(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3219"},"text":"108 Stat. 3219","children":[],"tail":". See section 6912 et seq. of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
