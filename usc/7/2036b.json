{"tag":"section","attrib":{"id":"idef67644c-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036b"},"text":null,"children":[{"tag":"num","attrib":{"value":"2036b"},"text":"§ 2036b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retail food store and recipient trafficking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef67644d-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of this section is to provide the Department of Agriculture with additional resources to prevent trafficking in violation of this chapter by strengthening recipient and retail food store program integrity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef67644e-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef67644f-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Additional funds are provided under this section to supplement the retail food store and recipient integrity activities of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef676450-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information technologies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use an appropriate amount of the funds provided under this section to employ information technologies known as data mining and data warehousing and other available information technologies to administer the supplemental nutrition assistance program and enforce regulations promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2013/c"},"text":"section 2013(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef676451-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef676452-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $5,000,000 for each of fiscal years 2014 through 2023.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef676453-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idef676454-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of any funds in the Treasury not otherwise appropriated, the Secretary of the Treasury shall transfer to the Secretary to carry out this section not less than $15,000,000 for fiscal year 2014, to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef676455-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt and acceptance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall be entitled to receive, shall accept, and shall use to carry out this section the funds transferred under subparagraph (A), without further appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idef676456-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2036b/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The funding provided under subparagraph (A) shall supplement (and not supplant) other Federal funding for programs carried out under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef676457-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/525/s29"},"text":"Pub. L. 88–525, § 29","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tIV/s4029"},"text":"Pub. L. 113–79, title IV, § 4029","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/813"},"text":"128 Stat. 813","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/334/tIV/s4020"},"text":"Pub. L. 115–334, title IV, § 4020","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-20"},"text":"Dec. 20, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4652"},"text":"132 Stat. 4652","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idef676458-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idef676459-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idef67645a-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/334"},"text":"Pub. L. 115–334","children":[],"tail":" substituted “2023” for “2018”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
