{"tag":"section","attrib":{"id":"idefe5bcc1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517"},"text":null,"children":[{"tag":"num","attrib":{"value":"6517"},"text":"§ 6517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National List","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idefe5bcc2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a National List of approved and prohibited substances that shall be included in the standards for organic production and handling established under this chapter in order for such products to be sold or labeled as organically produced under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bcc3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of list","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The list established under subsection (a) shall contain an itemization, by specific use or application, of each synthetic substance permitted under subsection (c)(1) or each natural substance prohibited under subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bcc4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines for prohibitions or exemptions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bcc5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for prohibited substances in organic production and handling operations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National List may provide for the use of substances in an organic farming or handling operation that are otherwise prohibited under this chapter only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bcc6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary determines, in consultation with the Secretary of Health and Human Services and the Administrator of the Environmental Protection Agency, that the use of such substances—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe5bcc7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not be harmful to human health or the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bcc8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to the production or handling of the agricultural product because of the unavailability of wholly natural substitute products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bcc9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with organic farming and handling;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bcca-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the substance—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe5bccb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is used in production and contains an active synthetic ingredient in the following categories: copper and sulfur compounds; toxins derived from bacteria; pheromones, soaps, horticultural oils, fish emulsions, treated seed, vitamins and minerals; livestock parasiticides and medicines and production aids including netting, tree wraps and seals, insect traps, sticky barriers, row covers, and equipment cleansers; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bccc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is used in production and contains synthetic inert ingredients that are not classified by the Administrator of the Environmental Protection Agency as inerts of toxicological concern; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bccd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific exemption is developed using the procedures described in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bcce-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on the use of specific natural substances","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National List may prohibit the use of specific natural substances in an organic farming or handling operation that are otherwise allowed under this chapter only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idefe5bccf-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary determines, in consultation with the Secretary of Health and Human Services and the Administrator of the Environmental Protection Agency, that the use of such substances—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idefe5bcd0-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be harmful to human health or the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idefe5bcd1-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is inconsistent with organic farming or handling, and the purposes of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idefe5bcd2-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific prohibition is developed using the procedures specified in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bcd3-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedure for establishing National List","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idefe5bcd4-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National List established by the Secretary shall be based upon a proposed national list or proposed amendments to the National List developed by the National Organic Standards Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bcd5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No additions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not include exemptions for the use of specific synthetic substances in the National List other than those exemptions contained in the Proposed National List or Proposed Amendments to the National List.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bcd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited substances","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In no instance shall the National List include any substance, the presence of which in food has been prohibited by Federal regulatory action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bcd7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and comment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before establishing the National List or before making any amendments to the National List, the Secretary shall publish the Proposed National List or any Proposed Amendments to the National List in the Federal Register and seek public comment on such proposals. The Secretary shall include in such Notice any changes to such proposed list or amendments recommended by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bcd8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of National List","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After evaluating all comments received concerning the Proposed National List or Proposed Amendments to the National List, the Secretary shall publish the final National List in the Federal Register, along with a discussion of comments received.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idefe5bcd9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited petitions for commercially unavailable organic agricultural products constituting less than 5 percent of an organic processed product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may develop emergency procedures for designating agricultural products that are commercially unavailable in organic form for placement on the National List for a period of time not to exceed 12 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idefe5bcda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6517/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset provision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No exemption or prohibition contained in the National List shall be valid unless the National Organic Standards Board has reviewed such exemption or prohibition as provided in this section within 5 years of such exemption or prohibition being adopted or reviewed and the Secretary has renewed such exemption or prohibition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idefe82cdb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/624/tXXI/s2118"},"text":"Pub. L. 101–624, title XXI, § 2118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-28"},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3946"},"text":"104 Stat. 3946","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/237/tX/s1001/6"},"text":"Pub. L. 102–237, title X, § 1001(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-13"},"text":"Dec. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1893"},"text":"105 Stat. 1893","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/97/tVII/s797/b"},"text":"Pub. L. 109–97, title VII, § 797(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-10"},"text":"Nov. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2165"},"text":"119 Stat. 2165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idefe82cdc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idefe82cdd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idefe82cde-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97/s797/b/1/A"},"text":"Pub. L. 109–97, § 797(b)(1)(A)","children":[],"tail":", inserted “in organic production and handling operations” after “substances” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97/s797/b/1/B"},"text":"Pub. L. 109–97, § 797(b)(1)(B)","children":[],"tail":", (C), struck out cl. (iii) which read as follows: “is used in handling and is non-synthetic but is not organically produced; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/97/s797/b/2"},"text":"Pub. L. 109–97, § 797(b)(2)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (c)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/237"},"text":"Pub. L. 102–237","children":[],"tail":" substituted “parasiticides” for “paraciticides”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
