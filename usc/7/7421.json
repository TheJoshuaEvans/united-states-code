{"tag":"section","attrib":{"id":"idf0099831-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7421"},"text":null,"children":[{"tag":"num","attrib":{"value":"7421"},"text":"§ 7421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension or termination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idf0099832-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7421/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory suspension or termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall suspend or terminate an order or a provision of an order if the Secretary finds that an order or a provision of an order obstructs or does not tend to effectuate the purpose of this subchapter, or if the Secretary determines that the order or a provision of an order is not favored by persons voting in a referendum conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7417"},"text":"section 7417 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idf0099833-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7421/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of suspension or termination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, as a result of a referendum conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7417"},"text":"section 7417 of this title","children":[],"tail":", the Secretary determines that an order is not approved, the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idf0099834-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7421/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after making the determination, suspend or terminate, as the case may be, collection of assessments under the order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idf0099835-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s7421/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as soon as practicable, suspend or terminate, as the case may be, activities under the order in an orderly manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idf0099836-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/127/tV/s522"},"text":"Pub. L. 104–127, title V, § 522","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-04"},"text":"Apr. 4, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1047"},"text":"110 Stat. 1047","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
