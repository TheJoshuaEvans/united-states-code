{"tag":"section","attrib":{"id":"idedc610f5-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6o"},"text":null,"children":[{"tag":"num","attrib":{"value":"6o"},"text":"§ 6o.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud and misrepresentation by commodity trading advisors, commodity pool operators, and associated persons","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idedc610f6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6o/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It shall be unlawful for a commodity trading advisor, associated person of a commodity trading advisor, commodity pool operator, or associated person of a commodity pool operator, by use of the mails or any means or instrumentality of interstate commerce, directly or indirectly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idedc610f7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6o/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to employ any device, scheme, or artifice to defraud any client or participant or prospective client or participant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idedc610f8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6o/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to engage in any transaction, practice, or course of business which operates as a fraud or deceit upon any client or participant or prospective client or participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idedc610f9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s6o/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It shall be unlawful for any commodity trading advisor, associated person of a commodity trading advisor, commodity pool operator, or associated person of a commodity pool operator registered under this chapter to represent or imply in any manner whatsoever that such person has been sponsored, recommended, or approved, or that such person’s abilities or qualifications have in any respect been passed upon, by the United States or any agency or officer thereof. This section shall not be construed to prohibit a statement that a person is registered under this chapter as a commodity trading advisor, associated person of a commodity trading advisor, commodity pool operator, or associated person of a commodity pool operator, if such statement is true in fact and if the effect of such registration is not misrepresented.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idedc610fa-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369/s4"},"text":"Sept. 21, 1922, ch. 369, § 4","children":[],"tail":null},{"tag":"i","attrib":{},"text":"o","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/93/463/tII/s205/a"},"text":"Pub. L. 93–463, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-23"},"text":"Oct. 23, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1399"},"text":"88 Stat. 1399","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/405/s10"},"text":"Pub. L. 95–405, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"Sept. 30, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/870"},"text":"92 Stat. 870","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/444/tII/s214"},"text":"Pub. L. 97–444, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-11"},"text":"Jan. 11, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2305"},"text":"96 Stat. 2305","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idedc610fb-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idedc610fc-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idedc610fd-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1983—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/444"},"text":"Pub. L. 97–444","children":[],"tail":" made the antifraud prohibition applicable to an associated person of a commodity trading advisor or a commodity pool operator."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/444"},"text":"Pub. L. 97–444","children":[],"tail":" made the misrepresentation prohibition applicable to an associated person of a commodity training advisor or a commodity pool operator, authorized registration statements of such persons, and substituted “such person” and “such person’s abilities” for “he” before “has been sponsored” and “his abilities”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/405"},"text":"Pub. L. 95–405","children":[],"tail":" struck out “registered under this chapter” after “pool operator”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idedc610fe-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idedc610ff-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/444"},"text":"Pub. L. 97–444","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1983-01-11"},"text":"Jan. 11, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/444/s239"},"text":"section 239 of Pub. L. 97–444","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idedc61100-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/405"},"text":"Pub. L. 95–405","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/405/s28"},"text":"section 28 of Pub. L. 95–405","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idedc61101-3a6e-11f1-addd-bbaf0b3f68e9"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/463/s418"},"text":"section 418 of Pub. L. 93–463","children":[],"tail":", set out as an Effective Date of 1974 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s2"},"text":"section 2 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
