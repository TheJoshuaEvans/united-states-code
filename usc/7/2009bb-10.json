hildren":[{"tag":"ref","attrib":{"href":"/us/pl/113/79"},"text":"Pub. L. 113–79","children":[],"tail":" inserted “for any fiscal year for which funds are appropriated” after “annual basis”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
