{"tag":"section","attrib":{"id":"idef2e2cd6-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–10"},"text":null,"children":[{"tag":"num","attrib":{"value":"2009bb–10"},"text":"§ 2009bb–10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idef2e2cd7-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–10/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records of the Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2e2cd8-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–10/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Authority shall maintain accurate and complete records of all transactions and activities of the Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2cd9-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–10/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All records of the Authority shall be available for audit and examination by the Comptroller General of the United States and the Inspector General of the Department of Agriculture (including authorized representatives of the Comptroller General and the Inspector General of the Department of Agriculture).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2e2cda-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–10/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records of recipients of Federal assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idef2e2cdb-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–10/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of Federal funds under this subchapter shall, as required by the Authority, maintain accurate and complete records of transactions and activities financed with Federal funds and report to the Authority on the transactions and activities to the Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idef2e2cdc-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–10/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All records required under paragraph (1) shall be available for audit by the Comptroller General of the United States, the Inspector General of the Department of Agriculture, and the Authority (including authorized representatives of the Comptroller General, the Inspector General of the Department of Agriculture, and the Authority).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idef2e2cdd-3a6e-11f1-addd-bbaf0b3f68e9","identifier":"/us/usc/t7/s2009bb–10/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual audit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Inspector General of the Department of Agriculture shall audit the activities, transactions, and records of the Authority on an annual basis for any fiscal year for which funds are appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idef2e2cde-3a6e-11f1-addd-bbaf0b3f68e9"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/128/tIII/s383L"},"text":"Pub. L. 87–128, title III, § 383L","children":[],"tail":", formerly § 383K, as added "},{"tag":"ref","attrib":{"href":"/us/pl/107/171/tVI/s6028"},"text":"Pub. L. 107–171, title VI, § 6028","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-13"},"text":"May 13, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/386"},"text":"116 Stat. 386","children":[],"tail":"; renumbered § 383L, "},{"tag":"ref","attrib":{"href":"/us/pl/110/234/tVI/s6026/c/1/A"},"text":"Pub. L. 110–234, title VI, § 6026(c)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-05-22"},"text":"May 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1178"},"text":"122 Stat. 1178","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/110/246/s4/a"},"text":"Pub. L. 110–246, § 4(a)","children":[],"tail":", title VI, § 6026(c)(1)(A), "},{"tag":"date","attrib":{"date":"2008-06-18"},"text":"June 18, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1664"},"text":"122 Stat. 1664","children":[],"tail":", 1940; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/79/tVI/s6027/a"},"text":"Pub. L. 113–79, title VI, § 6027(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-02-07"},"text":"Feb. 7, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/850"},"text":"128 Stat. 850","children":[],"tail":".)"}],"tail":"\n"},{"tag":"note