{"tag":"section","attrib":{"id":"idb562a970-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s969"},"text":null,"children":[{"tag":"num","attrib":{"value":"969"},"text":"§ 969.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revalidation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Commissioner, shall develop and implement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb562a971-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s969/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a revalidation process for Tier 2 and Tier 3 participants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a972-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s969/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a framework based upon objective criteria for identifying participants for periodic revalidation not less frequently than once during each 4-year period following the initial validation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a973-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s969/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an annual plan for revalidation that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb562a974-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s969/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562a975-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s969/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the personnel needed to perform the revalidations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562a976-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s969/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of participants that will be revalidated during the following year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb562a977-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tII/s219"},"text":"Pub. L. 109–347, title II, § 219","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1913"},"text":"120 Stat. 1913","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
