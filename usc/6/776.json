{"tag":"section","attrib":{"id":"idb55b7df3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776"},"text":null,"children":[{"tag":"num","attrib":{"value":"776"},"text":"§ 776.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Individuals and households pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55b7df4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55b7df5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, acting through the Administrator, in coordination with State, local, and tribal governments, shall establish and conduct a pilot program. The pilot program shall be designed to make better use of existing rental housing, located in areas covered by a major disaster declaration, in order to provide timely and cost-effective temporary housing assistance to individuals and households eligible for assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5174"},"text":"section 5174 of title 42","children":[],"tail":" where alternative housing options are less available or less cost-effective."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7df6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55b7df7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of the pilot program under this section, the Administrator may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55b7df8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into lease agreements with owners of multi-family rental property located in areas covered by a major disaster declaration to house individuals and households eligible for assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5174"},"text":"section 5174 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55b7df9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make improvements to properties under such lease agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55b7dfa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the pilot program where the program is cost effective in that the cost to the Government for the lease agreements is in proportion to the savings to the Government by not providing alternative housing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55b7dfb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit repairs to those required to ensure that the housing units shall meet Federal housing quality standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55b7dfc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvements to leased properties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under the terms of any lease agreement for a property described under subparagraph (A)(ii), the value of the contribution of the Agency to such improvements—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55b7dfd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be deducted from the value of the lease agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55b7dfe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not exceed the value of the lease agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7dff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In administering the pilot program under this section, the Administrator may consult with State, local, and tribal governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7e00-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55b7e01-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-03-31"},"text":"March 31, 2009","children":[],"tail":", the Administrator shall submit to the appropriate committees of Congress a report regarding the effectiveness of the pilot program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55b7e02-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall include in the report—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55b7e03-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the effectiveness of the pilot program under this section, including an assessment of cost-savings to the Federal Government and any benefits to individuals and households eligible for assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5174"},"text":"section 5174 of title 42","children":[],"tail":" under the pilot program;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55b7e04-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" findings and conclusions of the Administrator with respect to the pilot program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55b7e05-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of additional authorities needed to aid the Agency in its mission of providing disaster housing assistance to individuals and households eligible for assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5174"},"text":"section 5174 of title 42","children":[],"tail":", either under the pilot program under this section or other potential housing programs; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55b7e06-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/a/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations of the Administrator for additional authority to continue or make permanent the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55b7e07-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s776/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program project approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall not approve a project under the pilot program after ","children":[{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55b7e08-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s689i"},"text":"Pub. L. 109–295, title VI, § 689i","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1454"},"text":"120 Stat. 1454","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
