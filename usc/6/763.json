{"tag":"section","attrib":{"id":"idb55b7d65-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s763"},"text":null,"children":[{"tag":"num","attrib":{"value":"763"},"text":"§ 763.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of Noble Training Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Noble Training Center is transferred to the Center for Domestic Preparedness. The Center for Domestic Preparedness shall integrate the Noble Training Center into the program structure of the Center for Domestic Preparedness.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb55b7d66-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s663"},"text":"Pub. L. 109–295, title VI, § 663","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1433"},"text":"120 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
