{"tag":"section","attrib":{"id":"idb51b1946-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s394"},"text":null,"children":[{"tag":"num","attrib":{"value":"394"},"text":"§ 394.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unsolicited proposals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb51b1947-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s394/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Within 1 year of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", the Federal Acquisition Regulation shall be revised to include regulations with regard to unsolicited proposals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51b1948-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s394/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Content of regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations prescribed under subsection (a) shall require that before initiating a comprehensive evaluation, an agency contact point shall consider, among other factors, that the proposal—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51b1949-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s394/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not submitted in response to a previously published agency requirement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b194a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s394/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains technical and cost information for evaluation and overall scientific, technical or socioeconomic merit, or cost-related or price-related factors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb51b194b-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s834"},"text":"Pub. L. 107–296, title VIII, § 834","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2227"},"text":"116 Stat. 2227","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
