{"tag":"section","attrib":{"id":"idb55deec6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822"},"text":null,"children":[{"tag":"num","attrib":{"value":"822"},"text":"§ 822.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment of global catastrophic risk","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55deec7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary and the Administrator shall coordinate an assessment of global catastrophic risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55deec8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When coordinating the assessment under subsection (a), the Secretary and the Administrator shall coordinate with senior designees of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55deec9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant to the President for National Security Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deeca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Science and Technology Policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deecb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State and the Under Secretary of State for Arms Control and International Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deecc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General and the Director of the Federal Bureau of Investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deecd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Energy, the Under Secretary of Energy for Nuclear Security, and the Director of Science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deece-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Health and Human Services, the Assistant Secretary for Preparedness and Response, and the Assistant Secretary of Global Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deecf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce, the Under Secretary of Commerce for Oceans and Atmosphere, and the Under Secretary of Commerce for Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deed0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior and the Director of the United States Geological Survey;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deed1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Environmental Protection Agency and the Assistant Administrator for Water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deed2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the National Aeronautics and Space Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deed3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deed4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deed5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense, the Assistant Secretary of the Army for Civil Works, and the Chief of Engineers and Commanding General of the Army Corps of Engineers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deed6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chairman of the Joint Chiefs of Staff;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deed7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the United States Agency for International Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deed8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deed9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s822/b/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other stakeholders the Secretary and the Administrator determine appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55deeda-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXIII/s7303"},"text":"Pub. L. 117–263, div. G, title LXXIII, § 7303","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3685"},"text":"136 Stat. 3685","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
