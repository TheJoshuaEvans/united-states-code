{"tag":"section","attrib":{"id":"idb500db3b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258"},"text":null,"children":[{"tag":"num","attrib":{"value":"258"},"text":"§ 258.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeland Security Investigations Victim Assistance Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb500db3c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb500db3d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Forensic interview specialist","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “forensic interview specialist” is an interview professional who has specialized experience and training in conducting trauma-informed forensic interviews with victims of crime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500db3e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Victim","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “victim” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20141/e/2"},"text":"section 20141(e)(2) of title 34","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500db3f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Victim assistance specialist","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “victim assistance specialist” is a victim assistance professional who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb500db40-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has experience working with victims of crime in a service capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500db41-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been trained on the exposure of various forms of trauma and other stressors experienced in working with victims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500db42-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may have experience working with local government and community-based organizations, including victim advocacy centers, child advocacy centers, child welfare agencies, faith-based organizations, and other social service programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb500db43-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established, in Homeland Security Investigations of U.S. Immigration and Customs Enforcement, the Victim Assistance Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb500db44-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Victim Assistance Program shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb500db45-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide oversight, guidance, training, travel, equipment, and coordination to Homeland Security Investigations victim assistance personnel throughout the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500db46-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recruit not fewer than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb500db47-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 forensic interview specialist and 1 victim assistance specialist for each Homeland Security Investigations Special Agent in Charge office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500db48-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 1 victim assistance specialist for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb500db49-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every Homeland Security Investigations office participating in a human trafficking task force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb500db4a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every Homeland Security Investigations office participating in a child sexual exploitation task force;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500db4b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support Homeland Security Investigations regional attaché offices, to the extent necessary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500db4c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide training regarding victims’ rights, victim-related policies, roles of forensic interviewers and victim assistance specialists, and an approach that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb500db4d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" victim-centered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500db4e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trauma-informed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500db4f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" linguistically appropriate, to the extent feasible; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500db50-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s258/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase emergency items that are needed to assist identified victims in Homeland Security Investigations criminal investigations, including food, clothing, hygiene products, transportation, and temporary shelter that is not otherwise provided by a nongovernmental organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb500db51-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s447"},"text":"Pub. L. 107–296, title IV, § 447","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/118/96/s3/a"},"text":"Pub. L. 118–96, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1570"},"text":"138 Stat. 1570","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5034b52-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idb5034b53-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/96/s6"},"text":"section 6 of Pub. L. 118–96","children":[],"tail":", see Termination Date note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5034b54-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"idb5034b55-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section to cease to be effective ","children":[{"tag":"date","attrib":{"date":"2030-10-01"},"text":"Oct. 1, 2030","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/96/s6"},"text":"section 6 of Pub. L. 118–96","children":[],"tail":", set out as a Termination Date of 2024 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s252"},"text":"section 252 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5034b56-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Investigators Maintain Purposeful Awareness to Combat Trafficking Trauma Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/96/s2"},"text":"Pub. L. 118–96, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1569"},"text":"138 Stat. 1569","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/96/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established, in Homeland Security Investigations of U.S. Immigration and Customs Enforcement, the Investigators Maintain Purposeful Awareness to Combat Trafficking Trauma Program (referred to in this Act [see Short Title of 2024 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":"] as the ‘IMPACTT Program’)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The IMPACTT Program shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide outreach and training to Homeland Security Investigations employees who have been exposed to various forms of trauma in working with victims of human trafficking, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" self-awareness training for the relevant employees on recognizing the signs of burnout, compassion fatigue, critical incident stress, traumatic stress, posttraumatic stress, secondary traumatic stress, and vicarious trauma;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" training material that—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides mechanisms for self-care and resilience and notification of resources that are available through U.S. Immigration and Customs Enforcement, such as the Employee Assistance Program, the Peer Support Program, the Chaplain Program, and other relevant accredited programs that are available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides examples of potential resources that are available outside of U.S. Immigration and Customs Enforcement, which may include, faith-based and community-based resources; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide [sic] additional training to first line supervisors of relevant employees on recognizing the signs referred to in subparagraph (A) and the appropriate responses to employees exhibiting such signs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include training modules that are carried out by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" licensed and accredited clinicians who—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have been trained on the exposure of various forms of trauma and other stressors experienced in working with victims; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may have experience working with faith-based organizations, community-based organizations, counseling programs, or other social service programs; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional subject matter experts who are available; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be overseen and coordinated by the Department of Homeland Security Center for Countering Human Trafficking to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate program materials are distributed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training is offered to all relevant employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any needed travel and equipment is provided.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
