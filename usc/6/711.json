{"tag":"section","attrib":{"id":"idb556c32f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711"},"text":null,"children":[{"tag":"num","attrib":{"value":"711"},"text":"§ 711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surge Capacity Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb556c330-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb556c331-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", the Administrator shall prepare and submit to the appropriate committees of Congress a plan to establish and implement a Surge Capacity Force for deployment of individuals to respond to natural disasters, acts of terrorism, and other man-made disasters, including catastrophic incidents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5593332-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5593333-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the plan shall provide for individuals in the Surge Capacity Force to be trained and deployed under the authorities set forth in the Robert T. Stafford Disaster Relief and Emergency Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5593334-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator determines that the existing authorities are inadequate for the training and deployment of individuals in the Surge Capacity Force, the Administrator shall report to Congress as to the additional statutory authorities that the Administrator determines necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5593335-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees designated to serve","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan shall include procedures under which the Secretary shall designate employees of the Department who are not employees of the Agency and shall, in conjunction with the heads of other Executive agencies, designate employees of those other Executive agencies, as appropriate, to serve on the Surge Capacity Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5593336-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capabilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan shall ensure that the Surge Capacity Force—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5593337-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a sufficient number of individuals credentialed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s320"},"text":"section 320 of this title","children":[],"tail":" that are capable of deploying rapidly and efficiently after activation to prepare for, respond to, and recover from natural disasters, acts of terrorism, and other man-made disasters, including catastrophic incidents; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5593338-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a sufficient number of full-time, highly trained individuals credentialed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s320"},"text":"section 320 of this title","children":[],"tail":" to lead and manage the Surge Capacity Force."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5593339-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan shall ensure that the Administrator provides appropriate and continuous training to members of the Surge Capacity Force to ensure such personnel are adequately trained on the Agency’s programs and policies for natural disasters, acts of terrorism, and other man-made disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb559333a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No impact on agency personnel ceiling","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Surge Capacity Force members shall not be counted against any personnel ceiling applicable to the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb559333b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may provide members of the Surge Capacity Force with travel expenses, including per diem in lieu of subsistence, at rates authorized for employees of agencies under subchapter I of chapter 57 of title 5 for the purpose of participating in any training that relates to service as a member of the Surge Capacity Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb559333c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immediate implementation of Surge Capacity Force involving Federal employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", the Administrator shall develop and implement—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb559333d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedures under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559333e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s711/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other elements of the plan needed to establish the portion of the Surge Capacity Force consisting of individuals designated under those procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb559333f-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s624"},"text":"Pub. L. 109–295, title VI, § 624","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1419"},"text":"120 Stat. 1419","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5593340-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5593341-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5593342-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsec. (a)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", which is classified principally to chapter 68 (§ 5121 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
