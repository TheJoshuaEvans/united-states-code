{"tag":"section","attrib":{"id":"idb53a12ff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604"},"text":null,"children":[{"tag":"num","attrib":{"value":"604"},"text":"§ 604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urban Area Security Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb53a1300-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established an Urban Area Security Initiative to provide grants to assist high-risk urban areas in preventing, preparing for, protecting against, and responding to acts of terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a1301-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment and designation of high-risk urban areas","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a1302-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall designate high-risk urban areas to receive grants under this section based on procedures under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1303-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial assessment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a1304-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, the Administrator shall conduct an initial assessment of the relative threat, vulnerability, and consequences from acts of terrorism faced by each eligible metropolitan area, including consideration of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53a1305-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the factors set forth in subparagraphs (A) through (H) and (K) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s608/a/1"},"text":"section 608(a)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53a1306-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information and materials submitted under subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a1307-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of information by eligible metropolitan areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to conducting each initial assessment under subparagraph (A), the Administrator shall provide each eligible metropolitan area with, and shall notify each eligible metropolitan area of, the opportunity to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53a1308-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit information that the eligible metropolitan area believes to be relevant to the determination of the threat, vulnerability, and consequences it faces from acts of terrorism; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53a1309-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the risk assessment conducted by the Department of that eligible metropolitan area, including the bases for the assessment by the Department of the threat, vulnerability, and consequences from acts of terrorism faced by that eligible metropolitan area, and remedy erroneous or incomplete information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a130a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of high-risk urban areas","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a130b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53a130c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each fiscal year, after conducting the initial assessment under paragraph (2), and based on that assessment, the Administrator shall designate high-risk urban areas that may submit applications for grants under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53a130d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (2), the Administrator may—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb53a130e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any case where an eligible metropolitan area consists of more than 1 metropolitan division (as that term is defined by the Office of Management and Budget) designate more than 1 high-risk urban area within a single eligible metropolitan area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb53a130f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate an area that is not an eligible metropolitan area as a high-risk urban area based on the assessment by the Administrator of the relative threat, vulnerability, and consequences from acts of terrorism faced by the area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53a1310-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection may be construed to require the Administrator to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb53a1311-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/3/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate all eligible metropolitan areas that submit information to the Administrator under paragraph (2)(B)(i) as high-risk urban areas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb53a1312-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/3/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate all areas within an eligible metropolitan area as part of the high-risk urban area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a1313-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdictions included in high-risk urban areas","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53a1314-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In designating high-risk urban areas under subparagraph (A), the Administrator shall determine which jurisdictions, at a minimum, shall be included in each high-risk urban area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53a1315-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional jurisdictions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A high-risk urban area designated by the Administrator may, in consultation with the State or States in which such high-risk urban area is located, add additional jurisdictions to the high-risk urban area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a1316-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a1317-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An area designated as a high-risk urban area under subsection (b) may apply for a grant under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1318-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum contents of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In an application for a grant under this section, a high-risk urban area shall submit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a1319-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan describing the proposed division of responsibilities and distribution of funding among the local and tribal governments in the high-risk urban area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a131a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of an individual to serve as a high-risk urban area liaison with the Department and among the various jurisdictions in the high-risk urban area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a131b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such information in support of the application as the Administrator may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a131c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Applicants for grants under this section shall apply or reapply on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a131d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State review and transmission","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a131e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure consistency with State homeland security plans, a high-risk urban area applying for a grant under this section shall submit its application to each State within which any part of that high-risk urban area is located for review before submission of such application to the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a131f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after receiving an application from a high-risk urban area under subparagraph (A), a State shall transmit the application to the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a1320-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity for State comment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Governor of a State determines that an application of a high-risk urban area is inconsistent with the State homeland security plan of that State, or otherwise does not support the application, the Governor shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53a1321-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/c/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Administrator, in writing, of that fact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53a1322-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/c/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an explanation of the reason for not supporting the application at the time of transmission of the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1323-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity to amend","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In considering applications for grants under this section, the Administrator shall provide applicants with a reasonable opportunity to correct defects in the application, if any, before making final awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a1324-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of awards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a1325-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator approves the application of a high-risk urban area for a grant under this section, the Administrator shall distribute the grant funds to the State or States in which that high-risk urban area is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1326-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State distribution of funds","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a1327-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 45 days after the date that a State receives grant funds under paragraph (1), that State shall provide the high-risk urban area awarded that grant not less than 80 percent of the grant funds. Any funds retained by a State shall be expended on items, services, or activities that benefit the high-risk urban area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a1328-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funds retained","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall provide each relevant high-risk urban area with an accounting of the items, services, or activities on which any funds retained by the State under subparagraph (A) were expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1329-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interstate urban areas","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If parts of a high-risk urban area awarded a grant under this section are located in 2 or more States, the Administrator shall distribute to each such State—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a132a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a portion of the grant funds in accordance with the proposed distribution set forth in the application; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a132b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if no agreement on distribution has been reached, a portion of the grant funds determined by the Administrator to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a132c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications regarding distribution of grant funds to high-risk urban areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives grant funds under paragraph (1) shall certify to the Administrator that the State has made available to the applicable high-risk urban area the required funds under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a132d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for grants under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a132e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $850,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a132f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $950,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1330-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,050,000,000 for fiscal year 2010;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1331-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,150,000,000 for fiscal year 2011;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1332-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,300,000,000 for fiscal year 2012; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1333-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s604/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for fiscal year 2013, and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53a1334-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXX/s2003"},"text":"Pub. L. 107–296, title XX, § 2003","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tI/s101"},"text":"Pub. L. 110–53, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/274"},"text":"121 Stat. 274","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
