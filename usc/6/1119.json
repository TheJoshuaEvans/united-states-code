{"tag":"section","attrib":{"id":"idb5676508-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119"},"text":null,"children":[{"tag":"num","attrib":{"value":"1119"},"text":"§ 1119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary use of credentialing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5676509-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An applicable individual who is subject to credentialing or a background investigation may satisfy that requirement by obtaining a valid transportation security card.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb567650a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance of cards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Homeland Security—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb567650b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall expand the transportation security card program, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70105"},"text":"section 70105 of title 46","children":[],"tail":", to allow an applicable individual who is subject to credentialing or a background investigation to apply for a transportation security card; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb567650c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may charge reasonable fees, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s469/a"},"text":"section 469(a) of this title","children":[],"tail":", for providing the necessary credentialing and background investigation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb567650d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vetting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall develop and implement a plan to utilize, in addition to any background check required for initial issue, the Federal Bureau of Investigation’s Rap Back Service and other vetting tools as appropriate, including the No-Fly and Selectee lists, to get immediate notification of any criminal activity relating to any person with a valid transportation security card.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb567650e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb567650f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicable individual who is subject to credentialing or a background investigation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “applicable individual who is subject to credentialing or a background investigation” means only an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5676510-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of employment is regulated by the Transportation Security Administration, Department of Transportation, or Coast Guard and is required to have a background records check to obtain a hazardous materials endorsement on a commercial driver’s license issued by a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5103a"},"text":"section 5103a of title 49","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5676511-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to have a credential and background records check under section 622(d)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002143"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002143"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title at a facility with activities that are regulated by the Transportation Security Administration, Department of Transportation, or Coast Guard."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5676512-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Valid transportation security card","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “valid transportation security card” means a transportation security card that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5676513-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70105"},"text":"section 70105 of title 46","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5676514-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not expired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5676515-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shows ","children":[{"tag":"ref","attrib":{"idref":"fn002144"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002144"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" no signs of tampering; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5676516-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1119/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bears ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" a photograph of the individual representing such card."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5676517-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1977"},"text":"Pub. L. 115–254, div. K, title I, § 1977","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3617"},"text":"132 Stat. 3617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5676518-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5676519-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb567651a-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s622"},"text":"Section 622 of this title","children":[],"tail":", referred to in subsec. (d)(1)(B), was omitted from the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb567651b-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the TSA Modernization Act and also as part of the FAA Reauthorization Act of 2018, and not as part of the Implementing Recommendations of the 9/11 Commission Act of 2007 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb567651c-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idb567651d-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definition","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For definition of “Administrator” as used in this section, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1902"},"text":"section 1902 of Pub. L. 115–254","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s101"},"text":"section 101 of Title 49","children":[],"tail":", Transportation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
