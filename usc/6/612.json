{"tag":"section","attrib":{"id":"idb53c8430-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612"},"text":null,"children":[{"tag":"num","attrib":{"value":"612"},"text":"§ 612.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb53c8431-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits of grant programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53c8432-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance requirements","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c8433-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of a grant administered by the Department that expends not less than $500,000 in Federal funds during its fiscal year shall submit to the Administrator a copy of the organization-wide financial and compliance audit report required under chapter 75 of title 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8434-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Department and each recipient of a grant administered by the Department shall provide the Comptroller General and any officer or employee of the Government Accountability Office with full access to information regarding the activities carried out related to any grant administered by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8435-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improper payments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with subchapter IV of chapter 33 of title 31, for each of the grant programs under sections 604 and 605 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s762"},"text":"section 762 of this title","children":[],"tail":", the Administrator shall specify policies and procedures for—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb53c8436-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying activities funded under any such grant program that are susceptible to significant improper payments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c8437-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reporting any improper payments to the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c8438-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency program review","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c8439-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less than once every 2 years, the Administrator shall conduct, for each State and high-risk urban area receiving a grant administered by the Department, a programmatic and financial review of all grants awarded by the Department to prevent, prepare for, protect against, or respond to natural disasters, acts of terrorism, or other man-made disasters, excluding assistance provided under section 203, title IV, or title V of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5133"},"text":"42 U.S.C. 5133","children":[],"tail":", 5170 et seq., and 5191 et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c843a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each review under subparagraph (A) shall, at a minimum, examine—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53c843b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the funds awarded were used in accordance with the law, program guidance, and State homeland security plans or other applicable plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c843c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which funds awarded enhanced the ability of a grantee to prevent, prepare for, protect against, and respond to natural disasters, acts of terrorism, and other man-made disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c843d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to any other amounts authorized to be appropriated to the Administrator, there are authorized to be appropriated to the Administrator for reviews under this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53c843e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $8,000,000 for each of fiscal years 2008, 2009, and 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c843f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for fiscal year 2011, and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c8440-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to ensure that States and high-risk urban areas are using grants administered by the Department appropriately to meet target capabilities and preparedness priorities, the Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c8441-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any such State or high-risk urban area conducts or participates in exercises under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s748/b"},"text":"section 748(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8442-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use performance metrics in accordance with the comprehensive assessment system under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s749"},"text":"section 749 of this title","children":[],"tail":" and ensure that any such State or high-risk urban area regularly tests its progress against such metrics through the exercises required under subparagraph (A);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8443-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the remedial action management program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s750"},"text":"section 750 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8444-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that each State receiving a grant administered by the Department submits a report to the Administrator on its level of preparedness, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s752/c"},"text":"section 752(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c8445-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration of assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting program reviews and performance audits under paragraph (2), the Administrator and the Inspector General of the Department shall take into account the performance assessment elements required under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c8446-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery audits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall conduct a recovery audit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3352/i"},"text":"section 3352(i) of title 31","children":[],"tail":" for any grant administered by the Department with a total value of not less than $1,000,000, if the Administrator finds that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c8447-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a financial audit has identified improper payments that can be recouped; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8448-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is cost effective to conduct a recovery audit to recapture the targeted funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c8449-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedies for noncompliance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c844a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, as a result of a review or audit under this subsection or otherwise, the Administrator finds that a recipient of a grant under this subchapter has failed to substantially comply with any provision of law or with any regulations or guidelines of the Department regarding eligible expenditures, the Administrator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53c844b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the amount of payment of grant funds to the recipient by an amount equal to the amount of grants funds that were not properly expended by the recipient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c844c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the use of grant funds to programs, projects, or activities not affected by the failure to comply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c844d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refer the matter to the Inspector General of the Department for further investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c844e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate any payment of grant funds to be made to the recipient; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c844f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/6/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take such other action as the Administrator determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8450-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall apply an appropriate penalty under subparagraph (A) until such time as the Administrator determines that the grant recipient is in full compliance with the law and with applicable guidelines or regulations of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c8451-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by grant recipients","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53c8452-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly reports on homeland security spending","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c8453-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As a condition of receiving a grant under section 604 or 605 of this title, a State, high-risk urban area, or directly eligible tribe shall, not later than 30 days after the end of each Federal fiscal quarter, submit to the Administrator a report on activities performed using grant funds during that fiscal quarter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8454-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under subparagraph (A) shall at a minimum include, for the applicable State, high-risk urban area, or directly eligible tribe, and each subgrantee thereof—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53c8455-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount obligated to that recipient under section 604 or 605 of this title in that quarter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c8456-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds received and expended under section 604 or 605 of this title by that recipient in that quarter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c8457-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary description of expenditures made by that recipient using such funds, and the purposes for which such expenditures were made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8458-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" End-of-year report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report submitted under subparagraph (A) by a State, high-risk urban area, or directly eligible tribe relating to the last quarter of any fiscal year shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53c8459-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and date of receipt of all funds received under the grant during that fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c845a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity of, and amount provided to, any subgrantee for that grant during that fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c845b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and the dates of disbursements of all such funds expended in compliance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s611/a/1"},"text":"section 611(a)(1) of this title","children":[],"tail":" or under mutual aid agreements or other sharing arrangements that apply within the State, high-risk urban area, or directly eligible tribe, as applicable, during that fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c845c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/b/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the funds were used by each recipient or subgrantee during that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c845d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any State applying for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s605"},"text":"section 605 of this title","children":[],"tail":" shall submit to the Administrator annually a State preparedness report, as required by "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s752/c"},"text":"section 752(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c845e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by the Administrator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53c845f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Preparedness Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall submit to the appropriate committees of Congress annually the Federal Preparedness Report required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s752/a"},"text":"section 752(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c8460-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk assessment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c8461-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, the Administrator shall provide to the appropriate committees of Congress a detailed and comprehensive explanation of the methodologies used to calculate risk and compute the allocation of funds for grants administered by the Department, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53c8462-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all variables included in the risk assessment and the weights assigned to each such variable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c8463-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of how each such variable, as weighted, correlates to risk, and the basis for concluding there is such a correlation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c8464-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any change in the methodologies from the previous fiscal year, including changes in variables considered, weighting of those variables, and computational methods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8465-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified annex","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The information required under subparagraph (A) shall be provided in unclassified form to the greatest extent possible, and may include a classified annex if necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8466-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, the information required under subparagraph (A) shall be provided on the earlier of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53c8467-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" October 31; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53c8468-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 days before the issuance of any program guidance for grants administered by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c8469-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s612/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal funding report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the end of each fiscal year, the Administrator shall submit to the appropriate committees of Congress a report setting forth the amount of funding provided during that fiscal year to Indian tribes under any grant program administered by the Department, whether provided directly or through a subgrant from a State or high-risk urban area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53c846a-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXX/s2022"},"text":"Pub. L. 107–296, title XX, § 2022","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tI/s101"},"text":"Pub. L. 110–53, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/287"},"text":"121 Stat. 287","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/204/s2/h/6/B/iii"},"text":"Pub. L. 111–204, § 2(h)(6)(B)(iii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-22"},"text":"July 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2231"},"text":"124 Stat. 2231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/284/s2/c/1"},"text":"Pub. L. 113–284, § 2(c)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3089"},"text":"128 Stat. 3089","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/117/s3/b/2"},"text":"Pub. L. 116–117, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/133"},"text":"134 Stat. 133","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb53c846b-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb53c846c-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb53c846d-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsec. (a)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":". Section 203 of the Act is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5133"},"text":"section 5133 of Title 42","children":[],"tail":", The Public Health and Welfare. Titles IV and V of the Act are classified generally to subchapters IV (§ 5170 et seq.) and IV–A (§ 5191 et seq.), respectively, of chapter 68 of Title 42. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb53c846e-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/117/s3/b/2/A"},"text":"Pub. L. 116–117, § 3(b)(2)(A)","children":[],"tail":", substituted “Consistent with subchapter IV of chapter 33 of title 31” for “Consistent with the Improper Payments Information Act of 2002 ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3321"},"text":"31 U.S.C. 3321","children":[],"tail":" note)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/117/s3/b/2/B"},"text":"Pub. L. 116–117, § 3(b)(2)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3352/i"},"text":"section 3352(i) of title 31","children":[],"tail":"” for “section 2(h) of the Improper Payments Elimination and Recovery Act of 2010 ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3321"},"text":"31 U.S.C. 3321","children":[],"tail":" note)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a)(3) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/284"},"text":"Pub. L. 113–284","children":[],"tail":" redesignated pars. (4) to (7) as (3) to (6), respectively, substituted, in par. (4), “paragraph (2)” for “paragraphs (2) and (3)” and “paragraph (3)” for “paragraph (4)”, and struck out former par. (3) which related to Office of Inspector General performance audits."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/204"},"text":"Pub. L. 111–204","children":[],"tail":" substituted “under section 2(h) of the Improper Payments Elimination and Recovery Act of 2010 ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3321"},"text":"31 U.S.C. 3321","children":[],"tail":" note)” for “(as that term is defined by the Director of the Office of Management and Budget under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3561"},"text":"section 3561 of title 31","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb53c846f-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb53c8470-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2014 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/284/s2/c/3"},"text":"Pub. L. 113–284, § 2(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3090"},"text":"128 Stat. 3090","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/284/s2/c/3"},"text":"“The amendments made by this subsection [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2015-01-01"},"text":"January 1, 2015","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
