{"tag":"section","attrib":{"id":"idb5462109-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657"},"text":null,"children":[{"tag":"num","attrib":{"value":"657"},"text":"§ 657.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cyber Security Enhancement Act of 2002","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb546210a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section may be cited as the “Cyber Security Enhancement Act of 2002”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb546210b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendment of sentencing guidelines relating to certain computer crimes","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb546210c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Directive to the United States Sentencing Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Pursuant to its authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s994/p"},"text":"section 994(p) of title 28","children":[],"tail":" and in accordance with this subsection, the United States Sentencing Commission shall review and, if appropriate, amend its guidelines and its policy statements applicable to persons convicted of an offense under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1030"},"text":"section 1030 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb546210d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subsection, the Sentencing Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb546210e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the sentencing guidelines and policy statements reflect the serious nature of the offenses described in paragraph (1), the growing incidence of such offenses, and the need for an effective deterrent and appropriate punishment to prevent such offenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb546210f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider the following factors and the extent to which the guidelines may or may not account for them—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5462110-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential and actual loss resulting from the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5462111-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of sophistication and planning involved in the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5462112-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the offense was committed for purposes of commercial advantage or private financial benefit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5462113-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the defendant acted with malicious intent to cause harm in committing the offense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5462114-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the offense violated the privacy rights of individuals harmed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5462115-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the offense involved a computer used by the government in furtherance of national defense, national security, or the administration of justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5462116-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the violation was intended to or had the effect of significantly interfering with or disrupting a critical infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5462117-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the violation was intended to or had the effect of creating a threat to public health or safety, or injury to any person;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5462118-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure reasonable consistency with other relevant directives and with other sentencing guidelines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5462119-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" account for any additional aggravating or mitigating circumstances that might justify exceptions to the generally applicable sentencing ranges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb546211a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make any necessary conforming changes to the sentencing guidelines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb546211b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure that the guidelines adequately meet the purposes of sentencing as set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3553/a/2"},"text":"section 3553(a)(2) of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb546211c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report on computer crimes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2003-05-01"},"text":"May 1, 2003","children":[],"tail":", the United States Sentencing Commission shall submit a brief report to Congress that explains any actions taken by the Sentencing Commission in response to this section and includes any recommendations the Commission may have regarding statutory penalties for offenses under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1030"},"text":"section 1030 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb546211d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency disclosure exception","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb546211e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb546211f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s657/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting of disclosures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A government entity that receives a disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2702/b"},"text":"section 2702(b) of title 18","children":[],"tail":" shall file, not later than 90 days after such disclosure, a report to the Attorney General stating the paragraph of that section under which the disclosure was made, the date of the disclosure, the entity to which the disclosure was made, the number of customers or subscribers to whom the information disclosed pertained, and the number of communications, if any, that were disclosed. The Attorney General shall publish all such reports into a single report to be submitted to Congress 1 year after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5462120-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2207"},"text":"Pub. L. 107–296, title XXII, § 2207","children":[],"tail":", formerly title II, § 225, "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2156"},"text":"116 Stat. 2156","children":[],"tail":"; renumbered title XXII, § 2207, "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/2/I"},"text":"Pub. L. 115–278, § 2(g)(2)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4178"},"text":"132 Stat. 4178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5462121-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5462122-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5462123-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s145"},"text":"section 145 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/115/278"},"text":"Pub. L. 115–278","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s2207"},"text":"section 2207 of Pub. L. 107–296","children":[],"tail":". Subsecs. (d)(1) and (e) to (j) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s2207"},"text":"section 2207 of Pub. L. 107–296","children":[],"tail":" amended sections 1030, 2511, 2512, 2520, 2701 to 2703, and 3125 of Title 18, Crimes and Criminal Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
