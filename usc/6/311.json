{"tag":"section","attrib":{"id":"idb508075e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311"},"text":null,"children":[{"tag":"num","attrib":{"value":"311"},"text":"§ 311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb508075f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Administrator” means the Administrator of the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080760-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Agency” means the Federal Emergency Management Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080761-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “catastrophic incident” means any natural disaster, act of terrorism, or other man-made disaster that results in extraordinary levels of casualties or damage or disruption severely affecting the population (including mass evacuations), infrastructure, environment, economy, national morale, or government functions in an area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080762-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “credentialed” and “credentialing” mean having provided, or providing, respectively, documentation that identifies personnel and authenticates and verifies the qualifications of such personnel by ensuring that such personnel possess a minimum common level of training, experience, physical and medical fitness, and capability appropriate for a particular position in accordance with standards created under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s320"},"text":"section 320 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080763-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Federal coordinating officer” means a Federal coordinating officer as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5143"},"text":"section 5143 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080764-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “interoperable” has the meaning given the term “interoperable communications” under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s194/g/1"},"text":"section 194(g)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080765-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “National Incident Management System” means a system to enable effective, efficient, and collaborative incident management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080766-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “National Response Plan” means the National Response Plan or any successor plan prepared under section 314(a)(6) ","children":[{"tag":"ref","attrib":{"idref":"fn002051"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002051"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080767-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Regional Administrator” means a Regional Administrator appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s317"},"text":"section 317 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080768-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Regional Office” means a Regional Office established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s317"},"text":"section 317 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080769-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “resources” means personnel and major items of equipment, supplies, and facilities available or potentially available for responding to a natural disaster, act of terrorism, or other man-made disaster;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb508076a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “surge capacity” means the ability to rapidly and substantially increase the provision of search and rescue capabilities, food, water, medicine, shelter and housing, medical care, evacuation capacity, staffing (including disaster assistance employees), and other resources necessary to save lives and protect property during a catastrophic incident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb508076b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “tribal government” means the government of any entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s101/13/B"},"text":"section 101(13)(B) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb508076c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s311/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “typed” and “typing” mean having evaluated, or evaluating, respectively, a resource in accordance with standards created under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s320"},"text":"section 320 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb508076d-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tV/s501"},"text":"Pub. L. 107–296, title V, § 501","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s611/10"},"text":"Pub. L. 109–295, title VI, § 611(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1395"},"text":"120 Stat. 1395","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tIV/s401/a"},"text":"Pub. L. 110–53, title IV, § 401(a)","children":[],"tail":", title V, § 502(c)(1), "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/301"},"text":"121 Stat. 301","children":[],"tail":", 311; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXIX/s1913/b/2"},"text":"Pub. L. 114–328, div. A, title XIX, § 1913(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2687"},"text":"130 Stat. 2687","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb508076e-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb508076f-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5080770-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s314/a/6"},"text":"Section 314(a)(6) of this title","children":[],"tail":", referred to in par. (8), was in the original “section 502(a)(6)” and was translated as meaning "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s502"},"text":"section 502 of Pub. L. 107–296","children":[],"tail":" prior to its redesignation as section 504 by "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/s611/8"},"text":"Pub. L. 109–295, § 611(8)","children":[],"tail":", and not section 506 which was redesignated section 502 by "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/s611/9"},"text":"Pub. L. 109–295, § 611(9)","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s312"},"text":"section 312 of this title","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb5080771-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 311, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tV/s501"},"text":"Pub. L. 107–296, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2212"},"text":"116 Stat. 2212","children":[],"tail":", provided for an Under Secretary for Emergency Preparedness and Response, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s611/2"},"text":"Pub. L. 109–295, title VI, § 611(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1395"},"text":"120 Stat. 1395","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5080772-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" substituted “101(13)(B)” for “101(11)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Pars. (4) to (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s401/a/1"},"text":"Pub. L. 110–53, § 401(a)(1)","children":[],"tail":"–(4), added pars. (4) and (11) and redesignated former pars. (4) to (10) as (5) to (10) and (12), respectively. Former par. (11) redesignated (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s502/c/1"},"text":"Pub. L. 110–53, § 502(c)(1)","children":[],"tail":", substituted “101(11)(B)” for “101(10)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s401/a/1"},"text":"Pub. L. 110–53, § 401(a)(1)","children":[],"tail":", redesignated par. (11) as (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s401/a/5"},"text":"Pub. L. 110–53, § 401(a)(5)","children":[],"tail":"–(7), added par. (14)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5080773-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb5080774-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any reference to the Administrator of the Federal Emergency Management Agency in title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":" or an amendment by title VI to be considered to refer and apply to the Director of the Federal Emergency Management Agency until "},{"tag":"date","attrib":{"date":"2007-03-31"},"text":"Mar. 31, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/s612/f/2"},"text":"section 612(f)(2) of Pub. L. 109–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s313"},"text":"section 313 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5080775-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Interim Actions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s612/f/1"},"text":"Pub. L. 109–295, title VI, § 612(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1411"},"text":"120 Stat. 1411","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/295/tVI/s612/f/1"},"text":"“During the period beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":"] and ending on "},{"tag":"date","attrib":{"date":"2007-03-31"},"text":"March 31, 2007","children":[],"tail":", the Secretary [of Homeland Security], the Under Secretary for Preparedness, and the Director of the Federal Emergency Management Agency shall take such actions as are necessary to provide for the orderly implementation of any amendment under this subtitle [subtitle A (§§ 611–614) of title VI of "},{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":", see Tables for classification] that takes effect on "},{"tag":"date","attrib":{"date":"2007-03-31"},"text":"March 31, 2007","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
