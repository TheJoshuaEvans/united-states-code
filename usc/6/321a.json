{"tag":"section","attrib":{"id":"idb50ce8cf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a"},"text":null,"children":[{"tag":"num","attrib":{"value":"321a"},"text":"§ 321a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evacuation plans and exercises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb50ce8d0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, and subject to subsection (d), grants made to States or local or tribal governments by the Department through the State Homeland Security Grant Program or the Urban Area Security Initiative may be used to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50ce8d1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish programs for the development and maintenance of mass evacuation plans under subsection (b) in the event of a natural disaster, act of terrorism, or other man-made disaster;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce8d2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare for the execution of such plans, including the development of evacuation routes and the purchase and stockpiling of necessary supplies and shelters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce8d3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct exercises of such plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50ce8d4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan development","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the mass evacuation plans authorized under subsection (a), each State, local, or tribal government shall, to the maximum extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50ce8d5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish incident command and decision making processes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce8d6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that State, local, and tribal government plans, including evacuation routes, are coordinated and integrated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce8d7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify primary and alternative evacuation routes and methods to increase evacuation capabilities along such routes such as conversion of two-way traffic to one-way evacuation routes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce8d8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify evacuation transportation modes and capabilities, including the use of mass and public transit capabilities, and coordinating and integrating evacuation plans for all populations including for those individuals located in hospitals, nursing homes, and other institutional living facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce8d9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop procedures for informing the public of evacuation plans before and during an evacuation, including individuals—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50ce8da-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with disabilities or other special needs, including the elderly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce8db-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with limited English proficiency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce8dc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who might otherwise have difficulty in obtaining such information; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce8dd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify shelter locations and capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50ce8de-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50ce8df-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may establish any guidelines, standards, or requirements determined appropriate to administer this section and to ensure effective mass evacuation planning for State, local, and tribal areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce8e0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requested assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make assistance available upon request of a State, local, or tribal government to assist hospitals, nursing homes, and other institutions that house individuals with special needs to establish, maintain, and exercise mass evacuation plans that are coordinated and integrated into the plans developed by that State, local, or tribal government under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50ce8e1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multipurpose funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to preclude a State, local, or tribal government from using grant funds in a manner that enhances preparedness for a natural or man-made disaster unrelated to an act of terrorism, if such use assists such government in building capabilities for terrorism preparedness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb50ce8e2-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tV/s512"},"text":"Pub. L. 107–296, title V, § 512","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s611/13"},"text":"Pub. L. 109–295, title VI, § 611(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1407"},"text":"120 Stat. 1407","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tI/s102/b"},"text":"Pub. L. 110–53, title I, § 102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/293"},"text":"121 Stat. 293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb50ce8e3-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb50ce8e4-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb50ce8e5-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53"},"text":"Pub. L. 110–53","children":[],"tail":" inserted “, including the elderly” after “needs”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb50ce8e6-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb50ce8e7-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any reference to the Administrator of the Federal Emergency Management Agency in title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":" or an amendment by title VI to be considered to refer and apply to the Director of the Federal Emergency Management Agency until "},{"tag":"date","attrib":{"date":"2007-03-31"},"text":"Mar. 31, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/s612/f/2"},"text":"section 612(f)(2) of Pub. L. 109–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s313"},"text":"section 313 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
