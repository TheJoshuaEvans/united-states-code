{"tag":"section","attrib":{"id":"idb562a986-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s972"},"text":null,"children":[{"tag":"num","attrib":{"value":"972"},"text":"§ 972.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For fiscal years 2008 and 2009, the Commissioner shall increase by not less than 50 the number of full-time personnel engaged in the validation and revalidation of C–TPAT participants (over the number of such personnel on the last day of the previous fiscal year), and shall provide appropriate training and support to such additional personnel.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb562a987-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tII/s222"},"text":"Pub. L. 109–347, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1914"},"text":"120 Stat. 1914","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
