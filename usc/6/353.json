{"tag":"section","attrib":{"id":"idb518cfb9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353"},"text":null,"children":[{"tag":"num","attrib":{"value":"353"},"text":"§ 353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition professional career program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb518cfba-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Department an acquisition professional career program to develop a cadre of acquisition professionals within the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb518cfbb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary for Management shall administer the acquisition professional career program established pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb518cfbc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary for Management shall carry out the following with respect to the acquisition professional career program.","children":[{"tag":"ref","attrib":{"idref":"fn002061"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002061"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be a colon."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb518cfbd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Designate the occupational series, grades, and number of acquisition positions throughout the Department to be included in the program and manage centrally such positions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb518cfbe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establish and publish on the Department’s website eligibility criteria for candidates to participate in the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb518cfbf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Carry out recruitment efforts to attract candidates—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb518cfc0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from institutions of higher education, including such institutions with established acquisition specialties and courses of study, historically Black colleges and universities, and Hispanic-serving institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb518cfc1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with diverse work experience outside of the Federal Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb518cfc2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with military service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb518cfc3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hire eligible candidates for designated positions under the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb518cfc4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Develop a structured program comprised of acquisition training, on-the-job experience, Department-wide rotations, mentorship, shadowing, and other career development opportunities for program participants.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb518cfc5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provide, beyond required training established for program participants, additional specialized acquisition training, including small business contracting and innovative acquisition techniques training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb518cfc6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", and annually thereafter through 2027, the Secretary shall submit to the Committee on Homeland Security of the House of Representatives and the Committee on Homeland Security and Governmental Affairs of the Senate a report on the acquisition professional career program. Each such report shall include the following information:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb518cfc7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of candidates approved for the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb518cfc8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of candidates who commenced participation in the program, including generalized information on such candidates’ backgrounds with respect to education and prior work experience, but not including personally identifiable information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb518cfc9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A breakdown of the number of participants hired under the program by type of acquisition position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb518cfca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of Department components and offices that participated in the program and information regarding length of time of each program participant in each rotation at such components or offices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb518cfcb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Program attrition rates and post-program graduation retention data, including information on how such data compare to the prior year’s data, as available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb518cfcc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department’s recruiting efforts for the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb518cfcd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department’s efforts to promote retention of program participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb518cfce-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb518cfcf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hispanic-serving institution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Hispanic-serving institution” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1101a"},"text":"section 1101a of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb518cfd0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historically Black colleges and universities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “historically Black colleges and universities” has the meaning given the term “part B institution” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1061/2"},"text":"section 1061(2) of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb518cfd1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s353/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institution of higher education","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “institution of higher education” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb518cfd2-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVII/s713"},"text":"Pub. L. 107–296, title VII, § 713","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXIV/s6405/a"},"text":"Pub. L. 117–81, div. F, title LXIV, § 6405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2401"},"text":"135 Stat. 2401","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
