{"tag":"section","attrib":{"id":"idb52be233-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488b"},"text":null,"children":[{"tag":"num","attrib":{"value":"488b"},"text":"§ 488b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection and auditing of records","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a process for the periodic inspection and auditing of the records maintained by owners of ammonium nitrate facilities for the purpose of monitoring compliance with this part or for the purpose of deterring or preventing the misappropriation or use of ammonium nitrate in an act of terrorism.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb52be234-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s899C"},"text":"Pub. L. 107–296, title VIII, § 899C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dE/tV/s563/a"},"text":"Pub. L. 110–161, div. E, title V, § 563(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2087"},"text":"121 Stat. 2087","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
