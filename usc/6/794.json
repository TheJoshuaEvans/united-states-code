{"tag":"section","attrib":{"id":"idb55dee67-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s794"},"text":null,"children":[{"tag":"num","attrib":{"value":"794"},"text":"§ 794.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on length of certain noncompetitive contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55dee68-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s794/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall promulgate regulations applicable to contracts described in subsection (c) to restrict the contract period of any such contract entered into using procedures other than competitive procedures pursuant to the exception provided in paragraph (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3304/a"},"text":"section 3304(a) of title 41","children":[],"tail":" to the minimum contract period necessary—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55dee69-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s794/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet the urgent and compelling requirements of the work to be performed under the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee6a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s794/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into another contract for the required goods or services through the use of competitive procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee6b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s794/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific contract period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The regulations promulgated under subsection (a) shall require the contract period to not to exceed ","children":[{"tag":"ref","attrib":{"idref":"fn002128"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002128"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “period not to exceed”."}],"tail":" 150 days, unless the Secretary determines that exceptional circumstances apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee6c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s794/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section applies to any contract in an amount greater than the simplified acquisition threshold (as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":") entered into by the Department to facilitate response to or recovery from a natural disaster, act of terrorism, or other man-made disaster."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55dee6d-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s695"},"text":"Pub. L. 109–295, title VI, § 695","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1460"},"text":"120 Stat. 1460","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb55dee6e-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb55dee6f-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb55dee70-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (a), “paragraph (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3304/a"},"text":"section 3304(a) of title 41","children":[],"tail":"” substituted for “paragraph (2) of section 303(c) of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s253/c"},"text":"41 U.S.C. 253(c)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (c), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":"” substituted for “section 4 of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s403"},"text":"41 U.S.C. 403","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
