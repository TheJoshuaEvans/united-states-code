{"tag":"section","attrib":{"id":"idb5034b58-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271"},"text":null,"children":[{"tag":"num","attrib":{"value":"271"},"text":"§ 271.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Bureau of Citizenship and Immigration Services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5034b59-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Bureau","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5034b5a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Department a bureau to be known as the “Bureau of Citizenship and Immigration Services”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034b5b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of the Bureau of Citizenship and Immigration Services shall be the Director of the Bureau of Citizenship and Immigration Services, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5034b5c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall report directly to the Deputy Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5034b5d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have a minimum of 5 years of management experience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5034b5e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be paid at the same level as the Assistant Secretary of the Bureau of Border Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034b5f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Bureau of Citizenship and Immigration Services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5034b60-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish the policies for performing such functions as are transferred to the Director by this section or this chapter or otherwise vested in the Director by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5034b61-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall oversee the administration of such policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5034b62-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall advise the Deputy Secretary with respect to any policy or operation of the Bureau of Citizenship and Immigration Services that may affect the Bureau of Border Security of the Department, including potentially conflicting policies or operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5034b63-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish national immigration services policies and priorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5034b64-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall meet regularly with the Ombudsman described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s272"},"text":"section 272 of this title","children":[],"tail":" to correct serious service problems identified by the Ombudsman; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5034b65-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish procedures requiring a formal response to any recommendations submitted in the Ombudsman’s annual report to Congress within 3 months after its submission to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034b66-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Managerial rotation program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5034b67-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the effective date specified in section 455,","children":[{"tag":"ref","attrib":{"idref":"fn002043"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002043"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the Director of the Bureau of Citizenship and Immigration Services shall design and implement a managerial rotation program under which employees of such bureau holding positions involving supervisory or managerial responsibility and classified, in accordance with chapter 51 of title 5, as a GS–14 or above, shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb5034b68-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gain some experience in all the major functions performed by such bureau; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5034b69-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work in at least one field office and one service center of such bureau.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5034b6a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after the effective date specified in section 455,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" the Secretary shall submit a report to Congress on the implementation of such program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034b6b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot initiatives for backlog elimination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Bureau of Citizenship and Immigration Services is authorized to implement innovative pilot initiatives to eliminate any remaining backlog in the processing of immigration benefit applications, and to prevent any backlog in the processing of such applications from recurring, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1573/a"},"text":"section 1573(a) of title 8","children":[],"tail":". Such initiatives may include measures such as increasing personnel, transferring personnel to focus on areas with the largest potential for backlog, and streamlining paperwork."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5034b6c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions from Commissioner","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with subchapter XII (relating to transition provisions), there are transferred from the Commissioner of Immigration and Naturalization to the Director of the Bureau of Citizenship and Immigration Services the following functions, and all personnel, infrastructure, and funding provided to the Commissioner in support of such functions immediately before the effective date specified in section 455: ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5034b6d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adjudications of immigrant visa petitions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034b6e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adjudications of naturalization petitions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034b6f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adjudications of asylum and refugee applications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034b70-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Adjudications performed at service centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034b71-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All other adjudications performed by the Immigration and Naturalization Service immediately before the effective date specified in section 455.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5034b72-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief of Policy and Strategy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5034b73-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a position of Chief of Policy and Strategy for the Bureau of Citizenship and Immigration Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034b74-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In consultation with Bureau of Citizenship and Immigration Services personnel in field offices, the Chief of Policy and Strategy shall be responsible for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5034b75-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making policy recommendations and performing policy research and analysis on immigration services issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5034b76-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating immigration policy issues with the Chief of Policy and Strategy for the Bureau of Border Security of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5034b77-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal advisor","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5034b78-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a principal legal advisor to the Director of the Bureau of Citizenship and Immigration Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034b79-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The legal advisor shall be responsible for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5034b7a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing specialized legal advice, opinions, determinations, regulations, and any other assistance to the Director of the Bureau of Citizenship and Immigration Services with respect to legal matters affecting the Bureau of Citizenship and Immigration Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5034b7b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representing the Bureau of Citizenship and Immigration Services in visa petition appeal proceedings before the Executive Office for Immigration Review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5034b7c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget Officer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5034b7d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a Budget Officer for the Bureau of Citizenship and Immigration Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034b7e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5034b7f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002044"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002044"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. There is no subpar. (B)."}],"tail":" In general"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Budget Officer shall be responsible for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5034b80-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/e/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" formulating and executing the budget of the Bureau of Citizenship and Immigration Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5034b81-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/e/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial management of the Bureau of Citizenship and Immigration Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5034b82-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/e/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting all payments, fines, and other debts for the Bureau of Citizenship and Immigration Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5034b83-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief of Office of Citizenship","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5034b84-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a position of Chief of the Office of Citizenship for the Bureau of Citizenship and Immigration Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034b85-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s271/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief of the Office of Citizenship for the Bureau of Citizenship and Immigration Services shall be responsible for promoting instruction and training on citizenship responsibilities for aliens interested in becoming naturalized citizens of the United States, including the development of educational materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5034b86-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s451"},"text":"Pub. L. 107–296, title IV, § 451","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2195"},"text":"116 Stat. 2195","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/382/s2/a"},"text":"Pub. L. 110–382, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-09"},"text":"Oct. 9, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4087"},"text":"122 Stat. 4087","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5034b87-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5034b88-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5034b89-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(3)(A), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2135"},"text":"116 Stat. 2135","children":[],"tail":", known as the Homeland Security Act of 2002, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For the effective date specified in section 455, referred to in subsecs. (a)(4) and (b), see Effective Date note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5034b8a-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"A