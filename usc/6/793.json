{"tag":"section","attrib":{"id":"idb55dee52-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793"},"text":null,"children":[{"tag":"num","attrib":{"value":"793"},"text":"§ 793.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight and accountability of Federal disaster expenditures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55dee53-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Administrator to designate funds for oversight activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may designate up to 1 percent of the total amount provided to a Federal agency for a mission assignment as oversight funds to be used by the recipient agency for performing oversight of activities carried out under the Agency reimbursable mission assignment process. Such funds shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee54-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55dee55-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of oversight activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Oversight funds may be used for the following types of oversight activities related to Agency mission assignments:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55dee56-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Monitoring, tracking, and auditing expenditures of funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee57-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ensuring that sufficient management and internal control mechanisms are available so that Agency funds are spent appropriately and in accordance with all applicable laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee58-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reviewing selected contracts and other activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee59-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Investigating allegations of fraud involving Agency funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee5a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Conducting and participating in fraud prevention activities with other Federal, State, and local government personnel and contractors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee5b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans and reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Oversight funds may be used to issue the plans required under subsection (e) and the reports required under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee5c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Oversight funds may not be used to finance existing agency oversight responsibilities related to direct agency appropriations used for disaster response, relief, and recovery activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee5d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Methods of oversight activities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55dee5e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Oversight activities may be carried out by an agency under this section either directly or by contract. Such activities may include evaluations and financial and performance audits.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee5f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of oversight activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, evaluations and audits under this section shall be performed by the inspector general of the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee60-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of oversight plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55dee61-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an agency receives oversight funds for a fiscal year, the head of the agency shall prepare a plan describing the oversight activities for disaster response, relief, and recovery anticipated to be undertaken during the subsequent fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee62-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selection of oversight activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In preparing the plan, the head of the agency shall select oversight activities based upon a risk assessment of those areas that present the greatest risk of fraud, waste, and abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee63-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedule","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The plan shall include a schedule for conducting oversight activities, including anticipated dates of completion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee64-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal disaster assistance accountability reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A Federal agency receiving oversight funds under this section shall submit annually to the Administrator and the appropriate committees of Congress a consolidated report regarding the use of such funds, including information summarizing oversight activities and the results achieved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee65-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s793/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “oversight funds” means funds referred to in subsection (a) that are designated for use in performing oversight activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55dee66-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s693"},"text":"Pub. L. 109–295, title VI, § 693","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1458"},"text":"120 Stat. 1458","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
