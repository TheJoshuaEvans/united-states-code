{"tag":"section","attrib":{"id":"idb52be1f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a"},"text":null,"children":[{"tag":"num","attrib":{"value":"488a"},"text":"§ 488a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulation of the sale and transfer of ammonium nitrate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb52be1f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall regulate the sale and transfer of ammonium nitrate by an ammonium nitrate facility in accordance with this part to prevent the misappropriation or use of ammonium nitrate in an act of terrorism. Such regulations shall be carried out by the Cybersecurity and Infrastructure Security Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be1f4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ammonium nitrate mixtures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2007-12-26"},"text":"December 26, 2007","children":[],"tail":", the Secretary, in consultation with the heads of appropriate Federal departments and agencies (including the Secretary of Agriculture), shall, after notice and an opportunity for comment, establish a threshold percentage for ammonium nitrate in a substance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be1f5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of owners of ammonium nitrate facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52be1f6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a process by which any person that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be1f7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns an ammonium nitrate facility is required to register with the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be1f8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" registers under subparagraph (A) is issued a registration number for purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be1f9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person applying to register under paragraph (1) shall submit to the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be1fa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and telephone number of each ammonium nitrate facility owned by that person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be1fb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the person designated by that person as the point of contact for each such facility, for purposes of this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be1fc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Secretary may determine is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be1fd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of ammonium nitrate purchasers","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52be1fe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a process by which any person that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be1ff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intends to be an ammonium nitrate purchaser is required to register with the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be200-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" registers under subparagraph (A) is issued a registration number for purposes of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be201-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person applying to register under paragraph (1) as an ammonium nitrate purchaser shall submit to the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be202-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, address, and telephone number of the applicant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be203-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the intended use of ammonium nitrate to be purchased by the applicant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be204-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52be205-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of records","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The owner of an ammonium nitrate facility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be206-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a record of each sale or transfer of ammonium nitrate, during the two-year period beginning on the date of that sale or transfer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be207-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in such record the information described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be208-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific information required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each sale or transfer of ammonium nitrate, the owner of an ammonium nitrate facility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be209-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" record the name, address, telephone number, and registration number issued under subsection (c) or (d) of each person that purchases ammonium nitrate, in a manner prescribed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be20a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, record the name, address, and telephone number of an agent acting on behalf of the person described in subparagraph (A), at the point of sale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be20b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" record the date and quantity of ammonium nitrate sold or transferred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be20c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verify the identity of the persons described in subparagraphs (A) and (B), as applicable, in accordance with a procedure established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be20d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In maintaining records in accordance with paragraph (1), the owner of an ammonium nitrate facility shall take reasonable actions to ensure the protection of the information included in such records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be20e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for explosive purposes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may exempt from this part a person producing, selling, or purchasing ammonium nitrate exclusively for use in the production of an explosive under a license or permit issued under chapter 40 of title 18.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be20f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall consult with the Secretary of Agriculture, States, and appropriate private sector entities, to ensure that the access of agricultural producers to ammonium nitrate is not unduly burdened.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be210-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data confidentiality","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52be211-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" or the USA PATRIOT ACT ("},{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Public Law 107–56","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/115/272"},"text":"115 Stat. 272","children":[],"tail":"), and except as provided in paragraph (2), the Secretary may not disclose to any person any information obtained under this part."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be212-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may disclose any information obtained by the Secretary under this part to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be213-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee of the United States, or a person that has entered into a contract with the United States, who has a need to know the information to perform the duties of the officer, employee, or person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be214-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a State agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s488c"},"text":"section 488c of this title","children":[],"tail":", under appropriate arrangements to ensure the protection of the information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be215-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration procedures and check of terrorist screening database","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52be216-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration procedures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be217-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish procedures to efficiently receive applications for registration numbers under this part, conduct the checks required under paragraph (2), and promptly issue or deny a registration number.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be218-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial six-month registration period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall take steps to maximize the number of registration applications that are submitted and processed during the six-month period described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s488e/e"},"text":"section 488e(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be219-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Check of terrorist screening database","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be21a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Check required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall conduct a check of appropriate identifying information of any person seeking to register with the Department under subsection (c) or (d) against identifying information that appears in the terrorist screening database of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be21b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to deny registration number","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the identifying information of a person seeking to register with the Department under subsection (c) or (d) appears in the terrorist screening database of the Department, the Secretary may deny issuance of a registration number under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be21c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited review of applications","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be21d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Following the six-month period described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s488e/e"},"text":"section 488e(e) of this title","children":[],"tail":", the Secretary shall, to the extent practicable, issue or deny registration numbers under this part not later than 72 hours after the time the Secretary receives a complete registration application, unless the Secretary determines, in the interest of national security, that additional time is necessary to review an application."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be21e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of application status","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In all cases, the Secretary shall notify a person seeking to register with the Department under subsection (c) or (d) of the status of the application of that person not later than 72 hours after the time the Secretary receives a complete registration application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be21f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited appeals process","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be220-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb52be221-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appeals process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish an expedited appeals process for persons denied a registration number under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb52be222-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time period for resolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, to the extent practicable, resolve appeals not later than 72 hours after receiving a complete request for appeal unless the Secretary determines, in the interest of national security, that additional time is necessary to resolve an appeal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be223-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in developing the appeals process under subparagraph (A), shall consult with appropriate stakeholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be224-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide guidance regarding the procedures and information required for an appeal under subparagraph (A) to any person denied a registration number under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be225-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on use and maintenance of information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be226-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any information constituting grounds for denial of a registration number under this section shall be maintained confidentially by the Secretary and may be used only for making determinations under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be227-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this part, the Secretary may share any such information with Federal, State, local, and tribal law enforcement agencies, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be228-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be229-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to require information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require a person applying for a registration number under this part to submit such information as may be necessary to carry out the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be22a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to update information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require persons issued a registration under this part to update registration information submitted to the Secretary under this part, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be22b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Re-checks against terrorist screening database","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be22c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Re-checks","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, as appropriate, recheck persons provided a registration number pursuant to this part against the terrorist screening database of the Department, and may revoke such registration number if the Secretary determines such person may pose a threat to national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be22d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488a/i/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of revocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall, as appropriate, provide prior notice to a person whose registration number is revoked under this section and such person shall have an opportunity to appeal, as provided in paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb52be22e-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s899B"},"text":"Pub. L. 107–296, title VIII, § 899B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dE/tV/s563/a"},"text":"Pub. L. 110–161, div. E, title V, § 563(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2084"},"text":"121 Stat. 2084","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/5/B"},"text":"Pub. L. 115–278, § 2(g)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4179"},"text":"132 Stat. 4179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb52be22f-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb52be230-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb52be231-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The USA PATRIOT ACT, referred to in subsec. (h)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/272"},"text":"115 Stat. 272","children":[],"tail":", also known as the Uniting and Strengthening America by Providing Appropriate Tools Required to Intercept and Obstruct Terrorism Act of 2001. For complete classification of this Act to the Code, see Short Title of 2001 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1"},"text":"section 1 of Title 18","children":[],"tail":", Crimes and Criminal Procedure, and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb52be232-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278"},"text":"Pub. L. 115–278","children":[],"tail":" inserted at end “Such regulations shall be carried out by the Cybersecurity and Infrastructure Security Agency.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
