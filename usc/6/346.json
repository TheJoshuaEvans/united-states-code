{"tag":"section","attrib":{"id":"idb5165ec0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s346"},"text":null,"children":[{"tag":"num","attrib":{"value":"346"},"text":"§ 346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidation and co-location of offices","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", the Secretary shall develop and submit to Congress a plan for consolidating and co-locating—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5165ec1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s346/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regional offices or field offices of agencies that are transferred to the Department under this chapter, if such officers ","children":[{"tag":"ref","attrib":{"idref":"fn002059"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002059"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “offices”."}],"tail":" are located in the same municipality; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5165ec2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s346/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" portions of regional and field offices of other Federal agencies, to the extent such offices perform functions that are transferred to the Secretary under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5165ec3-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVII/s706"},"text":"Pub. L. 107–296, title VII, § 706","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2220"},"text":"116 Stat. 2220","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5165ec4-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5165ec5-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5165ec6-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in pars. (1) and (2), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2135"},"text":"116 Stat. 2135","children":[],"tail":", known as the Homeland Security Act of 2002, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
