{"tag":"section","attrib":{"id":"idb4f9d585-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s217"},"text":null,"children":[{"tag":"num","attrib":{"value":"217"},"text":"§ 217.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of resources by the Secretary","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4f9d586-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s217/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that adequate staffing is provided to assure that levels of customs revenue services provided on the day before the effective date of this chapter shall continue to be provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f9d587-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s217/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall notify the Committee on Ways and Means of the House of Representatives and the Committee on Finance of the Senate at least 90 days prior to taking any action which would—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f9d588-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s217/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" result in any significant reduction in customs revenue services, including hours of operation, provided at any office within the Department or any port of entry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f9d589-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s217/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminate or relocate any office of the Department which provides customs revenue services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f9d58a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s217/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminate any port of entry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f9d58b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s217/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “customs revenue services” means those customs revenue functions described in paragraphs (1) through (6) and paragraph (8) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s215"},"text":"section 215 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4f9d58c-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s417"},"text":"Pub. L. 107–296, title IV, § 417","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2181"},"text":"116 Stat. 2181","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4f9d58d-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4f9d58e-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4f9d58f-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this chapter, referred to in subsec. (a), is 60 days after ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
