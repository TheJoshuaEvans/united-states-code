{"tag":"section","attrib":{"id":"idb53a1335-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605"},"text":null,"children":[{"tag":"num","attrib":{"value":"605"},"text":"§ 605.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State Homeland Security Grant Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb53a1336-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a State Homeland Security Grant Program to assist State, local, and tribal governments in preventing, preparing for, protecting against, and responding to acts of terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a1337-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a1338-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State may apply for a grant under this section, and shall submit such information in support of the application as the Administrator may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1339-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum contents of application","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall require that each State include in its application, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a133a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose for which the State seeks grant funds and the reasons why the State needs the grant to meet the target capabilities of that State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a133b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the State plans to allocate the grant funds to local governments and Indian tribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a133c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a budget showing how the State intends to expend the grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a133d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Applicants for grants under this section shall apply or reapply on an annual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a133e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution to local and tribal governments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a133f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 45 days after receiving grant funds, any State receiving a grant under this section shall make available to local and tribal governments, consistent with the applicable State homeland security plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a1340-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 80 percent of the grant funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a1341-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the consent of local and tribal governments, items, services, or activities having a value of not less than 80 percent of the amount of the grant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a1342-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the consent of local and tribal governments, grant funds combined with other items, services, or activities having a total value of not less than 80 percent of the amount of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1343-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications regarding distribution of grant funds to local governments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall certify to the Administrator that the State has made the distribution to local and tribal governments required under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1344-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extension of period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Governor of a State may request in writing that the Administrator extend the period under paragraph (1) for an additional period of time. The Administrator may approve such a request if the Administrator determines that the resulting delay in providing grant funding to the local and tribal governments is necessary to promote effective investments to prevent, prepare for, protect against, or respond to acts of terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1345-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to the District of Columbia, the Commonwealth of Puerto Rico, American Samoa, the Commonwealth of the Northern Mariana Islands, Guam, or the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1346-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State fails to make the distribution to local or tribal governments required under paragraph (1) in a timely fashion, a local or tribal government entitled to receive such distribution may petition the Administrator to request that grant funds be provided directly to the local or tribal government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a1347-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multistate applications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a1348-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Instead of, or in addition to, any application for a grant under subsection (b), 2 or more States may submit an application for a grant under this section in support of multistate efforts to prevent, prepare for, protect against, and respond to acts of terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1349-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of grant","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a group of States applies for a grant under this section, such States shall submit to the Administrator at the time of application a plan describing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a134a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the division of responsibilities for administering the grant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a134b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distribution of funding among the States that are parties to the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a134c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a134d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In allocating funds under this section, the Administrator shall ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a134e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as provided in subparagraph (B), each State receives, from the funds appropriated for the State Homeland Security Grant Program established under this section, not less than an amount equal to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53a134f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.375 percent of the total funds appropriated for grants under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s604"},"text":"section 604 of this title","children":[],"tail":" in fiscal year 2008;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53a1350-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.365 percent of the total funds appropriated for grants under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s604"},"text":"section 604 of this title","children":[],"tail":" in fiscal year 2009;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53a1351-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.36 percent of the total funds appropriated for grants under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s604"},"text":"section 604 of this title","children":[],"tail":" in fiscal year 2010;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53a1352-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/e/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.355 percent of the total funds appropriated for grants under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s604"},"text":"section 604 of this title","children":[],"tail":" in fiscal year 2011; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53a1353-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/e/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.35 percent of the total funds appropriated for grants under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s604"},"text":"section 604 of this title","children":[],"tail":" in fiscal year 2012 and in each fiscal year thereafter; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a1354-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each fiscal year, American Samoa, the Commonwealth of the Northern Mariana Islands, Guam, and the Virgin Islands each receive, from the funds appropriated for the State Homeland Security Grant Program established under this section, not less than an amount equal to 0.08 percent of the total funds appropriated for grants under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s604"},"text":"section 604 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1355-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of multistate award on State minimum","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any portion of a multistate award provided to a State under subsection (d) shall be considered in calculating the minimum State allocation under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a1356-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for grants under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a1357-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $950,000,000 for each of fiscal years 2008 through 2012; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1358-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s605/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for fiscal year 2013, and each fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53a1359-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXX/s2004"},"text":"Pub. L. 107–296, title XX, § 2004","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tI/s101"},"text":"Pub. L. 110–53, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/277"},"text":"121 Stat. 277","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
