{"tag":"section","attrib":{"id":"idb4df96d7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124c"},"text":null,"children":[{"tag":"num","attrib":{"value":"124c"},"text":"§ 124c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with information sharing environment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4df96d8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"All activities to comply with sections 124, 124a, and 124b of this title shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4df96d9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with any policies, guidelines, procedures, instructions, or standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s485"},"text":"section 485 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4df96da-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implemented in coordination with, as appropriate, the program manager for the information sharing environment established under that section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4df96db-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with any applicable guidance issued by the Director of National Intelligence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4df96dc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with any applicable guidance issued by the Secretary relating to the protection of law enforcement information or proprietary information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4df96dd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the duties and responsibilities under this part, the Under Secretary for Intelligence and Analysis shall take into account the views of the heads of the intelligence components of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4df96de-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tII/s206"},"text":"Pub. L. 107–296, title II, § 206","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tV/s501/a/1"},"text":"Pub. L. 110–53, title V, § 501(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/309"},"text":"121 Stat. 309","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
