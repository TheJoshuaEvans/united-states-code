{"tag":"section","attrib":{"id":"idb55deeeb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824"},"text":null,"children":[{"tag":"num","attrib":{"value":"824"},"text":"§ 824.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhanced catastrophic incident annex","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55deeec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination with the Administrator and the Federal partners listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s822/b"},"text":"section 822(b) of this title","children":[],"tail":", shall supplement each Federal Interagency Operational Plan to include an annex containing a strategy to ensure the health, safety, and general welfare of the civilian population affected by catastrophic incidents by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55deeed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the basic needs of the civilian population of the United States that is impacted by catastrophic incidents in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deeee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating response efforts with State, local, and Indian Tribal governments, the private sector, and nonprofit relief organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deeef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting personal and local readiness and non-reliance on government relief during periods of heightened tension or after catastrophic incidents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deef0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing international partnerships with allied nations for the provision of relief services and goods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55deef1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements of the strategy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy required under subsection (a) shall include a description of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55deef2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions the Federal Government should take to ensure the basic needs of the civilian population of the United States in a catastrophic incident are met;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deef3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" how the Federal Government should coordinate with non-Federal entities to multiply resources and enhance relief capabilities, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55deef4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55deef5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Indian Tribal governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55deef6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State disaster relief agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55deef7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local disaster relief managers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55deef8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State National Guards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55deef9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement and first response entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55deefa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit relief services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deefb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" actions the Federal Government should take to enhance individual resiliency to the effects of a catastrophic incident, which actions shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55deefc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" readiness alerts to the public during periods of elevated threat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55deefd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to enhance domestic supply and availability of critical goods and basic necessities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55deefe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information campaigns to ensure the public is aware of response plans and services that will be activated when necessary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deeff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts the Federal Government should undertake and agreements the Federal Government should seek with international allies to enhance the readiness of the United States to provide for the general welfare;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55def00-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the strategy will be implemented should multiple levels of critical infrastructure be destroyed or taken offline entirely for an extended period of time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55def01-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authorities the Federal Government should implicate in responding to a catastrophic incident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55def02-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assumptions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In designing the strategy under subsection (a), the Secretary, in coordination with the Administrator and the Federal partners listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s822/b"},"text":"section 822(b) of this title","children":[],"tail":", shall account for certain factors to make the strategy operationally viable, including the assumption that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55def03-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiple levels of critical infrastructure have been taken offline or destroyed by catastrophic incidents or the effects of catastrophic incidents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55def04-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" impacted sectors may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55def05-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55def06-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the communication sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55def07-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the energy sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55def08-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the healthcare and public health sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55def09-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the water and wastewater sector;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55def0a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, Indian Tribal, and territorial governments have been equally affected or made largely inoperable by catastrophic incidents or the effects of catastrophic incidents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55def0b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the emergency has exceeded the response capabilities of State, local, and Indian Tribal governments under the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.) and other relevant disaster response laws; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55def0c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s824/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States military is sufficiently engaged in armed or cyber conflict with State or non-State adversaries, or is otherwise unable to augment domestic response capabilities in a significant manner due to a catastrophic incident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55def0d-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXIII/s7305"},"text":"Pub. L. 117–263, div. G, title LXXIII, § 7305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3687"},"text":"136 Stat. 3687","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb55def0e-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb55def0f-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb55def10-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsec. (c)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", which is classified principally to chapter 68 (§ 5121 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb55def11-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb55def12-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Validation of Strategy; Recommendations; Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXIII"},"text":"Pub. L. 117–263, div. G, title LXXIII","children":[],"tail":", §§ 7306–7308, "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3688"},"text":"136 Stat. 3688","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dG/tLXXIII"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7306"},"text":"“SEC. 7306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" VALIDATION OF THE STRATEGY THROUGH AN EXERCISE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“Not later than 1 year after the addition of the annex required under section 7305 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s824"},"text":"6 U.S.C. 824","children":[],"tail":"], the Administrator shall lead an exercise as part of the national exercise program to test and enhance the operationalization of the strategy required under section 7305."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7307"},"text":"“SEC. 7307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" RECOMMENDATIONS.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in coordination with the Administrator and the Federal partners listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s7303/b"},"text":"section 7303(b) of this title","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t6/s822/b"},"text":"6 U.S.C. 822(b)","children":[],"tail":"], shall provide recommendations to Congress for—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions that should be taken to prepare the United States to implement the strategy required under section 7305, increase readiness, and address preparedness gaps for responding to the impacts of catastrophic incidents on citizens of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional authorities that should be considered for Federal agencies to more effectively implement the strategy required under section 7305.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion in Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may include the recommendations required under subsection (a) in a report submitted under section 7308.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7308"},"text":"“SEC. 7308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" REPORTING REQUIREMENTS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“Not later than 1 year after the date on which the Administrator leads the exercise under section 7306, the Secretary, in coordination with the Administrator, shall submit to Congress a report that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the efforts of the Secretary and the Administrator to develop and update the strategy required under section 7305; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an after-action report following the conduct of the exercise described in section 7306.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
