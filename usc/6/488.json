{"tag":"section","attrib":{"id":"idb52be1eb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488"},"text":null,"children":[{"tag":"num","attrib":{"value":"488"},"text":"§ 488.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52be1ec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ammonium nitrate","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “ammonium nitrate” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be1ed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solid ammonium nitrate that is chiefly the ammonium salt of nitric acid and contains not less than 33 percent nitrogen by weight; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be1ee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any mixture containing a percentage of ammonium nitrate that is equal to or greater than the percentage determined by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s488a/b"},"text":"section 488a(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be1ef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ammonium nitrate facility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ammonium nitrate facility” means any entity that produces, sells or otherwise transfers ownership of, or provides application services for ammonium nitrate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be1f0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ammonium nitrate purchaser","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ammonium nitrate purchaser” means any person who purchases ammonium nitrate from an ammonium nitrate facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb52be1f1-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s899A"},"text":"Pub. L. 107–296, title VIII, § 899A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dE/tV/s563/a"},"text":"Pub. L. 110–161, div. E, title V, § 563(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2083"},"text":"121 Stat. 2083","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
