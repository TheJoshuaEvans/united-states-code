{"tag":"section","attrib":{"id":"idb55dee9a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s797"},"text":null,"children":[{"tag":"num","attrib":{"value":"797"},"text":"§ 797.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraud prevention training program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall develop and implement a program to provide training on the prevention of waste, fraud, and abuse of Federal disaster relief assistance relating to the response to or recovery from natural disasters and acts of terrorism or other man-made disasters and ways to identify such potential waste, fraud, and abuse.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb55dee9b-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s698"},"text":"Pub. L. 109–295, title VI, § 698","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1462"},"text":"120 Stat. 1462","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
