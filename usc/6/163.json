{"tag":"section","attrib":{"id":"idb4e90d77-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s163"},"text":null,"children":[{"tag":"num","attrib":{"value":"163"},"text":"§ 163.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of law enforcement technology","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For the purposes of this subchapter, the term “law enforcement technology” includes investigative and forensic technologies, corrections technologies, and technologies that support the judicial process.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb4e90d78-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tII/s233"},"text":"Pub. L. 107–296, title II, § 233","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2161"},"text":"116 Stat. 2161","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4e90d79-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4e90d7a-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4e90d7b-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in text, was in the original “this title”, meaning title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2145"},"text":"116 Stat. 2145","children":[],"tail":", which enacted this subchapter, amended sections 1030, 2511, 2512, 2520, 2701 to 2703, and 3125 of Title 18, Crimes and Criminal Procedure, sections 10102 and 10122 of Title 34, Crime Control and Law Enforcement, and "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s401a"},"text":"section 401a of Title 50","children":[],"tail":", War and National Defense, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":" and listed in a Provisions for Review, Promulgation, or Amendment of Federal Sentencing Guidelines Relating to Specific Offenses table set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s994"},"text":"section 994 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure. For complete classification of title II to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
