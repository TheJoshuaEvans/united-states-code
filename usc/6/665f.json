{"tag":"section","attrib":{"id":"idb54d2698-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f"},"text":null,"children":[{"tag":"num","attrib":{"value":"665f"},"text":"§ 665f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity education and training programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb54d2699-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d269a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Cybersecurity Education and Training Assistance Program (referred to in this section as “CETAP”) is established within the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d269b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of CETAP shall be to support the effort of the Agency in building and strengthening a national cybersecurity workforce pipeline capacity through enabling elementary and secondary cybersecurity education, including by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d269c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing foundational cybersecurity awareness and literacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d269d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging cybersecurity career exploration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d269e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the teaching of cybersecurity skills at the elementary and secondary education levels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d269f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out CETAP, the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d26a0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that the program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d26a1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creates and disseminates cybersecurity-focused curricula and career awareness materials appropriate for use at the elementary and secondary education levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d26a2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducts professional development sessions for teachers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d26a3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops resources for the teaching of cybersecurity-focused curricula described in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d26a4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides direct student engagement opportunities through camps and other programming;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d26a5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages with State educational agencies and local educational agencies to promote awareness of the program and ensure that offerings align with State and local curricula;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d26a6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrates with existing post-secondary education and workforce development programs at the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d26a7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotes and supports national standards for elementary and secondary cyber education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d26a8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partners with cybersecurity and education stakeholder groups to expand outreach; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d26a9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activity the Director determines necessary to meet the purpose described in subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d26aa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable the deployment of CETAP nationwide, with special consideration for underserved populations or communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d26ab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d26ac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the establishment of CETAP, and annually thereafter, the Secretary shall brief the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Homeland Security of the House of Representatives on the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d26ad-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each briefing conducted under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d26ae-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimated figures on the number of students reached and teachers engaged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d26af-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on outreach and engagement efforts, including the activities described in subsection (b)(1)(E);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d26b0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on any grants or cooperative agreements made pursuant to subsection (e), including how any such grants or cooperative agreements are being used to enhance cybersecurity education for underserved populations or communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d26b1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on new curricula offerings and teacher training platforms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d26b2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on coordination with post-secondary education and workforce development programs at the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54f96b3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission promotion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may use appropriated amounts to purchase promotional and recognition items and marketing and advertising services to publicize and promote the mission and services of the Agency, support the activities of the Agency, and to recruit and retain Agency personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54f96b4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants and cooperative agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may award financial assistance in the form of grants or cooperative agreements to States, local governments, institutions of higher education (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001"},"text":"section 1001 of title 20","children":[],"tail":"), nonprofit organizations, and other non-Federal entities as determined appropriate by the Director for the purpose of funding cybersecurity and infrastructure security education and training programs and initiatives to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54f96b5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the purposes of CETAP; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54f96b6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance CETAP to address the national shortfall of cybersecurity professionals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb54f96b7-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2220"},"text":"Pub. L. 107–296, title XXII, § 2220","children":[],"tail":", formerly § 2217, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVII/s1719/c"},"text":"Pub. L. 116–283, div. A, title XVII, § 1719(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4106"},"text":"134 Stat. 4106","children":[],"tail":"; renumbered § 2220 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXV/s1547/b/1/A/vii"},"text":"Pub. L. 117–81, div. A, title XV, § 1547(b)(1)(A)(vii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2061"},"text":"135 Stat. 2061","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7104"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3622"},"text":"136 Stat. 3622","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb54f96b8-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb54f96b9-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb54f96ba-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(2)(C) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7104/b"},"text":"Pub. L. 117–263, § 7104(b)","children":[],"tail":", added subpar. (C) and redesignated former subpars. (C) and (D) as (D) and (E), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7104/a"},"text":"Pub. L. 117–263, § 7104(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" reenacted section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
