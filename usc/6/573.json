{"tag":"section","attrib":{"id":"idb5330e21-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573"},"text":null,"children":[{"tag":"num","attrib":{"value":"573"},"text":"§ 573.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5330e22-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Baseline assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", and not less than every 5 years thereafter, the Secretary, acting through the Assistant Director for Emergency Communications, shall conduct an assessment of Federal, State, local, and tribal governments that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5330e23-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defines the range of capabilities needed by emergency response providers and relevant government officials to continue to communicate in the event of natural disasters, acts of terrorism, and other man-made disasters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e24-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defines the range of interoperable emergency communications capabilities needed for specific events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e25-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the current available capabilities to meet such communications needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e26-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the gap between such current capabilities and defined requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e27-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes a national interoperable emergency communications inventory to be completed by the Secretary of Homeland Security, the Secretary of Commerce, and the Chairman of the Federal Communications Commission that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5330e28-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifies for each Federal department and agency—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5330e29-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the channels and frequencies used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5330e2a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nomenclature used to refer to each channel or frequency used; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5330e2b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/a/5/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of communications systems and equipment used; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330e2c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the interoperable emergency communications systems in use by public safety agencies in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330e2d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified annex","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The baseline assessment under this section may include a classified annex including information provided under subsection (a)(5)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330e2e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting the baseline assessment under this section, the Secretary may incorporate findings from assessments conducted before, or ongoing on, ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330e2f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Progress reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", and biennially thereafter, the Secretary, acting through the Assistant Director for Emergency Communications, shall submit to Congress a report on the progress of the Department in achieving the goals of, and carrying out its responsibilities under, this subchapter, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5330e30-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the findings of the most recent baseline assessment conducted under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e31-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination of the degree to which interoperable emergency communications capabilities have been attained to date and the gaps that remain for interoperability to be achieved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e32-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an evaluation of the ability to continue to communicate and to provide and maintain interoperable emergency communications by emergency managers, emergency response providers, and relevant government officials in the event of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5330e33-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" natural disasters, acts of terrorism, or other man-made disasters, including Incidents of National Significance declared by the Secretary under the National Response Plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330e34-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a catastrophic loss of local and regional communications services;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e35-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of best practices relating to the ability to continue to communicate and to provide and maintain interoperable emergency communications in the event of natural disasters, acts of terrorism, or other man-made disasters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e36-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s573/d/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002092"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002092"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “(5)”."}],"tail":" an evaluation of the feasibility and desirability of the Department developing, on its own or in conjunction with the Department of Defense, a mobile communications capability, modeled on the Army Signal Corps, that could be deployed to support emergency communications at the site of natural disasters, acts of terrorism, or other man-made disasters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5330e37-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVIII/s1803"},"text":"Pub. L. 107–296, title XVIII, § 1803","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s671/b"},"text":"Pub. L. 109–295, title VI, § 671(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1437"},"text":"120 Stat. 1437","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/6/B"},"text":"Pub. L. 115–278, § 2(g)(6)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4179"},"text":"132 Stat. 4179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5330e38-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5330e39-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5330e3a-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1803"},"text":"section 1803 of Pub. L. 107–296","children":[],"tail":" was renumbered section 1903 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s593"},"text":"section 593 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5330e3b-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (a), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278"},"text":"Pub. L. 115–278","children":[],"tail":" substituted “Assistant Director for Emergency Communications” for “Director for Emergency Communications” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5330e3c-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb5330e3d-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Assistant Director for Emergency Communications deemed to be a reference to the Executive Assistant Director for Emergency Communications, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s571/g"},"text":"section 571(g) of this title","children":[],"tail":", enacted "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
