{"tag":"section","attrib":{"id":"idb51d8b31-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s424"},"text":null,"children":[{"tag":"num","attrib":{"value":"424"},"text":"§ 424.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased micro-purchase threshold for certain procurements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the administration of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1902"},"text":"section 1902 of title 41","children":[],"tail":" with respect to a procurement referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s422"},"text":"section 422 of this title","children":[],"tail":", the amount specified in subsections (a), (d), and (e) of such section 1902 shall be deemed to be $7,500."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb51d8b32-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s854"},"text":"Pub. L. 107–296, title VIII, § 854","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2236"},"text":"116 Stat. 2236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb51d8b33-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb51d8b34-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb51d8b35-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In text, “","children":[{"tag":"ref","attrib":{"href":"/us/us