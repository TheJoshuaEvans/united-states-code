{"tag":"section","attrib":{"id":"idb4e451e1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1"},"text":null,"children":[{"tag":"num","attrib":{"value":"124m–1"},"text":"§ 124m–1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Departmental coordination on counter threats","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4e451e2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized in the Department, for a period of 2 years beginning after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":", a Counter Threats Advisory Board (in this section referred to as the “Board”) which shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e451e3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be composed of senior representatives of departmental operational components and headquarters elements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e451e4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate departmental intelligence activities and policy and information related to the mission and functions of the Department that counter threats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e451e5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall be a charter to govern the structure and mission of the Board, which shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e451e6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct the Board to focus on the current threat environment and the importance of aligning departmental activities to counter threats under the guidance of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e451e7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be reviewed and updated as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e451e8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e451e9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall be composed of senior representatives of departmental operational components and headquarters elements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e451ea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chair","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary for Intelligence and Analysis shall serve as the Chair of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e451eb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall appoint additional members of the Board from among the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e451ec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Transportation Security Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451ed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" U.S. Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451ee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" U.S. Immigration and Customs Enforcement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451ef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451f0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451f1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" U.S. Citizenship and Immigration Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Secret Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Cybersecurity and Infrastructure Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451f4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Operations Coordination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451f5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the General Counsel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451f6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Intelligence and Analysis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451f7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Strategy, Policy, and Plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451f8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Science and Technology Directorate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451f9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office for State and Local Law Enforcement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451fa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Privacy Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451fb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office for Civil Rights and Civil Liberties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451fc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/c/3/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other departmental offices and programs as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e451fd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e451fe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet on a regular basis to discuss intelligence and coordinate ongoing threat mitigation efforts and departmental activities, including coordination with other Federal, State, local, tribal, territorial, and private sector partners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e451ff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e45200-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terrorism alerts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Board shall advise the Secretary on the issuance of terrorism alerts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s124"},"text":"section 124 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e45201-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m–1/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on additional funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No additional funds are authorized to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4e45202-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tII/s210F"},"text":"Pub. L. 107–296, title II, § 210F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dU/tVI/s602/a"},"text":"Pub. L. 116–260, div. U, title VI, § 602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2294"},"text":"134 Stat. 2294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4e45203-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4e45204-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb4e45205-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s210F"},"text":"section 210F of Pub. L. 107–296","children":[],"tail":" was renumbered section 210E and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s124m"},"text":"section 124m of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4e45206-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4e45207-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Notice Regarding Mechanisms to Coordinate Threats","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dU/tVI/s602/d"},"text":"Pub. L. 116–260, div. U, title VI, § 602(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2295"},"text":"134 Stat. 2295","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dU/tVI/s602/d"},"text":"“The Secretary of Homeland Security shall provide written notification to and brief the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Homeland Security of the House of Representatives on any changes to or introductions of new mechanisms to coordinate threats across the Department of Homeland Security.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
