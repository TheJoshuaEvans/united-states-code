{"tag":"section","attrib":{"id":"idb573728b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204"},"text":null,"children":[{"tag":"num","attrib":{"value":"1204"},"text":"§ 1204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motor carrier security-sensitive material tracking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb573728c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb573728d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", consistent with the findings of the Transportation Security Administration’s hazardous materials truck security pilot program, the Secretary, through the Administrator of the Transportation Security Administration and in consultation with the Secretary of Transportation, shall develop a program to facilitate the tracking of motor carrier shipments of security-sensitive materials and to equip vehicles used in such shipments with technology that provides—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb573728e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" frequent or continuous communications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb573728f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vehicle position location and tracking capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5737290-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a feature that allows a driver of such vehicles to broadcast an emergency distress signal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5737291-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the program required by paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5737292-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Secretary of Transportation to coordinate the program with any ongoing or planned efforts for motor carrier or security-sensitive materials tracking at the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5737293-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration the recommendations and findings of the report on the hazardous material safety and security operational field test released by the Federal Motor Carrier Safety Administration on ","children":[{"tag":"date","attrib":{"date":"2004-11-11"},"text":"November 11, 2004","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5737294-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" evaluate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5737295-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any new information related to the costs and benefits of deploying, equipping, and utilizing tracking technology, including portable tracking technology, for motor carriers transporting security-sensitive materials not included in the hazardous material safety and security operational field test report released by the Federal Motor Carrier Safety Administration on ","children":[{"tag":"date","attrib":{"date":"2004-11-11"},"text":"November 11, 2004","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5737296-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of tracking technology to resist tampering and disabling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5737297-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability of tracking technology to collect, display, and store information regarding the movement of shipments of security-sensitive materials by commercial motor vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5737298-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate range of contact intervals between the tracking technology and a commercial motor vehicle transporting security-sensitive materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5737299-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology that allows the installation by a motor carrier of concealed electronic devices on commercial motor vehicles that can be activated by law enforcement authorities to disable the vehicle or alert emergency response resources to locate and recover security-sensitive materials in the event of loss or theft of such materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb573729a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/2/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether installation of the technology described in clause (v) should be incorporated into the program under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb573729b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/2/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs, benefits, and practicality of such technology described in clause (v) in the context of the overall benefit to national security, including commerce in transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb573729c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/a/2/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other systems and information the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb573729d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts appropriated pursuant to section 114(w) ","children":[{"tag":"ref","attrib":{"idref":"fn002169"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002169"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 49, there shall be made available to the Secretary to carry out this section—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb573729e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7,000,000 for fiscal year 2008 of which $3,000,000 may be used for equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb573729f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7,000,000 for fiscal year 2009 of which $3,000,000 may be used for equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57372a0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7,000,000 for fiscal year 2010 of which $3,000,000 may be used for equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57372a1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the issuance of regulations under subsection (a), the Secretary shall issue a report to the appropriate congressional committees on the program developed and evaluation carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57372a2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1204/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not mandate the installation or utilization of a technology described under this section without additional congressional authority provided after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57372a3-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXV/s1554"},"text":"Pub. L. 110–53, title XV, § 1554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/473"},"text":"121 Stat. 473","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57372a4-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57372a5-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb57372a6-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s114/w"},"text":"Section 114(w) of title 49","children":[],"tail":", referred to in subsec. (b)(1), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s114/v"},"text":"section 114(v) of title 49","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/s1904/b/1/I"},"text":"Pub. L. 115–254, div. K, § 1904(b)(1)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3545"},"text":"132 Stat. 3545","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
