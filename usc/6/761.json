{"tag":"section","attrib":{"id":"idb55b7d44-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s761"},"text":null,"children":[{"tag":"num","attrib":{"value":"761"},"text":"§ 761.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency Management Assistance Compact grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55b7d45-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s761/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may make grants to administer the Emergency Management Assistance Compact consented to by the Joint Resolution entitled “Joint Resolution granting the consent of Congress to the Emergency Management Assistance Compact” (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/321"},"text":"Public Law 104–321","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/110/3877"},"text":"110 Stat. 3877","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55b7d46-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s761/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant under this section shall be used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55b7d47-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s761/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out recommendations identified in the Emergency Management Assistance Compact after-action reports for the 2004 and 2005 hurricane season;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7d48-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s761/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer compact operations on behalf of all member States and territories;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7d49-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s761/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to continue coordination with the Agency and appropriate Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7d4a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s761/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to continue coordination with State, local, and tribal government entities and their respective national organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7d4b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s761/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist State and local governments, emergency response providers, and organizations representing such providers with credentialing emergency response providers and the typing of emergency response resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55b7d4c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s761/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall consult with the Administrator of the Emergency Management Assistance Compact to ensure effective coordination of efforts in responding to requests for assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55b7d4d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s761/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out this section $4,000,000 for each of fiscal years 2018 through 2022. Such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55b7d4e-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s661"},"text":"Pub. L. 109–295, title VI, § 661","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1432"},"text":"120 Stat. 1432","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dD/s1217/b"},"text":"Pub. L. 115–254, div. D, § 1217(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3451"},"text":"132 Stat. 3451","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb55b7d4f-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb55b7d50-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb55b7d51-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Joint Resolution entitled “Joint Resolution granting the consent of Congress to the Emergency Management Assistance Compact”, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/321"},"text":"Pub. L. 104–321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3877"},"text":"110 Stat. 3877","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb55b7d52-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" substituted “for each of fiscal years 2018 through 2022” for “for fiscal year 2008”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
