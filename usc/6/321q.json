{"tag":"section","attrib":{"id":"idb511a32c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321q"},"text":null,"children":[{"tag":"num","attrib":{"value":"321q"},"text":"§ 321q.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of Department of Homeland Security efforts related to food, agriculture, and veterinary defense against terrorism","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb511a32d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321q/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary for the Countering Weapons of Mass Destruction Office, shall carry out a program to coordinate the Department’s efforts related to defending the food, agriculture, and veterinary systems of the United States against terrorism and other high-consequence events that pose a high risk to homeland security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb511a32e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321q/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The coordination program required by subsection (a) shall include, at a minimum, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb511a32f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321q/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing oversight and management of the Department’s responsibilities pursuant to Homeland Security Presidential Directive 9–Defense of United States Agriculture and Food.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511a330-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321q/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing oversight and integration of the Department’s activities related to veterinary public health, food defense, and agricultural security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511a331-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321q/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leading the Department’s policy initiatives relating to food, animal, and agricultural incidents, and the impact of such incidents on animal and public health.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511a332-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321q/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leading the Department’s policy initiatives relating to overall domestic preparedness for and collective response to agricultural terrorism.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511a333-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321q/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinating with other Department components, including U.S. Customs and Border Protection, as appropriate, on activities related to food and agriculture security and screening procedures for domestic and imported products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511a334-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321q/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinating with appropriate Federal departments and agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511a335-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321q/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other activities as determined necessary by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb511a336-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321q/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed as altering or superseding the authority of the Secretary of Agriculture or the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb511a337-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tV/s528"},"text":"Pub. L. 107–296, title V, § 528","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/43/s2/a"},"text":"Pub. L. 115–43, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-06-30"},"text":"June 30, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/884"},"text":"131 Stat. 884","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/387/s2/f/5"},"text":"Pub. L. 115–387, § 2(f)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5168"},"text":"132 Stat. 5168","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb511a338-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb511a339-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb511a33a-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/387"},"text":"Pub. L. 115–387","children":[],"tail":" substituted “the Countering Weapons of Mass Destruction Office,” for “Health Affairs,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
