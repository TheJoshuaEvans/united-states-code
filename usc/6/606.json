{"tag":"section","attrib":{"id":"idb53a135a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606"},"text":null,"children":[{"tag":"num","attrib":{"value":"606"},"text":"§ 606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants to directly eligible tribes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb53a135b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s605/b"},"text":"section 605(b) of this title","children":[],"tail":", the Administrator may award grants to directly eligible tribes under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s605"},"text":"section 605 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a135c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A directly eligible tribe may apply for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s605"},"text":"section 605 of this title","children":[],"tail":" by submitting an application to the Administrator that includes, as appropriate, the information required for an application by a State under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s605/b"},"text":"section 605(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a135d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency with State plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a135e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure consistency with any applicable State homeland security plan, a directly eligible tribe applying for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s605"},"text":"section 605 of this title","children":[],"tail":" shall provide a copy of its application to each State within which any part of the tribe is located for review before the tribe submits such application to the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a135f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity for comment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Governor of a State determines that the application of a directly eligible tribe is inconsistent with the State homeland security plan of that State, or otherwise does not support the application, not later than 30 days after the date of receipt of that application the Governor shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a1360-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the Administrator, in writing, of that fact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a1361-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an explanation of the reason for not supporting the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a1362-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall have final authority to approve any application of a directly eligible tribe. The Administrator shall notify each State within the boundaries of which any part of a directly eligible tribe is located of the approval of an application by the tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a1363-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall allocate funds to directly eligible tribes in accordance with the factors applicable to allocating funds among States under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s608"},"text":"section 608 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a1364-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of awards to directly eligible tribes","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator awards funds to a directly eligible tribe under this section, the Administrator shall distribute the grant funds directly to the tribe and not through any State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a1365-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum allocation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a1366-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In allocating funds under this section, the Administrator shall ensure that, for each fiscal year, directly eligible tribes collectively receive, from the funds appropriated for the State Homeland Security Grant Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s605"},"text":"section 605 of this title","children":[],"tail":", not less than an amount equal to 0.1 percent of the total funds appropriated for grants under sections 604 and 605 of this title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a1367-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection shall not apply in any fiscal year in which the Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a1368-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives fewer than 5 applications under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a1369-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not approve at least 2 applications under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a136a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal liaison","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A directly eligible tribe applying for a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s605"},"text":"section 605 of this title","children":[],"tail":" shall designate an individual to serve as a tribal liaison with the Department and other Federal, State, local, and regional government officials concerning preventing, preparing for, protecting against, and responding to acts of terrorism."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a136b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for other funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A directly eligible tribe that receives a grant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s605"},"text":"section 605 of this title","children":[],"tail":" may receive funds for other purposes under a grant from the State or States within the boundaries of which any part of such tribe is located and from any high-risk urban area of which it is a part, consistent with the homeland security plan of the State or high-risk urban area."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a136c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State obligations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a136d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"States shall be responsible for allocating grant funds received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s605"},"text":"section 605 of this title","children":[],"tail":" to tribal governments in order to help those tribal communities achieve target capabilities not achieved through grants to directly eligible tribes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a136e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of grant funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a grant to a State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s605"},"text":"section 605 of this title","children":[],"tail":", an Indian tribe shall be eligible for funding directly from that State, and shall not be required to seek funding from any local government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a136f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Imposition of requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State may not impose unreasonable or unduly burdensome requirements on an Indian tribe as a condition of providing the Indian tribe with grant funds or resources under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s605"},"text":"section 605 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a1370-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s606/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to affect the authority of an Indian tribe that receives funds under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53a1371-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXX/s2005"},"text":"Pub. L. 107–296, title XX, § 2005","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tI/s101"},"text":"Pub. L. 110–53, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/279"},"text":"121 Stat. 279","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
