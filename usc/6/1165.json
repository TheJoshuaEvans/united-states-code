{"tag":"section","attrib":{"id":"idb56e90c0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165"},"text":null,"children":[{"tag":"num","attrib":{"value":"1165"},"text":"§ 1165.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fire and life safety improvements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56e90c1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Life-safety needs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary of Transportation for making grants to Amtrak for the purpose of carrying out projects to make fire and life safety improvements to Amtrak tunnels on the Northeast Corridor the following amounts:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e90c2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the 6 New York and New Jersey tunnels to provide ventilation, electrical, and fire safety technology improvements, emergency communication and lighting systems, and emergency access and egress for passengers—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56e90c3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90c4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $30,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90c5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $45,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90c6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $60,000,000 for fiscal year 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e90c7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the Baltimore Potomac Tunnel and the Union Tunnel, together, to provide adequate drainage and ventilation, communication, lighting, standpipe, and passenger egress improvements—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56e90c8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90c9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90ca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90cb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for fiscal year 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e90cc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the Union Station tunnels in the District of Columbia to improve ventilation, communication, lighting, and passenger egress improvements—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56e90cd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90ce-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90cf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90d0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for fiscal year 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e90d1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infrastructure upgrades","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of funds appropriated pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1153"},"text":"section 1153 of this title","children":[],"tail":", there shall be made available to the Secretary of Transportation for fiscal year 2008, $3,000,000 for the preliminary design of options for a new tunnel on a different alignment to augment the capacity of the existing Baltimore tunnels."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e90d2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of amounts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e90d3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may not make amounts available to Amtrak for obligation or expenditure under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e90d4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" until Amtrak has submitted to the Secretary of Transportation, and the Secretary of Transportation has approved, an engineering and financial plan for such projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e90d5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless, for each project funded pursuant to this section, the Secretary of Transportation has approved a project management plan prepared by Amtrak.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e90d6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e90d7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation shall complete the review of a plan required under subsection (d) and approve or disapprove the plan within 45 days after the date on which each such plan is submitted by Amtrak.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e90d8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incomplete or deficient plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary of Transportation determines that a plan is incomplete or deficient, the Secretary of Transportation shall notify Amtrak of the incomplete items or deficiencies and Amtrak shall, within 30 days after receiving the Secretary of Transportation’s notification, submit a modified plan for the Secretary of Transportation’s review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e90d9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 15 days after receiving additional information on items previously included in the plan, and within 45 days after receiving items newly included in a modified plan, the Secretary of Transportation shall either approve the modified plan, or if the Secretary of Transportation finds the plan is still incomplete or deficient, the Secretary of Transportation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56e90da-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify in writing to the appropriate congressional committees the portions of the plan the Secretary finds incomplete or deficient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90db-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve all other portions of the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90dc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obligate the funds associated with those portions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90dd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute an agreement with Amtrak within 15 days thereafter on a process for resolving the remaining portions of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e90de-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial contribution from other tunnel users","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation, taking into account the need for the timely completion of all portions of the tunnel projects described in subsection (a), shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e90df-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the extent to which railroad carriers other than Amtrak use or plan to use the tunnels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e90e0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the feasibility of seeking a financial contribution from those other railroad carriers toward the costs of the projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e90e1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1165/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain financial contributions or commitments from such other railroad carriers at levels reflecting the extent of their use or planned use of the tunnels, if feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56e90e2-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXV/s1515"},"text":"Pub. L. 110–53, title XV, § 1515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/437"},"text":"121 Stat. 437","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
