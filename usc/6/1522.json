{"tag":"section","attrib":{"id":"idb57a776c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1522"},"text":null,"children":[{"tag":"num","attrib":{"value":"1522"},"text":"§ 1522.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced internal defenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb57a776d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1522/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced network security tools","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57a776e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1522/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall include, in the efforts of the Department to continuously diagnose and mitigate cybersecurity risks, advanced network security tools to improve visibility of network activity, including through the use of commercial and free or open source tools, and to detect and mitigate intrusions and anomalous activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a776f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1522/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall develop and the Secretary shall implement a plan to ensure that each agency utilizes advanced network security tools, including those described in paragraph (1), to detect and mitigate intrusions and anomalous activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57a7770-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1522/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritizing advanced security tools","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director and the Secretary, in consultation with appropriate agencies, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57a7771-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1522/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and update Government-wide policies and programs to ensure appropriate prioritization and use of network security monitoring tools within agency networks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a7772-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1522/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" brief appropriate congressional committees on such prioritization and use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57a7773-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1522/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improved metrics","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in collaboration with the Director, shall review and update the metrics used to measure security under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3554"},"text":"section 3554 of title 44","children":[],"tail":" to include measures of intrusion and incident detection and response times."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57a7774-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1522/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency and accountability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in consultation with the Secretary, shall increase transparency to the public on agency cybersecurity posture, including by increasing the number of metrics available on Federal Government performance websites and, to the greatest extent practicable, displaying metrics for department components, small agencies, and micro-agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57a7775-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1522/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57a7776-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1522/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements under this section shall not apply to the Department of Defense, a national security system, or an element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57a7777-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dN/tII/s224"},"text":"Pub. L. 114–113, div. N, title II, § 224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2967"},"text":"129 Stat. 2967","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57a7778-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57a7779-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb57a777a-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dN/tII/s224"},"text":"section 224 of title II of div. N of Pub. L. 114–113","children":[],"tail":". Subsec. (e) of "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dN/tII/s224"},"text":"section 224 of title II of div. N of Pub. L. 114–113","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3553"},"text":"section 3553 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
