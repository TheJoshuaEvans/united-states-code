{"tag":"section","attrib":{"id":"idb51b194c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395"},"text":null,"children":[{"tag":"num","attrib":{"value":"395"},"text":"§ 395.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on contracts with corporate expatriates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb51b194d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not enter into any contract with a foreign incorporated entity which is treated as an inverted domestic corporation under subsection (b), or any subsidiary of such an entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51b194e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inverted domestic corporation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a foreign incorporated entity shall be treated as an inverted domestic corporation if, pursuant to a plan (or a series of related transactions)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51b194f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity completes before, on, or after ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", the direct or indirect acquisition of substantially all of the properties held directly or indirectly by a domestic corporation or substantially all of the properties constituting a trade or business of a domestic partnership;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b1950-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" after the acquisition at least 80 percent of the stock (by vote or value) of the entity is held—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51b1951-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an acquisition with respect to a domestic corporation, by former shareholders of the domestic corporation by reason of holding stock in the domestic corporation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51b1952-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an acquisition with respect to a domestic partnership, by former partners of the domestic partnership by reason of holding a capital or profits interest in the domestic partnership; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b1953-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expanded affiliated group which after the acquisition includes the entity does not have substantial business activities in the foreign country in which or under the law of which the entity is created or organized when compared to the total business activities of such expanded affiliated group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51b1954-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and special rules","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51b1955-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules for application of subsection (b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In applying subsection (b) for purposes of subsection (a), the following rules shall apply:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51b1956-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain stock disregarded","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There shall not be taken into account in determining ownership for purposes of subsection (b)(2)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb51b1957-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock held by members of the expanded affiliated group which includes the foreign incorporated entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51b1958-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stock of such entity which is sold in a public offering related to the acquisition described in subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51b1959-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan deemed in certain cases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a foreign incorporated entity acquires directly or indirectly substantially all of the properties of a domestic corporation or partnership during the 4-year period beginning on the date which is 2 years before the ownership requirements of subsection (b)(2) are met, such actions shall be treated as pursuant to a plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51b195a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain transfers disregarded","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The transfer of properties or liabilities (including by contribution or distribution) shall be disregarded if such transfers are part of a plan a principal purpose of which is to avoid the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51b195b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for related partnerships","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of applying subsection (b) to the acquisition of a domestic partnership, except as provided in regulations, all domestic partnerships which are under common control (within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s482"},"text":"section 482 of title 26","children":[],"tail":") shall be treated as I "},{"tag":"ref","attrib":{"idref":"fn002064"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002064"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" partnership."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51b195c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment of certain rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe such regulations as may be necessary to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb51d8a5d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/c/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treat warrants, options, contracts to acquire stock, convertible debt instruments, and other similar interests as stock; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8a5e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/c/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" treat stock as not stock.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51d8a5f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expanded affiliated group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “expanded affiliated group” means an affiliated group as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1504/a"},"text":"section 1504(a) of title 26","children":[],"tail":" (without regard to section 1504(b) of such title), except that section 1504 of such title shall be applied by substituting “more than 50 percent” for “at least 80 percent” each place it appears."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51d8a60-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign incorporated entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “foreign incorporated entity” means any entity which is, or but for subsection (b) would be, treated as a foreign corporation for purposes of title 26.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51d8a61-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “person”, “domestic”, and “foreign” have the meanings given such terms by paragraphs (1), (4), and (5) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7701/a"},"text":"section 7701(a) of title 26","children":[],"tail":", respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51d8a62-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s395/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall waive subsection (a) with respect to any specific contract if the Secretary determines that the waiver is required in the interest of national security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb51d8a63-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s835"},"text":"Pub. L. 107–296, title VIII, § 835","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2227"},"text":"116 Stat. 2227","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dL/s101/2"},"text":"Pub. L. 108–7, div. L, § 101(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/528"},"text":"117 Stat. 528","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/334/tV/s523"},"text":"Pub. L. 108–334, title V, § 523","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1320"},"text":"118 Stat. 1320","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb51d8a64-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb51d8a65-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb51d8a66-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/334/s523/1"},"text":"Pub. L. 108–334, § 523(1)","children":[],"tail":", inserted before period at end “, or any subsidiary of such an entity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/334/s523/2"},"text":"Pub. L. 108–334, § 523(2)","children":[],"tail":", inserted “before, on, or” after “completes”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/334/s523/3"},"text":"Pub. L. 108–334, § 523(3)","children":[],"tail":", struck out “which is after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", and” after “beginning on the date”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/334/s523/4"},"text":"Pub. L. 108–334, § 523(4)","children":[],"tail":", substituted “national” for “homeland”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" struck out “, or to prevent the loss of any jobs in the United States or prevent the Government from incurring any additional costs that otherwise would not occur” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
