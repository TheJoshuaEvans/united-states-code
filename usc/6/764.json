{"tag":"section","attrib":{"id":"idb55b7d6c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s764"},"text":null,"children":[{"tag":"num","attrib":{"value":"764"},"text":"§ 764.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National exercise simulation center","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President shall establish a national exercise simulation center that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55b7d6d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s764/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" uses a mix of live, virtual, and constructive simulations to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55b7d6e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s764/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare elected officials, emergency managers, emergency response providers, and emergency support providers at all levels of government to operate cohesively;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55b7d6f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s764/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a learning environment for the homeland security personnel of all Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55b7d70-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s764/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the development of operational procedures and exercises, particularly those based on catastrophic incidents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55b7d71-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s764/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow incident commanders to exercise decisionmaking in a simulated environment; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7d72-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s764/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses modeling and simulation for training, exercises, and command and control functions at the operational level.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55b7d73-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s664"},"text":"Pub. L. 109–295, title VI, § 664","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1433"},"text":"120 Stat. 1433","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
