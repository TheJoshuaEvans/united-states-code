{"tag":"section","attrib":{"id":"idb54d262c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d"},"text":null,"children":[{"tag":"num","attrib":{"value":"665d"},"text":"§ 665d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sector Risk Management Agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb54d262d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with applicable law, Presidential directives, Federal regulations, and strategic guidance from the Secretary, each Sector Risk Management Agency, in coordination with the Director, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d262e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide specialized sector-specific expertise to critical infrastructure owners and operators within its designated critical infrastructure sector or subsector of such sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d262f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support programs and associated activities of such sector or subsector of such sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d2630-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, Sector Risk Management Agencies shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d2631-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the Department and, as appropriate, other relevant Federal departments and agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d2632-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborate with critical infrastructure owners and operators within the designated critical infrastructure sector or subsector of such sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d2633-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with independent regulatory agencies, and State, local, Tribal, and territorial entities, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d2634-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with applicable law, Presidential directives, Federal regulations, and strategic guidance from the Secretary, each Sector Risk Management Agency shall utilize its specialized expertise regarding its designated critical infrastructure sector or subsector of such sector and authorities under applicable law to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d2635-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" support sector risk management, in coordination with the Director, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d2636-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing and carrying out programs to assist critical infrastructure owners and operators within the designated sector or subsector of such sector in identifying, understanding, and mitigating threats, vulnerabilities, and risks to their systems or assets, or within a region, sector, or subsector of such sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2637-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommending security measures to mitigate the consequences of destruction, compromise, and disruption of systems and assets;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d2638-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assess sector risk, in coordination with the Director, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d2639-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying, assessing, and prioritizing risks within the designated sector or subsector of such sector, considering physical security and cybersecurity threats, vulnerabilities, and consequences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d263a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting national risk assessment efforts led by the Department;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d263b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" sector coordination, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d263c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving as a day-to-day Federal interface for the prioritization and coordination of sector-specific activities and responsibilities under this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d263d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving as the Federal Government coordinating council chair for the designated sector or subsector of such sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d263e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participating in cross-sector coordinating councils, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d263f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" facilitating, in coordination with the Director, the sharing with the Department and other appropriate Federal department of information regarding physical security and cybersecurity threats within the designated sector or subsector of such sector, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d2640-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating, in coordination with the Director, access to, and exchange of, information and intelligence necessary to strengthen the security of critical infrastructure, including through Information Sharing and Analysis Organizations and the national cybersecurity and communications integration center established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s659"},"text":"section 659 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2641-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the identification of intelligence needs and priorities of critical infrastructure owners and operators in the designated sector or subsector of such sector, in coordination with the Director of National Intelligence and the heads of other Federal departments and agencies, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2642-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the Director, and facilitating awareness within the designated sector or subsector of such sector, of ongoing, and where possible, real-time awareness of identified threats, vulnerabilities, mitigations, and other actions related to the security of such sector or subsector of such sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2643-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the reporting requirements of the Department under applicable law by providing, on an annual basis, sector-specific critical infrastructure information;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d2644-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" supporting incident management, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d2645-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting, in coordination with the Director, incident management and restoration efforts during or following a security incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2646-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the Director, upon request, in national cybersecurity asset response activities for critical infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d2647-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contributing to emergency preparedness efforts, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d2648-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating with critical infrastructure owners and operators within the designated sector or subsector of such sector and the Director in the development of planning documents for coordinated action in the event of a natural disaster, act of terrorism, or other man-made disaster or emergency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2649-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participating in and, in coordination with the Director, conducting or facilitating, exercises and simulations of potential natural disasters, acts of terrorism, or other man-made disasters or emergencies within the designated sector or subsector of such sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d264a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665d/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting the Department and other Federal departments or agencies in developing planning documents or conducting exercises or simulations when relevant to the designated sector or subsector or such sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb54d264b-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2218"},"text":"Pub. L. 107–296, title XXII, § 2218","children":[],"tail":", formerly § 2215, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXC/s9002/c/1"},"text":"Pub. L. 116–283, div. H, title XC, § 9002(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4770"},"text":"134 Stat. 4770","children":[],"tail":"; renumbered § 2218 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXV/s1547/b/1/A/v"},"text":"Pub. L. 117–81, div. A, title XV, § 1547(b)(1)(A)(v)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2061"},"text":"135 Stat. 2061","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7143/b/2/J"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7143(b)(2)(J)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3660"},"text":"136 Stat. 3660","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb54d264c-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb54d264d-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb54d264e-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s2218"},"text":"section 2218 of Pub. L. 107–296","children":[],"tail":" was renumbered section 2220A and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s665g"},"text":"section 665g of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb54d264f-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “Information Sharing and Analysis Organizations” for “information sharing and analysis organizations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" reenacted section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
