{"tag":"section","attrib":{"id":"idb562a92b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s964"},"text":null,"children":[{"tag":"num","attrib":{"value":"964"},"text":"§ 964.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tier 1 participants in C–TPAT","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb562a92c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s964/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Commissioner, shall offer limited benefits to a Tier 1 participant who has been certified in accordance with the guidelines referred to in subsection (b). Such benefits may include a reduction in the score assigned pursuant to the Automated Targeting System of not greater than 20 percent of the high-risk threshold established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a92d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s964/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-13"},"text":"October 13, 2006","children":[],"tail":", the Secretary, acting through the Commissioner, shall update the guidelines for certifying a C–TPAT participant’s security measures and supply chain security practices under this section. Such guidelines shall include a background investigation and extensive documentation review."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a92e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s964/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Timeframe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the Secretary, acting through the Commissioner, shall complete the Tier 1 certification process within 90 days of receipt of an application for participation in C–TPAT.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb562a92f-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tII/s214"},"text":"Pub. L. 109–347, title II, § 214","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1910"},"text":"120 Stat. 1910","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
