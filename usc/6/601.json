{"tag":"section","attrib":{"id":"idb537c9c8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601"},"text":null,"children":[{"tag":"num","attrib":{"value":"601"},"text":"§ 601.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb537c9c9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9ca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb537c9cb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9cc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those committees of the House of Representatives that the Speaker of the House of Representatives determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9cd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical infrastructure sectors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “critical infrastructure sectors” means the following sectors, in both urban and rural areas:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb537c9ce-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Agriculture and food.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9cf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Banking and finance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9d0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chemical industries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9d1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commercial facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9d2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/u