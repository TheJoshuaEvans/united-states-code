":[],"tail":null},{"tag":"content","attrib":{},"text":" Information technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9d9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/3/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" National monuments and icons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9da-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/3/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Postal and shipping.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9db-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/3/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public health and health care.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9dc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/3/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Telecommunications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9dd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/3/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9de-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/3/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Water.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9df-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Directly eligible tribe","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “directly eligible tribe” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb537c9e0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any Indian tribe—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb537c9e1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located in the continental United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb537c9e2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that operates a law enforcement or emergency response agency with the capacity to respond to calls for law enforcement or emergency services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb537c9e3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb537c9e4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/4/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located on or near an international border or a coastline bordering an ocean (including the Gulf of Mexico) or international waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb537c9e5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/4/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located within 10 miles of a system or asset included on the prioritized critical infrastructure list established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s664/a/2"},"text":"section 664(a)(2) of this title","children":[],"tail":" or has such a system or asset within its territory;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb537c9e6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/4/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located within or contiguous to 1 of the 50 most populous metropolitan statistical areas in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb537c9e7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/4/A/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the jurisdiction of which includes not less than 1,000 square miles of Indian country, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1151"},"text":"section 1151 of title 18","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb537c9e8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that certifies to the Secretary that a State has not provided funds under section 604 or 605 of this title to the Indian tribe or consortium of Indian tribes for the purpose for which direct funding is sought; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9e9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a consortium of Indian tribes, if each tribe satisfies the requirements of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9ea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible metropolitan area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “eligible metropolitan area” means any of the 100 most populous metropolitan statistical areas in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9eb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-risk urban area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “high-risk urban area” means a high-risk urban area designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s604/b/3/A"},"text":"section 604(b)(3)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9ec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian tribe","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian tribe” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304/e"},"text":"section 5304(e) of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9ed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metropolitan statistical area","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “metropolitan statistical area” means a metropolitan statistical area, as defined by the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9ee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Special Security Event","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “National Special Security Event” means a designated event that, by virtue of its political, economic, social, or religious significance, may be the target of terrorism or other criminal activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9ef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “population” means population according to the most recent United States census population estimates available at the start of the relevant fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9f0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Population density","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “population density” means population divided by land area in square miles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9f1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified intelligence analyst","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified intelligence analyst” means an intelligence analyst (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s124h/j"},"text":"section 124h(j) of this title","children":[],"tail":"), including law enforcement personnel—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb537c9f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has successfully completed training to ensure baseline proficiency in intelligence analysis and production, as determined by the Secretary, which may include training using a curriculum developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s124f"},"text":"section 124f of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose experience ensures baseline proficiency in intelligence analysis and production equivalent to the training required under subparagraph (A), as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9f4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Target capabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “target capabilities” means the target capabilities for Federal, State, local, and tribal government preparedness for which guidelines are required to be established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s746/a"},"text":"section 746(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9f5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s601/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tribal government” means the government of an Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53a12e6-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXX/s2001"},"text":"Pub. L. 107–296, title XX, § 2001","children":[],"tai