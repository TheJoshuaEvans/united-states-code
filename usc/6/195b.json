{"tag":"section","attrib":{"id":"idb4f038e4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b"},"text":null,"children":[{"tag":"num","attrib":{"value":"195b"},"text":"§ 195b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Biosurveillance Integration Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4f038e5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Secretary for the Countering Weapons of Mass Destruction Office, shall establish, operate, and maintain a National Biosurveillance Integration Center (referred to in this section as the “NBIC”), which shall be headed by a Directing Officer, under an office or directorate of the Department that is in existence as of ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f038e6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Primary mission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The primary mission of the NBIC is to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f038e7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enhance the capability of the Federal Government to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f038e8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rapidly identify, characterize, localize, and track a biological event of national concern by integrating and analyzing data relating to human health, animal, plant, food, and environmental monitoring systems (both national and international); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f038e9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate alerts and other information to Member Agencies and, in coordination with (and where possible through) Member Agencies, to agencies of State, local, and tribal governments, as appropriate, to enhance the ability of such agencies to respond to a biological event of national concern; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f038ea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee development and operation of the National Biosurveillance Integration System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f038eb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The NBIC shall detect, as early as possible, a biological event of national concern that presents a risk to the United States or the infrastructure or key assets of the United States, including by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f038ec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consolidating data from all relevant surveillance systems maintained by Member Agencies to detect biological events of national concern across human, animal, and plant species;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f038ed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seeking private sources of surveillance, both foreign and domestic, when such sources would enhance coverage of critical surveillance gaps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f038ee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using an information technology system that uses the best available statistical and other analytical tools to identify and characterize biological events of national concern in as close to real-time as is practicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f038ef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the infrastructure for such integration, including information technology systems and space, and support for personnel from Member Agencies with sufficient expertise to enable analysis and interpretation of data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f038f0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" working with Member Agencies to create information technology systems that use the minimum amount of patient data necessary and consider patient confidentiality and privacy issues at all stages of development and apprise the Privacy Officer of such efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f038f1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alerting Member Agencies and, in coordination with (and where possible through) Member Agencies, public health agencies of State, local, and tribal governments regarding any incident that could develop into a biological event of national concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f038f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Directing Officer of the NBIC","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f038f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Directing Officer of the NBIC shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f038f4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on an ongoing basis, monitor the availability and appropriateness of surveillance systems used by the NBIC and those systems that could enhance biological situational awareness or the overall performance of the NBIC;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f038f5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on an ongoing basis, review and seek to improve the statistical and other analytical methods used by the NBIC;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f038f6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive and consider other relevant homeland security information, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f038f7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance, as appropriate, to all Federal, regional, State, local, and tribal government entities and private sector entities that contribute data relevant to the operation of the NBIC.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f038f8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Directing Officer of the NBIC shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f038f9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on an ongoing basis, evaluate available data for evidence of a biological event of national concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f038fa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrate homeland security information with NBIC data to provide overall situational awareness and determine whether a biological event of national concern has occurred.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f038fb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information sharing","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f038fc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Directing Officer of the NBIC shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4f038fd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a method of real-time communication with the National Operations Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f038fe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the event that a biological event of national concern is detected, notify the Secretary and disseminate results of NBIC assessments relating to that biological event of national concern to appropriate Federal response entities and, in coordination with relevant Member Agencies, regional, State, local, and tribal governmental response entities in a timely manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f038ff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide any report on NBIC assessments to Member Agencies and, in coordination with relevant Member Agencies, any affected regional, State, local, or tribal government, and any private sector entity considered appropriate that may enhance the mission of such Member Agencies, governments, or entities or the ability of the Nation to respond to biological events of national concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f03900-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" share NBIC incident or situational awareness reports, and other relevant information, consistent with the information sharing environment established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s485"},"text":"section 485 of this title","children":[],"tail":" and any policies, guidelines, procedures, instructions, or standards established under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03901-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Directing Officer of the NBIC shall implement the activities described in subparagraph (A) consistent with the policies, guidelines, procedures, instructions, or standards established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s485"},"text":"section 485 of this title","children":[],"tail":" and in consultation with the Director of National Intelligence, the Under Secretary for Intelligence and Analysis, and other offices or agencies of the Federal Government, as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03902-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the NBIC member agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f03903-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002026"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002026"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" In general"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Member Agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f03904-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use its best efforts to integrate biosurveillance information into the NBIC, with the goal of promoting information sharing between Federal, State, local, and tribal governments to detect biological events of national concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03905-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide timely information to assist the NBIC in maintaining biological situational awareness for accurate detection and response purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03906-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable the NBIC to receive and use biosurveillance information from member agencies to carry out its requirements under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03907-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" connect the biosurveillance data systems of that Member Agency to the NBIC data system under mutually agreed protocols that are consistent with subsection (c)(5);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03908-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in the formation of strategy and policy for the operation of the NBIC and its information sharing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03909-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide personnel to the NBIC under an interagency personnel agreement and consider the qualifications of such personnel necessary to provide human, animal, and environmental data analysis and interpretation support to the NBIC; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0390a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/e/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain responsibility for the surveillance and intelligence systems of that department or agency, if applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f0390b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative authorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f0390c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hiring of experts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Directing Officer of the NBIC shall hire individuals with the necessary expertise to develop and operate the NBIC.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f0390d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Detail of personnel","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon the request of the Directing Officer of the NBIC, the head of any Federal department or agency may detail, on a reimbursable basis, any of the personnel of that department or agency to the Department to assist the NBIC in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f0390e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NBIC interagency working group","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Directing Officer of the NBIC shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f0390f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish an interagency working group to facilitate interagency cooperation and to advise the Directing Officer of the NBIC regarding recommendations to enhance the biosurveillance capabilities of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03910-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invite Member Agencies to serve on that working group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03911-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other departments and agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Directing Officer of the NBIC under this section shall not affect any authority or responsibility of any other department or agency of the Federal Government with respect to biosurveillance activities under any program administered by that department or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03912-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03913-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f03914-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “biological agent” and “toxin” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s178"},"text":"section 178 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03915-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “biological event of national concern” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f03916-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act of terrorism involving a biological agent or toxin; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03917-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a naturally occurring outbreak of an infectious disease that may result in a national epidemic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03918-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “homeland security information” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s482"},"text":"section 482 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03919-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Member Agency” means any Federal department or agency that, at the discretion of the head of that department or agency, has entered a memorandum of understanding regarding participation in the NBIC.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f0391a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195b/j/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Privacy Officer” means the Privacy Officer appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s142"},"text":"section 142 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4f0391b-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIII/s316"},"text":"Pub. L. 107–296, title III, § 316","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXI/s1101/a"},"text":"Pub. L. 110–53, title XI, § 1101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/375"},"text":"121 Stat. 375","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/387/s2/f/2"},"text":"Pub. L. 115–387, § 2(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5168"},"text":"132 Stat. 5168","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4f0391c-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4f0391d-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4f0391e-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/387"},"text":"Pub. L. 115–387","children":[],"tail":" substituted “Secretary, acting through the Assistant Secretary for the Countering Weapons of Mass Destruction Office, shall” for “Secretary shall”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4f0391f-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4f03920-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXI/s1101/c"},"text":"Pub. L. 110–53, title XI, § 1101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/378"},"text":"121 Stat. 378","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/53/tXI/s1101/c"},"text":"“The National Biosurveillance Integration Center under section 316 of the Homeland Security Act [of 2002, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s195b"},"text":"6 U.S.C. 195b","children":[],"tail":"], as added by subsection (a), shall be fully operational by not later than "},{"tag":"date","attrib":{"date":"2008-09-30"},"text":"September 30, 2008","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
