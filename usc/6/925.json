{"tag":"section","attrib":{"id":"idb5603877-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s925"},"text":null,"children":[{"tag":"num","attrib":{"value":"925"},"text":"§ 925.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Border Patrol unit for United States Virgin Islands","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5603878-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s925/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish at least 1 Border Patrol unit for the United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5603879-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s925/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-13"},"text":"October 13, 2006","children":[],"tail":", the Secretary shall submit a report to the appropriate congressional committees that includes the schedule, if any, for carrying out subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb560387a-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tI/s126"},"text":"Pub. L. 109–347, title I, § 126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1900"},"text":"120 Stat. 1900","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
