{"tag":"section","attrib":{"id":"idb5676532-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133"},"text":null,"children":[{"tag":"num","attrib":{"value":"1133"},"text":"§ 1133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Strategy for Public Transportation Security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5676533-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Strategy","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 9 months after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", and based upon the previous and ongoing security assessments conducted by the Department and the Department of Transportation, the Secretary, consistent with and as required by section 114(t) "},{"tag":"ref","attrib":{"idref":"fn002146"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002146"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 49, shall develop and implement the modal plan for public transportation, entitled the “National Strategy for Public Transportation Security”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5676534-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5676535-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the National Strategy for Public Transportation Security, the Secretary shall establish guidelines for public transportation security that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5676536-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize security threats to public transportation systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5676537-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximize the abilities of public transportation systems to mitigate damage resulting from terrorist attack or other major incident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5676538-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessments and consultations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the National Strategy for Public Transportation Security, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5676539-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use established and ongoing public transportation security assessments as the basis of the National Strategy for Public Transportation Security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb567653a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with all relevant stakeholders, including public transportation agencies, nonprofit labor organizations representing public transportation employees, emergency responders, public safety officials, and other relevant parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb567653b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the National Strategy for Public Transportation Security, the Secretary shall describe prioritized goals, objectives, policies, actions, and schedules to improve the security of public transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb567653c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall include in the National Strategy for Public Transportation Security a description of the roles, responsibilities, and authorities of Federal, State, and local agencies, tribal governments, and appropriate stakeholders. The plan shall also include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb567653d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of, and a plan to address, gaps and unnecessary overlaps in the roles, responsibilities, and authorities of Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb567653e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process for coordinating existing or future security strategies and plans for public transportation, including the National Infrastructure Protection Plan required by Homeland Security Presidential Directive–7; Executive Order No. 13416: Strengthening Surface Transportation Security dated ","children":[{"tag":"date","attrib":{"date":"2006-12-05"},"text":"December 5, 2006","children":[],"tail":"; the Memorandum of Understanding between the Department and the Department of Transportation on Roles and Responsibilities dated "},{"tag":"date","attrib":{"date":"2004-09-28"},"text":"September 28, 2004","children":[],"tail":"; and subsequent annexes and agreements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb567653f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adequacy of existing plans and strategies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the National Strategy for Public Transportation Security, the Secretary shall use relevant existing risk assessments and strategies developed by the Department or other Federal agencies, including those developed or implemented pursuant to section 114(t) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 49 or Homeland Security Presidential Directive–7."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d540-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1133/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $2,000,000 for fiscal year 2008.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb569d541-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXIV/s1404"},"text":"Pub. L. 110–53, title XIV, § 1404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/401"},"text":"121 Stat. 401","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb569d542-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb569d543-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb569d544-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s114/t"},"text":"Section 114(t) of title 49","children":[],"tail":", referred to in subsecs. (a) and (e), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s114/s"},"text":"section 114(s) of title 49","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dE/tV/s568/a"},"text":"Pub. L. 110–161, div. E, title V, § 568(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2092"},"text":"121 Stat. 2092","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Order No. 13416, referred to in subsec. (d)(2), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
