{"tag":"section","attrib":{"id":"idb57a77e5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531"},"text":null,"children":[{"tag":"num","attrib":{"value":"1531"},"text":"§ 1531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Apprehension and prosecution of international cyber criminals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb57a77e6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International cyber criminal defined","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “international cyber criminal” means an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57a77e7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is believed to have committed a cybercrime or intellectual property crime against the interests of the United States or the citizens of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a77e8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57a77e9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an arrest warrant has been issued by a judge in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57a77ea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an international wanted notice (commonly referred to as a “Red Notice”) has been circulated by Interpol.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57a77eb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations for noncooperation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State, or designee, shall consult with the appropriate government official of each country from which extradition is not likely due to the lack of an extradition treaty with the United States or other reasons, in which one or more international cyber criminals are physically present, to determine what actions the government of such country has taken—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57a77ec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to apprehend and prosecute such criminals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a77ed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent such criminals from carrying out cybercrimes or intellectual property crimes against the interests of the United States or its citizens.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57a77ee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57a77ef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall submit to the appropriate congressional committees an annual report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57a77f0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of international cyber criminals located in other countries, disaggregated by country, and indicating from which countries extradition is not likely due to the lack of an extradition treaty with the United States or other reasons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57a77f1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and number of significant discussions by an official of the Department of State on ways to thwart or prosecute international cyber criminals with an official of another country, including the name of each such country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57a77f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each international cyber criminal who was extradited to the United States during the most recently completed calendar year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb57a77f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his or her name;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a77f4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the crimes for which he or she was charged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a77f5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his or her previous country of residence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a77f6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/c/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the country from which he or she was extradited into the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a77f7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report required by this subsection shall be in unclassified form to the maximum extent possible, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a77f8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term “appropriate congressional committees” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57a77f9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations, the Committee on Appropriations, the Committee on Homeland Security and Governmental Affairs, the Committee on Banking, Housing, and Urban Affairs, the Select Committee on Intelligence, and the Committee on the Judiciary of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57a77fa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1531/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs, the Committee on Appropriations, the Committee on Homeland Security, the Committee on Financial Services, the Permanent Select Committee on Intelligence, and the Committee on the Judiciary of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57a77fb-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dN/tIV/s403"},"text":"Pub. L. 114–113, div. N, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2979"},"text":"129 Stat. 2979","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
