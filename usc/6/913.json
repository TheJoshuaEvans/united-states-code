{"tag":"section","attrib":{"id":"idb5603846-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s913"},"text":null,"children":[{"tag":"num","attrib":{"value":"913"},"text":"§ 913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Facility exercise requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Department in which the Coast Guard is operating shall require each high risk facility to conduct live or full-scale exercises described in section 105.220(c) of title 33, Code of Federal Regulations, not less frequently than once every 2 years, in accordance with the facility security plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70103/c"},"text":"section 70103(c) of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5603847-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tI/s115"},"text":"Pub. L. 109–347, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1897"},"text":"120 Stat. 1897","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
