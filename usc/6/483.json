{"tag":"section","attrib":{"id":"idb5270051-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s483"},"text":null,"children":[{"tag":"num","attrib":{"value":"483"},"text":"§ 483.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5270052-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s483/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", the President shall submit to the congressional committees specified in subsection (b) a report on the implementation of "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s482"},"text":"section 482 of this title","children":[],"tail":". The report shall include any recommendations for additional measures or appropriation requests, beyond the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s482"},"text":"section 482 of this title","children":[],"tail":", to increase the effectiveness of sharing of information between and among Federal, State, and local entities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5270053-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s483/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specified congressional committees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The congressional committees referred to in subsection (a) are the following committees:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5270054-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s483/b/1"},"tex