{"tag":"section","attrib":{"id":"idb554519f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677"},"text":null,"children":[{"tag":"num","attrib":{"value":"677"},"text":"§ 677.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sense of Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55451a0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose of this part is to authorize the Secretary to declare that a significant incident has occurred and to establish the authorities that are provided under the declaration to respond to and recover from the significant incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451a1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authorities established under this part are intended to enable the Secretary to provide voluntary assistance to non-Federal entities impacted by a significant incident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55451a2-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2231"},"text":"Pub. L. 107–296, title XXII, § 2231","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tVI/s70602/a"},"text":"Pub. L. 117–58, div. G, title VI, § 70602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1267"},"text":"135 Stat. 1267","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
