{"tag":"section","attrib":{"id":"idb55933ae-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748"},"text":null,"children":[{"tag":"num","attrib":{"value":"748"},"text":"§ 748.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and exercises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55933af-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National training program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55933b0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", the Administrator, in coordination with the heads of appropriate Federal agencies, the National Council on Disability, and the National Advisory Council, shall carry out a national training program to implement the national preparedness goal, National Incident Management System, National Response Plan, and other related plans and strategies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933b1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training partners","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing and implementing the national training program, the Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55933b2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with government training facilities, academic institutions, private organizations, and other entities that provide specialized, state-of-the-art training for emergency managers or emergency response providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55933b3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize, as appropriate, training courses provided by community colleges, State and local public safety academies, State and private universities, and other facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55933b4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National exercise program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55933b5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Beginning not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", the Administrator, in coordination with the heads of appropriate Federal agencies, the National Council on Disability, and the National Advisory Council, shall carry out a national exercise program to test and evaluate the national preparedness goal, National Incident Management System, National Response Plan, and other related plans and strategies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933b6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The national exercise program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55933b7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55933b8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as realistic as practicable, based on current risk assessments, including credible and emerging threats, vulnerabilities, and consequences, and designed to stress the national preparedness system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55933b9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed, as practicable, to simulate the partial or complete incapacitation of a State, local, or tribal government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55933ba-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carried out, as appropriate, with a minimum degree of notice to involved parties regarding the timing and details of such exercises, consistent with safety considerations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55933bb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to provide for the systematic evaluation of readiness and enhance operational understanding of the incident command system and relevant mutual aid agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55933bc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to address the unique requirements of populations with special needs, including the elderly; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55933bd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to promptly develop after-action reports and plans for quickly incorporating lessons learned into future operations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55933be-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include a selection of model exercises that State, local, and tribal governments can readily adapt for use and provide assistance to State, local, and tribal governments with the design, implementation, and evaluation of exercises (whether a model exercise program or an exercise designed locally) that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55933bf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conform to the requirements under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55933c0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with any applicable State, local, or tribal strategy or plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55933c1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for systematic evaluation of readiness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933c2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National level exercises","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall periodically, but not less than biennially, perform national exercises for the following purposes:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55933c3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To test and evaluate the capability of Federal, State, local, and tribal governments to detect, disrupt, and prevent threatened or actual catastrophic acts of terrorism, especially those involving weapons of mass destruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55933c4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s748/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To test and evaluate the readiness of Federal, State, local, and tribal governments to respond and recover in a coordinated and unified manner to catastrophic incidents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55933c5-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s648"},"text":"Pub. L. 109–295, title VI, § 648","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1427"},"text":"120 Stat. 1427","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tIV"},"text":"Pub. L. 110–53, title IV","children":[],"tail":", §§ 402, 403, "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/302"},"text":"121 Stat. 302","children":[],"tail":", 303; "},{"tag":"ref","attrib":{"href":"/us/pl/116/64/s3"},"text":"Pub. L. 116–64, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-10-09"},"text":"Oct. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1123"},"text":"133 Stat. 1123","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb55933c6-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb55933c7-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb55933c8-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (b)(2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/64"},"text":"Pub. L. 116–64","children":[],"tail":" inserted “and emerging” after “credible”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b)(2)(A)(iv) to (vi). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s402"},"text":"Pub. L. 110–53, § 402","children":[],"tail":", added cls. (iv) to (vi) and struck out former cls. (iv) and (v) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(iv) designed to provide for systematic evaluation of readiness; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(v) designed to address the unique requirements of populations with special needs; and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s403"},"text":"Pub. L. 110–53, § 403","children":[],"tail":", in introductory provisions, substituted “shall include a selection of model exercises that State, local, and tribal governments can readily adapt for use and provide assistance to State, local, and tribal governments with the design, implementation, and evaluation of exercises (whether a model exercise program or an exercise designed locally)” for “shall provide assistance to State, local, and tribal governments with the design, implementation, and evaluation of exercises”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
