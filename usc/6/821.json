{"tag":"section","attrib":{"id":"idb55deea9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821"},"text":null,"children":[{"tag":"num","attrib":{"value":"821"},"text":"§ 821.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55deeaa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Administrator” means the Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deeab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic need","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “basic need”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55deeac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any good, service, or activity necessary to protect the health, safety, and general welfare of the civilian population of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55deead-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55deeae-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55deeaf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" water;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55deeb0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shelter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55deeb1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic communication services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55deeb2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" basic sanitation and health services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55deeb3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deeb4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Catastrophic incident","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “catastrophic incident”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55deeb5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any natural or man-made disaster that results in extraordinary levels of casualties or damage, mass evacuations, or disruption severely affecting the population, infrastructure, environment, economy, national morale, or government functions in an area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55deeb6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may include an incident—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55deeb7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a sustained national impact over a prolonged period of time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55deeb8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that may rapidly exceed resources available to State and local government and private sector authorities in the impacted area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55deeb9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that may significantly interrupt governmental operations and emergency services to such an extent that national security could be threatened.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deeba-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical infrastructure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “critical infrastructure” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5195c/e"},"text":"section 5195c(e) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deebb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existential risk","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “existential risk” means the potential for an outcome that would result in human extinction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deebc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global catastrophic risk","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “global catastrophic risk” means the risk of events or incidents consequential enough to significantly harm or set back human civilization at the global scale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deebd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Global catastrophic and existential threats","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “global catastrophic and existential threats” means threats that with varying likelihood may produce consequences severe enough to result in systemic failure or destruction of critical infrastructure or significant harm to human civilization. Examples of global catastrophic and existential threats include severe global pandemics, nuclear war, asteroid and comet impacts, supervolcanoes, sudden and severe changes to the climate, and intentional or accidental threats arising from the use and development of emerging technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deebe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indian Tribal government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Indian Tribal government” has the meaning given the term “Indian tribal government” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"section 5122 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deebf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local government; State","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “local government” and “State” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"section 5122 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deec0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National exercise program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national exercise program” means activities carried out to test and evaluate the national preparedness goal and related plans and strategies as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s748/b"},"text":"section 748(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55deec1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s821/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Secretary” means the Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55deec2-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXIII/s7302"},"text":"Pub. L. 117–263, div. G, title LXXIII, § 7302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3684"},"text":"136 Stat. 3684","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb55deec3-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb55deec4-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb55deec5-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5195c/e"},"text":"Section 5195c(e) of title 42","children":[],"tail":", referred to in par. (4), was in the original “section 1016(e) of the Critical Infrastructure Protection Act of 2001” and was translated as reading “section 1016(e) of the Critical Infrastructures Protection Act of 2001”, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
