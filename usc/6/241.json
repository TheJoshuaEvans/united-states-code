{"tag":"section","attrib":{"id":"idb4fe9160-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s241"},"text":null,"children":[{"tag":"num","attrib":{"value":"241"},"text":"§ 241.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention of international child abduction","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4fe9161-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s241/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program established","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, through the Commissioner of U.S. Customs and Border Protection (referred to in this section as “CBP”), in coordination with the Secretary of State, the Attorney General, and the Director of the Federal Bureau of Investigation, shall establish a program that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fe9162-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s241/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seeks to prevent a child (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1204/b/1"},"text":"section 1204(b)(1) of title 18","children":[],"tail":") from departing from the territory of the United States if a parent or legal guardian of such child presents a court order from a court of competent jurisdiction prohibiting the removal of such child from the United States to a CBP Officer in sufficient time to prevent such departure for the duration of such court order; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fe9163-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s241/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverages other existing authorities and processes to address the wrongful removal and return of a child.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fe9164-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s241/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interagency coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fe9165-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s241/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of State shall convene and chair an interagency working group to prevent international parental child abduction. The group shall be composed of presidentially appointed, Senate confirmed officials from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fe9166-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s241/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fe9167-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s241/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Homeland Security, including U.S. Customs and Border Protection and U.S. Immigration and Customs Enforcement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fe9168-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s241/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Justice, including the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fe9169-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s241/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense shall designate an official within the Department of Defense—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fe916a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s241/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate with the Department of State on international child abduction issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fe916b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s241/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to oversee activities designed to prevent or resolve international child abduction cases relating to active duty military service members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4fe916c-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s433"},"text":"Pub. L. 107–296, title IV, § 433","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/150/tIII/s301/a"},"text":"Pub. L. 113–150, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-08-08"},"text":"Aug. 8, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/1822"},"text":"128 Stat. 1822","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
