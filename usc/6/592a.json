{"tag":"section","attrib":{"id":"idb537c932-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s592a"},"text":null,"children":[{"tag":"num","attrib":{"value":"592a"},"text":"§ 592a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technology research and development investment strategy for nuclear and radiological detection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb537c933-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s592a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2006-10-13"},"text":"October 13, 2006","children":[],"tail":", the Secretary, the Secretary of Energy, the Secretary of Defense, and the Director of National Intelligence shall submit to Congress a research and development investment strategy for nuclear and radiological detection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c934-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s592a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb537c935-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s592a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a long term technology roadmap for nuclear and radiological detection applicable to the mission needs of the Department, the Department of Energy, the Department of Defense, and the Office of the Director of National Intelligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c936-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s592a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" budget requirements necessary to meet the roadmap; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c937-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s592a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation of how the Department, the Department of Energy, the Department of Defense, and the Office of the Director of National Intelligence will execute this strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c938-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s592a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2006-10-13"},"text":"October 13, 2006","children":[],"tail":", the Secretary shall submit a report to the appropriate congressional committees on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb537c939-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s592a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of this title,","children":[{"tag":"ref","attrib":{"idref":"fn002095"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002095"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and the amendments made by this title, on the responsibilities under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s182"},"text":"section 182 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c93a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s592a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efforts of the Department to coordinate, integrate, and establish priorities for conducting all basic and applied research, development, testing, and evaluation of technology and systems to detect, prevent, protect, and respond to chemical, biological, radiological, and nuclear terrorist attacks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c93b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s592a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director for Domestic Nuclear Detection ","children":[{"tag":"ref","attrib":{"idref":"fn002096"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002096"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See Change of Name note below."}],"tail":" and the Under Secretary for Science and Technology shall jointly and annually notify Congress that the strategy and technology road map for nuclear and radiological detection developed under subsections (a) and (b) is consistent with the national policy and strategic plan for identifying priorities, goals, objectives, and policies for coordinating the Federal Government’s civilian efforts to identify and develop countermeasures to terrorist threats from weapons of mass destruction that are required under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s182/2"},"text":"section 182(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb537c93c-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tV/s502"},"text":"Pub. L. 109–347, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1935"},"text":"120 Stat. 1935","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb537c93d-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb537c93e-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb537c93f-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in subsec. (c)(1), is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347"},"text":"Pub. L. 109–347","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1932"},"text":"120 Stat. 1932","children":[],"tail":", which enacted this subchapter and this section and amended sections 113 and 182 of this title. For complete classification of title V to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb537c940-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"