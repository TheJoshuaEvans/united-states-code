{"tag":"section","attrib":{"id":"idb53a13ad-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609"},"text":null,"children":[{"tag":"num","attrib":{"value":"609"},"text":"§ 609.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb53a13ae-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall permit the recipient of a grant under section 604 or 605 of this title to use grant funds to achieve target capabilities related to preventing, preparing for, protecting against, and responding to acts of terrorism, consistent with a State homeland security plan and relevant local, tribal, and regional homeland security plans, including by working in conjunction with a National Laboratory (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801/3"},"text":"section 15801(3) of title 42","children":[],"tail":"), through—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a13af-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and enhancing homeland security, emergency management, or other relevant plans, assessments, or mutual aid agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13b0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designing, conducting, and evaluating training and exercises, including training and exercises conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s321a"},"text":"section 321a of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s748"},"text":"section 748 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13b1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting a system or asset included on the prioritized critical infrastructure list established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s664/a/2"},"text":"section 664(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13b2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchasing, upgrading, storing, or maintaining equipment, including computer hardware and software;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13b3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring operability and achieving interoperability of emergency communications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13b4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responding to an increase in the threat level under the Homeland Security Advisory System, or to the needs resulting from a National Special Security Event;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13b5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing, enhancing, and staffing with appropriately qualified personnel State, local, and regional fusion centers that comply with the guidelines established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s124h/i"},"text":"section 124h(i) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13b6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing school preparedness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13b7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing the security and preparedness of secure and nonsecure areas of eligible airports and surface transportation systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13b8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting public safety answering points;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13b9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paying salaries and benefits for personnel, including individuals employed by the grant recipient on the date of the relevant grant application, to serve as qualified intelligence analysts, regardless of whether such analysts are current or new full-time employees or contract employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13ba-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paying expenses directly related to administration of the grant, except that such expenses may not exceed 3 percent of the amount of the grant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13bb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any activity permitted under the Fiscal Year 2007 Program Guidance of the Department for the State Homeland Security Grant Program, the Urban Area Security Initiative (including activities permitted under the full-time counterterrorism staffing pilot), or the Law Enforcement Terrorism Prevention Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13bc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" migrating any online service (as defined in section 3 of the DOTGOV Online Trust in Government Act of 2020) ","children":[{"tag":"ref","attrib":{"idref":"fn002100"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002100"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" to the .gov internet domain; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13bd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other appropriate activity, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a13be-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on use of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a13bf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Funds provided under section 604 or 605 of this title may not be used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a13c0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to supplant State or local funds, except that nothing in this paragraph shall prohibit the use of grant funds provided to a State or high-risk urban area for otherwise permissible uses under subsection (a) on the basis that a State or high-risk urban area has previously used State or local funds to support the same or similar uses; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a13c1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any State or local government cost-sharing contribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13c2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a13c3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not more than 50 percent of the amount awarded to a grant recipient under section 604 or 605 of this title in any fiscal year may be used to pay for personnel, including overtime and backfill costs, in support of the permitted uses under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a13c4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of the recipient of a grant under section 604 or 605 of this title, the Administrator may grant a waiver of the limitation under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13c5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on discretion","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a13c6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to the use of amounts awarded to a grant recipient under section 604 or 605 of this title for personnel costs in accordance with paragraph (2) of this subsection, the Administrator may not—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53a13c7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose a limit on the amount of the award that may be used to pay for personnel, or personnel-related, costs that is higher or lower than the percent limit imposed in paragraph (2)(A); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53a13c8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impose any additional limitation on the portion of the funds of a recipient that may be used for a specific type, purpose, or category of personnel, or personnel-related, costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a13c9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If amounts awarded to a grant recipient under section 604 or 605 of this title are used for paying salary or benefits of a qualified intelligence analyst under subsection (a)(10),","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" the Administrator shall make such amounts available without time limitations placed on the period of time that the analyst can serve under the grant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13ca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a13cb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant awarded under section 604 or 605 of this title may not be used to acquire land or to construct buildings or other physical facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a13cc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53a13cd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding subparagraph (A), nothing in this paragraph shall prohibit the use of a grant awarded under section 604 or 605 of this title to achieve target capabilities related to preventing, preparing for, protecting against, or responding to acts of terrorism, including through the alteration or remodeling of existing buildings for the purpose of making such buildings secure against acts of terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53a13ce-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No grant awarded under section 604 or 605 of this title may be used for a purpose described in clause (i) unless—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb53a13cf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/4/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifically approved by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb53a13d0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/4/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any construction work occurs under terms and conditions consistent with the requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5196/j/9"},"text":"section 5196(j)(9) of title 42","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb53a13d1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/4/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount allocated for purposes under clause (i) does not exceed the greater of $1,000,000 or 15 percent of the grant award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13d2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recreation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants awarded under this part may not be used for recreational or social purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a13d3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiple-purpose funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this part shall be construed to prohibit State, local, or tribal governments from using grant funds under sections 604, 605, and 609a of this title in a manner that enhances preparedness for disasters unrelated to acts of terrorism, if such use assists such governments in achieving target capabilities related to preventing, preparing for, protecting against, or responding to acts of terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c83d4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of costs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53c83d5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paid-on-call or volunteer reimbursement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to the activities described in subsection (a), a grant under section 604 or 605 of this title may be used to provide a reasonable stipend to paid-on-call or volunteer emergency response providers who are not otherwise compensated for travel to or participation in training or exercises related to the purposes of this part. Any such reimbursement shall not be considered compensation for purposes of rendering an emergency response provider an employee under the Fair Labor Standards Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"29 U.S.C. 201","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c83d6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance of Federal duty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An applicant for a grant under section 604 or 605 of this title may petition the Administrator to use the funds from its grants under those sections for the reimbursement of the cost of any activity relating to preventing, preparing for, protecting against, or responding to acts of terrorism that is a Federal duty and usually performed by a Federal agency, and that is being performed by a State or local government under agreement with a Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c83d7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexibility in unspent homeland security grant funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon request by the recipient of a grant under section 604, 605, or 609a of this title, the Administrator may authorize the grant recipient to transfer all or part of the grant funds from uses specified in the grant agreement to other uses authorized under this section, if the Administrator determines that such transfer is in the interests of homeland security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c83d8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equipment standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53c83d9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If an applicant for a grant under section 604 or 605 of this title proposes to upgrade or purchase, with assistance provided under that grant, new equipment or systems that do not meet or exceed any applicable national voluntary consensus standards developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s747"},"text":"section 747 of this title","children":[],"tail":", the applicant shall include in its application an explanation of why such equipment or systems will serve the needs of the applicant better than equipment or systems that meet or exceed such standards."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c83da-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall implement a uniform process for reviewing applications that, in accordance with paragraph (1), contain explanations to use grants provided under section 604 or 605 of this title to purchase equipment or systems that do not meet or exceed any applicable national voluntary consensus standards developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s747"},"text":"section 747 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c83db-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Factors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the review process under paragraph (2), the Administrator shall consider the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c83dc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Current or past use of proposed equipment or systems by Federal agencies or the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c83dd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The absence of a national voluntary consensus standard for such equipment or systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c83de-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The existence of an international consensus standard for such equipment or systems, and whether such equipment or systems meets such standard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c83df-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The nature of the capability gap identified by the applicant and how such equipment or systems will address such gap.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c83e0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/f/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The degree to which such equipment or systems will serve the needs of the applicant better than equipment or systems that meet or exceed existing consensus standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c83e1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/f/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other factor determined appropriate by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c83e2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall implement a uniform process for reviewing applications to use grants provided under section 604 or 605 of this title to purchase equipment or systems not included on the Authorized Equipment List maintained by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53c83e3-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXX/s2008"},"text":"Pub. L. 107–296, title XX, § 2008","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tI/s101"},"text":"Pub. L. 110–53, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/283"},"text":"121 Stat. 283","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/412/s2"},"text":"Pub. L. 110–412, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4336"},"text":"122 Stat. 4336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dM/tVII/s711"},"text":"Pub. L. 114–113, div. M, title VII, § 711","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2934"},"text":"129 Stat. 2934","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/190/tIII/s3603"},"text":"Pub. L. 114–190, title III, § 3603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/665"},"text":"130 Stat. 665","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/7/B"},"text":"Pub. L. 115–278, § 2(g)(7)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4180"},"text":"132 Stat. 4180","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dU/tIX/s904/c"},"text":"Pub. L. 116–260, div. U, title IX, § 904(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2302"},"text":"134 Stat. 2302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7101/c"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3619"},"text":"136 Stat. 3619","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/165/s2/a"},"text":"Pub. L. 118–165, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2581"},"text":"138 Stat. 2581","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb53c83e4-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb53c83e5-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb53c83e6-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3 of the DOTGOV Online Trust in Government Act of 2020, referred to in subsec. (a)(14), probably means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dU/tIX/s903"},"text":"section 903 of title IX of div. U of Pub. L. 116–260","children":[],"tail":", which defines “online service” and is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s665"},"text":"section 665 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(10), referred to in subsec. (b)(3)(B), was redesignated subsec. (a)(11) by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/tIII/s3603/1"},"text":"Pub. L. 114–190, title III, § 3603(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/665"},"text":"130 Stat. 665","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Fair Labor Standards Act of 1938, referred to in subsec. (d)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch676"},"text":"act June 25, 1938, ch. 676","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1060"},"text":"52 Stat. 1060","children":[],"tail":", which is classified generally to chapter 8 (§ 201 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"section 201 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb53c83e7-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/165/s2/a/1"},"text":"Pub. L. 118–165, § 2(a)(1)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/165/s2/a/2"},"text":"Pub. L. 118–165, § 2(a)(2)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7101/c/1"},"text":"Pub. L. 117–263, § 7101(c)(1)","children":[],"tail":", substituted “sections 604, 605, and 609a of this title” for “sections 604 and 605 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7101/c/2"},"text":"Pub. L. 117–263, § 7101(c)(2)","children":[],"tail":", substituted “section 604, 605, or 609a of this title” for “section 604 or 605 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(14), (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added par. (14) and redesignated former par. (14) as (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278"},"text":"Pub. L. 115–278","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s664/a/2"},"text":"section 664(a)(2) of this title","children":[],"tail":"” for “section 124"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(a)(2) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(9) to (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190"},"text":"Pub. L. 114–190","children":[],"tail":" added par. (9) and redesignated former pars. (9) to (13) as (10) to (14), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":" inserted “including by working in conjunction with a National Laboratory (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s15801/3"},"text":"section 15801(3) of title 42","children":[],"tail":"),” after “plans,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/412/s2/1/A"},"text":"Pub. L. 110–412, § 2(1)(A)","children":[],"tail":", substituted “The Administrator shall permit the recipient of a grant under section 604 or 605 of this title to use grant funds” for “Grants awarded under section 604 or 605 of this title may be used” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/412/s2/1/B"},"text":"Pub. L. 110–412, § 2(1)(B)","children":[],"tail":", inserted “, regardless of whether such analysts are current or new full-time employees or contract employees” after “analysts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/412/s2/2"},"text":"Pub. L. 110–412, § 2(2)","children":[],"tail":", added par. (3) and redesignated former pars. (3) and (4) as (4) and (5), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
