{"tag":"section","attrib":{"id":"idb50a7830-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318"},"text":null,"children":[{"tag":"num","attrib":{"value":"318"},"text":"§ 318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Advisory Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb50a7831-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", the Secretary shall establish an advisory body under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s451/a"},"text":"section 451(a) of this title","children":[],"tail":" to ensure effective and ongoing coordination of Federal preparedness, protection, response, recovery, and mitigation for natural disasters, acts of terrorism, and other man-made disasters, to be known as the National Advisory Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50a7832-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50a7833-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Advisory Council shall advise the Administrator on all aspects of emergency management. The National Advisory Council shall incorporate State, local, and tribal government and private sector input in the development and revision of the national preparedness goal, the national preparedness system, the National Incident Management System, the National Response Plan, and other related plans and strategies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50a7834-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation on grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To ensure input from and coordination with State, local, and tribal governments and emergency response providers, the Administrator shall regularly consult and work with the National Advisory Council on the administration and assessment of grant programs administered by the Department, including with respect to the development of program guidance and the development and evaluation of risk-assessment methodologies, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50a7835-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50a7836-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the National Advisory Council shall be appointed by the Administrator, and shall, to the extent practicable, represent a geographic (including urban and rural) and substantive cross section of officials, emergency managers, and emergency response providers from State, local, and tribal governments, the private sector, and nongovernmental organizations, including as appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50a7837-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members selected from the emergency management field and emergency response providers, including fire service, law enforcement, hazardous materials response, emergency medical services, and emergency management personnel, or organizations representing such individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50a7838-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health scientists, emergency and inpatient medical providers, and public health professionals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50a7839-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts from Federal, State, local, and tribal governments, and the private sector, representing standards-setting and accrediting organizations, including representatives from the voluntary consensus codes and standards development community, particularly those with expertise in the emergency preparedness and response field;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50a783a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, and tribal government officials with expertise in preparedness, protection, response, recovery, and mitigation, including Adjutants General;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50a783b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elected State, local, and tribal government executives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50a783c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts in public and private sector infrastructure protection, cybersecurity, and communications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50a783d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of individuals with disabilities and other populations with special needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50a783e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other individuals as the Administrator determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50a783f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with the Departments of Health and Human Services and Transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the selection of members of the National Advisory Council who are health or emergency medical services professionals, the Administrator shall work with the Secretary of Health and Human Services and the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50a7840-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ex officio members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall designate 1 or more officers of the Federal Government to serve as ex officio members of the National Advisory Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce841-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of office","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50ce842-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the term of office of each member of the National Advisory Council shall be 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce843-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial appointments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the members initially appointed to the National Advisory Council—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb50ce844-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-third shall be appointed for a term of 1 year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce845-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-third shall be appointed for a term of 2 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50ce846-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" RESPONSE Subcommittee","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50ce847-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the Administrator shall establish, as a subcommittee of the National Advisory Council, the Railroad Emergency Services Preparedness, Operational Needs, and Safety Evaluation Subcommittee (referred to in this subsection as the “RESPONSE Subcommittee”)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce848-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (c), the RESPONSE Subcommittee shall be composed of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50ce849-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Administrator, Protection and National Preparedness of the Federal Emergency Management Agency, or designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce84a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Safety Officer of the Pipeline and Hazardous Materials Safety Administration, or designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce84b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Associate Administrator for Hazardous Materials Safety of the Pipeline and Hazardous Materials Safety Administration, or designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce84c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Director for Emergency Communications, or designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce84d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director for the Office of Railroad, Pipeline and Hazardous Materials Investigations of the National Transportation Safety Board, or designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce84e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Safety Officer and Associate Administrator for Railroad Safety of the Federal Railroad Administration, or designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce84f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Administrator for Security Policy and Industry Engagement of the Transportation Security Administration, or designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce850-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Commandant for Response Policy of the Coast Guard, or designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce851-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Administrator for the Office of Solid Waste and Emergency Response of the Environmental Protection Agency, or designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce852-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such other qualified individuals as the co-chairpersons shall jointly appoint as soon as practicable after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", from among the following:"}],"tail":null},{"tag":"clause","attrib":{"id":"idb50ce853-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Members of the National Advisory Council that have the requisite technical knowledge and expertise to address rail emergency response issues, including members from the following disciplines:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb50ce854-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency management and emergency response providers, including fire service, law enforcement, hazardous materials response, and emergency medical services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb50ce855-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State, local, and tribal government officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce856-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Individuals who have the requisite technical knowledge and expertise to serve on the RESPONSE Subcommittee, including at least 1 representative from each of the following:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb50ce857-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rail industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb50ce858-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rail labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb50ce859-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Persons who offer oil for transportation by rail.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb50ce85a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The communications industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb50ce85b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency response providers, including individuals nominated by national organizations representing State and local governments and emergency responders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb50ce85c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency response training providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb50ce85d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J/ii/VII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VII"},"text":"(VII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives from tribal organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb50ce85e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J/ii/VIII"},"text":null,"children":[{"tag":"num","attrib":{"value":"VIII"},"text":"(VIII)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technical experts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb50ce85f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J/ii/IX"},"text":null,"children":[{"tag":"num","attrib":{"value":"IX"},"text":"(IX)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vendors, developers, and manufacturers of systems, facilities, equipment, and capabilities for emergency responder services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce860-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/2/J/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives of such other stakeholders and interested and affected parties as the co-chairpersons consider appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce861-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Co-chairpersons","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members described in subparagraphs (A) and (B) of paragraph (2) shall serve as the co-chairpersons of the RESPONSE Subcommittee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce862-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The initial meeting of the RESPONSE Subcommittee shall take place not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce863-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with nonmembers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The RESPONSE Subcommittee and the program offices for emergency responder training and resources shall consult with other relevant agencies and groups, including entities engaged in federally funded research and academic institutions engaged in relevant work and research, which are not represented on the RESPONSE Subcommittee to consider new and developing technologies and methods that may be beneficial to preparedness and response to rail hazardous materials incidents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce864-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The RESPONSE Subcommittee shall develop recommendations, as appropriate, for improving emergency responder training and resource allocation for hazardous materials incidents involving railroads after evaluating the following topics:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50ce865-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The quality and application of training for State and local emergency responders related to rail hazardous materials incidents, including training for emergency responders serving small communities near railroads, including the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb50ce866-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Ease of access to relevant training for State and local emergency responders, including an analysis of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb50ce867-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals being trained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb50ce868-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals who are applying;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb50ce869-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether current demand is being met;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb50ce86a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current challenges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb50ce86b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projected needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce86c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Modernization of training course content related to rail hazardous materials incidents, with a particular focus on fluctuations in oil shipments by rail, including regular and ongoing evaluation of course opportunities, adaptation to emerging trends, agency and private sector outreach, effectiveness and ease of access for State and local emergency responders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce86d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of overlap in training content and identification of opportunities to develop complementary courses and materials among governmental and nongovernmental entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce86e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Online training platforms, train-the-trainer, and mobile training options.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce86f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The availability and effectiveness of Federal, State, local, and nongovernmental funding levels related to training emergency responders for rail hazardous materials incidents, including emergency responders serving small communities near railroads, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb50ce870-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying overlap in resource allocations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce871-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying cost savings measures that can be implemented to increase training opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce872-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leveraging government funding with nongovernmental funding to enhance training opportunities and fill existing training gaps;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce873-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adaptation of priority settings for agency funding allocations in response to emerging trends;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce874-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historic levels of funding across Federal agencies for rail hazardous materials incident response and training, including funding provided by the private sector to public entities or in conjunction with Federal programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce875-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current funding resources across agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce876-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The strategy for integrating commodity flow studies, mapping, and rail and hazardous materials databases for State and local emergency responders and increasing the rate of access to the individual responder in existing or emerging communications technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce877-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50ce878-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":", the RESPONSE Subcommittee shall submit a report to the National Advisory Council that—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb50ce879-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the recommendations developed under paragraph (6);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce87a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies the timeframes for implementing any such recommendations that do not require congressional action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce87b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/7/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies any such recommendations that do require congressional action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce87c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after receiving the report under subparagraph (A), the National Advisory Council shall begin a review of the report. The National Advisory Council may ask for additional clarification, changes, or other information from the RESPONSE Subcommittee to assist in the approval of the recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce87d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Once the National Advisory Council approves the recommendations of the RESPONSE Subcommittee, the National Advisory Council shall submit the report to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb50ce87e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the co-chairpersons of the RESPONSE Subcommittee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce87f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of each other agency represented on the RESPONSE Subcommittee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce880-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/7/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce881-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/7/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce882-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/7/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce883-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/7/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce884-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim activity","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50ce885-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates and oversight","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After the submission of the report by the National Advisory Council under paragraph (7), the Administrator shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb50ce886-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide annual updates to the congressional committees referred to in paragraph (7)(C) regarding the status of the implementation of the recommendations developed under paragraph (6); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce887-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the implementation of the recommendations described in paragraph (6)(G)(i), as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce888-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of subparagraph (A) shall terminate on the date that is 2 years after the date of the submission of the report required under paragraph (7)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce889-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The RESPONSE Subcommittee shall terminate not later than 90 days after the submission of the report required under paragraph (7)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50ce88a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of chapter 10 of title 5","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50ce88b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s318/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s451/a"},"text":"section 451(a) of this title","children":[],"tail":" and subject to paragraph (2), chapter 10 of title 5, including subsections (a), (b), and (d) of "},{"tag":"ref","attrib":{"hr