{"tag":"section","attrib":{"id":"idb4e451d0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m"},"text":null,"children":[{"tag":"num","attrib":{"value":"124m"},"text":"§ 124m.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified Information Advisory Officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4e451d1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to establish","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall identify and designate within the Department a Classified Information Advisory Officer, as described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e451d2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The responsibilities of the Classified Information Advisory Officer shall be as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e451d3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To develop and disseminate educational materials and to develop and administer training programs to assist State, local, and tribal governments (including State, local, and tribal law enforcement agencies) and private sector entities—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e451d4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in developing plans and policies to respond to requests related to classified information without communicating such information to individuals who lack appropriate security clearances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451d5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regarding the appropriate procedures for challenging classification designations of information received by personnel of such entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e451d6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the means by which such personnel may apply for security clearances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e451d7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To inform the Under Secretary for Intelligence and Analysis on policies and procedures that could facilitate the sharing of classified information with such personnel, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e451d8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2010-10-07"},"text":"October 7, 2010","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e451d9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate the initial Classified Information Advisory Officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e451da-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124m/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Homeland Security of the House of Representatives a written notification of the designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4e451db-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tII/s210E"},"text":"Pub. L. 107–296, title II, § 210E","children":[],"tail":", formerly § 210F, as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/258/s4/a"},"text":"Pub. L. 111–258, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2649"},"text":"124 Stat. 2649","children":[],"tail":"; renumbered § 210E, "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/2/J"},"text":"Pub. L. 115–278, § 2(g)(2)(J)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4178"},"text":"132 Stat. 4178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4e451dc-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4e451dd-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb4e451de-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s210E"},"text":"section 210E of Pub. L. 107–296","children":[],"tail":", title II, as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tX/s1001/a"},"text":"Pub. L. 110–53, title X, § 1001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/372"},"text":"121 Stat. 372","children":[],"tail":", was renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s2214"},"text":"section 2214 of Pub. L. 107–296","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/2/G"},"text":"Pub. L. 115–278, § 2(g)(2)(G)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4178"},"text":"132 Stat. 4178","children":[],"tail":", and transferred to "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s664"},"text":"section 664 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4e451df-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4e451e0-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/258/s2"},"text":"Pub. L. 111–258, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2648"},"text":"124 Stat. 2648","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/258/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Commission on Terrorist Attacks Upon the United States (commonly known as the ‘9/11 Commission’) concluded that security requirements nurture over-classification and excessive compartmentation of information among agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 9/11 Commission and others have observed that the over-classification of information interferes with accurate, actionable, and timely information sharing, increases the cost of information security, and needlessly limits stakeholder and public access to information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Over-classification of information causes considerable confusion regarding what information may be shared with whom, and negatively affects the dissemination of information within the Federal Government and with State, local, and tribal entities, and with the private sector.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Over-classification of information is antithetical to the creation and operation of the information sharing environment established under section 1016 of the Intelligence Reform and Terrorism Prevention Act of 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s485"},"text":"6 U.S.C. 485","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal departments or agencies authorized to make original classification decisions or that perform derivative classification of information are responsible for developing, implementing, and administering policies, procedures, and programs that promote compliance with applicable laws, executive orders, and other authorities pertaining to the proper use of classification markings and the policies of the National Archives and Records Administration.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
