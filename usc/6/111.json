xt":"section 3819 of Title 50","children":[],"tail":", War and National Defense.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 81. [Amended Ex. Ord. No. 10179.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 82. [Amended Ex. Ord. No. 10163.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 83. [Amended Ex. Ord. No. 10113, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s418"},"text":"section 418 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 84. [Amended Ex. Ord. No. 4601.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 85. "},{"tag":"i","attrib":{},"text":"Designation as a Defense Agency of the United States.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"I hereby designate the Department of Homeland Security as a defense agency of the United States for the purposes of chapter 17 of title 35 of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 86. "},{"tag":"i","attrib":{},"text":"Exception from the Provisions of the Government Employees Training Act.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Those elements of the Department of Homeland Security that are supervised by the Under Secretary of Homeland Security for Information Analysis and Infrastructure Protection through the Department’s Assistant Secretary for Information Analysis are, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4102/b/1"},"text":"section 4102(b)(1) of title 5","children":[],"tail":", United States Code, and in the public interest, excepted from the following provisions of the Government Employees Training Act as codified in title 5: sections 4103(a)(1), 4108, 4115, 4117, and 4118, and that part of 4109(a) that provides “under the regulations prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s4118/a/8"},"text":"section 4118(a)(8) of this title","children":[],"tail":" and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 87. "},{"tag":"i","attrib":{},"text":"Functions of Certain Officials in the Coast Guard.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Commandant and the Assistant Commandant for Intelligence of the Coast Guard each shall be considered a “Senior Official of the Intelligence Community” for purposes of Executive Order 12333 of ","children":[{"tag":"date","attrib":{"date":"1981-12-04"},"text":"December 4, 1981","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"50 U.S.C. 3001","children":[],"tail":" note], and all other relevant authorities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 88. "},{"tag":"i","attrib":{},"text":"Savings Provision.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided above or in Executive Order 13284 of ","children":[{"tag":"date","attrib":{"date":"2003-01-23"},"text":"January 23, 2003","children":[],"tail":" (“Amendment of Executive Orders, and Other Actions, in Connection With the Establishment of the Department of Homeland Security”) ["},{"tag":"ref","attrib":{"href":"/us/usc/t6/s121"},"text":"6 U.S.C. 121","children":[],"tail":" note], references in any prior Executive Order relating to an agency or an agency component that is transferred to the Department of Homeland Security (“the Department”), or relating to a function that is transferred to the Secretary of Homeland Security, shall be deemed to refer, as appropriate, to the Department or its officers, employees, agents, organizational units, or functions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 89. Nothing in this order shall be construed to impair or otherwise affect the authority of the Secretary of Defense with respect to the Department of Defense, including the chain of command for the armed forces of the United States under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s162/b"},"text":"section 162(b) of title 10","children":[],"tail":", United States Code, and the authority of the Secretary of Defense with respect to the Department of Defense under section 113(b) of that title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 90. Nothing in this order shall be construed to limit or restrict the authorities of the Central Intelligence Agency and the Director of Central Intelligence pursuant to the National Security Act of 1947 ["},{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343"},"text":"act July 26, 1947, ch. 343","children":[],"tail":"; see Tables for classification] and the CIA Act of 1949 [probably means the Central Intelligence Agency Act of 1949, "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-20/ch227"},"text":"act June 20, 1949, ch. 227","children":[],"tail":"; see Tables for classification]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 91. This order shall become effective on "},{"tag":"date","attrib":{"date":"2003-03-01"},"text":"March 1, 2003","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 92. This order does not create any right or benefit, substantive or procedural, enforceable at law or in equity, against the United States, its departments, agencies, or other entities, its officers or employees, or any other person."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the intelligence community deemed to be a reference to the Director of National Intelligence. Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the Central Intelligence Agency deemed to be a reference to the Director of the Central Intelligence Agency. See section 1081(a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of Title 50","children":[],"tail":", War and National Defense.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb4d3889c-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 13362","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 13362, ","children":[{"tag":"date","attrib":{"date":"2004-11-29"},"text":"Nov. 29, 2004","children":[],"tail":", 69 F.R. 70173, which designated additional officers for the Department of Homeland Security order of succession, was revoked by Ex. Ord. No. 13442, § 2, "},{"tag":"date","attrib":{"date":"2007-08-13"},"text":"Aug. 13, 2007","children":[],"tail":", 72 F.R. 45878."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
