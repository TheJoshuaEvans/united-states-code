{"tag":"section","attrib":{"id":"idb4d13e96-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s111"},"text":null,"children":[{"tag":"num","attrib":{"value":"111"},"text":"§ 111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive department; mission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4d13e97-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established a Department of Homeland Security, as an executive department of the United States within the meaning of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d13e98-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4d13e99-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The primary mission of the Department is to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4d13e9a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s111/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent terrorist attacks within the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d13e9b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s111/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the vulnerability of the United States to terrorism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d13e9c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s111/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the damage, and assist in the recovery, from terrorist attacks that do occur within the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d13e9d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s111/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out all functions of entities transferred to the Department, including by acting as a focal point regarding natural and manmade crises and emergency planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d13e9e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s111/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the functions of the agencies and subdivisions within the Department that are not related directly to securing the homeland are not diminished or neglected except by a specific explicit Act of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d13e9f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s111/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the overall economic security of the United States is not diminished by efforts, activities, and programs aimed at securing the homeland;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d13ea0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s111/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the civil rights and civil liberties of persons are not diminished by efforts, activities, and programs aimed at securing the homeland; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d13ea1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s111/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor connections between illegal drug trafficking and terrorism, coordinate efforts to sever such connections, and otherwise contribute to efforts to interdict illegal drug trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d13ea2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility for investigating and prosecuting terrorism","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as specifically provided by law with respect to entities transferred to the Department under this chapter, primary responsibility for investigating and prosecuting acts of terrorism shall be vested not in the Department, but rather in Federal, State, and local law enforcement agencies with jurisdiction over the acts in question.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4d13ea3-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tI/s101"},"text":"Pub. L. 107–296, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2142"},"text":"116 Stat. 2142","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVIII/s8302"},"text":"Pub. L. 108–458, title VIII, § 8302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3867"},"text":"118 Stat. 3867","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4d13ea4-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4d13ea5-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4d13ea6-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(2), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2135"},"text":"116 Stat. 2135","children":[],"tail":", known as the Homeland Security Act of 2002, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4d13ea7-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(1)(G), (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" added subpar. (G) and redesignated former subpar. (G) as (H)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4d13ea8-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4d13ea9-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Certain OPM Authority to Department of Homeland Security","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tV/s513"},"text":"Pub. L. 109–295, title V, § 513","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1378"},"text":"120 Stat. 1378","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/295/tV/s513"},"text":"“Notwithstanding any other provision of law, the authority of the Office of Personnel Management to conduct personnel security and suitability background investigations, update investigations, and periodic reinvestigations of applicants for, or appointees in, positions in the Office of the Secretary and Executive Management, the Office of the Under Secretary for Management, Analysis and Operations, Immigration and Customs Enforcement, the Directorate for Preparedness, and the Directorate of Science and Technology of the Department of Homeland Security is transferred to the Department of Homeland Security: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That on request of the Department of Homeland Security, the Office of Personnel Management shall cooperate with and assist the Department in any investigation or reinvestigation under this section: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That this section shall cease to be effective at such time as the President has selected a single agency to conduct security clearance investigations pursuant to section 3001(c) of the Intelligence Reform and Terrorism Prevention Act of 2004 ("},{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Public Law 108–458","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s435b"},"text":"50 U.S.C. 435b","children":[],"tail":" [now "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3341"},"text":"50 U.S.C. 3341","children":[],"tail":"]) and the entity selected pursuant to section 3001(b) of such Act has reported to Congress that the agency selected pursuant to such section 3001(c) is capable of conducting all necessary investigations in a timely manner or has authorized the entities within the Department of Homeland Security covered by this section to conduct their own investigations pursuant to section 3001 of such Act.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For transfer of all functions, personnel, assets, components, authorities, grant programs, and liabilities of the Directorate for Preparedness, as constituted on ","children":[{"tag":"date","attrib":{"date":"2006-06-01"},"text":"June 1, 2006","children":[],"tail":", including the functions of the Under Secretary for Preparedness relating thereto, to the Federal Emergency Management Agency, with certain exceptions, see section 315(a)(2), (b) of this title.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/90/tV/s516"},"text":"Pub. L. 109–90, title V, § 516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-10-18"},"text":"Oct. 18, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2084"},"text":"119 Stat. 2084","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/334/tV/s518"},"text":"Pub. L. 108–334, title V, § 518","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1318"},"text":"118 Stat. 1318","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb4d13eaa-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb4d13eab-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 13286. Amendment of Executive Orders, and Other Actions, in Connection With the Transfer of Certain Functions to the Secretary of Homeland Security","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 13286, ","children":[{"tag":"date","attrib":{"date":"2003-02-28"},"text":"Feb. 28, 2003","children":[],"tail":", 68 F.R. 10619, as amended by Ex. Ord. No. 13442, § 1, "},{"tag":"date","attrib":{"date":"2007-08-13"},"text":"Aug. 13, 2007","children":[],"tail":", 72 F.R. 45877; Ex. Ord. No. 13753, § 1, "},{"tag":"date","attrib":{"date":"2016-12-09"},"text":"Dec. 9, 2016","children":[],"tail":", 81 F.R. 90667; Ex. Ord. No. 14135, § 3(b), "},{"tag":"date","attrib":{"date":"2025-01-03"},"text":"Jan. 3, 2025","children":[],"tail":", 90 F.R. 2579, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including the Homeland Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Public Law 107–296","children":[],"tail":") [see Tables for classification] and "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, and in order to reflect the transfer of certain functions to, and other responsibilities vested in, the Secretary of Homeland Security, the transfer of certain agencies and agency components to the Department of Homeland Security, and the delegation of appropriate responsibilities to the Secretary of Homeland Security, it is hereby ordered as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. [Amended Ex. Ord. No. 13276, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t8/s1182"},"text":"section 1182 of Title 8","children":[],"tail":", Aliens and Nationality.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. [Amended Ex. Ord. No. 13274, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s301"},"text":"section 301 of Title 49","children":[],"tail":", Transportation.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 3. [Amended Ex. Ord. No. 13271, formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s509"},"text":"section 509 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure.]"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","