{"tag":"section","attrib":{"id":"idb55451d3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c"},"text":null,"children":[{"tag":"num","attrib":{"value":"677c"},"text":"§ 677c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cyber Response and Recovery Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55451d4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established a Cyber Response and Recovery Fund, which shall be available for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55451d5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s677b/b"},"text":"section 677b(b) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451d6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" response and recovery support for the specific significant incident associated with a declaration to Federal, State, local, and Tribal, entities and public and private entities on a reimbursable or non-reimbursable basis, including through asset response activities and technical assistance, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55451d7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vulnerability assessments and mitigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451d8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical incident mitigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451d9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" malware analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451da-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analytic support;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451db-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" threat detection and hunting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451dc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" network protections;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451dd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as the Director determines appropriate, grants for, or cooperative agreements with, Federal, State, local, and Tribal public and private entities to respond to, and recover from, the specific significant incident associated with a declaration, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55451de-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hardware or software to replace, update, improve, harden, or enhance the functionality of existing hardware, software, or systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451df-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical contract personnel support; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451e0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advance actions taken by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s677b/f/1/B"},"text":"section 677b(f)(1)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55451e1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposits and expenditures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55451e2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts shall be deposited into the Fund from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55451e3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriations to the Fund for activities of the Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451e4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimbursement from Federal agencies for the activities described in paragraphs (1), (2), and (4) of subsection (a), which shall only be from amounts made available in advance in appropriations Acts for such reimbursement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451e5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any expenditure from the Fund for the purposes of this part shall be made from amounts available in the Fund from a deposit described in paragraph (1), and amounts available in the Fund shall be in addition to any other appropriations available to the Cybersecurity and Infrastructure Security Agency for such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55451e6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplement not supplant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund shall be used to supplement, not supplant, other Federal, State, local, or Tribal funding for activities in response to a declaration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55451e7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require an entity that receives amounts from the Fund to submit a report to the Secretary that details the specific use of the amounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55451e8-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2234"},"text":"Pub. L. 107–296, title XXII, § 2234","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tVI/s70602/a"},"text":"Pub. L. 117–58, div. G, title VI, § 70602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1270"},"text":"135 Stat. 1270","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
