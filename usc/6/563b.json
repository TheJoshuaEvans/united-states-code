{"tag":"section","attrib":{"id":"idb5309d87-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b"},"text":null,"children":[{"tag":"num","attrib":{"value":"563b"},"text":"§ 563b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquisition baseline establishment and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5309d88-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Baseline requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5309d89-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the Administration implements any security-related technology acquisition, the appropriate acquisition official of the Department shall establish and document a set of formal baseline requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d8a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The baseline requirements under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5309d8b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include the estimated costs (including lifecycle costs), schedule, and performance milestones for the planned duration of the acquisition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5309d8c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the acquisition risks and a plan for mitigating those risks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5309d8d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the personnel necessary to manage the acquisition process, manage the ongoing program, and support training and other operations as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d8e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing the performance milestones under paragraph (2)(A), the appropriate acquisition official of the Department, to the extent possible and in consultation with the Under Secretary for Science and Technology, shall ensure that achieving those milestones is technologically feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d8f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Test and evaluation plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator, in consultation with the Under Secretary for Science and Technology, shall develop a test and evaluation plan that describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5309d90-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities that are expected to be required to assess acquired technologies against the performance milestones established under paragraph (2)(A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5309d91-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the necessary and cost-effective combination of laboratory testing, field testing, modeling, simulation, and supporting analysis to ensure that such technologies meet the Administration’s mission needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5309d92-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an efficient planning schedule to ensure that test and evaluation activities are completed without undue delay; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5309d93-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if commercial aviation passengers are expected to interact with the security-related technology, methods that could be used to measure passenger acceptance of and familiarization with the security-related technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d94-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification and validation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The appropriate acquisition official of the Department—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5309d95-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subparagraph (B), shall utilize independent reviewers to verify and validate the performance milestones and cost estimates developed under paragraph (2) for a security-related technology that pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s563/d/2"},"text":"section 563(d)(2) of this title","children":[],"tail":" has been identified as a high priority need in the most recent Plan; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5309d96-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ensure that the use of independent reviewers does not unduly delay the schedule of any acquisition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d97-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Streamlining access for interested vendors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish a streamlined process for an interested vendor of a security-related technology to request and receive appropriate access to the baseline requirements and test and evaluation plans that are necessary for the vendor to participate in the acquisitions process for that technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5309d98-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of baseline requirements and deviation; report to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5309d99-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5309d9a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The appropriate acquisition official of the Department shall review and assess each implemented acquisition to determine if the acquisition is meeting the baseline requirements established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330d9b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Test and evaluation assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The review shall include an assessment of whether—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5330d9c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planned testing and evaluation activities have been completed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5330d9d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of that testing and evaluation demonstrate that the performance milestones are technologically feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330d9e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after making a finding described in clause (i), (ii), or (iii) of subparagraph (A), the Administrator shall submit a report to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Homeland Security of the House of Representatives that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5330d9f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the results of any assessment that finds that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5330da0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual or planned costs exceed the baseline costs by more than 10 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5330da1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual or planned schedule for delivery has been delayed by more than 180 days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5330da2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a failure to meet any performance milestone that directly impacts security effectiveness;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330da3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cause for such excessive costs, delay, or failure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330da4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563b/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for corrective action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5330da5-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVI/s1613"},"text":"Pub. L. 107–296, title XVI, § 1613","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/245/s3/a"},"text":"Pub. L. 113–245, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2874"},"text":"128 Stat. 2874","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
