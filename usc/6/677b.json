{"tag":"section","attrib":{"id":"idb55451b8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b"},"text":null,"children":[{"tag":"num","attrib":{"value":"677b"},"text":"§ 677b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55451b9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55451ba-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the National Cyber Director, may make a declaration of a significant incident in accordance with this section for the purpose of enabling the activities described in this part if the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55451bb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a specific significant incident—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55451bc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has occurred; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55451bd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is likely to occur imminently; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451be-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise available resources, other than the Fund, are likely insufficient to respond effectively to, or to mitigate effectively, the specific significant incident described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451bf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on delegation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not delegate the authority provided to the Secretary under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55451c0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asset response activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon a declaration, the Director shall coordinate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55451c1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the asset response activities of each Federal agency in response to the specific significant incident associated with the declaration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451c2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with appropriate entities, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55451c3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public and private entities and State and local governments with respect to the asset response activities of those entities and governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451c4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, local, and Tribal law enforcement agencies with respect to investigations and threat response activities of those law enforcement agencies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451c5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, local, and Tribal emergency management and response agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55451c6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (d), a declaration shall terminate upon the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55451c7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination by the Secretary that the declaration is no longer necessary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451c8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expiration of the 120-day period beginning on the date on which the Secretary makes the declaration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55451c9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, without delegation, may renew a declaration as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55451ca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55451cb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 72 hours after a declaration or a renewal, the Secretary shall publish the declaration or renewal in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451cc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A declaration or renewal published under paragraph (1) may not include the name of any affected individual or private company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55451cd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance actions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55451ce-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55451cf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall assess the resources available to respond to a potential declaration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451d0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may take actions before and while a declaration is in effect to arrange or procure additional resources for asset response activities or technical assistance the Secretary determines necessary, which may include entering into standby contracts with private entities for cybersecurity services or incident responders in the event of a declaration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451d1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenditure of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any expenditure from the Fund for the purpose of paragraph (1)(B) shall be made from amounts available in the Fund, and amounts available in the Fund shall be in addition to any other appropriations available to the Cybersecurity and Infrastructure Security Agency for such purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55451d2-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2233"},"text":"Pub. L. 107–296, title XXII, § 2233","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tVI/s70602/a"},"text":"Pub. L. 117–58, div. G, title VI, § 70602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1268"},"text":"135 Stat. 1268","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
