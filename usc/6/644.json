{"tag":"section","attrib":{"id":"idb53ef4ba-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s644"},"text":null,"children":[{"tag":"num","attrib":{"value":"644"},"text":"§ 644.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance to non-Federal entities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary may provide training curricula to any State, local, or tribal government or private organization to assist the government or organization in establishing a program of training to identify human trafficking, upon request from the government or organization.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb53ef4bb-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/tIX/s904"},"text":"Pub. L. 114–22, title IX, § 904","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/266"},"text":"129 Stat. 266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb53ef4bc-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb53ef4bd-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb53ef4be-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Justice for Victims of Trafficking Act of 2015, and not as part of the Homeland Security Act of 2002 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
