{"tag":"section","attrib":{"id":"idb51ffbc0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s453"},"text":null,"children":[{"tag":"num","attrib":{"value":"453"},"text":"§ 453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of appropriated funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb51ffbc1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s453/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of property","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51ffbc2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s453/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strict compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If specifically authorized to dispose of real property in this chapter or any other Act, the Secretary shall exercise this authority in strict compliance with subchapter IV of chapter 5 of title 40.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51ffbc3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s453/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of proceeds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall deposit the proceeds of any exercise of property disposal authority into the miscellaneous receipts of the Treasury in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302/b"},"text":"section 3302(b) of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51ffbc4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s453/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2601"},"text":"section 2601 of title 10","children":[],"tail":", by section 93 "},{"tag":"ref","attrib":{"idref":"fn002074"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002074"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 14, or by section 321n or 464 of this title, gifts or donations of services or property of or for the Department may not be accepted, used, or disposed of unless specifically permitted in advance in an appropriations Act and only under the conditions and for the purposes specified in such appropriations Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51ffbc5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s453/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Budget request","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the President shall submit to Congress a detailed budget request for the Department for fiscal year 2004, and for each subsequent fiscal year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb51ffbc6-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s873"},"text":"Pub. L. 107–296, title VIII, § 873","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2243"},"text":"116 Stat. 2243","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dL/s103/3"},"text":"Pub. L. 108–7, div. L, § 103(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/529"},"text":"117 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/245/s2/a/2"},"text":"Pub. L. 111–245, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"Sept. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2621"},"text":"124 Stat. 2621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb51ffbc7-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb51ffbc8-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb51ffbc9-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (a)(1), was in the original a reference to this Act, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2135"},"text":"116 Stat. 2135","children":[],"tail":", known as the Homeland Security Act of 2002, which is classi