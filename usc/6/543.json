{"tag":"section","attrib":{"id":"idb5309cea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s543"},"text":null,"children":[{"tag":"num","attrib":{"value":"543"},"text":"§ 543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of congressional committee structures","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that each House of Congress should review its committee structure in light of the reorganization of responsibilities within the executive branch by the establishment of the Department.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5309ceb-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXV/s1503"},"text":"Pub. L. 107–296, title XV, § 1503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2309"},"text":"116 Stat. 2309","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
