{"tag":"section","attrib":{"id":"idb4e90d4a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162"},"text":null,"children":[{"tag":"num","attrib":{"value":"162"},"text":"§ 162.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission of Office; duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4e90d4b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The mission of the Office shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e90d4c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve as the national focal point for work on law enforcement technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d4d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out programs that, through the provision of equipment, training, and technical assistance, improve the safety and effectiveness of law enforcement technology and improve access to such technology by Federal, State, and local law enforcement agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e90d4e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out its mission, the Office shall have the following duties:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e90d4f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide recommendations and advice to the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d50-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish and maintain advisory groups (which shall be exempt from the provisions of chapter 10 of title 5) to assess the law enforcement technology needs of Federal, State, and local law enforcement agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d51-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish and maintain performance standards in accordance with the National Technology Transfer and Advancement Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113"},"text":"Public Law 104–113","children":[],"tail":") for, and test and evaluate law enforcement technologies that may be used by, Federal, State, and local law enforcement agencies."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d52-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish and maintain a program to certify, validate, and mark or otherwise recognize law enforcement technology products that conform to standards established and maintained by the Office in accordance with the National Technology Transfer and Advancement Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113"},"text":"Public Law 104–113","children":[],"tail":"). The program may, at the discretion of the Office, allow for supplier’s declaration of conformity with such standards."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d53-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To work with other entities within the Department of Justice, other Federal agencies, and the executive office of the President to establish a coordinated Federal approach on issues related to law enforcement technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d54-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To carry out research, development, testing, evaluation, and cost-benefit analyses in fields that would improve the safety, effectiveness, and efficiency of law enforcement technologies used by Federal, State, and local law enforcement agencies, including, but not limited to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e90d55-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" weapons capable of preventing use by unauthorized persons, including personalized guns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90d56-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protective apparel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90d57-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bullet-resistant and explosion-resistant glass;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90d58-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring systems and alarm systems capable of providing precise location information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90d59-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wire and wireless interoperable communication technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90d5a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tools and techniques that facilitate investigative and forensic work, including computer forensics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90d5b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment for particular use in counterterrorism, including devices and technologies to disable terrorist devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90d5c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guides to assist State and local law enforcement agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90d5d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/6/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" DNA identification technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90d5e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/6/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tools and techniques that facilitate investigations of computer crime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d5f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To administer a program of research, development, testing, and demonstration to improve the interoperability of voice and data public safety communications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d60-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To serve on the Technical Support Working Group of the Department of Defense, and on other relevant interagency panels, as requested.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d61-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To develop, and disseminate to State and local law enforcement agencies, technical assistance and training materials for law enforcement personnel, including prosecutors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d62-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To operate the regional National Law Enforcement and Corrections Technology Centers and, to the extent necessary, establish additional centers through a competitive process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d63-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To administer a program of acquisition, research, development, and dissemination of advanced investigative analysis and forensic tools to assist State and local law enforcement agencies in combating cybercrime.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d64-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To support research fellowships in support of its mission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d65-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To serve as a clearinghouse for information on law enforcement technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d66-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To represent the United States and State and local law enforcement agencies, as requested, in international activities concerning law enforcement technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d67-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To enter into contracts and cooperative agreements and provide grants, which may require in-kind or cash matches from the recipient, as necessary to carry out its mission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d68-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/b/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To carry out other duties assigned by the Attorney General to accomplish the mission of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e90d69-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competition required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise expressly provided by law, all research and development carried out by or through the Office shall be carried out on a competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e90d6a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information from Federal agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Federal agencies shall, upon request from the Office and in accordance with Federal law, provide the Office with any data, reports, or other information requested, unless compliance with such request is otherwise prohibited by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e90d6b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Decisions concerning publications issued by the Office shall rest solely with the Director of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e90d6c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office may transfer funds to other Federal agencies or provide funding to non-Federal entities through grants, cooperative agreements, or contracts to carry out its duties under this section: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That any such transfer or provision of funding shall be carried out in accordance with "},{"tag":"ref","attrib":{"href":"/us/pl/107/77/s605"},"text":"section 605 of Public Law 107–77","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e90d6d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office shall include with the budget justification materials submitted to Congress in support of the Department of Justice budget for each fiscal year (as submitted with the budget of the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":") a report on the activities of the Office. Each such report shall include the following:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e90d6e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the period of 5 fiscal years beginning with the fiscal year for which the budget is submitted—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e90d6f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director’s assessment of the needs of Federal, State, and local law enforcement agencies for assistance with respect to law enforcement technology and other matters consistent with the mission of the Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90d70-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategic plan for meeting such needs of such law enforcement agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d71-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s162/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the fiscal year preceding the fiscal year for which such budget is submitted, a description of the activities carried out by the Office and an evaluation of the extent to which those activities successfully meet the needs assessed under paragraph (1)(A) in previous reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4e90d72-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tII/s232"},"text":"Pub. L. 107–296, title II, § 232","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2159"},"text":"116 Stat. 2159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dL/s103/1"},"text":"Pub. L. 108–7, div. L, § 103(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/529"},"text":"117 Stat. 529","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/13"},"text":"Pub. L. 117–286, § 4(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4306"},"text":"136 Stat. 4306","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4e90d73-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4e90d74-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4e90d75-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Technology Transfer and Advancement Act of 1995, referred to in subsec. (b)(3), (4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/113"},"text":"Pub. L. 104–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-07"},"text":"Mar. 7, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/775"},"text":"110 Stat. 775","children":[],"tail":", as amended. For complete classification of this Act to the Code, see Short Title of 1996 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3701"},"text":"section 3701 of Title 15","children":[],"tail":", Commerce and Trade, and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/77/s605"},"text":"Section 605 of Public Law 107–77","children":[],"tail":", referred to in subsec. (f), is "},{"tag":"ref","attrib":{"href":"/us/pl/107/77/s605"},"text":"section 605 of Pub. L. 107–77","children":[],"tail":", title VI, "},{"tag":"date","attrib":{"date":"2001-11-28"},"text":"Nov. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/798"},"text":"115 Stat. 798","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4e90d76-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of title 5)” for “the Federal Advisory Committee Act (5 U.S.C. App.))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" inserted before period at end “: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That any such transfer or provision of funding shall be carried out in accordance with "},{"tag":"ref","attrib":{"href":"/us/pl/107/77/s605"},"text":"section 605 of Public Law 107–77","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
