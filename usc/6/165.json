{"tag":"section","attrib":{"id":"idb4e90d87-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s165"},"text":null,"children":[{"tag":"num","attrib":{"value":"165"},"text":"§ 165.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Law Enforcement and Corrections Technology Centers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4e90d88-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s165/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office shall operate and support National Law Enforcement and Corrections Technology Centers (hereinafter in this section referred to as “Centers”) and, to the extent necessary, establish new centers through a merit-based, competitive process.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e90d89-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s165/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose of Centers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purpose of the Centers shall be to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e90d8a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s165/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support research and development of law enforcement technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4eb7d8b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s165/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the transfer and implementation of technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4eb7d8c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s165/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the development and dissemination of guidelines and technological standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4eb7d8d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s165/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technology assistance, information, and support for law enforcement, corrections, and criminal justice purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4eb7d8e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s165/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each year, the Director shall convene a meeting of the Centers in order to foster collaboration and communication between Center participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4eb7d8f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s165/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", the Director shall transmit to the Congress a report assessing the effectiveness of the existing system of Centers and identify the number of Centers necessary to meet the technology needs of Federal, State, and local law enforcement in the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4eb7d90-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tII/s235"},"text":"Pub. L. 107–296, title II, § 235","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2162"},"text":"116 Stat. 2162","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
