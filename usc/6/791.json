{"tag":"section","attrib":{"id":"idb55dee26-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791"},"text":null,"children":[{"tag":"num","attrib":{"value":"791"},"text":"§ 791.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance contracting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55dee27-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55dee28-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", the Administrator shall submit a report under paragraph (2) identifying—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55dee29-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recurring disaster response requirements, including specific goods and services, for which the Agency is capable of contracting for in advance of a natural disaster or act of terrorism or other man-made disaster in a cost effective manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee2a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recurring disaster response requirements, including specific goods and services, for which the Agency can not contract in advance of a natural disaster or act of terrorism or other man-made disaster in a cost effective manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee2b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contracting strategy that maximizes the use of advance contracts to the extent practical and cost-effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee2c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The report under paragraph (1) shall be submitted to the appropriate committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee2d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Entering into contracts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55dee2e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", the Administrator shall enter into 1 or more contracts for each type of goods or services identified under subsection (a)(1)(A), and in accordance with the contracting strategy identified in subsection (a)(1)(C). Any contract for goods or services identified in subsection (a)(1)(A) previously awarded may be maintained in fulfilling this requirement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee2f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considered factors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before entering into any contract under this subsection, the Administrator shall consider ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5150"},"text":"section 5150 of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee30-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prenegotiated Federal contracts for goods and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in coordination with State and local governments and other Federal agencies, shall establish a process to ensure that Federal prenegotiated contracts for goods and services are coordinated with State and local governments, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee31-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prenegotiated State and local contracts for goods and services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall encourage State and local governments to establish prenegotiated contracts with vendors for goods and services in advance of natural disasters and acts of terrorism or other man-made disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee32-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance of contracts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the date described under subsection (b), the Administrator shall have the responsibility to maintain contracts for appropriate levels of goods and services in accordance with subsection (a)(1)(C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee33-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report on contracts not using competitive procedures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the end of each fiscal quarter, beginning with the first fiscal quarter occurring at least 90 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", the Administrator shall submit a report on each disaster assistance contract entered into by the Agency by other than competitive procedures to the appropriate committees of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee34-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updated report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":", the Administrator shall submit to the appropriate committees of Congress an updated report that contains—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55dee35-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required in the initial report under subparagraphs (A) and (B) of subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee36-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an updated strategy described in subsection (a)(1)(C) that clearly defines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55dee37-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the objectives of advance contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee38-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how advance contracts contribute to disaster response operations of the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee39-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how to maximize the award of advance contracts to small business concerns, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of title 15","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee3a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether and how advance contracts should be prioritized in relation to new post-disaster contract awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee3b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional Duties of the Administrator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55dee3c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Head of contracting","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall ensure that the head of contracting activity of the Agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55dee3d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":", updates the Disaster Contracting Desk Guide of the Agency to provide specific guidance—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb55dee3e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/f/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on whether and under what circumstances contracting officers should consider using existing advance contracts entered into in accordance with this section prior to making new post-disaster contract awards, and include this guidance in existing semi-annual training given to contracting officers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55dee3f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/f/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for contracting officers to perform outreach to State and local governments on the potential benefits of establishing their own pre-negotiated advance contracts;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee40-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adheres to hard copy contract file management requirements in effect to ensure that the files relating to advance contracts entered into in accordance with this section are complete and up to date, whether the files will be transferred into the Electronic Contract Filing System of the Agency or remain in hard copy format;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee41-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies contracting officers of the 3-day time frame requirement for entering completed award documentation into the contract writing system of the Agency when executing notice to proceed documentation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee42-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":", revises the reporting methodology of the Agency to ensure that all disaster contracts are included in each quarterly report submitted to the appropriate congressional committees under this section on disaster contract actions;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee43-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies a single centralized resource listing advance contracts entered into under this section and ensures that source is current and up to date and includes all available advance contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee44-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/f/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicates complete and up-to-date information on available advance contracts to State and local governments to inform their advance contracting efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee45-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Master acquisition planning schedule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":", the Administrator shall update and implement guidance for program office and acquisition personnel of the Agency to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55dee46-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify acquisition planning time frames and considerations across the entire acquisition planning process of the Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee47-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s791/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clearly communicate the purpose and use of a master acquisition planning schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55dee48-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s691"},"text":"Pub. L. 109–295, title VI, § 691","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1457"},"text":"120 Stat. 1457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/272/s3/a"},"text":"Pub. L. 116–272, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3349"},"text":"134 Stat. 3349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb55dee49-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb55dee4a-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb55dee4b-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/272"},"text":"Pub. L. 116–272","children":[],"tail":" added subsecs. (e) and (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb55dee4c-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb55dee4d-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/272/s2"},"text":"Pub. L. 116–272, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3349"},"text":"134 Stat. 3349","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/272/s2"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Post-Katrina Emergency Management and Reform Act of 2006 [Post-Katrina Emergency Management Reform Act of 2006] (","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/925"},"text":"Public Law 109–925","children":[],"tail":" ["},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI"},"text":"Pub. L. 109–295, title VI","children":[],"tail":"]; "},{"tag":"ref","attrib":{"href":"/us/stat/120/1394"},"text":"120 Stat. 1394","children":[],"tail":") required the Federal Emergency Management Agency to establish advance contracts, which are established prior to disasters and are typically needed to quickly provide life-sustaining goods and services in the immediate aftermath of a disaster;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the catastrophic hurricanes and wildfires in the United States in 2017 highlighted the importance of these advance contracts in disaster response;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a report issued by the Government Accountability Office entitled ‘2017 Disaster Contracting: Action Needed to Better Ensure More Effective Use and Management of Advance Contracts’, the Government Accountability Office identified a number of challenges with advance contracts and recommended actions to improve management by the Federal Emergency Management Agency of these contracts for future disasters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 691 of the Post-Katrina Emergency Management Reform Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s791"},"text":"6 U.S.C. 791","children":[],"tail":") should be amended to incorporate the recommendations made by the report described in paragraph (3) to ensure more effective use and management of advance contracts.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb55dee4e-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/272/s3/b"},"text":"Pub. L. 116–272, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3351"},"text":"134 Stat. 3351","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/272/s3/b"},"text":"“The Administrator of the Federal Emergency Management Agency shall regularly update the appropriate committees of Congress (as defined in section 602 of the Post-Katrina Emergency Management Reform Act of 2006 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s701"},"text":"6 U.S.C. 701","children":[],"tail":")) on the progress of the Federal Emergency Management Agency in implementing the recommendations of the Government Accountability Office in the report entitled ‘2017 Disaster Contracting: Action Needed to Better Ensure More Effective Use and Management of Advance Contracts’, as required under section 691 of the Post-Katrina Emergency Management Reform Act of 2006 ("},{"tag":"ref","attrib":{"href":"/us/usc/t6/s791"},"text":"6 U.S.C. 791","children":[],"tail":"), as amended by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
