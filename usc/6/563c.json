{"tag":"section","attrib":{"id":"idb5330da6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563c"},"text":null,"children":[{"tag":"num","attrib":{"value":"563c"},"text":"§ 563c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inventory utilization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5330da7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the procurement of additional quantities of equipment to fulfill a mission need, the Administrator, to the extent practicable, shall utilize any existing units in the Administration’s inventory to meet that need.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330da8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tracking of inventory","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5330da9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall establish a process for tracking—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5330daa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563c/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of security-related equipment in the inventory under subsection (a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330dab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563c/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the utilization status of security-related technology in the inventory under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330dac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563c/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of security-related equipment in the inventory under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330dad-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internal controls","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall implement internal controls to ensure up-to-date accurate data on security-related technology owned, deployed, and in use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330dae-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Logistics management","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5330daf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish logistics principles for managing inventory in an effective and efficient manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330db0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on just-in-time logistics","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may not use just-in-time logistics if doing so—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5330db1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would inhibit necessary planning for large-scale delivery of equipment to airports or other facilities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330db2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would unduly diminish surge capacity for response to a terrorist threat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5330db3-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVI/s1614"},"text":"Pub. L. 107–296, title XVI, § 1614","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/245/s3/a"},"text":"Pub. L. 113–245, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2876"},"text":"128 Stat. 2876","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
