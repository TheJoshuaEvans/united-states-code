{"tag":"section","attrib":{"id":"idb52be24d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e"},"text":null,"children":[{"tag":"num","attrib":{"value":"488e"},"text":"§ 488e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions and penalty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb52be24e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52be24f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taking possession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No person shall purchase ammonium nitrate from an ammonium nitrate facility unless such person is registered under subsection (c) or (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s488a"},"text":"section 488a of this title","children":[],"tail":", or is an agent of a person registered under subsection (c) or (d) of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be250-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transferring possession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An owner of an ammonium nitrate facility shall not transfer possession of ammonium nitrate from the ammonium nitrate facility to any ammonium nitrate purchaser who is not registered under subsection (c) or (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s488a"},"text":"section 488a of this title","children":[],"tail":", or to any agent acting on behalf of an ammonium nitrate purchaser when such purchaser is not registered under subsection (c) or (d) of "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s488a"},"text":"section 488a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be251-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other prohibitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be252-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase ammonium nitrate without a registration number required under subsection (c) or (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s488a"},"text":"section 488a of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be253-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" own or operate an ammonium nitrate facility without a registration number required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s488a/c"},"text":"section 488a(c) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be254-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to comply with any requirement or violate any other prohibition under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be255-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A person that violates this part may be assessed a civil penalty by the Secretary of not more than $50,000 per violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be256-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalty considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of a civil penalty under this section, the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52be257-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature and circumstances of the violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be258-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the person who commits the violation, any history of prior violations, the ability to pay the penalty, and any effect the penalty is likely to have on the ability of such person to do business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be259-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matter that the Secretary determines that justice requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be25a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice and opportunity for a hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No civil penalty may be assessed under this part unless the person liable for the penalty has been given notice and an opportunity for a hearing on the violation for which the penalty is to be assessed in the county, parish, or incorporated city of residence of that person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be25b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delay in application of prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraphs (1) and (2) of subsection (a) shall apply on and after the date that is 6 months after the date that the Secretary issues a final rule implementing this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb52be25c-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s899F"},"text":"Pub. L. 107–296, title VIII, § 899F","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dE/tV/s563/a"},"text":"Pub. L. 110–161, div. E, title V, § 563(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2088"},"text":"121 Stat. 2088","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
