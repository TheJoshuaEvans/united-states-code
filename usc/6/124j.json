{"tag":"section","attrib":{"id":"idb4e1e087-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124j"},"text":null,"children":[{"tag":"num","attrib":{"value":"124j"},"text":"§ 124j.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rural Policing Institute","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4e1e088-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124j/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a Rural Policing Institute, which shall be administered by the Federal Law Enforcement Training Center, to target training to law enforcement agencies and other emergency response providers located in rural areas. The Secretary, through the Rural Policing Institute, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e1e089-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124j/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the needs of law enforcement agencies and other emergency response providers in rural areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e1e08a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124j/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop expert training programs designed to address the needs of law enforcement agencies and other emergency response providers in rural areas as identified in the evaluation conducted under paragraph (1), including training programs about intelligence-led policing and protections for privacy, civil rights, and civil liberties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e1e08b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124j/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the training programs developed under paragraph (2) to law enforcement agencies and other emergency response providers in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e1e08c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124j/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach efforts to ensure that local and tribal governments in rural areas are aware of the training programs developed under paragraph (2) so they can avail themselves of such programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e1e08d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124j/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Curricula","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training at the Rural Policing Institute established under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e1e08e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124j/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be configured in a manner so as not to duplicate or displace any law enforcement or emergency response program of the Federal Law Enforcement Training Center or a local or tribal government entity in existence on ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e1e08f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124j/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, be delivered in a cost-effective manner at facilities of the Department, on closed military installations with adequate training facilities, or at facilities operated by the participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e1e090-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124j/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “rural” means an area that is not located in a metropolitan statistical area, as defined by the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e1e091-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124j/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to carry out this section (including for contracts, staff, and equipment)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e1e092-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124j/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $10,000,000 for fiscal year 2008; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e1e093-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124j/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for each of fiscal years 2009 through 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4e1e094-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tII/s210C"},"text":"Pub. L. 107–296, title II, § 210C","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tV/s513/a"},"text":"Pub. L. 110–53, title V, § 513(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/327"},"text":"121 Stat. 327","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4e1e095-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4e1e096-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4e1e097-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rural Area","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dD/tV/s546"},"text":"Pub. L. 112–74, div. D, title V, § 546","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/977"},"text":"125 Stat. 977","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/74/dD/tV/s546"},"text":"“For fiscal year 2012 and thereafter, for purposes of section 210C of the Homeland Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s124j"},"text":"6 U.S.C. 124j","children":[],"tail":"), a rural area shall also include any area that is located in a metropolitan statistical area and a county, borough, parish, or area under the jurisdiction of an Indian tribe with a population of not more than 50,000.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
