{"tag":"section","attrib":{"id":"idb51d8ad2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s413"},"text":null,"children":[{"tag":"num","attrib":{"value":"413"},"text":"§ 413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of counternarcotics enforcement activities in certain employee performance appraisals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb51d8ad3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each subdivision of the Department that is a National Drug Control Program Agency shall include as one of the criteria in its performance appraisal system, for each employee directly or indirectly involved in the enforcement of Federal, State, or local narcotics laws, the performance of that employee with respect to the enforcement of Federal, State, or local narcotics laws, relying to the greatest extent practicable on objective performance measures, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51d8ad4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s413/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contribution of that employee to seizures of narcotics and arrests of violators of Federal, State, or local narcotics laws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51d8ad5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s413/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which that employee cooperated with or contributed to the efforts of other employees, either within the Department or other Federal, State, or local agencies, in counternarcotics enforcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51d8ad6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51d8ad7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s413/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “National Drug Control Program Agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51d8ad8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s413/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a National Drug Control Program Agency ","children":[{"tag":"ref","attrib":{"idref":"fn002065"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002065"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “agency”."}],"tail":", as defined in section 1701(7) "},{"tag":"ref","attrib":{"idref":"fn002066"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002066"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 21 (as last in effect); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8ad9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s413/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any subdivision of the Department that has a significant counternarcotics responsibility, as determined by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb51d8ada-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s413/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the counternarcotics officer, appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s458"},"text":"section 458 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8adb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s413/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, the counternarcotics officer’s successor in function (as determined by the Secretary); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51d8adc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s413/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “performance appraisal system” means a system under which periodic appraisals of job performance of employees are made, whether under chapter 43 of title 5, or otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb51d8add-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s843"},"text":"Pub. L. 107–296, title VIII, § 843","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVII/s7408/a"},"text":"Pub. L. 108–458, title VII, § 7408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3854"},"text":"118 Stat. 3854","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb51d8ade-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb51d8adf-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb51d8ae0-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s1701/7"},"text":"Section 1701(7) of title 21","children":[],"tail":", referred to in subsec. (b)(1)(A), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s1701/11"},"text":"section 1701(11) of title 21","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII/s8216/4"},"text":"Pub. L. 115–271, title VIII, § 8216(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4117"},"text":"132 Stat. 4117","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
