{"tag":"section","attrib":{"id":"idb4fc204f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224"},"text":null,"children":[{"tag":"num","attrib":{"value":"224"},"text":"§ 224.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4fc2050-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unidentified remains","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc2051-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":", and annually thereafter, the Commissioner of U.S. Customs and Border Protection shall submit a report to the appropriate committees of Congress regarding all unidentified remains discovered, during the reporting period, on or near the border between the United States and Mexico, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fc2052-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each deceased person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4fc2053-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cause and manner of death, if known;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4fc2054-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sex, age (at time of death), and country of origin (if such information is determinable); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4fc2055-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of each unidentified remain;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fc2056-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of deceased people whose unidentified remains were discovered by U.S. Customs and Border Protection during the reporting period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fc2057-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent such information is available to U.S. Customs and Border Protection, the total number of deceased people whose unidentified remains were discovered by Federal, State, local or Tribal law enforcement officers, military personnel, or medical examiners offices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fc2058-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the efforts of U.S. Customs and Border Protection to engage with nongovernmental organizations, institutions of higher education, medical examiners and coroners, and law enforcement agencies—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4fc2059-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify and map the locations at which migrant deaths occur; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4fc205a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to count the number of deaths that occur at such locations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fc205b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of U.S. Customs and Border Protection’s Missing Migrant Program, including how the program helps mitigate migrant deaths while maintaining border security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc205c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after each report required under paragraph (1) is submitted, the Commissioner of U.S. Customs and Border Protection shall publish on the website of the agency the information described in subparagraphs (A), (B), and (C) of paragraph (1) during each reporting period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc205d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rescue beacons","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-12-31"},"text":"December 31, 2020","children":[],"tail":", and annually thereafter, the Commissioner of U.S. Customs and Border Protection shall submit a report to the appropriate committees of Congress regarding the use of rescue beacons along the border between the United States and Mexico, including, for the reporting period—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc205e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of rescue beacons in each border patrol sector;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc205f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific location of each rescue beacon;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc2060-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency with which each rescue beacon was activated by a person in distress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc2061-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the nature of the distress that resulted in each rescue beacon activation (if such information is determinable); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc2062-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment, in consultation with local stakeholders, including elected officials, nongovernmental organizations, and landowners, of necessary additional rescue beacons and recommendations for locations for deployment to reduce migrant deaths.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc2063-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after the report required under subsection (a) is submitted to the appropriate committees of Congress, the Comptroller General of the United States shall submit a report to the same committees that describes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc2064-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how U.S. Customs and Border Protection collects and records border-crossing death data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc2065-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the differences (if any) in U.S. Customs and Border Protection border-crossing death data collection methodology across its sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc2066-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how U.S. Customs and Border Protection’s data and statistical analysis on trends in the numbers, locations, causes, and characteristics of border-crossing deaths compare to other sources of data on these deaths, including border county medical examiners and coroners and the Centers for Disease Control and Prevention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc2067-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how U.S. Customs and Border Protection measures the effectiveness of its programs to mitigate migrant deaths; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc2068-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the extent to which U.S. Customs and Border Protection engages Federal, State, local, and Tribal governments, foreign diplomatic and consular posts, and nongovernmental organizations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fc2069-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accurately identify deceased individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fc206a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to resolve cases involving unidentified remains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fc206b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to resolve cases involving unidentified persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fc206c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s224/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to share information on missing persons and unidentified remains, specifically with the National Missing and Unidentified Persons System (NamUs).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4fc206d-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/277/s5"},"text":"Pub. L. 116–277, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3370"},"text":"134 Stat. 3370","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4fc206e-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4fc206f-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4fc2070-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of Missing Persons and Unidentified Remains Act of 2019, and not as part of the Homeland Security Act of 2002 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
