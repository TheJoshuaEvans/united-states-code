{"tag":"section","attrib":{"id":"idb51d8ae1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414"},"text":null,"children":[{"tag":"num","attrib":{"value":"414"},"text":"§ 414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeland Security Rotation Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb51d8ae2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002067"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002067"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. There is no subsec. (b)."}],"tail":" Establishment"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51d8ae3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", the Secretary shall establish the Homeland Security Rotation Program (in this section referred to as the “Rotation Program”) for employees of the Department. The Rotation Program shall use applicable best practices, including those from the Chief Human Capital Officers Council."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51d8ae4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Goals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Rotation Program established by the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51d8ae5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be established in accordance with the Human Capital Strategic Plan of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8ae6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide middle and senior level employees in the Department the opportunity to broaden their knowledge through exposure to other components of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8ae7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand the knowledge base of the Department by providing for rotational assignments of employees to other components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8ae8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build professional relationships and contacts among the employees in the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8ae9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" invigorate the workforce with exciting and professionally rewarding opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8aea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate Department human capital strategic plans and activities, and address critical human capital deficiencies, recruitment and retention efforts, and succession planning within the Federal workforce of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8aeb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complement and incorporate (but not replace) rotational programs within the Department in effect on ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51d8aec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51d8aed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Human Capital Officer shall administer the Rotation Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8aee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Human Capital Officer shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb51d8aef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide oversight of the establishment and implementation of the Rotation Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8af0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a framework that supports the goals of the Rotation Program and promotes cross-disciplinary rotational opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8af1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish eligibility for employees to participate in the Rotation Program and select participants from employees who apply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8af2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish incentives for employees to participate in the Rotation Program, including promotions and employment preferences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8af3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the Rotation Program provides professional education and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8af4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the Rotation Program develops qualified employees and future leaders with broad-based experience throughout the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8af5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for greater interaction among employees in components of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8af6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/3/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with rotational programs within the Department in effect on ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51d8af7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowances, privileges, and benefits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"All allowances, privileges, rights, seniority, and other benefits of employees participating in the Rotation Program shall be preserved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51d8af8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s414/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date of the establishment of the Rotation Program, the Secretary shall submit a report on the status of the Rotation Program, including a description of the Rotation Program, the number of employees participating, and how the Rotation Program is used in succession planning and leadership development to the appropriate committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb51d8af9-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s844"},"text":"Pub. L. 107–296, title VIII, § 844","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s622/a"},"text":"Pub. L. 109–295, title VI, § 622(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1416"},"text":"120 Stat. 1416","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
