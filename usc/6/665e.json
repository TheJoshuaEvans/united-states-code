{"tag":"section","attrib":{"id":"idb54d2650-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e"},"text":null,"children":[{"tag":"num","attrib":{"value":"665e"},"text":"§ 665e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb54d2651-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the Agency a Cybersecurity Advisory Committee (referred to in this section as the “Advisory Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d2652-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d2653-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall advise, consult with, report to, and make recommendations to the Director, as appropriate, on the development, refinement, and implementation of policies, programs, planning, and training pertaining to the cybersecurity mission of the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d2654-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d2655-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall develop, at the request of the Director, recommendations for improvements to advance the cybersecurity mission of the Agency and strengthen the cybersecurity of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2656-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recommendations of subcommittees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Recommendations agreed upon by subcommittees established under subsection (d) for any year shall be approved by the Advisory Committee before the Advisory Committee submits to the Director the annual report under paragraph (4) for that year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d2657-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall periodically submit to the Director—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d2658-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports on matters identified by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2659-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports on other matters identified by a majority of the members of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d265a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d265b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall submit to the Director an annual report providing information on the activities, findings, and recommendations of the Advisory Committee, including its subcommittees, for the preceding year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d265c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date on which the Director receives an annual report for a year under subparagraph (A), the Director shall publish a public version of the report describing the activities of the Advisory Committee and such related matters as would be informative to the public during that year, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d265d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feedback","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after receiving any recommendation submitted by the Advisory Committee under paragraph (2), (3), or (4), the Director shall respond in writing to the Advisory Committee with feedback on the recommendation. Such a response shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d265e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any recommendation with which the Director concurs, an action plan to implement the recommendation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d265f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to any recommendation with which the Director does not concur, a justification for why the Director does not plan to implement the recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d2660-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not less frequently than once per year after ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":", the Director shall provide to the Committee on Homeland Security and Governmental Affairs and the Committee on Appropriations of the Senate and the Committee on Homeland Security, the Committee on Energy and Commerce, and the Committee on Appropriations of the House of Representatives a briefing on feedback from the Advisory Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d2661-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governance rules","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall establish rules for the structure and governance of the Advisory Committee and all subcommittees established under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d2662-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d2663-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d2664-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date of enactment of the Cybersecurity Advisory Committee Authorization Act of 2020,","children":[{"tag":"ref","attrib":{"idref":"fn002111"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002111"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the Director shall appoint the members of the Advisory Committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2665-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The membership of the Advisory Committee shall consist of not more than 35 individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2666-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb54d2667-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The membership of the Advisory Committee shall satisfy the following criteria:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb54d2668-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consist of subject matter experts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb54d2669-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Be geographically balanced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb54d266a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Include representatives of State, local, and Tribal governments and of a broad range of industries, which may include the following:","children":[],"tail":null},{"tag":"item","attrib":{"id":"idb54d266b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb54d266c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb54d266d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/III/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Financial services and insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb54d266e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/III/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Healthcare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb54d266f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/III/ee"},"text":null,"children":[{"tag":"num","attrib":{"value":"ee"},"text":"(ee)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Manufacturing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb54d2670-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/III/ff"},"text":null,"children":[{"tag":"num","attrib":{"value":"ff"},"text":"(ff)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Media and entertainment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb54d2671-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/III/gg"},"text":null,"children":[{"tag":"num","attrib":{"value":"gg"},"text":"(gg)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chemicals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb54d2672-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/III/hh"},"text":null,"children":[{"tag":"num","attrib":{"value":"hh"},"text":"(hh)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Retail.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb54d2673-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/III/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb54d2674-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/III/jj"},"text":null,"children":[{"tag":"num","attrib":{"value":"jj"},"text":"(jj)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb54d2675-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/III/kk"},"text":null,"children":[{"tag":"num","attrib":{"value":"kk"},"text":"(kk)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information Technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb54d2676-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/III/ll"},"text":null,"children":[{"tag":"num","attrib":{"value":"ll"},"text":"(ll)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb54d2677-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/i/III/mm"},"text":null,"children":[{"tag":"num","attrib":{"value":"mm"},"text":"(mm)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other relevant fields identified by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d2678-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not fewer than one member nor more than three members may represent any one category under clause (i)(III).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb54d2679-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of membership list","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall publish its membership list on a publicly available website not less than once per fiscal year and shall update the membership list as changes occur.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d267a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d267b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of each member of the Advisory Committee shall be two years, except that a member may continue to serve until a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d267c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may review the participation of a member of the Advisory Committee and remove such member any time at the discretion of the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d267d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Advisory Committee may be reappointed for an unlimited number of terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d267e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Advisory Committee may not receive pay or benefits from the United States Government by reason of their service on the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d267f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d2680-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall require the Advisory Committee to meet not less frequently than semiannually, and may convene additional meetings as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2681-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least one of the meetings referred to in subparagraph (A) shall be open to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2682-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attendance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall maintain a record of the persons present at each meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d2683-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Member access to classified information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d2684-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date on which a member is first appointed to the Advisory Committee and before the member is granted access to any classified information, the Director shall determine, for the purposes of the Advisory Committee, if the member should be restricted from reviewing, discussing, or possessing classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2685-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Access to classified materials shall be managed in accordance with Executive Order No. 13526 of ","children":[{"tag":"date","attrib":{"date":"2009-12-29"},"text":"December 29, 2009","children":[],"tail":" (75 Fed. Reg. 707), or any subsequent corresponding Executive Order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2686-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A member of the Advisory Committee shall protect all classified information in accordance with the applicable requirements for the particular level of classification of such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2687-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph shall be construed to affect the security clearance of a member of the Advisory Committee or the authority of a Federal agency to provide a member of the Advisory Committee access to classified information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d2688-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall select, from among the members of the Advisory Committee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d2689-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member to serve as chairperson of the Advisory Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d268a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member to serve as chairperson of each subcommittee of the Advisory Committee established under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54d268b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subcommittees","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54d268c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall establish subcommittees within the Advisory Committee to address cybersecurity issues, which may include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54d268d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information exchange.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d268e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Critical infrastructure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d268f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Risk management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54d2690-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public and private partnerships.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d2691-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings and reporting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each subcommittee shall meet not less frequently than semiannually, and submit to the Advisory Committee for inclusion in the annual report required under subsection (b)(4) information, including activities, findings, and recommendations, regarding subject matter considered by the subcommittee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54d2692-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s665e/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject matter experts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chair of the Advisory Committee shall appoint members to subcommittees and shall ensure that each member appointed to a subcommittee has subject matter expertise relevant to the subject matter of the subcommittee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb54d2693-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2219"},"text":"Pub. L. 107–296, title XXII, § 2219","children":[],"tail":", formerly § 2216, as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXVII/s1718/a"},"text":"Pub. L. 116–283, div. A, title XVII, § 1718(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4102"},"text":"134 Stat. 4102","children":[],"tail":"; renumbered § 2219 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXV/s1547/b/1/A/vi"},"text":"Pub. L. 117–81, div. A, title XV, § 1547(b)(1)(A)(vi)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2061"},"text":"135 Stat. 2061","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb54d2694-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb54d2695-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb54d2696-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Cybersecurity Advisory Committee Authorization Act of 2020, referred to in subsec. (c)(1)(A), probably means the date of enactment of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":". No act named the Cybersecurity Advisory Committee Authorization Act of 2020 has been enacted. However, a bill, S. 4024, entitled “Cybersecurity Advisory Committee Authorization Act of 2020” was introduced to Senate on "},{"tag":"date","attrib":{"date":"2020-06-22"},"text":"June 22, 2020","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Order No. 13526, referred to in subsec. (c)(5)(B), is Ex. Ord. No. 13526, ","children":[{"tag":"date","attrib":{"date":"2009-12-29"},"text":"Dec. 29, 2009","children":[],"tail":", 75 F.R. 707, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb54d2697-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" reenacted section catchline."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
