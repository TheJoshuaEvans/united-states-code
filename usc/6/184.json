{"tag":"section","attrib":{"id":"idb4eb7dba-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s184"},"text":null,"children":[{"tag":"num","attrib":{"value":"184"},"text":"§ 184.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of certain public health-related activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4eb7dbb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s184/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to civilian human health-related research and development activities relating to countermeasures for chemical, biological, radiological, and nuclear and other emerging terrorist threats carried out by the Department of Health and Human Services (including the Public Health Service), the Secretary of Health and Human Services shall set priorities, goals, objectives, and policies and develop a coordinated strategy for such activities in collaboration with the Secretary of Homeland Security to ensure consistency with the national policy and strategic plan developed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s182/2"},"text":"section 182(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4eb7dbc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s184/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation of progress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out subsection (a), the Secretary of Health and Human Services shall collaborate with the Secretary in developing specific benchmarks and outcome measurements for evaluating progress toward achieving the priorities and goals described in such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4eb7dbd-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIII/s304"},"text":"Pub. L. 107–296, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2165"},"text":"116 Stat. 2165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4eb7dbe-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4eb7dbf-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4eb7dc0-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s304"},"text":"section 304 of Pub. L. 107–296","children":[],"tail":". Subsec. (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s304"},"text":"section 304 of Pub. L. 107–296","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s233"},"text":"section 233 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
