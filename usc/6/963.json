{"tag":"section","attrib":{"id":"idb562a91e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s963"},"text":null,"children":[{"tag":"num","attrib":{"value":"963"},"text":"§ 963.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum requirements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An applicant seeking to participate in C–TPAT shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb562a91f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s963/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate a history of moving cargo in the international supply chain;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a920-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s963/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct an assessment of its supply chain based upon security criteria established by the Secretary, acting through the Commissioner, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb562a921-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s963/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business partner requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562a922-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s963/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" container security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562a923-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s963/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical security and access controls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562a924-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s963/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" personnel security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562a925-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s963/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedural security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562a926-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s963/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security training and threat awareness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562a927-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s963/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information technology security;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a928-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s963/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement and maintain security measures and supply chain security practices meeting security criteria established by the Commissioner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a929-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s963/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet all other requirements established by the Commissioner, in consultation with the Commercial Operations Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb562a92a-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tII/s213"},"text":"Pub. L. 109–347, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1909"},"text":"120 Stat. 1909","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
