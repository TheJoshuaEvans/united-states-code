{"tag":"section","attrib":{"id":"idb53ef4bf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645"},"text":null,"children":[{"tag":"num","attrib":{"value":"645"},"text":"§ 645.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Victim protection training for the Department of Homeland Security","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb53ef4c0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Directive to DHS law enforcement officials and task forces","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53ef4c1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"December 21, 2018","children":[],"tail":", the Secretary shall issue a directive to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53ef4c2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all Federal law enforcement officers and relevant personnel employed by the Department who may be involved in the investigation of human trafficking offenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53ef4c3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of all task forces led by the Department that participate in the investigation of human trafficking offenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53ef4c4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required instructions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The directive required to be issued under paragraph (1) shall include instructions on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53ef4c5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the investigation of individuals who patronize or solicit human trafficking victims as being engaged in severe trafficking in persons and how such individuals should be investigated for their roles in severe trafficking in persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53ef4c6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how victims of sex or labor trafficking often engage in criminal acts as a direct result of severe trafficking in persons and such individuals are victims of a crime and affirmative measures should be taken to avoid arresting, charging, or prosecuting such individuals for any offense that is the direct result of their victimization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53ef4c7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Victim screening protocol","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53ef4c8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"December 21, 2018","children":[],"tail":", the Secretary shall issue a screening protocol for use during all anti-trafficking law enforcement operations in which the Department is involved."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53ef4c9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The protocol required to be issued under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53ef4ca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the individual screening of all adults and children who are suspected of engaging in commercial sex acts, child labor that is a violation of law, or work in violation of labor standards to determine whether each individual screened is a victim of human trafficking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53ef4cb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require affirmative measures to avoid arresting, charging, or prosecuting human trafficking victims for any offense that is the direct result of their victimization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53ef4cc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be developed in consultation with relevant interagency partners and nongovernmental organizations that specialize in the prevention of human trafficking or in the identification and support of victims of human trafficking and survivors of human trafficking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53ef4cd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53ef4ce-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures and practices to ensure that the screening process minimizes trauma or revictimization of the person being screened; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53ef4cf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidelines on assisting victims of human trafficking in identifying and receiving restorative services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53ef4d0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory training","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training described in sections 642 and 644 of this title shall include training necessary to implement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53ef4d1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the directive required under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53ef4d2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s645/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protocol required under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53ef4d3-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/22/tIX/s906"},"text":"Pub. L. 114–22, title IX, § 906","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/392/s5/a"},"text":"Pub. L. 115–392, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5252"},"text":"132 Stat. 5252","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb53ef4d4-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb53ef4d5-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb53ef4d6-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Justice for Victims of Trafficking Act of 2015, and not as part of the Homeland Security Act of 2002 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
