{"tag":"section","attrib":{"id":"idb57a777b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523"},"text":null,"children":[{"tag":"num","attrib":{"value":"1523"},"text":"§ 1523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal cybersecurity requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb57a777c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of Federal cybersecurity standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3553"},"text":"section 3553 of title 44","children":[],"tail":", the Secretary, in consultation with the Director, shall exercise the authority to issue binding operational directives to assist the Director in ensuring timely agency adoption of and compliance with policies and standards promulgated under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s11331"},"text":"section 11331 of title 40","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002172"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002172"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" for securing agency information systems."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57a777d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity requirements at agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57a777e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with policies, standards, guidelines, and directives on information security under subchapter II of chapter 35 of title 44 and the standards and guidelines promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11331"},"text":"section 11331 of title 40","children":[],"tail":" and except as provided in paragraph (2), not later than 1 year after "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", the head of each agency shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57a777f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify sensitive and mission critical data stored by the agency consistent with the inventory required under the first subsection (c) (relating to the inventory of major information systems) and the second subsection (c) (relating to the inventory of information systems) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3505"},"text":"section 3505 of title 44","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57a7780-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess access controls to the data described in subparagraph (A), the need for readily accessible storage of the data, and individuals’ need to access the data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57a7781-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encrypt or otherwise render indecipherable to unauthorized users the data described in subparagraph (A) that is stored on or transiting agency information systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57a7782-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement a single sign-on trusted identity platform for individuals accessing each public website of the agency that requires user authentication, as developed by the Administrator of General Services in collaboration with the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57a7783-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" implement identity management consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s7464"},"text":"section 7464 of title 15","children":[],"tail":", including multi-factor authentication, for—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb57a7784-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remote access to an agency information system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a7785-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each user account with elevated privileges on an agency information system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a7786-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements under paragraph (1) shall not apply to an agency information system for which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57a7787-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the head of the agency has personally certified to the Director with particularity that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb57a7788-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operational requirements articulated in the certification and related to the agency information system would make it excessively burdensome to implement the cybersecurity requirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a7789-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cybersecurity requirement is not necessary to secure the agency information system or agency information stored on or transiting it; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a778a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency has taken all necessary steps to secure the agency information system and agency information stored on or transiting it; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57a778b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the agency or the designee of the head of the agency has submitted the certification described in subparagraph (A) to the appropriate congressional committees and the agency’s authorizing committees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a778c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed to alter the authority of the Secretary, the Director, or the Director of the National Institute of Standards and Technology in implementing subchapter II of chapter 35 of title 44. Nothing in this section shall be construed to affect the National Institute of Standards and Technology standards process or the requirement under section 3553(a)(4) of such title or to discourage continued improvements and advancements in the technology, standards, policies, and guidelines used to promote Federal information security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57a778d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1523/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements under this section shall not apply to the Department of Defense, a national security system, or an element of the intelligence community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57a778e-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dN/tII/s225"},"text":"Pub. L. 114–113, div. N, title II, § 225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2967"},"text":"129 Stat. 2967","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57a778f-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57a7790-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb57a7791-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The text of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11331"},"text":"section 11331 of title 40","children":[],"tail":", referred to in subsec. (a), was generally amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/167/dB/tII/s10246/f"},"text":"Pub. L. 117–167, div. B, title II, § 10246(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-08-09"},"text":"Aug. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1492"},"text":"136 Stat. 1492","children":[],"tail":", so as to provide for the prescription by the Secretary of Commerce of standards and guidelines pertaining to Federal information systems."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
