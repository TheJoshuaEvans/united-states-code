{"tag":"section","attrib":{"id":"idb56e90fb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167"},"text":null,"children":[{"tag":"num","attrib":{"value":"1167"},"text":"§ 1167.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroad security training program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56e90fc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", the Secretary shall develop and issue regulations for a training program to prepare railroad frontline employees for potential security threats and conditions. The regulations shall take into consideration any current security training requirements or best practices."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e90fd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop the regulations under subsection (a) in consultation with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e90fe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate law enforcement, fire service, emergency response, security, and terrorism experts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e90ff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" railroad carriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9100-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" railroad shippers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9101-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit employee labor organizations representing railroad employees or emergency response personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e9102-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations developed under subsection (a) shall require security training programs described in subsection (a) to include, at a minimum, elements to address the following, as applicable:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e9103-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Determination of the seriousness of any occurrence or threat.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9104-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Crew and passenger communication and coordination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9105-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriate responses to defend or protect oneself.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9106-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of personal and other protective equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9107-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evacuation procedures for passengers and railroad employees, including individuals with disabilities and the elderly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9108-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Psychology, behavior, and methods of terrorists, including observation and analysis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9109-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training related to psychological responses to terrorist incidents, including the ability to cope with hijacker behavior and passenger responses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e910a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Live situational training exercises regarding various threat conditions, including tunnel evacuation procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e910b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recognition and reporting of dangerous substances, suspicious packages, and situations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e910c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Understanding security incident procedures, including procedures for communicating with governmental and nongovernmental emergency response providers and for on-scene interaction with such emergency response providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e910d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operation and maintenance of security equipment and systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e910e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other security training activities that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e910f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e9110-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development and submission to Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the Secretary issues regulations under subsection (a), each railroad carrier shall develop a security training program in accordance with this section and submit the program to the Secretary for approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9111-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval or disapproval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after receiving a security training program proposal under this subsection, the Secretary shall approve the program or require the railroad carrier that developed the program to make any revisions to the program that the Secretary considers necessary for the program to meet the requirements of this section. A railroad carrier shall respond to the Secretary’s comments within 30 days after receiving them.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9112-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the Secretary approves a security training program in accordance with this subsection, the railroad carrier that developed the program shall complete the training of all railroad frontline employees who were hired by a carrier more than 30 days preceding such date. For such employees employed less than 30 days by a carrier preceding such date, training shall be completed within the first 60 days of employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9113-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates of regulations and program revisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall periodically review and update as appropriate the training regulations issued under subsection (a) to reflect new or changing security threats. Each railroad carrier shall revise its training program accordingly and provide additional training as necessary to its frontline employees within a reasonable time after the regulations are updated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e9114-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Training Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the training program developed under subsection (a) is a component of the National Training Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s748"},"text":"section 748 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e9115-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after the date of regulation issuance, the Secretary shall review implementation of the training program of a representative sample of railroad carriers and railroad frontline employees, and report to the appropriate congressional committees on the number of reviews conducted and the results of such reviews. The Secretary may submit the report in both classified and redacted formats as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e9116-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1167/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall issue guidance and best practices for a railroad shipper employee security program containing the elements listed under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56e9117-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXV/s1517"},"text":"Pub. L. 110–53, title XV, § 1517","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/439"},"text":"121 Stat. 439","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
