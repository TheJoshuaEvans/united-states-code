{"tag":"section","attrib":{"id":"idb57372ca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1401"},"text":null,"children":[{"tag":"num","attrib":{"value":"1401"},"text":"§ 1401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57372cb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Commissioner” means the Commissioner of U.S. Customs and Border Protection of the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57372cc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maquiladora","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “maquiladora” means an entity located in Mexico that assembles and produces goods from imported parts for export to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57372cd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Northern border","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “northern border” means the international border between the United States and Canada.","children":[],"tail":"\n"}],