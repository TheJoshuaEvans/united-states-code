{"tag":"section","attrib":{"id":"idb51b191e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s392"},"text":null,"children":[{"tag":"num","attrib":{"value":"392"},"text":"§ 392.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal services","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51b191f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s392/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may procure the temporary or intermittent services of experts or consultants (or organizations thereof) in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b1920-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s392/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, whenever necessary due to an urgent homeland security need, procure temporary (not to exceed 1 year) or intermittent personal services, including the services of experts or consultants (or organizations thereof), without regard to the pay limitations of such section 3109.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb51b1921-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s832"},"text":"Pub. L. 107–296, title VIII, § 832","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2225"},"text":"116 Stat. 2225","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
