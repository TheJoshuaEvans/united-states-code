{"tag":"section","attrib":{"id":"idb569d61f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139"},"text":null,"children":[{"tag":"num","attrib":{"value":"1139"},"text":"§ 1139.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information sharing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb569d620-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the Department of Transportation receives appropriate and timely notification of all credible terrorist threats against public transportation assets in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d621-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information Sharing and Analysis Center","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb569d622-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide for the reasonable costs of the Information Sharing and Analysis Center for Public Transportation (referred to in this subsection as the “ISAC”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d623-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb569d624-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require public transportation agencies that the Secretary determines to be at high risk of terrorist attack to participate in the ISAC;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d625-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall encourage all other public transportation agencies to participate in the ISAC;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d626-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall encourage the participation of nonprofit employee labor organizations representing public transportation employees, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d627-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not charge a fee for participating in the ISAC.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d628-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Comptroller General shall report, not less than 3 years after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", to the appropriate congressional committees, as to the value and efficacy of the ISAC along with any other public transportation information-sharing programs ongoing at the Department. The report shall include an analysis of the user satisfaction of public transportation agencies on the state of information-sharing and the value that each system provides the user, the costs and benefits of all centers and programs, the coordination among centers and programs, how each center or program contributes to implementing the information sharing plan under section 1203,"},{"tag":"ref","attrib":{"idref":"fn002149"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002149"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and analysis of the extent to which the ISAC is duplicative with the Department’s information-sharing program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d629-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb569d62a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb569d62b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $600,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d62c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $600,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d62d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $600,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d62e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as may be necessary for 2011, provided the report required in subsection (c) of this section has been submitted to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d62f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1139/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb569d630-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXIV/s1410"},"text":"Pub. L. 110–53, title XIV, § 1410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/412"},"text":"121 Stat. 412","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb569d631-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb569d632-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb569d633-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1203, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXII/s1203"},"text":"section 1203 of title XII of Pub. L. 110–53","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/383"},"text":"121 Stat. 383","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s114"},"text":"section 114 of Title 49","children":[],"tail":", Transportation, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s114"},"text":"section 114 of Title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
