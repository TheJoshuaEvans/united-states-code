{"tag":"section","attrib":{"id":"idb50ce8bf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321"},"text":null,"children":[{"tag":"num","attrib":{"value":"321"},"text":"§ 321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The National Infrastructure Simulation and Analysis Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb50ce8c0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “National Infrastructure Simulation and Analysis Center” means the National Infrastructure Simulation and Analysis Center established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5195c/d"},"text":"section 5195c(d) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50ce8c1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50ce8c2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is in the Department the National Infrastructure Simulation and Analysis Center which shall serve as a source of national expertise to address critical infrastructure protection and continuity through support for activities related to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50ce8c3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" counterterrorism, threat assessment, and risk mitigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce8c4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a natural disaster, act of terrorism, or other man-made disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50ce8c5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infrastructure modeling","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50ce8c6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Particular support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The support provided under paragraph (1) shall include modeling, simulation, and analysis of the systems and assets comprising critical infrastructure, in order to enhance preparedness, protection, response, recovery, and mitigation activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce8c7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship with other agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each Federal agency and department with critical infrastructure responsibilities under Homeland Security Presidential Directive 7, or any successor to such directive, shall establish a formal relationship, including an agreement regarding information sharing, between the elements of such agency or department and the National Infrastructure Simulation and Analysis Center, through the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50ce8c8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb50ce8c9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the relationship under subparagraph (B) shall be to permit each Federal agency and department described in subparagraph (B) to take full advantage of the capabilities of the National Infrastructure Simulation and Analysis Center (particularly vulnerability and consequence analysis), consistent with its work load capacity and priorities, for real-time response to reported and projected natural disasters, acts of terrorism, and other man-made disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50ce8ca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recipient of certain support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Modeling, simulation, and analysis provided under this subsection shall be provided to relevant Federal agencies and departments, including Federal agencies and departments with critical infrastructure responsibilities under Homeland Security Presidential Directive 7, or any successor to such directive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb50ce8cb-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tV/s511"},"text":"Pub. L. 107–296, title V, § 511","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s611/13"},"text":"Pub. L. 109–295, title VI, § 611(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1406"},"text":"120 Stat. 1406","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb50ce8cc-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb50ce8cd-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb50ce8ce-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 321, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tV/s510"},"text":"Pub. L. 107–296, title V, § 510","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVII/s7303/d"},"text":"Pub. L. 108–458, title VII, § 7303(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3844"},"text":"118 Stat. 3844","children":[],"tail":", related to urban and other high risk area communications capabilities, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s611/5"},"text":"Pub. L. 109–295, title VI, § 611(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1395"},"text":"120 Stat. 1395","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
