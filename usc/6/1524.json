{"tag":"section","attrib":{"id":"idb57a7792-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524"},"text":null,"children":[{"tag":"num","attrib":{"value":"1524"},"text":"§ 1524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment; reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb57a7793-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57a7794-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agency information” has the meaning given the term in section 2213 of the Homeland Security Act of 2002 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s663"},"text":"6 U.S.C. 663","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a7795-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cyber threat indicator; defensive measure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “cyber threat indicator” and “defensive measure” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s650"},"text":"section 650 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a7796-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intrusion assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intrusion assessments” means actions taken under the intrusion assessment plan to identify and remove intruders in agency information systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a7797-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intrusion assessment plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intrusion assessment plan” means the plan required under section 2210(b)(1) of the Homeland Security Act of 2002 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s660/b/1"},"text":"6 U.S.C. 660(b)(1)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a7798-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intrusion detection and prevention capabilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intrusion detection and prevention capabilities” means the capabilities required under section 2213(b) of the Homeland Security Act of 2002 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s663/b"},"text":"6 U.S.C. 663(b)","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57a7799-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third-party assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after ","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", the Comptroller General of the United States shall conduct a study and publish a report on the effectiveness of the approach and strategy of the Federal Government to securing agency information systems, including the intrusion detection and prevention capabilities and the intrusion assessment plan."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57a779a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57a779b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intrusion detection and prevention capabilities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57a779c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of Homeland Security report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", and annually thereafter, the Secretary shall submit to the appropriate congressional committees a report on the status of implementation of the intrusion detection and prevention capabilities, including—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb57a779d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of privacy controls;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a779e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the technologies and capabilities utilized to detect cybersecurity risks in network traffic, including the extent to which those technologies and capabilities include existing commercial and noncommercial technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a779f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the technologies and capabilities utilized to prevent network traffic associated with cybersecurity risks from transiting or traveling to or from agency information systems, including the extent to which those technologies and capabilities include existing commercial and noncommercial technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a77a0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the types of indicators or other identifiers or techniques used to detect cybersecurity risks in network traffic transiting or traveling to or from agency information systems on each iteration of the intrusion detection and prevention capabilities and the number of each such type of indicator, identifier, and technique;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a77a1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of instances in which the intrusion detection and prevention capabilities detected a cybersecurity risk in network traffic transiting or traveling to or from agency information systems and the number of times the intrusion detection and prevention capabilities blocked network traffic associated with cybersecurity risk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a77a2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the pilot established under section 2213(c)(5) of the Homeland Security Act of 2002 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s663/c/5"},"text":"6 U.S.C. 663(c)(5)","children":[],"tail":"], including the number of new technologies tested and the number of participating agencies."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57a77a3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OMB report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", and annually thereafter, the Director shall submit to Congress, as part of the report required under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3553/c"},"text":"section 3553(c) of title 44","children":[],"tail":", an analysis of agency application of the intrusion detection and prevention capabilities, including—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb57a77a4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of each agency and the degree to which each agency has applied the intrusion detection and prevention capabilities to an agency information system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a77a5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a list by agency of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb57a77a6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of instances in which the intrusion detection and prevention capabilities detected a cybersecurity risk in network traffic transiting or traveling to or from an agency information system and the types of indicators, identifiers, and techniques used to detect such cybersecurity risks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb57a77a7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of instances in which the intrusion detection and prevention capabilities prevented network traffic associated with a cybersecurity risk from transiting or traveling to or from an agency information system and the types of indicators, identifiers, and techniques used to detect such agency information systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57a77a8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief information officer","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not earlier than 18 months after ","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", and not later than 2 years after "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", the Federal Chief Information Officer shall review and submit to the appropriate congressional committees a report assessing the intrusion detection and intrusion prevention capabilities, including—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb57a77a9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of the system in detecting, disrupting, and preventing cyber-threat actors, including advanced persistent threats, from accessing agency information and agency information systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a77aa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the intrusion detection and prevention capabilities, continuous diagnostics and mitigation, and other systems deployed under subtitle D ","children":[{"tag":"ref","attrib":{"idref":"fn002173"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002173"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title II of the Homeland Security Act of 2002 ("},{"tag":"ref","attrib":{"href":"/us/usc/t6/s231"},"text":"6 U.S.C. 231","children":[],"tail":" et seq.) are effective in securing Federal information systems;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a77ab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs and benefits of the intrusion detection and prevention capabilities, including as compared to commercial technologies and tools and including the value of classified cyber threat indicators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a77ac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability of agencies to protect sensitive cyber threat indicators and defensive measures if they were shared through unclassified mechanisms for use in commercial technologies and tools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a77ad-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" OMB report on development and implementation of intrusion assessment plan, advanced internal defenses, and Federal cybersecurity requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57a77ae-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 6 months after ","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", and 30 days after any update thereto, submit the intrusion assessment plan to the appropriate congressional committees;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57a77af-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", and annually thereafter, submit to Congress, as part of the report required under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3553/c"},"text":"section 3553(c) of title 44","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb57a77b0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the implementation of the intrusion assessment plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a77b1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings of the intrusion assessments conducted pursuant to the intrusion assessment plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a77b2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the advanced network security tools included in the efforts to continuously diagnose and mitigate cybersecurity risks pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1522/a/1"},"text":"section 1522(a)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57a77b3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list by agency of compliance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1523/b"},"text":"section 1523(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57a77b4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", submit to the appropriate congressional committees—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb57a77b5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1524/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the plan developed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1522/a/2"},"text":"section 1522(a)(2) of this title","children":[],"tail":"; and"}],"tail":