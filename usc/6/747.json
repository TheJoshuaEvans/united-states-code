{"tag":"section","attrib":{"id":"idb55933a1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s747"},"text":null,"children":[{"tag":"num","attrib":{"value":"747"},"text":"§ 747.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equipment and training standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55933a2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s747/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equipment standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55933a3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s747/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in coordination with the heads of appropriate Federal agencies and the National Advisory Council, shall support the development, promulgation, and updating, as necessary, of national voluntary consensus standards for the performance, use, and validation of equipment used by Federal, State, local, and tribal governments and nongovernmental emergency response providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933a4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s747/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The national voluntary consensus standards shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55933a5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s747/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designed to achieve equipment and other capabilities consistent with the national preparedness goal, including the safety and health of emergency response providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55933a6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s747/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, be consistent with existing national voluntary consensus standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55933a7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s747/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account, as appropriate, threats that may not have been contemplated when the existing standards were developed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55933a8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s747/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focus on maximizing operability, interoperability, interchangeability, durability, flexibility, efficiency, efficacy, portability, sustainability, and safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55933a9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s747/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training standards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55933aa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s747/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development, promulgation, and regular updating, as necessary, of national voluntary consensus standards for training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933ab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s747/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the training provided under the national training program is consistent with the standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55933ac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s747/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with standards organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Administrator shall consult with representatives of relevant public and private sector national voluntary consensus standards development organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55933ad-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s647"},"text":"Pub. L. 109–295, title VI, § 647","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1426"},"text":"120 Stat. 1426","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
