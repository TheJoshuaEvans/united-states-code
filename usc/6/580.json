{"tag":"section","attrib":{"id":"idb53557be-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580"},"text":null,"children":[{"tag":"num","attrib":{"value":"580"},"text":"§ 580.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Border interoperability demonstration project","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb53557bf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53557c0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Assistant Director for Emergency Communications (referred to in this section as the “Assistant Director”), and in coordination with the Federal Communications Commission and the Secretary of Commerce, shall establish an International Border Community Interoperable Communications Demonstration Project (referred to in this section as the “demonstration project”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557c1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum number of communities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Director shall select no fewer than 6 communities to participate in a demonstration project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557c2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Location of communities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No fewer than 3 of the communities selected under paragraph (2) shall be located on the northern border of the United States and no fewer than 3 of the communities selected under paragraph (2) shall be located on the southern border of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53557c3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Director, in coordination with the Federal Communications Commission and the Secretary of Commerce, shall ensure that the project is carried out as soon as adequate spectrum is available as a result of the 800 megahertz rebanding process in border areas, and shall ensure that the border projects do not impair or impede the rebanding process, but under no circumstances shall funds be distributed under this section unless the Federal Communications Commission and the Secretary of Commerce agree that these conditions have been met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53557c4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with the responsibilities of the Emergency Communications Division under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s571"},"text":"section 571 of this title","children":[],"tail":", the Assistant Director shall foster local, tribal, State, and Federal interoperable emergency communications, as well as interoperable emergency communications with appropriate Canadian and Mexican authorities in the communities selected for the demonstration project. The Assistant Director shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53557c5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify solutions to facilitate interoperable communications across national borders expeditiously;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557c6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help ensure that emergency response providers can communicate with each other in the event of natural disasters, acts of terrorism, and other man-made disasters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557c7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to enable emergency response providers to deal with threats and contingencies in a variety of environments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557c8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify appropriate joint-use equipment to ensure communications access;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557c9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify solutions to facilitate communications between emergency response providers in communities of differing population densities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557ca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take other actions or provide equipment as the Assistant Director deems appropriate to foster interoperable emergency communications.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53557cb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53557cc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall distribute funds under this section to each community participating in the demonstration project through the State, or States, in which each community is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557cd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other participants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State shall make the funds available promptly to the local and tribal governments and emergency response providers selected by the Secretary to participate in the demonstration project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557ce-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after a State receives funds under this subsection the State shall report to the Assistant Director on the status of the distribution of such funds to local and tribal governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53557cf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum period of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Director may not fund any participant under the demonstration project for more than 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53557d0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of information and knowledge","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Director shall establish mechanisms to ensure that the information and knowledge gained by participants in the demonstration project are transferred among the participants and to other interested parties, including other communities that submitted applications to the participant in the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53557d1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s580/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated for grants under this section such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53557d2-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVIII/s1810"},"text":"Pub. L. 107–296, title XVIII, § 1810","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tIII/s302/a"},"text":"Pub. L. 110–53, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/300"},"text":"121 Stat. 300","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/6/D"},"text":"Pub. L. 115–278, § 2(g)(6)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4180"},"text":"132 Stat. 4180","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb53557d3-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb53557d4-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb53557d5-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/6/D/iii"},"text":"Pub. L. 115–278, § 2(g)(6)(D)(iii)","children":[],"tail":", substituted “Assistant Director” for “Director” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/6/D/i"},"text":"Pub. L. 115–278, § 2(g)(6)(D)(i)","children":[],"tail":", substituted “Assistant Director for Emergency Communications (referred to in this section as the ‘Assistant Director’)” for “Director of the Office of Emergency Communications (referred to in this section as the ‘Director’)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/6/D/ii"},"text":"Pub. L. 115–278, § 2(g)(6)(D)(ii)","children":[],"tail":", substituted “Emergency Communications Division” for “Office of Emergency Communications” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb53557d6-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb53557d7-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Assistant Director for Emergency Communications deemed to be a reference to the Executive Assistant Director for Emergency Communications, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s571/g"},"text":"section 571(g) of this title","children":[],"tail":", enacted "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
