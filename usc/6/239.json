{"tag":"section","attrib":{"id":"idb4fe912e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s239"},"text":null,"children":[{"tag":"num","attrib":{"value":"239"},"text":"§ 239.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Cargo Security Policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4fe912f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s239/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department an Office of Cargo Security Policy (referred to in this section as the “Office”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fe9130-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s239/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fe9131-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s239/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate all Department policies relating to cargo security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fe9132-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s239/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with stakeholders and coordinate with other Federal agencies in the establishment of standards and regulations and to promote best practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fe9133-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s239/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fe9134-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s239/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office shall be headed by a Director, who shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fe9135-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s239/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fe9136-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s239/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Assistant Secretary for Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fe9137-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s239/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fe9138-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s239/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the Assistant Secretary for Policy in the development of Department-wide policies regarding cargo security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fe9139-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s239/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate all policies relating to cargo security among the agencies and offices within the Department relating to cargo security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fe913a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s239/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the cargo security policies of the Department with the policies of other executive agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4fe913b-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s431"},"text":"Pub. L. 107–296, title IV, § 431","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/347/tIII/s301/a"},"text":"Pub. L. 109–347, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1920"},"text":"120 Stat. 1920","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4fe913c-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4fe913d-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4fe913e-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tIII/s301/c"},"text":"Pub. L. 109–347, title III, § 301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1920"},"text":"120 Stat. 1920","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/347/tIII/s301/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in this section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1001"},"text":"section 1001 of this title","children":[],"tail":"] shall be construed to affect—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the authorities, functions, or capabilities of the Coast Guard to perform its missions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement under section 888 of the Homeland Security Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s468"},"text":"6 U.S.C. 468","children":[],"tail":") that those authorities, functions, and capabilities be maintained intact.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
