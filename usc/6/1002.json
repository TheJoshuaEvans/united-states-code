{"tag":"section","attrib":{"id":"idb5651b0b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1002"},"text":null,"children":[{"tag":"num","attrib":{"value":"1002"},"text":"§ 1002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeland Security Science and Technology Advisory Committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Under Secretary for Science and Technology shall utilize the Homeland Security Science and Technology Advisory Committee, as appropriate, to provide outside expertise in advancing cargo security technology.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5651b0c-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tIII/s302/c"},"text":"Pub. L. 109–347, title III, § 302(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1921"},"text":"120 Stat. 1921","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
