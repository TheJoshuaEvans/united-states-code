{"tag":"section","attrib":{"id":"idb55b7de5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s775"},"text":null,"children":[{"tag":"num","attrib":{"value":"775"},"text":"§ 775.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Emergency Family Registry and Locator System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55b7de6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s775/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55b7de7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s775/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “displaced individual” means an individual displaced by an emergency or major disaster; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7de8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s775/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “National Emergency Family Registry and Locator System” means the National Emergency Family Registry and Locator System established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55b7de9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s775/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", the Administrator shall establish a National Emergency Family Registry and Locator System to help reunify families separated after an emergency or major disaster."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55b7dea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s775/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation of System","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Emergency Family Registry and Locator System shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55b7deb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s775/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow a displaced adult (including medical patients) to voluntarily register (and allow an adult that is the parent or guardian of a displaced child to register such child), by submitting personal information to be entered into a database (such as the name, current location of residence, and any other relevant information that could be used by others seeking to locate that individual);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7dec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s775/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that information submitted under paragraph (1) is accessible to those individuals named by a displaced individual and to those law enforcement officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7ded-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s775/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be accessible through the Internet and through a toll-free number, to receive reports of displaced individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7dee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s775/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a means of referring displaced children to the National Emergency Child Locator Center established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s774"},"text":"section 774 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55b7def-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s775/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 210 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", the Administrator shall establish a mechanism to inform the public about the National Emergency Family Registry and Locator System and its potential usefulness for assisting to reunite displaced individuals with their families."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55b7df0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s775/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", the Administrator shall enter a memorandum of understanding with the Department of Justice, the National Center for Missing and Exploited Children, the Department of Health and Human Services, and the American Red Cross and other relevant private organizations that will enhance the sharing of information to facilitate reuniting displaced individuals (including medical patients) with their families."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55b7df1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s775/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 270 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":", the Administrator shall submit to the appropriate committees of Congress a report describing in detail the status of the National Emergency Family Registry and Locator System, including any difficulties or issues in establishing the System, including funding issues."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55b7df2-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s689c"},"text":"Pub. L. 109–295, title VI, § 689c","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1451"},"text":"120 Stat. 1451","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
