{"tag":"section","attrib":{"id":"idb55933dc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s750"},"text":null,"children":[{"tag":"num","attrib":{"value":"750"},"text":"§ 750.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Remedial action management program","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator, in coordination with the National Council on Disability and the National Advisory Council, shall establish a remedial action management program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55933dd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s750/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze training, exercises, and real-world events to identify and disseminate lessons learned and best practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933de-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s750/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" generate and disseminate, as appropriate, after action reports to participants in exercises and real-world events; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933df-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s750/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct remedial action tracking and long-term trend analysis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55933e0-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s650"},"text":"Pub. L. 109–295, title VI, § 650","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1428"},"text":"120 Stat. 1428","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
