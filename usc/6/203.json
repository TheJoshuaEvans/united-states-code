{"tag":"section","attrib":{"id":"idb4f4f327-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s203"},"text":null,"children":[{"tag":"num","attrib":{"value":"203"},"text":"§ 203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions transferred","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In accordance with subchapter XII (relating to transition provisions), there shall be transferred to the Secretary the functions, personnel, assets, and liabilities of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f4f328-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s203/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Customs Service of the Department of the Treasury, including the functions of the Secretary of the Treasury relating thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f329-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s203/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Transportation Security Administration of the Department of Transportation, including the functions of the Secretary of Transportation, and of the Under Secretary of Transportation for Security, relating thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f32a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s203/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Protective Service of the General Services Administration, including the functions of the Administrator of General Services relating thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f32b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s203/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Law Enforcement Training Center of the Department of the Treasury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f32c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s203/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office for Domestic Preparedness of the Office of Justice Programs, including the functions of the Attorney General relating thereto.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4f4f32d-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s403"},"text":"Pub. L. 107–296, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2178"},"text":"116 Stat. 2178","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
