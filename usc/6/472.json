{"tag":"section","attrib":{"id":"idb524b630-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s472"},"text":null,"children":[{"tag":"num","attrib":{"value":"472"},"text":"§ 472.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual weaponry report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb524b631-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s472/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Homeland Security shall submit to the Congress, not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2015-03-04"},"text":"March 4, 2015","children":[],"tail":", and annually thereafter, beginning at the time the President’s budget proposal for fiscal year 2017 is submitted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of title 31","children":[],"tail":", a comprehensive report on the purchase and usage of weapons, subdivided by weapon type. The report shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb524b632-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s472/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quantity of weapons in inventory at the end of the preceding calendar year, and the amount of weapons, subdivided by weapon type, included in the budget request for each relevant component or agency in the Department of Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb524b633-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s472/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how such quantity and purchase aligns to each component or agency’s mission requirements for certification, qualification, training, and operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb524b634-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s472/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" details on all contracting practices applied by the Department of Homeland Security, including comparative details regarding other contracting options with respect to cost and availability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb524b635-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s472/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reports required by subsection (a) shall be submitted in an appropriate format in order to ensure the safety of law enforcement personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb524b636-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/4/tV/s562"},"text":"Pub. L. 114–4, title V, § 562","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-03-04"},"text":"Mar. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/72"},"text":"129 Stat. 72","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb524b637-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb524b638-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb524b639-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the appropriation act cited in the credit of this section, and not as part of the Homeland Security Act of 2002 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
