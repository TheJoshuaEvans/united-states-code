{"tag":"section","attrib":{"id":"idb5462124-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658"},"text":null,"children":[{"tag":"num","attrib":{"value":"658"},"text":"§ 658.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity recruitment and retention","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5462125-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5462126-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate committees of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “appropriate committees of Congress” means the Committee on Homeland Security and Governmental Affairs and the Committee on Appropriations of the Senate and the Committee on Homeland Security and the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5462127-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collective bargaining agreement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “collective bargaining agreement” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7103/a/8"},"text":"section 7103(a)(8) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5462128-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excepted service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “excepted service” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2103"},"text":"section 2103 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5462129-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference eligible","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “preference eligible” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2108"},"text":"section 2108 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb546212a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualified position","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “qualified position” means a position, designated by the Secretary for the purpose of this section, in which the incumbent performs, manages, or supervises functions that execute the responsibilities of the Department relating to cybersecurity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb546212b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior Executive Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Senior Executive Service” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2101a"},"text":"section 2101a of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb546212c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb546212d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establish positions, appoint personnel, and fix rates of pay","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb546212e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb546212f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish, as positions in the excepted service, such qualified positions in the Department as the Secretary determines necessary to carry out the responsibilities of the Department relating to cybersecurity, including positions formerly identified as—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb5462130-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" senior level positions designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5462131-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" positions in the Senior Executive Service;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5462132-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint an individual to a qualified position (after taking into consideration the availability of preference eligibles for appointment to the position); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5462133-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the requirements of paragraphs (2) and (3), fix the compensation of an individual for service in a qualified position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5462134-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction with other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Secretary under this subsection applies without regard to the provisions of any other law relating to the appointment, number, classification, or compensation of employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5462135-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic pay","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5462136-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to fix rates of basic pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with this section, the Secretary shall fix the rates of basic pay for any qualified position established under paragraph (1) in relation to the rates of pay provided for employees in comparable positions in the Department of Defense and subject to the same limitations on maximum rates of pay established for such employees by law or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5462137-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevailing rate systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5341"},"text":"section 5341 of title 5","children":[],"tail":", adopt such provisions of that title as provide for prevailing rate systems of basic pay and may apply those provisions to qualified positions for employees in or under which the Department may employ individuals described by section 5342(a)(2)(A) of that title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5462138-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional compensation, incentives, and allowances","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5462139-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional compensation based on title 5 authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may provide employees in qualified positions compensation (in addition to basic pay), including benefits, incentives, and allowances, consistent with, and not in excess of the level authorized for, comparable positions authorized by title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb546213a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowances in nonforeign areas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An employee in a qualified position whose rate of basic pay is fixed under paragraph (2)(A) shall be eligible for an allowance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5941"},"text":"section 5941 of title 5","children":[],"tail":", on the same basis and to the same extent as if the employee was an employee covered by such section 5941, including eligibility conditions, allowance rates, and all other terms and conditions in law or regulation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb546213b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan for execution of authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2014-12-18"},"text":"December 18, 2014","children":[],"tail":", the Secretary shall submit a report to the appropriate committees of Congress with a plan for the use of the authorities provided under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb546213c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collective bargaining agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in paragraph (1) may be construed to impair the continued effectiveness of a collective bargaining agreement with respect to an office, component, subcomponent, or equivalent of the Department that is a successor to an office, component, subcomponent, or equivalent of the Department covered by the agreement before the succession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb546213d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in coordination with the Director of the Office of Personnel Management, shall prescribe regulations for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb546213e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2014-12-18"},"text":"December 18, 2014","children":[],"tail":", and every year thereafter for 4 years, the Secretary shall submit to the appropriate committees of Congress a detailed report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb546213f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discusses the process used by the Secretary in accepting applications, assessing candidates, ensuring adherence to veterans’ preference, and selecting applicants for vacancies to be filled by an individual for a qualified position;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5462140-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5462141-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the Secretary plans to fulfill the critical need of the Department to recruit and retain employees in qualified positions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5462142-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the measures that will be used to measure progress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5462143-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any actions taken during the reporting period to fulfill such critical need;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5462144-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discusses how the planning and actions taken under paragraph (2) are integrated into the strategic workforce planning of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5462145-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides metrics on actions occurring during the reporting period, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5462146-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees in qualified positions hired by occupation and grade and level or pay band;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5462147-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the placement of employees in qualified positions by directorate and office within the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5462148-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of veterans hired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5462149-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of separations of employees in qualified positions by occupation and grade and level or pay band;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb546214a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of retirements of employees in qualified positions by occupation and grade and level or pay band; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb546214b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and amounts of recruitment, relocation, and retention incentives paid to employees in qualified positions by occupation and grade and level or pay band; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb546214c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the training provided to supervisors of employees in qualified positions at the Department on the use of the new authorities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb546214d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Three-year probationary period","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The probationary period for all employees hired under the authority established in this section shall be 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb546214e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incumbents of existing competitive service positions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb546214f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual serving in a position on ","children":[{"tag":"date","attrib":{"date":"2014-12-18"},"text":"December 18, 2014","children":[],"tail":", that is selected to be converted to a position in the excepted service under this section shall have the right to refuse such conversion."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5462150-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent conversion","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"After the date on which an individual who refuses a conversion under paragraph (1) stops serving in the position selected to be converted, the position may be converted to a position in the excepted service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5462151-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Study and report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2014-12-18"},"text":"December 18, 2014","children":[],"tail":", the National Protection and Programs Directorate shall submit a report regarding the availability of, and benefits (including cost savings and security) of using, cybersecurity personnel and facilities outside of the National Capital Region (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2674"},"text":"section 2674 of title 10","children":[],"tail":") to serve the Federal and national need to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5462152-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Homeland Security of the Committee on Appropriations and the Committee on Homeland Security and Governmental Affairs of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5462153-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s658/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Homeland Security of the Committee on Appropriations and the Committee on Homeland Security of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5462154-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2208"},"text":"Pub. L. 107–296, title XXII, § 2208","children":[],"tail":", formerly title II, § 226, as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/277/s3/a"},"text":"Pub. L. 113–277, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3005"},"text":"128 Stat. 3005","children":[],"tail":"; renumbered title XXII, § 2208, "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/2/I"},"text":"Pub. L. 115–278, § 2(g)(2)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4178"},"text":"132 Stat. 4178","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5462155-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"i