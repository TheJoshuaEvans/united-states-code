{"tag":"section","attrib":{"id":"idb5355764-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s576"},"text":null,"children":[{"tag":"num","attrib":{"value":"576"},"text":"§ 576.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency Communications Preparedness Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5355765-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s576/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established the Emergency Communications Preparedness Center (in this section referred to as the “Center”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5355766-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s576/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, the Chairman of the Federal Communications Commission, the Secretary of Defense, the Secretary of Commerce, the Attorney General of the United States, and the heads of other Federal departments and agencies or their designees shall jointly operate the Center in accordance with the Memorandum of Understanding entitled, “Emergency Communications Preparedness Center (ECPC) Charter”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5355767-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s576/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5355768-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s576/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serve as the focal point for interagency efforts and as a clearinghouse with respect to all relevant intergovernmental information to support and promote (including specifically by working to avoid duplication, hindrances, and counteractive efforts among the participating Federal departments and agencies)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5355769-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s576/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of emergency response providers and relevant government officials to continue to communicate in the event of natural disasters, acts of terrorism, and other man-made disasters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb535576a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s576/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interoperable emergency communications;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb535576b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s576/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prepare and submit to Congress, on an annual basis, a strategic assessment regarding the coordination efforts of Federal departments and agencies to advance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb535576c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s576/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of emergency response providers and relevant government officials to continue to communicate in the event of natural disasters, acts of terrorism, and other man-made disasters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb535576d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s576/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interoperable emergency communications;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb535576e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s576/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider, in preparing the strategic assessment under paragraph (2), the goals stated in the National Emergency Communications Plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s572"},"text":"section 572 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb535576f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s576/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other functions as are provided in the Emergency Communications Preparedness Center (ECPC) Charter described in subsection (b)(1).","children":[{"tag":"ref","attrib":{"idref":"fn002093"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002093"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Subsection (b) of this section does not contain a paragraph (1)."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5355770-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVIII/s1806"},"text":"Pub. L. 107–296, title XVIII, § 1806","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s671/b"},"text":"Pub. L. 109–295, title VI, § 671(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1440"},"text":"120 Stat. 1440","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5355771-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5355772-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5355773-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1806"},"text":"section 1806 of Pub. L. 107–296","children":[],"tail":" was renumbered section 1906 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s596"},"text":"section 596 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
