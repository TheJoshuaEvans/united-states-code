{"tag":"section","attrib":{"id":"idb500dac3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s243"},"text":null,"children":[{"tag":"num","attrib":{"value":"243"},"text":"§ 243.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maritime operations coordination plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb500dac4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s243/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", and biennially thereafter, the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb500dac5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s243/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update the Maritime Operations Coordination Plan, published by the Department on ","children":[{"tag":"date","attrib":{"date":"2011-07-07"},"text":"July 7, 2011","children":[],"tail":", to strengthen coordination, planning, information sharing, and intelligence integration for maritime operations of components and offices of the Department with responsibility for maritime security missions; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500dac6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s243/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit each update to the Committee on Commerce, Science, and Transportation and the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Transportation and Infrastructure and the Committee on Homeland Security of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb500dac7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s243/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each update shall address the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb500dac8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s243/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinating the planning, integration of maritime operations, and development of joint maritime domain awareness efforts of any component or office of the Department with responsibility for maritime security missions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500dac9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s243/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maintaining effective information sharing and, as appropriate, intelligence integration, with Federal, State, and local officials and the private sector, regarding threats to maritime security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500daca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s243/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cooperating and coordinating with Federal departments and agencies, and State and local agencies, in the maritime environment, in support of maritime security missions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500dacb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s243/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Highlighting the work completed within the context of other national and Department maritime security strategic guidance and how that work fits with the Maritime Operations Coordination Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb500dacc-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s435"},"text":"Pub. L. 107–296, title IV, § 435","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dJ/s1807/a"},"text":"Pub. L. 115–254, div. J, § 1807(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3536"},"text":"132 Stat. 3536","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
