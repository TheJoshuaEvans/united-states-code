{"tag":"section","attrib":{"id":"idb4f4f32e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204"},"text":null,"children":[{"tag":"num","attrib":{"value":"204"},"text":"§ 204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surface Transportation Security Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4f4f32f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Transportation Security Administration (referred to in this section as “Administrator”) shall establish within the Transportation Security Administration the Surface Transportation Security Advisory Committee (referred to in this section as the “Advisory Committee”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f4f330-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f4f331-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee may advise, consult with, report to, and make recommendations to the Administrator on surface transportation security matters, including the development, refinement, and implementation of policies, programs, initiatives, rulemakings, and security directives pertaining to surface transportation security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f332-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Risk-based security","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall consider risk-based security approaches in the performance of its duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f4f333-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f4f334-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f4f335-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voting members appointed by the Administrator under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f336-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" nonvoting members, serving in an advisory capacity, who shall be designated by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4f4f337-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Transportation Security Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f4f338-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f4f339-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Coast Guard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f4f33a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other Federal department or agency as the Administrator considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f33b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall appoint voting members from among stakeholders representing each mode of surface transportation, such as passenger rail, freight rail, mass transit, pipelines, highways, over-the-road bus, school bus industry, and trucking, including representatives from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f4f33c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" associations representing such modes of surface transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f33d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" labor organizations representing such modes of surface transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f33e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" groups representing the users of such modes of surface transportation, including asset manufacturers, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f33f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relevant law enforcement, first responders, and security experts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f340-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other groups as the Administrator considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f341-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall select a chairperson from among its voting members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f342-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f4f343-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4f4f344-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term of each voting member of the Advisory Committee shall be 2 years, but a voting member may continue to serve until the Administrator appoints a successor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f4f345-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reappointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A voting member of the Advisory Committee may be reappointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f346-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4f4f347-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may review the participation of a member of the Advisory Committee and remove such member for cause at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f4f348-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may remove any member of the Advisory Committee that the Administrator determines should be restricted from reviewing, discussing, or possessing classified information or sensitive security information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f349-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on compensation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The members of the Advisory Committee shall not receive any compensation from the Government by reason of their service on the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f34a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f4f34b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall require the Advisory Committee to meet at least semiannually in person or through web conferencing and may convene additional meetings as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f34c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public meetings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At least 1 of the meetings of the Advisory Committee each year shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4f4f34d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" announced in the Federal Register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f4f34e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" announced on a public website; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f4f34f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/6/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" open to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f350-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attendance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall maintain a record of the persons present at each meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f351-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minutes","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4f4f352-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/6/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Unless otherwise prohibited by other Federal law, minutes of the meetings shall be published on the public website under subsection (e)(5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f4f353-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/6/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of classified and sensitive information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee may redact or summarize, as necessary, minutes of the meetings to protect classified or other sensitive information in accordance with law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f354-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voting member access to classified and sensitive security information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f4f355-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date on which a voting member is appointed to the Advisory Committee and before that voting member may be granted any access to classified information or sensitive security information, the Administrator shall determine if the voting member should be restricted from reviewing, discussing, or possessing classified information or sensitive security information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f356-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4f4f357-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sensitive security information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a voting member is not restricted from reviewing, discussing, or possessing sensitive security information under subparagraph (A) and voluntarily signs a nondisclosure agreement, the voting member may be granted access to sensitive security information that is relevant to the voting member’s service on the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f4f358-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Access to classified materials shall be managed in accordance with Executive Order 13526 of ","children":[{"tag":"date","attrib":{"date":"2009-12-29"},"text":"December 29, 2009","children":[],"tail":" (75 Fed. Reg. 707), or any subsequent corresponding Executive order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f359-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protections","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4f4f35a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sensitive security information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Voting members shall protect sensitive security information in accordance with part 1520 of title 49, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f4f35b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Voting members shall protect classified information in accordance with the applicable requirements for the particular level of classification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f35c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint committee meetings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee may meet with 1 or more of the following advisory committees to discuss multimodal security issues and other security-related issues of common concern:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f4f35d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Aviation Security Advisory Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44946"},"text":"section 44946 of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f35e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Maritime Security Advisory Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70112"},"text":"section 70112 of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f35f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Railroad Safety Advisory Committee established by the Federal Railroad Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f360-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject matter experts","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee may request the assistance of subject matter experts with expertise related to the jurisdiction of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f4f361-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f4f362-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall periodically submit reports to the Administrator on matters requested by the Administrator or by a majority of the members of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f363-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f4f364-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Advisory Committee shall submit to the Administrator and the appropriate congressional committees an annual report that provides information on the activities, findings, and recommendations of the Advisory Committee during the preceding year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f365-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 6 months after the date that the Administrator receives an annual report under subparagraph (A), the Administrator shall publish a public version of the report, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a/b"},"text":"section 552a(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f4f366-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration response","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f4f367-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall consider the information, advice, and recommendations of the Advisory Committee in formulating policies, programs, initiatives, rulemakings, and security directives pertaining to surface transportation security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f368-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feedback","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date that the Administrator receives a recommendation from the Advisory Committee under subsection (d)(2), the Administrator shall submit to the Advisory Committee written feedback on the recommendation, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f4f369-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Administrator agrees with the recommendation, a plan describing the actions that the Administrator has taken, will take, or recommends that the head of another Federal department or agency take to implement the recommendation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f36a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Administrator disagrees with the recommendation, a justification for that determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f36b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notices","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the date the Administrator submits feedback under paragraph (2), the Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f4f36c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the appropriate congressional committees of the feedback, including the determination under subparagraph (A) or subparagraph (B) of that paragraph, as applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f36d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the appropriate congressional committees with a briefing upon request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f36e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after the date the Administrator receives a recommendation from the Advisory Committee under subsection (d)(2) that the Administrator agrees with, and quarterly thereafter until the recommendation is fully implemented, the Administrator shall submit a report to the appropriate congressional committees or post on the public website under paragraph (5) an update on the status of the recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f36f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Website","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall maintain a public website that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f4f370-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lists the members of the Advisory Committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f4f371-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the contact information for the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f4f372-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s204/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonapplicability of FACA","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"ref","attrib":{"idref":"fn002030"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002030"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall not apply to the Advisory Committee or any subcommittee established under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4f4f373-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s404"},"text":"Pub. L. 107–296, title IV, § 404","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1969/a"},"text":"Pub. L. 115–254, div. K, title I, § 1969(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3609"},"text":"132 Stat. 3609","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4f4f374-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4f4f375-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4f4f376-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 13526, referred to in subsec. (c)(7)(B)(ii), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"section 3161 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Federal Advisory Committee Act, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463"},"text":"Pub. L. 92–463","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-06"},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/770"},"text":"86 Stat. 770","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was substantially repealed and restated in chapter 10 (§ 1001 et seq.) of Title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4197"},"text":"136 Stat. 4197","children":[],"tail":", 4361. For disposition of sections of the Act into chapter 10 of Title 5, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4f4f377-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4f4f378-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Surface Transportation Security Advisory Committee Members","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1969/b"},"text":"Pub. L. 115–254, div. K, title I, § 1969(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3612"},"text":"132 Stat. 3612","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dK/tI/s1969/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voting members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":"], the Administrator [of the Transportation Security Administration] shall appoint the voting members of the Surface Transportation Security Advisory Committee established under section 404 of the Homeland Security Act of 2002 ["},{"tag":"ref","attrib":{"href":"/us/usc/t6/s204"},"text":"6 U.S.C. 204","children":[],"tail":"], as added by subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonvoting members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of this Act, each Federal Government department and agency with regulatory authority over a mode of surface or maritime transportation, as the Administrator considers appropriate, shall designate an appropriate representative to serve as a nonvoting member of the Surface Transportation Security Advisory Committee.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
