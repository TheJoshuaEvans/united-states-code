{"tag":"section","attrib":{"id":"idb4fc208d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231"},"text":null,"children":[{"tag":"num","attrib":{"value":"231"},"text":"§ 231.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of certain agricultural inspection functions of the Department of Agriculture","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4fc208e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of agricultural import and entry inspection functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be transferred to the Secretary the functions of the Secretary of Agriculture relating to agricultural import and entry inspection activities under the laws specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc208f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered animal and plant protection laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The laws referred to in subsection (a) are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc2090-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Act commonly known as the Virus-Serum-Toxin Act (the eighth paragraph under the heading “Bureau of Animal Industry” in the Act of ","children":[{"tag":"date","attrib":{"date":"1913-03-04"},"text":"March 4, 1913","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s151"},"text":"21 U.S.C. 151","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc2091-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-08-31/s1"},"text":"Section 1 of the Act of August 31, 1922","children":[],"tail":" (commonly known as the Honeybee Act; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s281"},"text":"7 U.S.C. 281","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc2092-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Title III of the Federal Seed Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s1581"},"text":"7 U.S.C. 1581","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc2093-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Plant Protection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s7701"},"text":"7 U.S.C. 7701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc2094-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Animal Health Protection Act (subtitle E of title X of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/171"},"text":"Public Law 107–171","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s8301"},"text":"7 U.S.C. 8301","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc2095-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Lacey Act Amendments of 1981 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s3371"},"text":"16 U.S.C. 3371","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc2096-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 11 of the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1540"},"text":"16 U.S.C. 1540","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc2097-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of quarantine activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “functions” does not include any quarantine activities carried out under the laws specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc2098-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of transfer","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc2099-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance with Department of Agriculture regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority transferred pursuant to subsection (a) shall be exercised by the Secretary in accordance with the regulations, policies, and procedures issued by the Secretary of Agriculture regarding the administration of the laws specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc209a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture shall coordinate with the Secretary whenever the Secretary of Agriculture prescribes regulations, policies, or procedures for administering the functions transferred under subsection (a) under a law specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc209b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in consultation with the Secretary of Agriculture, may issue such directives and guidelines as are necessary to ensure the effective use of personnel of the Department of Homeland Security to carry out the functions transferred pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc209c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer agreement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc209d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agreement required; revision","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before the end of the transition period, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s541"},"text":"section 541 of this title","children":[],"tail":", the Secretary of Agriculture and the Secretary shall enter into an agreement to effectuate the transfer of functions required by subsection (a) of this section. The Secretary of Agriculture and the Secretary may jointly revise the agreement as necessary thereafter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc209e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required terms","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The agreement required by this subsection shall specifically address the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fc209f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The supervision by the Secretary of Agriculture of the training of employees of the Secretary to carry out the functions transferred pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fc20a0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The transfer of funds to the Secretary under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc20a1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation and reciprocity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Agriculture and the Secretary may include as part of the agreement the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4fc20a2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Authority for the Secretary to perform functions delegated to the Animal and Plant Health Inspection Service of the Department of Agriculture regarding the protection of domestic livestock and plants, but not transferred to the Secretary pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4fc20a3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Authority for the Secretary of Agriculture to use employees of the Department of Homeland Security to carry out authorities delegated to the Animal and Plant Health Inspection Service regarding the protection of domestic livestock and plants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc20a4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic transfer of funds to Department of Homeland Security","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fc20a5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Out of funds collected by fees authorized under sections 136 and 136a of title 21, the Secretary of Agriculture shall transfer, from time to time in accordance with the agreement under subsection (e), to the Secretary funds for activities carried out by the Secretary for which such fees were collected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fc20a6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The proportion of fees collected pursuant to such sections that are transferred to the Secretary under this subsection may not exceed the proportion of the costs incurred by the Secretary to all costs incurred to carry out activities funded by such fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fc20a7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s231/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of Department of Agriculture employees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than the completion of the transition period defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s541"},"text":"section 541 of this title","children":[],"tail":", the Secretary of Agriculture shall transfer to the Secretary not more than 3,200 full-time equivalent positions of the Department of Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4fc20a8-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s421"},"text":"Pub. L. 107–296, title IV, § 421","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2182"},"text":"116 Stat. 2182","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4fc20a9-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4fc20aa-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4fc20ab-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Virus-Serum-Toxin Act, referred to in subsec. (b)(1), is the eighth paragraph under the heading “Bureau of Animal Industry” in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch145"},"text":"act Mar. 4, 1913, ch. 145","children":[],"tail":", "},{"tag":"ref","attri