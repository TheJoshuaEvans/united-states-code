of Pub. L. 107–296","children":[],"tail":". Subsec. (h) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s421"},"text":"section 421 of Pub. L. 107–296","children":[],"tail":" amended sections 2279e and 2279f of Title 7, Agriculture."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
