{"tag":"section","attrib":{"id":"idb5782d6c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503"},"text":null,"children":[{"tag":"num","attrib":{"value":"1503"},"text":"§ 1503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizations for preventing, detecting, analyzing, and mitigating cybersecurity threats","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5782d6d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for monitoring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5782d6e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, a private entity may, for cybersecurity purposes, monitor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5782d6f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an information system of such private entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782d70-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an information system of another non-Federal entity, upon the authorization and written consent of such other entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782d71-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an information system of a Federal entity, upon the authorization and written consent of an authorized representative of the Federal entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782d72-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information that is stored on, processed by, or transiting an information system monitored by the private entity under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782d73-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection shall be construed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5782d74-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize the monitoring of an information system, or the use of any information obtained through such monitoring, other than as provided in this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782d75-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit otherwise lawful activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782d76-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for operation of defensive measures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5782d77-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, a private entity may, for cybersecurity purposes, operate a defensive measure that is applied to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5782d78-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an information system of such private entity in order to protect the rights or property of the private entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782d79-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an information system of another non-Federal entity upon written consent of such entity for operation of such defensive measure to protect the rights or property of such entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782d7a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an information system of a Federal entity upon written consent of an authorized representative of such Federal entity for operation of such defensive measure to protect the rights or property of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782d7b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection shall be construed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5782d7c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize the use of a defensive measure other than as provided in this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782d7d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit otherwise lawful activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782d7e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization for sharing or receiving cyber threat indicators or defensive measures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5782d7f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2) and notwithstanding any other provision of law, a non-Federal entity may, for a cybersecurity purpose and consistent with the protection of classified information, share with, or receive from, any other non-Federal entity or the Federal Government a cyber threat indicator or defensive measure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782d80-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lawful restriction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A non-Federal entity receiving a cyber threat indicator or defensive measure from another non-Federal entity or a Federal entity shall comply with otherwise lawful restrictions placed on the sharing or use of such cyber threat indicator or defensive measure by the sharing non-Federal entity or Federal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782d81-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection shall be construed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5782d82-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize the sharing or receiving of a cyber threat indicator or defensive measure other than as provided in this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782d83-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit otherwise lawful activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782d84-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection and use of information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5782d85-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A non-Federal entity monitoring an information system, operating a defensive measure, or providing or receiving a cyber threat indicator or defensive measure under this section shall implement and utilize a security control to protect against unauthorized access to or acquisition of such cyber threat indicator or defensive measure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782d86-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of certain personal information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A non-Federal entity sharing a cyber threat indicator pursuant to this subchapter shall, prior to such sharing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5782d87-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review such cyber threat indicator to assess whether such cyber threat indicator contains any information not directly related to a cybersecurity threat that the non-Federal entity knows at the time of sharing to be personal information of a specific individual or information that identifies a specific individual and remove such information; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782d88-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implement and utilize a technical capability configured to remove any information not directly related to a cybersecurity threat that the non-Federal entity knows at the time of sharing to be personal information of a specific individual or information that identifies a specific individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782d89-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of cyber threat indicators and defensive measures by non-Federal entities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5782d8a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with this subchapter, a cyber threat indicator or defensive measure shared or received under this section may, for cybersecurity purposes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5782d8b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be used by a non-Federal entity to monitor or operate a defensive measure that is applied to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb5782d8c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an information system of the non-Federal entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5782d8d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an information system of another non-Federal entity or a Federal entity upon the written consent of that other non-Federal entity or that Federal entity; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5782d8e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be otherwise used, retained, and further shared by a non-Federal entity subject to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb5782d8f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an otherwise lawful restriction placed by the sharing non-Federal entity or Federal entity on such cyber threat indicator or defensive measure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5782d90-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an otherwise applicable provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782d91-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this paragraph shall be construed to authorize the use of a cyber threat indicator or defensive measure other than as provided in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782d92-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of cyber threat indicators by State, tribal, or local government","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5782d93-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law enforcement use","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State, tribal, or local government that receives a cyber threat indicator or defensive measure under this subchapter may use such cyber threat indicator or defensive measure for the purposes described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1504/d/5/A"},"text":"section 1504(d)(5)(A) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782d94-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from disclosure","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A cyber threat indicator or defensive measure shared by or with a State, tribal, or local government, including a component of a State, tribal, or local government that is a private entity, under this section shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5782d95-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deemed voluntarily shared information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5782d96-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt from disclosure under any provision of State, tribal, or local freedom of information law, open government law, open meetings law, open records law, sunshine law, or similar law requiring disclosure of information or records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782d97-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State, tribal, and local regulatory authority","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5782d98-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in clause (ii), a cyber threat indicator or defensive measure shared with a State, tribal, or local government under this subchapter shall not be used by any State, tribal, or local government to regulate, including an enforcement action, the lawful activity of any non-Federal entity or any activity taken by a non-Federal entity pursuant to mandatory standards, including an activity relating to monitoring, operating a defensive measure, or sharing of a cyber threat indicator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5782d99-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/d/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory authority specifically relating to prevention or mitigation of cybersecurity threats","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A cyber threat indicator or defensive measure shared as described in clause (i) may, consistent with a State, tribal, or local government regulatory authority specifically relating to the prevention or mitigation of cybersecurity threats to information systems, inform the development or implementation of a regulation relating to such information systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782d9a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antitrust exemption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5782d9b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1507/e"},"text":"section 1507(e) of this title","children":[],"tail":", it shall not be considered a violation of any provision of antitrust laws for 2 or more private entities to exchange or provide a cyber threat indicator or defensive measure, or assistance relating to the prevention, investigation, or mitigation of a cybersecurity threat, for cybersecurity purposes under this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782d9c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Paragraph (1) shall apply only to information that is exchanged or assistance provided in order to assist with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5782d9d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating the prevention, investigation, or mitigation of a cybersecurity threat to an information system or information that is stored on, processed by, or transiting an information system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782d9e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicating or disclosing a cyber threat indicator to help prevent, investigate, or mitigate the effect of a cybersecurity threat to an information system or information that is stored on, processed by, or transiting an information system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782d9f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1503/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No right or benefit","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The sharing of a cyber threat indicator or defensive measure with a non-Federal entity under this subchapter shall not create a right or benefit to similar information by such non-Federal entity or any other non-Federal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5782da0-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dN/tI/s104"},"text":"Pub. L. 114–113, div. N, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2940"},"text":"129 Stat. 2940","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
