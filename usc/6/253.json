{"tag":"section","attrib":{"id":"idb500db0c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s253"},"text":null,"children":[{"tag":"num","attrib":{"value":"253"},"text":"§ 253.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional responsibility and quality review","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb500db0d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s253/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting investigations of noncriminal allegations of misconduct, corruption, and fraud involving any employee of U.S. Immigration and Customs Enforcement that are not subject to investigation by the Inspector General for the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500db0e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s253/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspecting the operations of U.S. Immigration and Customs Enforcement and providing assessments of the quality of the operations of such agency as a whole and each of its components; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500db0f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s253/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing an analysis of the management of U.S. Immigration and Customs Enforcement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb500db10-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s443"},"text":"Pub. L. 107–296, title IV,