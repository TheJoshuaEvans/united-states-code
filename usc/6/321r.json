{"tag":"section","attrib":{"id":"idb511a33b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r"},"text":null,"children":[{"tag":"num","attrib":{"value":"321r"},"text":"§ 321r.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of equipment during a public health emergency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb511a33c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of transfer of equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"During a public health emergency declared by the Secretary of Health and Human Services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d/a"},"text":"section 247d(a) of title 42","children":[],"tail":", the Secretary, at the request of the Secretary of Health and Human Services, may transfer to the Department of Health and Human Services, on a reimbursable basis, excess personal protective equipment or medically necessary equipment in the possession of the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb511a33d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination by Secretaries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb511a33e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb511a33f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before requesting a transfer under subsection (a), the Secretary of Health and Human Services shall determine whether the personal protective equipment or medically necessary equipment is otherwise available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a340-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before initiating a transfer under subsection (a), the Secretary, in consultation with the heads of each component within the Department, shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb511a341-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether the personal protective equipment or medically necessary equipment requested to be transferred under subsection (a) is excess equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a342-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify that the transfer of the personal protective equipment or medically necessary equipment will not adversely impact the health or safety of officers, employees, or contractors of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511a343-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Health and Human Services and the Secretary shall each submit to Congress a notification explaining the determination made under subparagraphs (A) and (B), respectively, of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511a344-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required inventory","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb511a345-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb511a346-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting through the Chief Medical Officer of the Department, maintain an inventory of all personal protective equipment and medically necessary equipment in the possession of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a347-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" make the inventory required under clause (i) available, on a continual basis, to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb511a348-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/b/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Health and Human Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb511a349-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/b/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations and the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Appropriations and the Committee on Homeland Security of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a34a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321r/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each inventory required to be made available under subparagraph (A) shall be submitted in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb511a34b-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tV/s529"},"text":"Pub. L. 107–296, title V, § 529","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tIX/s70953/f/2/A"},"text":"Pub. L. 117–58, div. G, title IX, § 70953(f)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1315"},"text":"135 Stat. 1315","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
