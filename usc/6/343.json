{"tag":"section","attrib":{"id":"idb513ed67-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343"},"text":null,"children":[{"tag":"num","attrib":{"value":"343"},"text":"§ 343.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Information Officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb513ed68-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Information Officer shall report to the Secretary, or to another official of the Department, as the Secretary may direct.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb513ed69-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geospatial information functions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb513ed6a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb513ed6b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geospatial information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “geospatial information” means graphical or digital data depicting natural or manmade physical features, phenomena, or boundaries of the earth and any information related thereto, including surveys, maps, charts, remote sensing data, and images.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb513ed6c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geospatial technology","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “geospatial technology” means any technology utilized by analysts, specialists, surveyors, photogrammetrists, hydrographers, geodesists, cartographers, architects, or engineers for the collection, storage, retrieval, or dissemination of geospatial information, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb513ed6d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" global satellite surveillance systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb513ed6e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" global position systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb513ed6f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geographic information systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb513ed70-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mapping equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb513ed71-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geocoding technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb513ed72-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remote sensing devices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb513ed73-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Geospatial Management","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb513ed74-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Geospatial Management is established within the Office of the Chief Information Officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb513ed75-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Geospatial Information Officer","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb513ed76-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Office of Geospatial Management shall be administered by the Geospatial Information Officer, who shall be appointed by the Secretary and serve under the direction of the Chief Information Officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb513ed77-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Geospatial Information Officer shall assist the Chief Information Officer in carrying out all functions under this section and in coordinating the geospatial information needs of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb513ed78-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of geospatial information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Information Officer shall establish and carry out a program to provide for the efficient use of geospatial information, which shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb513ed79-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing such geospatial information as may be necessary to implement the critical infrastructure protection programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb513ed7a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing leadership and coordination in meeting the geospatial information requirements of those responsible for planning, prevention, mitigation, assessment and response to emergencies, critical infrastructure protection, and other functions of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb513ed7b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating with users of geospatial information within the Department to assure interoperability and prevent unnecessary duplication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb513ed7c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this subsection, the responsibilities of the Chief Information Officer shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb513ed7d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating the geospatial information needs and activities of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb513ed7e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" implementing standards, as adopted by the Director of the Office of Management and Budget under the processes established under section 216 of the E-Government Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"44 U.S.C. 3501","children":[],"tail":" note), to facilitate the interoperability of geospatial information pertaining to homeland security among all users of such information within—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idb513ed7f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb513ed80-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb513ed81-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/D/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb513ed82-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating with the Federal Geographic Data Committee and carrying out the responsibilities of the Department pursuant to Office of Management and Budget Circular A–16 and Executive Order 12906; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb513ed83-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" making recommendations to the Secretary and the Executive Director of the Office for State and Local Government Coordination and Preparedness on awarding grants to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb513ed84-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/D/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fund the creation of geospatial data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb513ed85-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/2/D/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" execute information sharing agreements regarding geospatial data with State, local, and tribal governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb513ed86-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s343/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this subsection for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb513ed87-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVII/s703"},"text":"Pub. L. 107–296, title VII, § 703","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2219"},"text":"116 Stat. 2219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVIII/s8201/b"},"text":"Pub. L. 108–458, title VIII, § 8201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3865"},"text":"118 Stat. 3865","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb513ed88-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb513ed89-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb513ed8a-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 216 of the E-Government Act of 2002, referred to in subsec. (b)(2)(D)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347/s216"},"text":"section 216 of Pub. L. 107–347","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"section 3501 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Executive Order 12906, referred to in subsec. (b)(2)(D)(iii), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t43/s1457"},"text":"section 1457 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb513ed8b-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb513ed8c-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5165e8d-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVIII/s8201/a"},"text":"Pub. L. 108–458, title VIII, § 8201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3865"},"text":"118 Stat. 3865","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/458/tVIII/s8201/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Geospatial technologies and geospatial data improve government capabilities to detect, plan for, prepare for, and respond to disasters in order to save lives and protect property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Geospatial data improves the ability of information technology applications and systems to enhance public security in a cost-effective manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Geospatial information preparedness in the United States, and specifically in the Department of Homeland Security, is insufficient because of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inadequate geospatial data compatibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insufficient geospatial data sharing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology interoperability barriers.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
