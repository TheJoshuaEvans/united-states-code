{"tag":"section","attrib":{"id":"idb500dae1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s251"},"text":null,"children":[{"tag":"num","attrib":{"value":"251"},"text":"§ 251.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In accordance with subchapter XII (relating to transition provisions), there shall be transferred from the Commissioner of Immigration and Naturalization to the Secretary all functions performed under the following programs, and all personnel, assets, and liabilities pertaining to such programs, immediately before such transfer occurs:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb500dae2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s251/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Border Patrol program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500dae3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s251/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The detention and removal program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500dae4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s251/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The intelligence program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500dae5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s251/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The investigations program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib"