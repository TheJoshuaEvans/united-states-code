{"tag":"section","attrib":{"id":"idb57101cd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182"},"text":null,"children":[{"tag":"num","attrib":{"value":"1182"},"text":"§ 1182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Over-the-road bus security assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb57101ce-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program for making grants to eligible private operators providing transportation by an over-the-road bus for security improvements described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101cf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient of a grant received under subsection (a) shall use the grant funds for one or more of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57101d0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Constructing and modifying terminals, garages, and facilities, including terminals and other over-the-road bus facilities owned by State or local governments, to increase their security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101d1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Modifying over-the-road buses to increase their security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101d2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Protecting or isolating the driver of an over-the-road bus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101d3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Acquiring, upgrading, installing, or operating equipment, software, or accessorial services for collection, storage, or exchange of passenger and driver information through ticketing systems or other means and for information links with government agencies, for security purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101d4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Installing cameras and video surveillance equipment on over-the-road buses and at terminals, garages, and over-the-road bus facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101d5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing and improving an emergency communications system linking drivers and over-the-road buses to the recipient’s operations center or linking the operations center to law enforcement and emergency personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101d6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Implementing and operating passenger screening programs for weapons and explosives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101d7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public awareness campaigns for enhanced over-the-road bus security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101d8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operating and capital costs associated with over-the-road bus security awareness, preparedness, and response training, including training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1184"},"text":"section 1184 of this title","children":[],"tail":" and training developed by institutions of higher education and by nonprofit employee labor organizations, for over-the-road bus employees, including frontline employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101d9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chemical, biological, radiological, or explosive detection, including canine patrols for such detection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101da-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Overtime reimbursement, including reimbursement of State, local, and tribal governments for costs, for enhanced security personnel assigned to duties related to over-the-road bus security during periods of high or severe threat levels, National Special Security Events, or other periods of heightened security as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101db-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Live or simulated exercises, including those described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1183"},"text":"section 1183 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101dc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operational costs to hire, train, and employ police and security officers, including canine units, assigned to full-time security or counterterrorism duties related to over-the-road bus transportation, including reimbursement of State, local, and tribal government costs for such personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101dd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of assessments or security plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1181"},"text":"section 1181 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101de-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other improvements as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101df-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Due consideration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making grants under this section, the Secretary shall prioritize grant funding based on security risks to bus passengers and the ability of a project to reduce, or enhance response to, that risk, and shall not penalize private operators of over-the-road buses that have taken measures to enhance over-the-road bus transportation security prior to ","children":[{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101e0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Homeland Security responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the responsibilities under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57101e1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the requirements for recipients of grants under this section, including application requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101e2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select grant recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101e3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award the funds authorized by this section based on risk, as identified by the plans required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1181"},"text":"section 1181 of this title","children":[],"tail":" or assessment or plan described in subsection (f)(2); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101e4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to subsection (c), establish priorities for the use of funds for grant recipients.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101e5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", the Secretary and the Secretary of Transportation shall determine the most effective and efficient way to distribute grant funds to the recipients of grants determined by the Secretary under subsection (a). Subject to the determination made by the Secretaries, the Secretary may transfer funds to the Secretary of Transportation for the purposes of disbursing funds to the grant recipient."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101e6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57101e7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A private operator providing transportation by an over-the-road bus is eligible for a grant under this section if the operator has completed a vulnerability assessment and developed a security plan that the Secretary has approved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1181"},"text":"section 1181 of this title","children":[],"tail":". Grant funds may only be used for permissible uses under subsection (b) to further an over-the-road bus security plan."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101e8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the requirements for eligibility and uses in paragraph (1), prior to the earlier of 1 year after the date of issuance of final regulations requiring vulnerability assessments and security plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1181"},"text":"section 1181 of this title","children":[],"tail":" or 3 years after "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", the Secretary may award grants under this section for over-the-road bus security improvements listed under subsection (b) based upon over-the-road bus vulnerability assessments and security plans that the Secretary deems are sufficient for the purposes of this section but have not been approved by the Secretary in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s1181"},"text":"section 1181 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101e9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject to certain terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided in this section, a grant made under this section shall be subject to the terms and conditions applicable to subrecipients who provide over-the-road bus transportation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5311/f"},"text":"section 5311(f) of title 49","children":[],"tail":" and such other terms and conditions as are determined necessary by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101ea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on uses of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant made under this section may not be used to make any State or local government cost-sharing contribution under any other Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101eb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of a grant under this section shall report annually to the Secretary and on the use of such grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101ec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out this section, the Secretary shall consult with over-the-road bus operators and nonprofit employee labor organizations representing over-the-road bus employees, public safety and law enforcement officials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101ed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57101ee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts appropriated pursuant to section 114(w) ","children":[{"tag":"ref","attrib":{"idref":"fn002165"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002165"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 49, there shall be made available to the Secretary to make grants under this section—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57101ef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/k/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $12,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57101f0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/k/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57101f1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/k/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57101f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/k/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25,000,000 for fiscal year 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1182/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Sums appropriated to carry out this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57101f4-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXV/s1532"},"text":"Pub. L. 110–53, title XV, § 1532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/457"},"text":"121 Stat. 457","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57101f5-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57101f6-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb57101f7-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s114/w"},"text":"Section 114(w) of title 49","children":[],"tail":", referred to in subsec. (k)(1), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s114/v"},"text":"section 114(v) of title 49","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/s1904/b/1/I"},"text":"Pub. L. 115–254, div. K, § 1904(b)(1)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3545"},"text":"132 Stat. 3545","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
