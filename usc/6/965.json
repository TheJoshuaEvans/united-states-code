{"tag":"section","attrib":{"id":"idb562a930-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s965"},"text":null,"children":[{"tag":"num","attrib":{"value":"965"},"text":"§ 965.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tier 2 participants in C–TPAT","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb562a931-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s965/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Validation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Commissioner, shall validate the security measures and supply chain security practices of a Tier 1 participant in accordance with the guidelines referred to in subsection (c). Such validation shall include on-site assessments at appropriate foreign locations utilized by the Tier 1 participant in its supply chain and shall, to the extent practicable, be completed not later than 1 year after certification as a Tier 1 participant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a932-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s965/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Commissioner, shall extend benefits to each C–TPAT participant that has been validated as a Tier 2 participant under this section, which may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb562a933-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s965/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduced scores in the Automated Targeting System;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a934-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s965/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduced examinations of cargo; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a935-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s965/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priority searches of cargo.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a936-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s965/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-13"},"text":"October 13, 2006","children":[],"tail":", the Secretary, acting through the Commissioner, shall develop a schedule and update the guidelines for validating a participant’s security measures and supply chain security practices under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb562a937-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tII/s215"},"text":"Pub. L. 109–347, title II, § 215","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1910"},"text":"120 Stat. 1910","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
