{"tag":"section","attrib":{"id":"idb57a7751-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1509"},"text":null,"children":[{"tag":"num","attrib":{"value":"1509"},"text":"§ 1509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception to limitation on authority of Secretary of Defense to disseminate certain information","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding subsection (c)(3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s393"},"text":"section 393 of title 10","children":[],"tail":", the Secretary of Defense may authorize the sharing of cyber threat indicators and defensive measures pursuant to the policies, procedures, and guidelines developed or issued under this subchapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb57a7752-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dN/tI/s110"},"text":"Pub. L. 114–113, div. N, title I, § 110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2956"},"text":"129 Stat. 2956","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
