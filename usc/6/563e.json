{"tag":"section","attrib":{"id":"idb5330dbd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563e"},"text":null,"children":[{"tag":"num","attrib":{"value":"563e"},"text":"§ 563e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consistency with the Federal Acquisition Regulation and departmental policies and directives","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall execute the responsibilities set forth in this part in a manner consistent with, and not duplicative of, the Federal Acquisition Regulation and the Department’s policies and directives.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5330dbe-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVI/s1616"},"text":"Pub. L. 107–296, title XVI, § 1616","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/245/s3/a"},"text":"Pub. L. 113–245, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2877"},"text":"128 Stat. 2877","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
