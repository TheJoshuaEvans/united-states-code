{"tag":"section","attrib":{"id":"idb50f3213-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321h"},"text":null,"children":[{"tag":"num","attrib":{"value":"321h"},"text":"§ 321h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of national private sector networks in emergency response","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"To the maximum extent practicable, the Secretary shall use national private sector networks and infrastructure for emergency response to chemical, biological, radiological, nuclear, or explosive disasters, and other major disasters.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb50f3214-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tV/s519"},"text":"Pub. L. 107–296, title V, § 519","children":[],"tail":", formerly § 508, "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2215"},"text":"116 Stat. 2215","children":[],"tail":"; renumbered § 519, "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s611/6"},"text":"Pub. L. 109–295, title VI, § 611(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1395"},"text":"120 Stat. 1395","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb50f3215-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb50f3216-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb50f3217-47c4-11f1-9665-b3e99855dc0d