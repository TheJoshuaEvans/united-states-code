{"tag":"section","attrib":{"id":"idb4e90ce1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142"},"text":null,"children":[{"tag":"num","attrib":{"value":"142"},"text":"§ 142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4e90ce2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment and responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall appoint a senior official in the Department, who shall report directly to the Secretary, to assume primary responsibility for privacy policy, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e90ce3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assuring that the use of technologies sustain, and do not erode, privacy protections relating to the use, collection, and disclosure of personal information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90ce4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assuring that personal information contained in Privacy Act systems of records is handled in full compliance with fair information practices as set out in the Privacy Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"5 U.S.C. 552a","children":[],"tail":"];"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90ce5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating legislative and regulatory proposals involving collection, use, and disclosure of personal information by the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90ce6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting a privacy impact assessment of proposed rules of the Department or that of the Department on the privacy of personal information, including the type of personal information collected and the number of people affected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90ce7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" coordinating with the Officer for Civil Rights and Civil Liberties to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e90ce8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs, policies, and procedures involving civil rights, civil liberties, and privacy considerations are addressed in an integrated and comprehensive manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90ce9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress receives appropriate reports on such programs, policies, and procedures; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90cea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparing a report to Congress on an annual basis on activities of the Department that affect privacy, including complaints of privacy violations, implementation of the Privacy Act of 1974 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"5 U.S.C. 552a","children":[],"tail":"], internal controls, and other matters."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e90ceb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to investigate","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e90cec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The senior official appointed under subsection (a) may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e90ced-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have access to all records, reports, audits, reviews, documents, papers, recommendations, and other materials available to the Department that relate to programs and operations with respect to the responsibilities of the senior official under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90cee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such investigations and reports relating to the administration of the programs and operations of the Department as are, in the senior official’s judgment, necessary or desirable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90cef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the approval of the Secretary, require by subpoena the production, by any person other than a Federal agency, of all information, documents, reports, answers, records, accounts, papers, and other data and documentary evidence necessary to performance of the responsibilities of the senior official under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90cf0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer to or take from any person an oath, affirmation, or affidavit, whenever necessary to performance of the responsibilities of the senior official under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90cf1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of subpoenas","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any subpoena issued under paragraph (1)(C) shall, in the case of contumacy or refusal to obey, be enforceable by order of any appropriate United States district court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90cf2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of oaths","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any oath, affirmation, or affidavit administered or taken under paragraph (1)(D) by or before an employee of the Privacy Office designated for that purpose by the senior official appointed under subsection (a) shall have the same force and effect as if administered or taken by or before an officer having a seal of office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e90cf3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supervision and coordination","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e90cf4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The senior official appointed under subsection (a) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e90cf5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to, and be under the general supervision of, the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90cf6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate activities with the Inspector General of the Department in order to avoid duplication of effort.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90cf7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with the Inspector General","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e90cf8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subparagraph (B), the senior official appointed under subsection (a) may investigate any matter relating to possible violations or abuse concerning the administration of any program or operation of the Department relevant to the purposes under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90cf9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4e90cfa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Referral","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before initiating any investigation described under subparagraph (A), the senior official shall refer the matter and all related complaints, allegations, and information to the Inspector General of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4e90cfb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determinations and notifications by the Inspector General","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb4e90cfc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the receipt of a matter referred under clause (i), the Inspector General shall—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idb4e90cfd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/2/B/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a determination regarding whether the Inspector General intends to initiate an audit or investigation of the matter referred under clause (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb4e90cfe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/2/B/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the senior official of that determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb4e90cff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation not initiated","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Inspector General notifies the senior official under subclause (I)(bb) that the Inspector General intended to initiate an audit or investigation, but does not initiate that audit or investigation within 90 days after providing that notification, the Inspector General shall further notify the senior official that an audit or investigation was not initiated. The further notification under this subclause shall be made not later than 3 days after the end of that 90-day period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4e90d00-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigation by senior official","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The senior official may investigate a matter referred under clause (i) if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb4e90d01-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/2/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Inspector General notifies the senior official under clause (ii)(I)(bb) that the Inspector General does not intend to initiate an audit or investigation relating to that matter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb4e90d02-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/2/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Inspector General provides a further notification under clause (ii)(II) relating to that matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4e90d03-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/c/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy training","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any employee of the Office of Inspector General who audits or investigates any matter referred under clause (i) shall be required to receive adequate training on privacy laws, rules, and regulations, to be provided by an entity approved by the Inspector General in consultation with the senior official appointed under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e90d04-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to Congress on removal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary removes the senior official appointed under subsection (a) or transfers that senior official to another position or location within the Department, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e90d05-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promptly submit a written notification of the removal or transfer to Houses of Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d06-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in any such notification the reasons for the removal or transfer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e90d07-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by senior official to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The senior official appointed under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e90d08-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit reports directly to the Congress regarding performance of the responsibilities of the senior official under this section, without any prior comment or amendment by the Secretary, Deputy Secretary, or any other officer or employee of the Department or the Office of Management and Budget; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e90d09-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" inform the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Homeland Security of the House of Representatives not later than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e90d0a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 days after the Secretary disapproves the senior official’s request for a subpoena under subsection (b)(1)(C) or the Secretary substantively modifies the requested subpoena; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e90d0b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s142/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 45 days after the senior official’s request for a subpoena under subsection (b)(1)(C), if that subpoena has not either been approved or disapproved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4e90d0c-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tII/s222"},"text":"Pub. L. 107–296, title II, § 222","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2155"},"text":"116 Stat. 2155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVIII/s8305"},"text":"Pub. L. 108–458, title VIII, § 8305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3868"},"text":"118 Stat. 3868","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tVIII/s802"},"text":"Pub. L. 110–53, title VIII, § 802","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/358"},"text":"121 Stat. 358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4e90d0d-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4e90d0e-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4e90d0f-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Privacy Act of 1974, referred to in subsec. (a)(2), (6), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/579"},"text":"Pub. L. 93–579","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1896"},"text":"88 Stat. 1896","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":", Government Organization and Employees, and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1974 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of Title 5","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4e90d10-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53"},"text":"Pub. L. 110–53","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsecs. (b) to (e)."}],"tail":"\n"},{"