{"tag":"section","attrib":{"id":"idb511a328-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321p"},"text":null,"children":[{"tag":"num","attrib":{"value":"321p"},"text":"§ 321p.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National planning and education","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall, to the extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb511a329-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321p/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in national planning frameworks the threat of an EMP or GMD event; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511a32a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321p/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct outreach to educate owners and operators of critical infrastructure, emergency planners, and emergency response providers at all levels of government regarding threats of EMP and GMD.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb511a32b-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tV/s527"},"text":"Pub. L. 107–296, title V, § 527","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXIX/s1913/a/4"},"text":"Pub. L. 114–328, div. A, title XIX, § 1913(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2686"},"text":"130 Stat. 2686","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
