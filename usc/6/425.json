{"tag":"section","attrib":{"id":"idb51d8b36-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s425"},"text":null,"children":[{"tag":"num","attrib":{"value":"425"},"text":"§ 425.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of certain commercial items authorities to certain procurements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb51d8b37-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s425/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51d8b38-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s425/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The head of an executive agency may apply the provisions of law listed in paragraph (2) to a procurement referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s422"},"text":"section 422 of this title","children":[],"tail":" without regard to whether the property or services are commercial items."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51d8b39-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s425/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial item laws","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The provisions of law referred to in paragraph (1) are as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51d8b3a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s425/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 1901 and 1906 of title 41.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8b3b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s425/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3205"},"text":"Section 3205 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8b3c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s425/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s3305"},"text":"Section 3305 of title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51d8b3d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s425/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of limitation on use of simplified acquisition procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51d8b3e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s425/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The $5,000,000 limitation provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1901/a/2"},"text":"section 1901(a)(2) of title 41","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3205/a/2"},"text":"section 3205(a)(2) of title 10","children":[],"tail":", and "},{"tag"