{"tag":"section","attrib":{"id":"idb51b18d5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s381"},"text":null,"children":[{"tag":"num","attrib":{"value":"381"},"text":"§ 381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions transferred","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In accordance with subchapter XII, there shall be transferred to the Secretary the functions, personnel, assets, and obligations of the United States Secret Service, which shall be maintained as a distinct entity within the Department, including the functions of the Secretary of the Treasury relating thereto.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb51b18d6-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s821"},"text":"Pub. L. 107–296, title VIII, § 821","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2224"},"text":"116 Stat. 2224","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
