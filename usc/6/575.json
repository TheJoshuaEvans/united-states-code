{"tag":"section","attrib":{"id":"idb5330e4d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575"},"text":null,"children":[{"tag":"num","attrib":{"value":"575"},"text":"§ 575.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional emergency communications coordination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5330e4e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in each Regional Office a Regional Emergency Communications Coordination Working Group (in this section referred to as an “RECC Working Group”). Each RECC Working Group shall report to the relevant Regional Administrator and coordinate its activities with the relevant Regional Advisory Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330e4f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each RECC Working Group shall consist of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5330e50-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Organizations representing the interests of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5330e51-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State officials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330e52-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local government officials, including sheriffs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330e53-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State police departments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330e54-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local police departments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330e55-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local fire departments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330e56-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public safety answering points (9–1–1 services).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330e57-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State emergency managers, homeland security directors, or representatives of State Administrative Agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330e58-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local emergency managers or homeland security directors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5330e59-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other emergency response providers as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e5a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Representatives from the Department, the Federal Communications Commission, and other Federal departments and agencies with responsibility for coordinating interoperable emergency communications with or providing emergency support services to State, local, and tribal governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330e5b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each RECC Working Group shall coordinate its activities with the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5330e5c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communications equipment manufacturers and vendors (including broadband data service providers).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e5d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local exchange carriers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e5e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Local broadcast media.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e5f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Wireless carriers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e60-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Satellite communications services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e61-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cable operators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e62-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hospitals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e63-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public utility services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e64-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency evacuation transit services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e65-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ambulance services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e66-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" HAM and amateur radio operators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e67-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Representatives from other private sector entities and nongovernmental organizations as the Regional Administrator determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330e68-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of each RECC Working Group shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5330e69-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the survivability, sustainability, and interoperability of local emergency communications systems to meet the goals of the National Emergency Communications Plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e6a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reporting annually to the relevant Regional Administrator, the Assistant Director for Emergency Communications, the Chairman of the Federal Communications Commission, and the Assistant Secretary for Communications and Information of the Department of Commerce on the status of its region in building robust and sustainable interoperable voice and data emergency communications networks and, not later than 60 days after the completion of the initial National Emergency Communications Plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s572"},"text":"section 572 of this title","children":[],"tail":", on the progress of the region in meeting the goals of such plan;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330e6b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring a process for the coordination of effective multijurisdictional, multi-agency emergency communications networks for use during natural disasters, acts of terrorism, and other man-made disasters through the expanded use of emergency management and public safety communications mutual aid agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb535575c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s575/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating the establishment of Federal, State, local, and tribal support services and networks designed to address the immediate and critical human needs in responding to natural disasters, acts of terrorism, and other man-made disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb535575d-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVIII/s1805"},"text":"Pub. L. 107–296, title XVIII, § 1805","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s671/b"},"text":"Pub. L. 109–295, title VI, § 671(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1439"},"text":"120 Stat. 1439","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/6/B"},"text":"Pub. L. 115–278, § 2(g)(6)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4179"},"text":"132 Stat. 4179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb535575e-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb535575f-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5355760-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1805"},"text":"section 1805 of Pub. L. 107–296","children":[],"tail":" was renumbered section 1905 and was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s595"},"text":"section 595 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/387/s2/a/4"},"text":"Pub. L. 115–387, § 2(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5163"},"text":"132 Stat. 5163","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5355761-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278"},"text":"Pub. L. 115–278","children":[],"tail":" substituted “Assistant Director for Emergency Communications” for “Director for Emergency Communications”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5355762-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb5355763-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Assistant Director for Emergency Communications deemed to be a reference to the Executive Assistant Director for Emergency Communications, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s571/g"},"text":"section 571(g) of this title","children":[],"tail":", enacted "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
