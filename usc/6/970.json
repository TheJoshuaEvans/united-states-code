{"tag":"section","attrib":{"id":"idb562a978-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s970"},"text":null,"children":[{"tag":"num","attrib":{"value":"970"},"text":"§ 970.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncontainerized cargo","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Commissioner, shall consider the potential for participation in C–TPAT by importers of noncontainerized cargoes that otherwise meet the requirements under this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb562a979-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tII/s220"},"text":"Pub. L. 109–347, title II, § 220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1914"},"text":"120 Stat. 1914","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
