{"tag":"section","attrib":{"id":"idb543afcb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s653"},"text":null,"children":[{"tag":"num","attrib":{"value":"653"},"text":"§ 653.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity Division","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb543afcc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s653/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543afcd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s653/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Agency a Cybersecurity Division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afce-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s653/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Assistant Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Cybersecurity Division shall be headed by an Executive Assistant Director for Cybersecurity (in this section referred to as “the Executive Assistant Director”), who shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb543afcf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s653/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be at the level of Assistant Secretary within the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543afd0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s653/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the President without the advice and consent of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543afd1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s653/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afd2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s653/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference to the Assistant Secretary for Cybersecurity and Communications or Assistant Director for Cybersecurity in any law, regulation, map, document, record, or other paper of the United States shall be deemed to be a reference to the Executive Assistant Director for Cybersecurity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543afd3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s653/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Assistant Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543afd4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s653/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct the cybersecurity efforts of the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afd5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s653/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out activities, at the direction of the Director, related to the security of Federal information and Federal information systems consistent with law, including subchapter II of chapter 35 of title 44 and the Cybersecurity Act of 2015 (contained in division N of the Consolidated Appropriations Act, 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Public Law 114–113","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afd6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s653/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fully participate in the mechanisms required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s652/c/7"},"text":"section 652(c)(7) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afd7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s653/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such other duties and powers as prescribed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb543afd8-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2203"},"text":"Pub. L. 107–296, title XXII, § 2203","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/a"},"text":"Pub. L. 115–278, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4174"},"text":"132 Stat. 4174","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXC/s9001/c/1"},"text":"Pub. L. 116–283, div. H, title XC, § 9001(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4766"},"text":"134 Stat. 4766","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb543afd9-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb543afda-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb543afdb-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Cybersecurity Act of 2015, referred to in subsec. (b)(2), is div. N of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2835"},"text":"129 Stat. 2835","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s1501"},"text":"section 1501 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb543afdc-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9001/c/1/A/i"},"text":"Pub. L. 116–283, § 9001(c)(1)(A)(i)","children":[],"tail":", in heading, substituted “Executive Assistant Director” for “Assistant Director” and, in introductory provisions, substituted “Executive Assistant Director for Cybersecurity” for “Assistant Director for Cybersecurity” and “ ‘the Executive Assistant Director’ ” for “the ‘Assistant Director’ ”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9001/c/1/A/ii"},"text":"Pub. L. 116–283, § 9001(c)(1)(A)(ii)","children":[],"tail":", inserted “or Assistant Director for Cybersecurity” after “Assistant Secretary for Cybersecurity” and substituted “Executive Assistant Director for Cybersecurity.” for “Assistant Director for Cybersecurity.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9001/c/1/B"},"text":"Pub. L. 116–283, § 9001(c)(1)(B)","children":[],"tail":", substituted “Executive Assistant Director” for “Assistant Director” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb543afdd-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb543afde-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuation in Office","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXC/s9001/c/2"},"text":"Pub. L. 116–283, div. H, title XC, § 9001(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4767"},"text":"134 Stat. 4767","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dH/tXC/s9001/c/2"},"text":"“The individual serving as the Assistant Director for Cybersecurity of the Cybersecurity and Infrastructure Security Agency of the Department of Homeland Security on the day before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"] may serve as the Executive Assistant Director for Cybersecurity on and after that date without the need for renomination or reappointment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb543afdf-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Assistant Secretary for Cybersecurity and Communications Authorized To Serve as Assistant Director for Cybersecurity","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/b/3"},"text":"Pub. L. 115–278, § 2(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4175"},"text":"132 Stat. 4175","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/278/s2/b/3"},"text":"“The individual serving as the Assistant Secretary for Cybersecurity and Communications on the day before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":"] may continue to serve as the Assistant Director for Cybersecurity on and after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
