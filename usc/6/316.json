{"tag":"section","attrib":{"id":"idb50a77ed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s316"},"text":null,"children":[{"tag":"num","attrib":{"value":"316"},"text":"§ 316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preserving the Federal Emergency Management Agency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb50a77ee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distinct entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Agency shall be maintained as a distinct entity within the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50a77ef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reorganization","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s452"},"text":"Section 452 of this title","children":[],"tail":" shall not apply to the Agency, including any function or organizational unit of the Agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50a77f0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s316/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on changes to missions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50a77f1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s316/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not substantially or significantly reduce, including through a Joint Task Force established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s348"},"text":"section 348 of this title","children":[],"tail":", the authorities, responsibilities, or functions of the Agency or the capability of the Agency to perform those missions, authorities, responsibilities,"},{"tag":"ref","attrib":{"idref":"fn002052"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002052"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “authorities, responsibilities, or functions”."}],"tail":" except as otherwise specifically provided in an Act enacted after "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50a77f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s316/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain transfers prohibited","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No asset, function, or mission of the Agency may be diverted to the principal and continuing use of any other organization, unit, or entity of the Department, including a Joint Task Force established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s348"},"text":"section 348 of this title","children":[],"tail":", except for details or assignments that do not reduce the capability of the Agency to perform its missions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50a77f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s316/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reprogramming and transfer of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In reprogramming or transferring funds, the Secretary shall comply with any applicable provisions of any Act making appropriations for the Department for fiscal year 2007, or any succeeding fiscal year, relating to the reprogramming or transfer of funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb50a77f4-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tV/s506"},"text":"Pub. L. 107–296, title V, § 506","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s611/13"},"text":"Pub. L. 109–295, title VI, § 611(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1400"},"text":"120 Stat. 1400","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXIX/s1901/d/1"},"text":"Pub. L. 114–328, div. A, title XIX, § 1901(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2670"},"text":"130 Stat. 2670","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb50a77f5-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb50a77f6-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb50a77f7-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s506"},"text":"section 506 of Pub. L. 107–296","children":[],"tail":" was renumbered section 502 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s312"},"text":"section 312 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb50a77f8-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1901/d/1/A"},"text":"Pub. L. 114–328, § 1901(d)(1)(A)","children":[],"tail":", inserted “, including through a Joint Task Force established under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s348"},"text":"section 348 of this title","children":[],"tail":", after “reduce”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1901/d/1/B"},"text":"Pub. L. 114–328, § 1901(d)(1)(B)","children":[],"tail":", inserted “including a Joint Task Force established under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s348"},"text":"section 348 of this title","children":[],"tail":",” after “Department,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
