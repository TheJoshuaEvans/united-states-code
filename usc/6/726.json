{"tag":"section","attrib":{"id":"idb5593358-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s726"},"text":null,"children":[{"tag":"num","attrib":{"value":"726"},"text":"§ 726.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic life supporting first aid and education","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Administrator shall enter into agreements with organizations to provide funds to emergency response providers to provide education and training in life supporting first aid to children.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5593359-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s639"},"text":"Pub. L. 109–295, title VI, § 639","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1423"},"text":"120 Stat. 1423","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
