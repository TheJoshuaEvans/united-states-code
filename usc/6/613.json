{"tag":"section","attrib":{"id":"idb53c8471-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613"},"text":null,"children":[{"tag":"num","attrib":{"value":"613"},"text":"§ 613.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of reporting redundancies and development of performance metrics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb53c8472-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “covered grants” means grants awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s604"},"text":"section 604 of this title","children":[],"tail":", grants awarded under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s605"},"text":"section 605 of this title","children":[],"tail":", and any other grants specified by the Administrator."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c8473-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2010-10-12"},"text":"October 12, 2010","children":[],"tail":", the Administrator shall submit to the appropriate committees of Congress a report that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53c8474-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of redundant reporting requirements imposed by the Administrator on State, local, and tribal governments in connection with the awarding of grants, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c8475-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of each discrete item of data requested by the Administrator from grant recipients as part of the process of administering covered grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8476-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of the items of data from the list described in subparagraph (A) that are required to be submitted by grant recipients on multiple occasions or to multiple systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8477-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of the items of data from the list described in subparagraph (A) that are not necessary to be collected in order for the Administrator to effectively and efficiently administer the programs under which covered grants are awarded;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c8478-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan, including a specific timetable, for eliminating any redundant and unnecessary reporting requirements identified under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c8479-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan, including a specific timetable, for promptly developing a set of quantifiable performance measures and metrics to assess the effectiveness of the programs under which covered grants are awarded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c847a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date on which the initial report is required to be submitted under subsection (b), and once every 2 years thereafter, the Administrator shall submit to the appropriate committees of Congress a grants management report that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53c847b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the status of efforts to eliminate redundant and unnecessary reporting requirements imposed on grant recipients, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c847c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress made in implementing the plan required under subsection (b)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c847d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reassessment of the reporting requirements to identify and eliminate redundant and unnecessary requirements;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c847e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the status of efforts to develop quantifiable performance measures and metrics to assess the effectiveness of the programs under which the covered grants are awarded, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c847f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress made in implementing the plan required under subsection (b)(3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8480-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress made in developing and implementing additional performance metrics and measures for grants, including as part of the comprehensive assessment system required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s749"},"text":"section 749 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c8481-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a performance assessment of each program under which the covered grants are awarded, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c8482-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the objectives and goals of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8483-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the extent to which the objectives and goals described in subparagraph (A) have been met, based on the quantifiable performance measures and metrics required under this section, section 612(a)(4) ","children":[{"tag":"ref","attrib":{"idref":"fn002101"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002101"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s749"},"text":"section 749 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8484-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for any program modifications to improve the effectiveness of the program, to address changed or emerging conditions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8485-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the experience of recipients of covered grants, including the availability of clear and accurate information, the timeliness of reviews and awards, and the provision of technical assistance, and recommendations for improving that experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c8486-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants program measurement study","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53c8487-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after ","children":[{"tag":"date","attrib":{"date":"2010-10-12"},"text":"October 12, 2010","children":[],"tail":", the Administrator shall enter into a contract with the National Academy of Public Administration under which the National Academy of Public Administration shall assist the Administrator in studying, developing, and implementing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c8488-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantifiable performance measures and metrics to assess the effectiveness of grants administered by the Department, as required under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s749"},"text":"section 749 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8489-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan required under subsection (b)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c848a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the date on which the contract described in paragraph (1) is awarded, the Administrator shall submit to the appropriate committees of Congress a report that describes the findings and recommendations of the study conducted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c848b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s613/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to the Administrator such sums as may be necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53c848c-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXX/s2023"},"text":"Pub. L. 107–296, title XX, § 2023","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/271/s2/a"},"text":"Pub. L. 111–271, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-12"},"text":"Oct. 12, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2852"},"text":"124 Stat. 2852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb53c848d-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb53c848e-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb53c848f-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s612/a/4"},"text":"Section 612(a)(4) of this title","children":[],"tail":", referred to in subsec. (c)(3)(B), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s612/a/3"},"text":"section 612(a)(3) of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/113/284/s2/c/2/A"},"text":"Pub. L. 113–284, § 2(c)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3089"},"text":"128 Stat. 3089","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
