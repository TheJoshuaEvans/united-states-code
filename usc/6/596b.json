{"tag":"section","attrib":{"id":"idb537c97a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b"},"text":null,"children":[{"tag":"num","attrib":{"value":"596b"},"text":"§ 596b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securing the Cities program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb537c97b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, through the Assistant Secretary, shall establish a program, to be known as the “Securing the Cities” or “STC” program, to enhance the ability of the United States to detect and prevent terrorist attacks and other high-consequence events utilizing nuclear or other radiological materials that pose a high risk to homeland security in high-risk urban areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c97c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Through the STC program the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb537c97d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist State, local, Tribal, and territorial governments in designing and implementing, or enhancing existing, architectures for coordinated and integrated detection and interdiction of nuclear or other radiological materials that are out of regulatory control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c97e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development of an operating capability to detect and report on nuclear and other radiological materials out of regulatory control;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c97f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide resources to enhance detection, analysis, communication, and coordination to better integrate State, local, Tribal, and territorial assets into Federal operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c980-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate alarm adjudication and provide subject matter expertise and technical assistance on concepts of operations, training, exercises, and alarm response protocols;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c981-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicate with, and promote sharing of information about the presence or detection of nuclear or other radiological materials among appropriate Federal, State, local, Tribal, and territorial government agencies, in a manner that ensures transparency with the jurisdictions designated under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c982-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide augmenting resources, as appropriate, to enable State, local, Tribal, and territorial governments to sustain and refresh their capabilities developed under the STC program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c983-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor expenditures under the STC program and track performance in meeting the goals of the STC program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c984-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide any other assistance the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c985-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of jurisdictions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb537c986-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the STC program under subsection (a), the Secretary shall designate jurisdictions from among high-risk urban areas under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s604"},"text":"section 604 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c987-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify the Committee on Homeland Security and the Committee on Appropriations of the House of Representatives and the Committee on Homeland Security and Governmental Affairs and the Committee on Appropriations of the Senate not later than 3 days before the designation of a new jurisdiction under paragraph (1) or any change to a jurisdiction previously designated under that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c988-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accountability","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb537c989-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation plan","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb537c98a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop, in consultation with relevant stakeholders, an implementation plan for carrying out the STC program that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb537c98b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discussion of the goals of the STC program and a strategy to achieve those goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb537c98c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance metrics and milestones for the STC program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb537c98d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measures for achieving and sustaining capabilities under the STC program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb537c98e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs associated with achieving the goals of the STC program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c98f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2018-12-21"},"text":"December 21, 2018","children":[],"tail":", the Secretary shall submit to the appropriate congressional committees and the Comptroller General of the United States the implementation plan required by subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c990-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after the submission of the implementation plan under paragraph (1)(B), the Secretary shall submit to the appropriate congressional committees and the Comptroller General a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb537c991-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the effectiveness of the STC program, based on the performance metrics and milestones required by paragraph (1)(A)(ii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c992-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposals for any changes to the STC program, including an explanation of how those changes align with the strategy and goals of the STC program and, as appropriate, address any challenges faced by the STC program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c993-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller general review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after the submission of the report required by paragraph (2), the Comptroller General of the United States shall submit to the appropriate congressional committees a report evaluating the implementation plan required by paragraph (1) and the report required by paragraph (2), including an assessment of progress made with respect to the performance metrics and milestones required by paragraph (1)(A)(ii) and the sustainment of the capabilities of the STC program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c994-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefing and submission requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before making any changes to the structure or requirements of the STC program, the Assistant Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb537c995-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the appropriate congressional committees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c996-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide to those committees—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb537c997-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a briefing on the proposed changes, including a justification for the changes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb537c998-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation relating to the changes, including plans, strategies, and resources to implement the changes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb537c999-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596b/d/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the effect of the changes on the capabilities of the STC program, taking into consideration previous resource allocations and stakeholder input.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb537c99a-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIX/s1928"},"text":"Pub. L. 107–296, title XIX, § 1928","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/387/s2/a/10"},"text":"Pub. L. 115–387, § 2(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5164"},"text":"132 Stat. 5164","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
