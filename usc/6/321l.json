{"tag":"section","attrib":{"id":"idb50f3232-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l"},"text":null,"children":[{"tag":"num","attrib":{"value":"321l"},"text":"§ 321l.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance and recommendations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb50f3233-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Consistent with their responsibilities and authorities under law, as of the day before ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", the Administrator and the Director of the Cybersecurity and Infrastructure Security Agency, in consultation with the private sector, may develop guidance or recommendations and identify best practices to assist or foster action by the private sector in—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50f3234-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying potential hazards and assessing risks and impacts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50f3235-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mitigating the impact of a wide variety of hazards, including weapons of mass destruction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50f3236-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" managing necessary emergency preparedness and response resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50f3237-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing mutual aid agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50f3238-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and maintaining emergency preparedness and response plans, and associated operational procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50f3239-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and conducting training and exercises to support and evaluate emergency preparedness and response plans and operational procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50f323a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and conducting training programs for security guards to implement emergency preparedness and response plans and operations procedures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50f323b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing procedures to respond to requests for information from the media or the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50f323c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance and promotion","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any guidance or recommendations developed or best practices identified under subsection (a) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50f323d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued through the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50f323e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoted by the Secretary to the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50f323f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business concerns","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing guidance or recommendations or identifying best practices under subsection (a), the Administrator and the Director of the Cybersecurity and Infrastructure Security Agency shall take into consideration small business concerns (under the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of title 15","children":[],"tail":"), including any need for separate guidance or recommendations or best practices, as necessary and appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50f3240-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321l/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed to supersede any requirement established under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb50f3241-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tV/s523"},"text":"Pub. L. 107–296, title V, § 523","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tIX/s901/a"},"text":"Pub. L. 110–53, title IX, § 901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/364"},"text":"121 Stat. 364","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/4/C"},"text":"Pub. L. 115–278, § 2(g)(4)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4178"},"text":"132 Stat. 4178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7143/c/1"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7143(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3662"},"text":"136 Stat. 3662","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb50f3242-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb50f3243-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb50f3244-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “Director of the Cybersecurity and Infrastructure Security Agency” for “Director of Cybersecurity and Infrastructure Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278"},"text":"Pub. L. 115–278","children":[],"tail":" substituted “Director of Cybersecurity and Infrastructure Security” for “Assistant Secretary for Infrastructure Protection”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb50f3245-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb50f3246-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in amendment made by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" to be construed to alter the authorities, responsibilities, functions, or activities of any agency (as such term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3502"},"text":"44 U.S.C. 3502","children":[],"tail":") or officer or employee of the United States on or before "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/f/1"},"text":"section 7143(f)(1) of Pub. L. 117–263","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s650"},"text":"section 650 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
