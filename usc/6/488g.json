{"tag":"section","attrib":{"id":"idb52be261-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488g"},"text":null,"children":[{"tag":"num","attrib":{"value":"488g"},"text":"§ 488g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption of other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb52be262-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other Federal regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s488f"},"text":"section 488f of this title","children":[],"tail":", nothing in this part affects any regulation issued by any agency other than an agency of the Department."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be263-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State law","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s488f"},"text":"section 488f of this title","children":[],"tail":", this part preempts the laws of any State to the extent that such laws are inconsistent with this part, except that this part shall not preempt any State law that provides additional protection against the acquisition of ammonium nitrate by terrorists or the use of ammonium nitrate in explosives in acts of terrorism or for other illicit purposes, as determined by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb52be264-47c4-11f1-9665-b3e99855dc0d"},"text