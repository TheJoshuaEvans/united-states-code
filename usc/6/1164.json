{"tag":"section","attrib":{"id":"idb56e909b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164"},"text":null,"children":[{"tag":"num","attrib":{"value":"1164"},"text":"§ 1164.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Systemwide Amtrak security upgrades","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56e909c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e909d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b), the Secretary, in consultation with the Administrator of the Transportation Security Administration, is authorized to make grants to Amtrak in accordance with the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e909e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make such grants for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56e909f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting underwater and underground assets and systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90a0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protecting high-risk and high-consequence assets identified through systemwide risk assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90a1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing counterterrorism or security training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90a2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing both visible and unpredictable deterrence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90a3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting emergency preparedness drills and exercises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e90a4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specific projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make such grants—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56e90a5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to secure major tunnel access points and ensure tunnel integrity in New York, New Jersey, Maryland, and Washington, DC;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90a6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to secure Amtrak trains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90a7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to secure Amtrak stations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90a8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain a watchlist identification system approved by the Secretary, or to connect to the National Terrorism Screening Center watchlist;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90a9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain train tracking and interoperable communications systems that are coordinated with Federal, State, and local agencies and tribal governments to the maximum extent possible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90aa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to hire, train, and employ police and security officers, including canine units, assigned to full-time security or counterterrorism duties related to railroad transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90ab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for operating and capital costs associated with security awareness, preparedness, and response training, including training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1167"},"text":"section 1167 of this title","children":[],"tail":", and training developed by universities, institutions of higher education, and nonprofit employee labor organizations, for railroad employees, including frontline employees;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90ac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for live or simulated exercises, including exercises described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1166"},"text":"section 1166 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90ad-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for improvements to passenger verification systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90ae-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for improvements to employee and contractor verification systems, including identity verification technology; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90af-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/a/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for improvements to the security of Amtrak computer systems, including cybersecurity assessments and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e90b0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall award grants to Amtrak under this section for projects contained in a systemwide security plan approved by the Secretary developed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1162"},"text":"section 1162 of this title","children":[],"tail":". Not later than 5 business days after awarding a grant to Amtrak under this section, the Secretary shall transfer the grant funds to the Secretary of Transportation to be disbursed to Amtrak."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e90b1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitable geographic allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that, subject to meeting the highest security needs on Amtrak’s entire system and consistent with the risk assessment required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1161"},"text":"section 1161 of this title","children":[],"tail":" and Amtrak’s vulnerability assessment and security plan developed under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s1162"},"text":"section 1162 of this title","children":[],"tail":", stations and facilities located outside of the Northeast Corridor receive an equitable share of the security funds authorized by this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e90b2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e90b3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Out of funds appropriated pursuant to section 114(w) ","children":[{"tag":"ref","attrib":{"idref":"fn002160"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002160"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 49, there shall be made available to the Secretary and the Administrator of the Transportation Security Administration to carry out this section—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56e90b4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90b5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90b6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $175,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e90b7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $175,000,000 for fiscal year 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e90b8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1164/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of appropriated funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts appropriated pursuant to paragraph (1) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56e90b9-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXV/s1514"},"text":"Pub. L. 110–53, title XV, § 1514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/435"},"text":"121 Stat. 435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1973/b"},"text":"Pub. L. 115–254, div. K, title I, § 1973(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3614"},"text":"132 Stat. 3614","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb56e90ba-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb56e90bb-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb56e90bc-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s114/w"},"text":"Section 114(w) of title 49","children":[],"tail":", referred to in subsec. (d)(1), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s114/v"},"text":"section 114(v) of title 49","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/s1904/b/1/I"},"text":"Pub. L. 115–254, div. K, § 1904(b)(1)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3545"},"text":"132 Stat. 3545","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb56e90bd-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1973/b/1"},"text":"Pub. L. 115–254, § 1973(b)(1)","children":[],"tail":", inserted “, or to connect to the National Terrorism Screening Center watchlist” after “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(I) to (K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1973/b/2"},"text":"Pub. L. 115–254, § 1973(b)(2)","children":[],"tail":"–(4), added subpars. (I) to (K)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb56e90be-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb56e90bf-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Passenger Rail Vetting","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1974"},"text":"Pub. L. 115–254, div. K, title I, § 1974","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3615"},"text":"132 Stat. 3615","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dK/tI/s1974"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date on which the Amtrak Board of Directors submits a request to the Administrator [of the Transportation Security Administration], the Administrator shall issue a decision on the use by Amtrak of the Transportation Security Administration’s Secure Flight Program or a similar passenger vetting system to enhance passenger rail security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a decision under subsection (a), the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the technological, privacy, operational, and security impacts of such a decision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe such impacts in any strategic plan developed under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Strategic Plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Administrator decides to grant the request by Amtrak under subsection (a), the decision shall include a strategic plan for working with rail stakeholders to enhance passenger rail security by—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vetting passengers using terrorist watch lists maintained by the Federal Government or a similar passenger vetting system maintained by the Transportation Security Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where applicable and in consultation with the Commissioner of U.S. Customs and Border Protection, assessing whether the vetting process should be integrated into preclearance operations established under section 813 of the Trade Facilitation and Trade Enforcement Act of 2015 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4432"},"text":"19 U.S.C. 4432","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall notify the appropriate committees of Congress [Committees on Commerce, Science and Transportation and Homeland Security and Governmental Affairs of the Senate and Committee on Homeland Security of the House of Representatives] of any decision made under subsection (a) and the details of the strategic plan under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to limit the Administrator’s authority to set the access to, or terms and conditions of using, the Secure Flight Program or a similar passenger vetting system.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
