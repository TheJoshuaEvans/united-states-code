{"tag":"section","attrib":{"id":"idb4edc7d6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195a"},"text":null,"children":[{"tag":"num","attrib":{"value":"195a"},"text":"§ 195a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency communications interoperability research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4edc7d7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary for Science and Technology, acting through the Director of the Office for Interoperability and Compatibility, shall establish a comprehensive research and development program to support and promote—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4edc7d8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of emergency response providers and relevant government officials to continue to communicate in the event of natural disasters, acts of terrorism, and other man-made disasters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f038d9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" interoperable emergency communications capabilities among emergency response providers and relevant government officials, including by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f038da-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting research on a competitive basis, including through the Directorate of Science and Technology and Homeland Security Advanced Research Projects Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f038db-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considering the establishment of a Center of Excellence under the Department of Homeland Security Centers of Excellence Program focused on improving emergency response providers’ communication capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f038dc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the program established under subsection (a) include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f038dd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting research, development, testing, and evaluation on emergency communication capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f038de-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" understanding the strengths and weaknesses of the public safety communications systems in use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f038df-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examining how current and emerging technology can make emergency response providers more effective, and how Federal, State, local, and tribal government agencies can use this technology in a coherent and cost-effective manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f038e0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigating technologies that could lead to long-term advancements in emergency communications capabilities and supporting research on advanced technologies and potential systemic changes to dramatically improve emergency communications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f038e1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating and validating advanced technology concepts, and facilitating the development and deployment of interoperable emergency communication capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f038e2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of this section, the term “interoperable”, with respect to emergency communications, has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s578"},"text":"section 578 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4f038e3-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIII/s315"},"text":"Pub. L. 107–296, title III, § 315","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s673/a"},"text":"Pub. L. 109–295, title VI, § 673(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1443"},"text":"120 Stat. 1443","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
