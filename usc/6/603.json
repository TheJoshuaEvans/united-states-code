{"tag":"section","attrib":{"id":"idb53a12eb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s603"},"text":null,"children":[{"tag":"num","attrib":{"value":"603"},"text":"§ 603.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeland security grant programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb53a12ec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s603/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grants authorized","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, through the Administrator, may award grants under sections 604, 605, and 609a of this title to State, local, and tribal governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a12ed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s603/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Programs not affected","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"This part shall not be construed to affect any of the following Federal programs:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a12ee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s603/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Firefighter and other assistance programs authorized under the Federal Fire Prevention and Control Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2201"},"text":"15 U.S.C. 2201","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a12ef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s603/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grants authorized under the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a12f0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s603/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency Management Performance Grants under the amendments made by title II of the Implementing Recommendations of the 9/11 Commission Act of 2007.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a12f1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s603/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grants to protect critical infrastructure, including port security grants authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70107"},"text":"section 70107 of title 46","children":[],"tail":" and the grants authorized under title "},{"tag":"ref","attrib":{"idref":"fn002098"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002098"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “titles”."}],"tail":" XIV and XV of the Implementing Recommendations of the 9/11 Commission Act of 2007 ["},{"tag":"ref","attrib":{"href":"/us/usc/t6/s1131"},"text":"6 U.S.C. 1131","children":[],"tail":" et seq., 1151 et seq.] and the amendments made by such titles."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a12f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s603/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Metropolitan Medical Response System authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s723"},"text":"section 723 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a12f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s603/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Interoperable Emergency Communications Grant Program authorized under subchapter XIII.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a12f4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s603/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Grant programs other than those administered by the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a12f5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s603/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a12f6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s603/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The grant programs authorized under sections 604 and 605 of this title shall supercede all grant programs authorized under section 1014 of the USA PATRIOT Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3714"},"text":"42 U.S.C. 3714","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002099"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002099"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a12f7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s603/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The allocation of grants authorized under section 604 or 605 of this title shall be governed by the terms of this part and not by any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53a12f8-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXX/s2002"},"text":"Pub. L. 107–296, title XX, § 2002","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tI/s101"},"text":"Pub. L. 110–53, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/273"},"text":"121 Stat. 273","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/108/s2/b"},"text":"Pub. L. 116–108, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-24"},"text":"Jan. 24, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3295"},"text":"133 Stat. 3295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb53a12f9-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb53a12fa-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb53a12fb-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Fire Prevention and Control Act of 1974, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/498"},"text":"Pub. L. 93–498","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-29"},"text":"Oct. 29, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1535"},"text":"88 Stat. 1535","children":[],"tail":", which is classified principally to chapter 49 (§ 2201 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2201"},"text":"section 2201 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsec. (b)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", which is classified principally to chapter 68 (§ 5121 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Implementing Recommendations of the 9/11 Commission Act of 2007, referred to in subsec. (b)(3), (4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53"},"text":"Pub. L. 110–53","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/266"},"text":"121 Stat. 266","children":[],"tail":". Title II of the Act amended "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s762"},"text":"section 762 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5196c"},"text":"section 5196c of Title 42","children":[],"tail":", The Public Health and Welfare. Title XIV of the Act is classified generally to subchapter III (§ 1131 et seq.) of chapter 4 of this title. Title XV of the Act is classified principally to subchapter IV (§ 1151 et seq.) of chapter 4 of this title. For complete classification of this Act to the Code, see Short Title of 2007 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1014 of the USA PATRIOT Act, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s1014"},"text":"section 1014 of Pub. L. 107–56","children":[],"tail":", which is set out as a note under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb53a12fc-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/108"},"text":"Pub. L. 116–108","children":[],"tail":" substituted “sections 604, 605, and 609a” for “sections 604 and 605”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb53a12fd-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb53a12fe-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Grant Program for State and Local Domestic Preparedness Support","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/tX/s1014"},"text":"Pub. L. 107–56, title X, § 1014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/399"},"text":"115 Stat. 399","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tI/s11003"},"text":"Pub. L. 107–273, div. C, title I, § 11003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1816"},"text":"116 Stat. 1816","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/273/dC/tI/s11003"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office for Domestic Preparedness of the Office of Justice Programs shall make a grant to each State, which shall be used by the State, in conjunction with units of local government, to enhance the capability of State and local jurisdictions to prepare for and respond to terrorist acts including events of terrorism involving weapons of mass destruction and biological, nuclear, radiological, incendiary, chemical, and explosive devices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of grant amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Grants under this section may be used to purchase needed equipment and to provide training and technical assistance to State and local first responders. In addition, grants under this section may be used to construct, develop, expand, modify, operate, or improve facilities to provide training or assistance to State and local first responders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to carry out this section such sums as necessary for each of fiscal years 2002 through 2007.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the amount made available to carry out this section in any fiscal year not more than 3 percent may be used by the Attorney General for salaries and administrative expenses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each State shall be allocated in each fiscal year under this section not less than 0.75 percent of the total amount appropriated in the fiscal year for grants pursuant to this section, except that the United States Virgin Islands, America Samoa, Guam, and the Northern Mariana Islands each shall be allocated not less than 0.25 percent.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For transfer of functions, personnel, assets, and liabilities of the Office for Domestic Preparedness of the Office of Justice Programs, including the functions of the Attorney General relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(5), 551(d), 552(d), and 557 of this title and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
