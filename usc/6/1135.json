{"tag":"section","attrib":{"id":"idb569d575-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135"},"text":null,"children":[{"tag":"num","attrib":{"value":"1135"},"text":"§ 1135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public transportation security assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb569d576-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security assistance program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb569d577-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program for making grants to eligible public transportation agencies for security improvements described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d578-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A public transportation agency is eligible for a grant under this section if the Secretary has performed a security assessment or the agency has developed a security plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1134"},"text":"section 1134 of this title","children":[],"tail":". Grant funds shall only be awarded for permissible uses under subsection (b) to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb569d579-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address items included in a security assessment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d57a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further a security plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d57b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient of a grant under subsection (a) shall use the grant funds for one or more of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb569d57c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Capital uses of funds, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb569d57d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tunnel protection systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d57e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perimeter protection systems, including access control, installation of improved lighting, fencing, and barricades;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d57f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" redundant critical operations control systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d580-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chemical, biological, radiological, or explosive detection systems, including the acquisition of canines used for such detection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d581-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surveillance equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d582-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communications equipment, including mobile service equipment to provide access to wireless Enhanced 911 (E911) emergency services in an underground fixed guideway system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d583-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency response equipment, including personal protective equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d584-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fire suppression and decontamination equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d585-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" global positioning or tracking and recovery equipment, and other automated-vehicle-locator-type system equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d586-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evacuation improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d587-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" purchase and placement of bomb-resistant trash cans throughout public transportation facilities, including subway exits, entrances, and tunnels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d588-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital costs associated with security awareness, security preparedness, and security response training, including training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1137"},"text":"section 1137 of this title","children":[],"tail":" and exercises under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s1136"},"text":"section 1136 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d589-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security improvements for public transportation systems, including extensions thereto, in final design or under construction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d58a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security improvements for stations and other public transportation infrastructure, including stations and other public transportation infrastructure owned by State or local governments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d58b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/1/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other capital security improvements determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d58c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Operating uses of funds, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb569d58d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security training and associated backfill, including training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1137"},"text":"section 1137 of this title","children":[],"tail":" and training developed by institutions of higher education and by nonprofit employee labor organizations, for public transportation employees, including frontline employees;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d58e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" live or simulated exercises under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1136"},"text":"section 1136 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d58f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public awareness campaigns for enhanced public transportation security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d590-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" canine patrols for chemical, radiological, biological, or explosives detection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d591-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of security plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1134"},"text":"section 1134 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d592-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overtime reimbursement including reimbursement of State, local, and tribal governments, for costs for enhanced security personnel during significant national and international public events;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d593-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operational costs, including reimbursement of State, local, and tribal governments for costs for personnel assigned to full-time or part-time security or counterterrorism duties related to public transportation, provided that this expense totals no more than 10 percent of the total grant funds received by a public transportation agency in any 1 year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d594-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other operational security costs determined appropriate by the Secretary, excluding routine, ongoing personnel costs, other than those set forth in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d595-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Homeland Security responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the responsibilities under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb569d596-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the requirements for recipients of grants under this section, including application requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d597-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to subsection (a)(2), select the recipients of grants based solely on risk; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d598-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to subsection (b), establish the priorities for which grant funds may be used under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d599-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of grants","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", the Secretary and the Secretary of Transportation shall determine the most effective and efficient way to distribute grant funds to the recipients of grants determined by the Secretary under subsection (a). Subject to the determination made by the Secretaries, the Secretary may transfer funds to the Secretary of Transportation for the purposes of disbursing funds to the grant recipient."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d59a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject to certain terms and conditions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided in this section, a grant provided under this section shall be subject to the terms and conditions applicable to a grant made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5307"},"text":"section 5307 of title 49","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":", and such other terms and conditions as are determined necessary by the Secretary."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d59b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on uses of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grants made under this section may not be used to make any State or local government cost-sharing contribution under any other Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d59c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of a grant under this section shall report annually to the Secretary on the use of the grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d59d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before distribution of funds to recipients of grants, the Secretary shall issue guidelines to ensure that, to the extent that recipients of grants under this section use contractors or subcontractors, such recipients shall use small, minority, women-owned, or disadvantaged business concerns as contractors or subcontractors to the extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d59e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with State homeland security plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In establishing security improvement priorities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1134"},"text":"section 1134 of this title","children":[],"tail":" and in awarding grants for capital security improvements and operational security improvements under subsection (b), the Secretary shall act consistently with relevant State homeland security plans."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d59f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multistate transportation systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In cases in which a public transportation system operates in more than one State, the Secretary shall give appropriate consideration to the risks of the entire system, including those portions of the States into which the system crosses, in establishing security improvement priorities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1134"},"text":"section 1134 of this title","children":[],"tail":" and in awarding grants for capital security improvements and operational security improvements under subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d5a0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 days before the award of any grant under this section, the Secretary shall notify simultaneously, the appropriate congressional committees of the intent to award such grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d5a1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of misspent grant funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a process to require the return of any misspent grant funds received under this section determined to have been spent for a purpose other than those specified in the grant award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d5a2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periods of performance","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb569d5a3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in paragraph (2), funds provided pursuant to a grant awarded under this section for a use specified in subsection (b) shall remain available for use by a grant recipient for a period of not fewer than 36 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d5a4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Funds provided pursuant to a grant awarded under this section for a use specified in subparagraph (M) or (N) of subsection (b)(1) shall remain available for use by a grant recipient for a period of not fewer than 48 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d5a5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb569d5a6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/n/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There are authorized to be appropriated to the Secretary to make grants under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb569d5a7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/n/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d5a8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/n/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $650,000,000 for fiscal year 2008, except that not more than 50 percent of such funds may be used for operational costs under subsection (b)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d5a9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/n/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $750,000,000 for fiscal year 2009, except that not more than 30 percent of such funds may be used for operational costs under subsection (b)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d5aa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/n/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $900,000,000 for fiscal year 2010, except that not more than 20 percent of such funds may be used for operational costs under subsection (b)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d5ab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/n/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $1,100,000,000 for fiscal year 2011, except that not more than 10 percent of such funds may be used for operational costs under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d5ac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/n/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Sums appropriated to carry out this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d5ad-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/n/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may waive the limitation on operational costs specified in subparagraphs (B) through (E) of paragraph (1) if the Secretary determines that such a waiver is required in the interest of national security, and if the Secretary provides a written justification to the appropriate congressional committees prior to any such action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d5ae-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1135/n/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds provided for fiscal year 2007 transit security grants under ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Public Law 110–28","children":[],"tail":" shall be allocated based on security assessments that are in existence as of "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb569d5af-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXIV/s1406"},"text":"Pub. L. 110–53, title XIV, § 1406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/405"},"text":"121 Stat. 405","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXIV"},"text":"Pub. L. 117–81, div. F, title LXIV","children":[],"tail":", §§ 6420, 6421, "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2418"},"text":"135 Stat. 2418","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb569d5b0-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb569d5b1-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb569d5b2-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Public Law 110–28","children":[],"tail":", referred to in subsec. (n)(4), is "},{"tag":"ref","attrib":{"href":"/us/pl/110/28"},"text":"Pub. L. 110–28","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-25"},"text":"May 25, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/112"},"text":"121 Stat. 112","children":[],"tail":", known as the U.S. Troop Readinesss, Veterans’ Care, Katrina Recovery, and Iraq Accountability Appropriations Act, 2007. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb569d5b3-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6420"},"text":"Pub. L. 117–81, § 6420","children":[],"tail":", inserted “and associated backfill” after “security training”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (m), (n). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6421"},"text":"Pub. L. 117–81, § 6421","children":[],"tail":", added subsec. (m) and redesignated former subsec. (m) as (n)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
