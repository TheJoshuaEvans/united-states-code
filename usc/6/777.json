{"tag":"section","attrib":{"id":"idb55b7e09-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777"},"text":null,"children":[{"tag":"num","attrib":{"value":"777"},"text":"§ 777.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public assistance pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55b7e0a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55b7e0b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President, acting through the Administrator, and in coordination with State and local governments, shall establish and conduct a pilot program to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55b7e0c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the costs to the Federal Government of providing assistance to States and local governments under sections 5170b(a)(3)(A), 5172, and 5173 of title 42;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55b7e0d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase flexibility in the administration of sections 5170b(a)(3)(A), 5172, and 5173 of title 42; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55b7e0e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expedite the provision of assistance to States and local governments provided under sections 5170b(a)(3)(A), 5172, and 5173 of title 42.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7e0f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Only States and local governments that elect to participate in the pilot program may participate in the pilot program for a particular project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7e10-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Innovative administration","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55b7e11-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the pilot program, the Administrator shall establish new procedures to administer assistance provided under the sections referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee12-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New procedures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The new procedures established under subparagraph (A) may include 1 or more of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55dee13-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5172/c/1/A"},"text":"section 5172(c)(1)(A) of title 42","children":[],"tail":", providing an option for a State or local government to elect to receive an in-lieu contribution in an amount equal to 90 percent of the Federal share of the Federal estimate of the cost of repair, restoration, reconstruction, or replacement of a public facility owned or controlled by the State or local government and of management expenses."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55dee14-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Making grants on the basis of estimates agreed to by the local government (or where no local government is involved, by the State government) and the Administrator to provide financial incentives and disincentives for the local government (or where no local government is involved, for the State government) for the timely or cost effective completion of projects under sections 5170b(a)(3)(A), 5172, and 5173 of title 42.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55dee15-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Increasing the Federal share for removal of debris and wreckage for States and local governments that have a debris management plan approved by the Administrator and have pre-qualified 1 or more debris and wreckage removal contractors before the date of declaration of the major disaster.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55dee16-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Using a sliding scale for the Federal share for removal of debris and wreckage based on the time it takes to complete debris and wreckage removal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55dee17-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Using a financial incentive to recycle debris.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55dee18-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reimbursing base wages for employees and extra hires of a State or local government involved in or administering debris and wreckage removal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee19-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may waive such regulations or rules applicable to the provisions of assistance under the sections referred to in paragraph (1) as the Administrator determines are necessary to carry out the pilot program under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee1a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55dee1b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2009-03-31"},"text":"March 31, 2009","children":[],"tail":", the Administrator shall submit to the appropriate committees of Congress a report regarding the effectiveness of the pilot program under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee1c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report submitted under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55dee1d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment by the Administrator of any administrative or financial benefits of the pilot program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee1e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment by the Administrator of the effect, including any savings in time and cost, of the pilot program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee1f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any identified legal or other obstacles to increasing the amount of debris recycled after a major disaster;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee20-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other findings and conclusions of the Administrator with respect to the pilot program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee21-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations of the Administrator for additional authority to continue or make permanent the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee22-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for initiation of implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall initiate implementation of the pilot program under this section not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"October 4, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee23-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s777/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program project duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may not approve a project under the pilot program under this section after ","children":[{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55dee24-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s689j"},"text":"Pub. L. 109–295, title VI, § 689j","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1455"},"text":"120 Stat. 1455","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
