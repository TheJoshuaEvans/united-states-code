{"tag":"section","attrib":{"id":"idb556c30c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701"},"text":null,"children":[{"tag":"num","attrib":{"value":"701"},"text":"§ 701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this title— ","children":[{"tag":"ref","attrib":{"idref":"fn002127"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002127"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb556c30d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Administrator” means the Administrator of the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c30e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Agency” means the Federal Emergency Management Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c30f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb556c310-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556c311-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those committees of the House of Representatives that the Speaker of the House of Representatives determines appropriate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c312-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “catastrophic incident” means any natural disaster, act of terrorism, or other man-made disaster that results in extraordinary levels of casualties or damage or disruption severely affecting the population (including mass evacuations), infrastructure, environment, economy, national morale, or government functions in an area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c313-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Department” means the Department of Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c314-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “emergency” and “major disaster” have the meanings given the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5122"},"text":"section 5122 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c315-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “emergency management” means the governmental function that coordinates and integrates all activities necessary to build, sustain, and improve the capability to prepare for, protect against, respond to, recover from, or mitigate against threatened or actual natural disasters, acts of terrorism, or other man-made disasters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c316-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “emergency response provider” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c317-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Federal coordinating officer” means a Federal coordinating officer as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5143"},"text":"section 5143 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c318-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “individual with a disability” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12102"},"text":"section 12102 of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c319-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “local government” and “State” have the meaning given the terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c31a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “National Incident Management System” means a system to enable effective, efficient, and collaborative incident management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c31b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “National Response Plan” means the National Response Plan or any successor plan prepared under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s314/a/6"},"text":"section 314(a)(6) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c31c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c31d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “surge capacity” means the ability to rapidly and substantially increase the provision of search and rescue capabilities, food, water, medicine, shelter and housing, medical care, evacuation capacity, staffing (including disaster assistance employees), and other resources necessary to save lives and protect property during a catastrophic incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c31e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s701/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “tribal government” means the government of an Indian tribe or authorized tribal organization, or in Alaska a Native village or Alaska Regional Native Corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb556c31f-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s602"},"text":"Pub. L. 109–295, title VI, § 602","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1394"},"text":"120 Stat. 1394","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb556c320-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb556c321-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb556c322-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This title, referred to in text, is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1355"},"text":"120 Stat. 1355","children":[],"tail":", known as the Post-Katrina Emergency Management Reform Act of 2006. For complete classification of title VI to the Code, see Short Title note set out below and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s314/a/6"},"text":"Section 314(a)(6) of this title","children":[],"tail":", referred to in par. (13), was in the original “section 502(a)(6) of the Homeland Security Act 2002” and was translated as meaning "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s502"},"text":"section 502 of Pub. L. 107–296","children":[],"tail":" prior to its redesignation as section 504 by "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/s611/8"},"text":"Pub. L. 109–295, § 611(8)","children":[],"tail":", and not "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s506"},"text":"section 506 of Pub. L. 107–296","children":[],"tail":" which was redesignated section 502 by "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/s611/9"},"text":"Pub. L. 109–295, § 611(9)","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s312"},"text":"section 312 of this title","children":[],"tail":", to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb556c323-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb556c324-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Any reference to the Administrator of the Federal Emergency Management Agency in title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":" or an amendment by title VI to be considered to refer and apply to the Director of the Federal Emergency Management Agency until "},{"tag":"date","attrib":{"date":"2007-03-31"},"text":"Mar. 31, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/s612/f/2"},"text":"section 612(f)(2) of Pub. L. 109–295","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s313"},"text":"section 313 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb556c325-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s614"},"text":"Pub. L. 109–295, title VI, § 614","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1411"},"text":"120 Stat. 1411","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/295/tVI/s614"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), this title [see Tables for classification] and the amendments made by this title shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following shall take effect on ","children":[{"tag":"date","attrib":{"date":"2007-03-31"},"text":"March 31, 2007","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by section 611(11) [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s313"},"text":"section 313 of this title","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by section 611(12) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s314"},"text":"section 314 of this title","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 505, 507, 508, and 514 of the Homeland Security Act of 2002 [sections 315, 317, 318, and 321c of this title], as amended by section 611(13) of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by subsection (a) [sic].","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by subsection (b)(1) [sic].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb556c326-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXIII/s7301"},"text":"Pub. L. 117–263, div. G, title LXXIII, § 7301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3684"},"text":"136 Stat. 3684","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dG/tLXXIII/s7301"},"text":"“This subtitle [subtitle A (§§ 7301–7309) of title LXXIII of div. G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", enacting part F of subchapter II of this chapter] may be cited as the ‘Global Catastrophic Risk Management Act of 2022’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb556c327-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/272/s1"},"text":"Pub. L. 116–272, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-31"},"text":"Dec. 31, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3349"},"text":"134 Stat. 3349","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/272/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s791"},"text":"section 791 of this title","children":[],"tail":" and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s791"},"text":"section 791 of this title","children":[],"tail":"] may be cited as the ‘Federal Advance Contracts Enhancement Act’ or the ‘FACE Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idb556c328-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/64/s1"},"text":"Pub. L. 116–64, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-10-09"},"text":"Oct. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1122"},"text":"133 Stat. 1122","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/64/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s748"},"text":"section 748 of this title","children":[],"tail":"] may be cited as the ‘Terrorist and Foreign Fighter Travel Exercise Act of 2019’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb556c329-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s601"},"text":"Pub. L. 109–295, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1394"},"text":"120 Stat. 1394","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/295/tVI/s601"},"text":"“This title [see Tables for classification] may be cited as the ‘Post-Katrina Emergency Management Reform Act of 2006’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb556c32a-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Clarification of Congressional Intent","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXXII/s2202"},"text":"Pub. L. 110–53, title XXII, § 2202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/541"},"text":"121 Stat. 541","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/53/tXXII/s2202"},"text":"“The Federal departments and agencies (including independent agencies) identified under the provisions of this title [enacting provisions set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s194"},"text":"section 194 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s247d–3a"},"text":"section 247d–3a of Title 42","children":[],"tail":", The Public Health and Welfare, and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t47/s309"},"text":"section 309 of Title 47","children":[],"tail":", Telecommunications] and title III of this Act [enacting sections 579 and 580 of this title and amending sections 194 and 572 of this title] and title VI of "},{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Public Law 109–295","children":[],"tail":" [see Short Title note set out above] shall carry out their respective duties and responsibilities in a manner that does not impede the implementation of requirements specified under this title and title III of this Act and title VI of "},{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Public Law 109–295","children":[],"tail":". Notwithstanding the obligations under "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/s1806"},"text":"section 1806 of Public Law 109–295","children":[],"tail":" [probably means "},{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s576"},"text":"6 U.S.C. 576","children":[],"tail":"], the provisions of this title and title III of this Act and title VI of "},{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Public Law 109–295","children":[],"tail":" shall not preclude or obstruct any such department or agency from exercising its other authorities related to emergency communications matters.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb556c32b-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Weather Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s613"},"text":"Pub. L. 109–295, title VI, § 613","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1411"},"text":"120 Stat. 1411","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/295/tVI/s613"},"text":"“Nothing in this title [see Tables for classification] shall alter or otherwise affect the authorities and activities of the National Weather Service to protect life and property, including under the Act of ","children":[{"tag":"date","attrib":{"date":"1890-10-01"},"text":"October 1, 1890","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/26/653"},"text":"26 Stat. 653","children":[],"tail":"-55) ["},{"tag":"ref","attrib":{"href":"/us/usc/t15/s312"},"text":"15 U.S.C. 312","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb556c32c-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s699A"},"text":"Pub. L. 109–295, title VI, § 699A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1463"},"text":"120 Stat. 1463","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/295/tVI/s699A"},"text":"“Except as expressly provided otherwise, any reference to ‘this Act’ contained in this title [see Tables for classification] shall be treated as referring only to the provisions of this title.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
