{"tag":"section","attrib":{"id":"idb52be284-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s495"},"text":null,"children":[{"tag":"num","attrib":{"value":"495"},"text":"§ 495.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff composition","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Council shall have a staff, the head of which shall be a civilian Executive Secretary, who shall be appointed by the President. The President is authorized to fix the pay of the Executive Secretary at a rate not to exceed the rate of pay payable to the Executive Secretary of the National Security Council.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb52be285-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIX/s905"},"text":"Pub. L. 107–296, title IX, § 905","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2259"},"text":"116 Stat. 2259","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
