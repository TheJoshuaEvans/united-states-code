{"tag":"section","attrib":{"id":"idb5651b93-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113"},"text":null,"children":[{"tag":"num","attrib":{"value":"1113"},"text":"§ 1113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surface transportation security inspectors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5651b94-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Administrator of the Transportation Security Administration, is authorized to train, employ, and utilize surface transportation security inspectors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651b95-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall use surface transportation security inspectors to assist surface transportation carriers, operators, owners, entities, and facilities to enhance their security against terrorist attack and other security threats and to assist the Secretary in enforcing applicable surface transportation security regulations and directives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651b96-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Surface transportation security inspectors employed pursuant to this section shall be authorized such powers and delegated such responsibilities as the Secretary determines appropriate, subject to subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651b97-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require that surface transportation security inspectors have relevant transportation experience and other security and inspection qualifications, as determined appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651b98-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5651b99-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspectors","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Surface transportation inspectors shall be prohibited from issuing fines to public transportation agencies, as defined in subchapter III, for violations of the Department’s regulations or orders except through the process described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b9a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall be prohibited from assessing civil penalties against public transportation agencies, as defined in subchapter III, for violations of the Department’s regulations or orders, except in accordance with the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5651b9b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a public transportation agency that is found to be in violation of a regulation or order issued by the Secretary, the Secretary shall seek correction of the violation through a written notice to the public transportation agency and shall give the public transportation agency reasonable opportunity to correct the violation or propose an alternative means of compliance acceptable to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5651b9c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the public transportation agency does not correct the violation or propose an alternative means of compliance acceptable to the Secretary within a reasonable time period that is specified in the written notice, the Secretary may take any action authorized in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s114"},"text":"section 114 of title 49","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b9d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not initiate civil enforcement actions for violations of administrative and procedural requirements pertaining to the application for, and expenditure of, funds awarded under transportation security grant programs under this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651b9e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of inspectors","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall employ up to a total of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5651b9f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 surface transportation security inspectors in fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651ba0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 150 surface transportation security inspectors in fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651ba1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 175 surface transportation security inspectors in fiscal year 2009; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651ba2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 200 surface transportation security inspectors in fiscal years 2010 and 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651ba3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the mission of the surface transportation security inspectors is consistent with any relevant risk assessments required by this Act or completed by the Department, the modal plans required under section 114(t) ","children":[{"tag":"ref","attrib":{"idref":"fn002140"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002140"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 49, the Memorandum of Understanding between the Department and the Department of Transportation on Roles and Responsibilities, dated "},{"tag":"date","attrib":{"date":"2004-09-28"},"text":"September 28, 2004","children":[],"tail":", and any and all subsequent annexes to this Memorandum of Understanding, and other relevant documents setting forth the Department’s transportation security strategy, as appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651ba4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall periodically consult with the surface transportation entities which are or may be inspected by the surface transportation security inspectors, including, as appropriate, railroad carriers, over-the-road bus operators and terminal owners and operators, motor carriers, public transportation agencies, owners or operators of highways, and pipeline operators on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5651ba5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inspectors’ duties, responsibilities, authorities, and mission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651ba6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies to improve transportation security and to ensure compliance with transportation security requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651ba7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2008-09-30"},"text":"September 30, 2008","children":[],"tail":", the Department of Homeland Security Inspector General shall transmit a report to the appropriate congressional committees on the performance and effectiveness of surface transportation security inspectors, whether there is a need for additional inspectors, and other recommendations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651ba8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5651ba9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $11,400,000 for fiscal year 2007;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651baa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $17,100,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651bab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $19,950,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651bac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $22,800,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651bad-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1113/j/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $22,800,000 for fiscal year 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5651bae-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXIII/s1304"},"text":"Pub. L. 110–53, title XIII, § 1304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/393"},"text":"121 Stat. 393","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5651baf-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5651bb0-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5651bb1-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsecs. (e)(3) and (g), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53"},"text":"Pub. L. 110–53","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/266"},"text":"121 Stat. 266","children":[],"tail":", known as the Implementing Recommendations of the 9/11 Commission Act of 2007, which enacted this chapter and enacted and amended numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title of 2007 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s114/t"},"text":"Section 114(t) of title 49","children":[],"tail":", referred to in subsec. (g), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s114/s"},"text":"section 114(s) of title 49","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dE/tV/s568/a"},"text":"Pub. L. 110–161, div. E, title V, § 568(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2092"},"text":"121 Stat. 2092","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
