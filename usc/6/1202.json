{"tag":"section","attrib":{"id":"idb573726b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1202"},"text":null,"children":[{"tag":"num","attrib":{"value":"1202"},"text":"§ 1202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroad security-sensitive material tracking","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb573726c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Communications","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb573726d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conjunction with the research and development program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1168"},"text":"section 1168 of this title","children":[],"tail":" and consistent with the results of research relating to wireless and other tracking technologies, the Secretary, in consultation with the Administrator of the Transportation Security Administration, shall develop a program that will encourage the equipping of railroad cars transporting security-sensitive materials, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s1151"},"text":"section 1151 of this title","children":[],"tail":", with technology that provides—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb573726e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1202/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" car position location and tracking capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb573726f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1202/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notification of railroad car depressurization, breach, unsafe temperature, or release of hazardous materials, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5737270-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the program required by paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5737271-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1202/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the Secretary of Transportation to coordinate the program with any ongoing or planned efforts for railroad car tracking at the Department of Transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5737272-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1202/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the program is consistent with recommendations and findings of the Department of Homeland Security’s hazardous material railroad tank car tracking pilot programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5737273-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts appropriated pursuant to ","children":[{"tag":"ref","attrib":{"idref":"fn002167"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002167"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by “section”."}],"tail":" 114(w) "},{"tag":"ref","attrib":{"idref":"fn002168"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002168"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 49, there shall be made available to the Secretary to carry out this section—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5737274-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5737275-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000 for fiscal year 2009; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5737276-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1202/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,000,000 for fiscal year 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5737277-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"