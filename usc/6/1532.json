{"tag":"section","attrib":{"id":"idb57a77fc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1532"},"text":null,"children":[{"tag":"num","attrib":{"value":"1532"},"text":"§ 1532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhancement of emergency services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb57a77fd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1532/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", the Secretary of Homeland Security, acting through the center established under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s659"},"text":"section 659 of this title","children":[],"tail":", in coordination with appropriate Federal entities and the Assistant Director for Emergency Communications, shall establish a process by which a Statewide Interoperability Coordinator may report data on any cybersecurity risk or incident involving any information system or network used by emergency response providers (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":") within the State."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57a77fe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1532/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Analysis of data","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":", the Secretary of Homeland Security, acting through the Director of the National Cybersecurity and Communications Integration Center, in coordination with appropriate entities and the Assistant Director for Emergency Communications, and in consultation with the Secretary of Commerce, acting through the Director of the National Institute of Standards and Technology, shall conduct integration and analysis of the data reported under subsection (a) to develop information and recommendations on security and resilience measures for any information system or network used by State emergency response providers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57a77ff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1532/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Best practices","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57a7800-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1532/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Using the results of the integration and analysis conducted under subsection (b), and any other relevant information, the Director of the National Institute of Standards and Technology shall, on an ongoing basis, facilitate and support the development of methods for reducing cybersecurity risks to emergency response providers using the process described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s272/e"},"text":"section 272(e) of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a7801-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1532/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the National Institute of Standards and Technology shall submit to Congress a report on the result of the activities of the Director under paragraph (1), including any methods developed by the Director under such paragraph, and shall make such report publicly available on the website of the National Institute of Standards and Technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57a7802-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1532/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57a7803-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1532/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a State to report data under subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57a7804-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1532/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require a non-Federal entity (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1501"},"text":"section 1501 of this title","children":[],"tail":") to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57a7805-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1532/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt a recommended measure developed under subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57a7806-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1532/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" follow the result of the activities carried out under subsection (c), including any methods developed under such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57a7807-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dN/tIV/s404"},"text":"Pub. L. 114–113, div. N, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2980"},"text":"129 Stat. 2980","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/h/1/H"},"text":"Pub. L. 115–278, § 2(h)(1)(H)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4183"},"text":"132 Stat. 4183","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57a7808-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57a7809-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb57a780a-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/h/1/H"},"text":"Pub. L. 115–278, § 2(h)(1)(H)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s659"},"text":"section 659 of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s148"},"text":"section 148 of this title","children":[],"tail":", as redesignated by section 223(a)(3) of this division,” and “Assistant Director for Emergency Communications” for “Director for Emergency Communications”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/h/1/H/ii"},"text":"Pub. L. 115–278, § 2(h)(1)(H)(ii)","children":[],"tail":", substituted “Assistant Director for Emergency Communications” for “Director for Emergency Communications”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb57a780b-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb57a780c-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Assistant Director for Emergency Communications deemed to be a reference to the Executive Assistant Director for Emergency Communications, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s571/g"},"text":"section 571(g) of this title","children":[],"tail":", enacted "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
