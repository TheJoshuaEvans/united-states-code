{"tag":"section","attrib":{"id":"idb52245d3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s464e"},"text":null,"children":[{"tag":"num","attrib":{"value":"464e"},"text":"§ 464e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short-term medical services for students","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In fiscal year 2004 and thereafter, the Center is authorized to provide short-term medical services for students undergoing training at the Center.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb52245d4-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/90/tIV"},"text":"Pub. L. 108–90, title IV","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-10-01"},"text":"Oct. 1, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1151"},"text":"117 Stat. 1151","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb52245d5-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb52245d6-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb52245d7-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Center, referred to in text, means the Federal Law Enforcement Training Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb524b5d8-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","