{"tag":"section","attrib":{"id":"idb51d8a74-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397"},"text":null,"children":[{"tag":"num","attrib":{"value":"397"},"text":"§ 397.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements to buy certain items related to national security interests","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb51d8a75-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51d8a76-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered item","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered item” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51d8a77-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Footwear provided as part of a uniform.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a78-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Uniforms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a79-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Holsters and tactical pouches.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a7a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Patches, insignia, and embellishments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a7b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chemical, biological, radiological, and nuclear protective gear.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a7c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Body armor components intended to provide ballistic protection for an individual, consisting of 1 or more of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb51d8a7d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/1/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Soft ballistic panels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8a7e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/1/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hard ballistic plates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8a7f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/1/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Concealed armor carriers worn under a uniform.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8a80-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/1/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" External armor carriers worn over a uniform.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a81-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other item of clothing or protective equipment as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51d8a82-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Frontline operational component","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “frontline operational component” means any of the following entities of the Department:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51d8a83-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" U.S. Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a84-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" U.S. Immigration and Customs Enforcement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a85-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Secret Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a86-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Transportation Security Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a87-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Protective Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a88-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a89-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Law Enforcement Training Centers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a8a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Cybersecurity and Infrastructure Security Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51d8a8b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51d8a8c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that any procurement of a covered item for a frontline operational component meets the following criteria:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51d8a8d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb51d8a8e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the maximum extent possible, not less than one-third of funds obligated in a specific fiscal year for the procurement of such covered items shall be covered items that are manufactured or supplied in the United States by entities that qualify as small business concerns, as such term is described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8a8f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Covered items may only be supplied pursuant to subparagraph (A) to the extent that United States entities that qualify as small business concerns—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb51d8a90-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are unable to manufacture covered items in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb51d8a91-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the criteria identified in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a92-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each contractor with respect to the procurement of such a covered item, including the end-item manufacturer of such a covered item—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb51d8a93-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an entity registered with the System for Award Management (or successor system) administered by the General Services Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8a94-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in compliance with ISO 9001:2015 of the International Organization for Standardization (or successor standard) or a standard determined appropriate by the Secretary to ensure the quality of products and adherence to applicable statutory and regulatory requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a95-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each supplier of such a covered item with an insignia (such as any patch, badge, or emblem) and each supplier of such an insignia, if such covered item with such insignia or such insignia, as the case may be, is not produced, applied, or assembled in the United States, shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb51d8a96-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" store such covered item with such insignia or such insignia in a locked area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8a97-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report any pilferage or theft of such covered item with such insignia or such insignia occurring at any stage before delivery of such covered item with such insignia or such insignia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8a98-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" destroy any such defective or unusable covered item with insignia or insignia in a manner established by the Secretary, and maintain records, for three years after the creation of such records, of such destruction that include the date of such destruction, a description of the covered item with insignia or insignia destroyed, the quantity of the covered item with insignia or insignia destroyed, and the method of destruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51d8a99-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiver","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51d8a9a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the case of a national emergency declared by the President under the National Emergencies Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"50 U.S.C. 1601","children":[],"tail":" et seq.) or a major disaster declared by the President under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"section 5170 of title 42","children":[],"tail":", the Secretary may waive a requirement in subparagraph (A), (B) or (C) of paragraph (1) if the Secretary determines there is an insufficient supply of a covered item that meets such requirement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8a9b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date on which the Secretary determines a waiver under subparagraph (A) is necessary, the Secretary shall provide to the Committee on Homeland Security and Governmental Affairs and the Committee on Appropriations of the Senate and the Committee on Homeland Security, the Committee on Oversight and Reform, and the Committee on Appropriations of the House of Representatives notice of such determination, which shall include the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb51d8a9c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of the national emergency or major disaster declared by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8a9d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of the covered item for which the Secretary intends to issue the waiver.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb51d8a9e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the demand for the covered item and corresponding lack of supply from contractors able to meet the criteria described in subparagraph (B) or (C) of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51d8a9f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pricing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that covered items are purchased at a fair and reasonable price, consistent with the procedures and guidelines specified in the Federal Acquisition Regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51d8aa0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", and annually thereafter, the Secretary shall provide to the Committee on Homeland Security, the Committee on Oversight and Reform, the Committee on Small Business, and the Committee on Appropriations of the House of Representatives, and the Committee on Homeland Security and Governmental Affairs, the Committee on Small Business and Entrepreneurship, and the Committee on Appropriations of the Senate a briefing on instances in which vendors have failed to meet deadlines for delivery of covered items and corrective actions taken by the Department in response to such instances."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51d8aa1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s397/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section applies with respect to a contract entered into by the Department or any frontline operational component on or after the date that is 180 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb51d8aa2-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s836"},"text":"Pub. L. 107–296, title VIII, § 836","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7112/a"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3628"},"text":"136 Stat. 3628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb51d8aa3-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb51d8aa4-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb51d8aa5-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Emergencies Act, referred to in subsec. (b)(2)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/412"},"text":"Pub. L. 94–412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-09-14"},"text":"Sept. 14, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1255"},"text":"90 Stat. 1255","children":[],"tail":", which is classified principally to chapter 34 (§ 1601 et seq.) of Title 50, War and National Defense. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1601"},"text":"section 1601 of Title 50","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb51d8aa6-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb51d8aa7-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
