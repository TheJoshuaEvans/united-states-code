{"tag":"section","attrib":{"id":"idb4e1e067-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i"},"text":null,"children":[{"tag":"num","attrib":{"value":"124i"},"text":"§ 124i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeland Security Information Sharing Fellows Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4e1e068-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e1e069-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Under Secretary for Intelligence and Analysis, and in consultation with the Chief Human Capital Officer, shall establish a fellowship program in accordance with this section for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e1e06a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" detailing State, local, and tribal law enforcement officers and intelligence analysts to the Department in accordance with subchapter VI of chapter 33 of title 5 to participate in the work of the Office of Intelligence and Analysis in order to become familiar with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4e1e06b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relevant missions and capabilities of the Department and other Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4e1e06c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role, programs, products, and personnel of the Office of Intelligence and Analysis; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e1e06d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" promoting information sharing between the Department and State, local, and tribal law enforcement officers and intelligence analysts by assigning such officers and analysts to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4e1e06e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a point of contact in the Department to assist in the representation of State, local, and tribal information requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4e1e06f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify information within the scope of the information sharing environment, including homeland security information, terrorism information, and weapons of mass destruction information, that is of interest to State, local, and tribal law enforcement officers, intelligence analysts, and other emergency response providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4e1e070-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist Department analysts in preparing and disseminating products derived from information within the scope of the information sharing environment, including homeland security information, terrorism information, and weapons of mass destruction information, that are tailored to State, local, and tribal law enforcement officers and intelligence analysts and designed to prepare for and thwart acts of terrorism; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4e1e071-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist Department analysts in preparing products derived from information within the scope of the information sharing environment, including homeland security information, terrorism information, and weapons of mass destruction information, that are tailored to State, local, and tribal emergency response providers and assist in the dissemination of such products through appropriate Department channels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e1e072-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program name","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The program under this section shall be known as the “Homeland Security Information Sharing Fellows Program”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e1e073-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e1e074-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to be eligible for selection as an Information Sharing Fellow under the program under this section, an individual shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e1e075-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have homeland security-related responsibilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e1e076-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be eligible for an appropriate security clearance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e1e077-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possess a valid need for access to classified information, as determined by the Under Secretary for Intelligence and Analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e1e078-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an employee of an eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e1e079-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have undergone appropriate privacy and civil liberties training that is developed, supported, or sponsored by the Privacy Officer and the Officer for Civil Rights and Civil Liberties, in consultation with the Privacy and Civil Liberties Oversight Board established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000ee"},"text":"section 2000ee of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e1e07a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e1e07b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, local, or regional fusion center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e1e07c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or local law enforcement or other government entity that serves a major metropolitan area, suburban area, or rural area, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e1e07d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or local law enforcement or other government entity with port, border, or agricultural responsibilities, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e1e07e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tribal law enforcement or other authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e1e07f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other entity as the Secretary determines is appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e1e080-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Optional participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No State, local, or tribal law enforcement or other government entity shall be required to participate in the Homeland Security Information Sharing Fellows Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e1e081-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procedures for nomination and selection","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e1e082-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary for Intelligence and Analysis shall establish procedures to provide for the nomination and selection of individuals to participate in the Homeland Security Information Sharing Fellows Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e1e083-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Under Secretary for Intelligence and Analysis shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e1e084-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select law enforcement officers and intelligence analysts representing a broad cross-section of State, local, and tribal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e1e085-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124i/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the number of Information Sharing Fellows selected does not impede the activities of the Office of Intelligence and Analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4e1e086-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tII/s210B"},"text":"Pub. L. 107–296, title II, § 210B","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tV/s512/a"},"text":"Pub. L. 110–53, title V, § 512(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/324"},"text":"121 Stat. 324","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
