{"tag":"section","attrib":{"id":"idb4f2aa00-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195h"},"text":null,"children":[{"tag":"num","attrib":{"value":"195h"},"text":"§ 195h.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Urban Security Technology Laboratory","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4f2aa01-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195h/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Under Secretary for Science and Technology, shall designate the laboratory described in subsection (b) as an additional laboratory pursuant to the authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s188/c/2"},"text":"section 188(c)(2) of this title","children":[],"tail":". Such laboratory shall be used to test and evaluate emerging technologies and conduct research and development to assist emergency response providers in preparing for, and protecting against, threats of terrorism."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f2aa02-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195h/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laboratory described","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The laboratory described in this subsection is the laboratory—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f2aa03-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195h/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" known, as of ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", as the National Urban Security Technology Laboratory; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f2aa04-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195h/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferred to the Department pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s183/1/E"},"text":"section 183(1)(E) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f2aa05-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195h/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laboratory activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Urban Security Technology Laboratory shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f2aa06-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195h/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct tests, evaluations, and assessments of current and emerging technologies, including, as appropriate, the cybersecurity of such technologies that can connect to the internet, for emergency response providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f2aa07-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195h/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" act as a technical advisor to emergency response providers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f2aa08-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195h/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out other such activities as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f2aa09-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195h/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed as affecting in any manner the authorities or responsibilities of the Countering Weapons of Mass Destruction Office of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4f2aa0a-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIII/s322"},"text":"Pub. L. 107–296, title III, § 322","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXIV/s6406/a"},"text":"Pub. L. 117–81, div. F, title LXIV, § 6406(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2402"},"text":"135 Stat. 2402","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
