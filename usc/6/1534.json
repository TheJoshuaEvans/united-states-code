{"tag":"section","attrib":{"id":"idb57ce841-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1534"},"text":null,"children":[{"tag":"num","attrib":{"value":"1534"},"text":"§ 1534.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybercrime","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, and in accordance with the comparable level of the General Schedule, the Attorney General and the Secretary of Homeland Security shall provide incentive pay, in an amount that is not more than 25 percent of the basic pay of the individual, to an individual appointed to a position in the Department of Justice (including the Federal Bureau of Investigation) or the Department of Homeland Security (including positions in Homeland Security Investigations), respectively, requiring significant cyber skills, including to aid in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57ce842-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1534/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of trafficking victims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57ce843-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1534/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prevention of trafficking in persons; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57ce844-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1534/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the prosecution of technology-facilitated crimes against children by buyers or traffickers in persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57ce845-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/347/tIV/s401"},"text":"Pub. L. 117–347, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6207"},"text":"136 Stat. 6207","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57ce846-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57ce847-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb57ce848-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in text, is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb57ce849-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Abolish Trafficking Reauthorization Act of 2022, and not as part of the Cybersecurity Act of 2015 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
