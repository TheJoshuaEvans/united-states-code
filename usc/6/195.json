{"tag":"section","attrib":{"id":"idb4edc7c2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195"},"text":null,"children":[{"tag":"num","attrib":{"value":"195"},"text":"§ 195.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office for Interoperability and Compatibility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4edc7c3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clarification of responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office for Interoperability and Compatibility shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4edc7c4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Secretary in developing and implementing the science and technology aspects of the program described in subparagraphs (D), (E), (F), and (G) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s194/a/1"},"text":"section 194(a)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc7c5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with the Federal Communications Commission, the National Institute of Standards and Technology, and other Federal departments and agencies with responsibility for standards, support the creation of national voluntary consensus standards for interoperable emergency communications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc7c6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a comprehensive research, development, testing, and evaluation program for improving interoperable emergency communications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc7c7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish, in coordination with the Director for Emergency Communications,","children":[{"tag":"ref","attrib":{"idref":"fn002025"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002025"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" requirements for interoperable emergency communications capabilities, which shall be nonproprietary where standards for such capabilities exist, for all public safety radio and data communications systems and equipment purchased using homeland security assistance administered by the Department, excluding any alert and warning device, technology, or system;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc7c8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the Department’s responsibilities and authorities relating to research, development, testing, evaluation, or standards-related elements of the SAFECOM Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc7c9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and assess new technology in real-world environments to achieve interoperable emergency communications capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc7ca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage more efficient use of existing resources, including equipment, to achieve interoperable emergency communications capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc7cb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" test public safety communications systems that are less prone to failure, support new nonvoice services, use spectrum more efficiently, and cost less than existing systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc7cc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with the private sector to develop solutions to improve emergency communications capabilities and achieve interoperable emergency communications capabilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc7cd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct pilot projects, in coordination with the Director for Emergency Communications,","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" to test and demonstrate technologies, including data and video, that enhance—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4edc7ce-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of emergency response providers and relevant government officials to continue to communicate in the event of natural disasters, acts of terrorism, and other man-made disasters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4edc7cf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interoperable emergency communications capabilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edc7d0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director of the Office for Interoperability and Compatibility shall coordinate with the Director for Emergency Communications ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" with respect to the SAFECOM program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edc7d1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sufficiency of resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide the Office for Interoperability and Compatibility the resources and staff necessary to carry out the responsibilities under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4edc7d2-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIII/s314"},"text":"Pub. L. 107–296, title III, § 314","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s672/a"},"text":"Pub. L. 109–295, title VI, § 672(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1441"},"text":"120 Stat. 1441","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4edc7d3-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4edc7d4-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb4edc7d5-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to Director for Emergency Communications deemed to be a reference to Assistant Director for Emergency Communications, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/c/2"},"text":"section 2(c)(2) of Pub. L. 115–278","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s571"},"text":"section 571 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
