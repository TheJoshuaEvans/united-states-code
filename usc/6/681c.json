{"tag":"section","attrib":{"id":"idb556c2aa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681c"},"text":null,"children":[{"tag":"num","attrib":{"value":"681c"},"text":"§ 681c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary reporting of other cyber incidents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb556c2ab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Entities may voluntarily report cyber incidents or ransom payments to the Agency that are not required under paragraph (1), (2), or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s681b/a"},"text":"section 681b(a) of this title","children":[],"tail":", but may enhance the situational awareness of cyber threats."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556c2ac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary provision of additional information in required reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Covered entities may voluntarily include in reports required under paragraph (1), (2), or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s681b/a"},"text":"section 681b(a) of this title","children":[],"tail":" information that is not required to be included, but may enhance the situational awareness of cyber threats."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556c2ad-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681c/c"},"text":null,"chi