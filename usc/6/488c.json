{"tag":"section","attrib":{"id":"idb52be235-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c"},"text":null,"children":[{"tag":"num","attrib":{"value":"488c"},"text":"§ 488c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb52be236-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperative agreements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52be237-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into a cooperative agreement with the Secretary of Agriculture, or the head of any State department of agriculture or its designee involved in agricultural regulation, in consultation with the State agency responsible for homeland security, to carry out the provisions of this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be238-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wherever possible, shall seek to cooperate with State agencies or their designees that oversee ammonium nitrate facility operations when seeking cooperative agreements to implement the registration and enforcement provisions of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be239-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52be23a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may delegate to a State the authority to assist the Secretary in the administration and enforcement of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be23b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At the request of a Governor of a State, the Secretary shall delegate to that State the authority to carry out functions under sections 488a and 488b of this title, if the Secretary determines that the State is capable of satisfactorily carrying out such functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be23c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the availability of appropriations, if the Secretary delegates functions to a State under this subsection, the Secretary shall provide to that State sufficient funds to carry out the delegated functions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be23d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of guidance and notification materials to ammonium nitrate facilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52be23e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make available to each owner of an ammonium nitrate facility registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s488a/c/1"},"text":"section 488a(c)(1) of this title","children":[],"tail":" guidance on—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be23f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of suspicious ammonium nitrate purchases or transfers or attempted purchases or transfers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be240-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the appropriate course of action to be taken by the ammonium nitrate facility owner with respect to such a purchase or transfer or attempted purchase or transfer, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb52be241-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercising the right of the owner of the ammonium nitrate facility to decline sale of ammonium nitrate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb52be242-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifying appropriate law enforcement entities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be243-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional subjects determined appropriate to prevent the misappropriation or use of ammonium nitrate in an act of terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be244-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of materials and programs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In providing guidance under this subsection, the Secretary shall, to the extent practicable, leverage any relevant materials and programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be245-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification materials","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb52be246-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall make available materials suitable for posting at locations where ammonium nitrate is sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb52be247-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Design of materials","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Materials made available under subparagraph (A) shall be designed to notify prospective ammonium nitrate purchasers of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb52be248-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the record-keeping requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s488a"},"text":"section 488a of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb52be249-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s488c/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the penalties for violating such requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb52be24a-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s899D"},"text":"Pub. L. 107–296, title VIII, § 899D","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dE/tV/s563/a"},"text":"Pub. L. 110–161, div. E, title V, § 563(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2087"},"text":"121 Stat. 2087","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
