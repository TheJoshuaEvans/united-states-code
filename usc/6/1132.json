{"tag":"section","attrib":{"id":"idb567652a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1132"},"text":null,"children":[{"tag":"num","attrib":{"value":"1132"},"text":"§ 1132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb567652b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1132/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 182 public transportation systems throughout the world have been primary targets of terrorist attacks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb567652c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1132/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 6,000 public transportation agencies operate in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb567652d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1132/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" people use public transportation vehicles 33,000,000 times each day;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb567652e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1132/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Transit Administration has invested $93,800,000,000 since 1992 for construction and improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb567652f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1132/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal investment in transit security has been insufficient; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5676530-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1132/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" greater Federal investment in transit security improvements per passenger boarding is necessary to better protect the American people, given transit’s vital importance in creating mobility and promoting our Nation’s economy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5676531-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXIV/s1403"},"text":"Pub. L. 110–53, title XIV, § 1403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/401"},"text":"121 Stat. 401","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
