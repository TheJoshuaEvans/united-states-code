{"tag":"section","attrib":{"id":"idb537c949-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s594"},"text":null,"children":[{"tag":"num","attrib":{"value":"594"},"text":"§ 594.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Testing authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb537c94a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s594/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall coordinate with the responsible Federal agency or other entity to facilitate the use by the Office, by its contractors, or by other persons or entities, of existing Government laboratories, centers, ranges, or other testing facilities for the testing of materials, equipment, models, computer software, and other items as may be related to the missions identified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s592"},"text":"section 592 of this title","children":[],"tail":". Any such use of Government facilities shall be carried out in accordance with all applicable laws, regulations, and contractual provisions, including those governing security, safety, and environmental protection, including, when applicable, the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s189"},"text":"section 189 of this title","children":[],"tail":". The Office may direct that private sector entities utilizing Government facilities in accordance with this section pay an appropriate fee to the agency that owns or operates those facilities to defray additional costs to the Government resulting from such use."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c94b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s594/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Confidentiality of test results","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The results of tests performed with services made available shall be confidential and shall not be disclosed outside the Federal Government without the consent of the persons for whom the tests are performed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c94c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s594/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees for services made available under this section shall not exceed the amount necessary to recoup the direct and indirect costs involved, such as direct costs of utilities, contractor support, and salaries of personnel that are incurred by the United States to provide for the testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c94d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s594/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of fees","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Fees received for services made available under this section may be credited to the appropriation from which funds were expended to provide such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb537c94e-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIX/s1925"},"text":"Pub. L. 107–296, title XIX, § 1925","children":[],"tail":", formerly title XVIII, § 1804, as added "},{"tag":"ref","attrib":{"href":"/us/pl/109/347/tV/s501/a"},"text":"Pub. L. 109–347, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1934"},"text":"120 Stat. 1934","children":[],"tail":"; renumbered title XIX, § 1904, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tI/s104/a/1"},"text":"Pub. L. 110–53, title I, § 104(a)(1)","children":[],"tail":"–(3), "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/294"},"text":"121 Stat. 294","children":[],"tail":"; renumbered § 1925 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/387/s2/a/5"},"text":"Pub. L. 115–387, § 2(a)(5)","children":[],"tail":", (7), "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5163"},"text":"132 Stat. 5163","children":[],"tail":", 5164.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb537c94f-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb537c950-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb537c951-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/387/s2/a/7"},"text":"Pub. L. 115–387, § 2(a)(7)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s592"},"text":"section 592 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s104/a/3"},"text":"Pub. L. 110–53, § 104(a)(3)","children":[],"tail":", made technical amendment to reference in original act which appears in text as reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s592"},"text":"section 592 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
