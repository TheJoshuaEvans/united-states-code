{"tag":"section","attrib":{"id":"idb5593384-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s744"},"text":null,"children":[{"tag":"num","attrib":{"value":"744"},"text":"§ 744.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of national preparedness system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5593385-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s744/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, acting through the Administrator, shall develop a national preparedness system to enable the Nation to meet the national preparedness goal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5593386-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s744/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Components","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The national preparedness system shall include the following components:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5593387-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s744/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Target capabilities and preparedness priorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5593388-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s744/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Equipment and training standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5593389-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s744/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training and exercises.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559338a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s744/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Comprehensive assessment system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559338b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s744/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Remedial action management program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559338c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s744/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal response capability inventory.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559338d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s744/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reporting requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559338e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s744/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal preparedness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb559338f-47c4-11f1-9665-b3e