{"tag":"section","attrib":{"id":"idb55dee7d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796"},"text":null,"children":[{"tag":"num","attrib":{"value":"796"},"text":"§ 796.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registry of disaster response contractors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55dee7e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55dee7f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “registry” means the registry created under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee80-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “small business concern”, “small business concern owned and controlled by socially and economically disadvantaged individuals”, “small business concern owned and controlled by women”, and “small business concern owned and controlled by service-disabled veterans” have the meanings given those terms under the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"15 U.S.C. 631","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55dee81-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registry","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55dee82-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish and maintain a registry of contractors who are willing to perform debris removal, distribution of supplies, reconstruction, and other disaster or emergency relief activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee83-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The registry shall include, for each business concern—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55dee84-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the business concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee85-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of the business concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee86-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the area served by the business concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee87-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of good or service provided by the business concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee88-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the bonding level of the business concern; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee89-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether the business concern is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55dee8a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a small business concern;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55dee8b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a small business concern owned and controlled by socially and economically disadvantaged individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55dee8c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/2/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a small business concern owned and controlled by women; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55dee8d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/2/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a small business concern owned and controlled by service-disabled veterans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee8e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Source of information","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55dee8f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information maintained in the registry shall be submitted on a voluntary basis and be kept current by the submitting business concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee90-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attestation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each business concern submitting information to the registry shall submit—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55dee91-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an attestation that the information is true; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55dee92-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation supporting such attestation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55dee93-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall verify that the documentation submitted by each business concern supports the information submitted by that business concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee94-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of registry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The registry shall be made generally available on the Internet site of the Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55dee95-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s796/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation of registry","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the acquisition planning for contracting for debris removal, distribution of supplies in a disaster, reconstruction, and other disaster or emergency relief activities, a Federal agency shall consult the registry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55dee96-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s697"},"text":"Pub. L. 109–295, title VI, § 697","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1461"},"text":"120 Stat. 1461","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb55dee97-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb55dee98-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb55dee99-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Small Business Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/536/s2"},"text":"Pub. L. 85–536, § 2","children":[],"tail":"(1 et seq.), "},{"tag":"date","attrib":{"date":"1958-07-18"},"text":"July 18, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/384"},"text":"72 Stat. 384","children":[],"tail":", which is classified generally to chapter 14A (§ 631 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
