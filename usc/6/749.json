{"tag":"section","attrib":{"id":"idb55933d3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s749"},"text":null,"children":[{"tag":"num","attrib":{"value":"749"},"text":"§ 749.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comprehensive assessment system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55933d4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s749/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in coordination with the National Council on Disability and the National Advisory Council, shall establish a comprehensive system to assess, on an ongoing basis, the Nation’s prevention capabilities and overall preparedness, including operational readiness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55933d5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s749/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance metrics and measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall ensure that each component of the national preparedness system, National Incident Management System, National Response Plan, and other related plans and strategies, and the reports required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s752"},"text":"section 752 of this title","children":[],"tail":" is developed, revised, and updated with clear and quantifiable performance metrics, measures, and outcomes."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55933d6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s749/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The assessment system established under subsection (a) shall assess—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55933d7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s749/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with the national preparedness system, National Incident Management System, National Response Plan, and other related plans and strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933d8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s749/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capability levels at the time of assessment against target capability levels defined pursuant to the guidelines established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s746/a"},"text":"section 746(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933d9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s749/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resource needs to meet the desired target capability levels defined pursuant to the guidelines established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s746/a"},"text":"section 746(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933da-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s749/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance of training, exercises, and operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55933db-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s649"},"text":"Pub. L. 109–295, title VI, § 649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1428"},"text":"120 Stat. 1428","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
