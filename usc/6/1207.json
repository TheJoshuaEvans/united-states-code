{"tag":"section","attrib":{"id":"idb57372af-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1207"},"text":null,"children":[{"tag":"num","attrib":{"value":"1207"},"text":"§ 1207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pipeline security inspections and enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb57372b0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1207/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 9 months after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", consistent with the Annex to the Memorandum of Understanding executed on "},{"tag":"date","attrib":{"date":"2006-08-09"},"text":"August 9, 2006","children":[],"tail":", between the Department of Transportation and the Department, the Secretary, in consultation with the Secretary of Transportation, shall establish a program for reviewing pipeline operator adoption of recommendations of the "},{"tag":"date","attrib":{"date":"2002-09-05"},"text":"September 5, 2002","children":[],"tail":", Department of Transportation Research and Special Programs Administration’s Pipeline Security Information Circular, including the review of pipeline security plans and critical facility inspections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57372b1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1207/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and inspection","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", the Secretary and the Secretary of Transportation shall develop and implement a plan for reviewing the pipeline security plans and an inspection of the critical facilities of the 100 most critical pipeline operators covered by the "},{"tag":"date","attrib":{"date":"2002-09-05"},"text":"September 5, 2002","children":[],"tail":", circular, where such facilities have not been inspected for security purposes since "},{"tag":"date","attrib":{"date":"2002-09-05"},"text":"September 5, 2002","children":[],"tail":", by either the Department or the Department of Transportation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57372b2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1207/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance review methodology","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In reviewing pipeline operator compliance under subsections (a) and (b), risk assessment methodologies shall be used to prioritize risks and to target inspection and enforcement actions to the highest risk pipeline assets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57372b3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1207/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", the Secretary and the Secretary of Transportation shall develop and transmit to pipeline operators security recommendations for natural gas and hazardous liquid pipelines and pipeline facilities. If the Secretary determines that regulations are appropriate, the Secretary shall consult with the Secretary of Transportation on the extent of risk and appropriate mitigation measures, and the Secretary or the Secretary of Transportation, consistent with the Annex to the Memorandum of Understanding executed on "},{"tag":"date","attrib":{"date":"2006-08-09"},"text":"August 9, 2006","children":[],"tail":", shall promulgate such regulations and carry out necessary inspection and enforcement actions. Any regulations shall incorporate the guidance provided to pipeline operators by the "},{"tag":"date","attrib":{"date":"2002-09-05"},"text":"September 5, 2002","children":[],"tail":", Department of Transportation Research and Special Programs Administration’s Pipeline Security Information Circular and contain additional requirements as necessary based upon the results of the inspections performed under subsection (b). The regulations shall include the imposition of civil penalties for noncompliance."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57372b4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1207/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the amounts appropriated pursuant to section 114(w) ","children":[{"tag":"ref","attrib":{"idref":"fn002170"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002170"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 49, there shall be made available to the Secretary to carry out this section—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57372b5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1207/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57372b6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1207/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for fiscal year 2009; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57372b7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1207/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $2,000,000 for fiscal year 2010.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57372b8-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXV/s1557"},"text":"Pub. L. 110–53, title XV, § 1557","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/475"},"text":"121 Stat. 475","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57372b9-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57372ba-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb57372bb-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s114/w"},"text":"Section 114(w) of title 49","children":[],"tail":", referred to in subsec. (e)(1), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s114/v"},"text":"section 114(v) of title 49","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/s1904/b/1/I"},"text":"Pub. L. 115–254, div. K, § 1904(b)(1)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3545"},"text":"132 Stat. 3545","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
