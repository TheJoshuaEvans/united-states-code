{"tag":"section","attrib":{"id":"idb53c83e8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a"},"text":null,"children":[{"tag":"num","attrib":{"value":"609a"},"text":"§ 609a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit Security Grant Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb53c83e9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Department a program to be known as the “Nonprofit Security Grant Program” (in this section referred to as the “Program”). Under the Program, the Secretary, acting through the Administrator, shall make grants to eligible nonprofit organizations described in subsection (b), through the State in which such organizations are located, for target hardening and other security enhancements to protect against terrorist attacks or other threats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c83ea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible recipients","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligible nonprofit organizations described in this subsection are organizations that are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53c83eb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and exempt from tax under section 501(a) of such title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c83ec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined by the Secretary to be at risk of terrorist attacks or other threats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c83ed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permitted uses","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53c83ee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The recipient of a grant under this section may use such grant for any of the following uses:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c83ef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Target hardening activities, including physical security enhancement equipment, inspection and screening systems, and alteration or remodeling of existing buildings or physical facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c83f0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fees for security training relating to physical security and cybersecurity, target hardening, terrorism awareness, and employee awareness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c83f1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facility security personnel costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c83f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expenses directly related to the administration of the grant, except that those expenses may not exceed 5 percent of the amount of the grant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c83f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other appropriate activity, including cybersecurity resilience activities, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c83f4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State through which a recipient receives a grant under this section may retain not more than 5 percent of each grant for expenses directly related to the administration of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c83f5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Outreach and technical assistance","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c83f6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Administrator establishes target allocations in determining award amounts under the Program, a State may request a project to use a portion of the target allocation for outreach and technical assistance if the State does not receive enough eligible applications from nonprofit organizations located outside high-risk urban areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c83f7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any outreach or technical assistance described in subparagraph (A) should prioritize underserved communities and nonprofit organizations that are traditionally underrepresented in the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c83f8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parameters","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In determining grant guidelines under subsection (g), the Administrator may determine the parameters for outreach and technical assistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c83f9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of performance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall make funds provided under this section available for use by a recipient of a grant for a period of not less than 36 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c83fa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall annually for each of fiscal years 2022 through 2028 submit to the Committee on Homeland Security of the House of Representatives and the Committee on Homeland Security and Governmental Affairs of the Senate a report containing information on the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53c83fb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expenditure by each grant recipient of grant funds made under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c83fc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of applications submitted by eligible nonprofit organizations to each State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c83fd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of applications submitted by each State to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c83fe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operations of the program office of the Program, including staffing resources and efforts with respect to subparagraphs (A) through (D) of subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c83ff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", the Administrator shall ensure that within the Federal Emergency Management Agency a program office for the Program (in this subsection referred to as the “program office”) shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53c8400-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be headed by a senior official of the Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c8401-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" administer the Program (including, where appropriate, in coordination with States), including relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c8402-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outreach, engagement, education, and technical assistance and support to eligible nonprofit organizations described in subsection (b), with particular attention to those organizations in underserved communities, before, during, and after the awarding of grants, including web-based training videos for eligible nonprofit organizations that provide guidance on preparing an application and the environmental planning and historic preservation process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8403-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of mechanisms to ensure program office processes are conducted in accordance with constitutional, statutory, and regulatory requirements that protect civil rights and civil liberties and advance equal access for members of underserved communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8404-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of mechanisms for the Administrator to provide feedback to eligible nonprofit organizations that do not receive grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8405-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of mechanisms to identify and collect data to measure the effectiveness of grants under the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8406-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment and enforcement of standardized baseline operational requirements for States, including requirements for States to eliminate or prevent any administrative or operational obstacles that may impact eligible nonprofit organizations described in subsection (b) from receiving grants under the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8407-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out efforts to prevent waste, fraud, and abuse, including through audits of grantees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8408-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/f/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting diversity in the types and locations of eligible nonprofit organizations that are applying for grants under the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c8409-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant guidelines","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, before awarding grants under this section, the Administrator—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53c840a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall publish guidelines, including a notice of funding opportunity or similar announcement, as the Administrator determines appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c840b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may prohibit States from closing application processes before the publication of those guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c840c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Paperwork Reduction Act","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Chapter 35 of title 44 (commonly known as the “Paperwork Reduction Act”) shall not apply to any changes to the application materials, Program forms, or other core Program documentation intended to enhance participation by eligible nonprofit organizations in the Program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53c840d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53c840e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated $360,000,000 for each of fiscal years 2023 through 2028 for grants under this section, of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53c840f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $180,000,000 each such fiscal year shall be for recipients in high-risk urban areas that receive funding under section 2003; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53c8410-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $180,000,000 each such fiscal year shall be for recipients in jurisdictions that do not so receive such funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53c8411-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s609a/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operations and support","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $18,000,000 for each of fiscal years 2023 through 2028 for Operations and Support at the Federal Emergency Management Agency for costs incurred for the management and administration (including evaluation) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53c8412-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXX/s2009"},"text":"Pub. L. 107–296, title XX, § 2009","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/108/s2/a"},"text":"Pub. L. 116–108, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-24"},"text":"Jan. 24, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3294"},"text":"133 Stat. 3294","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7101/a"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3616"},"text":"136 Stat. 3616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb53c8413-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb53c8414-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb53c8415-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7101/a/1"},"text":"Pub. L. 117–263, § 7101(a)(1)","children":[],"tail":", inserted “or other threats” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7101/a/2/A"},"text":"Pub. L. 117–263, § 7101(a)(2)(A)","children":[],"tail":", struck out “(a)” after “this subsection” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7101/a/2/B"},"text":"Pub. L. 117–263, § 7101(a)(2)(B)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “determined to be at risk of a terrorist attack by the Administrator.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7101/a/3/A"},"text":"Pub. L. 117–263, § 7101(a)(3)(A)","children":[],"tail":", (B), (D), (E), designated existing provisions as par. (1) and inserted heading, redesignated former pars. (1) to (3) as subpars. (A), (B), and (E), respectively, of par. (1) and realigned margins, added subpars. (C) and (D) of par. (1), and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7101/a/3/C"},"text":"Pub. L. 117–263, § 7101(a)(3)(C)","children":[],"tail":", substituted “equipment, inspection and screening systems, and alteration or remodeling of existing buildings or physical facilities” for “equipment and inspection and screening systems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7101/a/4/B"},"text":"Pub. L. 117–263, § 7101(a)(4)(B)","children":[],"tail":", (C), substituted “on the following:” and “(1) The expenditure” for “on the expenditure” and added pars. (2) to (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7101/a/4/A"},"text":"Pub. L. 117–263, § 7101(a)(4)(A)","children":[],"tail":", substituted “2022 through 2028” for “2020 through 2024”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7101/a/5"},"text":"Pub. L. 117–263, § 7101(a)(5)","children":[],"tail":", added subsecs. (f) to (i) and struck out former subsec. (f) which related to authorization of appropriations for fiscal years 2020 through 2024."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
