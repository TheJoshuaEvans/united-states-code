{"tag":"section","attrib":{"id":"idb5603832-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912"},"text":null,"children":[{"tag":"num","attrib":{"value":"912"},"text":"§ 912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Port Security Exercise Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5603833-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Under Secretary for Preparedness and in coordination with the Commandant of the Coast Guard, shall establish a Port Security Exercise Program (referred to in this section as the “Exercise Program”) for the purpose of testing and evaluating the capabilities of Federal, State, local, and foreign governments, commercial seaport personnel and management, governmental and nongovernmental emergency response providers, the private sector, or any other organization or entity, as the Secretary determines to be appropriate, to prevent, prepare for, mitigate against, respond to, and recover from acts of terrorism, natural disasters, and other emergencies at facilities required to submit a plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70103/c"},"text":"section 70103(c) of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5603834-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the Exercise Program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5603835-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conducts, on a periodic basis, port security exercises at such facilities that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5603836-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scaled and tailored to the needs of each facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5603837-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" live, in the case of the most at-risk facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5603838-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as realistic as practicable and based on current risk assessments, including credible threats, vulnerabilities, and consequences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5603839-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the National Incident Management System, the National Response Plan, the National Infrastructure Protection Plan, the National Preparedness Guidance, the National Preparedness Goal, the National Maritime Transportation Security Plan, and other such national initiatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb560383a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluated against clear and consistent performance measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb560383b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessed to learn best practices, which shall be shared with appropriate Federal, State, and local officials, commercial seaport personnel and management, governmental and nongovernmental emergency response providers, and the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb560383c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" followed by remedial action in response to lessons learned; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb560383d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assists State and local governments and facilities in designing, implementing, and evaluating exercises that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb560383e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conform to the requirements of paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb560383f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with any applicable Area Maritime Transportation Security Plan and State or Urban Area Homeland Security Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5603840-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Improvement plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish a port security exercise improvement plan process to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5603841-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and analyze each port security exercise for lessons learned and best practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5603842-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disseminate lessons learned and best practices to participants in the Exercise Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5603843-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitor the implementation of lessons learned and best practices by participants in the Exercise Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5603844-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s912/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct remedial action tracking and long-term trend analysis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5603845-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tI/s114"},"text":"Pub. L. 109–347, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1896"},"text":"120 Stat. 1896","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
