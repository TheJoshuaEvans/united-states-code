{"tag":"section","attrib":{"id":"idb57101f8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183"},"text":null,"children":[{"tag":"num","attrib":{"value":"1183"},"text":"§ 1183.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Over-the-road bus exercises","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb57101f9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a program for conducting security exercises for over-the-road bus transportation for the purpose of assessing and improving the capabilities of entities described in subsection (b) to prevent, prepare for, mitigate, respond to, and recover from acts of terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101fa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Entities to be assessed under the program shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57101fb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, and local agencies and tribal governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101fc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over-the-road bus operators and over-the-road bus terminal owners and operators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101fd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" governmental and nongovernmental emergency response providers and law enforcement agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101fe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other organization or entity that the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101ff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that the program—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5710200-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consolidates existing security exercises for over-the-road bus operators and terminals administered by the Department and the Department of Transportation, as jointly determined by the Secretary and the Secretary of Transportation, unless the Secretary waives this consolidation requirement, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5710201-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consists of exercises that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5710202-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scaled and tailored to the needs of the over-the-road bus operators and terminals, including addressing the needs of the elderly and individuals with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5710203-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" live, in the case of the most at-risk facilities to a terrorist attack;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5710204-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinated with appropriate officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5710205-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as realistic as practicable and based on current risk assessments, including credible threats, vulnerabilities, and consequences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5710206-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inclusive, as appropriate, of over-the-road bus frontline employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5710207-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the National Incident Management System, the National Response Plan, the National Infrastructure Protection Plan, the National Preparedness Guidance, the National Preparedness Goal, and other such national initiatives;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5710208-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides that exercises described in paragraph (2) will be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5710209-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluated by the Secretary against clear and consistent performance measures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb571020a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessed by the Secretary to identify best practices, which shall be shared, as appropriate, with operators providing over-the-road bus transportation, nonprofit employee organizations that represent over-the-road bus employees, Federal, State, local, and tribal officials, governmental and nongovernmental emergency response providers, and law enforcement personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb571020b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used to develop recommendations, as appropriate, provided to over-the-road bus operators and terminal owners and operators on remedial action to be taken in response to lessons learned;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb571020c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows for proper advanced notification of communities and local governments in which exercises are held, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb571020d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assists State, local, and tribal governments and over-the-road bus operators and terminal owners and operators in designing, implementing, and evaluating additional exercises that conform to the requirements of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb571020e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1183/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Exercise Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall ensure that the exercise program developed under subsection (c) is consistent with the National Exercise Program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s748"},"text":"section 748 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb571020f-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXV/s1533"},"text":"Pub. L. 110–53, title XV, § 1533","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/460"},"text":"121 Stat. 460","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
