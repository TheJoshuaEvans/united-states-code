{"tag":"section","attrib":{"id":"idb4dd257a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s121a"},"text":null,"children":[{"tag":"num","attrib":{"value":"121a"},"text":"§ 121a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeland Security Intelligence Program","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is established within the Department of Homeland Security a Homeland Security Intelligence Program. The Homeland Security Intelligence Program constitutes the intelligence activities of the Office of Intelligence and Analysis of the Department that serve predominantly departmental missions.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb4dd257b-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/277/tV/s501"},"text":"Pub. L. 112–277, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2476"},"text":"126 Stat. 2476","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4dd257c-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4dd257d-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4dd257e-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Intelligence Authorization Act for Fiscal Year 2013, and not as part of the Homeland Security Act of 2002 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
