{"tag":"section","attrib":{"id":"idb4f2aa0b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195i"},"text":null,"children":[{"tag":"num","attrib":{"value":"195i"},"text":"§ 195i.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chemical Security Analysis Center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4f2aa0c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195i/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Under Secretary for Science and Technology, shall designate the laboratory described in subsection (b) as an additional laboratory pursuant to the authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s188/c/2"},"text":"section 188(c)(2) of this title","children":[],"tail":", which shall be used to conduct studies, analyses, and research to assess and address domestic chemical security events."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f2aa0d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195i/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laboratory described","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The laboratory described in this subsection is the laboratory known, as of ","children":[{"tag":"date","attrib":{"date":"2022-12-23"},"text":"December 23, 2022","children":[],"tail":", as the Chemical Security Analysis Center."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f2aa0e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195i/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laboratory activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to the authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s182/4"},"text":"section 182(4) of this title","children":[],"tail":", the Chemical Security Analysis Center shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f2aa0f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195i/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and develop approaches and mitigation strategies to domestic chemical security threats, including the development of comprehensive, research-based definable goals relating to such approaches and mitigation strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f2aa10-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195i/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an enduring science-based chemical threat and hazard analysis capability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f2aa11-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195i/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide expertise regarding risk and consequence modeling, chemical sensing and detection, analytical chemistry, acute chemical toxicology, synthetic chemistry and reaction characterization, and nontraditional chemical agents and emerging chemical threats;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f2aa12-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195i/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" staff and operate a technical assistance program that provides operational support and subject matter expertise, design and execute laboratory and field tests, and provide a comprehensive knowledge repository of chemical threat information that is continuously updated with data from scientific, intelligence, operational, and private sector sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f303-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195i/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult, as appropriate, with the Countering Weapons of Mass Destruction Office of the Department to mitigate, prepare, and respond to threats, hazards, and risks associated with domestic chemical security events; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f304-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195i/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such other activities authorized under this section as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f4f305-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195i/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section amends, alters, or affects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f4f306-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195i/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the responsibilities of the Countering Weapons of Mass Destruction Office of the Department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f4f307-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195i/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities or requirements authorized to other entities within the Federal Government, including the activities and requirements of the Environmental Protection Agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7412/r"},"text":"section 7412(r) of title 42","children":[],"tail":", the Toxic Substances Control Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2601"},"text":"15 U.S.C. 2601","children":[],"tail":" et seq.), and the Comprehensive Environmental Response, Compensation, and Liability Act of 1980 (commonly referred to as “Superfund”; "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"42 U.S.C. 9601","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4f4f308-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIII/s323"},"text":"Pub. L. 107–296, title III, § 323","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7106/a"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3624"},"text":"136 Stat. 3624","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4f4f309-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4f4f30a-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4f4f30b-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Toxic Substances Control Act, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/469"},"text":"Pub. L. 94–469","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-11"},"text":"Oct. 11, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2003"},"text":"90 Stat. 2003","children":[],"tail":", which is classified generally to chapter 53 (§ 2601 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s2601"},"text":"section 2601 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Comprehensive Environmental Response, Compensation, and Liability Act of 1980, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/510"},"text":"Pub. L. 96–510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2767"},"text":"94 Stat. 2767","children":[],"tail":", which is classified principally to chapter 103 (§ 9601 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s9601"},"text":"section 9601 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
