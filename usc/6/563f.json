{"tag":"section","attrib":{"id":"idb5330dbf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f"},"text":null,"children":[{"tag":"num","attrib":{"value":"563f"},"text":"§ 563f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Diversified security technology industry marketplace","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5330dc0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", the Administrator shall develop and submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Homeland Security of the House of Representatives a strategy to promote a diverse security technology industry marketplace upon which the Administrator can rely to acquire advanced transportation security technologies or capabilities, including by increased participation of small business innovators."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330dc1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy required under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5330dc2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information on how existing Administration solicitation, testing, evaluation, piloting, acquisition, and procurement processes impact the Administrator’s ability to acquire from the security technology industry marketplace, including small business innovators that have not previously provided technology to the Administration, innovative technologies or capabilities with the potential to enhance transportation security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330dc3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Specific actions that the Administrator will take, including modifications to the processes described in paragraph (1), to foster diversification within the security technology industry marketplace.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330dc4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projected timelines for implementing the actions described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330dc5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Plans for how the Administrator could, to the extent practicable, assist a small business innovator periodically during such processes, including when such an innovator lacks adequate resources to participate in such processes, to facilitate an advanced transportation security technology or capability being developed and acquired by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330dc6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the feasibility of partnering with an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and exempt from tax under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"section 501(a) of title 26","children":[],"tail":" to provide venture capital to businesses, particularly small business innovators, for commercialization of innovative transportation security technologies that are expected to be ready for commercialization in the near term and within 36 months."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330dc7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Feasibility assessment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the feasibility assessment under subsection (b)(5), the Administrator shall consider the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5330dc8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establishing an organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"section 501(c)(3) of title 26","children":[],"tail":" and exempt from tax under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"section 501(a) of title 26","children":[],"tail":" as a venture capital partnership between the private sector and the intelligence community to help businesses, particularly small business innovators, commercialize innovative security-related technologies."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330dc9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enhanced engagement through the Science and Technology Directorate of the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330dca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed as requiring changes to the Transportation Security Administration standards for security technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330dcb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5330dcc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence community","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “intelligence community” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"section 3003 of title 50","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330dcd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business concern","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “small business concern” has the meaning described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"section 632 of title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330dce-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563f/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small business innovator","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “small business innovator” means a small business concern that has an advanced transportation security technology or capability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5330dcf-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVI/s1617"},"text":"Pub. L. 107–296, title XVI, § 1617","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1913/a"},"text":"Pub. L. 115–254, div. K, title I, § 1913(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3554"},"text":"132 Stat. 3554","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
