{"tag":"section","attrib":{"id":"idb52be27f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s494"},"text":null,"children":[{"tag":"num","attrib":{"value":"494"},"text":"§ 494.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other functions and activities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of more effectively coordinating the policies and functions of the United States Government relating to homeland security, the Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52be280-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s494/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess the objectives, commitments, and risks of the United States in the interest of homeland security and to ","children":[{"tag":"ref","attrib":{"idref":"fn002088"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002088"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “to” probably should not appear."}],"tail":" make resulting recommendations to the President;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be281-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s494/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee and review homeland security policies of the Federal Government and to ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" make resulting recommendations to the President; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be282-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s494/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform such other functions as the President may direct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb52be283-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIX/s904"},"text":"Pub. L. 107–296, title IX, § 904","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2259"},"text":"116 Stat. 2259","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
