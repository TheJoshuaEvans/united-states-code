{"tag":"section","attrib":{"id":"idb552085f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671"},"text":null,"children":[{"tag":"num","attrib":{"value":"671"},"text":"§ 671.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5520860-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “agency” has the meaning given it in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551"},"text":"section 551 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5520861-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered Federal agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered Federal agency” means the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5520862-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical infrastructure information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “critical infrastructure information” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s650"},"text":"section 650 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5520863-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical infrastructure protection program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “critical infrastructure protection program” means any component or bureau of a covered Federal agency that has been designated by the President or any agency head to receive critical infrastructure information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5520864-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protected system","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “protected system”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5520865-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any service, physical or computer-based system, process, or procedure that directly or indirectly affects the viability of a facility of critical infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5520866-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any physical or computer-based system, including a computer, computer system, computer or communications network, or any component hardware or element thereof, software program, processing instructions, or information or data in transmission or storage therein, irrespective of the medium of transmission or storage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5520867-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5520868-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “voluntary”, in the case of any submittal of critical infrastructure information to a covered Federal agency, means the submittal thereof in the absence of such agency’s exercise of legal authority to compel access to or submission of such information and may be accomplished by a single entity or an Information Sharing and Analysis Organization on behalf of itself or its members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5520869-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “voluntary”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb552086a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of any action brought under the securities laws as is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c/a/47"},"text":"section 78c(a)(47) of title 15","children":[],"tail":"—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idb552086b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671/6/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include information or statements contained in any documents or materials filed with the Securities and Exchange Commission, or with Federal banking regulators, pursuant to section 78","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"(i) of title 15; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb552086c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671/6/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the submittal of critical infrastructure information, does not include any disclosure or writing that when made accompanied the solicitation of an offer or a sale of securities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb552086d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s671/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include information or statements submitted or relied upon as a basis for making licensing or permitting determinations, or during regulatory proceedings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb552086e-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2222"},"text":"Pub. L. 107–296, title XXII, § 2222","children":[],"tail":", formerly title II, § 212, "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2150"},"text":"116 Stat. 2150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dN/tII/s204"},"text":"Pub. L. 114–113, div. N, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2961"},"text":"129 Stat. 2961","children":[],"tail":"; renumbered title XXII, § 2222, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/2/H"},"text":"Pub. L. 115–278, § 2(g)(2)(H)","children":[],"tail":", (9)(B)(i), "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4178"},"text":"132 Stat. 4178","children":[],"tail":", 4181; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7143/b/2/M"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7143(b)(2)(M)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3661"},"text":"136 Stat. 3661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb552086f-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5520870-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb5520871-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s131"},"text":"section 131 of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/115/278"},"text":"Pub. L. 115–278","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5520872-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/M/i"},"text":"Pub. L. 117–263, § 7143(b)(2)(M)(i)","children":[],"tail":", added par. (3) and struck out former par. (3) which defined critical infrastructure information."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (5) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/M/ii"},"text":"Pub. L. 117–263, § 7143(b)(2)(M)(ii)","children":[],"tail":", (iii), redesignated pars. (6) and (7) as (5) and (6), respectively, and struck out former pars. (5) and (8) which defined Information Sharing and Analysis Organization and cybersecurity risk and incident, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/9/B/i"},"text":"Pub. L. 115–278, § 2(g)(9)(B)(i)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s659"},"text":"section 659 of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s148"},"text":"section 148 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Par. (5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s204/1/A"},"text":"Pub. L. 114–113, § 204(1)(A)","children":[],"tail":", inserted “, including information related to cybersecurity risks and incidents,” after “critical infrastructure information” and “, including cybersecurity risks and incidents,” after “related to critical infrastructure”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s204/1/B"},"text":"Pub. L. 114–113, § 204(1)(B)","children":[],"tail":", inserted “, including cybersecurity risks and incidents,” after “critical infrastructure information” and “, including cybersecurity risks and incidents,” after “related to critical infrastructure”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s204/1/C"},"text":"Pub. L. 114–113, § 204(1)(C)","children":[],"tail":", inserted “, including cybersecurity risks and incidents,” after “critical infrastructure information”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s204/2"},"text":"Pub. L. 114–113, § 204(2)","children":[],"tail":", added par. (8)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5520873-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb5520874-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of this part as the “Critical Infrastructure Information Act of 2002”, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s2221"},"text":"section 2221 of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb5520875-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition on New Regulatory Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dN/tII/s210"},"text":"Pub. L. 114–113, div. N, title II, § 210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2962"},"text":"129 Stat. 2962","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/113/dN/tII/s210"},"text":"“Nothing in this subtitle [subtitle A (§§ 201–211) of title II of div. N of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":", see Short Title of 2015 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":"] or the amendments made by this subtitle may be construed to grant the Secretary any authority to promulgate regulations or set standards relating to the cybersecurity of non-Federal entities, not including State, local, and tribal governments, that was not in effect on the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idb5520876-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Definitions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dN/tII/s202"},"text":"Pub. L. 114–113, div. N, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2956"},"text":"129 Stat. 2956","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/h/1/A"},"text":"Pub. L. 115–278, § 2(h)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4181"},"text":"132 Stat. 4181","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/278/s2/h/1/A"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this subtitle [subtitle A (§§ 201–211) of title II of div. N of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":", see Short Title of 2015 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate congressional committees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘appropriate congressional committees’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cybersecurity risk; incident","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms ‘cybersecurity risk’ and ‘incident’ have the meanings given those terms in section 2209 of the Homeland Security Act of 2002 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s659"},"text":"6 U.S.C. 659","children":[],"tail":"] [see now "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s650"},"text":"6 U.S.C. 650","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cyber threat indicator; defensive measure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms ‘cyber threat indicator’ and ‘defensive measure’ have the meanings given those terms in section 102 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1501"},"text":"6 U.S.C. 1501","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Department’ means the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of Homeland Security.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
