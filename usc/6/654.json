{"tag":"section","attrib":{"id":"idb543afe0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s654"},"text":null,"children":[{"tag":"num","attrib":{"value":"654"},"text":"§ 654.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Infrastructure Security Division","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb543afe1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s654/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543afe2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s654/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established in the Agency an Infrastructure Security Division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afe3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s654/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Executive Assistant Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Infrastructure Security Division shall be headed by an Executive Assistant Director for Infrastructure Security (in this section referred to as “the Executive Assistant Director”), who shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb543afe4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s654/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be at the level of Assistant Secretary within the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543afe5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s654/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the President without the advice and consent of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543afe6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s654/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afe7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s654/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reference","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any reference to the Assistant Secretary for Infrastructure Protection or Assistant Director for Infrastructure Security in any law, regulation, map, document, record, or other paper of the United States shall be deemed to be a reference to the Executive Assistant Director for Infrastructure Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543afe8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s654/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Executive Assistant Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543afe9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s654/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct the critical infrastructure security efforts of the Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s654/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out, at the direction of the Director, the Chemical Facilities Anti-Terrorism Standards Program established under subchapter XVI and the secure handling of ammonium nitrate program established under part J of subchapter VIII, or any successor programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afeb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s654/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fully participate in the mechanisms required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s652/c/7"},"text":"section 652(c)(7) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s654/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such other duties and powers as prescribed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb543afed-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2204"},"text":"Pub. L. 107–296, title XXII, § 2204","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/a"},"text":"Pub. L. 115–278, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4174"},"text":"132 Stat. 4174","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXC/s9001/d/1"},"text":"Pub. L. 116–283, div. H, title XC, § 9001(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4767"},"text":"134 Stat. 4767","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb543afee-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb543afef-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb543aff0-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9001/d/1/A/i"},"text":"Pub. L. 116–283, § 9001(d)(1)(A)(i)","children":[],"tail":", in heading, substituted “Executive Assistant Director” for “Assistant Director” and, in introductory provisions, substituted “Executive Assistant Director for Infrastructure Security” for “Assistant Director for Infrastructure Security” and “‘the Executive Assistant Director’ ” for “the ‘Assistant Director’ ”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9001/d/1/A/ii"},"text":"Pub. L. 116–283, § 9001(d)(1)(A)(ii)","children":[],"tail":", inserted “or Assistant Director for Infrastructure Security” after “Assistant Secretary for Infrastructure Protection” and substituted “Executive Assistant Director for Infrastructure Security.” for “Assistant Director for Infrastructure Security.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s9001/d/1/B"},"text":"Pub. L. 116–283, § 9001(d)(1)(B)","children":[],"tail":", substituted “Executive Assistant Director” for “Assistant Director” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb543aff1-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb543aff2-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuation in Office","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXC/s9001/d/2"},"text":"Pub. L. 116–283, div. H, title XC, § 9001(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4767"},"text":"134 Stat. 4767","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dH/tXC/s9001/d/2"},"text":"“The individual serving as the Assistant Director for Infrastructure Security of the Cybersecurity and Infrastructure Security Agency of the Department of Homeland Security on the day before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"] may serve as the Executive Assistant Director for Infrastructure Security on and after that date without the need for renomination or reappointment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb54620f3-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Assistant Secretary for Infrastructure Protection Authorized To Serve as Assistant Director for Infrastructure Security","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/b/4"},"text":"Pub. L. 115–278, § 2(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4175"},"text":"132 Stat. 4175","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/278/s2/b/4"},"text":"“The individual serving as the Assistant Secretary for Infrastructure Protection on the day before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":"] may continue to serve as the Assistant Director for Infrastructure Security on and after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
