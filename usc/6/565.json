{"tag":"section","attrib":{"id":"idb5330dd1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s565"},"text":null,"children":[{"tag":"num","attrib":{"value":"565"},"text":"§ 565.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance validation and oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5330dd2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s565/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", the Administrator shall develop and implement a preventive maintenance validation process for security-related technology deployed to airports."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330dd3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s565/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance by Administration personnel at airports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For maintenance to be carried out by Administration personnel at airports, the process referred to in subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5330dd4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s565/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guidance to Administration personnel at airports specifying how to conduct and document preventive maintenance actions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330dd5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s565/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mechanisms for the Administrator to verify compliance with the guidance issued pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330dd6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s565/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maintenance by contractors at airports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For maintenance to be carried by a contractor at airports, the process referred to in subsection (a) shall require the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5330dd7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s565/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Provision of monthly preventative maintenance schedules to appropriate Administration personnel at each airport that includes information on each action to be completed by contractor.","children":[{"tag":"ref","attrib":{"idref":"fn002091"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002091"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “a”."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330dd8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s565/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notification to appropriate Administration personnel at each airport when maintenance action is completed by a contractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5330dd9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s565/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A process for independent validation by a third party of contractor maintenance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5330dda-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s565/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for noncompliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall require maintenance for any contracts entered into 60 days after ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", or later for security-related technology deployed to airports to include penalties for noncompliance when it is determined that either preventive or corrective maintenance has not been completed according to contractual requirements and manufacturers’ specifications."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5330ddb-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVI/s1621"},"text":"Pub. L. 107–296, title XVI, § 1621","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1918/a"},"text":"Pub. L. 115–254, div. K, title I, § 1918(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3558"},"text":"132 Stat. 3558","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
