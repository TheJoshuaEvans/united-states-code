{"tag":"section","attrib":{"id":"idb5593368-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741"},"text":null,"children":[{"tag":"num","attrib":{"value":"741"},"text":"§ 741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5593369-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “capability” means the ability to provide the means to accomplish one or more tasks under specific conditions and to specific performance standards. A capability may be achieved with any combination of properly planned, organized, equipped, trained, and exercised personnel that achieves the intended outcome.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559336a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Credentialed; credentialing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “credentialed” and “credentialing” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s311"},"text":"section 311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559336b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hazard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “hazard” has the meaning given that term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5195a/a/1"},"text":"section 5195a(a)(1) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559336c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission assignment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “mission assignment” means a work order issued to a Federal agency by the Agency, directing completion by that agency of a specified task and setting forth funding, other managerial controls, and guidance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559336d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National preparedness goal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national preparedness goal” means the national preparedness goal established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s743"},"text":"section 743 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559336e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National preparedness system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national preparedness system” means the national preparedness system established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s744"},"text":"section 744 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559336f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National training program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national training program” means the national training program established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s748/a"},"text":"section 748(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5593370-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational readiness","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “operational readiness” means the capability of an organization, an asset, a system, or equipment to perform the missions or functions for which it is organized or designed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5593371-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance measure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “performance measure” means a quantitative or qualitative characteristic used to gauge the results of an outcome compared to its intended purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5593372-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance metric","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “performance metric” means a particular value or characteristic used to measure the outcome that is generally expressed in terms of a baseline and a target.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5593373-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prevention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “prevention” means any activity undertaken to avoid, prevent, or stop a threatened or actual act of terrorism.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5593374-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resources","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “resources” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s311"},"text":"section 311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5593375-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Type","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “type” means a classification of resources that refers to the capability of a resource.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5593376-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s741/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Typed; typing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “typed” and “typing” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s311"},"text":"section 311 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5593377-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s641"},"text":"Pub. L. 109–295, title VI, § 641","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1424"},"text":"120 Stat. 1424","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tIV/s401/b"},"text":"Pub. L. 110–53, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/302"},"text":"121 Stat. 302","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5593378-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5593379-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb559337a-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Pars. (2) to (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53"},"text":"Pub. L. 110–53","children":[],"tail":" added pars. (2) and (12) to (14) and redesignated former pars. (2) to (10) as (3) to (11), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
