{"tag":"section","attrib":{"id":"idb4f03959-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d"},"text":null,"children":[{"tag":"num","attrib":{"value":"195d"},"text":"§ 195d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Social media working group","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4f0395a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish within the Department a social media working group (in this section referred to as the “Group”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f0395b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In order to enhance the dissemination of information through social media technologies between the Department and appropriate stakeholders and to improve use of social media technologies in support of preparedness, response, and recovery, the Group shall identify, and provide guidance and best practices to the emergency preparedness and response community on, the use of social media technologies before, during, and after a natural disaster or an act of terrorism or other man-made disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f0395c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f0395d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Membership of the Group shall be composed of a cross section of subject matter experts from Federal, State, local, tribal, territorial, and nongovernmental organization practitioners, including representatives from the following entities:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f0395e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Public Affairs of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0395f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Chief Information Officer of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03960-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Privacy Office of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03961-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03962-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Disability Integration and Coordination of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03963-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The American Red Cross.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03964-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Forest Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03965-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Centers for Disease Control and Prevention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03966-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Geological Survey.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03967-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Oceanic and Atmospheric Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03968-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson; co-chairperson","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f03969-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, or a designee of the Secretary, shall serve as the chairperson of the Group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0396a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Co-chairperson","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairperson shall designate, on a rotating basis, a representative from a State or local government who is a member of the Group to serve as the co-chairperson of the Group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f0396b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The chairperson shall appoint, on a rotating basis, qualified individuals to the Group. The total number of such additional members shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f0396c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be equal to or greater than the total number of regular members under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0396d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4f0396e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not fewer than 3 representatives from the private sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f0396f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" representatives from—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb4f03970-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" State, local, tribal, and territorial entities, including from—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idb4f03971-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/3/B/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb4f03972-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/3/B/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fire services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb4f03973-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/3/B/ii/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb4f03974-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/3/B/ii/I/dd"},"text":null,"children":[{"tag":"num","attrib":{"value":"dd"},"text":"(dd)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health entities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb4f03975-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" universities and academia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb4f03976-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/3/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit disaster relief organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03977-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term limits","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairperson shall establish term limits for individuals appointed to the Group under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03978-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation with non-members","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent practicable, the Group shall work with entities in the public and private sectors to carry out subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03979-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f0397a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial meeting","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2015-11-05"},"text":"November 5, 2015","children":[],"tail":", the Group shall hold its initial meeting."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f0397b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsequent meetings","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"After the initial meeting under paragraph (1), the Group shall meet—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f0397c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the call of the chairperson; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0397d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less frequently than twice each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f0397e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Virtual meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each meeting of the Group may be held virtually.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f0397f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"During each year in which the Group meets, the Group shall submit to the appropriate congressional committees a report that includes the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f03980-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A review and analysis of current and emerging social media technologies being used to support preparedness and response activities related to natural disasters and acts of terrorism and other man-made disasters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03981-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A review of best practices and lessons learned on the use of social media technologies during the response to natural disasters and acts of terrorism and other man-made disasters that occurred during the period covered by the report at issue.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03982-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations to improve the Department’s use of social media technologies for emergency management purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03983-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations to improve public awareness of the type of information disseminated through social media technologies, and how to access such information, during a natural disaster or an act of terrorism or other man-made disaster.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03984-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A review of available training for Federal, State, local, tribal, and territorial officials on the use of social media technologies in response to a natural disaster or an act of terrorism or other man-made disaster.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03985-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A review of coordination efforts with the private sector to discuss and resolve legal, operational, technical, privacy, and security concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03986-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of group","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f03987-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Group shall terminate on the date that is 5 years after ","children":[{"tag":"date","attrib":{"date":"2015-11-05"},"text":"November 5, 2015","children":[],"tail":", unless the chairperson renews the Group for a successive 5-year period, prior to the date on which the Group would otherwise terminate, by submitting to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Homeland Security of the House of Representatives a certification that the continued existence of the Group is necessary to fulfill the purpose described in subsection (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03988-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195d/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continued renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The chairperson may continue to renew the Group for successive 5-year periods by submitting a certification in accordance with paragraph (1) prior to the date on which the Group would otherwise terminate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4f03989-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIII/s318"},"text":"Pub. L. 107–296, title III, § 318","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/80/s2/a"},"text":"Pub. L. 114–80, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-05"},"text":"Nov. 5, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/646"},"text":"129 Stat. 646","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
