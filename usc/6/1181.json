{"tag":"section","attrib":{"id":"idb571018d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181"},"text":null,"children":[{"tag":"num","attrib":{"value":"1181"},"text":"§ 1181.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Over-the-road bus security assessments and plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb571018e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", the Secretary shall issue regulations that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb571018f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require each over-the-road bus operator assigned to a high-risk tier under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5710190-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct a vulnerability assessment in accordance with subsections (c) and (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5710191-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prepare, submit to the Secretary for approval, and implement a security plan in accordance with subsection (e); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5710192-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish standards and guidelines for developing and implementing the vulnerability assessments and security plans for carriers assigned to high-risk tiers consistent with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5710193-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non high-risk programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may establish a security program for over-the-road bus operators not assigned to a high-risk tier, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5710194-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance for such operators in conducting vulnerability assessments and preparing and implementing security plans, as determined appropriate by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5710195-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process to review and approve such assessments and plans, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5710196-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for submission","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 9 months after the date of issuance of the regulations under subsection (a), the vulnerability assessments and security plans required by such regulations for over-the-road bus operators assigned to a high-risk tier shall be completed and submitted to the Secretary for review and approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5710197-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vulnerability assessments","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5710198-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide technical assistance and guidance to over-the-road bus operators in conducting vulnerability assessments under this section and shall require that each vulnerability assessment of an operator assigned to a high-risk tier under this section includes, as appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5710199-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification and evaluation of critical assets and infrastructure, including platforms, stations, terminals, and information systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb571019a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of the vulnerabilities to those assets and infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb571019b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identification of weaknesses in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb571019c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/d/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb571019d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/d/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" passenger and cargo security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb571019e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/d/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the security of programmable electronic devices, computers, or other automated systems which are used in providing over-the-road bus transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb571019f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/d/1/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" alarms, cameras, and other protection systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57101a0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/d/1/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communications systems and utilities needed for over-the-road bus security purposes, including dispatching systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57101a1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/d/1/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency response planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57101a2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/d/1/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57101a3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/d/1/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101a4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threat information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide in a timely manner to the appropriate employees of an over-the-road bus operator, as designated by the over-the-road bus operator, threat information that is relevant to the operator when preparing and submitting a vulnerability assessment and security plan, including an assessment of the most likely methods that could be used by terrorists to exploit weaknesses in over-the-road bus security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101a5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57101a6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide technical assistance and guidance to over-the-road bus operators in preparing and implementing security plans under this section and shall require that each security plan of an over-the-road bus operator assigned to a high-risk tier under this section includes, as appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57101a7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the identification of a security coordinator having authority—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb57101a8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement security actions under the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57101a9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate security improvements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb57101aa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive communications from appropriate Federal officials regarding over-the-road bus security;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57101ab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of needed capital and operational improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57101ac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures to be implemented or used by the over-the-road bus operator in response to a terrorist attack, including evacuation and passenger communication plans that include individuals with disabilities, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57101ad-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of steps taken with State and local law enforcement agencies, emergency responders, and Federal officials to coordinate security measures and plans for response to a terrorist attack;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57101ae-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/e/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategy and timeline for conducting training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1184"},"text":"section 1184 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57101af-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/e/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhanced security measures to be taken by the over-the-road bus operator when the Secretary declares a period of heightened security risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57101b0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/e/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans for providing redundant and backup systems required to ensure the continued operation of critical elements of the over-the-road bus operator’s system in the event of a terrorist attack or other incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57101b1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/e/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other actions or procedures as the Secretary determines are appropriate to address the security of over-the-road bus operators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101b2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security coordinator requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall require that the individual serving as the security coordinator identified in paragraph (1)(A) is a citizen of the United States. The Secretary may waive this requirement with respect to an individual if the Secretary determines that it is appropriate to do so based on a background check of the individual and a review of the consolidated terrorist watchlist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101b3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for review process","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after receiving the assessments and plans required under this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57101b4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review each vulnerability assessment and security plan submitted to the Secretary in accordance with subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101b5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require amendments to any security plan that does not meet the requirements of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101b6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve any vulnerability assessment or security plan that meets the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101b7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim security measures","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may require over-the-road bus operators, during the period before the deadline established under subsection (c), to submit a security plan to implement any necessary interim security measures essential to providing adequate security of the over-the-road bus operator’s system. An interim plan required under this subsection shall be superseded by a plan required under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101b8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tier assignment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall assign each over-the-road bus operator to a risk-based tier established by the Secretary:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57101b9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may request, and an over-the-road bus operator shall provide, information necessary for the Secretary to assign an over-the-road bus operator to the appropriate tier under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101ba-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date an over-the-road bus operator is assigned to a tier under this section, the Secretary shall notify the operator of the tier to which it is assigned and the reasons for such assignment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101bb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-risk tiers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least one of the tiers established by the Secretary under this section shall be a tier designated for high-risk over-the-road bus operators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101bc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reassignment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may reassign an over-the-road bus operator to another tier, as appropriate, in response to changes in risk and the Secretary shall notify the over-the-road bus operator within 60 days after such reassignment and provide the operator with the reasons for such reassignment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101bd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Existing procedures, protocols, and standards","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57101be-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In response to a petition by an over-the-road bus operator or at the discretion of the Secretary, the Secretary may determine that existing procedures, protocols, and standards meet all or part of the requirements of this section regarding vulnerability assessments and security plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101bf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon review and written determination by the Secretary that existing procedures, protocols, or standards of an over-the-road bus operator satisfy the requirements of this section, the over-the-road bus operator may elect to comply with those procedures, protocols, or standards instead of the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101c0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partial approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that the existing procedures, protocols, or standards of an over-the-road bus operator satisfy only part of the requirements of this section, the Secretary may accept such submission, but shall require submission by the operator of any additional information relevant to the vulnerability assessment and security plan of the operator to ensure that the remaining requirements of this section are fulfilled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101c1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Secretary determines that particular existing procedures, protocols, or standards of an over-the-road bus operator under this subsection do not satisfy the requirements of this section, the Secretary shall provide to the operator a written notification that includes an explanation of the reasons for nonacceptance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101c2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection shall relieve the Secretary of the obligation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb57101c3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/i/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to review the vulnerability assessment and security plan submitted by an over-the-road bus operator under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb57101c4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/i/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to approve or disapprove each submission on an individual basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101c5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic evaluation by over-the-road bus provider required","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57101c6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 3 years after the date on which a vulnerability assessment or security plan required to be submitted to the Secretary under subsection (c) is approved, and at least once every 5 years thereafter (or on such a schedule as the Secretary may establish by regulation), an over-the-road bus operator who submitted a vulnerability assessment and security plan and who is still assigned to the high-risk tier shall also submit to the Secretary an evaluation of the adequacy of the vulnerability assessment and security plan that includes a description of any material changes made to the vulnerability assessment or security plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101c7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of evaluation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 180 days after the date on which an evaluation is submitted, the Secretary shall review the evaluation and notify the over-the-road bus operator submitting the evaluation of the Secretary’s approval or disapproval of the evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101c8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Shared facilities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may permit under this section the development and implementation of coordinated vulnerability assessments and security plans to the extent that an over-the-road bus operator shares facilities with, or is colocated with, other transportation entities or providers that are required to develop vulnerability assessments and security plans under Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb57101c9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondisclosure of information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb57101ca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submission of information to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as authorizing the withholding of any information from Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb57101cb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1181/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of independently furnished information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed as affecting any authority or obligation of a Federal agency to disclose any record or information that the Federal agency obtains from an over-the-road bus operator under any other Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57101cc-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXV/s1531"},"text":"Pub. L. 110–53, title XV, § 1531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/454"},"text":"121 Stat. 454","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
