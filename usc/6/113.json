{"tag":"section","attrib":{"id":"idb4d388c8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113"},"text":null,"children":[{"tag":"num","attrib":{"value":"113"},"text":"§ 113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4d388c9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputy Secretary; Under Secretaries","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4d388ca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided under paragraph (2), there are the following officers, appointed by the President, by and with the advice and consent of the Senate:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4d388cb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Deputy Secretary of Homeland Security, who shall be the Secretary’s first assistant for purposes of subchapter III of chapter 33 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d388cc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Under Secretary for Science and Technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d388cd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Commissioner of U.S. Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d388ce-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Administrator of the Federal Emergency Management Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d388cf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Director of the Bureau of Citizenship and Immigration Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d388d0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Under Secretary for Management, who shall be first assistant to the Deputy Secretary of Homeland Security for purposes of subchapter III of chapter 33 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d388d1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Director of U.S. Immigration and Customs Enforcement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d388d2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Director of the Cybersecurity and Infrastructure Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d388d3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 12 Assistant Secretaries.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d388d4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/a/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A General Counsel, who shall be the chief legal officer of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4d388d5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/a/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Under Secretary for Strategy, Policy, and Plans.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d388d6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Secretaries","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If any of the Assistant Secretaries referred to under paragraph (1)(I) is designated to be the Assistant Secretary for Health Affairs, the Assistant Secretary for Legislative Affairs, or the Assistant Secretary for Public Affairs, that Assistant Secretary shall be appointed by the President without the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d388d7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspector General","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Department an Office of Inspector General and an Inspector General at the head of such office, as provided in chapter 4 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d388d8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commandant of the Coast Guard","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To assist the Secretary in the performance of the Secretary’s functions, there is a Commandant of the Coast Guard, who shall be appointed as provided in section 44 ","children":[{"tag":"ref","attrib":{"idref":"fn002005"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 14 and who shall report directly to the Secretary. In addition to such duties as may be provided in this chapter and as assigned to the Commandant by the Secretary, the duties of the Commandant shall include those required by section 2 "},{"tag":"ref","attrib":{"idref":"fn002005"},"text":"1","children":[],"tail":" of title 14."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d388d9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other officers","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To assist the Secretary in the performance of the Secretary’s functions, there are the following officers, appointed by the President:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4d388da-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Director of the Secret Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d388db-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Chief Information Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d388dc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Officer for Civil Rights and Civil Liberties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d388dd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An Assistant Secretary for the Countering Weapons of Mass Destruction Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d388de-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any Director of a Joint Task Force under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s348"},"text":"section 348 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d388df-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Financial Officer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Department a Chief Financial Officer, as provided in chapter 9 of title 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d388e0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance of specific functions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to the provisions of this chapter, every officer of the Department shall perform the functions specified by law for the official’s office or prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d388e1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4d388e2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Absence, disability, or vacancy of Secretary or Deputy Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding chapter 33 of title 5, the Under Secretary for Management shall serve as the Acting Secretary if by reason of absence, disability, or vacancy in office, neither the Secretary nor Deputy Secretary is available to exercise the duties of the Office of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d388e3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Further order of succession","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding chapter 33 of title 5, the Secretary may designate such other officers of the Department in further order of succession to serve as Acting Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d388e4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s113/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification of vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall notify the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Homeland Security of the House of Representatives of any vacancies that require notification under sections 3345 through 3349d of title 5 (commonly known as the “Federal Vacancies Reform Act of 1998”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4d388e5-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tI/s103"},"text":"Pub. L. 107–296, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 