{"tag":"section","attrib":{"id":"idb560387b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s926"},"text":null,"children":[{"tag":"num","attrib":{"value":"926"},"text":"§ 926.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center of Excellence for Maritime Domain Awareness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb560387c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s926/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a university-based Center for Excellence for Maritime Domain Awareness following the merit-review processes and procedures that have been established by the Secretary for selecting university program centers of excellence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb560387d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s926/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center established under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb560387e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s926/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize its activities based on the “National Plan To Improve Maritime Domain Awareness” published by the Department in October 2005;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb560387f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s926/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognize the extensive previous and ongoing work and existing competence in the field of maritime domain awareness at numerous academic and research institutions, such as the Naval Postgraduate School;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5603880-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s926/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage existing knowledge and continue development of a broad base of expertise within academia and industry in maritime domain awareness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5603881-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s926/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide educational, technical, and analytical assistance to Federal agencies with responsibilities for maritime domain awareness, including the Coast Guard, to focus on the need for interoperability, information sharing, and common information technology standards and architecture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5603882-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tI/s128"},"text":"Pub. L. 109–347, title I, § 128","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1900"},"text":"120 Stat. 1900","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
