{"tag":"section","attrib":{"id":"idb500dab6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242b"},"text":null,"children":[{"tag":"num","attrib":{"value":"242b"},"text":"§ 242b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb500dab7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information sharing to facilitate reports and analysis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each subagency of the Department of Homeland Security shall share with CCHT—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb500dab8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information needed by CCHT to develop the strategy and proposal required under section 4(a);","children":[{"tag":"ref","attrib":{"idref":"fn002042"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002042"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500dab9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional data analysis to help CCHT better understand the issues surrounding human trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb500daba-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-27"},"text":"December 27, 2022","children":[],"tail":", the CCHT Director shall submit a report to Congress that identifies any legislation that is needed to facilitate the Department of Homeland Security’s mission to end human trafficking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb500dabb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on potential human trafficking victims","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"2022-12-27"},"text":"December 27, 2022","children":[],"tail":", and annually thereafter, the Secretary of Homeland Security shall submit a report to Congress that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb500dabc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the numbers of screened and identified potential victims of trafficking (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/17"},"text":"section 7102(17) of title 22","children":[],"tail":") at or near the international border between the United States and Mexico, including a summary of the age ranges of such victims and their countries of origin; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500dabd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an update on the Department of Homeland Security’s efforts to establish protocols and methods for personnel to report human trafficking, pursuant to the Department of Homeland Security Strategy to Combat Human Trafficking, the Importation of Goods Produced with Forced Labor, and Child Sexual Exploitation, published in January 2020.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb500dabe-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/322/s5"},"text":"Pub. L. 117–322, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4435"},"text":"136 Stat. 4435","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb500dabf-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb500dac0-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb500dac1-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"CCHT, referred to in text, means the Center for Countering Human Trafficking, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s242a/a/1"},"text":"section 242a(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4(a), referred to in subsec. (a)(1), means ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/322/s4/a"},"text":"section 4(a) of Pub. L. 117–322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4435"},"text":"136 Stat. 4435","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb500dac2-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Countering Human Trafficking Act of 2021, and not as part of the Homeland Security Act of 2002 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
