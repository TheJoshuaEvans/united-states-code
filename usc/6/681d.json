{"tag":"section","attrib":{"id":"idb556c2b2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d"},"text":null,"children":[{"tag":"num","attrib":{"value":"681d"},"text":"§ 681d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncompliance with required reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb556c2b3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In the event that a covered entity that is required to submit a report under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s681b/a"},"text":"section 681b(a) of this title","children":[],"tail":" fails to comply with the requirement to report, the Director may obtain information about the cyber incident or ransom payment by engaging the covered entity directly to request information about the cyber incident or ransom payment, and if the Director is unable to obtain information through such engagement, by issuing a subpoena to the covered entity, pursuant to subsection (c), to gather information sufficient to determine whether a covered cyber incident or ransom payment has occurred."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556c2b4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Initial request for information","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb556c2b5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Director has reason to believe, whether through public reporting or other information in the possession of the Federal Government, including through analysis performed pursuant to paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s681a/a"},"text":"section 681a(a) of this title","children":[],"tail":", that a covered entity has experienced a covered cyber incident or made a ransom payment but failed to report such cyber incident or payment to the Agency in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s681b/a"},"text":"section 681b(a) of this title","children":[],"tail":", the Director may request additional information from the covered entity to confirm whether or not a covered cyber incident or ransom payment has occurred."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c2b6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Information provided to the Agency in response to a request under paragraph (1) shall be treated as if it was submitted through the reporting procedures established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s681b"},"text":"section 681b of this title","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002126"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002126"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" including that "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s681e"},"text":"section 681e of this title","children":[],"tail":" shall apply to such information in the same manner and to the same extent to information submitted in response to requests under paragraph (1) as it applies to information submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s681b"},"text":"section 681b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556c2b7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb556c2b8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If, after the date that is 72 hours from the date on which the Director made the request for information in subsection (b), the Director has received no response from the covered entity from which such information was requested, or received an inadequate response, the Director may issue to such covered entity a subpoena to compel disclosure of information the Director deems necessary to determine whether a covered cyber incident or ransom payment has occurred and obtain the information required to be reported pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s681b"},"text":"section 681b of this title","children":[],"tail":" and any implementing regulations, and assess potential impacts to national security, economic security, or public health and safety."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c2b9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb556c2ba-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a covered entity fails to comply with a subpoena, the Director may refer the matter to the Attorney General to bring a civil action in a district court of the United States to enforce such subpoena.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556c2bb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Venue","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An action under this paragraph may be brought in the judicial district in which the covered entity against which the action is brought resides, is found, or does business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556c2bc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contempt of court","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A court may punish a failure to comply with a subpoena issued under this subsection as contempt of court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c2bd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-delegation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority of the Director to issue a subpoena under this subsection may not be delegated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c2be-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authentication","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb556c2bf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any subpoena issued electronically pursuant to this subsection shall be authenticated with a cryptographic digital signature of an authorized representative of the Agency, or other comparable successor technology, that allows the Agency to demonstrate that such subpoena was issued by the Agency and has not been altered or modified since such issuance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb556c2c0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Invalid if not authenticated","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any subpoena issued electronically pursuant to this subsection that is not authenticated in accordance with subparagraph (A) shall not be considered to be valid by the recipient of such subpoena.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556c2c1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision of certain information to Attorney General","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb556c2c2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s681e/a/5"},"text":"section 681e(a)(5) of this title","children":[],"tail":" and paragraph (b)(2) of this section, if the Director determines, based on the information provided in response to a subpoena issued pursuant to subsection (c), that the facts relating to the cyber incident or ransom payment at issue may constitute grounds for a regulatory enforcement action or criminal prosecution, the Director may provide such information to the Attorney General or the head of the appropriate Federal regulatory agency, who may use such information for a regulatory enforcement action or criminal prosecution."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c2c3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may consult with the Attorney General or the head of the appropriate Federal regulatory agency when making the determination under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556c2c4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"When determining whether to exercise the authorities provided under this section, the Director shall take into consideration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb556c2c5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the complexity in determining if a covered cyber incident has occurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c2c6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior interaction with the Agency or awareness of the covered entity of the policies and procedures of the Agency for reporting covered cyber incidents and ransom payments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556c2c7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall not apply to a State, local, Tribal, or territorial government entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556c2c8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall submit to Congress an annual report on the number of times the Director—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb556c2c9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued an initial request for information pursuant to subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c2ca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued a subpoena pursuant to subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c2cb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" referred a matter to the Attorney General for a civil action pursuant to subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556c2cc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of the annual report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall publish a version of the annual report required under subsection (g) on the website of the Agency, which shall include, at a minimum, the number of times the Director—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb556c2cd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued an initial request for information pursuant to subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb556c2ce-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued a subpoena pursuant to subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556c2cf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681d/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anonymization of reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall ensure any victim information contained in a report required to be published under subsection (h) be anonymized before the report is published.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb556c2d0-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2244"},"text":"Pub. L. 107–296, title XXII, § 2244","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dY/s103/a/2"},"text":"Pub. L. 117–103, div. Y, § 103(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1049"},"text":"136 Stat. 1049","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7143/e/2"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7143(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3664"},"text":"136 Stat. 3664","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb556c2d1-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb556c2d2-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb556c2d3-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" inserted “including that "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s681e"},"text":"section 681e of this title","children":[],"tail":" shall apply to such information in the same manner and to the same extent to information submitted in response to requests under paragraph (1) as it applies to information submitted under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s681b"},"text":"section 681b of this title","children":[],"tail":"” after “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s681b"},"text":"section 681b of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
