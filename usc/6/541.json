{"tag":"section","attrib":{"id":"idb52e2bc4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s541"},"text":null,"children":[{"tag":"num","attrib":{"value":"541"},"text":"§ 541.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52e2bc5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s541/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “agency” includes any entity, organizational unit, program, or function.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52e2bc6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s541/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “transition period” means the 12-month period beginning on the effective date of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb52e2bc7-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXV/s1501"},"text":"Pub. L. 107–296, title XV, § 1501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2307"},"text":"116 Stat. 2307","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb52e2bc8-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb52e2bc9-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"