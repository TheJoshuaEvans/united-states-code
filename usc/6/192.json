{"tag":"section","attrib":{"id":"idb4edc752-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192"},"text":null,"children":[{"tag":"num","attrib":{"value":"192"},"text":"§ 192.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeland Security Institute","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4edc753-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish a federally funded research and development center to be known as the “Homeland Security Institute” (in this section referred to as the “Institute”).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edc754-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall be administered as a separate entity by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edc755-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The duties of the Institute shall be determined by the Secretary, and may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4edc756-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Systems analysis, risk analysis, and simulation and modeling to determine the vulnerabilities of the Nation’s critical infrastructures and the effectiveness of the systems deployed to reduce those vulnerabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc757-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Economic and policy analysis to assess the distributed costs and benefits of alternative approaches to enhancing security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc758-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluation of the effectiveness of measures deployed to enhance the security of institutions, facilities, and infrastructure that may be terrorist targets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc759-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of instances when common standards and protocols could improve the interoperability and effective utilization of tools developed for field operators and first responders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc75a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assistance for Federal agencies and departments in establishing testbeds to evaluate the effectiveness of technologies under development and to assess the appropriateness of such technologies for deployment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc75b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Design of metrics and use of those metrics to evaluate the effectiveness of homeland security programs throughout the Federal Government, including all national laboratories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc75c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Design of and support for the conduct of homeland security-related exercises and simulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4edc75d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Creation of strategic technology development plans to reduce vulnerabilities in the Nation’s critical infrastructure and key resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edc75e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation on Institute activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the duties described in subsection (c), the Institute shall consult widely with representatives from private industry, institutions of higher education, nonprofit institutions, other Government agencies, and federally funded research and development centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edc75f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of centers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall utilize the capabilities of the National Infrastructure Simulation and Analysis Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edc760-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Institute shall transmit to the Secretary and Congress an annual report on the activities of the Institute under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4edc761-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s192/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Homeland Security Institute shall terminate 5 years after its establishment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4edc762-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIII/s312"},"text":"Pub. L. 107–296, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2176"},"text":"116 Stat. 2176","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/334/tV/s519"},"text":"Pub. L. 108–334, title V, § 519","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1318"},"text":"118 Stat. 1318","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4edc763-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4edc764-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4edc765-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/334"},"text":"Pub. L. 108–334","children":[],"tail":" amended heading and text of subsec. (g) generally. Prior to amendment, text read as follows: “The Homeland Security Institute shall terminate 3 years after the effective date of this chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
