{"tag":"section","attrib":{"id":"idb5593354-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s725"},"text":null,"children":[{"tag":"num","attrib":{"value":"725"},"text":"§ 725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prepositioned equipment program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5593355-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall establish a prepositioned equipment program to preposition standardized emergency equipment in at least 11 locations to sustain and replenish critical assets used by State, local, and tribal governments in response to (or rendered inoperable by the effects of) natural disasters, acts of terrorism, and other man-made disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5593356-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall notify State, local, and tribal officials in an area in which a location for the prepositioned equipment program will be closed not later than 60 days before the date of such closure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5593357-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s637"},"text":"Pub. L. 109–295, title VI, § 637","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1422"},"text":"120 Stat. 1422","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
