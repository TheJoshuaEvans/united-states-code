{"tag":"section","attrib":{"id":"idb50f3298-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321n"},"text":null,"children":[{"tag":"num","attrib":{"value":"321n"},"text":"§ 321n.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of gifts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb50f3299-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321n/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may accept and use gifts of property, both real and personal, and may accept gifts of services, including from guest lecturers, for otherwise authorized activities of the Center for Domestic Preparedness that are related to efforts to prevent, prepare for, protect against, or respond to a natural disaster, act of terrorism, or other man-made disaster, including the use of a weapon of mass destruction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50f329a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321n/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not accept a gift under this section if the Secretary determines that the use of the property or services would compromise the integrity or appearance of integrity of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50f329b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321n/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program of the Department; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50f329c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321n/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual involved in a program of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50f329d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321n/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50f329e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321n/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to the Committee on Homeland Security of the House of Representatives and the Committee on Homeland Security and Governmental Affairs of the Senate an annual report disclosing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50f329f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321n/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any gifts that were accepted under this section during the year covered by the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50f32a0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321n/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the gifts contribute to the mission of the Center for Domestic Preparedness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50f32a1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321n/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of Federal savings that were generated from the acceptance of the gifts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50f32a2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s321n/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each report required under paragraph (1) shall be made publically available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb50f32a3-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tV/s525"},"text":"Pub. L. 107–296, title V, § 525","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/111/245/s2/a/1"},"text":"Pub. L. 111–245, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"Sept. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2620"},"text":"124 Stat. 2620","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
