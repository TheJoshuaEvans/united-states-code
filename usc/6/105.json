{"tag":"section","attrib":{"id":"idb4d13e6b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s105"},"text":null,"children":[{"tag":"num","attrib":{"value":"105"},"text":"§ 105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biodefense analysis and budget submission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4d13e6c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual analysis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each fiscal year, beginning in fiscal year 2023, the Director of the Office of Management and Budget, in consultation with the Secretary of Health and Human Services shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4d13e6d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a detailed and comprehensive analysis of Federal biodefense programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d13e6e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an integrated biodefense budget submission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d13e6f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of biodefense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with the National Biodefense Strategy, the Director shall develop and disseminate to all Federal departments and agencies a unified definition of the term “biodefense” to identify which programs and activities are included in the annual budget submission required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d13e70-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for analysis","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The analysis required under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4d13e71-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the display of all funds requested for biodefense activities, both mandatory and discretionary, by agency and categorized by biodefense enterprise element, such as threat awareness, prevention, deterrence, preparedness, surveillance and detection, response, attribution (including bioforensic capabilities), recovery, and mitigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4d13e72-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detailed explanations of how each program and activity included aligns with biodefense goals and objectives as part of the National Biodefense Strategy required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s104"},"text":"section 104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4d13e73-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Submittal to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director, in consultation with the Secretary of Health and Human Services, shall submit to Congress the analysis required under subsection (a) for a fiscal year concurrently with the President’s annual budget request for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4d13e74-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tIII/s363"},"text":"Pub. L. 116–283, div. A, title III, § 363","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3547"},"text":"134 Stat. 3547","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4d13e75-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4d13e76-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4d13e77-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the William M. (Mac) Thornberry National Defense Authorization Act for Fiscal Year 2021, and not as part of the Homeland Security Act of 2002 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
