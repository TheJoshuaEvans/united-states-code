{"tag":"section","attrib":{"id":"idb51b1922-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393"},"text":null,"children":[{"tag":"num","attrib":{"value":"393"},"text":"§ 393.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special streamlined acquisition authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb51b1923-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51b1924-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may use the authorities set forth in this section with respect to any procurement made during the period beginning on the effective date of this chapter and ending ","children":[{"tag":"date","attrib":{"date":"2007-09-30"},"text":"September 30, 2007","children":[],"tail":", if the Secretary determines in writing that the mission of the Department (as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s111"},"text":"section 111 of this title","children":[],"tail":") would be seriously impaired without the use of such authorities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b1925-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to make the determination described in paragraph (1) may not be delegated by the Secretary to an officer of the Department who is not appointed by the President with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b1926-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the date that is 7 days after the date of any determination under paragraph (1), the Secretary shall submit to the Committee on Government Reform of the House of Representatives and the Committee on Governmental Affairs of the Senate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51b1927-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notification of such determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51b1928-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the justification for such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51b1929-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increased micro-purchase threshold for certain procurements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51b192a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may designate certain employees of the Department to make procurements described in subsection (a) for which in the administration of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1902"},"text":"section 1902 of title 41","children":[],"tail":" the amount specified in subsections (a), (d), and (e) of such section 1902 shall be deemed to be $7,500."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b192b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Number of employees","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The number of employees designated under paragraph (1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51b192c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fewer than the number of employees of the Department who are authorized to make purchases without obtaining competitive quotations, pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1902/d"},"text":"section 1902(d) of title 41","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51b192d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient to ensure the geographic dispersal of the availability of the use of the procurement authority under such paragraph at locations reasonably considered to be potential terrorist targets; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51b192e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficiently limited to allow for the careful monitoring of employees designated under such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b192f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Procurements made under the authority of this subsection shall be subject to review by a designated supervisor on not less than a monthly basis. The supervisor responsible for the review shall be responsible for no more than 7 employees making procurements under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51b1930-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simplified acquisition procedures","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51b1931-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a procurement described in subsection (a), the Secretary may deem the simplified acquisition threshold referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":" to be—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51b1932-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a contract to be awarded and performed, or purchase to be made, within the United States, $200,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51b1933-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a contract to be awarded and performed, or purchase to be made, outside of the United States, $300,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b1934-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51b1935-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of certain commercial items authorities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51b1936-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With respect to a procurement described in subsection (a), the Secretary may deem any item or service to be a commercial item for the purpose of Federal procurement laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b1937-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The $5,000,000 limitation provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1901/a/2"},"text":"section 1901(a)(2) of title 41","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s3305/a/2"},"text":"section 3305(a)(2) of title 41","children":[],"tail":" shall be deemed to be $7,500,000 for purposes of property or services under the authority of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b1938-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Authority under a provision of law referred to in paragraph (2) that expires under section 4202(e) of the Clinger-Cohen Act of 1996 (divisions D and E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Public Law 104–106","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2304"},"text":"10 U.S.C. 2304","children":[],"tail":" note) shall, notwithstanding such section, continue to apply for a procurement described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51b1939-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the end of fiscal year 2005, the Comptroller General shall submit to the Committee on Governmental Affairs of the Senate and the Committee on Government Reform of the House of Representatives a report on the use of the authorities provided in this section. The report shall contain the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51b193a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the extent to which property and services acquired using authorities provided under this section contributed to the capacity of the Federal workforce to facilitate the mission of the Department as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s111"},"text":"section 111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b193b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the extent to which prices for property and services acquired using authorities provided under this section reflected the best value.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b193c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of employees designated by each executive agency under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b193d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of the extent to which the Department has implemented subsections (b)(2) and (b)(3) to monitor the use of procurement authority by employees designated under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b193e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s393/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any recommendations of the Comptroller General for improving the effectiveness of the implementation of the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb51b193f-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s833"},"text":"Pub. L. 107–296, title VIII, § 833","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2225"},"text":"116 Stat. 2225","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb51b1940-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb51b1941-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb51b1942-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The effective date of this chapter, referred to in subsec. (a)(1), is 60 days after ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4202(e) of the Clinger-Cohen Act of 1996, referred to in subsec. (d)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s4202/e"},"text":"section 4202(e) of Pub. L. 104–106","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2304"},"text":"section 2304 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb51b1943-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(1), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1902"},"text":"section 1902 of title 41","children":[],"tail":"” substituted for “section 32 of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s428"},"text":"41 U.S.C. 428","children":[],"tail":")” and “subsections (a), (d), and (e) of such section 1902” substituted for “subsections (c), (d), and (f) of such section 32” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b)(2)(A), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1902/d"},"text":"section 1902(d) of title 41","children":[],"tail":"” substituted for “section 32(c) of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s428/c"},"text":"41 U.S.C. 428(c)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (c)(1), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s134"},"text":"section 134 of title 41","children":[],"tail":"” substituted for “section 4(11) of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s403/11"},"text":"41 U.S.C. 403(11)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (d)(2), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1901/a/2"},"text":"section 1901(a)(2) of title 41","children":[],"tail":"” substituted for “section 31(a)(2) of the Office of Federal Procurement Policy Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s427/a/2"},"text":"41 U.S.C. 427(a)(2)","children":[],"tail":")” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s3305/a/2"},"text":"section 3305(a)(2) of title 41","children":[],"tail":"” substituted for “section 303(g)(1)(B) of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s253/g/1/B"},"text":"41 U.S.C. 253(g)(1)(B)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s6/c"},"text":"Pub. L. 111–350, § 6(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3854"},"text":"124 Stat. 3854","children":[],"tail":", which Act enacted Title 41, Public Contracts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is comprised of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s833"},"text":"section 833 of Pub. L. 107–296","children":[],"tail":". Subsec. (c)(2) of "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s833"},"text":"section 833 of Pub. L. 107–296","children":[],"tail":" amended section 416 of former Title 41, Public Contracts."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb51b1944-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb51b1945-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Government Reform of House of Representatives changed to Committee on Oversight and Government Reform of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Governmental Affairs of Senate changed to Committee on Homeland Security and Governmental Affairs of Senate, effective ","children":[{"tag":"date","attrib":{"date":"2005-01-04"},"text":"Jan. 4, 2005","children":[],"tail":", by Senate Resolution No. 445, One Hundred Eighth Congress, "},{"tag":"date","attrib":{"date":"2004-10-09"},"text":"Oct. 9, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
