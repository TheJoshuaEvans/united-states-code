{"tag":"section","attrib":{"id":"idb53a1391-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608"},"text":null,"children":[{"tag":"num","attrib":{"value":"608"},"text":"§ 608.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prioritization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb53a1392-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In allocating funds among States and high-risk urban areas applying for grants under section 604 or 605 of this title, the Administrator shall consider, for each State or high-risk urban area—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a1393-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" its relative threat, vulnerability, and consequences from acts of terrorism, including consideration of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53a1394-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its population, including appropriate consideration of military, tourist, and commuter populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a1395-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its population density;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a1396-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its history of threats, including whether it has been the target of a prior act of terrorism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a1397-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its degree of threat, vulnerability, and consequences related to critical infrastructure (for all critical infrastructure sectors) or key resources identified by the Administrator or the State homeland security plan, including threats, vulnerabilities, and consequences related to critical infrastructure or key resources in nearby jurisdictions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a1398-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most current threat assessments available to the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a1399-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the State has, or the high-risk urban area is located at or near, an international border;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a139a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether it has a coastline bordering an ocean (including the Gulf of Mexico) or international waters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a139b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" its likely need to respond to acts of terrorism occurring in nearby jurisdictions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a139c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which it has unmet target capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a139d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of a high-risk urban area, the extent to which that high-risk urban area includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb53a139e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/1/J/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those incorporated municipalities, counties, parishes, and Indian tribes within the relevant eligible metropolitan area, the inclusion of which will enhance regional efforts to prevent, prepare for, protect against, and respond to acts of terrorism; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb53a139f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/1/J/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other local and tribal governments in the surrounding area that are likely to be called upon to respond to acts of terrorism within the high-risk urban area; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53a13a0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other factors as are specified in writing by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13a1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated effectiveness of the proposed use of the grant by the State or high-risk urban area in increasing the ability of that State or high-risk urban area to prevent, prepare for, protect against, and respond to acts of terrorism, to meet its target capabilities, and to otherwise reduce the overall risk to the high-risk urban area, the State, or the Nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53a13a2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Types of threat","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In assessing threat under this section, the Administrator shall consider the following types of threat to critical infrastructure sectors and to populations in all areas of the United States, urban and rural:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53a13a3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Biological.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13a4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chemical.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13a5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cyber.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13a6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Explosives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13a7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Incendiary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13a8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nuclear.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13a9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Radiological.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13aa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Suicide bombers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53a13ab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s608/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other types of threat determined relevant by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53a13ac-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXX/s2007"},"text":"Pub. L. 107–296, title XX, § 2007","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tI/s101"},"text":"Pub. L. 110–53, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/282"},"text":"121 Stat. 282","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
