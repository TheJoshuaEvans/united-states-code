,"text":"129 Stat. 2516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/31/dF/tV/s514"},"text":"Pub. L. 115–31, div. F, title V, § 514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-05-05"},"text":"May 5, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/427"},"text":"131 Stat. 427","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702/c/1"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2155"},"text":"135 Stat. 2155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXII/s7227/b"},"text":"Pub. L. 117–263, div. G, title LXXII, § 7227(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3675"},"text":"136 Stat. 3675","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb51b1917-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb51b1918-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb51b1919-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsection (d), referred to in subsec. (a), was redesignated subsec. (c) of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dD/tV/s527/3"},"text":"Pub. L. 112–74, div. D, title V, § 527(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/974"},"text":"125 Stat. 974","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) of this section, referred to in subsec. (a)(1), probably means the former subsec. (b) of this section which related to annual reports by the Comptroller General and which was struck out by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74/dD/tV/s527/2"},"text":"Pub. L. 112–74, div. D, title V, § 527(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/974"},"text":"125 Stat. 974","children":[],"tail":". See 2011 Amendment note for subsec. (b) below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb51b191a-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7227/b/1/A"},"text":"Pub. L. 117–263, § 7227(b)(1)(A)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2017-09-30"},"text":"September 30, 2017","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7227/b/1/B"},"text":"Pub. L. 117–263, § 7227(b)(1)(B)","children":[],"tail":", amended par. (2) generally. Prior to amendment, text read as follows: “The Secretary may, under the authority of paragraph (1), carry out prototype projects in accordance with the requirements and conditions provided for carrying out prototype projects under section 845 of the National Defense Authorization Act for Fiscal Year 1994 ("},{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Public Law 103–160","children":[],"tail":"). In applying the authorities of that section 845, subsection (c) of that section shall apply with respect to prototype projects under this paragraph, and the Secretary shall perform the functions of the Secretary of Defense under subsection (d) thereof.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7227/b/2"},"text":"Pub. L. 117–263, § 7227(b)(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2017-09-30"},"text":"September 30, 2017","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7227/b/3"},"text":"Pub. L. 117–263, § 7227(b)(3)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4022/e"},"text":"section 4022(e) of title 10","children":[],"tail":".” for “section 845(e) of the National Defense Authorization Act for Fiscal Year 1994 ("},{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Public Law 103–160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2371"},"text":"10 U.S.C. 2371","children":[],"tail":" note).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “section 4021” for “section 2371”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31/s514/1"},"text":"Pub. L. 115–31, § 514(1)","children":[],"tail":", substituted “Until "},{"tag":"date","attrib":{"date":"2017-09-30"},"text":"September 30, 2017","children":[],"tail":",” for “Until "},{"tag":"date","attri