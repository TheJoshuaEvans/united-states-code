his section would be applied by substituting "},{"tag":"date","attrib":{"date":"2020-09-30"},"text":"Sept. 30, 2020","children":[],"tail":", for "},{"tag":"date","attrib":{"date":"2017-09-30"},"text":"Sept. 30, 2017","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6/dA/tV/s541/a"},"text":"Pub. L. 116–6, div. A, title V, § 541(a)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/116/26/tIII/s302"},"text":"Pub. L. 116–26, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-07-01"},"text":"July 1, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1021"},"text":"133 Stat. 1021","children":[],"tail":", provided that subsecs. (a) and (c)(1) of this section would be applied by substituting "},{"tag":"date","attrib":{"date":"2019-09-30"},"text":"Sept. 30, 2019","children":[],"tail":", for "},{"tag":"date","attrib":{"date":"2017-09-30"},"text":"Sept. 30, 2017","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dF/tV/s538/a"},"text":"Pub. L. 115–141, div. F, title V, § 538(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/632"},"text":"132 Stat. 632","children":[],"tail":", provided that subsecs. (a) and (c)(1) of this section would be applied by substituting "},{"tag":"date","attrib":{"date":"2018-09-30"},"text":"Sept. 30, 2018","children":[],"tail":", for "},{"tag":"date","attrib":{"date":"2017-09-30"},"text":"Sept. 30, 2017","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb51b191d-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Documentation Requirements for Major Acquisition Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dF/tV/s561"},"text":"Pub. L. 114–113, div. F, title V, § 561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2521"},"text":"129 Stat. 2521","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/113/dF/tV/s561"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each major acquisition program of the Department of Homeland Security, as defined in Department of Homeland Security Management Directive 102–2, shall meet established acquisition documentation requirements for its acquisition program baseline established in the Department of Homeland Security Instruction Manual 102–01–001 and the Department of Homeland Security Acquisition Instruction/Guidebook 102–01–001, Appendix K.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department shall report to the Committees on Appropriations of the Senate and the House of Representatives in the Comprehensive Acquisition Status Report and its quarterly updates, required under the heading ‘Office of the Under Secretary for Management’ of this Act [div. F of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113"},"text":"Pub. L. 114–113","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2493"},"text":"129 Stat. 2493","children":[],"tail":"], on any major acquisition program that does not meet such documentation requirements and the schedule by which the program will come into compliance with these requirements."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" None of the funds made available by this or any other Act for any fiscal year may be used for a major acquisition program that is out of compliance with such documentation requirements for more than two years except that funds may be used solely to come into compliance with such documentation requirements or to terminate the program.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
