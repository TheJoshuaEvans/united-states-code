{"tag":"section","attrib":{"id":"idb51b1907-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391"},"text":null,"children":[{"tag":"num","attrib":{"value":"391"},"text":"§ 391.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb51b1908-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until ","children":[{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":", and subject to subsection (d),"},{"tag":"ref","attrib":{"idref":"fn002063"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002063"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" the Secretary may carry out a pilot program under which the Secretary may exercise the following authorities:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51b1909-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"When the Secretary carries out basic, applied, and advanced research and development projects, including the expenditure of funds for such projects, the Secretary may exercise the same authority (subject to the same limitations and conditions) with respect to such research and projects as the Secretary of Defense may exercise under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4021"},"text":"section 4021 of title 10","children":[],"tail":" (except for subsections (b) and (f)), after making a determination that the use of a contract, grant, or cooperative agreement for such project is not feasible or appropriate. The annual report required under subsection (b) "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of this section, as applied to the Secretary by this paragraph, shall be submitted to the President of the Senate and the Speaker of the House of Representatives."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b190a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prototype projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51b190b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, under the authority of paragraph (1), carry out prototype projects under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4022"},"text":"section 4022 of title 10","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51b190c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in applying the authorities of such section 4022, the Secretary shall perform the functions of the Secretary of Defense as prescribed in such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51b190d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Procurement of temporary and intermittent services","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51b190e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure the temporary or intermittent services of experts or consultants (or organizations thereof) in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b190f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whenever necessary due to an urgent homeland security need, procure temporary (not to exceed 1 year) or intermittent personal services, including the services of experts or consultants (or organizations thereof), without regard to the pay limitations of such section 3109.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51b1910-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51b1911-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The authority of the Secretary under this section shall terminate ","children":[{"tag":"date","attrib":{"date":"2024-09-30"},"text":"September 30, 2024","children":[],"tail":", unless before that date the Secretary—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51b1912-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issues policy guidance detailing the appropriate use of that authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51b1913-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides training to each employee that is authorized to exercise that authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51b1914-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall provide an annual report to the Committees on Appropriations of the Senate and the House of Representatives, the Committee on Homeland Security and Governmental Affairs of the Senate, and the Committee on Homeland Security of the House of Representatives detailing the projects for which the authority granted by subsection (a) was used, the rationale for its use, the funds spent using that authority, the outcome of each project for which that authority was used, and the results of any audits of such projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb51b1915-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s391/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of nontraditional Government contractor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “nontraditional Government contractor” has the same meaning as the term “nontraditional defense contractor” as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4022/e"},"text":"section 4022(e) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb51b1916-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s831"},"text":"Pub. L. 107–296, title VIII, § 831","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2224"},"text":"116 Stat. 2224","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dE/tV/s572"},"text":"Pub. L. 110–161, div. E, title V, § 572","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2093"},"text":"121 Stat. 2093","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/329/dD/tV/s537"},"text":"Pub. L. 110–329, div. D, title V, § 537","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-09-30"},"text":"Sept. 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3687"},"text":"122 Stat. 3687","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/83/tV/s531"},"text":"Pub. L. 111–83, title V, § 531","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"