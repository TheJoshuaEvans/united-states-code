ed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1801"},"text":"section 1801 of title 50","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575bc4f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1501/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security control","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “security control” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s650"},"text":"section 650 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575bc50-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1501/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security vulnerability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “security vulnerability” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s650"},"text":"section 650 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb575bc51-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1501/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tribal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “tribal” has the meaning given the term “Indian tribe” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"