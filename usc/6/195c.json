{"tag":"section","attrib":{"id":"idb4f03921-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c"},"text":null,"children":[{"tag":"num","attrib":{"value":"195c"},"text":"§ 195c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Promoting antiterrorism through international cooperation program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4f03922-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f03923-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director selected under subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03924-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International cooperative activity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “international cooperative activity” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f03925-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinated research projects, joint research projects, or joint ventures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03926-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" joint studies or technical demonstrations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03927-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinated field exercises, scientific seminars, conferences, symposia, and workshops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03928-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training of scientists and engineers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03929-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" visits and exchanges of scientists, engineers, or other appropriate personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0392a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exchanges or sharing of scientific and technological information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0392b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" joint use of laboratory facilities and equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f0392c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Science and Technology Homeland Security International Cooperative Programs Office","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f0392d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Under Secretary shall establish the Science and Technology Homeland Security International Cooperative Programs Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f0392e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office shall be headed by a Director, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f0392f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be selected, in consultation with the Assistant Secretary for International Affairs, by and shall report to the Under Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03930-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be an officer of the Department serving in another position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03931-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f03932-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development of mechanisms","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall be responsible for developing, in coordination with the Department of State and, as appropriate, the Department of Defense, the Department of Energy, and other Federal agencies, understandings and agreements to allow and to support international cooperative activity in support of homeland security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03933-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall be responsible for developing, in coordination with the Office of International Affairs and other Federal agencies, strategic priorities for international cooperative activity for the Department in support of homeland security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03934-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Activities","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall facilitate the planning, development, and implementation of international cooperative activity to address the strategic priorities developed under subparagraph (B) through mechanisms the Under Secretary considers appropriate, including grants, cooperative agreements, or contracts to or with foreign public or private entities, governmental organizations, businesses (including small businesses and socially and economically disadvantaged small businesses (as those terms are defined in sections 632 and 637 of title 15, respectively)), federally funded research and development centers, and universities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03935-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of partners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall facilitate the matching of United States entities engaged in homeland security research with non-United States entities engaged in homeland security research so that they may partner in homeland security research activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03936-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall ensure that the activities under this subsection are coordinated with the Office of International Affairs and the Department of State and, as appropriate, the Department of Defense, the Department of Energy, and other relevant Federal agencies or interagency bodies. The Director may enter into joint activities with other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03937-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Matching funding","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f03938-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f03939-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Equitability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director shall ensure that funding and resources expended in international cooperative activity will be equitably matched by the foreign partner government or other entity through direct funding, funding of complementary activities, or the provision of staff, facilities, material, or equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0393a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant matching and repayment","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4f0393b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may require a recipient of a grant under this section—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb4f0393c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/c/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make a matching contribution of not more than 50 percent of the total cost of the proposed project for which the grant is awarded; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb4f0393d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/c/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to repay to the Secretary the amount of the grant (or a portion thereof), interest on such amount at an appropriate rate, and such charges for administration of the grant as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4f0393e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum amount","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not require that repayment under clause (i)(II) be more than 150 percent of the amount of the grant, adjusted for inflation on the basis of the Consumer Price Index.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f0393f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign partners","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Partners may include Israel, the United Kingdom, Canada, Australia, Singapore, and other allies in the global war on terrorism as determined to be appropriate by the Secretary of Homeland Security and the Secretary of State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03940-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Loans of equipment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Director may make or accept loans of equipment for research and development and comparative testing purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03941-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign reimbursements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If the Science and Technology Homeland Security International Cooperative Programs Office participates in an international cooperative activity with a foreign partner on a cost-sharing basis, any reimbursements or contributions received from that foreign partner to meet its share of the project may be credited to appropriate current appropriations accounts of the Directorate of Science and Technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03942-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress on international cooperative activities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", and every 5 years thereafter, the Under Secretary, acting through the Director, shall submit to Congress a report containing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f03943-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief description of each grant, cooperative agreement, or contract made or entered into under subsection (b)(3)(C), including the participants, goals, and amount and sources of funding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03944-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of international cooperative activities underway, including the participants, goals, expected duration, and amount and sources of funding, including resources provided to support the activities in lieu of direct funding; and ","children":[{"tag":"ref","attrib":{"idref":"fn002027"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002027"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “and” probably should not appear."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03945-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for international cooperative activities identified in the previous reporting period, a status update on the progress of such activities, including whether goals were realized, explaining any lessons learned, and evaluating overall success; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03946-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a discussion of obstacles encountered in the course of forming, executing, or implementing agreements for international cooperative activities, including administrative, legal, or diplomatic challenges or resource constraints.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03947-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Animal and zoonotic diseases","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the international cooperative activities authorized in this section, the Under Secretary, in coordination with the Assistant Secretary for the Countering Weapons of Mass Destruction Office, the Department of State, and appropriate officials of the Department of Agriculture, the Department of Defense, and the Department of Health and Human Services, may enter into cooperative activities with foreign countries, including African nations, to strengthen American preparedness against foreign animal and zoonotic diseases overseas that could harm the Nation’s agricultural and public health sectors if they were to reach the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03948-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"As part of the international cooperative activities authorized in this section, the Under Secretary, in coordination with the Department of State and appropriate Federal officials, may enter into cooperative research activities with Israel to strengthen preparedness against cyber threats and enhance capabilities in cybersecurity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03949-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction; authorities of the Secretary of State","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to alter or affect the following provisions of law:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f0394a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Title V of the Foreign Relations Authorization Act, Fiscal Year 1979 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2656a"},"text":"22 U.S.C. 2656a","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f0394b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s112b/g"},"text":"Section 112b(g) of title 1","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f0394c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2651a/e/2"},"text":"Section 2651a(e)(2) of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f0394d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 2752 and 2767 of title 22.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f0394e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/h/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2382/c"},"text":"Section 2382(c) of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f0394f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195c/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated to carry out this section such sums as are necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4f03950-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIII/s317"},"text":"Pub. L. 107–296, title III, § 317","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXIX/s1901/b/1"},"text":"Pub. L. 110–53, title XIX, § 1901(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/505"},"text":"121 Stat. 505","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/304/s2/a"},"text":"Pub. L. 114–304, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1519"},"text":"130 Stat. 1519","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/387/s2/f/3"},"text":"Pub. L. 115–387, § 2(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5168"},"text":"132 Stat. 5168","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIX/s5947/a/3"},"text":"Pub. L. 117–263, div. E, title LIX, § 5947(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3481"},"text":"136 Stat. 3481","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4f03951-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4f03952-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4f03953-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Relations Authorization Act, Fiscal Year 1979, referred to in subsec. (h)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/426"},"text":"Pub. L. 95–426","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-07"},"text":"Oct. 7, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/963"},"text":"92 Stat. 963","children":[],"tail":". Title V of the Act is classified generally to sections 2656a to 2656d of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4f03954-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (h)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “Section 112b(g)” for “Section 112b(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/387"},"text":"Pub. L. 115–387","children":[],"tail":" substituted “the Assistant Secretary for the Countering Weapons of Mass Destruction Office,” for “the Chief Medical Officer,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (e)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/304/s2/a/1"},"text":"Pub. L. 114–304, § 2(a)(1)","children":[],"tail":", added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/304/s2/a/2"},"text":"Pub. L. 114–304, § 2(a)(2)","children":[],"tail":", (3), added subsec. (g) and redesignated former subsecs. (g) and (h) as (h) and (i), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4f03955-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb4f03956-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" effective 270 days after "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5947/c"},"text":"section 5947(c) of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t1/s112a"},"text":"section 112a of Title 1","children":[],"tail":", General Provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4f03957-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXIX/s1901/a"},"text":"Pub. L. 110–53, title XIX, § 1901(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/505"},"text":"121 Stat. 505","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/53/tXIX/s1901/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds the following:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development and implementation of technology is critical to combating terrorism and other high consequence events and implementing a comprehensive homeland security strategy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States and its allies in the global war on terrorism share a common interest in facilitating research, development, testing, and evaluation of equipment, capabilities, technologies, and services that will aid in detecting, preventing, responding to, recovering from, and mitigating against acts of terrorism.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Certain United States allies in the global war on terrorism, including Israel, the United Kingdom, Canada, Australia, and Singapore have extensive experience with, and technological expertise in, homeland security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States and certain of its allies in the global war on terrorism have a history of successful collaboration in developing mutually beneficial equipment, capabilities, technologies, and services in the areas of defense, agriculture, and telecommunications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States and its allies in the global war on terrorism will mutually benefit from the sharing of technological expertise to combat domestic and international terrorism.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The establishment of an office to facilitate and support cooperative endeavors between and among government agencies, for-profit business entities, academic institutions, and nonprofit entities of the United States and its allies will safeguard lives and property worldwide against acts of terrorism and other high consequence events.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4f03958-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transparency of Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXIX/s1902"},"text":"Pub. L. 110–53, title XIX, § 1902","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/508"},"text":"121 Stat. 508","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/53/tXIX/s1902"},"text":"“For each Federal award (as that term is defined in section 2 of the Federal Funding Accountability and Transparency Act of 2006 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/282"},"text":"Pub. L. 109–282","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6101"},"text":"31 U.S.C. 6101","children":[],"tail":" note)) under this title [enacting this section and provisions set out as notes under this section] or an amendment made by this title, the Director of the Office of Management and Budget shall ensure full and timely compliance with the requirements of the Federal Funding Accountability and Transparency Act of 2006 ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6101"},"text":"31 U.S.C. 6101","children":[],"tail":" note).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
