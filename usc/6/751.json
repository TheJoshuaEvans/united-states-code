{"tag":"section","attrib":{"id":"idb55933e1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751"},"text":null,"children":[{"tag":"num","attrib":{"value":"751"},"text":"§ 751.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal response capability inventory","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55933e2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5196/h/1/C"},"text":"section 5196(h)(1)(C) of title 42","children":[],"tail":", the Administrator shall accelerate the completion of the inventory of Federal response capabilities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55933e3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each Federal agency with responsibilities under the National Response Plan, the inventory shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55933e4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each capability—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55933e5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance parameters of the capability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55933e6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the timeframe within which the capability can be brought to bear on an incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55933e7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the readiness of the capability to respond to all hazards, including natural disasters, acts of terrorism, and other man-made disasters;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933e8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of personnel credentialed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s320"},"text":"section 320 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933e9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of resources typed in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s320"},"text":"section 320 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933ea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency communications assets maintained by the Federal Government and, if appropriate, State, local, and tribal governments and the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55933eb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Defense","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator, in coordination with the Secretary of Defense, shall develop a list of organizations and functions within the Department of Defense that may be used, pursuant to the authority provided under the National Response Plan and sections 5170a, 5170b, and 5192 of title 42, to provide support to civil authorities during natural disasters, acts of terrorism, and other man-made disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55933ec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Database","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall establish an inventory database to allow—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55933ed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" real-time exchange of information regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55933ee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55933ef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" readiness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55933f0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compatibility of equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55933f1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credentialed personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55933f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" typed resources;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" easy identification and rapid deployment of capabilities, credentialed personnel, and typed resources during an incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55933f4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s751/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sharing of the inventory described in subsection (a) with other Federal agencies, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55933f5-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s651"},"text":"Pub. L. 109–295, title VI, § 651","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1429"},"text":"120 Stat. 1429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tIV/s405"},"text":"Pub. L. 110–53, title IV, § 405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/303"},"text":"121 Stat. 303","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb55933f6-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb55933f7-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb55933f8-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s405/1/A"},"text":"Pub. L. 110–53, § 405(1)(A)","children":[],"tail":", substituted “For each Federal agency with responsibilities under the National Response Plan, the inventory” for “The inventory” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s405/1/B"},"text":"Pub. L. 110–53, § 405(1)(B)","children":[],"tail":"–(D), added pars. (2) and (3) and redesignated former par. (2) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s405/2/A"},"text":"Pub. L. 110–53, § 405(2)(A)","children":[],"tail":", substituted “regarding—” for “regarding capabilities, readiness, or the compatibility of equipment;” in introductory provisions and added subpars. (A) to (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s405/2/B"},"text":"Pub. L. 110–53, § 405(2)(B)","children":[],"tail":", inserted “of capabilities, credentialed personnel, and typed resources” after “rapid deployment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s405/2/C"},"text":"Pub. L. 110–53, § 405(2)(C)","children":[],"tail":", substituted “the inventory described in subsection (a)” for “inventories”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
