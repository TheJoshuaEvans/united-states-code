{"tag":"section","attrib":{"id":"idb562a938-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s966"},"text":null,"children":[{"tag":"num","attrib":{"value":"966"},"text":"§ 966.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tier 3 participants in C–TPAT","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb562a939-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s966/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Commissioner, shall establish a third tier of C–TPAT participation that offers additional benefits to participants who demonstrate a sustained commitment to maintaining security measures and supply chain security practices that exceed the guidelines established for validation as a Tier 2 participant in C–TPAT under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s965"},"text":"section 965 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a93a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s966/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Commissioner, shall designate criteria for validating a C–TPAT participant as a Tier 3 participant under this section. Such criteria may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb562a93b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s966/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with any additional guidelines established by the Secretary that exceed the guidelines established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s965"},"text":"section 965 of this title","children":[],"tail":" for validating a C–TPAT participant as a Tier 2 participant, particularly with respect to controls over access to cargo throughout the supply chain;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a93c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s966/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submission of additional information regarding cargo prior to loading, as determined by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a93d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s966/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilization of container security devices, technologies, policies, or practices that meet standards and criteria established by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a93e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s966/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with any other cargo requirements established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a93f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s966/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Benefits","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Commissioner, in consultation with the Commercial Operations Advisory Committee and the National Maritime Security Advisory Committee, shall extend benefits to each C–TPAT participant that has been validated as a Tier 3 participant under this section, which may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb562a940-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s966/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expedited release of a Tier 3 participant’s cargo in destination ports within the United States during all threat levels designated by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a941-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s966/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further reduction in examinations of cargo;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a942-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s966/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priority for examinations of cargo; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a943-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s966/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further reduction in the risk score assigned pursuant to the Automated Targeting System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a944-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s966/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inclusion in joint incident management exercises, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a945-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s966/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2006-10-13"},"text":"October 13, 2006","children":[],"tail":", the Secretary, acting through the Commissioner, shall designate appropriate criteria pursuant to subsection (b) and provide benefits to validated Tier 3 participants pursuant to subsection (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb562a946-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tII/s216"},"text":"Pub. L. 109–347, title II, § 216","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1910"},"text":"120 Stat. 1910","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
