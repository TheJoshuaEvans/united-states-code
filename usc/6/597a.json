{"tag":"section","attrib":{"id":"idb537c9a9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a"},"text":null,"children":[{"tag":"num","attrib":{"value":"597a"},"text":"§ 597a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical countermeasures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb537c9aa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Secretary shall, as appropriate, establish a medical countermeasures program within the components of the Department to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb537c9ab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate personnel readiness and protection for the employees and working animals of the Department in the event of a chemical, biological, radiological, nuclear, or explosives attack, naturally occurring disease outbreak, other event impacting health, or pandemic; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9ac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the mission continuity of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c9ad-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Chief Medical Officer of the Department, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb537c9ae-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide programmatic oversight of the medical countermeasures program established under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9af-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop standards for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb537c9b0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical countermeasure storage, security, dispensing, and documentation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9b1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining a stockpile of medical countermeasures, including antibiotics, antivirals, antidotes, therapeutics, and radiological countermeasures, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9b2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring adequate partnerships with manufacturers and executive agencies that enable advance prepositioning by vendors of inventories of appropriate medical countermeasures in strategic locations nationwide, based on risk and employee density, in accordance with applicable Federal statutes and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9b3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing oversight and guidance regarding the dispensing of stockpiled medical countermeasures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9b4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring rapid deployment and dispensing of medical countermeasures in a chemical, biological, radiological, nuclear, or explosives attack, naturally occurring disease outbreak, other event impacting health, or pandemic;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9b5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing training to employees of the Department on medical countermeasures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9b6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting dispensing exercises.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c9b7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical countermeasures working group","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Chief Medical Officer of the Department, shall establish a medical countermeasures working group comprised of representatives from appropriate components and offices of the Department to ensure that medical countermeasures standards are maintained and guidance is consistent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c9b8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical countermeasures management","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after the date on which appropriations are made available to carry out subsection (a), the Chief Medical Officer shall develop and submit to the Secretary an integrated logistics support plan for medical countermeasures, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb537c9b9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a methodology for determining the ideal types and quantities of medical countermeasures to stockpile and how frequently such methodology shall be reevaluated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9ba-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a replenishment plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9bb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inventory tracking, reporting, and reconciliation procedures for existing stockpiles and new medical countermeasure purchases.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c9bc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", the Secretary shall transfer all medical countermeasures-related programmatic and personnel resources from the Under Secretary for Management to the Chief Medical Officer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c9bd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Stockpile elements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the types and quantities of medical countermeasures to stockpile under subsection (d), the Secretary, acting through the Chief Medical Officer of the Department—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb537c9be-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall use a risk-based methodology for evaluating types and quantities of medical countermeasures required; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9bf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may use, if available—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb537c9c0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chemical, biological, radiological, and nuclear risk assessments of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb537c9c1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance on medical countermeasures of the Office of the Assistant Secretary for Preparedness and Response and the Centers for Disease Control and Prevention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c9c2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Briefing","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", the Secretary shall provide a briefing to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Homeland Security of the House of Representatives regarding—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb537c9c3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan developed under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c9c4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation of the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb537c9c5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s597a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “medical countermeasures” means antibiotics, antivirals, antidotes, therapeutics, radiological countermeasures, and other countermeasures that may be deployed to protect the employees and working animals of the Department in the event of a chemical, biological, radiological, nuclear, or explosives attack, naturally occurring disease outbreak, other event impacting health, or pandemic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb537c9c6-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIX/s1932"},"text":"Pub. L. 107–296, title XIX, § 1932","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXIV/s6408/a"},"text":"Pub. L. 117–81, div. F, title LXIV, § 6408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2404"},"text":"135 Stat. 2404","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
