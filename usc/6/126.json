{"tag":"section","attrib":{"id":"idb4e69ba9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126"},"text":null,"children":[{"tag":"num","attrib":{"value":"126"},"text":"§ 126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Homeland Security data framework","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4e69baa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e69bab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Development","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security shall develop a data framework to integrate existing Department of Homeland Security datasets and systems, as appropriate, for access by authorized personnel in a manner consistent with relevant legal authorities and privacy, civil rights, and civil liberties policies and protections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e69bac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the framework required under paragraph (1), the Secretary of Homeland Security shall ensure, in accordance with all applicable statutory and regulatory requirements, the following information is included:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e69bad-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All information acquired, held, or obtained by an office or component of the Department of Homeland Security that falls within the scope of the information sharing environment, including homeland security information, terrorism information, weapons of mass destruction information, and national intelligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e69bae-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any information or intelligence relevant to priority mission needs and capability requirements of the homeland security enterprise, as determined appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e69baf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data framework access","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e69bb0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Homeland Security shall ensure that the data framework required under this section is accessible to employees of the Department of Homeland Security who the Secretary determines—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e69bb1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have an appropriate security clearance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e69bb2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are assigned to perform a function that requires access to information in such framework; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e69bb3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are trained in applicable standards for safeguarding and using such information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e69bb4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Homeland Security shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4e69bb5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue guidance for Department of Homeland Security employees authorized to access and contribute to the data framework pursuant to paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4e69bb6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that such guidance enforces a duty to share between offices and components of the Department when accessing or contributing to such framework for mission needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e69bb7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Efficiency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security shall promulgate data standards and instruct components of the Department of Homeland Security to make available information through the data framework required under this section in a machine-readable standard format, to the greatest extent practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e69bb8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of information","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Homeland Security may exclude information from the data framework required under this section if the Secretary determines inclusion of such information may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e69bb9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jeopardize the protection of sources, methods, or activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e69bba-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compromise a criminal or national security investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e69bbb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be inconsistent with other Federal laws or regulations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e69bbc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be duplicative or not serve an operational purpose if included in such framework.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e69bbd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safeguards","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Homeland Security shall incorporate into the data framework required under this section systems capabilities for auditing and ensuring the security of information included in such framework. Such capabilities shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e69bbe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mechanisms for identifying insider threats.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e69bbf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Mechanisms for identifying security risks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e69bc0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Safeguards for privacy, civil rights, and civil liberties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e69bc1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deadline for implementation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after ","children":[{"tag":"date","attrib":{"date":"2018-12-19"},"text":"December 19, 2018","children":[],"tail":", the Secretary of Homeland Security shall ensure the data framework required under this section has the ability to include appropriate information in existence within the Department of Homeland Security to meet the critical mission operations of the Department of Homeland Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e69bc2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice to Congress","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e69bc3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security shall submit to the appropriate congressional committees regular updates on the status of the data framework until the framework is fully operational.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e69bc4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational notification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after the date on which the data framework required under this section is fully operational, the Secretary of Homeland Security shall provide notice to the appropriate congressional committees that the data framework is fully operational.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e69bc5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value added","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security shall annually brief Congress on component use of the data framework required under this section to support operations that disrupt terrorist activities and incidents in the homeland.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4e69bc6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4e69bc7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriate congressional committee; homeland","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “appropriate congressional committee” and “homeland” have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e69bc8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Homeland security information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “homeland security information” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s482"},"text":"section 482 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e69bc9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National intelligence","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “national intelligence” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/5"},"text":"section 3003(5) of title 50","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4e69bca-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s126/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terrorism information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “terrorism information” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s485"},"text":"section 485 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4e69bcb-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/331/s2"},"text":"Pub. L. 115–331, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-19"},"text":"Dec. 19, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4484"},"text":"132 Stat. 4484","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4e69bcc-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4e69bcd-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb4e69bce-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the Department of Homeland Security Data Framework Act of 2018, and not as part of the Homeland Security Act of 2002 which comprises this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
