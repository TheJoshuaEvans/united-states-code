{"tag":"section","attrib":{"id":"idb56e9143-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169"},"text":null,"children":[{"tag":"num","attrib":{"value":"1169"},"text":"§ 1169.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroad tank car security testing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56e9144-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroad tank car vulnerability assessment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e9145-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assessment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall assess the likely methods of a deliberate terrorist attack against a railroad tank car used to transport toxic-inhalation-hazard materials, and for each method assessed, the degree to which it may be successful in causing death, injury, or serious adverse effects to human health, the environment, critical infrastructure, national security, the national economy, or public welfare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9146-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Threats","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall consider the most current threat information as to likely methods of a successful terrorist attack on a railroad tank car transporting toxic-inhalation-hazard materials, and may consider the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56e9147-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Explosive devices placed along the tracks or attached to a railroad tank car.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e9148-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The use of missiles, grenades, rockets, mortars, or other high-caliber weapons against a railroad tank car.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9149-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Physical testing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In developing the assessment required under paragraph (1), the Secretary shall conduct physical testing of the vulnerability of railroad tank cars used to transport toxic-inhalation-hazard materials to different methods of a deliberate attack, using technical information and criteria to evaluate the structural integrity of railroad tank cars.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e914a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after the completion of the assessment under paragraph (1), the Secretary shall provide to the appropriate congressional committees a report, in the appropriate format, on such assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e914b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroad tank car dispersion modeling","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e914c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the National Infrastructure Simulation and Analysis Center, shall conduct an air dispersion modeling analysis of release scenarios of toxic-inhalation-hazard materials resulting from a terrorist attack on a loaded railroad tank car carrying such materials in urban and rural environments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e914d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The analysis under this subsection shall take into account the following considerations:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb571014e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The most likely means of attack and the resulting dispersal rate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb571014f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Different times of day, to account for differences in cloud coverage and other atmospheric conditions in the environment being modeled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5710150-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Differences in population size and density.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5710151-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Historically accurate wind speeds, temperatures, and wind directions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5710152-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Differences in dispersal rates or other relevant factors related to whether a railroad tank car is in motion or stationary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5710153-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency response procedures by local officials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5710154-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other considerations the Secretary believes would develop an accurate, plausible dispersion model for toxic-inhalation-hazard materials released from a railroad tank car as a result of a terrorist act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5710155-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In conducting the dispersion modeling under paragraph (1), the Secretary shall consult with the Secretary of Transportation, hazardous materials experts, railroad carriers, nonprofit employee labor organizations representing railroad employees, appropriate State, local, and tribal officials, and other Federal agencies, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5710156-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information sharing","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Upon completion of the analysis required under paragraph (1), the Secretary shall share the information developed with the appropriate stakeholders, given appropriate information protection provisions as may be required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5710157-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1169/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 30 days after completion of all dispersion analyses under paragraph (1), the Secretary shall submit to the appropriate congressional committees a report detailing the Secretary’s conclusions and findings in an appropriate format.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5710158-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXV/s1519"},"text":"Pub. L. 110–53, title XV, § 1519","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/443"},"text":"121 Stat. 443","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
