{"tag":"section","attrib":{"id":"idb52be272-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s493"},"text":null,"children":[{"tag":"num","attrib":{"value":"493"},"text":"§ 493.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb52be273-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s493/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Council shall be the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52be274-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s493/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be275-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s493/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Vice President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be276-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s493/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be277-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s493/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be278-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s493/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52be279-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s493/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other individuals as may be designated by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52be27a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s493/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attendance of Chairman of Joint Chiefs of Staff at meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chairman of the Joint Chiefs of Staff (or, in the absence of the Chairman, the Vice Chairman of the Joint Chiefs of Staff) may, in the role of the Chairman of the Joint Chiefs of Staff as principal military adviser to the Council and subject to the direction of the President, attend and participate in meetings of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb52be27b-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIX/s903"},"text":"Pub. L. 107–296, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2258"},"text":"116 Stat. 2258","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tIX/s908/b"},"text":"Pub. L. 109–163, div. A, title IX, § 908(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3404"},"text":"119 Stat. 3404","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb52be27c-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb52be27d-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb52be27e-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
