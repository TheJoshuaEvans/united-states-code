{"tag":"section","attrib":{"id":"idb505bc37-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292"},"text":null,"children":[{"tag":"num","attrib":{"value":"292"},"text":"§ 292.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary separation incentive payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb505bc38-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb505bc39-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “employee” means an employee (as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of title 5","children":[],"tail":") who—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb505bc3a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed at least 3 years of current continuous service with 1 or more covered entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb505bc3b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving under an appointment without time limitation,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include any person under subparagraphs (A)–(G) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s663/a/2"},"text":"section 663(a)(2) of Public Law 104–208","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5597"},"text":"5 U.S.C. 5597","children":[],"tail":" note);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505bc3c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb505bc3d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Immigration and Naturalization Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb505bc3e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Border Security of the Department of Homeland Security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb505bc3f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Citizenship and Immigration Services of the Department of Homeland Security; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505bc40-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “transfer date” means the date on which the transfer of functions specified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s251"},"text":"section 251 of this title","children":[],"tail":" takes effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb505bc41-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strategic restructuring plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the Attorney General or the Secretary obligates any resources for voluntary separation incentive payments under this section, such official shall submit to the appropriate committees of Congress a strategic restructuring plan, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb505bc42-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an organizational chart depicting the covered entities after their restructuring pursuant to this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505bc43-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary description of how the authority under this section will be used to help carry out that restructuring; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505bc44-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information specified in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s663/b/2"},"text":"section 663(b)(2) of Public Law 104–208","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5597"},"text":"5 U.S.C. 5597","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"As used in the preceding sentence, the “appropriate committees of Congress” are the Committees on Appropriations, Government Reform, and the Judiciary of the House of Representatives, and the Committees on Appropriations, Governmental Affairs, and the Judiciary of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb505bc45-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General and the Secretary may, to the extent necessary to help carry out their respective strategic restructuring plan described in subsection (b), make voluntary separation incentive payments to employees. Any such payment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb505bc46-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be paid to the employee, in a lump sum, after the employee has separated from service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505bc47-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be paid from appropriations or funds available for the payment of basic pay of the employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505bc48-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be equal to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb505bc49-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount the employee would be entitled to receive under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5595/c"},"text":"section 5595(c) of title 5","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb505bc4a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount not to exceed $25,000, as determined by the Attorney General or the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505bc4b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may not be made except in the case of any qualifying employee who voluntarily separates (whether by retirement or resignation) before the end of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb505bc4c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 3-month period beginning on the date on which such payment is offered or made available to such employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb505bc4d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 3-year period beginning on ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whichever occurs first;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505bc4e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be a basis for payment, and shall not be included in the computation, of any other type of Government benefit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505bc4f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be taken into account in determining the amount of any severance pay to which the employee may be entitled under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5595"},"text":"section 5595 of title 5","children":[],"tail":", based on any other separation."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb505bc50-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional agency contributions to the retirement fund","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb505bc51-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to any payments which it is otherwise required to make, the Department of Justice and the Department of Homeland Security shall, for each fiscal year with respect to which it makes any voluntary separation incentive payments under this section, remit to the Office of Personnel Management for deposit in the Treasury of the United States to the credit of the Civil Service Retirement and Disability Fund the amount required under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505bc52-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amount required","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amount required under this paragraph shall, for any fiscal year, be the amount under subparagraph (A) or (B), whichever is greater.","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb505bc53-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" First method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount under this subparagraph shall, for any fiscal year, be equal to the minimum amount necessary to offset the additional costs to the retirement systems under title 5 (payable out of the Civil Service Retirement and Disability Fund) resulting from the voluntary separation of the employees described in paragraph (3), as determined under regulations of the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb505bc54-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Second method","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The amount under this subparagraph shall, for any fiscal year, be equal to 45 percent of the sum total of the final basic pay of the employees described in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505bc55-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Computations to be based on separations occurring in the fiscal year involved","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The employees described in this paragraph are those employees who receive a voluntary separation incentive payment under this section based on their separating from service during the fiscal year with respect to which the payment under this subsection relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505bc56-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Final basic pay defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this subsection, the term “final basic pay” means, with respect to an employee, the total amount of basic pay which would be payable for a year of service by such employee, computed using the employee’s final rate of basic pay, and, if last serving on other than a full-time basis, with appropriate adjustment therefor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb505bc57-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of subsequent employment with the Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An individual who receives a voluntary separation incentive payment under this section and who, within 5 years after the date of the separation on which the payment is based, accepts any compensated employment with the Government or works for any agency of the Government through a personal services contract, shall be required to pay, prior to the individual’s first day of employment, the entire amount of the incentive payment. Such payment shall be made to the covered entity from which the individual separated or, if made on or after the transfer date, to the Deputy Secretary or the Under Secretary for Border and Transportation Security (for transfer to the appropriate component of the Department of Homeland Security, if necessary).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb505bc58-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on employment levels","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb505bc59-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intended effect","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Voluntary separations under this section are not intended to necessarily reduce the total number of full-time equivalent positions in any covered entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb505bc5a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s292/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of voluntary separations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A covered entity may redeploy or use the full-time equivalent positions vacated by voluntary separations under this section to make other positions available to more critical locations or more critical occupations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb505bc5b-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s472"},"text":"Pub. L. 107–296, title IV, § 472","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2205"},"text":"116 Stat. 2205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb505bc5c-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb505bc5d-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb505bc5e-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s663"},"text":"Section 663 of Public Law 104–208","children":[],"tail":", referred to in subsecs. (a)(1) and (b)(3), probably means "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/f/tVI/s663"},"text":"Pub. L. 104–208, div. A, title I, § 101(f) [title VI, § 663]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-314"},"text":"110 Stat. 3009–314","children":[],"tail":", 3009–383, which is classified as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5597"},"text":"section 5597 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (b)(1), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2135"},"text":"116 Stat. 2135","children":[],"tail":", known as the Homeland Security Act of 2002, which is classified principally to this chapter. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb505bc5f-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb505bc60-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Bureau of Border Security, referred to in subsec. (a)(2)(B), changed to Bureau of Immigration and Customs Enforcement by Reorganization Plan Modification for the Department of Homeland Security, eff. ","children":[{"tag":"date","attrib":{"date":"2003-03-01"},"text":"Mar. 1, 2003","children":[],"tail":", H. Doc. No. 108–32, 108th Congress, 1st Session, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Government Reform of House of Representatives changed to Committee on Oversight and Government Reform of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Governmental Affairs of Senate changed to Committee on Homeland Security and Governmental Affairs of Senate, effective ","children":[{"tag":"date","attrib":{"date":"2005-01-04"},"text":"Jan. 4, 2005","children":[],"tail":", by Senate Resolution No. 445, One Hundred Eighth Congress, "},{"tag":"date","attrib":{"date":"2004-10-09"},"text":"Oct. 9, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
