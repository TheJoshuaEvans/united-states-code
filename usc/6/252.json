{"tag":"section","attrib":{"id":"idb500daeb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252"},"text":null,"children":[{"tag":"num","attrib":{"value":"252"},"text":"§ 252.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" U.S. Immigration and Customs Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb500daec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb500daed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be in the Department of Homeland Security a bureau to be known as the “Bureau of Border Security”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500daee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistant Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of U.S. Immigration and Customs Enforcement shall be the Assistant Secretary of U.S. Immigration and Customs Enforcement, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb500daef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall report directly to the Under Secretary for Border and Transportation Security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500daf0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall have a minimum of 5 years professional experience in law enforcement, and a minimum of 5 years of management experience.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500daf1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary of U.S. Immigration and Customs Enforcement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb500daf2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall establish the policies for performing such functions as are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb500daf3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferred to the Under Secretary for Border and Transportation Security by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s251"},"text":"section 251 of this title","children":[],"tail":" and delegated to the Assistant Secretary by the Under Secretary for Border and Transportation Security; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb500daf4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise vested in the Assistant Secretary by law;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500daf5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall oversee the administration of such policies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500daf6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall advise the Under Secretary for Border and Transportation Security with respect to any policy or operation of U.S. Immigration and Customs Enforcement affecting U.S. Citizenship and Immigration Services established under part E of this subchapter, including potentially conflicting policies or operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500daf7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to collect information relating to foreign students","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Secretary of U.S. Immigration and Customs Enforcement shall be responsible for administering the program to collect information relating to nonimmigrant foreign students and other exchange program participants described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1372"},"text":"section 1372 of title 8","children":[],"tail":", including the Student and Exchange Visitor Information System established under that section, and shall use such information to carry out the enforcement functions of the agency."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500daf8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Managerial rotation program","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb500daf9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date on which the transfer of functions specified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s251"},"text":"section 251 of this title","children":[],"tail":" takes effect, the Assistant Secretary of U.S. Immigration and Customs Enforcement shall design and implement a managerial rotation program under which employees of such agency holding positions involving supervisory or managerial responsibility and classified, in accordance with chapter 51 of title 5, as a GS–14 or above, shall—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb500dafa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gain some experience in all the major functions performed by such agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb500dafb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work in at least one local office of such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500dafc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 2 years after the date on which the transfer of functions specified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s251"},"text":"section 251 of this title","children":[],"tail":" takes effect, the Secretary shall submit a report to the Congress on the implementation of such program."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb500dafd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief of Policy and Strategy","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb500dafe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a position of Chief of Policy and Strategy for U.S. Immigration and Customs Enforcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500daff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In consultation with U.S. Immigration and Customs Enforcement personnel in local offices, the Chief of Policy and Strategy shall be responsible for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb500db00-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making policy recommendations and performing policy research and analysis on immigration enforcement issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500db01-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinating immigration policy issues with the Chief of Policy and Strategy for U.S. Citizenship and Immigration Services (established under part E of this subchapter), as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb500db02-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s252/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Legal advisor","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There shall be a principal legal advisor to the Assistant Secretary of U.S. Immigration and Customs Enforcement. The legal advisor shall provide specialized legal advice to the Assistant Secretary of U.S. Immigration and Customs Enforcement and shall represent the agency in all exclusion, deportation, and removal proceedings before the Executive Office for Immigration Review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb500db03-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s442"},"text":"Pub. L. 107–296, title IV, § 442","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2193"},"text":"116 Stat. 2193","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/96/s3/b/2"},"text":"Pub. L. 118–96, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1571"},"text":"138 Stat. 1571","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb500db04-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idb500db05-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/96/s6"},"text":"section 6 of Pub. L. 118–96","children":[],"tail":", see Termination Date of 2024 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb500db06-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb500db07-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Part E of this subchapter, referred to in subsecs. (a)(3)(C) and (b)(2)(B), was in the original “subtitle E”, meaning subtitle E (§§ 451–462) of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2195"},"text":"116 Stat. 2195","children":[],"tail":", which enacted part E (§ 271 et seq.) of this subchapter, amended sections 1356 and 1573 of Title 8, Aliens and Nationality, and enacted provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s271"},"text":"section 271 of this title","children":[],"tail":". For complete classification of subtitle E to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb500db08-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/96"},"text":"Pub. L. 118–96","children":[],"tail":", §§ 3(b)(2)(C), 6, temporarily substituted “U.S. Immigration and Customs Enforcement” for “the Bureau of Border Security” wherever appearing. See Termination Date of 2024 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/96"},"text":"Pub. L. 118–96","children":[],"tail":", §§ 3(b)(2)(A), 6, temporarily amended section catchline generally, substituting “U.S. Immigration and Customs Enforcement” for “Establishment of Bureau of Border Security”. See Termination Date of 2024 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/96"},"text":"Pub. L. 118–96","children":[],"tail":", §§ 3(b)(2)(D)(i), 6, temporarily struck out “of Bureau” after “Establishment” in heading. See Termination Date of 2024 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/96"},"text":"Pub. L. 118–96","children":[],"tail":", §§ 3(b)(2)(D)(ii), 6, which directed the temporary substitution of “affecting U.S.” for “affecting the Bureau of”, was executed by making the temporary substitution for “that may affect the Bureau of” to reflect the probable intent of Congress. See Termination Date of 2024 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/96"},"text":"Pub. L. 118–96","children":[],"tail":", §§ 3(b)(2)(D), 6, temporarily substituted “the agency.” for “the Bureau.” See Termination Date of 2024 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/96"},"text":"Pub. L. 118–96","children":[],"tail":", §§ 3(b)(2)(B), 6, temporarily substituted “agency” for “bureau” wherever appearing. See Termination Date of 2024 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/96"},"text":"Pub. L. 118–96","children":[],"tail":", §§ 3(b)(2)(E)(i), 6, temporarily substituted “U.S. Immigration and Customs Enforcement” for “Bureau of Border Security” in introductory provisions. See Termination Date of 2024 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/96"},"text":"Pub. L. 118–96","children":[],"tail":", §§ 3(b)(2)(E)(ii), 6, temporarily substituted “U.S.” for “the Bureau of”. See Termination Date of 2024 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/96"},"text":"Pub. L. 118–96","children":[],"tail":", §§ 3(b)(2)(B), 6, temporarily substituted “agency” for “bureau”. See Termination Date of 2024 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb500db09-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"idb500db0a-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/96/s6"},"text":"Pub. L. 118–96, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1572"},"text":"138 Stat. 1572","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/96/s6"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s258"},"text":"section 258 of this title","children":[],"tail":", amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s253"},"text":"section 253 of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s258"},"text":"section 258 of this title","children":[],"tail":"] and the amendments made by this Act shall cease to have force or effect beginning on "},{"tag":"date","attrib":{"date":"2030-10-01"},"text":"October 1, 2030","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb500db0b-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Bureau of Border Security, referred to in section catchline and text, changed to Bureau of Immigration and Customs Enforcement by Reorganization Plan Modification for the Department of Homeland Security, eff. ","children":[{"tag":"date","attrib":{"date":"2003-03-01"},"text":"Mar. 1, 2003","children":[],"tail":", H. Doc. No. 108–32, 108th Congress, 1st Session, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
