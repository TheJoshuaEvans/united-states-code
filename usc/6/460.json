{"tag":"section","attrib":{"id":"idb5224535-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s460"},"text":null,"children":[{"tag":"num","attrib":{"value":"460"},"text":"§ 460.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of the Terrorism Information and Prevention System","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any and all activities of the Federal Government to implement the proposed component program of the Citizen Corps known as Operation TIPS (Terrorism Information and Prevention System) are hereby prohibited.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5224536-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s880"},"text":"Pub. L. 107–296, title VIII, § 880","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2245"},"text":"116 Stat. 2245","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
