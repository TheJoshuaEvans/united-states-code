{"tag":"section","attrib":{"id":"idb562a94e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968"},"text":null,"children":[{"tag":"num","attrib":{"value":"968"},"text":"§ 968.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Third party validations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb562a94f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Commissioner, shall develop a plan to implement a 1-year voluntary pilot program to test and assess the feasibility, costs, and benefits of using third party entities to conduct validations of C–TPAT participants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a950-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 120 days after ","children":[{"tag":"date","attrib":{"date":"2006-10-13"},"text":"October 13, 2006","children":[],"tail":", after consulting with private sector stakeholders, including the Commercial Operations Advisory Committee, the Secretary shall submit a report to the appropriate congressional committees on the plan described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a951-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb562a952-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 1 year after the consultations described in subsection (b), the Secretary shall carry out the 1-year pilot program to conduct validations of C–TPAT participants using third party entities described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a953-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The decision to validate a C–TPAT participant is solely within the discretion of the Secretary, or the Secretary’s designee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a954-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of third party entities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall certify a third party entity to conduct validations under subsection (c) if the entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb562a955-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates to the satisfaction of the Secretary that the entity has the ability to perform validations in accordance with standard operating procedures and requirements designated by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a956-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" agrees—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb562a957-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perform validations in accordance with such standard operating procedures and requirements (and updates to such procedures and requirements); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562a958-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain liability insurance coverage at policy limits and in accordance with conditions to be established by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a959-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" signs an agreement to protect all proprietary information of C–TPAT participants with respect to which the entity will conduct validations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a95a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information for establishing limits of liability insurance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A third party entity seeking a certificate under subsection (d) shall submit to the Secretary necessary information for establishing the limits of liability insurance required to be maintained by the entity under this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a95b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb562a95c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any third party entity certified under this section does not have—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb562a95d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any beneficial interest in or any direct or indirect control over the C–TPAT participant for which the validation services are performed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562a95e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other conflict of interest with respect to the C–TPAT participant; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a95f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the C–TPAT participant has entered into a contract with the third party entity under which the C–TPAT participant agrees to pay all costs associated with the validation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a960-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb562a961-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall regularly monitor and inspect the operations of a third party entity conducting validations under subsection (c) to ensure that the entity is meeting the minimum standard operating procedures and requirements for the validation of C–TPAT participants established by the Secretary and all other applicable requirements for validation services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a962-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary determines that a third party entity is not meeting the minimum standard operating procedures and requirements designated by the Secretary under subsection (d)(1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb562a963-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoke the entity’s certificate of conformance issued under subsection (d)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb562a964-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review any validations conducted by the entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a965-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may only grant a C–TPAT validation by a third party entity pursuant to subsection (c) if the C–TPAT participant voluntarily submits to validation by such third party entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb562a966-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the completion of the pilot program conducted pursuant to subsection (c), the Secretary shall submit a report to the appropriate congressional committees that contains—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb562a967-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the pilot program, including the extent to which the pilot program ensured sufficient protection for proprietary commercial information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a968-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost and efficiency associated with validations under the pilot program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a969-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of the pilot program on the rate of validations conducted under C–TPAT;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a96a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any impact on national security of the pilot program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb562a96b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s968/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations by the Secretary based upon the results of the pilot program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb562a96c-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tII/s218"},"text":"Pub. L. 109–347, title II, § 218","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1912"},"text":"120 Stat. 1912","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb562a96d-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb562a96e-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb562a96f-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347"},"text":"Pub. L. 109–347","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1884"},"text":"120 Stat. 1884","children":[],"tail":", known as the Security and Accountability For Every Port Act of 2006 or the SAFE Port Act. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
