{"tag":"section","attrib":{"id":"idb5782e07-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1505"},"text":null,"children":[{"tag":"num","attrib":{"value":"1505"},"text":"§ 1505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection from liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5782e08-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Monitoring of information systems","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No cause of action shall lie or be maintained in any court against any private entity, and such action shall be promptly dismissed, for the monitoring of an information system and information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1503/a"},"text":"section 1503(a) of this title","children":[],"tail":" that is conducted in accordance with this subchapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e09-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing or receipt of cyber threat indicators","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"No cause of action shall lie or be maintained in any court against any private entity, and such action shall be promptly dismissed, for the sharing or receipt of a cyber threat indicator or defensive measure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1503/c"},"text":"section 1503(c) of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5782e0a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sharing or receipt is conducted in accordance with this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782e0b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in a case in which a cyber threat indicator or defensive measure is shared with the Federal Government, the cyber threat indicator or defensive measure is shared in a manner that is consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1504/c/1/B"},"text":"section 1504(c)(1)(B) of this title","children":[],"tail":" and the sharing or receipt, as the case may be, occurs after the earlier of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5782e0c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1505/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the interim policies and procedures are submitted to Congress under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1504/a/1"},"text":"section 1504(a)(1) of this title","children":[],"tail":" and guidelines are submitted to Congress under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s1504/b/1"},"text":"section 1504(b)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782e0d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1505/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 60 days after ","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"December 18, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e0e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5782e0f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1505/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to create—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5782e10-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1505/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a duty to share a cyber threat indicator or defensive measure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5782e11-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1505/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a duty to warn or act based on the receipt of a cyber threat indicator or defensive measure; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782e12-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1505/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to undermine or limit the availability of otherwise applicable common law or statutory defenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5782e13-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dN/tI/s106"},"text":"Pub. L. 114–113, div. N, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2950"},"text":"129 Stat. 2950","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
