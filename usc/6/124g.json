{"tag":"section","attrib":{"id":"idb4df96f1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124g"},"text":null,"children":[{"tag":"num","attrib":{"value":"124g"},"text":"§ 124g.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information sharing incentives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4df96f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124g/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In making cash awards under chapter 45 of title 5, the President or the head of an agency, in consultation with the program manager designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s485"},"text":"section 485 of this title","children":[],"tail":", may consider the success of an employee in appropriately sharing information within the scope of the information sharing environment established under that section, including homeland security information, terrorism information, and weapons of mass destruction information, or national intelligence (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/5"},"text":"section 3003(5) of title 50","children":[],"tail":" "},{"tag":"ref","attrib":{"idref":"fn002009"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. A closing parenthesis probably should precede the comma."}],"tail":", in a manner consistent with any policies, guidelines, procedures, instructions, or standards established by the President or, as appropriate, the program manager of that environment for the implementation and management of that environment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4df96f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124g/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other incentives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each department or agency described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s485/h"},"text":"section 485(h) of this title","children":[],"tail":", in consultation with the program manager designated under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s485"},"text":"section 485 of this title","children":[],"tail":", shall adopt best practices regarding effective ways to educate and motivate officers and employees of the Federal Government to participate fully in the information sharing environment, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4df96f4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124g/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promotions and other nonmonetary awards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4df96f5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s124g/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publicizing information sharing accomplishments by individual employees and, where appropriate, the tangible end benefits that resulted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4df96f6-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tII/s210"},"text":"Pub. L. 107–296, title II, § 210","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tV/s503/a"},"text":"Pub. L. 110–53, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/313"},"text":"121 Stat. 313","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dF/tLXVIII/s6811/c/2"},"text":"Pub. L. 117–263, div. F, title LXVIII, § 6811(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3601"},"text":"136 Stat. 3601","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4df96f7-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4df96f8-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4df96f9-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s485/h"},"text":"section 485(h) of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s485/i"},"text":"section 485(i) of this title","children":[],"tail":"” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
