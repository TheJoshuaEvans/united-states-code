{"tag":"section","attrib":{"id":"idb55451e9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d"},"text":null,"children":[{"tag":"num","attrib":{"value":"677d"},"text":"§ 677d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification and reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb55451ea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon a declaration or renewal, the Secretary shall immediately notify the National Cyber Director and appropriate congressional committees and include in the notification—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55451eb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimation of the planned duration of the declaration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451ec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to a notification of a declaration, the reason for the declaration, including information relating to the specific significant incident or imminent specific significant incident, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55451ed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operational or mission impact or anticipated impact of the specific significant incident on Federal and non-Federal entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451ee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if known, the perpetrator of the specific significant incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451ef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scope of the Federal and non-Federal entities impacted or anticipated to be impacted by the specific significant incident;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451f0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a notification of a renewal, the reason for the renewal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451f1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" justification as to why available resources, other than the Fund, are insufficient to respond to or mitigate the specific significant incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the coordination activities described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s677b/b"},"text":"section 677b(b) of this title","children":[],"tail":" that the Secretary anticipates the Director to perform."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55451f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of a declaration or renewal, the Secretary shall submit to the appropriate congressional committees a report that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55451f4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reason for the declaration or renewal, including information and intelligence relating to the specific significant incident that led to the declaration or renewal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451f5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of any funds from the Fund for the purpose of responding to the incident or threat described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451f6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the actions, initiatives, and projects undertaken by the Department and State and local governments and public and private entities in responding to and recovering from the specific significant incident described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451f7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accounting of the specific obligations and outlays of the Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451f8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an analysis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55451f9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of the specific significant incident described in paragraph (1) on Federal and non-Federal entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451fa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of the declaration or renewal on the response to, and recovery from, the specific significant incident described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451fb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of the funds made available from the Fund as a result of the declaration or renewal on the recovery from, and response to, the specific significant incident described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55451fc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classification","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each notification made under subsection (a) and each report submitted under subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55451fd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in an unclassified form with appropriate markings to indicate information that is exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" (commonly known as the “Freedom of Information Act”); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451fe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55451ff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidated report","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall not be required to submit multiple reports under subsection (b) for multiple declarations or renewals if the Secretary determines that the declarations or renewals substantively relate to the same specific significant incident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5545200-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677d/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The requirements of subchapter I of chapter 35 of title 44 (commonly known as the “Paperwork Reduction Act”) shall not apply to the voluntary collection of information by the Department during an investigation of, a response to, or an immediate post-response review of, the specific significant incident leading to a declaration or renewal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5545201-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2235"},"text":"Pub. L. 107–296, title XXII, § 2235","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tVI/s70602/a"},"text":"Pub. L. 117–58, div. G, title VI, § 70602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1270"},"text":"135 Stat. 1270","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
