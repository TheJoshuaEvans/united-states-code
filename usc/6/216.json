{"tag":"section","attrib":{"id":"idb4f9d572-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s216"},"text":null,"children":[{"tag":"num","attrib":{"value":"216"},"text":"§ 216.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection against potential synthetic opioid exposure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4f9d573-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s216/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner of U.S. Customs and Border Protection shall issue a policy that specifies effective protocols and procedures for the safe handling of potential synthetic opioids, including fentanyl, by U.S. Customs and Border Protection officers, agents, other personnel, and canines, and to reduce the risk of injury or death resulting from accidental exposure and enhance post-exposure management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f9d574-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s216/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f9d575-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s216/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Together with the issuance of the policy described in subsection (a), the Commissioner of U.S. Customs and Border Protection shall require mandatory and recurrent training on the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f9d576-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s216/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The potential risk of opioid exposure and safe handling procedures for potential synthetic opioids, including precautionary measures such as the use of personal protective equipment during such handling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f9d577-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s216/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" How to access and administer opioid receptor antagonists, including naloxone, post-exposure to potential synthetic opioids.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f9d578-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s216/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" How to use containment devices to prevent potential synthetic opioid exposure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f9d579-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s216/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Integration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The training described in paragraph (1) may be integrated into existing training under section 211(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of this title for U.S. Customs and Border Protection officers, agents, and other personnel."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f9d57a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s216/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal protective equipment, containment devices, and opioid receptor antagonists","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Together with the issuance of the policy described in subsection (a), the Commissioner of U.S. Customs and Border Protection shall ensure the availability of personal protective equipment, opioid receptor antagonists, including naloxone, and containment devices, to all U.S. Customs and Border Protection officers, agents, other personnel, and canines at risk of accidental exposure to synthetic opioids.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f9d57b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s216/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure effectiveness of the policy described in subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f9d57c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s216/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commissioner of U.S. Customs and Border Protection shall regularly monitor the efficacy of the implementation of such policy and adjust protocols and procedures, as necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f9d57d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s216/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Inspector General of the Department shall audit compliance with the requirements of this section not less than once during the 3-year period after ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4f9d57e-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s416"},"text":"Pub. L. 107–296, title IV, § 416","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dU/tIII/s302/a"},"text":"Pub. L. 116–260, div. U, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2291"},"text":"134 Stat. 2291","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7135/a"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7135(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3650"},"text":"136 Stat. 3650","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4f9d57f-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4f9d580-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb4f9d581-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s216"},"text":"section 216 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s416"},"text":"Pub. L. 107–296, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2181"},"text":"116 Stat. 2181","children":[],"tail":", related to GAO report to Congress, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s802/f"},"text":"Pub. L. 114–125, title VIII, § 802(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/210"},"text":"130 Stat. 210","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4f9d582-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7135/a"},"text":"Pub. L. 117–263, § 7135(a)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7135/b"},"text":"Pub. L. 117–263, § 7135(b)","children":[],"tail":", inserted “, containment devices,” after “equipment” in heading and substituted “, opioid receptor antagonists, including naloxone, and containment devices” for “and opioid receptor antagonists, including naloxone” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb4f9d583-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb4f9d584-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability to Other Components","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7135/c"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7135(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3650"},"text":"136 Stat. 3650","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dG/tLXXI/s7135/c"},"text":"“If the Secretary of Homeland Secretary determines that officers, agents, other personnel, or canines of a component of the Department of Homeland Security other than U.S. Customs and Border Protection are at risk of potential synthetic opioid exposure in the course of their duties, the head of such component shall carry out the responsibilities under section 416 of the Homeland Security Act of 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s216"},"text":"6 U.S.C. 216","children":[],"tail":") in the same manner and to the same degree as the Commissioner of U.S. Customs and Border Protection carries out such responsibilities.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
