{"tag":"section","attrib":{"id":"idb522452a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s459"},"text":null,"children":[{"tag":"num","attrib":{"value":"459"},"text":"§ 459.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of International Affairs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb522452b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s459/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Office of the Secretary an Office of International Affairs. The Office shall be headed by a Director, who shall be a senior official appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb522452c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s459/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of the Director","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall have the following duties:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb522452d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s459/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To promote information and education exchange with nations friendly to the United States in order to promote sharing of best practices and technologies relating to homeland security. Such exchange shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb522452e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s459/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Exchange of information on research and development on homeland security technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb522452f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s459/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Joint training exercises of first responders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5224530-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s459/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Exchange of expertise on terrorism prevention, response, and crisis management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5224531-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s459/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To identify areas for homeland security information and training exchange where the United States has a demonstrated weakness and another friendly nation or nations have a demonstrated expertise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5224532-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s459/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To plan and undertake international conferences, exchange programs, and training activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5224533-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s459/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To manage international activities within the Department in coordination with other Federal officials with responsibility for counter-terrorism matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5224534-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s879"},"text":"Pub. L. 107–296, title VIII, § 879","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2245"},"text":"116 Stat. 2245","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
