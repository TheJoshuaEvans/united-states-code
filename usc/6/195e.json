{"tag":"section","attrib":{"id":"idb4f0398a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e"},"text":null,"children":[{"tag":"num","attrib":{"value":"195e"},"text":"§ 195e.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transparency in research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4f0398b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to list research and development programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f0398c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall maintain a detailed list of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f0398d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each classified and unclassified research and development project, and all appropriate details for each such project, including the component of the Department responsible for each such project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0398e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each task order for a Federally Funded Research and Development Center not associated with a research and development project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0398f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each task order for a University-based center of excellence not associated with a research and development project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f03990-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The indicators developed and tracked by the Under Secretary for Science and Technology with respect to transitioned projects pursuant to subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03991-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception for certain completed projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to a project completed or otherwise terminated before ","children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"December 23, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03992-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Updates","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The list required under paragraph (1) shall be updated as frequently as possible, but not less frequently than once per quarter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03993-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For purposes of the list required under paragraph (1), the Secretary shall provide a definition for the term “research and development”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03994-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to report to Congress on all projects","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2017-01-01"},"text":"January 1, 2017","children":[],"tail":", and annually thereafter, the Secretary shall submit to the Committee on Homeland Security of the House of Representatives and the Committee on Homeland Security and Governmental Affairs of the Senate a classified and unclassified report, as applicable, that lists each ongoing classified and unclassified project at the Department, including all appropriate details of each such project."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03995-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Indicators of success of transitioned projects","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f03996-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"For each project that has been transitioned to practice from research and development, the Under Secretary for Science and Technology shall develop and track indicators to demonstrate the uptake of the technology or project among customers or end-users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f03997-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the fullest extent possible, the tracking of a project required under paragraph (1) shall continue for the three-year period beginning on the date on which such project was transitioned to practice from research and development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f03998-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4f03999-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" All appropriate details","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “all appropriate details” means, with respect to a research and development project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f0399a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of such project, including both classified and unclassified names if applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0399b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the component of the Department carrying out such project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0399c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an abstract or summary of such project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0399d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding levels for such project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0399e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project duration or timeline;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f0399f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of each contractor, grantee, or cooperative agreement partner involved in such project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f039a0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expected objectives and milestones for such project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f039a1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, relevant literature and patents that are associated with such project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f039a2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “classified” means anything containing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4f039a3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classified national security information as defined in section 6.1 of Executive Order 13526 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"50 U.S.C. 3161","children":[],"tail":" note) or any successor order;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f039a4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Restricted Data or data that was formerly Restricted Data, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2014/y"},"text":"section 2014(y) of title 42","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f039a5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" material classified at the Sensitive Compartmented Information (SCI) level, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3345"},"text":"section 3345 of title 50","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4f039a6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information relating to a special access program, as defined in section 6.1 of Executive Order 13526 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3161"},"text":"50 U.S.C. 3161","children":[],"tail":" note) or any successor order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f039a7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Controlled unclassified information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “controlled unclassified information” means information described as “Controlled Unclassified Information” under Executive Order 13556 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3501"},"text":"50 U.S.C. 3501","children":[],"tail":" note) "},{"tag":"ref","attrib":{"idref":"fn002028"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002028"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" or any successor order."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4f039a8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “project” means a research or development project, program, or activity administered by the Department, whether ongoing, completed, or otherwise terminated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4f039a9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s195e/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section overrides or otherwise affects the requirements specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s468"},"text":"section 468 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4f039aa-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIII/s319"},"text":"Pub. L. 107–296, title III, § 319","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXIX/s1906/a"},"text":"Pub. L. 114–328, div. A, title XIX, § 1906(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2676"},"text":"130 Stat. 2676","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4f039ab-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4f039ac-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4f039ad-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 13556, referred to in subsec. (d)(3), is set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"section 3501 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb4f039ae-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s319"},"text":"section 319 of Pub. L. 107–296","children":[],"tail":" was renumbered section 320 and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s195f"},"text":"section 195f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
