{"tag":"section","attrib":{"id":"idb52e2bb3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s532"},"text":null,"children":[{"tag":"num","attrib":{"value":"532"},"text":"§ 532.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Explosives Training and Research Facility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb52e2bb4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s532/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Bureau an Explosives Training and Research Facility at Fort AP Hill, Fredericksburg, Virginia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52e2bb5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s532/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The facility established under subsection (a) shall be utilized to train Federal, State, and local law enforcement officers to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52e2bb6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s532/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigate bombings and explosions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52e2bb7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s532/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" properly handle, utilize, and dispose of explosive materials and devices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52e2bb8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s532/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train canines on explosive detection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52e2bb9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s532/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct research on explosives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb52e2bba-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s532/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb52e2bbb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s532/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to establish and maintain the facility established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb52e2bbc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s532/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any amounts appropriated pursuant to paragraph (1) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb52e2bbd-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXI/s1114"},"text":"Pub. L. 107–296, title XI, § 1114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2280"},"text":"116 Stat. 2280","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
