{"tag":"section","attrib":{"id":"idb51d8b15-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s417"},"text":null,"children":[{"tag":"num","attrib":{"value":"417"},"text":"§ 417.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rotational cybersecurity research program","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To enhance the Department’s cybersecurity capacity, the Secretary may establish a rotational research, development, and training program for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb51d8b16-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s417/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" detail to the Cybersecurity and Infrastructure Security Agency (including the national cybersecurity and communications integration center authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s659"},"text":"section 659 of this title","children":[],"tail":") of Coast Guard Academy graduates and faculty; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb51d8b17-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s417/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" detail to the Coast Guard Academy, as faculty, of individuals with expertise and experience in cybersecurity who are employed by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb51d8b18-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s417/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Agency (including the center);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8b19-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s417/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Directorate of Science and Technology; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb51d8b1a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s417/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions that have been designated by the Department as a Center of Excellence for Cyber Defense, or the equivalent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb51d8b1b-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s846"},"text":"Pub. L. 107–296, title VIII, § 846","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXII"},"text":"Pub. L. 116–283, div. G, title LVXXXII","children":[],"tail":" [LXXXII], § 8278(a), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4687"},"text":"134 Stat. 4687","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
