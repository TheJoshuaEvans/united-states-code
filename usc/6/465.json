{"tag":"section","attrib":{"id":"idb524b5da-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s465"},"text":null,"children":[{"tag":"num","attrib":{"value":"465"},"text":"§ 465.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint Interagency Task Force","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb524b5db-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s465/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may establish and operate a permanent Joint Interagency Homeland Security Task Force composed of representatives from military and civilian agencies of the United States Government for the purposes of anticipating terrorist threats against the United States and taking appropriate actions to prevent harm to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb524b5dc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s465/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Structure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"It is the sense of Congress that the Secretary should model the Joint Interagency Homeland Security Task Force on the approach taken by the Joint Interagency Task Forces for drug interdiction at Key West, Florida and Alameda, California, to the maximum extent feasible and appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb524b5dd-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tVIII/s885"},"text":"Pub. L. 107–296, title VIII, § 885","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2247"},"text":"116 Stat. 2247","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
