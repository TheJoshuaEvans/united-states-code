{"tag":"section","attrib":{"id":"idb5593421-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753"},"text":null,"children":[{"tag":"num","attrib":{"value":"753"},"text":"§ 753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal preparedness","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5593422-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency responsibility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In support of the national preparedness system, the President shall ensure that each Federal agency with responsibilities under the National Response Plan—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5593423-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has the operational capability to meet the national preparedness goal, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5593424-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the personnel to make and communicate decisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5593425-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizational structures that are assigned, trained, and exercised for the missions of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5593426-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sufficient physical resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5593427-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the command, control, and communication channels to make, monitor, and communicate decisions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5593428-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with the National Incident Management System, including credentialing of personnel and typing of resources likely needed to respond to a natural disaster, act of terrorism, or other man-made disaster in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s320"},"text":"section 320 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5593429-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops, trains, and exercises rosters of response personnel to be deployed when the agency is called upon to support a Federal response;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559342a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develops deliberate operational plans and the corresponding capabilities, including crisis planning, to respond effectively to natural disasters, acts of terrorism, and other man-made disasters in support of the National Response Plan to ensure a coordinated Federal response; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559342b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regularly updates, verifies the accuracy of, and provides to the Administrator the information in the inventory required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s751"},"text":"section 751 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb559342c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Operational plans","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"An operations plan developed under subsection (a)(4) shall meet the following requirements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb559342d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operations plan shall be coordinated under a unified system with a common terminology, approach, and framework.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559342e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The operations plan shall be developed, in coordination with State, local, and tribal government officials, to address both regional and national risks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb559342f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The operations plan shall contain, as appropriate, the following elements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5593430-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Concepts of operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5593431-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Critical tasks and responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5593432-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Detailed resource and personnel requirements, together with sourcing requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5593433-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Specific provisions for the rapid integration of the resources and personnel of the agency into the overall response.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5593434-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The operations plan shall address, as appropriate, the following matters:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5593435-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Support of State, local, and tribal governments in conducting mass evacuations, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5593436-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation and relocation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5593437-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" short- and long-term sheltering and accommodation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5593438-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions for populations with special needs, keeping families together, and expeditious location of missing children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5593439-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies and provisions for pets.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb559343a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The preparedness and deployment of public health and medical resources, including resources to address the needs of evacuees and populations with special needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb559343b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The coordination of interagency search and rescue operations, including land, water, and airborne search and rescue operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb559343c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The roles and responsibilities of the Senior Federal Law Enforcement Official with respect to other law enforcement entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb559343d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The protection of critical infrastructure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb559343e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The coordination of maritime salvage efforts among relevant agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb559343f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The coordination of Department of Defense and National Guard support of civilian authorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5593440-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent practicable, the utilization of Department of Defense, National Air and Space Administration, National Oceanic and Atmospheric Administration, and commercial aircraft and satellite remotely sensed imagery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55b7d31-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The coordination and integration of support from the private sector and nongovernmental organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55b7d32-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The safe disposal of debris, including hazardous materials, and, when practicable, the recycling of debris.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55b7d33-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The identification of the required surge capacity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55b7d34-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/b/4/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Specific provisions for the recovery of affected geographic areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55b7d35-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mission assignments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To expedite the provision of assistance under the National Response Plan, the President shall ensure that the Administrator, in coordination with Federal agencies with responsibilities under the National Response Plan, develops prescripted mission assignments, including logistics, communications, mass care, health services, and public safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55b7d36-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall certify to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Homeland Security and the Committee on Transportation and Infrastructure of the House of Representatives on an annual basis that each Federal agency with responsibilities under the National Response Plan complies with subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb55b7d37-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to limit the authority of the Secretary of Defense with regard to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55b7d38-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the command, control, training, planning, equipment, exercises, or employment of Department of Defense forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55b7d39-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s753/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allocation of Department of Defense resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55b7d3a-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s653"},"text":"Pub. L. 109–295, title VI, § 653","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1430"},"text":"120 Stat. 1430","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tIV/s407"},"text":"Pub. L. 110–53, title IV, § 407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/304"},"text":"121 Stat. 304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb55b7d3b-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb55b7d3c-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb55b7d3d-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s407/1/A"},"text":"Pub. L. 110–53, § 407(1)(A)","children":[],"tail":", struck out “coordinating, primary, or supporting” before “responsibilities” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s407/1/B"},"text":"Pub. L. 110–53, § 407(1)(B)","children":[],"tail":", inserted “, including credentialing of personnel and typing of resources likely needed to respond to a natural disaster, act of terrorism, or other man-made disaster in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s320"},"text":"section 320 of this title","children":[],"tail":"” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s407/1/C"},"text":"Pub. L. 110–53, § 407(1)(C)","children":[],"tail":"–(E), added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s407/2"},"text":"Pub. L. 110–53, § 407(2)","children":[],"tail":", inserted “to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Homeland Security and the Committee on Transportation and Infrastructure of the House of Representatives” after “certify” and struck out “coordinating, primary, or supporting” before “responsibilities”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
