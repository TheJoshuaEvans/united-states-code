{"tag":"section","attrib":{"id":"idb5486b39-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661"},"text":null,"children":[{"tag":"num","attrib":{"value":"661"},"text":"§ 661.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cybersecurity strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5486b3a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"December 23, 2016","children":[],"tail":", the Secretary shall develop a departmental strategy to carry out cybersecurity responsibilities as set forth in law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5486b3b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The strategy required under subsection (a) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5486b3c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategic and operational goals and priorities to successfully execute the full range of the Secretary’s cybersecurity responsibilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5486b3d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information on the programs, policies, and activities that are required to successfully execute the full range of the Secretary’s cybersecurity responsibilities, including programs, policies, and activities in furtherance of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5486b3e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cybersecurity functions set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s659"},"text":"section 659 of this title","children":[],"tail":" (relating to the national cybersecurity and communications integration center)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5486b3f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cybersecurity investigations capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5486b40-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cybersecurity research and development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5486b41-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Engagement with international cybersecurity partners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5486b42-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the strategy required under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5486b43-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5486b44-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cybersecurity strategy for the Homeland Security Enterprise published by the Secretary in November 2011;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5486b45-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Homeland Security Fiscal Years 2014–2018 Strategic Plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5486b46-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recent Quadrennial Homeland Security Review issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s347"},"text":"section 347 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5486b47-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include information on the roles and responsibilities of components and offices of the Department, to the extent practicable, to carry out such strategy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5486b48-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the development of the strategy required under subsection (a), the Secretary shall issue an implementation plan for the strategy that includes the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5486b49-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Strategic objectives and corresponding tasks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5486b4a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projected timelines and costs for such tasks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5486b4b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Metrics to evaluate performance of such tasks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5486b4c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional oversight","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall submit to Congress for assessment the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5486b4d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A copy of the strategy required under subsection (a) upon issuance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5486b4e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A copy of the implementation plan required under subsection (d) upon issuance, together with detailed information on any associated legislative or budgetary proposals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5486b4f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The strategy required under subsection (a) shall be in an unclassified form but may contain a classified annex.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb54adb50-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s661/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section may be construed as permitting the Department to engage in monitoring, surveillance, exfiltration, or other collection activities for the purpose of tracking an individual’s personally identifiable information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb54adb51-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2211"},"text":"Pub. L. 107–296, title XXII, § 2211","children":[],"tail":", formerly title II, § 228A, as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXIX/s1912/a"},"text":"Pub. L. 114–328, div. A, title XIX, § 1912(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2683"},"text":"130 Stat. 2683","children":[],"tail":"; renumbered title XXII, § 2211, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/2/I"},"text":"Pub. L. 115–278, § 2(g)(2)(I)","children":[],"tail":", (9)(A)(v), "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4178"},"text":"132 Stat. 4178","children":[],"tail":", 4181; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7143/b/2/F"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7143(b)(2)(F)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3660"},"text":"136 Stat. 3660","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb54adb52-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb54adb53-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb54adb54-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was formerly classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s149a"},"text":"section 149a of this title","children":[],"tail":" prior to renumbering by "},{"tag":"ref","attrib":{"href":"/us/pl/115/278"},"text":"Pub. L. 115–278","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb54adb55-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" struck out subsec. (h). Text read as follows: “In this section, the term ‘Homeland Security Enterprise’ means relevant governmental and nongovernmental entities involved in homeland security, including Federal, State, local, and tribal government officials, private sector representatives, academics, and other policy experts.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/9/A/v"},"text":"Pub. L. 115–278, § 2(g)(9)(A)(v)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s659"},"text":"section 659 of this title","children":[],"tail":"” for “the "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s148"},"text":"section 148 of this title","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
