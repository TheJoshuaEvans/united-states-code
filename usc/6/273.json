{"tag":"section","attrib":{"id":"idb5034bb6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s273"},"text":null,"children":[{"tag":"num","attrib":{"value":"273"},"text":"§ 273.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Professional responsibility and quality review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5034bb7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s273/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Bureau of Citizenship and Immigration Services shall be responsible for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5034bb8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s273/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting investigations of noncriminal allegations of misconduct, corruption, and fraud involving any employee of the Bureau of Citizenship and Immigration Services that are not subject to investigation by the Inspector General for the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034bb9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s273/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspecting the operations of the Bureau of Citizenship and Immigration Services and providing assessments of the quality of the operations of such bureau as a whole and each of its components; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034bba-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s273/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing an analysis of the management of the Bureau of Citizenship and Immigration Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5034bbb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s273/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing assessments in accordance with subsection (a)(2) with respect to a decision of the Bureau of Citizenship and Immigration Services, or any of its components, consideration shall be given to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5034bbc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s273/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accuracy of the findings of fact and conclusions of law used in rendering the decision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034bbd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s273/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any fraud or misrepresentation associated with the decision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5034bbe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s273/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efficiency with which the decision was rendered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5034bbf-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s453"},"text":"Pub. L. 107–296, title IV, § 453","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2199"},"text":"116 Stat. 2199","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5034bc0-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb5034bc1-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb5034bc2-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date on which the transfer of functions specified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s251"},"text":"section 251 of this title","children":[],"tail":" takes effect, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s455"},"text":"section 455 of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s271"},"text":"section 271 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
