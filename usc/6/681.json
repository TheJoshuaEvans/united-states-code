{"tag":"section","attrib":{"id":"idb5545209-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681"},"text":null,"children":[{"tag":"num","attrib":{"value":"681"},"text":"§ 681.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb554520a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Center” means the center established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s659"},"text":"section 659 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb554520b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Council” means the Cyber Incident Reporting Council described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s681f"},"text":"section 681f of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb554520c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered cyber incident","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered cyber incident” means a substantial cyber incident experienced by a covered entity that satisfies the definition and criteria established by the Director in the final rule issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s681b/b"},"text":"section 681b(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb554520d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “covered entity” means an entity in a critical infrastructure sector, as defined in Presidential Policy Directive 21, that satisfies the definition established by the Director in the final rule issued pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s681b/b"},"text":"section 681b(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb554520e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cyber incident","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “cyber incident”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb554520f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term “incident” in section 659 ","children":[{"tag":"ref","attrib":{"idref":"fn002120"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002120"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5545210-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include an occurrence that imminently, but not actually, jeopardizes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5545211-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on information systems; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5545212-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5545213-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cyber threat","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “cyber threat” has the meaning given the term “cybersecurity threat” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s650"},"text":"section 650 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5545214-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal entity","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal entity” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1501"},"text":"section 1501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5545215-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ransom payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “ransom payment” means the transmission of any money or other property or asset, including virtual currency, or any portion thereof, which has at any time been delivered as ransom in connection with a ransomware attack.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5545216-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Significant cyber incident","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “significant cyber incident” means a cyber incident, or a group of related cyber incidents, that the Secretary determines is likely to result in demonstrable harm to the national security interests, foreign relations, or economy of the United States or to the public confidence, civil liberties, or public health and safety of the people of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5545217-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Virtual currency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “virtual currency” means the digital representation of value that functions as a medium of exchange, a unit of account, or a store of value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5545218-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Virtual currency address","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “virtual currency address” means a unique public cryptographic key identifying the location to which a virtual currency payment can be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5545219-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2240"},"text":"Pub. L. 107–296, title XXII, § 2240","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dY/s103/a/2"},"text":"Pub. L. 117–103, div. Y, § 103(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1039"},"text":"136 Stat. 1039","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7143/b/2/N"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7143(b)(2)(N)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3661"},"text":"136 Stat. 3661","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb554521a-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb554521b-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb554521c-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s659"},"text":"Section 659 of this title","children":[],"tail":", referred to in par. (5)(A), was subsequently amended, and section 659(a) no longer defines the term “incident”. Reference to term, “incident”, as defined in this chapter deemed to be a reference to that term as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s650/12"},"text":"section 650(12) of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/f/2"},"text":"section 7143(f)(2) of Pub. L. 117–263","children":[],"tail":", set out as a Rule of Construction note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s650"},"text":"section 650 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb554521d-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/i"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(i)","children":[],"tail":", (ii), redesignated par. (3) as (2) and struck out former par. (2). Prior to amendment, text of par. (2) read as follows: “The term ‘cloud service provider’ means an entity offering products or services related to cloud computing, as defined by the National Institute of Standards and Technology in NIST Special Publication 800–145 and any amendatory or superseding document relating thereto.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/ii"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(ii)","children":[],"tail":", redesignated pars. (4) to (6) as (3) to (5), respectively. Former par. (3) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/ii"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(ii)","children":[],"tail":", (iii), redesignated par. (7) as (6) and substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s650"},"text":"section 650 of this title","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t6/s651"},"text":"section 651 of this title","children":[],"tail":"”. Former par. (6) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/iv"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(iv)","children":[],"tail":", added par. (7). Former par. (7) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/iv"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(iv)","children":[],"tail":", (vi), redesignated par. (13) as (8) and struck out former par. (8). Prior to amendment, text of par. (8) read as follows: “The terms ‘cyber threat indicator’, ‘cybersecurity purpose’, ‘defensive measure’, ‘Federal entity’, and ‘security vulnerability’ have the meanings given those terms in "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s1501"},"text":"section 1501 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/v"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(v)","children":[],"tail":", (vi), redesignated par. (16) as (9) and struck out former par. (9). Prior to amendment, text of par. (9) read as follows: “The terms ‘incident’ and ‘sharing’ have the meanings given those terms in "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s659"},"text":"section 659 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/v"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(v)","children":[],"tail":", (vi), redesignated par. (18) as (10) and struck out former par. (10). Prior to amendment, text of par. (10) read as follows: “The term ‘Information Sharing and Analysis Organization’ has the meaning given the term in "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s671"},"text":"section 671 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/v"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(v)","children":[],"tail":", (vi), redesignated par. (19) as (11) and struck out former par. (11). Prior to amendment, text of par. (11) read as follows: “The term ‘information system’—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3502"},"text":"section 3502 of title 44","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) includes industrial control systems, such as supervisory control and data acquisition systems, distributed control systems, and programmable logic controllers.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/v"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(v)","children":[],"tail":", struck out par. (12). Text read as follows: “The term ‘managed service provider’ means an entity that delivers services, such as network, application, infrastructure, or security services, via ongoing and regular support and active administration on the premises of a customer, in the data center of the entity (such as hosting), or in a third party data center.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/vi"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(vi)","children":[],"tail":", redesignated par. (13) as (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/v"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(v)","children":[],"tail":", struck out par. (14). Text read as follows: “The term ‘ransomware attack’—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) means an incident that includes the use or threat of use of unauthorized or malicious code on an information system, or the use or threat of use of another digital mechanism such as a denial of service attack, to interrupt or disrupt the operations of an information system or compromise the confidentiality, availability, or integrity of electronic data stored on, processed by, or transiting an information system to extort a demand for a ransom payment; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) does not include any such event where the demand for payment is—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) not genuine; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) made in good faith by an entity in response to a specific request by the owner or operator of the information system.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/v"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(v)","children":[],"tail":", struck out par. (15). Text read as follows: “The term ‘Sector Risk Management Agency’ has the meaning given the term in "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s651"},"text":"section 651 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/vi"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(vi)","children":[],"tail":", redesignated par. (16) as (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/v"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(v)","children":[],"tail":", struck out par. (17). Text read as follows: “The term ‘supply chain compromise’ means an incident within the supply chain of an information system that an adversary can leverage or does leverage to jeopardize the confidentiality, integrity, or availability of the information system or the information the system processes, stores, or transmits, and can occur at any point during the life cycle.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (18), (19). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s7143/b/2/N/vi"},"text":"Pub. L. 117–263, § 7143(b)(2)(N)(vi)","children":[],"tail":", redesignated pars. (18) and (19) as (10) and (11), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
