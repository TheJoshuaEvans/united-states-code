{"tag":"section","attrib":{"id":"idb569d5e9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a"},"text":null,"children":[{"tag":"num","attrib":{"value":"1137a"},"text":"§ 1137a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local law enforcement security training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb569d5ea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Homeland Security, in consultation with public and private sector stakeholders, may in a manner consistent with the protection of privacy rights, civil rights, and civil liberties, develop, through the Federal Law Enforcement Training Centers, a training program to enhance the protection, preparedness, and response capabilities of law enforcement agencies with respect to threats of terrorism and other threats, including targeted violence, at a surface transportation asset.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d5eb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of Homeland Security develops the training program described in subsection (a), such training program shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb569d5ec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be informed by current information regarding tactics used by terrorists and others engaging in targeted violence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d5ed-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include tactical instruction tailored to the diverse nature of the surface transportation asset operational environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d5ee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize training officers from law enforcement agencies that are eligible for or receive grants under sections ","children":[{"tag":"ref","attrib":{"idref":"fn002147"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002147"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" 2003 or "},{"tag":"ref","attrib":{"idref":"fn002147"},"text":"1","children":[],"tail":" 2004 of the Homeland Security Act of 2002 ("},{"tag":"ref","attrib":{"href":"/us/usc/t6/s604"},"text":"6 U.S.C. 604","children":[],"tail":" and "},{"tag":"ref","attrib":{"idref":"fn002147"},"text":"1","children":[],"tail":" 605) and officers employed by railroad carriers that operate passenger service, including interstate passenger service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d5ef-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of Homeland Security develops the training program described in subsection (a), not later than one year after the date on which the Secretary first implements the program, and annually thereafter during each year the Secretary carries out the program, the Secretary shall submit to the Committee on Homeland Security of the House of Representatives and the Committee on Homeland Security and Governmental Affairs of the Senate a report on the program. Each such report shall include, for the year covered by the report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb569d5f0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the curriculum for the training and any changes to such curriculum;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d5f1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of any contracts entered into for the development or provision of training under the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d5f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the law enforcement agencies the personnel of which received the training, and for each such agency, the number of participants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d5f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the measures used to ensure the program was carried out to provide for protections of privacy rights, civil rights, and civil liberties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb569d5f4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb569d5f5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “public and private sector stakeholders” has the meaning given such term in section 114(t)(1)(c) ","children":[{"tag":"ref","attrib":{"idref":"fn002148"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002148"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “114(t)(1)(C)”."}],"tail":" of title 49."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d5f6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “surface transportation asset” includes facilities, equipment, or systems used to provide transportation services by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb569d5f7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public transportation agency (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1131/5"},"text":"section 1131(5) of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d5f8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a railroad carrier (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20102/3"},"text":"section 20102(3) of title 49","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d5f9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an owner or operator of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb569d5fa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity offering scheduled, fixed-route transportation services by over-the-road bus (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1151/4"},"text":"section 1151(4) of this title","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb569d5fb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bus terminal; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d5fc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other transportation facilities, equipment, or systems, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d5fd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “targeted violence” means an incident of violence in which an attacker selected a particular target in order to inflict mass injury or death with no discernable political or ideological motivation beyond mass injury or death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb569d5fe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “terrorism” means the terms—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb569d5ff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" domestic terrorism (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2331/5"},"text":"section 2331(5) of title 18","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb569d600-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1137a/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" international terrorism (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2331/1"},"text":"section 2331(1) of title 18","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb569d601-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXIV/s6419"},"text":"Pub. L. 117–81, div. F, title LXIV, § 6419","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2417"},"text":"135 Stat. 2417","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb569d602-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb569d603-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb569d604-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section was enacted as part of the National Defense Authorization Act for Fiscal Year 2022, and not as part of the National Transit Systems Security Act of 2007 which comprises this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
