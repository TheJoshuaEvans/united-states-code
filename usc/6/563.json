{"tag":"section","attrib":{"id":"idb5309d41-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563"},"text":null,"children":[{"tag":"num","attrib":{"value":"563"},"text":"§ 563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 5-year technology investment plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5309d42-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5309d43-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"2014-12-18"},"text":"December 18, 2014","children":[],"tail":", develop and submit to Congress a strategic 5-year technology investment plan, that may include a classified addendum to report sensitive transportation security risks, technology vulnerabilities, or other sensitive security information; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d44-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent possible, publish the Plan in an unclassified format in the public domain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5309d45-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall develop the Plan in consultation with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5309d46-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary for Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d47-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary for Science and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d48-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief Information Officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d49-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aviation industry stakeholder advisory committee established by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5309d4a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator may not publish the Plan under subsection (a)(2) until it has been approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5309d4b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents of Plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Plan shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5309d4c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of transportation security risks and the associated capability gaps that would be best addressed by security-related technology, including consideration of the most recent quadrennial homeland security review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s347"},"text":"section 347 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d4d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a set of security-related technology acquisition needs that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5309d4e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is prioritized based on risk and associated capability gaps identified under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5309d4f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes planned technology programs and projects with defined objectives, goals, timelines, and measures;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d50-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of current and forecast trends in domestic and international passenger travel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d51-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of currently deployed security-related technologies that are at or near the end of their lifecycles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d52-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of test, evaluation, modeling, and simulation capabilities, including target methodologies, rationales, and timelines necessary to support the acquisition of the security-related technologies expected to meet the needs under paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d53-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of opportunities for public-private partnerships, small and disadvantaged company participation, intragovernment collaboration, university centers of excellence, and national laboratory technology transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d54-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the Administration’s acquisition workforce needs for the management of planned security-related technology acquisitions, including consideration of leveraging acquisition expertise of other Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d55-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of the security resources, including information security resources, that will be required to protect security-related technology from physical or cyber theft, diversion, sabotage, or attack;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d56-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of initiatives to streamline the Administration’s acquisition process and provide greater predictability and clarity to small, medium, and large businesses, including the timeline for testing and evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d57-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the impact to commercial aviation passengers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d58-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategy for consulting airport management, air carrier representatives, and Federal security directors whenever an acquisition will lead to the removal of equipment at airports, and how the strategy for consulting with such officials of the relevant airports will address potential negative impacts on commercial passengers or airport operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d59-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/d/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the National Institutes of Standards and Technology, an identification of security-related technology interface standards, in existence or if implemented, that could promote more interoperable passenger, baggage, and cargo screening systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5309d5a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leveraging the private sector","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent possible, and in a manner that is consistent with fair and equitable practices, the Plan shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5309d5b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage emerging technology trends and research and development investment trends within the public and private sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d5c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate private sector input, including from the aviation industry stakeholder advisory committee established by the Administrator, through requests for information, industry days, and other innovative means consistent with the Federal Acquisition Regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d5d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with the Under Secretary for Science and Technology, identify technologies in existence or in development that, with or without adaptation, are expected to be suitable to meeting mission needs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5309d5e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall include with the Plan a list of nongovernment persons that contributed to the writing of the Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5309d5f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Update and report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall, in collaboration with relevant industry and government stakeholders, annually submit to Congress in an appendix to the budget request and publish in an unclassified format in the public domain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5309d60-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an update of the Plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d61-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report on the extent to which each security-related technology acquired by the Administration since the last issuance or update of the Plan is consistent with the planned technology programs and projects identified under subsection (d)(2) for that security-related technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d62-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information about acquisitions completed during the fiscal year preceding the fiscal year during which the report is submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5309d63-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional update requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Updates and reports under subsection (g) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5309d64-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be prepared in consultation with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5309d65-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the persons described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5309d66-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Surface Transportation Security Advisory Committee established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s204"},"text":"section 204 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d67-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5309d68-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information relating to technology investments by the Transportation Security Administration and the private sector that the Department supports with research, development, testing, and evaluation for aviation, including air cargo, and surface transportation security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5309d69-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information about acquisitions completed during the fiscal year preceding the fiscal year during which the report is submitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5309d6a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information relating to equipment of the Transportation Security Administration that is in operation after the end of the life-cycle of the equipment specified by the manufacturer of the equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5309d6b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, a classified addendum to report sensitive transportation security risks and associated capability gaps that would be best addressed by security-related technology described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5309d6c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice of covered changes to plan","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5309d6d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Homeland Security of the House of Representatives notice of any covered change to the Plan not later than 90 days after the date that the covered change is made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5309d6e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of covered change","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the term “covered change” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5309d6f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increase or decrease in the dollar amount allocated to the procurement of a technology; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5309d70-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s563/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an increase or decrease in the number of a technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5309d71-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVI/s1611"},"text":"Pub. L. 107–296, title XVI, § 1611","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/113/245/s3/a"},"text":"Pub. L. 113–245, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2872"},"text":"128 Stat. 2872","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1917"},"text":"Pub. L. 115–254, div. K, title I, § 1917","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3557"},"text":"132 Stat. 3557","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5309d72-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5309d73-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5309d74-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1917/1/A"},"text":"Pub. L. 115–254, § 1917(1)(A)","children":[],"tail":", substituted “The Administrator shall, in collaboration with relevant industry and government stakeholders, annually submit to Congress in an appendix to the budget request and publish in an unclassified format in the public domain—” for “Beginning 2 years after the date the Plan is submitted to Congress under subsection (a), and biennially thereafter, the Administrator shall submit to Congress—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1917/1/B"},"text":"Pub. L. 115–254, § 1917(1)(B)","children":[],"tail":"–(D), added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h), (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1917/2"},"text":"Pub. L. 115–254, § 1917(2)","children":[],"tail":", added subsecs. (h) and (i)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
