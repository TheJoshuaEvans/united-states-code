{"tag":"section","attrib":{"id":"idb5593349-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s722"},"text":null,"children":[{"tag":"num","attrib":{"value":"722"},"text":"§ 722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Urban Search and Rescue Response System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb559334a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is in the Agency a system known as the Urban Search and Rescue Response System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb559334b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated to carry out the system for fiscal year 2008, an amount equal to the amount appropriated for the system for fiscal year 2007 and an additional $20,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb559334c-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s634"},"text":"Pub. L. 109–295, title VI, § 634","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1421"},"text":"120 Stat. 1421","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
