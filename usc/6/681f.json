{"tag":"section","attrib":{"id":"idb556c2f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681f"},"text":null,"children":[{"tag":"num","attrib":{"value":"681f"},"text":"§ 681f.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cyber Incident Reporting Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb556c2f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681f/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility of the Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall lead an intergovernmental Cyber Incident Reporting Council, in consultation with the Director of the Office of Management and Budget, the Attorney General, the National Cyber Director, Sector Risk Management Agencies, and other appropriate Federal agencies, to coordinate, deconflict, and harmonize Federal incident reporting requirements, including those issued through regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb556c2f4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s681f/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in subsection (a) shall be construed to provide any additional regulatory authority to any Federal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb556c2f5-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2246"},"text":"Pub. L. 107–296, title XXII, § 2246","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dY/s103/a/2"},"text":"Pub. L. 117–103, div. Y, § 103(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1054"},"text":"136 Stat. 1054","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
