{"tag":"section","attrib":{"id":"idb5651b58-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104"},"text":null,"children":[{"tag":"num","attrib":{"value":"1104"},"text":"§ 1104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity for reports of suspected terrorist activity or suspicious behavior and response","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5651b59-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity for reports of suspected terrorist activity or suspicious behavior","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5651b5a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person who, in good faith and based on objectively reasonable suspicion, makes, or causes to be made, a voluntary report of covered activity to an authorized official shall be immune from civil liability under Federal, State, and local law for such report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b5b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Paragraph (1) shall not apply to any report that the person knew to be false or was made with reckless disregard for the truth at the time that person made that report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651b5c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity for response","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5651b5d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any authorized official who observes, or receives a report of, covered activity and takes reasonable action in good faith to respond to such activity shall have qualified immunity from civil liability for such action, consistent with applicable law in the relevant jurisdiction. An authorized official as defined by subsection (d)(1)(A) not entitled to assert the defense of qualified immunity shall nevertheless be immune from civil liability under Federal, State, and local law if such authorized official takes reasonable action, in good faith, to respond to the reported activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b5e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Savings clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subsection shall affect the ability of any authorized official to assert any defense, privilege, or immunity that would otherwise be available, and this subsection shall not be construed as affecting any such defense, privilege, or immunity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651b5f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Attorney fees and costs","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any person or authorized official found to be immune from civil liability under this section shall be entitled to recover from the plaintiff all reasonable costs and attorney fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651b60-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5651b61-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorized official","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “authorized official” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5651b62-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee or agent of a passenger transportation system or other person with responsibilities relating to the security of such systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5651b63-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any officer, employee, or agent of the Department of Homeland Security, the Department of Transportation, or the Department of Justice with responsibilities relating to the security of passenger transportation systems; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5651b64-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Federal, State, or local law enforcement officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b65-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Covered activity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered activity” means any suspicious transaction, activity, or occurrence that involves, or is directed against, a passenger transportation system or vehicle or its passengers indicating that an individual may be engaging, or preparing to engage, in a violation of law relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5651b66-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a threat to a passenger transportation system or passenger safety or security; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5651b67-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act of terrorism (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3077"},"text":"section 3077 of title 18","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b68-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Passenger transportation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “passenger transportation” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5651b69-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public transportation, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5302"},"text":"section 5302 of title 49","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5651b6a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over-the-road bus transportation, as defined in subchapter IV, and school bus transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5651b6b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intercity passenger rail ","children":[{"tag":"ref","attrib":{"idref":"fn002137"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002137"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “intercity rail passenger”."}],"tail":" transportation "},{"tag":"ref","attrib":{"idref":"fn002138"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002138"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s24102"},"text":"section 24102 of title 49","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5651b6c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation of passengers onboard a passenger vessel ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s2101"},"text":"section 2101 of title 46","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5651b6d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other regularly scheduled waterborne transportation service of passengers by vessel of at least 20 gross tons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5651b6e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" air transportation, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102"},"text":"section 40102 of title 49","children":[],"tail":", of passengers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b6f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Passenger transportation system","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “passenger transportation system” means an entity or entities organized to provide passenger transportation using vehicles, including the infrastructure used to provide such transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b70-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vehicle","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “vehicle” has the meaning given to that term in section 1992(16) ","children":[{"tag":"ref","attrib":{"idref":"fn002139"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002139"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be section “1992(d)(16)”."}],"tail":" of title 18."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651b71-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"2006-10-01"},"text":"October 1, 2006","children":[],"tail":", and shall apply to all activities and claims occurring on or after such date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5651b72-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXII/s1206"},"text":"Pub. L. 110–53, title XII, § 1206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/388"},"text":"121 Stat. 388","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5651b73-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5651b74-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb5651b75-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter IV, referred to in subsec. (d)(3)(B), was in the original “title XV of this Act”, meaning title XV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53"},"text":"Pub. L. 110–53","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/422"},"text":"121 Stat. 422","children":[],"tail":", which is classified principally to subchapter IV (§ 1151 et seq.) of this chapter. For complete classification of title XV to the Code, see References in Text note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s1151"},"text":"section 1151 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
