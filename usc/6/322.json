{"tag":"section","attrib":{"id":"idb511a34c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322"},"text":null,"children":[{"tag":"num","attrib":{"value":"322"},"text":"§ 322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuity of the economy plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb511a34d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb511a34e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President shall develop and maintain a plan to maintain and restore the economy of the United States in response to a significant event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511a34f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principles","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan required under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb511a350-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be consistent with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb511a351-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a free market economy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a352-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rule of law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a353-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respect private property rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb511a354-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan required under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb511a355-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the distribution of goods and services across the United States necessary for the reliable functioning of the United States during a significant event;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a356-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify the economic functions of relevant actors, the disruption, corruption, or dysfunction of which would have a debilitating effect in the United States on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb511a357-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a358-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a359-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defense readiness; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a35a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health or safety;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a35b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify the critical distribution mechanisms for each economic sector that should be prioritized for operation during a significant event, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb511a35c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bulk power and electric transmission systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a35d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national and international financial systems, including wholesale payments, stocks, and currency exchanges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a35e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" national and international communications networks, data-hosting services, and cloud services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a35f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interstate oil and natural gas pipelines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a360-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mechanisms for the interstate and international trade and distribution of materials, food, and medical supplies, including road, rail, air, and maritime shipping;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a361-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify economic functions of relevant actors, the disruption, corruption, or dysfunction of which would cause—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb511a362-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" catastrophic economic loss;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a363-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the loss of public confidence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a364-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the widespread imperilment of human life;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a365-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the economic functions of relevant actors that are so vital to the economy of the United States that the disruption, corruption, or dysfunction of those economic functions would undermine response, recovery, or mobilization efforts during a significant event;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a366-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate, to the greatest extent practicable, the principles and practices contained within Federal plans for the continuity of Government and continuity of operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a367-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb511a368-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" industrial control networks for which a loss of internet connectivity, a loss of network integrity or availability, an exploitation of a system connected to the network, or another failure, disruption, corruption, or dysfunction would have a debilitating effect in the United States on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb511a369-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/G/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb511a36a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/G/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb511a36b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/G/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defense readiness; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb511a36c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/G/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public health or safety; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a36d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each industrial control network identified under clause (i), risk mitigation measures, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb511a36e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/G/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the installation of parallel services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb511a36f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/G/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of stand-alone analog services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb511a370-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/G/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the significant hardening of the industrial control network against failure, disruption, corruption, or dysfunction;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a371-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify critical economic sectors for which the preservation of data in a protected, verified, and uncorrupted status would be required for the quick recovery of the economy of the United States in the face of a significant disruption following a significant event;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a372-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a list of raw materials, industrial goods, and other items, the absence of which would significantly undermine the ability of the United States to sustain the functions described in subparagraphs (B), (D), and (E);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a373-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an analysis of supply chain diversification for the items described in subparagraph (I) in the event of a disruption caused by a significant event;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a374-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb511a375-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/K/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recommendation as to whether the United States should maintain a strategic reserve of 1 or more of the items described in subparagraph (I); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a376-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/K/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each item described in subparagraph (I) for which the President recommends maintaining a strategic reserve under clause (i), an identification of mechanisms for tracking inventory and availability of the item in the strategic reserve;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a377-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify mechanisms in existence on ","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"January 1, 2021","children":[],"tail":" and mechanisms that can be developed to ensure that the swift transport and delivery of the items described in subparagraph (I) is feasible in the event of a distribution network disturbance or degradation, including a distribution network disturbance or degradation caused by a significant event;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a378-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include guidance for determining the prioritization for the distribution of the items described in subparagraph (I), including distribution to States and Indian Tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a379-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider the advisability and feasibility of mechanisms for extending the credit of the United States or providing other financial support authorized by law to key participants in the economy of the United States if the extension or provision of other financial support—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb511a37a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/N/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to avoid severe economic degradation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb511a37b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/N/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allows for the recovery from a significant event;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a37c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include guidance for determining categories of employees that should be prioritized to continue to work in order to sustain the functions described in subparagraphs (B), (D), and (E) in the event that there are limitations on the ability of individuals to travel to workplaces or to work remotely, including considerations for defense readiness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a37d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify critical economic sectors necessary to provide material and operational support to the defense of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a37e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether the Secretary of Homeland Security, the National Guard, and the Secretary of Defense have adequate authority to assist the United States in a recovery from a severe economic degradation caused by a significant event;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a37f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and assess the authority and capability of heads of other agencies that the President determines necessary to assist the United States in a recovery from a severe economic degradation caused by a significant event; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb511a380-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/a/3/S"},"text":null,"children":[{"tag":"num","attrib":{"value":"S"},"text":"(S)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider any other matter that would aid in protecting and increasing the resilience of the economy of the United States from a significant event.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb511a381-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordinatio