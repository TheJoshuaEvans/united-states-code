{"tag":"num","attrib":{"value":"BB"},"text":"(BB)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designation of any subsectors of such sectors; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb543afbc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/3/B/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recommendations of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afbd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any designation of critical infrastructure sectors shall be published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb543afbe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sector Risk Management Agencies","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb543afbf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afc0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afc1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" References","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any reference to a Sector Specific Agency (including any permutations or conjugations thereof) in any law, regulation, map, document, record, or other paper of the United States shall be deemed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb543afc2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a reference to the Sector Risk Management Agency of the relevant critical infrastructure sector; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543afc3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s650"},"text":"section 650 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afc4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Omitted","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"t