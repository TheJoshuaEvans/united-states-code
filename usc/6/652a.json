hildren":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop recommendations to—","children":[],"tail":null},{"tag":"subitem","attrib":{"id":"idb543afa4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/1/B/i/I/bb/AA"},"text":null,"children":[{"tag":"num","attrib":{"value":"AA"},"text":"(AA)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revise the current list of critical infrastructure sectors designated pursuant to Presidential Policy Directive 21, any successor or related document, or policy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subitem","attrib":{"id":"idb543afa5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/1/B/i/I/bb/BB"},"text":null,"children":[{"tag":"num","attrib":{"value":"BB"},"text":"(BB)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and designate any subsectors of such sectors;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb543afa6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the data, metrics, and other information used to develop the recommendations required under clause (ii); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb543afa7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations relating to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb543afa8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" revising—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idb543afa9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/1/B/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current framework for securing critical infrastructure referred to in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb543afaa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/1/B/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current list of critical infrastructure sectors designated pursuant to Presidential Policy Directive 21, any successor or related document, or policy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb543afab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/1/B/ii/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification and designation of any subsectors of such sectors; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb543afac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any revisions to the list of designated Federal departments or agencies that serve as the Sector Risk Management Agency for a sector or subsector of such section, necessary to comply with paragraph (3)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afad-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Periodic evaluation by the Secretary","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"At least once every five years, the Secretary, in consultation with the Director and the heads of Sector Risk Management Agencies, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb543afae-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the current list of designated critical infrastructure sectors and subsectors of such sectors and the appropriateness of Sector Risk Management Agency designations, as set forth in Presidential Policy Directive 21, any successor or related document, or policy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543afaf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommend, as appropriate, to the President—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb543afb0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revisions to the current list of designated critical infrastructure sectors or subsectors of such sectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb543afb1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revisions to the designation of any Federal department or agency designated as the Sector Risk Management Agency for a sector or subsector of such sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb543afb2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review and revision by the President","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the Secretary submits a recommendation pursuant to paragraph (1) or (2), the President shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb543afb3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the recommendation and revise, as appropriate, the designation of a critical infrastructure sector or subsector or the designation of a Sector Risk Management Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb543afb4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit to the appropriate congressional committees, the Majority and Minority Leaders of the Senate, and the Speaker and Minority Leader of the House of Representatives, a report that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb543afb5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s652a/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation with respect to the basis for accepting or rejecting the recommendations of the Secretary; and","children":[],"tail":"\n"}],"