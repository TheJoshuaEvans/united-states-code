{"tag":"section","attrib":{"id":"idb4fe90cb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s235"},"text":null,"children":[{"tag":"num","attrib":{"value":"235"},"text":"§ 235.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of information and information technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4fe90cc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s235/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of affected agency","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “affected agency” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fe90cd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s235/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fe90ce-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s235/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fe90cf-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s235/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Health and Human Services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fe90d0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s235/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other department or agency determined to be appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fe90d1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s235/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, in coordination with the Secretary of Agriculture, the Secretary of Health and Human Services, and the head of each other department or agency determined to be appropriate by the Secretary, shall ensure that appropriate information (as determined by the Secretary) concerning inspections of articles that are imported or entered into the United States, and are inspected or regulated by 1 or more affected agencies, is timely and efficiently exchanged between the affected agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fe90d2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s235/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report and plan","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", the Secretary, in consultation with the Secretary of Agriculture, the Secretary of Health and Human Services, and the head of each other department or agency determined to be appropriate by the Secretary, shall submit to Congress—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fe90d3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s235/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report on the progress made in implementing this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fe90d4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s235/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan to complete implementation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4fe90d5-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s427"},"text":"Pub. L. 107–296, title IV, § 427","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2187"},"text":"116 Stat. 2187","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
