{"tag":"section","attrib":{"id":"idb537c955-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596"},"text":null,"children":[{"tag":"num","attrib":{"value":"596"},"text":"§ 596.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting and grant making authorities","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Assistant Secretary, in carrying out the responsibilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s592"},"text":"section 592 of this title","children":[],"tail":", shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb537c956-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate extramural and intramural programs and distribute funds through grants, cooperative agreements, and other transactions and contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c957-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that activities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s592"},"text":"section 592 of this title","children":[],"tail":" include investigations of radiation detection equipment in configurations suitable for deployment at seaports, which may include underwater or water surface detection equipment and detection equipment that can be mounted on cranes and straddle cars used to move shipping containers; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb537c958-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s596/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the au