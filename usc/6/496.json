{"tag":"section","attrib":{"id":"idb52be286-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s496"},"text":null,"children":[{"tag":"num","attrib":{"value":"496"},"text":"§ 496.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relation to the National Security Council","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may convene joint meetings of the Homeland Security Council and the National Security Council with participation by members of either Council or as the President may otherwise direct.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb52be287-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIX/s906"},"text":"Pub. L. 107–296, title IX, § 906","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2259"},"text":"116 Stat. 2259","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
