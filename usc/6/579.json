{"tag":"section","attrib":{"id":"idb535577d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579"},"text":null,"children":[{"tag":"num","attrib":{"value":"579"},"text":"§ 579.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interoperable Emergency Communications Grant Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb535577e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall establish the Interoperable Emergency Communications Grant Program to make grants to States to carry out initiatives to improve local, tribal, statewide, regional, national and, where appropriate, international interoperable emergency communications, including communications in collective response to natural disasters, acts of terrorism, and other man-made disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb535577f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Director for Emergency Communications shall ensure that a grant awarded to a State under this section is consistent with the policies established pursuant to the responsibilities and authorities of the Emergency Communications Division under this subchapter, including ensuring that activities funded by the grant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5355780-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with the statewide plan for that State required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s194/f"},"text":"section 194(f) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5355781-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with the National Emergency Communications Plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s572"},"text":"section 572 of this title","children":[],"tail":", when completed."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5355782-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5355783-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Administrator of the Federal Emergency Management Agency shall administer the Interoperable Emergency Communications Grant Program pursuant to the responsibilities and authorities of the Administrator under subchapter V.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5355784-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In administering the grant program, the Administrator shall ensure that the use of grants is consistent with guidance established by the Assistant Director for Emergency Communications pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s194/a/1/H"},"text":"section 194(a)(1)(H) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5355785-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives a grant under this section shall use the grant to implement that State’s Statewide Interoperability Plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s194/f"},"text":"section 194(f) of this title","children":[],"tail":" and approved under subsection (e), and to assist with activities determined by the Secretary to be integral to interoperable emergency communications."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5355786-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of plans","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5355787-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval as condition of grant","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before a State may receive a grant under this section, the Assistant Director for Emergency Communications shall approve the State’s Statewide Interoperable Communications Plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s194/f"},"text":"section 194(f) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5355788-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plan requirements","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In approving a plan under this subsection, the Assistant Director for Emergency Communications shall ensure that the plan—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5355789-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed to improve interoperability at the city, county, regional, State and interstate level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb535578a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considers any applicable local or regional plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb535578b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies, to the maximum extent practicable, with the National Emergency Communications Plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s572"},"text":"section 572 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb535578c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of revisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Assistant Director for Emergency Communications may approve revisions to a State’s plan if the Assistant Director determines that doing so is likely to further interoperability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb535578d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on uses of funds","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb535578e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The recipient of a grant under this section may not use the grant—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb535578f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to supplant State or local funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5355790-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any State or local government cost-sharing contribution; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5355791-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for recreational or social purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5355792-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In addition to other remedies currently available, the Secretary may take such actions as necessary to ensure that recipients of grant funds are using the funds for the purpose for which they were intended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5355793-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on award of grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5355794-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National emergency communications plan required","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not award a grant under this section before the date on which the Secretary completes and submits to Congress the National Emergency Communications Plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s572"},"text":"section 572 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5355795-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary consensus standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not award a grant to a State under this section for the purchase of equipment that does not meet applicable voluntary consensus standards, unless the State demonstrates that there are compelling reasons for such purchase.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5355796-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award of grants","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In approving applications and awarding grants under this section, the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5355797-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the risk posed to each State by natural disasters, acts of terrorism, or other manmade disasters, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5355798-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likely need of a jurisdiction within the State to respond to such risk in nearby jurisdictions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5355799-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree of threat, vulnerability, and consequences related to critical infrastructure (from all critical infrastructure sectors) or key resources identified by the Administrator or the State homeland security and emergency management plans, including threats to, vulnerabilities of, and consequences from damage to critical infrastructure and key resources in nearby jurisdictions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb535579a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/h/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the size of the population and density of the population of the State, including appropriate consideration of military, tourist, and commuter populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb535579b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/h/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the State is on or near an international border;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb535579c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/h/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the State encompasses an economically significant border crossing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb535579d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/h/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the State has a coastline bordering an ocean, a major waterway used for interstate commerce, or international waters; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb535579e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated effectiveness of the State’s proposed use of grant funds to improve interoperability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb535579f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Opportunity to amend applications","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In considering applications for grants under this section, the Administrator shall provide applicants with a reasonable opportunity to correct defects in the application, if any, before making final awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53557a0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum grant amounts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53557a1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" States","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall ensure that for each fiscal year, except as provided in paragraph (2), no State receives a grant in an amount that is less than the following percentage of the total amount appropriated for grants under this section for that fiscal year:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53557a2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2008, 0.50 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53557a3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2009, 0.50 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53557a4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/j/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2010, 0.45 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53557a5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/j/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2011, 0.40 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53557a6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/j/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For fiscal year 2012 and each subsequent fiscal year, 0.35 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557a7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Territories and possessions","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In awarding grants under this section, the Secretary shall ensure that for each fiscal year, American Samoa, the Commonwealth of the Northern Mariana Islands, Guam, and the Virgin Islands each receive grants in amounts that are not less than 0.08 percent of the total amount appropriated for grants under this section for that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53557a8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each State that receives a grant under this section shall certify that the grant is used for the purpose for which the funds were intended and in compliance with the State’s approved Statewide Interoperable Communications Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53557a9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53557aa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds to local and tribal governments","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 45 days after receiving grant funds, any State that receives a grant under this section shall obligate or otherwise make available to local and tribal governments—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb53557ab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/l/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 80 percent of the grant funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53557ac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/l/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the consent of local and tribal governments, eligible expenditures having a value of not less than 80 percent of the amount of the grant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb53557ad-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/l/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant funds combined with other eligible expenditures having a total value of not less than 80 percent of the amount of the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557ae-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allocation of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives a grant under this section shall allocate grant funds to tribal governments in the State to assist tribal communities in improving interoperable communications, in a manner consistent with the Statewide Interoperable Communications Plan. A State may not impose unreasonable or unduly burdensome requirements on a tribal government as a condition of providing grant funds or resources to the tribal government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557af-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"If a State violates the requirements of this subsection, in addition to other remedies available to the Secretary, the Secretary may terminate or reduce the amount of the grant awarded to that State or transfer grant funds previously awarded to the State directly to the appropriate local or tribal government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53557b0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53557b1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/m/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports by State grant recipients","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A State that receives a grant under this section shall annually submit to the Assistant Director for Emergency Communications a report on the progress of the State in implementing that State’s Statewide Interoperable Communications Plans required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s194/f"},"text":"section 194(f) of this title","children":[],"tail":" and achieving interoperability at the city, county, regional, State, and interstate levels. The Assistant Director shall make the reports publicly available, including by making them available on the Internet website of the Cybersecurity and Infrastructure Security Agency, subject to any redactions that the Assistant Director determines are necessary to protect classified or other sensitive information."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557b2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/m/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At least once each year, the Assistant Director for Emergency Communications shall submit to Congress a report on the use of grants awarded under this section and any progress in implementing Statewide Interoperable Communications Plans and improving interoperability at the city, county, regional, State, and interstate level, as a result of the award of such grants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53557b3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this section shall be construed or interpreted to preclude a State from using a grant awarded under this section for interim or long-term Internet Protocol-based interoperable solutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb53557b4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/o"},"text":null,"children":[{"tag":"num","attrib":{"value":"o"},"text":"(o)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated for grants under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb53557b5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/o/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for fiscal year 2008, such sums as may be necessary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557b6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/o/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each of fiscal years 2009 through 2012, $400,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb53557b7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s579/o/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each subsequent fiscal year, such sums as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb53557b8-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVIII/s1809"},"text":"Pub. L. 107–296, title XVIII, § 1809","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tIII/s301/a"},"text":"Pub. L. 110–53, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/296"},"text":"121 Stat. 296","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/6/C"},"text":"Pub. L. 115–278, § 2(g)(6)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4179"},"text":"132 Stat. 4179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb53557b9-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb53557ba-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb53557bb-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/6/C/i"},"text":"Pub. L. 115–278, § 2(g)(6)(C)(i)","children":[],"tail":", substituted “Assistant Director for Emergency Communications” for “Director of Emergency Communications” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/6/C/ii"},"text":"Pub. L. 115–278, § 2(g)(6)(C)(ii)","children":[],"tail":", substituted “Assistant Director for Emergency Communications” for “Director for Emergency Communications” and “Emergency Communications Division” for “Office of Emergency Communications” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/6/C/iii"},"text":"Pub. L. 115–278, § 2(g)(6)(C)(iii)","children":[],"tail":", substituted “the Assistant Director” for “the Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (m)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/6/C/iv"},"text":"Pub. L. 115–278, § 2(g)(6)(C)(iv)","children":[],"tail":", substituted “The Assistant Director” for “the Director”, “Cybersecurity and Infrastructure Security Agency” for “Office of Emergency Communications”, and “the Assistant Director determines” for “the Director determines”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb53557bc-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb53557bd-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Assistant Director for Emergency Communications deemed to be a reference to the Executive Assistant Director for Emergency Communications, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s571/g"},"text":"section 571(g) of this title","children":[],"tail":", enacted "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
