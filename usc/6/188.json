{"tag":"section","attrib":{"id":"idb4eb7de7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188"},"text":null,"children":[{"tag":"num","attrib":{"value":"188"},"text":"§ 188.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conduct of research, development, demonstration, testing and evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4eb7de8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Under Secretary for Science and Technology, shall carry out the responsibilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s182/4"},"text":"section 182(4) of this title","children":[],"tail":" through both extramural and intramural programs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4eb7de9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Extramural programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4eb7dea-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Under Secretary for Science and Technology, shall operate extramural research, development, demonstration, testing, and evaluation programs so as to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4eb7deb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that colleges, universities, private research institutes, and companies (and consortia thereof) from as many areas of the United States as practicable participate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4eb7dec-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the research funded is of high quality, as determined through merit review processes developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s182/14"},"text":"section 182(14) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4eb7ded-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distribute funds through grants, cooperative agreements, and contracts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4eb7dee-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" University-based centers for homeland security","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4eb7def-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Under Secretary for Science and Technology, shall designate a university-based center or several university-based centers for homeland security. The purpose of the center or these centers shall be to establish a coordinated, university-based system to enhance the Nation’s homeland security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4eb7df0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for designation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Criteria for the designation of colleges or universities as a center for homeland security, shall include, but are not limited to, demonstrated expertise in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4eb7df1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The training of first responders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7df2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Responding to incidents involving weapons of mass destruction and biological warfare.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7df3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency and diagnostic medical services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7df4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chemical, biological, radiological, and nuclear countermeasures or detection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7df5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Animal and plant health and diagnostics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7df6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Food safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7df7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Water and wastewater operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7df8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Port and waterway security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7df9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Multi-modal transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7dfa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information security and information engineering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7dfb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Engineering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7dfc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Educational outreach and technical assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7dfd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B/xiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiii"},"text":"(xiii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Border transportation and security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7dfe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/B/xiv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiv"},"text":"(xiv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The public policy implications and public dissemination of homeland security related research and development.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4eb7dff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discretion of Secretary","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To the extent that exercising such discretion is in the interest of homeland security, and with respect to the designation of any given university-based center for homeland security, the Secretary may except certain criteria as specified in subparagraph (B) and consider additional criteria beyond those specified in subparagraph (B). Upon designation of a university-based center for homeland security, the Secretary shall that day publish in the Federal Register the criteria that were excepted or added in the selection process and the justification for the set of criteria that were used for that designation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4eb7e00-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Report to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary shall report annually, from the date of enactment, to Congress concerning the implementation of this section. That report shall indicate which center or centers have been designated and how the designation or designations enhance homeland security, as well as report any decisions to revoke or modify such designations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4eb7e01-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4eb7e02-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intramural programs","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4eb7e03-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out the duties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s182"},"text":"section 182 of this title","children":[],"tail":", the Secretary, acting through the Under Secretary for Science and Technology, may draw upon the expertise of any laboratory of the Federal Government, whether operated by a contractor or the Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4eb7e04-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Laboratories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Under Secretary for Science and Technology, may establish a headquarters laboratory for the Department at any laboratory or site and may establish additional laboratory units at other laboratories or sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4eb7e05-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for headquarters laboratory","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary chooses to establish a headquarters laboratory pursuant to paragraph (2), then the Secretary shall do the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4eb7e06-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establish criteria for the selection of the headquarters laboratory in consultation with the National Academy of Sciences, appropriate Federal agencies, and other experts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4eb7e07-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Publish the criteria in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4eb7e08-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluate all appropriate laboratories or sites against the criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4eb7e09-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Select a laboratory or site on the basis of the criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4eb7e0a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Report to the appropriate congressional committees on which laboratory was selected, how the selected laboratory meets the published criteria, and what duties the headquarters laboratory shall perform.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4eb7e0b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on operation of laboratories","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"No laboratory shall begin operating as the headquarters laboratory of the Department until at least 30 days after the transmittal of the report required by paragraph (3)(E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4eb7e0c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference for United States industry","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4eb7e0d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4eb7e0e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Country of concern","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “country of concern” means a country that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4eb7e0f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a covered nation, as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s4872/d"},"text":"section 4872(d) of title 10","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7e10-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines is engaged in conduct that is detrimental to the national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4eb7e11-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonprofit organization; small business firm; subject invention","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The terms “nonprofit organization”, “small business firm”, and “subject invention” have the meanings given such terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t35/s201"},"text":"section 201 of title 35","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4eb7e12-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufactured substantially in the United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “manufactured substantially in the United States” means an item is a domestic end product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4eb7e13-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic end product","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “domestic end product” has the meaning given such term in section 25.003 of title 48, Code of Federal Regulations, or any successor thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4eb7e14-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002023"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002023"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. There is no par. (2)."}],"tail":" Waivers"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb4eb7e15-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subparagraph (B), in individual cases, the requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t35/s204"},"text":"section 204 of title 35","children":[],"tail":" may be waived by the Secretary upon a showing by the small business firm, nonprofit organization, or assignee that reasonable but unsuccessful efforts have been made to grant licenses on similar terms to potential licensees that would be likely to manufacture substantially in the United States or that under the circumstances domestic manufacture is not commercially feasible."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb4eb7e16-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Conditions on waivers granted by Department","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb4eb7e17-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Before grant of waiver","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Before granting a waiver under subparagraph (A), the Secretary shall comply with the procedures developed and implemented by the Department pursuant to section 70923(b)(2) of the Build America, Buy America Act (enacted as subtitle A of title IX of division G of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Public Law 117–58","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb4eb7e18-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s188/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on granting certain waivers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary may not grant a waiver under subparagraph (A) if, as a result of such waiver, products embodying the applicable subject invention, or produced through the use of the applicable subject invention, would be manufactured substantially in a country of concern.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb4eb7e19-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIII/s308"},"text":"Pub. L. 107–296, title III, § 308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2170"},"text":"116 Stat. 2170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dL/s101/1"},"text":"Pub. L. 108–7, div. L, § 101(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/526"},"text":"117 Stat. 526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7114"},"text":"Pub. L. 117–263, div. G, title LXXI, § 7114","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3633"},"text":"136 Stat. 3633","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb4eb7e1a-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb4eb7e1b-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb4eb7e1c-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment, referred to in subsec. (b)(2)(D), probably means the date of enactment of this section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 70923(b)(2) of the Build America, Buy America Act, referred to in subsec. (d)(3)(B)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s70923/b/2"},"text":"section 70923(b)(2) of Pub. L. 117–58","children":[],"tail":", div. G, title IX, "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1306"},"text":"135 Stat. 1306","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb4eb7e1d-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsecs. (a) to (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" added subsecs. (a) to (c)(1) and struck out former subsecs. (a) to (c)(1) which related to the responsibilities of the Secretary, acting through the Under Secretary for Science and Technology, to carry out the responsibilities under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s182/4"},"text":"section 182(4) of this title","children":[],"tail":" through both extramural and intramural programs, to operate extramural research, development, demonstration, testing, and evaluation programs, to establish a coordinated, university-based system to enhance the Nation’s homeland security, and to draw upon the expertise of any laboratory of the Federal Government."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
