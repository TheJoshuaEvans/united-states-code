{"tag":"section","attrib":{"id":"idb55451a3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a"},"text":null,"children":[{"tag":"num","attrib":{"value":"677a"},"text":"§ 677a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this part:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb55451a4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asset response activity","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “asset response activity” means an activity to support an entity impacted by an incident with the response to, remediation of, or recovery from, the incident, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55451a5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnishing technical and advisory assistance to the entity to protect the assets of the entity, mitigate vulnerabilities, and reduce the related impacts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451a6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing potential risks to the critical infrastructure sector or geographic region impacted by the incident, including potential cascading effects of the incident on other critical infrastructure sectors or geographic regions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451a7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing courses of action to mitigate the risks assessed under subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451a8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitating information sharing and operational coordination with entities performing threat response activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451a9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing guidance on how best to use Federal resources and capabilities in a timely, effective manner to speed recovery from the incident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451aa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Declaration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “declaration” means a declaration of the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s677b/a/1"},"text":"section 677b(a)(1) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451ab-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Director” means the Director of the Cybersecurity and Infrastructure Security Agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451ac-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Federal agency” has the meaning given the term “agency” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3502"},"text":"section 3502 of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451ad-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “Fund” means the Cyber Response and Recovery Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s677c/a"},"text":"section 677c(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451ae-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incident","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “incident” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3552"},"text":"section 3552 of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451af-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Renewal","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The term “renewal” means a renewal of a declaration under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s677b/d"},"text":"section 677b(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb55451b0-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Significant incident","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “significant incident”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb55451b1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means an incident or a group of related incidents that results, or is likely to result, in demonstrable harm to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55451b2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national security interests, foreign relations, or economy of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55451b3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public confidence, civil liberties, or public health and safety of the people of the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb55451b4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include an incident or a portion of a group of related incidents that occurs on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb55451b5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national security system (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3552"},"text":"section 3552 of title 44","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb55451b6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s677a/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an information system described in paragraph (2) or (3) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3553/e"},"text":"section 3553(e) of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb55451b7-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2232"},"text":"Pub. L. 107–296, title XXII, § 2232","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dG/tVI/s70602/a"},"text":"Pub. L. 117–58, div. G, title VI, § 70602(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1267"},"text":"135 Stat. 1267","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
