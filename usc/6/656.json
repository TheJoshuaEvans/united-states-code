{"tag":"section","attrib":{"id":"idb5462101-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s656"},"text":null,"children":[{"tag":"num","attrib":{"value":"656"},"text":"§ 656.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" NET Guard","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Cybersecurity and Infrastructure Security Agency may establish a national technology guard, to be known as “NET Guard”, comprised of local teams of volunteers with expertise in relevant areas of science and technology, to assist local communities to respond and recover from attacks on information systems and communications networks.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb5462102-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2206"},"text":"Pub. L. 107–296, title XXII, § 2206","children":[],"tail":", formerly title II, § 224, "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2156"},"text":"116 Stat. 2156","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tV/s531/b/1/B"},"text":"Pub. L. 110–53, title V, § 531(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/334"},"text":"121 Stat. 334","children":[],"tail":"; renumbered title XXII, § 2206, and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/278/s2/g/2/I"},"text":"Pub. L. 115–278, § 2(g)(2)(I)","children":[],"tail":", (9)(A)(ii), "},{"tag":"date","attrib":{"date":"2018-11-16"},"text":"Nov. 16, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4178"},"text":"132 Stat. 4178","children":[],"tail":", 4180; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dG/tLXXI/s7143/c/7