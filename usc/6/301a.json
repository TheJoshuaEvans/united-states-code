{"tag":"section","attrib":{"id":"idb50806f1-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a"},"text":null,"children":[{"tag":"num","attrib":{"value":"301a"},"text":"§ 301a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Port of entry donation authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb50806f2-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personal property donation authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50806f3-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner of U.S. Customs and Border Protection, in consultation with the Administrator of General Services, may enter into an agreement with any entity to accept a donation of personal property, money, or nonpersonal services for the uses described in paragraph (3) only with respect to the following locations at which U.S. Customs and Border Protection performs or will be performing inspection services:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50806f4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A new or existing sea or air port of entry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50806f5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An existing Federal Government-owned or -leased land port of entry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50806f6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A new Federal Government-owned or -leased land port of entry if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb50806f7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the donation is $75,000,000 or less; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb50806f8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of donations with respect to the land port of entry total $75,000,000 or less over the preceding five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50806f9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on monetary donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Any monetary donation accepted pursuant to this subsection may not be used to pay the salaries of U.S. Customs and Border Protection employees performing inspection services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb50806fa-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Donations accepted pursuant to this subsection may be used for activities of the Office of Field Operations set forth in subparagraphs (A) through (F) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s211/g/3"},"text":"section 211(g)(3) of this title","children":[],"tail":", which are related to a new or existing sea or air port of entry or a new or existing Federal Government-owned or -leased land port of entry described in paragraph (1), including expenses related to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50806fb-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furniture, fixtures, equipment, or technology, including the installation or deployment of such items; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb50806fc-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation and maintenance of such furniture, fixtures, equipment, or technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb50806fd-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Real property donation authority","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb50806fe-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (3), the Commissioner of U.S. Customs and Border Protection, and the Administrator of General Services, as applicable, may enter into an agreement with any entity to accept a donation of real property or money for uses described in paragraph (2) only with respect to the following locations at which U.S. Customs and Border Protection performs or will be performing inspection services:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb50806ff-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A new or existing sea or air port of entry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5080700-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An existing Federal Government-owned land port of entry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5080701-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A new Federal Government-owned land port of entry if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5080702-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of the donation is $75,000,000 or less; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5080703-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fair market value of donations with respect to the land port of entry total $75,000,000 or less over the preceding five years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080704-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Donations accepted pursuant to this subsection may be used for activities of the Office of Field Operations set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s211/g"},"text":"section 211(g) of this title","children":[],"tail":", which are related to the construction, alteration, operation, or maintenance of a new or existing sea or air port of entry or a new or existing a "},{"tag":"ref","attrib":{"idref":"fn002048"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002048"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" Federal Government-owned land port of entry described in paragraph (1), including expenses related to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5080705-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" land acquisition, design, construction, repair, or alteration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5080706-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation and maintenance of such port of entry facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080707-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on real property donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A donation of real property under this subsection at an existing land port of entry owned by the General Services Administration may only be accepted by the Administrator of General Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080708-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sunset","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5080709-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The authority to enter into an agreement under this subsection shall terminate on ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb508070a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The termination date referred to in subparagraph (A) shall not apply to a proposal accepted for consideration by U.S. Customs and Border Protection or the General Services Administration pursuant to this section or a prior pilot program prior to such termination date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb508070b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General provisions","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb508070c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"An agreement entered into under subsection (a) or (b) (and, in the case of such subsection (b), in accordance with paragraph (4) of such subsection) may last as long as required to meet the terms of such agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb508070d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out an agreement entered into under subsection (a) or (b), the Commissioner of U.S. Customs and Border Protection, in consultation with the Administrator of General Services, shall establish criteria regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb508070e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the selection and evaluation of donors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb508070f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification of roles and responsibilities between U.S. Customs and Border Protection, the General Services Administration, and donors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5080710-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification, allocation, and management of explicit and implicit risks of partnering between the Federal Government and donors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5080711-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decision-making and dispute resolution processes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5080712-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processes for U.S. Customs and Border Protection, and the General Services Administration, as applicable, to terminate agreements if selected donors are not meeting the terms of any such agreement, including the security standards established by U.S. Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080713-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation procedures","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5080714-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner of U.S. Customs and Border Protection, in consultation with the Administrator of General Services, as applicable, shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5080715-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish criteria for evaluating a proposal to enter into an agreement under subsection (a) or (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5080716-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make such criteria publicly available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5080717-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Considerations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Criteria established pursuant to subparagraph (A) shall consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5080718-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of a proposal referred to in such subparagraph on the land, sea, or air port of entry at issue and other ports of entry or similar facilities or other infrastructure near the location of the proposed donation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5080719-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such proposal’s potential to increase trade and travel efficiency through added capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb508071a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such proposal’s potential to enhance the security of the port of entry at issue;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb508071b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of the proposal on reducing wait times at that port of entry or facility and other ports of entry on the same border;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb508071c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a donation under subsection (b)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb508071d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether such donation satisfies the requirements of such proposal, or whether additional real property would be required; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb508071e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how such donation was acquired, including if eminent domain was used;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb508071f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding available to complete the intended use of such donation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5080720-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of maintaining and operating such donation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5080721-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of such proposal on U.S. Customs and Border Protection staffing requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5080722-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors that the Commissioner or Administrator determines to be relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5080723-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination and notification","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb5080724-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incomplete proposals","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb5080725-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/C/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 60 days after receiving the proposals for a donation agreement from an entity, the Commissioner of U.S. Customs and Border Protection shall notify such entity as to whether such proposal is complete or incomplete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb5080726-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/C/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resubmission","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Commissioner of U.S. Customs and Border Protection determines that a proposal is incomplete, the Commissioner shall—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idb5080727-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/C/i/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the appropriate entity and provide such entity with a description of all information or material that is needed to complete review of the proposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idb5080728-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/C/i/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the entity to resubmit the proposal with additional information and material described in item (aa) to complete the proposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5080729-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complete proposals","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after receiving a completed proposal to enter into an agreement under subsection (a) or (b), the Commissioner of U.S. Customs and Border Protection, with the concurrence of the Administrator of General Services, as applicable, shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb508072a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether to approve or deny such proposal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb508072b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/3/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the entity that submitted such proposal of such determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb508072c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental funding","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3307"},"text":"section 3307 of title 40","children":[],"tail":", real property donations to the Administrator of General Services made pursuant to subsection "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (a) and "},{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" (b) at a GSA-owned land port of entry may be used in addition to any other funding for such purpose, including appropriated funds, property, or services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb508072d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Return of donations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Commissioner of U.S. Customs and Border Protection, or the Administrator of General Services, as applicable, may return any donation made pursuant to subsection (a) or (b). No interest shall be owed to the donor with respect to any donation provided under such subsections that is returned pursuant to this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb508072e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on certain funding","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb508072f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as provided in subsections (a) and (b) regarding the acceptance of donations, the Commissioner of U.S. Customs and Border Protection and the Administrator of General Services, as applicable, may not, with respect to an agreement entered into under either of such subsections, obligate or expend amounts in excess of amounts that have been appropriated pursuant to any appropriations Act for purposes specified in either of such subsections or otherwise made available for any of such purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5080730-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification requirement","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before accepting any donations pursuant to an agreement under subsection (a) or (b), the Commissioner of U.S. Customs and Border Protection shall certify to the congressional committees set forth in paragraph (7) that ","children":[{"tag":"ref","attrib":{"idref":"fn002049"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002049"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by a dash."}],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idb5080731-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/6/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the donation will not be used for the construction of a detention facility or a border fence or wall; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb5080732-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/6/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the donor will be notified in the Donations Acceptance Agreement that the donor shall be financially responsible for all costs and operating expenses related to the operation, maintenance, and repair of the donated real property until such time as U.S. Customs and Border Protection provides the donor written notice otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080733-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commissioner of U.S. Customs and Border Protection, in collaboration with the Administrator of General Services, as applicable, shall submit an annual report identifying the activities undertaken and agreements entered into pursuant to subsections (a) and (b) to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5080734-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5080735-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Environment and Public Works of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5080736-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Finance of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5080737-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5080738-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on the Judiciary of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5080739-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/7/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb508073a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/7/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb508073b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/7/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on the Judiciary of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb508073c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/7/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb508073d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/c/7/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Ways and Means of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb508073e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" GAO report","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General of the United States shall submit an ","children":[{"tag":"ref","attrib":{"idref":"fn002050"},"text":"3","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002050"},"text":null,"children":[{"tag":"num","attrib":{},"text":"3","children":[],"tail":" So in original. Probably should be “a”."}],"tail":" biennial report to the congressional committees referred to in subsection (c)(7) that evaluates—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb508073f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fee agreements entered into pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s301"},"text":"section 301 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080740-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" donation agreements entered into pursuant to subsections (a) and (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5080741-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fees and donations received by U.S. Customs and Border Protection pursuant to such agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5080742-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Decisions of the Commissioner of U.S. Customs and Border Protection and the Administrator of General Services under this section regarding the acceptance of real or personal property are in the discretion of the Commissioner and the Administrator and are not subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5080743-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s301a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rule of construction","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided in this section, nothing in this section may be construed as affecting in any manner the responsibilities, duties, or authorities of U.S. Customs and Border Protection or the General Services Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5080744-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s482"},"text":"Pub. L. 107–296, title IV, § 482","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/114/279/s2/a"},"text":"Pub. L. 114–279, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1417"},"text":"130 Stat. 1417","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dO/tIII/s301"},"text":"Pub. L. 116–260, div. O, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2149"},"text":"134 Stat. 2149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXIV/s6410"},"text":"Pub. L. 117–81, div. F, title LXIV, § 6410","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2408"},"text":"135 Stat. 2408","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb5080745-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb5080746-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb5080747-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6410/1/A/i"},"text":"Pub. L. 117–81, § 6410(1)(A)(i)","children":[],"tail":", (ii)(I), inserted “or -leased” before “land”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6410/1/A/ii/II"},"text":"Pub. L. 117–81, § 6410(1)(A)(ii)(II)","children":[],"tail":", substituted “$75,000,000” for “$50,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6410/1/A/ii/III"},"text":"Pub. L. 117–81, § 6410(1)(A)(ii)(III)","children":[],"tail":", amended cl. (ii) generally. Prior to amendment, text read as follows: “the fair market value, including any personal and real property donations in total, of such port of entry when completed, is $50,000,000 or less.”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6410/1/B"},"text":"Pub. L. 117–81, § 6410(1)(B)","children":[],"tail":", inserted “or -leased” before “land” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6410/2/A"},"text":"Pub. L. 117–81, § 6410(2)(A)","children":[],"tail":", which directed substitution of “Administrator of General Services” for “Administrator of the General Services Administration” in the matter preceding par. (1), was executed in par. (1) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6410/2/B/i"},"text":"Pub. L. 117–81, § 6410(2)(B)(i)","children":[],"tail":", substituted “$75,000,000” for “$50,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6410/2/b/ii"},"text":"Pub. L. 117–81, § 6410(2)(b)(ii)","children":[],"tail":", amended cl. (ii) genrally. Prior to amendment, text read as follows: “the fair market value, including any personal and real property donations in total, of such port of entry when completed, is $50,000,000 or less.”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6410/2/C/i"},"text":"Pub. L. 117–81, § 6410(2)(C)(i)","children":[],"tail":", substituted “terminate on "},{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":".” for “terminate on the date that is "},{"tag":"date","attrib":{"date":"2021-12-16"},"text":"December 16, 2021","children":[],"tail":".”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6410/2/C/ii"},"text":"Pub. L. 117–81, § 6410(2)(C)(ii)","children":[],"tail":", substituted “a proposal accepted for consideration by U.S. Customs and Border Protection or the General Services Administration pursuant to this section or a prior pilot program prior to such termination date” for “carrying out the terms of an agreement under this subsection if such agreement is entered into before such termination date”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6410/3"},"text":"Pub. L. 117–81, § 6410(3)","children":[],"tail":", substituted cls. (i) and (ii) for “the donation will not be used for the construction of a detention facility or a border fence or wall.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6401/4"},"text":"Pub. L. 117–81, § 6401(4)","children":[],"tail":", substituted “biennial” for “annual” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6410/d"},"text":"Pub. L. 117–81, § 6410(d)","children":[],"tail":", substituted “Administrator of General Services” for “Administrator of the General Services Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", which directed substitution of “"},{"tag":"date","attrib":{"date":"2021-12-16"},"text":"December 16, 2021","children":[],"tail":"” for “4 years after "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"”, was executed by making the substitution for original text reading “4 years after the date of the enactment of this section”, which had been translated as “4 years after "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"December 16, 2016","children":[],"tail":"”, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
