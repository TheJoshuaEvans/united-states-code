{"tag":"section","attrib":{"id":"idb4fe916d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242"},"text":null,"children":[{"tag":"num","attrib":{"value":"242"},"text":"§ 242.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Homeland Security Blue Campaign","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb4fe916e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In this section, the term “human trafficking” means an act or practice described in paragraph (9) or (10) ","children":[{"tag":"ref","attrib":{"idref":"fn002041"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002041"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of title 22","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fe916f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"There is established within the Department a program, which shall be known as the “Blue Campaign”. The Blue Campaign shall be headed by a Director, who shall be appointed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fe9170-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The purpose of the Blue Campaign shall be to unify and coordinate Department efforts to address human trafficking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fe9171-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, working through the Director, shall, in accordance with subsection (e)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fe9172-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue Department-wide guidance to appropriate Department personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fe9173-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop training programs for such personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fe9174-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate departmental efforts, including training for such personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb4fe9175-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance and training on trauma-informed practices to ensure that human trafficking victims are afforded prompt access to victim support service providers, in addition to the assistance required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7105"},"text":"section 7105 of title 22","children":[],"tail":", to address their immediate and long-term needs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb4fe9176-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Guidance and training","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Blue Campaign shall provide guidance and training to Department personnel and other Federal, State, tribal, and law enforcement personnel, as appropriate, regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb4fe9177-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs to help identify instances of human trafficking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500da68-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of information that should be collected and recorded in information technology systems utilized by the Department to help identify individuals suspected or convicted of human trafficking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500da69-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" systematic and routine information sharing within the Department and among Federal, State, tribal, and local law enforcement agencies regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb500da6a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals suspected or convicted of human trafficking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500da6b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patterns and practices of human trafficking;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500da6c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" techniques to identify suspected victims of trafficking along the United States border and at airport security checkpoints;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500da6d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" methods to be used by the Transportation Security Administration and personnel from other appropriate agencies to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb500da6e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" train employees of the Transportation Security Administration to identify suspected victims of trafficking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500da6f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a liaison and resource regarding human trafficking prevention to appropriate State, local, and private sector aviation workers and the traveling public;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500da70-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" developing and utilizing, in consultation with the Blue Campaign Advisory Board established pursuant to subsection (g), resources such as indicator cards, fact sheets, pamphlets, posters, brochures, and radio and television campaigns to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb500da71-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educate partners and stakeholders; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500da72-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase public awareness of human trafficking;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500da73-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leveraging partnerships with State and local governmental, nongovernmental, and private sector organizations to raise public awareness of human trafficking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500da74-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/e/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other activities the Secretary determines necessary to carry out the Blue Campaign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb500da75-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Web-based training programs","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To enhance training opportunities, the Director of the Blue Campaign shall develop web-based interactive training videos that utilize a learning management system to provide online training opportunities. During the 10-year period beginning on the date that is 90 days after ","children":[{"tag":"date","attrib":{"date":"2021-12-27"},"text":"December 27, 2021","children":[],"tail":", such training opportunities shall be made available to the following individuals:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb500da76-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal, State, local, Tribal, and territorial law enforcement officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500da77-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Non-Federal correction system personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500da78-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other individuals as the Director determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb500da79-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Blue Campaign Advisory Board","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb500da7a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established in the Department a Blue Campaign Advisory Board, which shall be comprised of representatives assigned by the Secretary from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb500da7b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office for Civil Rights and Civil Liberties of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500da7c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Privacy Office of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500da7d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not fewer than four other separate components or offices of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500da7e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Charter","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to issue a charter for the Blue Campaign Advisory Board, and such charter shall specify the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb500da7f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board’s mission, goals, and scope of its activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500da80-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The duties of the Board’s representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500da81-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The frequency of the Board’s meetings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb500da82-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall consult the Blue Campaign Advisory Board and, as appropriate, experts from other components and offices of the Center for Countering Human Trafficking of the Department regarding the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb500da83-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recruitment tactics used by human traffickers to inform the development of training and materials by the Blue Campaign.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500da84-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The development of effective awareness tools for distribution to Federal and non-Federal officials to identify and prevent instances of human trafficking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb500da85-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/g/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Identification of additional persons or entities that may be uniquely positioned to recognize signs of human trafficking and the development of materials for such persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb500da86-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s242/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"With regard to the development of programs under the Blue Campaign and the implementation of such programs, the Director is authorized to consult with State, local, Tribal, and territorial agencies, non-governmental organizations, private sector organizations, and experts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb500da87-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s434"},"text":"Pub. L. 107–296, title IV, § 434","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/115/125/s2/a"},"text":"Pub. L. 115–125, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-14"},"text":"Feb. 14, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/315"},"text":"132 Stat. 315","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dF/tLXIV/s6407"},"text":"Pub. L. 117–81, div. F, title LXIV, § 6407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2403"},"text":"135 Stat. 2403","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb500da88-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb500da89-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb500da8a-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Paragraphs (9) and (10) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of title 22","children":[],"tail":", referred to in subsec. (a), were redesignated pars. (11) and (12), respectively, of "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"section 7102 of title 22","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/427/s2/1"},"text":"Pub. L. 115–427, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5503"},"text":"132 Stat. 5503","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb500da8b-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (e)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6407/1"},"text":"Pub. L. 117–81, § 6407(1)","children":[],"tail":", substituted “developing and utilizing, in consultation with the Blue Campaign Advisory Board established pursuant to subsection (g), resources” for “utilizing resources,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/s6407/2"},"text":"Pub. L. 117–81, § 6407(2)","children":[],"tail":", added subsecs. (f) to (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb500da8c-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb500da8d-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Other Functions Related to Human Trafficking","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/322/s6"},"text":"Pub. L. 117–322, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4436"},"text":"136 Stat. 4436","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/322/s6"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Blue Campaign","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The functions and resources of the Blue Campaign located within the Office of Partnership and Engagement on the day before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":"] are hereby transferred to CCHT [Center for Countering Human Trafficking]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Transfer.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act, the Secretary of Homeland Security may transfer the functions and resources of any component, directorate, or other office of the Department of Homeland Security related to combating human trafficking to the CCHT.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days before executing any transfer authorized under paragraph (1), the Secretary of Homeland Security shall notify the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Homeland Security of the House of Representatives of such planned transfer.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb500da8e-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Information Technology Systems","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/125/s3"},"text":"Pub. L. 115–125, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-14"},"text":"Feb. 14, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/316"},"text":"132 Stat. 316","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/125/s3"},"text":"“Not later than one year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-02-14"},"text":"Feb. 14, 2018","children":[],"tail":"], the Secretary of Homeland Security shall ensure, in accordance with the Department of Homeland Security-wide guidance required under section 434(d) of the Homeland Security Act of 2002 ["},{"tag":"ref","attrib":{"href":"/us/usc/t6/s242/d"},"text":"6 U.S.C. 242(d)","children":[],"tail":"], as added by section 2 of this Act, the integration of information technology systems utilized within the Department to record and track information regarding individuals suspected or convicted of human trafficking (as such term is defined in such section).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
