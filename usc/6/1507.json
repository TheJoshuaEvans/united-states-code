{"tag":"section","attrib":{"id":"idb5782e30-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507"},"text":null,"children":[{"tag":"num","attrib":{"value":"1507"},"text":"§ 1507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Construction and preemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5782e31-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Otherwise lawful disclosures","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5782e32-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit or prohibit otherwise lawful disclosures of communications, records, or other information, including reporting of known or suspected criminal activity, by a non-Federal entity to any other non-Federal entity or the Federal Government under this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782e33-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit or prohibit otherwise lawful use of such disclosures by any Federal entity, even when such otherwise lawful disclosures duplicate or replicate disclosures made under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e34-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Whistle blower protections","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to prohibit or limit the disclosure of information protected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/b/8"},"text":"section 2302(b)(8) of title 5","children":[],"tail":" (governing disclosures of illegality, waste, fraud, abuse, or public health or safety threats), "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7211"},"text":"section 7211 of title 5","children":[],"tail":" (governing disclosures to Congress), "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1034"},"text":"section 1034 of title 10","children":[],"tail":" (governing disclosure to Congress by members of the military), "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3234"},"text":"section 3234 of title 50","children":[],"tail":" (governing disclosure by employees of elements of the intelligence community), or any similar provision of Federal or State law."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e35-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Protection of sources and methods","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5782e36-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as creating any immunity against, or otherwise affecting, any action brought by the Federal Government, or any agency or department thereof, to enforce any law, executive order, or procedure governing the appropriate handling, disclosure, or use of classified information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782e37-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to affect the conduct of authorized law enforcement or intelligence activities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782e38-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to modify the authority of a department or agency of the Federal Government to protect classified information and sources and methods and the national security of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e39-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to affect any requirement under any other provision of law for a non-Federal entity to provide information to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e3a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited conduct","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to permit price-fixing, allocating a market between competitors, monopolizing or attempting to monopolize a market, boycotting, or exchanges of price or cost information, customer lists, or information regarding future competitive planning.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e3b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information sharing relationships","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5782e3c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit or modify an existing information sharing relationship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782e3d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit a new information sharing relationship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782e3e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require a new information sharing relationship between any non-Federal entity and a Federal entity or another non-Federal entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782e3f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require the use of the capability and process within the Department of Homeland Security developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1504/c"},"text":"section 1504(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e40-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of contractual obligations and rights","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5782e41-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to amend, repeal, or supersede any current or future contractual agreement, terms of service agreement, or other contractual relationship between any non-Federal entities, or between any non-Federal entity and a Federal entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782e42-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to abrogate trade secret or intellectual property rights of any non-Federal entity or Federal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e43-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Anti-tasking restriction","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall be construed to permit a Federal entity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5782e44-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require a non-Federal entity to provide information to a Federal entity or another non-Federal entity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782e45-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to condition the sharing of cyber threat indicators with a non-Federal entity on such entity’s provision of cyber threat indicators to a Federal entity or another non-Federal entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782e46-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to condition the award of any Federal grant, contract, or purchase on the provision of a cyber threat indicator to a Federal entity or another non-Federal entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e47-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" No liability for non-participation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to subject any entity to liability for choosing not to engage in the voluntary activities authorized in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e48-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use and retention of information","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to authorize, or to modify any existing authority of, a department or agency of the Federal Government to retain or use any information shared under this subchapter for any use other than permitted in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e49-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal preemption","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5782e4a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"This subchapter supersedes any statute or other provision of law of a State or political subdivision of a State that restricts or otherwise expressly regulates an activity authorized under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782e4b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State law enforcement","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to supersede any statute or other provision of law of a State or political subdivision of a State concerning the use of authorized law enforcement practices and procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e4c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulatory authority","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subchapter shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5782e4d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize the promulgation of any regulations not specifically authorized to be issued under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782e4e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish or limit any regulatory authority not specifically established or limited under this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5782e4f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize regulatory actions that would duplicate or conflict with regulatory requirements, mandatory standards, or related processes under another provision of Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e50-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of Secretary of Defense to respond to malicious cyber activity carried out by foreign powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to limit the authority of the Secretary of Defense under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s394"},"text":"section 394 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5782e51-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1507/n"},"text":null,"children":[{"tag":"num","attrib":{"value":"n"},"text":"(n)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal prosecution","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Nothing in this subchapter shall be construed to prevent the disclosure of a cyber threat indicator or defensive measure shared under this subchapter in a case of criminal prosecution, when an applicable provision of Federal, State, tribal, or local law requires disclosure in such case.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb57a7742-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dN/tI/s108"},"text":"Pub. L. 114–113, div. N, title I, § 108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2953"},"text":"129 Stat. 2953","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXVI/s1631/b"},"text":"Pub. L. 115–232, div. A, title XVI, § 1631(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2123"},"text":"132 Stat. 2123","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb57a7743-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb57a7744-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb57a7745-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (m). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “section 394” for “section 130g”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
