{"tag":"section","attrib":{"id":"idb5593380-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s743"},"text":null,"children":[{"tag":"num","attrib":{"value":"743"},"text":"§ 743.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National preparedness goal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5593381-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s743/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The President, acting through the Administrator, shall complete, revise, and update, as necessary, a national preparedness goal that defines the target level of preparedness to ensure the Nation’s ability to prevent, respond to, recover from, and mitigate against natural disasters, acts of terrorism, and other man-made disasters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5593382-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s743/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Incident Management System and National Response Plan","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The national preparedness goal, to the greatest extent practicable, shall be consistent with the National Incident Management System and the National Response Plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5593383-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s643"},"text":"Pub. L. 109–295, title VI, § 643","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1425"},"text":"120 Stat. 1425","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
