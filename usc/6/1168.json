{"tag":"section","attrib":{"id":"idb56e9118-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168"},"text":null,"children":[{"tag":"num","attrib":{"value":"1168"},"text":"§ 1168.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroad security research and development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56e9119-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of research and development program","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary, acting through the Under Secretary for Science and Technology and the Administrator of the Transportation Security Administration, shall carry out a research and development program for the purpose of improving the security of railroad transportation systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e911a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligible projects","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The research and development program may include projects—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e911b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the vulnerability of passenger trains, stations, and equipment to explosives and hazardous chemical, biological, and radioactive substances, including the development of technology to screen passengers in large numbers at peak commuting times with minimal interference and disruption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e911c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to test new emergency response and recovery techniques and technologies, including those used at international borders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e911d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to develop improved railroad security technologies, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56e911e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technologies for sealing or modifying railroad tank cars;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e911f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automatic inspection of railroad cars;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e9120-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communication-based train control systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e9121-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency response training, including training in a tunnel environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e9122-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security and redundancy for critical communications, electrical power, computer, and train control systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e9123-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/b/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technologies for securing bridges and tunnels;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9124-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to test wayside detectors that can detect tampering;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9125-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to support enhanced security for the transportation of security-sensitive materials by railroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9126-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to mitigate damages in the event of a cyber attack; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9127-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address other vulnerabilities and risks identified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e9128-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with other research initiatives","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e9129-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall ensure that the research and development program is consistent with the National Strategy for Railroad Transportation Security developed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1161"},"text":"section 1161 of this title","children":[],"tail":" and any other transportation security research and development programs required by this Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e912a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall, to the extent practicable, coordinate the research and development activities of the Department with other ongoing research and development security-related initiatives, including research being conducted by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56e912b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Transportation, including University Transportation Centers and other institutes, centers, and simulators funded by the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e912c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Academy of Sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e912d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Technical Support Working Group;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e912e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal departments and agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e912f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal and private research laboratories, research entities, and universities and institutions of higher education, including Historically Black Colleges and Universities, Hispanic Serving Institutions, or Indian Tribally Controlled Colleges and Universities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9130-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall carry out any research and development project authorized by this section through a reimbursable agreement with an appropriate Federal agency, if the agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56e9131-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is currently sponsoring a research and development project in a similar area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e9132-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a unique facility or capability that would be useful in carrying out the project;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9133-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may award grants, or enter into cooperative agreements, contracts, other transactions, or reimbursable agreements to the entities described in paragraph (2) and the eligible grant recipients under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1163"},"text":"section 1163 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9134-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall make reasonable efforts to enter into memoranda of understanding, contracts, grants, cooperative agreements, or other transactions with railroad carriers willing to contribute both physical space and other resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e9135-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy and civil rights and civil liberties issues","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e9136-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consultation","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In carrying out research and development projects under this section, the Secretary shall consult with the Chief Privacy Officer of the Department and the Officer for Civil Rights and Civil Liberties of the Department as appropriate and in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s142"},"text":"section 142 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9137-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Privacy impact assessments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In accordance with sections 142 and 345 of this title, the Chief Privacy Officer shall conduct privacy impact assessments and the Officer for Civil Rights and Civil Liberties shall conduct reviews, as appropriate, for research and development initiatives developed under this section that the Secretary determines could have an impact on privacy, civil rights, or civil liberties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e9138-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e9139-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Out of funds appropriated pursuant to section 114(w) ","children":[{"tag":"ref","attrib":{"idref":"fn002162"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002162"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 49, there shall be made available to the Secretary to carry out this section—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56e913a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $33,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e913b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $33,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e913c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $33,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e913d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $33,000,000 for fiscal year 2011.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e913e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1168/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Period of availability","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb56e913f-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXV/s1518"},"text":"Pub. L. 110–53, title XV, § 1518","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/441"},"text":"121 Stat. 441","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb56e9140-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb56e9141-47c4-11f1-9665-b3e99855dc0d"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb56e9142-47c4-11f1-9665-b3e99855dc0d"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This Act, referred to in subsec. (c)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53"},"text":"Pub. L. 110–53","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/266"},"text":"121 Stat. 266","children":[],"tail":", known as the Implementing Recommendations of the 9/11 Commission Act of 2007, which enacted this chapter and enacted and amended numerous other sections and notes in the Code. For complete classification of this Act to the Code, see Short Title of 2007 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s114/w"},"text":"Section 114(w) of title 49","children":[],"tail":", referred to in subsec. (e)(1), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s114/v"},"text":"section 114(v) of title 49","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/s1904/b/1/I"},"text":"Pub. L. 115–254, div. K, § 1904(b)(1)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3545"},"text":"132 Stat. 3545","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
