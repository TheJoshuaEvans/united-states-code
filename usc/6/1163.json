{"tag":"section","attrib":{"id":"idb56e9063-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163"},"text":null,"children":[{"tag":"num","attrib":{"value":"1163"},"text":"§ 1163.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroad security assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb56e9064-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security improvement grants","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e9065-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, in consultation with the Administrator of the Transportation Security Administration and other appropriate agencies or officials, is authorized to make grants to railroad carriers, the Alaska Railroad, security-sensitive materials offerors who ship by railroad, owners of railroad cars used in the transportation of security-sensitive materials, State and local governments (for railroad passenger facilities and infrastructure not owned by Amtrak), and Amtrak for intercity passenger railroad and freight railroad security improvements described in subsection (b) as approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9066-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A railroad carrier is eligible for a grant under this section if the carrier has completed a vulnerability assessment and developed a security plan that the Secretary has approved in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1162"},"text":"section 1162 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9067-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A recipient of a grant under this section may use grant funds only for permissible uses under subsection (b) to further a railroad security plan that meets the requirements of paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9068-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the requirement for eligibility and uses of funds in paragraphs (2) and (3), a railroad carrier is eligible for a grant under this section if the applicant uses the funds solely for the development of assessments or security plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1162"},"text":"section 1162 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9069-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the requirements for eligibility and uses of funds in paragraphs (2) and (3), prior to the earlier of 1 year after the date of issuance of final regulations requiring vulnerability assessments and security plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1162"},"text":"section 1162 of this title","children":[],"tail":" or 3 years after "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", the Secretary may award grants under this section for rail security improvements listed under subsection (b) based upon railroad carrier vulnerability assessments and security plans that the Secretary determines are sufficient for the purposes of this section but have not been approved by the Secretary in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s1162"},"text":"section 1162 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e906a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Uses of funds","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient of a grant under this section shall use the grant funds for one or more of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e906b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Security and redundancy for critical communications, computer, and train control systems essential for secure railroad operations, including communications interoperability where appropriate with relevant outside agencies and entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e906c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Accommodation of railroad cargo or passenger security inspection facilities, related infrastructure, and operations at or near United States international borders or other ports of entry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e906d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The security of security-sensitive materials transportation by railroad.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e906e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chemical, biological, radiological, or explosive detection, including canine patrols for such detection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e906f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The security and preparedness of intercity passenger railroad stations, trains, and infrastructure, including security capital improvement projects that the Secretary determines enhance railroad station security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9070-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technologies to reduce the vulnerabilities of railroad cars, including structural modification of railroad cars transporting security-sensitive materials to improve their resistance to acts of terrorism.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9071-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The sharing of intelligence and information about security threats and preparedness, including connectivity to the National Terrorist Screening Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9072-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To obtain train tracking and communications equipment, including equipment that is interoperable with Federal, State, and local agencies and tribal governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9073-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To hire, train, and employ police, security, and preparedness officers, including canine units, assigned to full-time security or counterterrorism duties related to railroad transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9074-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Overtime reimbursement, including reimbursement of State, local, and tribal governments for costs, for enhanced security personnel assigned to duties related to railroad security during periods of high or severe threat levels and National Special Security Events or other periods of heightened security as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9075-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Perimeter protection systems, including access control, installation of improved lighting, fencing, and barricades at railroad facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9076-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Tunnel protection systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9077-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Passenger evacuation and evacuation-related capital improvements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9078-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Railroad security inspection technologies, including verified visual inspection technologies using hand-held readers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9079-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Surveillance equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e907a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cargo or passenger screening equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e907b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Emergency response equipment, including fire suppression and decontamination equipment, personal protective equipment, and defibrillators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e907c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operating and capital costs associated with security awareness, preparedness, and response training, including training under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1167"},"text":"section 1167 of this title","children":[],"tail":", and training developed by universities, institutions of higher education, and nonprofit employee labor organizations, for railroad employees, including frontline employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e907d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Live or simulated exercises, including exercises described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1166"},"text":"section 1166 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e907e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Public awareness campaigns for enhanced railroad security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e907f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Development of assessments or security plans under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s1162"},"text":"section 1162 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9080-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Other security improvements—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56e9081-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/22/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified, required, or recommended under sections 1161 and 1162 of this title, including infrastructure, facilities, and equipment upgrades; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e9082-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/b/22/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e9083-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Department of Homeland Security responsibilities","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the responsibilities under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e9084-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the requirements for recipients of grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9085-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish priorities for uses of funds for grant recipients;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9086-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award the funds authorized by this section based on risk, as identified by the plans required under sections 1161 and 1162 of this title, or assessment or plan described in subsection (a)(5);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9087-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into account whether stations or facilities are used by commuter railroad passengers as well as intercity railroad passengers in reviewing grant applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9088-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage non-Federal financial participation in projects funded by grants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb56e9089-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 5 business days after awarding a grant to Amtrak under this section, transfer grant funds to the Secretary of Transportation to be disbursed to Amtrak.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e908a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear awards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Grant funds awarded under this section may be awarded for projects that span multiple years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e908b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on uses of funds","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A grant made under this section may not be used to make any State or local government cost-sharing contribution under any other Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e908c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Each recipient of a grant under this section shall report annually to the Secretary on the use of grant funds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e908d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Federal match study","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Not later than 240 days after ","children":[{"tag":"date","attrib":{"date":"2007-08-03"},"text":"August 3, 2007","children":[],"tail":", the Secretary shall provide a report to the appropriate congressional committees on the feasibility and appropriateness of requiring a non-Federal match for grants awarded to freight railroad carriers and other private entities under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e908e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subject to certain standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A recipient of a grant under this section and sections 1164 and 1165 of this title shall be required to comply with the standards of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s24312"},"text":"section 24312 of title 49","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":", with respect to the project in the same manner as Amtrak is required to comply with such standards for construction work financed under an agreement made under section 24308(a) of that title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb56e908f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb56e9090-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Out of funds appropriated pursuant to section 114(w) ","children":[{"tag":"ref","attrib":{"idref":"fn002159"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002159"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 49, there shall be made available to the Secretary to carry out this section—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb56e9091-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $300,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e9092-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $300,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e9093-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1163/i/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $300,000,000 for fiscal year 2010; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb56e9094-47c4-11f1-9665-b3e99855dc0d","id