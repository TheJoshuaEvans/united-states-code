{"tag":"section","attrib":{"id":"idb54620f4-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s655"},"text":null,"children":[{"tag":"num","attrib":{"value":"655"},"text":"§ 655.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enhancement of Federal and non-Federal cybersecurity","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out the responsibilities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s652"},"text":"section 652 of this title","children":[],"tail":", the Director of the Cybersecurity and Infrastructure Security Agency shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb54620f5-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s655/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as appropriate, provide to State and local government entities, and upon request to private entities that own or operate critical information systems—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb54620f6-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s655/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analysis and warnings related to threats to, and vulnerabilities of, critical information systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb54620f7-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s655/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with the Under Secretary for Emergency Preparedness and Response, crisis management support in response to threats to, or attacks on, critical information systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54620f8-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s655/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as appropriate, provide technical assistance, upon request, to the private sector and other government entities, in coordination with the Under Secretary for Emergency Preparedness and Response, with respect to emergency recovery plans to respond to major failures of critical information systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb54620f9-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s655/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fulfill the responsibilities of the Secretary to protect Federal information systems under subchapter II of chapter 35 of title 44.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb54620fa-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXXII/s2205"},"text":"Pub. L. 107–296, title XXII, § 2205","children":[],"tail":", formerly title II, § 223, "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2156"},"text":"116 Stat. 2156","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tV/s531/b/1/A"},"text":"Pub. L. 110–53, title V, § 531(b)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/334"},"text":"121 Stat. 334","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/283/s2/e/3/A"},"text":"Pub. L. 113–283, § 2(e)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3086