{"tag":"section","attrib":{"id":"idb5651b27-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102"},"text":null,"children":[{"tag":"num","attrib":{"value":"1102"},"text":"§ 1102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Domestic Preparedness Consortium","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb5651b28-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" In general","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary is authorized to establish, operate, and maintain a National Domestic Preparedness Consortium within the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651b29-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Members","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Members of the National Domestic Preparedness Consortium shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5651b2a-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Center for Domestic Preparedness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b2b-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Energetic Materials Research and Testing Center, New Mexico Institute of Mining and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b2c-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Center for Biomedical Research and Training, Louisiana State University;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b2d-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Emergency Response and Rescue Training Center, Texas A&M University;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b2e-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Exercise, Test, and Training Center, Nevada Test Site;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b2f-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Transportation Technology Center, Incorporated, in Pueblo, Colorado; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b30-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Disaster Preparedness Training Center, University of Hawaii.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651b31-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The National Domestic Preparedness Consortium shall identify, develop, test, and deliver training to State, local, and tribal emergency response providers, provide on-site and mobile training at the performance and management and planning levels, and facilitate the delivery of training by the training partners of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb5651b32-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb5651b33-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the Center for Domestic Preparedness—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb5651b34-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $57,000,000 for fiscal year 2008;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb5651b35-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $60,000,00