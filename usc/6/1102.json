exico Institute of Mining and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b40-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Center for Biomedical Research and Training, Louisiana State University;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b41-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Emergency Response and Rescue Training Center, Texas A&M University; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb5651b42-47c4-11f1-9665-b3e99855dc0d","identifier":"/us/usc/t6/s1102/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Exercise, Test, and Training Center, Nevada Test Site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb5651b43-47c4-11f1-9665-b3e99855dc0d"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXII/s1204"},"text":"Pub. L. 110–53, title XII, § 1204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/386"},"text":"121 Stat. 386","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
