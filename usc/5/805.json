{"tag":"section","attrib":{"id":"idb7d92001-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s805"},"text":null,"children":[{"tag":"num","attrib":{"value":"805"},"text":"§ 805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No determination, finding, action, or omission under this chapter shall be subject to judicial review.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7d92002-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/121/tII/s251"},"text":"Pub. L. 104–121, title II, § 251","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-29"},"text":"Mar. 29, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/873"},"text":"110 Stat. 873","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
