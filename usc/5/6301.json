{"tag":"section","attrib":{"id":"idb8959332-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301"},"text":null,"children":[{"tag":"num","attrib":{"value":"6301"},"text":"§ 6301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8959333-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States”, when used in a geographical sense means the several States and the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8959334-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8959335-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8959336-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual first employed by the government of the District of Columbia before ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include—","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8959337-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a teacher or librarian of the public schools of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8959338-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a part-time employee who does not have an established regular tour of duty during the administrative workweek;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8959339-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a temporary employee engaged in construction work at an hourly rate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb895933a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of the Panama Canal Commission when employed on the Isthmus of Panama;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb895933b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of the Veterans Health Administration who is covered by a leave system established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7421"},"text":"section 7421 of title 38","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb895933c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of either House of Congress or of the two Houses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb895933d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of a corporation supervised by the Farm Credit Administration if private interests elect or appoint a member of the board of directors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb895933e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an alien employee who occupies a position outside the United States, except as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6310"},"text":"section 6310 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb895933f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a “teacher” or an individual holding a “teaching position” as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s901"},"text":"section 901 of title 20","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8959340-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer in the executive branch or in the government of the District of Columbia who is appointed by the President and whose rate of basic pay exceeds the highest rate payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8959341-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer in the executive branch or in the government of the District of Columbia who is designated by the President, except a postmaster, United States attorney, or United States marshal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8959342-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a chief of mission (as defined in section 102(a)(3) of the Foreign Service Act of 1980); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8959343-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6301/2/xiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiii"},"text":"(xiii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer in the legislative or judicial branch who is appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Notwithstanding clauses (x)–(xii) of paragraph (2), the term “employee” includes any member of the Senior Foreign Service or any Foreign Service officer (other than a member or officer serving as chief of mission or in a position which requires appointment by and with the advice and consent of the Senate) and any member of the Foreign Service commissioned as a diplomatic or consular officer, or both, under section 312 of the Foreign Service Act of 1980.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8959344-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/517"},"text":"80 Stat. 517","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s6/c/17"},"text":"Pub. L. 91–375, § 6(c)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/776"},"text":"84 Stat. 776","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/519/s1"},"text":"Pub. L. 95–519, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1819"},"text":"92 Stat. 1819","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/70/tIII/s3302/e/2"},"text":"Pub. L. 96–70, title III, § 3302(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/498"},"text":"93 Stat. 498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII"},"text":"Pub. L. 96–465, title II","children":[],"tail":", §§ 2312(a), 2314(f)(1), "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2166"},"text":"94 Stat. 2166","children":[],"tail":", 2168; "},{"tag":"ref","attrib":{"href":"/us/pl/99/335/tII/s207/c/1"},"text":"Pub. L. 99