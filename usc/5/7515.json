{"tag":"section","attrib":{"id":"idb8b6fd5b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515"},"text":null,"children":[{"tag":"num","attrib":{"value":"7515"},"text":"§ 7515.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discipline of supervisors based on retaliation against whistleblowers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b6fd5c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b6fd5d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “agency”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b6fd5e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term in section 2302(a)(2)(C), without regard to whether any other provision of this chapter is applicable to the entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b6fd5f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include any entity that is an element of the intelligence community, as defined in section 3 of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003"},"text":"50 U.S.C. 3003","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd60-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “prohibited personnel action” means taking or failing to take an action in violation of paragraph (8), (9), or (14) of section 2302(b) against an employee of an agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd61-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “supervisor” means an employee who would be a supervisor, as defined in section 7103(a), if the entity employing the employee was an agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b6fd62-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proposed Disciplinary Actions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b6fd63-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to section 1214(f), if the head of the agency in which a supervisor is employed, an administrative law judge, the Merit Systems Protection Board, the Special Counsel, a judge of the United States, or the Inspector General of the agency in which a supervisor is employed has determined that the supervisor committed a prohibited personnel action, the head of the agency in which the supervisor is employed, consistent with the procedures required under paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b6fd64-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the first prohibited personnel action committed by the supervisor—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8b6fd65-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall propose suspending the supervisor for a period that is not less than 3 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8b6fd66-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may propose an additional action determined appropriate by the head of the agency, including a reduction in grade or pay; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b6fd67-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the second prohibited personnel action committed by the supervisor, shall propose removing the supervisor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd68-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b6fd69-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A supervisor against whom an action is proposed to be taken under paragraph (1) is entitled to written notice that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8b6fd6a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" states the specific reasons for the proposed action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8b6fd6b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" informs the supervisor about the right of the supervisor to review the material that is relied on to support the reasons given in the notice for the proposed action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b6fd6c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Answer and evidence.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idb8b6fd6d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A supervisor who receives notice under subparagraph (A) may, not later than 14 days after the date on which the supervisor receives the notice, submit an answer and furnish evidence in support of that answer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8b6fd6e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No evidence furnished; insufficient evidence furnished","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, after the end of the 14-day period described in clause (i), a supervisor does not furnish any evidence as described in that clause, or if the head of the agency in which the supervisor is employed determines that the evidence furnished by the supervisor is insufficient, the head of the agency shall carry out the action proposed under subparagraph (A) or (B) of paragraph (1), as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b6fd6f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of procedures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An action carried out under this section—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8b6fd70-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in clause (ii), shall be subject to the same requirements and procedures, including those with respect to an appeal, as an action under section 7503, 7513, or 7543; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8b6fd71-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not be subject to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8b6fd72-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/2/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraphs (1) and (2) of section 7503(b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b6fd73-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/2/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraphs (1) and (2) of subsection (b) and subsection (c) of section 7513; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8b6fd74-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/2/C/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraphs (1) and (2) of subsection (b) and subsection (c) of section 7543.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd75-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7515/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-delegation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the head of an agency is responsible for determining whether a supervisor has committed a prohibited personnel action for purposes of paragraph (1), the head of the agency may not delegate that responsibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b6fd76-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1097/e/1/B"},"text":"Pub. L. 115–91, div. A, title X, § 1097(e)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1621"},"text":"131 Stat. 1621","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b6fd77-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b6fd78-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8b6fd79-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7515, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/73/tI/s104/a"},"text":"Pub. L. 115–73, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-10-26"},"text":"Oct. 26, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1236"},"text":"131 Stat. 1236","children":[],"tail":", related to discipline of supervisors based on retaliation against whistleblowers, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1097/e/1/A"},"text":"Pub. L. 115–91, div. A, title X, § 1097(e)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1621"},"text":"131 Stat. 1621","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
