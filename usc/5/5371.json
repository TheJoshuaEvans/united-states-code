{"tag":"section","attrib":{"id":"idb85c5aab-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5371"},"text":null,"children":[{"tag":"num","attrib":{"value":"5371"},"text":"§ 5371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Health care positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb85c5aac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5371/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, “health care” means direct patient-care services or services incident to direct patient-care services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85c5aad-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5371/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office of Personnel Management may, with respect to any employee described in subsection (c), provide that 1 or more provisions of chapter 74 of title 38 shall apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85c5aae-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5371/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in lieu of any provision of chapter 51 or 61, subchapter V of chapter 55, or any other provision of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5aaf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5371/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any lack of specific authority for a matter with respect to which chapter 51 or 61, subchapter V of chapter 55, or this chapter, relates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85c5ab0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5371/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Authority under subsection (b) may be exercised with respect to any employee holding a position—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85c5ab1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5371/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which chapter 51 applies, excluding any Senior Executive Service position and any position in the Federal Bureau of Investigation and Drug Enforcement Administration Senior Executive Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5ab2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5371/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which involves health care responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb85c5ab3-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/473"},"text":"80 Stat. 473","children":[],"tail":", § 5361; renumbered § 5371 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVIII/s801/a/3/A/ii"},"text":"Pub. L. 95–454, title VIII, § 801(a)(3)(A)(ii)","children":[],"tail":", title IX, § 906(a)(2), "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat