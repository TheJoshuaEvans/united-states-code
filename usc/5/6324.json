{"tag":"section","attrib":{"id":"idb89cbe69-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6324"},"text":null,"children":[{"tag":"num","attrib":{"value":"6324"},"text":"§ 6324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Absence of certain police and firemen","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89cbe6a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sick leave may not be charged to the account of a member of the Metropolitan Police force or the Fire Department of the District of Columbia, the United States Park Police force, or the United States Secret Service Uniformed Division for an absence due to injury or illness resulting from the performance of duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbe6b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The determination of whether an injury or illness resulted from the performance of duty shall be made under regulations prescribed by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbe6c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6324/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia Council for members of the Metropolitan Police force and the Fire Department of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbe6d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6324/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior for the United States Park Police force; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbe6e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6324/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Homeland Security for the United States Secret Service Uniformed Division.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbe6f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6324/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not apply to members of the United States Secret Service Uniformed Division who are covered under chapter 84 for the purpose of retirement benefits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89cbe70-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/522"},"text":"80 Stat. 522","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/623/s1/18"},"text":"Pub. L. 90–623, § 1(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1313"},"text":"82 Stat. 1313","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/183/s2/28"},"text":"Pub. L. 94–183, § 2(28)","children":[],"tail":", (29), "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1058"},"text":"89 Stat. 1058","children":[],"tail":"; "},{"ta