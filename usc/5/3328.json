{"tag":"section","attrib":{"id":"idb8125976-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3328"},"text":null,"children":[{"tag":"num","attrib":{"value":"3328"},"text":"§ 3328.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Selective Service registration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8125977-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3328/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8125978-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3328/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who was born after ","children":[{"tag":"date","attrib":{"date":"1959-12-31"},"text":"December 31, 1959","children":[],"tail":", and is or was required to register under section 3 of the Military Selective Service Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3802"},"text":"50 U.S.C. 3802","children":[],"tail":") and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8125979-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3328/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is not so registered or knowingly and willfully did not so register before the requirement terminated or became inapplicable to the individual,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be ineligible for appointment to a position in an Executive agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb812597a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3328/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) shall not apply to an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb812597b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3328/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a veteran;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb812597c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3328/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who provides evidence of active duty service to the Executive agency in which the individual seeks an appointment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb812597d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3328/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for whom the requirement to register under section 3 of the Military Selective Service Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3802"},"text":"50 U.S.C. 3802","children":[],"tail":") has terminated or is now inapplicable due to age."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb812597e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3328/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management, in consultation with the Director of the Selective Service System, shall prescribe regulations to carry out this section. Such regulations shall include provisions prescribing procedures for the adjudication of determinations of whether a failure to register was knowing and willful. Such procedures shall require that such a determination may not be made if the individual concerned shows by a preponderance of the evidence that the failure to register was neither knowing nor willful. Such procedures may provide that determinations of eligibility under the requirements of this section shall be adjudicated by the Executive agency making the appointment for which the eligibility is determined.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb812597f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3328/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the terms “active duty” and “veteran” have the meaning given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8125980-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145/tXVI/s1622/a/1"},"text":"Pub. L. 99–145, title XVI, § 1622(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-11-08"},"text":"Nov. 8, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/777"},"text":"99 Stat. 777","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/180/dA/tXII/s1249"},"text":"Pub. L. 100–180, div. A, title XII, § 1249","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-04"},"text":"Dec. 4, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1167"},"text":"101 Stat. 1167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tXI/s1108"},"text":"Pub. L. 118–159, div. A, title XI, § 1108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2089"},"text":"138 Stat. 2089","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8125981-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8125982-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8125983-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1108/1"},"text":"Pub. L. 118–159, § 1108(1)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3802"},"text":"50 U.S.C. 3802","children":[],"tail":")” for “(50 U.S.C. App. 453)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1108/2"},"text":"Pub. L. 118–159, § 1108(2)","children":[],"tail":", (3), added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1108/4"},"text":"Pub. L. 118–159, § 1108(4)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/180"},"text":"Pub. L. 100–180","children":[],"tail":" struck out “within the Office” after “for the adjudication” in second sentence and inserted at end “Such procedures may provide that determinations of eligibility under the requirements of this section shall be adjudicated by the Executive agency making the appointment for which the eligibility is determined.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
