{"tag":"section","attrib":{"id":"idb8be29e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109"},"text":null,"children":[{"tag":"num","attrib":{"value":"8109"},"text":"§ 8109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Beneficiaries of awards unpaid at death; order of precedence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8be29e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8be29e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has sustained disability compensable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8107/a"},"text":"section 8107(a) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has filed a valid claim in his lifetime; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dies from a cause other than the injury before the end of the period specified by the schedule;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the compensation specified by the schedule that is unpaid at his death, whether or not accrued or due at his death, shall be paid—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be29eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/a/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under an award made before or after the death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be29ec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/a/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the period specified by the schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be29ed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/a/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to and for the benefit of the persons then in being within the classes and proportions and on the conditions specified by this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be29ee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/a/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the following order of precedence:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8be29ef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/a/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there is no child, to the widow or widower.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8be29f0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/a/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there are both a widow or widower and a child or children, one-half to the widow or widower and one-half to the child or children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8be29f1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/a/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there is no widow or widower, to the child or children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8be29f2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/a/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there is no survivor in the above classes, to the parent or parents wholly or partly dependent for support on the decedent, or to other wholly dependent relatives listed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8133/a/5"},"text":"section 8133(a)(5) of this title","children":[],"tail":", or to both in proportions provided by regulation."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8be29f3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/a/D/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If there is no survivor in the above classes and no burial allowance is payable under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8134"},"text":"section 8134 of this title","children":[],"tail":", an amount not exceeding that which would be expendable under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8134"},"text":"section 8134 of this title","children":[],"tail":" if applicable shall be paid to reimburse a person equitably entitled thereto to the extent and in the proportion that he has paid the burial expenses, but a compensated insurer or other person obligated by law or contract to pay the burial expenses or a State or political subdivision or entity is deemed not equitably entitled."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be29f4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments under subsection (a) of this section, except for an amount payable for a period preceding the death of the individual, are at the basic rate of compensation for permanent disability specified by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8107/a"},"text":"section 8107(a) of this title","children":[],"tail":" even if at the time of death the individual was entitled to the augmented rate specified by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8110"},"text":"section 8110 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be29f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A surviving beneficiary under subsection (a) of this section, except one under subsection (a)(D)(v), does not have a vested right to payment and must be alive to receive payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be29f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A beneficiary under subsection (a) of this section, except one under subsection (a)(D)(v), ceases to be entitled to payment on the happening of an event which would terminate his right to compensation for death under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8133"},"text":"section 8133 of this title","children":[],"tail":". When that entitlement ceases, compensation remaining unpaid under subsection (a) of this section is payable to the surviving beneficiary in accordance with subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8be29f7-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/538"},"text":"80 Stat. 538","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/52"},"text":"Pub. L. 90–83, § 1(52)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/210"},"text":"81 Stat. 210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8be29f8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8be29f9-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8be29fa-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"ta