{"tag":"section","attrib":{"id":"idb86ab257-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538"},"text":null,"children":[{"tag":"num","attrib":{"value":"5538"},"text":"§ 5538.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonreduction in pay while serving in the uniformed services or National Guard","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb86ab258-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee who is absent from a position of employment with the Federal Government in order to perform active duty in the uniformed services pursuant to a call or order to active duty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s12304b"},"text":"section 12304b of title 10","children":[],"tail":" or a provision of law referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/13/B"},"text":"section 101(a)(13)(B) of title 10","children":[],"tail":" shall be entitled, while serving on active duty, to receive, for each pay period described in subsection (b), an amount equal to the amount by which—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86ab259-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of basic pay which would otherwise have been payable to such employee for such pay period if such employee’s civilian employment with the Government had not been interrupted by that service, exceeds (if at all)","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86ab25a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the amount of pay and allowances which (as determined under subsection (d))—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86ab25b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is payable to such employee for that service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86ab25c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is allocable to such pay period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86ab25d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts under this section shall be payable with respect to each pay period (which would otherwise apply if the employee’s civilian employment had not been interrupted)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86ab25e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during which such employee is entitled to re-employment rights under chapter 43 of title 38 with respect to the position from which such employee is absent (as referred to in subsection (a)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86ab25f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which such employee does not otherwise receive basic pay (including by taking any annual, military, or other paid leave) to which such employee is entitled by virtue of such employee’s civilian employment with the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86ab260-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any amount payable under this section to an employee shall be paid—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86ab261-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by such employee’s employing agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86ab262-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the appropriation or fund which would be used to pay the employee if such employee were in a pay status; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86ab263-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, at the same time and in the same manner as would basic pay if such employee’s civilian employment had not been interrupted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86ab264-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall, in consultation with Secretary of Defense, prescribe any regulations necessary to carry out the preceding provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86ab265-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86ab266-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of each agency referred to in section 2302(a)(2)(C)(ii) shall, in consultation with the Office, prescribe procedures to ensure that the rights under this section apply to the employees of such agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86ab267-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Federal Aviation Administration shall, in consultation with the Office, prescribe procedures to ensure that the rights under this section apply to the employees of that agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86ab268-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86ab269-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “employee”, “Federal Government”, and “uniformed services” have the same respective meanings as given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4303"},"text":"section 4303 of title 38","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86ab26a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employing agency”, as used with respect to an employee entitled to any payments under this section, means the agency or other entity of the Government (including an agency referred to in section 2302(a)(2)(C)(ii)) with respect to which such employee has reemployment rights under chapter 43 of title 38; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86ab26b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5538/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “basic pay” includes any amount payable under section 5304.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86ab26c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/dD/tVII/s751/a"},"text":"Pub. L. 111–8, div. D, title VII, § 751(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/693"},"text":"123 Stat. 693","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/117/dC/tVII/s745/a"},"text":"Pub. L. 111–117, div. C, title VII, § 745(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-12-16"},"text":"Dec. 16, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3219"},"text":"123 Stat. 3219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVI/s605"},"text":"Pub. L. 115–232, div. A, title VI, § 605","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1795"},"text":"132 Stat. 1795","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb86ab26d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb86ab26e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb86ab26f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" inserted “"},{"tag":"ref","attrib":{"href":"/us/usc/t10/s12304b"},"text":"section 12304b of title 10","children":[],"tail":" or” after “under” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/117"},"text":"Pub. L. 111–117","children":[],"tail":" added subsec. (b) and struck out former subsec. (b), which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b)(1) Amounts under this section shall be payable with respect to each pay period (which would otherwise apply if the employee’s civilian employment had not been interrupted)—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) during which such employee is entitled to reemployment rights under chapter 43 of title 38 with respect to the position from which such employee is absent (as referred to in subsection (a)); and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) for which such employee does not otherwise receive basic pay (including by taking any annual, military, or other paid leave) to which such employee is entitled by virtue of such employee’s civilian employment with the Government.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) For purposes of this section, the period during which an employee is entitled to reemployment rights under chapter 43 of title 38—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) shall be determined disregarding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4312/d"},"text":"section 4312(d) of title 38","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) shall include any period of time specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4312/e"},"text":"section 4312(e) of title 38","children":[],"tail":" within which an employee may report or apply for employment or reemployment following completion of service on active duty to which called or ordered as described in subsection (a).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb86ab270-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb86ab271-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/117/dC/tVII/s745/b"},"text":"Pub. L. 111–117, div. C, title VII, § 745(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-12-16"},"text":"Dec. 16, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3219"},"text":"123 Stat. 3219","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/117/dC/tVII/s745/b"},"text":"“The amendments made by this section [amending this section] shall take effect on the first day of the first applicable pay period beginning on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2009-12-16"},"text":"Dec. 16, 2009","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb86ab272-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/8/dD/tVII/s751/c"},"text":"Pub. L. 111–8, div. D, title VII, § 751(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/695"},"text":"123 Stat. 695","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/8/dD/tVII/s751/c"},"text":"“The amendments made by this section [enacting this section] shall apply with respect to pay periods (as described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5538/b"},"text":"section 5538(b) of title 5","children":[],"tail":", United States Code, as amended by this section) beginning on or after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2009-03-11"},"text":"Mar. 11, 2009","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
