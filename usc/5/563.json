{"tag":"section","attrib":{"id":"idb7ba26f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563"},"text":null,"children":[{"tag":"num","attrib":{"value":"563"},"text":"§ 563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of need for negotiated rulemaking committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7ba26f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of Need by the Agency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agency may establish a negotiated rulemaking committee to negotiate and develop a proposed rule, if the head of the agency determines that the use of the negotiated rulemaking procedure is in the public interest. In making such a determination, the head of the agency shall consider whether—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ba26f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a need for a rule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there are a limited number of identifiable interests that will be significantly affected by the rule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" there is a reasonable likelihood that a committee can be convened with a balanced representation of persons who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7ba26fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" can adequately represent the interests identified under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ba26fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are willing to negotiate in good faith to reach a consensus on the proposed rule;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a reasonable likelihood that a committee will reach a consensus on the proposed rule within a fixed period of time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26fe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the negotiated rulemaking procedure will not unreasonably delay the notice of proposed rulemaking and the issuance of the final rule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26ff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency has adequate resources and is willing to commit such resources, including technical assistance, to the committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba2700-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency, to the maximum extent possible consistent with the legal obligations of the agency, will use the consensus of the committee with respect to the proposed rule as the basis for the rule proposed by the agency for notice and comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ba2701-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Conveners.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ba2702-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes of conveners","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agency may use the services of a convener to assist the agency in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7ba2703-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying persons who will be significantly affected by a proposed rule, including residents of rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ba2704-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting discussions with such persons to identify the issues of concern to such persons, and to ascertain whether the establishment of a negotiated rulemaking committee is feasible and appropriate in the particular rulemaking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba2705-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s563/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties of conveners","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The convener shall report findings and may make recommendations to the agency. Upon request of the agency, the convener shall ascertain the names of persons who are willing and qualified to represent interests that will be significantly affected by the proposed rule, including residents of rural areas. The report and any recommendations of the convener shall be made available to the public upon request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7ba2706-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/648/s3/a"},"text":"Pub. L. 101–648, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4970"},"text":"104 Stat. 4970","children":[],"tail":", § 583; renumbered § 563, "},{"tag":"ref","attrib":{"href":"/us/pl/102/354/s3/a/2"},"text":"Pub. L. 102–354, § 3(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/944"},"text":"106 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7ba2707-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7ba2708-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7ba2709-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/354"},"text":"Pub. L. 102–354","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s583"},"text":"section 583 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7ba270a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb7ba270b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Negotiated Rulemaking Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/320/s11/e"},"text":"Pub. L. 104–320, § 11(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3874"},"text":"110 Stat. 3874","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/6"},"text":"Pub. L. 117–286, § 4(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4305"},"text":"136 Stat. 4305","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/286/s4/a/6"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Director of the Office of Management and Budget shall—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 180 days of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":"], take appropriate action to expedite the establishment of negotiated rulemaking committees and committees established to resolve disputes under the Administrative Dispute Resolution Act ["},{"tag":"ref","attrib":{"href":"/us/pl/101/552"},"text":"Pub. L. 101–552","children":[],"tail":", see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s571"},"text":"section 571 of this title","children":[],"tail":"], including, with respect to negotiated rulemaking committees, eliminating any redundant administrative requirements related to filing a committee charter under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1008"},"text":"section 1008 of title 5","children":[],"tail":", United States Code, and providing public notice of such committee under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s564"},"text":"section 564 of title 5","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within one year of the date of the enactment of this Act, submit recommendations to Congress for any necessary legislative changes.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
