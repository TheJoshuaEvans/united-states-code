{"tag":"section","attrib":{"id":"idb827dcd6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4105"},"text":null,"children":[{"tag":"num","attrib":{"value":"4105"},"text":"§ 4105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-Government facilities; use of","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The head of an agency, without regard to section 6101(b) to (d) of title 41, may make agreements or other arrangements for the training of employees of the agency by, in, or through non-Government facilities under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb827dcd7-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/434"},"text":"80 Stat. 434","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/226/s2/a/3"},"text":"Pub. L. 103–226, § 2(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-30"},"text":"Mar. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/111"},"text":"108 Stat. 111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/a/7"},"text":"Pub. L. 111–350, § 5(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3841"},"text":"124 Stat. 3841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb827dcd8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb827dcd9-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb827dcd