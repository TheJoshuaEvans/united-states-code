rib":{"href":"/us/usc/t5/s2308"},"text":"5 U.S.C. 2308","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/507/s9"},"text":"Pub. L. 85–507, § 9","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/331"},"text":"72 Stat. 331","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “appropriate” is omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “by, in, and through non-Government facilities” are omitted as unnecessary in view of the previous reference in the subsection.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the word “appropriate” is omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb827dcdb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb827dcdc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “section 6101(b) to (d) of title 41” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"section 5 of title 41","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226"},"text":"Pub. L. 103–226","children":[],"tail":" struck out subsec. (a) designation and subsecs. (b) and (c), which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) An agency program for the training of employees by, in, and through non-Government facilities under this chapter shall—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) provide that information concerning the selection and assignment of employees for training and the applicable training limitations and restrictions be made available to employees of the agency; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) give consideration to the needs and requirements of the agency in recruiting and retaining scientific, professional, technical, and administrative employees.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) In order to protect the Government concerning payment and reimbursement of training expenses, each agency shall prescribe such regulations as it considers necessary to implement the regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4118/a/8"},"text":"section 4118(a)(8) of this title","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
