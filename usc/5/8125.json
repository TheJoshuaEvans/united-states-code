{"tag":"section","attrib":{"id":"idb8c073e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8125"},"text":null,"children":[{"tag":"num","attrib":{"value":"8125"},"text":"§ 8125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Misbehavior at proceedings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"If an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c073ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8125/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disobeys or resists a lawful order or process in proceedings under this subchapter before the Secretary of Labor or his representative; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c073eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8125/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" misbehaves during a hearing or so near the place of hearing as to obstruct it;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary or his representative shall certify the facts to the district court having jurisdiction in the place where he is sitting. The court, in a summary manner, shall hear the evidence as to the acts complained of and if the evidence warrants, punish the individual in the same manner and to the same extent as for a contempt committed before the court, or commit the individual on the same conditions as if the forbidden act had occurred with reference to the process of or in the presence of the court.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c073ec-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/545"},"text":"80 Stat. 545","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c073ed-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c073ee-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c073ef-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s773/c"},"text":"5 U.S.C. 773(c)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-14/ch691/s208"},"text":"Oct. 14, 1949, ch. 691, § 208","children":[],"tail":" “Sec. 23(c)”, "},{"tag":"html:a","attrib":{"href":"/us/stat/63/865"},"text":"63 Stat. 865","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “the district court of the United States for the District of Columbia” are omitted as included in “district court”. The words “under this subchapter” are added for clarity since this section which was formerly a subsection referred to the subsection preceding it which identified the proceedings.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Administration of this subchapter was transferred to the Secretary of Labor by section 1 of 1950 Reorg. Plan No. 19, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1271"},"text":"64 Stat. 1271","children":[],"tail":" (see section 8145)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
