{"tag":"section","attrib":{"id":"idb7ff463a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116"},"text":null,"children":[{"tag":"num","attrib":{"value":"3116"},"text":"§ 3116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited hiring authority for post-secondary students; competitive service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7ff463b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff463c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Director” means the Director of the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff463d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Institution of higher education","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “institution of higher education” has the meaning given the term in section 101(a) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"20 U.S.C. 1001(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff463e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Student","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “student” means an individual enrolled or accepted for enrollment in an institution of higher education who is pursuing a baccalaureate or graduate degree on at least a part-time basis as determined by the institution of higher education.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff463f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff4640-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency may make a time-limited appointment of a student, without regard to any provision of sections 3309 through 3319 and 3330, to a position in the competitive service at the GS–11 level, or an equivalent level, or below for which the student is qualified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4641-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restrictions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An appointment under paragraph (1) shall be made in accordance with regulations prescribed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff4642-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Notice","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff4643-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency making an appointment under subsection (b) shall publicly advertise positions available under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4644-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the head of an agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7ff4645-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adhere to merit system principles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4646-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advertise positions in a manner that provides for diverse and qualified applicants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4647-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure potential applicants have appropriate information relevant to the positions available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff4648-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Appointments.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff4649-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the total number of students that the head of an agency may appoint under this section during a fiscal year may not exceed the number equal to 15 percent of the number of students that the agency head appointed during the previous fiscal year to a position at the GS–11 level, or an equivalent level, or below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff464a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under a regulation prescribed under subsection (g), the Director may establish a lower limit on the number of students that may be appointed under paragraph (1) of this subsection during a fiscal year based on any factor the Director considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff464b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conversion","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an agency may, without regard to any provision of chapter 33 or any other provision of law relating to the examination, certification, and appointment of individuals in the competitive service, convert a student serving in an appointment under subsection (b) to a permanent appointment in the competitive service within the agency without further competition if the student—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff464c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed the course of study leading to the baccalaureate or graduate degree;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff464d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has completed not less than 640 hours of current continuous employment in an appointment under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff464e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the qualification standards for the position to which the student will be converted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff464f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency shall, without regard to any provision of chapter 35 or 75, terminate the appointment of a student appointed under subsection (b) upon completion of the designated academic course of study unless the student is selected for conversion under subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff4650-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of enactment of this section, the Director shall issue interim regulations, with an opportunity for comment, for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff4651-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff4652-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than September 30 of each of the first 3 fiscal years beginning after the date of enactment of this section, the head of an agency that makes an appointment under this section shall submit a report to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7ff4653-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress that assesses the impact of the use of the authority provided under this section during the fiscal year in which the report is submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4654-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director that contains data that the Director considers necessary for the Director to assess the impact and effectiveness of the authority described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4655-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an agency shall include in each report under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7ff4656-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of individuals appointed by the agency under this section, as well as the number of such individuals who are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7ff4657-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/h/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minorities or members of other underrepresented groups; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7ff4658-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/h/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4659-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff465a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/h/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of individuals appointed by the agency during the applicable fiscal year to a position in the competitive service at the GS–11 level, or an equivalent level, or below; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff465b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/h/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional data specified by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff465c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Provision Regarding the Department of Defense.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff465d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall preclude the Secretary of Defense from exercising any authority to appoint a post-secondary student under section 1106 of the National Defense Authorization Act for Fiscal Year 2017 (10 U.S.C. note prec. 1580), or any applicable successor statute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff465e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3116/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any regulations prescribed by the Director for the administration of this section shall not apply to the Department of Defense during the period ending on the date on which the appointment authority of the Secretary of Defense under section 1106 of the National Defense Authorization Act for Fiscal Year 2017 (10 U.S.C. note prec. 1580), or any applicable successor statute, terminates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7ff465f-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXI/s1108/a"},"text":"Pub. L. 115–232, div. A, title XI, § 1108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2007"},"text":"132 Stat. 2007","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI/s1115"},"text":"Pub. L. 116–92, div. A, title XI, § 1115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1604"},"text":"133 Stat. 1604","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7ff4660-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7ff4661-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb7ff4662-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"GS–11, referred to in subsecs. (b)(1), (d)(1), and (h)(2)(C), is contained in the General Schedule which is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsecs. (g) and (h)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1106 of the National Defense Authorization Act for Fiscal Year 2017, referred to in subsec. (i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1106"},"text":"section 1106 of Pub. L. 114–328","children":[],"tail":", which is set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1580"},"text":"section 1580 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7ff4663-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" amended par. (1) generally. Prior to amendment, text read as follows: “Except as provided in paragraph (2), the total number of students that the head of an agency may appoint under this section during a fiscal year may not exceed the number equal to 15 percent of the number of students that the agency head appointed during the previous fiscal year to a position in the competitive service at the GS–11 level, or an equivalent level, or below.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
