{"tag":"section","attrib":{"id":"idb82f0934-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4521"},"text":null,"children":[{"tag":"num","attrib":{"value":"4521"},"text":"§ 4521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter, the term “law enforcement officer” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82f0935-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4521/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement officer within the meaning of section 5541(3) and to whom the provisions of chapter 51 apply;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f0936-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4521/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the United States Secret Service Uniformed Division;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f0937-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4521/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the United States Park Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f0938-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4521/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a special agent in the Diplomatic Security Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f0939-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4521/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a probation officer (referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3672"},"text":"section 3672 of title 18","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f093a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4521/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pretrial services officer (referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3153"},"text":"section 3153 of title 18","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82f093b-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tIV/s408/a"},"text":"Pub. L. 101–509, title V, § 529 [title IV, § 408(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1467; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/141/tVI/s627"},"text":"Pub. L. 102–141, title VI, § 627","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/874"},"text":"105 Stat. 874","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/21"},"text":"Pub. L. 102–378, § 2(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1348"},"text":"106 Stat. 1348","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82f093c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb82f093d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb82f093e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378"},"text":"Pub. L. 102–378","children":[],"tail":" amended section generally, substituting in par. (1) “section 5541(3)” for “section 8331(20) or section 8401(17)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/141"},"text":"Pub. L. 102–141","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “For the purpose of this subchapter, the term ‘law enforcement officer’ has the same meaning as under section 5949(a).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82f093f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb82f0940-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tIV/s408/d"},"text":"Pub. L. 101–509, title V, § 529 [title IV, § 408(d)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1468, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/509/tV/s529/tIV/s408/d"},"text":"“The amendments made by this section [enacting this subchapter and amending provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5541"},"text":"section 5541 of this title","children":[],"tail":"] shall be effective on "},{"tag":"date","attrib":{"date":"1992-01-01"},"text":"January 1, 1992","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb82f0941-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of the functions, personnel, assets, and obligations of the United States Secret Service, including the functions of the Secretary of the Treasury relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 381, 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
