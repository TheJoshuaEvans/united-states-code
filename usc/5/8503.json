pter” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb90f2eb7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb90f2eb8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1967 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 5","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8503(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[Uncodified].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/778/s542/a/1"},"text":"Pub. L. 86–778, § 542(a)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/985"},"text":"74 Stat. 985","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section also amends ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8503"},"text":"5 U.S.C. 8503","children":[],"tail":" to eliminate certain provisions that are now obsolete. The obsolete provisions were based on section 542(b)(1)(B) and (C) of the act of "},{"tag":"date","attrib":{"date":"1960-09-13"},"text":"September 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/986"},"text":"74 Stat. 986","children":[],"tail":", that amended section 1503 (a) and (b) of the Social Security Act effective "},{"tag":"date","attrib":{"date":"1961-01-01"},"text":"January 1, 1961","children":[],"tail":", but only in the case of weeks of unemployment beginning before "},{"tag":"date","attrib":{"date":"1966-01-01"},"text":"January 1, 1966","children":[],"tail":". Any existing rights are preserved by section 7 of this bill."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb90f2eb9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb90f2eba-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/566/s116/e/2"},"text":"Pub. L. 94–566, § 116(e)(2)","children":[],"tail":", redesignated subsec. (c) as (b) and substituted “subsection (a)” for “subsection (a) or (b)”. Former subsec. (b), which made special provision for Federal employees whose Federal service and Federal wages were assigned to the Virgin Islands, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/566/s116/e/2/A"},"text":"Pub. L. 94–566, § 116(e)(2)(A)","children":[],"tail":", struck out subsec. (d) which authorized the Secretary to use the personnel and facilities of the agency in the Virgin Islands cooperating with the United States Employment Service."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb90f2ebb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90f2ebc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/566"},"text":"Pub. L. 94–566","children":[],"tail":" applicable with respect to benefit years beginning on or after later of "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"Oct. 1, 1976","children":[],"tail":", or first day of first week for which compensation becomes payable under an unemployment compensation law of Virgin Islands which is approved by Secretary of Labor under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304/a"},"text":"section 3304(a) of Title 26","children":[],"tail":", Internal Revenue Code, see "},{"tag":"ref","attrib":{"href":"/us/pl/94/566/s116/f/3"},"text":"section 116(f)(3) of Pub. L. 94–566","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s3304"},"text":"section 3304 of Title 26","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
