{"tag":"section","attrib":{"id":"idb8a8a5c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7113"},"text":null,"children":[{"tag":"num","attrib":{"value":"7113"},"text":"§ 7113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National consultation rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a8a5c4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, in connection with any agency, no labor organization has been accorded exclusive recognition on an agency basis, a labor organization which is the exclusive representative of a substantial number of the employees of the agency, as determined in accordance with criteria prescribed by the Authority, shall be granted national consultation rights by the agency. National consultation rights shall terminate when the labor organization no longer meets the criteria prescribed by the Authority. Any issue relating to any labor organization’s eligibility for, or continuation of, national consultation rights shall be subject to determination by the Authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a8a5c5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a8a5c6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any labor organization having national consultation rights in connection with any agency under subsection (a) of this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a8a5c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7113/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be informed of any substantive change in conditions of employment proposed by the agency, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a8a5c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7113/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be permitted reasonable time to present its views and recommendations regarding the changes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a8a5c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If any views or recommendations are presented under paragraph (1) of this subsection to an agency by any labor organization—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a8a5ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7113/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency shall consider the views or recommendations before taking final action on any matter with respect to which the views or recommendations are presented; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a8a5cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7113/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency shall provide the labor organization a written statement of the reasons for taking the final action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a8a5cc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be construed to limit the right of any agency or exclusive representative to engage in collective bargaining.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a8a5cd-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVII/s701"},"text":"Pub. L. 95–454, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1201"},"text":"92 Stat. 1201","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/55"},"text":"Pub. L. 102–378, § 2(55)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1354"},"text":"106 Stat. 1354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a8a5ce-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a8a5cf-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8a8a5d0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378"},"text":"Pub. L. 102–378","children":[],"tail":" struck out “(1)” after subsec. (a) designation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a8a5d1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8a8a5d2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
