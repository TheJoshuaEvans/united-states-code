{"tag":"section","attrib":{"id":"idb7e52e5d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1202"},"text":null,"children":[{"tag":"num","attrib":{"value":"1202"},"text":"§ 1202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of office; filling vacancies; removal","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7e52e5e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term of office of each member of the Merit Systems Protection Board is 7 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7e52e5f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member appointed to fill a vacancy occurring before the end of a term of office of the member’s predecessor serves for the remainder of that term. Any appointment to fill a vacancy is subject to the requirements of section 1201. Any new member serving only a portion of a seven-year term in office may continue to serve until a successor is appointed and has qualified, except that such member may not continue to serve for more than one year after the date on which the term of the member would otherwise expire, unless reappointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7e52e60-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any member appointed for a 7-year term may not be reappointed to any following term but may continue to serve beyond the expiration of the term until a successor is appointed and has qualified, except that such member may not continue to serve for more than one year after the date on which the term of the member would otherwise expire under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7e77851-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1202/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any member may be removed by the President only for inefficiency, neglect of duty, or malfeasance in office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7e77852-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tII/s202/a"},"text":"Pub. L. 95–454, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1122"},"text":"92 Stat. 1122","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/m/tVI/s620"},"text":"Pub. L. 100–202, § 101(m) [title VI, § 620]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-390"},"text":"101 Stat. 1329–390","children":[],"tail":", 1329–427; "},{"tag":"ref","attrib":{"href":"/us/pl/101/12/s3/a/2"},"text":"Pub. L. 101–12, § 3(a)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1989-04-10"},"text":"Apr. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/17"},"text":"103 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7e77853-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7e77854-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7e77855-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/12/s3/a/2"},"text":"Pub. L. 101–12, § 3(a)(2)","children":[],"tail":", substituted a semicolon for the comma after “office” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/12/s3/a/3"},"text":"Pub. L. 101–12, § 3(a)(3)","children":[],"tail":", substituted “the member’s” for “his” in first sentence and struck out “of this title” after “section 1201” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202"},"text":"Pub. L. 100–202","children":[],"tail":" inserted provision permitting any new member serving portion of seven-year term to continue serving until successor is appointed and has qualified, with exception limiting duration of such service."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7e77856-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7e77857-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/12"},"text":"Pub. L. 101–12","children":[],"tail":" effective 90 days following "},{"tag":"date","attrib":{"date":"1989-04-10"},"text":"Apr. 10, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/12/s11"},"text":"section 11 of Pub. L. 101–12","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
