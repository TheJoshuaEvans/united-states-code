{"tag":"section","attrib":{"id":"idb908046e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462"},"text":null,"children":[{"tag":"num","attrib":{"value":"8462"},"text":"§ 8462.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost-of-living adjustments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb908046f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9080470-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “base quarter”, as used with respect to a year, means the calendar quarter ending on September 30 of such year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9080471-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price index for a base quarter is the arithmetical mean of such index for the 3 months comprising such quarter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9080472-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “percent change in the price index”, as used with respect to a year, means the percentage derived by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9080473-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reducing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9080474-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price index for the base quarter of such year, by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9080475-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the price index for the base quarter of the preceding year in which an adjustment under this subsection was made;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9080476-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dividing the difference under subparagraph (A) by the price index referred to in subparagraph (A)(ii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9080477-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiplying the quotient under subparagraph (B) by 100.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9080478-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9080479-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (c), effective December 1 of any year in which an adjustment under this subsection is to be made, as determined under paragraph (2), each annuity payable from the Fund under this chapter (other than an annuity under section 8443) having a commencing date not later than such December 1 shall be adjusted as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb908047a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the percent change in the price index for the year does not exceed 3 percent, each annuity subject to adjustment under this subsection shall be increased by the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb908047b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percent change in the price index (rounded to the nearest one-tenth of 1 percent); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb908047c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb908047d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the percent change in the price index for the year exceeds 3 percent, each annuity subject to adjustment under this subsection shall be increased by the excess of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb908047e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percent change in the price index (rounded to the nearest one-tenth of 1 percent), over","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb908047f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9080480-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An adjustment under this subsection shall be made in a year only if the price index for the base quarter of such year exceeds the price index for the base quarter of the preceding year in which an adjustment under this subsection was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9080481-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An annuity under this chapter shall not be subject to adjustment under section 8340. Nothing in the preceding sentence shall affect the computation of any amount under section 8443(a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9080482-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Eligibility for an annuity increase under this section is governed by the commencing date of each annuity payable from the Fund as of the effective date of an increase, except as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9080483-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The first increase (if any) made under subsection (b) to an annuity which is payable from the Fund to an annuitant or survivor (other than a child under section 8443) whose annuity has not been increased under this subsection or subsection (b) shall be equal to the product (adjusted to the nearest one-tenth of 1 percent) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9080484-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-twelfth of the applicable percent change computed under subsection (b), multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9080485-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of months (not to exceed 12 months, counting any portion of a month as a month)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9080486-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the annuity was payable from the Fund before the effective date of the increase; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9080487-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a survivor of a deceased annuitant whose annuity has not been so increased, since the annuity was first payable to the deceased annuitant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9080488-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective from its commencing date, an annuity payable from the Fund to an annuitant’s survivor (other than a widow or widower whose annuity is computed under section 8442(g) or a child under section 8443) shall be increased by the total percentage by which the deceased annuitant’s annuity had been increased under this section during the period beginning on the date the deceased annuitant’s annuity commenced and ending on the date of the deceased annuitant’s death.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9080489-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb908048a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An adjustment under subsection (b) for any year shall not be effective with respect to the annuity of an annuitant who is under 62 years of age as of the date on which such adjustment would otherwise first take effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb908048b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb908048c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in clause (ii), this paragraph applies only with respect to an annuitant under section 8412, 8413, or 8414.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb908048d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This paragraph does not apply with respect to an annuitant under subsection (d)(1) or (e) of section 8412 or (in the case of an annuitant separated from service as a military reserve technician as a result of disability) under section 8414(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb908048e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The first increase (if any) made under subsection (b) to an annuity which is payable from the Fund to a widow or widower whose annuity is computed under section 8442(g) shall be equal to the product (adjusted to the nearest one-tenth of 1 percent) of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb908048f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-twelfth of the applicable percent change computed under subsection (b), multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9080490-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of months (not to exceed 12 months, counting any portion of a month as a month) since—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb9080491-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date of the adjustment last made under this section in the annuity of the annuitant on whose service on the widow’s or widower’s annuity is based; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb9080492-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the annuity of the annuitant (referred to in clause (i)) has not been increased under this section, the commencement date of such annuitant’s annuity (determined subject to section 8452(a)(1)(B)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9080493-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The monthly installment of an annuity after adjustment under this section shall be rounded to the next lowest dollar. However, the monthly installment shall, after adjustment, reflect an increase of at least $1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9080494-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8462/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The $15,000 amount referred to in section 8442(b)(1)(A)(ii) shall be increased at the same time that, and by the same percent as the percentage by which, annuities under subchapter III of chapter 83 are increased.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9080495-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/572"},"text":"100 Stat. 572","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/556/tI/s117/b"},"text":"Pub. L. 99–556, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3134"},"text":"100 Stat. 3134","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/225/s3/b/2/A/vi"},"text":"Pub. L. 117–225, § 3(b)(2)(A)(vi)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-09"},"text":"Dec. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2296"},"text":"136 Stat. 2296","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9080496-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9080497-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb9080498-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(3)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/225"},"text":"Pub. L. 117–225","children":[],"tail":" inserted “(1)” after “subsection (d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/556"},"text":"Pub. L. 99–556","children":[],"tail":" inserted provision relating to the computation of any amount under section 8443(a)(2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9080499-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb908049a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/225"},"text":"Pub. L. 117–225","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-12-09"},"text":"Dec. 9, 2022","children":[],"tail":", and applicable to an individual who suffers an illness or injury described in certain Code provisions on or after the date that is 2 years after "},{"tag":"date","attrib":{"date":"2022-12-09"},"text":"Dec. 9, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/225/s3/f"},"text":"section 3(f) of Pub. L. 117–225","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8336"},"text":"section 8336 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb908049b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Delay in Cost-of-Living Adjustments During Fiscal Years 1994, 1995, and 1996","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Any cost-of-living increase scheduled to take effect during fiscal year 1994, 1995, or 1996 under subsec. (b) of this section delayed until first day of third calendar month after date such increase would otherwise take effect, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s11001"},"text":"section 11001 of Pub. L. 103–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8340"},"text":"section 8340 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
