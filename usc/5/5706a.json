{"tag":"section","attrib":{"id":"idb8800e6c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5706a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5706a"},"text":"§ 5706a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Subsistence and travel expenses for threatened law enforcement personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8800e6d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5706a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5707"},"text":"section 5707 of this title","children":[],"tail":", when the life of an employee who serves in a law enforcement, investigative, or similar capacity, or members of such employee’s immediate family, is threatened as a result of the employee’s assigned duties, the head of the agency concerned may approve appropriate subsistence payments for the employee or members of the employee’s family (or both) while occupying temporary living accommodations at or away from the employee’s designated post of duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8800e6e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5706a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When a situation described in subsection (a) of this section requires the employee or members of the employee’s family (or both) to be temporarily relocated away from the employee’s designated post of duty, the head of the agency concerned may approve transportation expenses to and from such alternate location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8800e6f-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/234/tI/s103/a"},"text":"Pub. L. 99–234, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-02"},"text":"Jan. 2, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1757"},"text":"99 Stat. 1757","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8800e70-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8800e71-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8800e72-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective (1) on effective date of regulations to be promulgated not later than 150 days after ","children":[{"tag":"date","attrib":{"date":"1986-01-02"},"text":"Jan. 2, 1986","children":[],"tail":", or (2) 180 days after "},{"tag":"date","attrib":{"date":"1986-01-02"},"text":"Jan. 2, 1986","children":[],"tail":", whichever occurs first, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/234/s301/a"},"text":"section 301(a) of Pub. L. 99–234","children":[],"tail":", set out as an Effective Date of 1986 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5701"},"text":"section 5701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
