{"tag":"section","attrib":{"id":"idb86f6deb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546"},"text":null,"children":[{"tag":"num","attrib":{"value":"5546"},"text":"§ 5546.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay for Sunday and holiday work","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb86f6dec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee who performs work during a regularly scheduled 8-hour period of service which is not overtime work as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5542/a"},"text":"section 5542(a) of this title","children":[],"tail":" a part of which is performed on Sunday is entitled to pay for the entire period of service at the rate of his basic pay, plus premium pay at a rate equal to 25 percent of his rate of basic pay. For employees serving outside the United States in areas where Sunday is a routine workday and another day of the week is officially recognized as the day of rest and worship, the Secretary of State may designate the officially recognized day of rest and worship as the day with respect to which the preceding sentence shall apply instead of Sunday."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86f6ded-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee who performs work on a holiday designated by Federal statute, Executive order, or with respect to an employee of the government of the District of Columbia, by order of the District of Columbia Council, is entitled to pay at the rate of his basic pay, plus premium pay at a rate equal to the rate of his basic pay, for that holiday work which is not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86f6dee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in excess of 8 hours; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86f6def-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" overtime work as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5542/a"},"text":"section 5542(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86f6df0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee who is required to perform any work on a designated holiday is entitled to pay for at least 2 hours of holiday work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86f6df1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee who performs overtime work as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5542/a"},"text":"section 5542(a) of this title","children":[],"tail":" on a Sunday or a designated holiday is entitled to pay for that overtime work in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5542/a"},"text":"section 5542(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86f6df2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Premium pay under this section is in addition to premium pay which may be due for the same work under section 5545(a) and (b) of this title, providing premium pay for nightwork.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86f6df3-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/488"},"text":"80 Stat. 488","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/29"},"text":"Pub. L. 90–83, § 1(29)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/201"},"text":"81 Stat. 201","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/623/s1/13"},"text":"Pub. L. 90–623, § 1(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1312"},"text":"82 Stat. 1312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. B, title XXIII, § 2317(2), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-829"},"text":"112 Stat. 2681–829","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb86f6df4-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb86f6df5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{