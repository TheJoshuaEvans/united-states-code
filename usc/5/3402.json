{"tag":"section","attrib":{"id":"idb81e6736-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402"},"text":null,"children":[{"tag":"num","attrib":{"value":"3402"},"text":"§ 3402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of part-time career employment programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb81e6737-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81e6738-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to promote part-time career employment opportunities in all grade levels, the head of each agency, by regulation, shall establish and maintain a program for part-time career employment within such agency. Such regulations shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81e6739-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the review of positions which, after such positions become vacant, may be filled on a part-time career employment basis (including the establishment of criteria to be used in identifying such positions);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e673a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures and criteria to be used in connection with establishing or converting positions for part-time career employment, subject to the limitations of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3403"},"text":"section 3403 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e673b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual goals for establishing or converting positions for part-time career employment, and a timetable setting forth interim and final deadlines for achieving such goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e673c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a continuing review and evaluation of the part-time career employment program established under such regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e673d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for notifying the public of vacant part-time positions in such agency, utilizing facilities and funds otherwise available to such agency for the dissemination of information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81e673e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of each agency shall provide for communication between, and coordination of the activities of, the individuals within such agency whose responsibilities relate to the part-time career employment program established within that agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81e673f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulations established under paragraph (1) of this subsection may provide for such exceptions as may be necessary to carry out the mission of the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81e6740-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81e6741-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management, by regulation, shall establish and maintain a program under which it shall, on the request of an agency, advise and assist such agency in the establishment and maintenance of its part-time career employment program under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81e6742-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office shall conduct a research and demonstration program with respect to part-time career employment within the Federal Government. In particular, such program shall be directed to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81e6743-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the extent to which part-time career employment may be used in filling positions which have not traditionally been open for such employment on any extensive basis, such as supervisory, managerial, and professional positions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e6744-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the extent to which job-sharing arrangements may be established for various occupations and positions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e6745-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3402/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating attitudes, benefits, costs, efficiency, and productivity associated with part-time career employment, as well as its various sociological effects as a mode of employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb81e6746-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/437/s3/a"},"text":"Pub. L. 95–437, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1056"},"text":"92 Stat. 1056","children":[],"tail":", § 3392; renumbered § 3402 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/c/1/B"},"text":"Pub. L. 95–454, title IX, § 906(c)(1)(B)","children":[],"tail":", (2)(B), "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1226"},"text":"92 Stat. 1226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb81e6747-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb81e6748-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb81e6749-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s906/c/1/B"},"text":"Pub. L. 95–454, § 906(c)(1)(B)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3392"},"text":"section 3392 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s906/c/2/B/i"},"text":"Pub. L. 95–454, § 906(c)(2)(B)(i)","children":[],"tail":", substituted “3403” for “3393”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s906/c/2/B/ii"},"text":"Pub. L. 95–454, § 906(c)(2)(B)(ii)","children":[],"tail":", substituted “Office of Personnel Management” for “Civil Service Commission” and “chapter” for “subchapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s906/c/2/B/iii"},"text":"Pub. L. 95–454, § 906(c)(2)(B)(iii)","children":[],"tail":", substituted “Office” for “Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb81e674a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb81e674b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
