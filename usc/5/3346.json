{"tag":"section","attrib":{"id":"idb8198500-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3346"},"text":null,"children":[{"tag":"num","attrib":{"value":"3346"},"text":"§ 3346.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Time limitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8198501-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3346/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except in the case of a vacancy caused by sickness, the person serving as an acting officer as described under section 3345 may serve in the office—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8198502-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3346/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for no longer than 210 days beginning on the date the vacancy occurs; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198503-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3346/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsection (b), once a first or second nomination for the office is submitted to the Senate, from the date of such nomination for the period that the nomination is pending in the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8198504-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3346/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8198505-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3346/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the first nomination for the office is rejected by the Senate, withdrawn, or returned to the President by the Senate, the person may continue to serve as the acting officer for no more than 210 days after the date of such rejection, withdrawal, or return.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198506-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3346/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding paragraph (1), if a second nomination for the office is submitted to the Senate after the rejection, withdrawal, or return of the first nomination, the person serving as the acting officer may continue to serve—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8198507-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3346/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" until the second nomination is confirmed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8198508-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3346/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for no more than 210 days after the second nomination is rejected, withdrawn, or returned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8198509-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3346/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a vacancy occurs during an adjournment of the Congress sine die, the 210-day period under subsection (a) shall begin on the date that the Senate first reconvenes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb819850a-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s151/b"},"text":"Pub. L. 105–277, div. C, title I, § 151(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-612"},"text":"112 Stat. 2681–612","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb819850b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb819850c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb819850d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3346, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/426"},"text":"80 Stat. 426","children":[],"tail":", provided for details to subordinate offices, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s151/b"},"text":"Pub. L. 105–277, div. C, title I, § 151(b)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-611"},"text":"112 Stat. 2681–611","children":[],"tail":", 2681–616, effective 30 days after "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3345"},"text":"section 3345 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb819850e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb819850f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 30 days after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", and applicable to any office that becomes vacant after such effective date, with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s151/d"},"text":"section 151(d) of Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3345"},"text":"section 3345 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
