{"tag":"section","attrib":{"id":"idb8be299c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8105"},"text":null,"children":[{"tag":"num","attrib":{"value":"8105"},"text":"§ 8105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Total disability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8be299d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the disability is total, the United States shall pay the employee during the disability monthly monetary compensation equal to 66⅔ percent of his monthly pay, which is known as his basic compensation for total disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be299e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The loss of use of both hands, both arms, both feet, or both legs, or the loss of sight of both eyes, is prima facie permanent total disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8be299f-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/535"},"text":"80 Stat. 535","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8be29a0-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8be29a1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8be29a2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","c