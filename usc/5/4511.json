{"tag":"section","attrib":{"id":"idb82f0915-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4511"},"text":null,"children":[{"tag":"num","attrib":{"value":"4511"},"text":"§ 4511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition and general provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82f0916-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subchapter, the term “agency” means any Executive agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f0917-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A cash award under this subchapter is in addition to the regular pay of the recipient. Acceptance of a cash award under this subchapter constitutes an agreement that the use by the Government of an idea, method, or device for which the award is made does not form the basis of a further claim of any nature against the Government by the employee, his heirs, or assigns.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82f0918-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXVII/s1703/a"},"text":"Pub. L. 97–35, title XVII, § 1703(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/755"},"text":"95 Stat. 755","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82f0919-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82f091a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb82f091b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/s1703/c"},"text":"section 1703(c) of Pub. L. 97–35","children":[],"tail":", set out as an Effective Date of 1981 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s4501"},"text":"section 4501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb82f091c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority To Make Awards","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/487/s1/c"},"text":"Pub. L. 102–487, § 1(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3134"},"text":"106 Stat. 3134","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/487/s1/c"},"text":"“Awards may be made under subchapter II of chapter 45 of title 5, United States Code, on and after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
