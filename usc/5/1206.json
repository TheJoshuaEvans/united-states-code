{"tag":"section","attrib":{"id":"idb7e778a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1206"},"text":null,"children":[{"tag":"num","attrib":{"value":"1206"},"text":"§ 1206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board shall submit an annual report to the President and the Congress on its activities, which shall include a description of significant actions taken by the Board to carry out its functions under this title. The report shall also review the significant actions of the Office of Personnel Management, including an analysis of whether the actions of the Office of Personnel Management are in accord with merit system principles and free from prohibited personnel practices.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7e778a4-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tII/s202/a"},"text":"Pub. L. 95–454, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1131"},"text":"92 Stat. 1131","children":[],"tail":", § 1209(b); renumbered § 1206 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/12/s3/a/10"},"text":"Pub. L. 101–12, § 3(a)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-04-10"},"text":"Apr. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/18"},"text":"103 Stat. 18","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7e778a5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7e778a6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children