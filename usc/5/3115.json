{"tag":"section","attrib":{"id":"idb7ff4611-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115"},"text":null,"children":[{"tag":"num","attrib":{"value":"3115"},"text":"§ 3115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expedited hiring authority for college graduates; competitive service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7ff4612-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff4613-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Director” means the Director of the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4614-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Institution of higher education","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “institution of higher education” has the meaning given the term in section 101(a) of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1001/a"},"text":"20 U.S.C. 1001(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff4615-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff4616-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency may appoint, without regard to any provision of sections 3309 through 3319 and 3330, a qualified individual to a position in the competitive service classified in a professional or administrative occupational category at the GS–11 level, or an equivalent level, or below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4617-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restrictions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An appointment under paragraph (1) shall be made in accordance with regulations prescribed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff4618-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications for Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an agency may make an appointment under subsection (b) only if the individual being appointed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff4619-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has received a baccalaureate or graduate degree from an institution of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff461a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" applies for the position—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7ff461b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 2 years after the date on which the individual being appointed received the degree described in paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff461c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an individual who has completed a period of not less than 4 years of obligated service in a uniformed service, not later than 2 years after the date of the discharge or release of the individual from that service; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff461d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets each minimum qualification standard prescribed by the Director for the position to which the individual is being appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff461e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Notice and Advertising.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff461f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency making an appointment under subsection (b) shall publicly advertise positions under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4620-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out paragraph (1), the head of an agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7ff4621-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adhere to merit system principles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4622-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advertise positions in a manner that provides for diverse and qualified applicants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4623-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure potential applicants have appropriate information relevant to the positions available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff4624-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Appointments.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff4625-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the total number of employees that the head of an agency may appoint under this section during a fiscal year may not exceed the number equal to 15 percent of the number of individuals that the agency head appointed during the previous fiscal year to a position in the competitive service classified in a professional or administrative occupational category, at the GS–11 level, or an equivalent level, or below, under a competitive examining procedure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4626-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under a regulation prescribed under subsection (f), the Director may establish a lower limit on the number of individuals that may be appointed under paragraph (1) of this subsection during a fiscal year based on any factor the Director considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff4627-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of enactment of this section, the Director shall issue interim regulations, with an opportunity for comment, for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff4628-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff4629-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than September 30 of each of the first 3 fiscal years beginning after the date of enactment of this section, the head of an agency that makes an appointment under this section shall submit a report to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7ff462a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress that assesses the impact of the use of the authority provided under this section during the fiscal year in which the report is submitted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff462b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director that contains data that the Director considers necessary for the Director to assess the impact and effectiveness of the authority described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff462c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an agency shall include in each report under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7ff462d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of individuals appointed by the agency under this section, as well as the number of such individuals who are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7ff462e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minorities or members of other underrepresented groups; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7ff462f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" veterans;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4630-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4631-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of individuals appointed by the agency during the applicable fiscal year to a position in the competitive service classified in a professional or administrative occupational category at the GS–11 level, or an equivalent level, or below; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ff4632-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any additional data specified by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff4633-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Provision Regarding the Department of Defense.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff4634-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall preclude the Secretary of Defense from exercising any authority to appoint a recent graduate under section 1106 of the National Defense Authorization Act for Fiscal Year 2017 (10 U.S.C. note prec. 1580), or any applicable successor statute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4635-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3115/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any regulations prescribed by the Director for the administration of this section shall not apply to the Department of Defense during the period ending on the date on which the appointment authority of the Secretary of Defense under section 1106 of the National Defense Authorization Act for Fiscal Year 2017 (10 U.S.C. note prec. 1580), or any applicable successor statute, terminates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7ff4636-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXI/s1108/a"},"text":"Pub. L. 115–232, div. A, title XI, § 1108(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2006"},"text":"132 Stat. 2006","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7ff4637-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7ff4638-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb7ff4639-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"GS–11, referred to in subsecs. (b)(1), (e)(1), and (g)(2)(C), is contained in the General Schedule which is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsecs. (f) and (g)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1106 of the National Defense Authorization Act for Fiscal Year 2017, referred to in subsec. (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1106"},"text":"section 1106 of Pub. L. 114–328","children":[],"tail":", which is set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1580"},"text":"section 1580 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
