{"tag":"section","attrib":{"id":"idb7e52e03-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103"},"text":null,"children":[{"tag":"num","attrib":{"value":"1103"},"text":"§ 1103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of the Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7e52e04-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The following functions are vested in the Director of the Office of Personnel Management, and shall be performed by the Director, or subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1104"},"text":"section 1104 of this title","children":[],"tail":", by such employees of the Office as the Director designates:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7e52e05-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing accuracy, uniformity, and justice in the functions of the Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e52e06-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appointing individuals to be employed by the Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e52e07-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directing and supervising employees of the Office, distributing business among employees and organizational units of the Office, and directing the internal management of the Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e52e08-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directing the preparation of requests for appropriations for the Office and the use and expenditure of funds by the Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e52e09-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" executing, administering, and enforcing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7e52e0a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the civil service rules and regulations of the President and the Office and the laws governing the civil service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e52e0b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the other activities of the Office including retirement and classification activities;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except with respect to functions for which the Merit Systems Protection Board or the Special Counsel is primarily responsible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e52e0c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing the operations under chapter 87 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e52e0d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aiding the President, as the President may request, in preparing such civil service rules as the President prescribes, and otherwise advising the President on actions which may be taken to promote an efficient civil service and a systematic application of the merit system principles, including recommending policies relating to the selection, promotion, transfer, performance, pay, conditions of service, tenure, and separation of employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e52e0e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting, or otherwise providing for the conduct of, studies and research under chapter 47 of this title into methods of assuring improvements in personnel management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e52e0f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incurring official reception and representation expenses of the Office subject to any limitation prescribed in any law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7e52e10-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7e52e11-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall publish in the Federal Register general notice of any rule or regulation which is proposed by the Office and the application of which does not apply solely to the Office or its employees. Any such notice shall include the matter required under section 553(b)(1), (2), and (3) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e52e12-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director shall take steps to ensure that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7e52e13-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any proposed rule or regulation to which paragraph (1) of this subsection applies is posted in offices of Federal agencies maintaining copies of the Federal personnel regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e52e14-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent the Director determines appropriate and practical, exclusive representatives of employees affected by such proposed rule or regulation and interested members of the public are notified of such proposed rule or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e52e15-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (1) and (2) of this subsection shall not apply to any proposed rule or regulation which is temporary in nature and which is necessary to be implemented expeditiously as a result of an emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e52e16-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (1) and (2) of this subsection and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1105"},"text":"section 1105 of this title","children":[],"tail":" shall not apply to the establishment of any schedules or rates of basic pay or allowances under subpart D of part III of this title. The preceding sentence does not apply to the establishment of the procedures, methodology, or criteria used to establish such schedules, rates, or allowances."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7e52e17-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7e52e18-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall design a set of systems, including appropriate metrics, for assessing the management of human capital by Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7e52e19-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The systems referred to under paragraph (1) shall be defined in regulations of the Office of Personnel Management and include standards for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7e52e1a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7e52e1b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aligning human capital strategies of agencies with the missions, goals, and organizational objectives of those agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7e52e1c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrating those strategies into the budget and strategic plans of those agencies;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e52e1d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" closing skill gaps in mission critical occupations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e52e1e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring continuity of effective leadership through implementation of recruitment, development, and succession plans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e52e1f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustaining a culture that cultivates and develops a high performing workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e52e20-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and implementing a knowledge management strategy supported by appropriate investment in training and technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7e52e21-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1103/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holding managers and human resources officers accountable for efficient and effective human resources management in support of agency missions in accordance with merit system principles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7e52e22-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/399"},"text":"80 Stat. 399","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tII/s201/a"},"text":"Pub. L. 95–454, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1119"},"text":"92 Stat. 1119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/251/tIII"},"text":"Pub. L. 99–251, title III","children":[],"tail":", §§ 301, 302, "},{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/26"},"text":"100 Stat. 26","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1304"},"text":"Pub. L. 107–296, title XIII, § 1304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2289"},"text":"116 Stat. 2289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7e52e23-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7e52e24-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7e52e25-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"[Uncodified].","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"1949 Reorg. Plan No. 5, §§ 1, 2(a) (35th through 46th words), 3, eff. ","children":[{"tag":"html:span","attrib":{},"text":"Aug. 20, 1949","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/1067"},"text":"63 Stat. 1067","children":[],"tail":", 1069."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s632"},"text":"5 U.S.C. 632","children":[],"tail":" (5th par.)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-07-31/ch804/s201/b"},"text":"July 31, 1956, ch. 804, § 201(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/742"},"text":"70 Stat. 742","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7e52e26-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7e52e27-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/251/s301"},"text":"Pub. L. 99–251, § 301","children":[],"tail":", added par. (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/251/s302"},"text":"Pub. L. 99–251, § 302","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Functions of the Director” for “Chairman; Vice Chairman; Executive Director” in section catchline, and in text provisions relating to the functions of the Director of the Office of Personnel Management for provisions relating to the Chairman, Vice Chairman, and Executive Director of the United States Civil Service Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7e52e28-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7e52e29-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1305"},"text":"Pub. L. 107–296, title XIII, § 1305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2289"},"text":"116 Stat. 2289","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/296/tXIII/s1305"},"text":"“This subtitle [subtitle A (§§ 1301–1305) of title XIII of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":", enacting chapter 14 of this title, amending this section, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1401"},"text":"section 1401 of this title","children":[],"tail":"] shall take effect 180 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7e52e2a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
