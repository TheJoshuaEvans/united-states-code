{"tag":"section","attrib":{"id":"idb7fcfb79-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3105"},"text":null,"children":[{"tag":"num","attrib":{"value":"3105"},"text":"§ 3105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of administrative law judges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each agency shall appoint as many administrative law judges as are necessary for proceedings required to be conducted in accordance with sections 556 and 557 of this title. Administrative law judges shall be assigned to cases in rotation so far as practicable, and may not perform duties inconsistent with their duties and responsibilities as administrative law judges.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7fcfb7a-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/415"},"text":"80 Stat. 415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/251/s2/a/1"},"text":"Pub. L. 95–251, § 2(a)(1)","children":[],"tail":", (b)(2), (d)(1), "},{"tag":"date","attrib":{"date":"1978-03-27"},"text":"Mar. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/183"},"text":"92 Stat. 183","children":[],"tail":", 184.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7fcfb7b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7fcfb7c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7fcfb7d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"te