{"tag":"section","attrib":{"id":"idb8f761b7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8413"},"text":null,"children":[{"tag":"num","attrib":{"value":"8413"},"text":"§ 8413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deferred retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8f761b8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee or Member who is separated from the service, or transferred to a position in which the employee or Member does not continue subject to this chapter, after completing 5 years of service is entitled to an annuity beginning at the age of 62 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f761b9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f761ba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8413/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee or Member who is separated from the service, or transferred to a position in which the employee or Member does not continue subject to this chapter, after completing 10 years of service but before attaining the applicable minimum retirement age under section 8412(h) is entitled to an annuity beginning on the date designated by the employee or Member in a written election under this subsection. The date designated under this subsection may not precede the date on which the employee or Member attains such minimum retirement age and must precede the date on which the employee or Member becomes 62 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761bb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8413/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The election of an annuity under this subsection shall not be effective unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f761bc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8413/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is made at such time and in such manner as the Office shall by regulation prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f761bd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8413/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee or Member will not otherwise be eligible to receive an annuity within 31 days after filing the election.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761be-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8413/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The election of an annuity under this subsection extinguishes the right of the employee or Member to receive any other annuity based on the service on which the annuity under this subsection is based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8f761bf-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/525"},"text":"100 Stat. 525","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/556/tI/s105/b/1"},"text":"Pub. L. 99–556, title I, § 105(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3132"},"text":"100 Stat. 3132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8f761c0-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8f761c1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8f761c2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/556"},"text":"Pub. L. 99–556","children":[],"tail":" inserted “but before attaining the applicable minimum retirement age under section 8412(h)” in first sentence and substituted “such minimum retirement age” for “the applicable minimum retirement age under section 8412(h)” in second sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
