{"tag":"section","attrib":{"id":"idb86840ae-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524"},"text":null,"children":[{"tag":"num","attrib":{"value":"5524"},"text":"§ 5524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Review of accounts","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The head of each agency shall provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86840af-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the review of the account of each employee of the agency in receipt of payments under section 5522 or 5523 of this title, or both, as the case may be; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86840b0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the adjustment of the amounts of the payments on the basis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86840b1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rates of pay, allowances, and differentials to which the employee would have been entitled under applicable statute other than this subchapter for the respective periods covered by the payments, if he had performed active service under the terms of his appointment during each period in the position he held immediately before the issuance of the applicable evacuation order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86840b2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional amounts as the employee is authorized to receive in accordance with a determination of the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5523/b"},"text":"section 5523(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86840b3-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/481"},"text":"80 Stat. 481","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb86840b4-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb86840b5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb86840b6-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i",