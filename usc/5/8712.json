{"tag":"section","attrib":{"id":"idb913ea5c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8712"},"text":null,"children":[{"tag":"num","attrib":{"value":"8712"},"text":"§ 8712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual accounting; special contingency reserve","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A policy purchased under this chapter shall provide for an accounting to the Office of Personnel Management not later than 90 days after the end of each policy year. The accounting shall set forth, in a form approved by the Office—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb913ea5d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8712/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts of premiums actually accrued under the policy from its date of issue to the end of the policy year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb913ea5e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8712/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total of all mortality and other claim charges incurred for that period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb913ea5f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8712/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amounts of the insurers’ expense and risk charges for that period.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"An excess of the total of paragraph (1) of this section over the sum of paragraphs (2) and (3) of this section shall be held by the company issuing the policy as a special contingency reserve to be used by the company only for charges under the policy. The reserve shall bear interest at a rate determined in advance of each policy year by the company and approved by the Office as being consistent with the rates generally used by the company for similar funds held under other group life insurance policies. When the Office determines that the special contingency reserve has attained an amount estimated by it to make satisfactory provision for adverse fluctuations in future charges under the policy, any further excess shall be deposited in the Treasury of the United States to the credit of the Employees’ Life Insurance Fund. When a policy is discontinued, any balance remaining in the special contingency reserve after all charges have been made shall be deposited in the Treasury to the credit of the Fund. The company may make the deposit in equal monthly installments over a period of not more than 2 years.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb913ea60-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/598"},"text":"80 Stat. 598","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/a/2"},"text":"Pub. L. 95–454, title IX, § 906(a)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1224"},"text":"92 Stat. 1224","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb913ea61-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb913ea62-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb913ea63-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s2097/d"},"text":"5 U.S.C. 2097(d)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-08-17/ch752/s8/d"},"text":"Aug. 17, 1954, ch. 752, § 8(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/741"},"text":"68 Stat. 741","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “A policy purchased under this chapter” are substituted for “Each such policy” for clarity. The word “insurance”, preceding the word “company”, is omitted as unnecessary; and the word “company” is substituted for “company or companies” on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"1 U.S.C. 1","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “Employees’ Life Insurance Fund” are substituted for “fund”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb913ea64-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb913ea65-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Office of Personnel Management” and “Office” for “Civil Service Commission” and “Commission”, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb913ea66-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb913ea67-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
