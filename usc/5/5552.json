{"tag":"section","attrib":{"id":"idb87427f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5552"},"text":null,"children":[{"tag":"num","attrib":{"value":"5552"},"text":"§ 5552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lump-sum payment for accumulated and accrued leave on entering active duty; election","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":" or an individual employed by a territory or possession of the United States or the government of the District of Columbia who enters on active duty in the armed forces is entitled to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb87427fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5552/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive, in addition to his pay and allowances from the armed forces, a lump-sum payment for accumulated and current accrued annual or vacation leave in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5551"},"text":"section 5551 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb87427fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5552/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elect to have the leave remain to his credit until his return from active duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb87427fc-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/489"},"text":"80 Stat. 489","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb87427fd-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb87427fe-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb87427ff-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s61a"},"text":"5 U.S.C. 61a","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1941-08-01/ch348"},"text":"Aug. 1, 1941, ch. 348","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/55/616"},"text":"55 Stat. 616","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-04-07/ch220"},"text":"Apr. 7, 1942, ch. 220","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/200"},"text":"56 Stat. 200","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “An employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":"” are coextensive with and substituted for “Employees of the United States Government, . . . (including employees of any corporation created under authority of an Act of Congress which is either wholly controlled or wholly owned by the United States Government, or any corporation, all the stock of which is owned or controlled by the United States Government, or any department, agency, or establishment thereof, whether or not the employees thereof are paid from funds appropriated by Congress)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “subsequent to ","children":[{"tag":"date","attrib":{"date":"1940-05-01"},"text":"May 1, 1940","children":[],"tail":"” are omitted as obsolete. The words “active duty in the armed forces” and “active duty” are substituted for “active military or naval service in the land or naval forces of the United States” and “active military or naval service”, respectively, on authority of the National Security Act of 1947, "},{"tag":"ref","attrib":{"href":"/us/stat/61/495"},"text":"61 Stat. 495","children":[],"tail":", as amended. The words “by voluntary enlistment or otherwise” are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1), the words “in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5551"},"text":"section 5551 of this title","children":[],"tail":"” are added on authority of former section 61b, which is carried into section 5551."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
