href":"/us/stat/76/264"},"text":"76 Stat. 264","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the exception for the President and Vice President is omitted as surplusage as these elected officers are not employed in or under an agency and thus are not included in the definition of “employee” in section 4101(2).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(C), the words “as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s231/a"},"text":"section 231(a) of Title 37","children":[],"tail":"” are omitted as unnecessary in view of the definition of “uniformed services” in section 2101(b). The words “"},{"tag":"ref","attrib":{"href":"/us/usc/t37/s204"},"text":"section 204 of title 37","children":[],"tail":"” are substituted for “sections 232–234, 235, 236, 237, 238, and 239 of Title 37” on authority of "},{"tag":"ref","attrib":{"href":"/us/act/1962-09-07/s12/b"},"text":"section 12(b) of the Act of Sept. 7, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/649"},"text":"Pub. L. 87–649","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/497"},"text":"76 Stat. 497","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(B), the words “by the President” are coextensive with and substituted for “by the President by and with the advice and consent of the Senate or by the President alone”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), reference to “section 21, and section 22” is omitted as unnecessary since the sections are not carried into this title, but are scheduled for repeal, see Table II.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8256c98-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8256c99-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/19"},"text":"Pub. L. 96–54, § 2(a)(19)","children":[],"tail":", substituted “National Oceanic and Atmospheric” for “Environmental Science Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/15"},"text":"Pub. L. 96–54, § 2(a)(15)","children":[],"tail":", substituted “Office” for “Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Office of Personnel Management” for “Civil Service Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/183"},"text":"Pub. L. 94–183","children":[],"tail":" struck out “(except a Postmaster)” after “an individual appointed by the President”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83"},"text":"Pub. L. 90–83","children":[],"tail":" substituted “Environmental Science Services Administration” for “Coast and Geodetic Survey.” See Historical and Revision Notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2101"},"text":"section 2101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"