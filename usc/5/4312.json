{"tag":"section","attrib":{"id":"idb82c9825-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312"},"text":null,"children":[{"tag":"num","attrib":{"value":"4312"},"text":"§ 4312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senior Executive Service performance appraisal systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82c9826-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each agency shall, in accordance with standards established by the Office of Personnel Management, develop one or more performance appraisal systems designed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82c9827-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the accurate evaluation of performance in any position on the basis of criteria which are related to the position and which specify the critical elements of the position;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c9828-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for systematic appraisals of performance of senior executives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c9829-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage excellence in performance by senior executives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c982a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a basis for making eligibility determinations for retention in the Senior Executive Service and for Senior Executive Service performance awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82c982b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each performance appraisal system established by an agency under subsection (a) of this section shall provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82c982c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that, on or before the beginning of each rating period, performance requirements for each senior executive in the agency are established in consultation with the senior executive and communicated to the senior executive;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c982d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that written appraisals of performance are based on the individual and organizational performance requirements established for the rating period involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c982e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that each senior executive in the agency is provided a copy of the appraisal and rating under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4314"},"text":"section 4314 of this title","children":[],"tail":" and is given an opportunity to respond in writing and have the rating reviewed by an employee, or (with the consent of the senior executive) a commissioned officer in the uniformed services serving on active duty, in a higher level in the agency before the rating becomes final."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82c982f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82c9830-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall review each agency’s performance appraisal system under this section, and determine whether the agency performance appraisal system meets the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c9831-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General shall from time to time review performance appraisal systems under this section to determine the extent to which any such system meets the requirements under this subchapter and shall periodically report its findings to the Office and to each House of the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c9832-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Office determines that an agency performance appraisal system does not meet the requirements under this subchapter (including regulations prescribed under section 4315), the agency shall take such corrective action as may be required by the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82c9833-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4312/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A senior executive may not appeal any appraisal and rating under any performance appraisal system under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82c9834-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIV/s405/a"},"text":"Pub. L. 95–454, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1167"},"text":"92 Stat. 1167","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/tIII/s306/b/2"},"text":"Pub. L. 98–615, title III, § 306(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3220"},"text":"98 Stat. 3220","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82c9835-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb82c9836-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb82c9837-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" inserted “, or (with the consent of the senior executive) a commissioned officer in the uniformed services serving on active duty,” and directed that “executive” be struck out which was executed by striking “executive” only where it appeared before “level in the agency”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82c9838-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82c9839-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" effective following expiration of 90-day period beginning on "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/s307"},"text":"section 307 of Pub. L. 98–615","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393"},"text":"section 3393 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb82c983a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 9 months after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", and congressional review of provisions of sections 401 through 412 of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", see section 415(a)(1), (b), of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3131"},"text":"section 3131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
