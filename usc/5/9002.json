{"tag":"section","attrib":{"id":"idb924b38f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9002"},"text":null,"children":[{"tag":"num","attrib":{"value":"9002"},"text":"§ 9002.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of insurance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb924b390-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9002/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office of Personnel Management shall establish and, in consultation with the appropriate Secretaries, administer a program through which an individual described in paragraph (1), (2), (3), (4), or (5) of section 9001 may obtain long-term care insurance coverage under this chapter for such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b391-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9002/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discretionary Authority Regarding Nonappropriated Fund Instrumentalities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense may determine that a nonappropriated fund instrumentality of the Department of Defense is covered under this chapter or is covered under an alternative long-term care insurance program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b392-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9002/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Long-term care insurance may not be offered under this chapter unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb924b393-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9002/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the only coverage provided is under qualified long-term care insurance contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b394-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9002/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each insurance contract under which any such coverage is provided is issued by a qualified carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b395-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9002/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Documentation Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As a condition for obtaining long-term care insurance coverage under this chapter based on one’s status as a qualified relative, an applicant shall provide documentation to demonstrate the relationship, as prescribed by the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b396-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9002/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Underwriting Standards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb924b397-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9002/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disqualifying condition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this chapter shall be considered to require that long-term care insurance coverage be made available in the case of any individual who would be eligible for benefits immediately.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b398-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9002/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Spousal parity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of underwriting standards, a spouse of an individual described in paragraph (1), (2), (3), or (4) of section 9001 shall, as nearly as practicable, be treated like that individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b399-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9002/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guaranteed issue","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this chapter shall be considered to require that long-term care insurance coverage be guaranteed to an eligible individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b39a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9002/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement that contract be fully insured","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to the requirements otherwise applicable under section 9001(9), in order to be considered a qualified long-term care insurance contract for purposes of this chapter, a contract must be fully insured, whether through reinsurance with other companies or otherwise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b39b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9002/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Higher standards allowable","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this chapter shall, in the case of an individual applying for long-term care insurance coverage under this chapter after the expiration of such individual’s first opportunity to enroll, preclude the application of underwriting standards more stringent than those that would have applied if that opportunity had not yet expired.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b39c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9002/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guaranteed Renewability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The benefits and coverage made available to eligible individuals under any insurance contract under this chapter shall be guaranteed renewable (as defined by section 7A(2) of the model regulations described in section 7702B(g)(2) of the Internal Revenue Code of 1986), including the right to have insurance remain in effect so long as premiums continue to be timely made. However, the authority to revise premiums under this chapter shall be available only on a class basis and only to the extent otherwise allowable under section 9003(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb924b39d-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/265/tI/s1002/a"},"text":"Pub. L. 106–265, title I, § 1002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-19"},"text":"Sept. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/764"},"text":"114 Stat. 764","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tXI/s1101/b"},"text":"Pub. L. 107–314, div. A, title XI, § 1101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2660"},"text":"116 Stat. 2660","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb924b39e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb924b39f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb924b3a0-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 7702B(g)(2) of the Internal Revenue Code of 1986, referred to in subsec. (f), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7702B/g/2"},"text":"section 7702B(g)(2) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb924b3a1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsecs. (b) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" added subsec. (b) and redesignated former subsecs. (b) to (e) as (c) to (f), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
