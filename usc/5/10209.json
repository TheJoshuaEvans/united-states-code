{"tag":"section","attrib":{"id":"idb9309a5a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10209"},"text":null,"children":[{"tag":"num","attrib":{"value":"10209"},"text":"§ 10209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Clothing allowances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9309a5b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10209/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to the benefits provided under section 5901, the Director of the United States Secret Service or the designee of the Director is authorized to provide a clothing allowance to a member assigned to perform duties in normal business or work attire purchased at the discretion of the employee. Such clothing allowance shall not to be treated as part of the member’s basic pay for any purpose (including retirement purposes) and shall not be used for the purpose of computing the member’s overtime pay, pay during leave or other paid time off, lump-sum payments under section 5551 or section 5552, workers’ compensation, or any other benefit. Such allowance for any member may be discontinued at any time upon written notification by the Director of the United States Secret Service or the designee of the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9309a5c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10209/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Amount Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A clothing allowance authorized under this section shall not exceed $500 per annum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9309a5d-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/282/s2/a"},"text":"Pub. L. 111–282, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3037"},"text":"124 Stat. 3037","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9309a5e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9309a5f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9309a60-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of first pay period which begins after ","children":[{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/282/s5"},"text":"section 5 of Pub. L. 111–282","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5102"},"text":"section 5102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
