{"tag":"section","attrib":{"id":"idb89592ed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6129"},"text":null,"children":[{"tag":"num","attrib":{"value":"6129"},"text":"§ 6129.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of leave and retirement provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For purposes of administering sections 6303(a), 6304, 6307(a) and (d), 6323, 6326, 6327, and 8339(m) of this title, in the case of an employee who is in any program under this subchapter, references to a day or workday (or to multiples or parts thereof) contained in such sections shall be considered to be references to 8 hours (or to the respective multiples or parts thereof).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb89592ee-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/221/s2/a/2"},"text":"Pub. L. 97–221, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-23"},"text":"July 23, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/231"},"text":"96 Stat. 231","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/329/tVI/s629/a/2/A"},"text":"Pub. L. 103–329, title VI, § 629(a)(2)(A)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"Sept. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2423"},"text":"108 Stat. 2423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb89592ef-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89592f0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":nu