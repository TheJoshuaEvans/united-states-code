{"tag":"section","attrib":{"id":"idb8198563-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349c"},"text":null,"children":[{"tag":"num","attrib":{"value":"3349c"},"text":"§ 3349c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusion of certain officers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Sections 3345 through 3349b shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8198564-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any member who is appointed by the President, by and with the advice and consent of the Senate to any board, commission, or similar entity that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8198565-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is composed of multiple members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8198566-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" governs an independent establishment or Government corporation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198567-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any commissioner of the Federal Energy Regulatory Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198568-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any member of the Surface Transportation Board; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198569-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any judge appointed by the President, by and with the advice and consent of the Senate, to a court constituted under article I of the United States Constitution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb819856a-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s151/b"},"text":"Pub. L. 105–277, div. C, title I, § 151(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-615"},"text":"112 Stat. 2681–615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb819856b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb819856c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb819856d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 30 days after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", and applicable to any office that becomes vacant after such effective date, with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s151/d"},"text":"section 151(d) of Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3345"},"text":"section 3345 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
