{"tag":"section","attrib":{"id":"idb8a17a9c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506"},"text":null,"children":[{"tag":"num","attrib":{"value":"6506"},"text":"§ 6506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a17a9d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “executive agency” shall not include the Government Accountability Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a9e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports by the Office of Personnel Management.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a17a9f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after the date of enactment of this chapter and on an annual basis thereafter, the Director of the Office of Personnel Management, in consultation with Chief ","children":[{"tag":"ref","attrib":{"idref":"fn002131"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002131"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “the”."}],"tail":" Human Capital Officers Council, shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17aa0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit a report addressing the telework programs of each executive agency to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8a17aa1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8a17aa2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Oversight and Government Reform of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17aa3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit a copy of the report to the Comptroller General and the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17aa4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17aa5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the degree of participation by employees of each executive agency in teleworking during the period covered by the report (and for each executive agency whose head is referred to under section 5312, the degree of participation in each bureau, division, or other major administrative unit of that agency), including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8a17aa6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of employees in the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8a17aa7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and percent of employees in the agency who are eligible to telework; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8a17aa8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number and percent of eligible employees in the agency who are teleworking—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8a17aa9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 or more days per pay period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8a17aaa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or 2 days per pay period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8a17aab-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" once per month; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8a17aac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/A/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on an occasional, episodic, or short-term basis;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17aad-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method for gathering telework data in each agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17aae-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the total number of employees teleworking is 10 percent higher or lower than the previous year in any agency, the reasons for the positive or negative variation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17aaf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency goal for increasing participation to the extent practicable or necessary for the next reporting period, as indicated by the percent of eligible employees teleworking in each frequency category described under subparagraph (A)(iii);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17ab0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of whether or not the agency met the goals for the last reporting period and, if not, what actions are being taken to identify and eliminate barriers to maximizing telework opportunities for the next reporting period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17ab1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of the progress each agency has made in meeting agency participation rate goals during the reporting period, and other agency goals relating to telework, such as the impact of telework on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8a17ab2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency readiness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8a17ab3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" energy use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8a17ab4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/F/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recruitment and retention;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8a17ab5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/F/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8a17ab6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/F/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" productivity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8a17ab7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/F/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employee attitudes and opinions regarding telework; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17ab8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the best practices in agency telework programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17ab9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comptroller General Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a17aba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report on government accountability office telework program.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17abb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after the date of enactment of this chapter and on an annual basis thereafter, the Comptroller General shall submit a report addressing the telework program of the Government Accountability Office to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8a17abc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8a17abd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Oversight and Government Reform of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17abe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report submitted by the Comptroller General shall include the same information as required under subsection (b) applicable to the Government Accountability Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17abf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to congress on office of personnel management report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 6 months after the submission of the first report to Congress required under subsection (b), the Comptroller General shall review that report required under subsection (b) and submit a report to Congress on the progress each executive agency has made towards the goals established under section 6504(b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17ac0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chief Human Capital Officer Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a17ac1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each year the Chief Human Capital Officer of each executive agency, in consultation with the Telework Managing Officer of that agency, shall submit a report to the Chair and Vice Chair of the Chief Human Capital Officers Council on agency management efforts to promote telework.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17ac2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review and inclusion of relevant information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chair and Vice Chair of the Chief Human Capital Officers Council shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17ac3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the reports submitted under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17ac4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include relevant information from the submitted reports in the annual report to Congress required under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17ac5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6506/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use that relevant information for other purposes related to the strategic management of human capital.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a17ac6-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/292/s2/a"},"text":"Pub. L. 111–292, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3169"},"text":"124 Stat. 3169","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a17ac7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a17ac8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8a17ac9-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this chapter, referred to in subsecs. (b)(1) and (c)(1)(A), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/292"},"text":"Pub. L. 111–292","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a17aca-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb8a17acb-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
