attrib":{"href":"/us/stat/80/526"},"text":"80 Stat. 526","children":[],"tail":", authorized nonpartisan political activities, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/94"},"text":"Pub. L. 103–94","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 7327, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/526"},"text":"80 Stat. 526","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/14"},"text":"Pub. L. 96–54, § 2(a)(14)","children":[],"tail":", (15), "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/382"},"text":"93 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/468/tVI/s615/b/1/E"},"text":"Pub. L. 97–468, title VI, § 615(b)(1)(E)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2578"},"text":"96 Stat. 2578","children":[],"tail":", related to permitted political activity in certain municipalities where employees reside, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/94"},"text":"Pub. L. 103–94","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 7328, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/191/s8/e/1"},"text":"Pub. L. 96–191, § 8(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-02-15"},"text":"Feb. 15, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/33"},"text":"94 Stat. 33","children":[],"tail":", exempted employees of the General Accounting Office from provisions of this subchapter, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/94"},"text":"Pub. L. 103–94","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8b21c0a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “An employee or individual who violates section 7323 or 7324 shall be subject to removal, reduction in grade, debarment from Federal employment for a period not to exceed 5 years, suspension, reprimand, or an assessment of a civil penalty not to exceed $1,000.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b21c0b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b21c0c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment; Applicability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1097/k/2"},"text":"Pub. L. 115–91, div. A, title X, § 1097(k)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1626"},"text":"131 Stat. 1626","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/91/dA/tX/s1097/k/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply to any violation of section 7323 or 7324 of title 5, United States Code, occurring after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8b21c0d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date; Applicability","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 30 days after ","children":[{"tag":"date","attrib":{"date":"2012-12-28"},"text":"Dec. 28, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/230/s5/a"},"text":"section 5(a) of Pub. L. 112–230","children":[],"tail":", set out as an Effective Date of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1501"},"text":"section 1501 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/230/s5/b"},"text":"Pub. L. 112–230, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-28"},"text":"Dec. 28, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1617"},"text":"126 Stat. 1617","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/230/s5/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the amendment made by section 4 [enacting this section and repealing former ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7326"},"text":"section 7326 of this title","children":[],"tail":"] shall apply with respect to any violation occurring before, on, or after the effective date of this Act [see above]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendment made by section 4 shall not apply with respect to an alleged violation if, before the effective date of this Act—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Special Counsel has presented a complaint for disciplinary action, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1215"},"text":"section 1215 of title 5","children":[],"tail":", United States Code, with respect to the alleged violation; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee alleged to have committed the violation has entered into a signed settlement agreement with the Special Counsel with respect to the alleged violation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
