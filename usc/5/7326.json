{"tag":"section","attrib":{"id":"idb8b21c02-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7326"},"text":null,"children":[{"tag":"num","attrib":{"value":"7326"},"text":"§ 7326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An employee or individual who violates section 7323 or 7324 shall be subject to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b21c03-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7326/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disciplinary action consisting of removal, reduction in grade, debarment from Federal employment for a period not to exceed 5 years, suspension, or reprimand;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21c04-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7326/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of a civil penalty not to exceed $1,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21c05-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7326/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of the penalties described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b21c06-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/230/s4"},"text":"Pub. L. 112–230, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-28"},"text":"Dec. 28, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1617"},"text":"126 Stat. 1617","children":[],"tail":"; 