{"tag":"section","attrib":{"id":"idb89cbf9c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333"},"text":null,"children":[{"tag":"num","attrib":{"value":"6333"},"text":"§ 6333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Receipt and use of transferred leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89cbf9d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbf9e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An application to receive donations of leave under this subchapter, whether submitted by or on behalf of an employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89cbf9f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be submitted to the employing agency of the proposed leave recipient; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89cbfa0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb89cbfa1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name, position title, and grade or pay level of the proposed leave recipient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb89cbfa2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons why transferred leave is needed, including a brief description of the nature, severity, anticipated duration, and, if it is a recurring one, the approximate frequency of the medical emergency involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb89cbfa3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the employing agency so requires, certification from 1 or more physicians, or other appropriate experts, with respect to any matter under clause (ii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb89cbfa4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information which the employing agency may reasonably require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbfa5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an agency requires that an employee obtain certification under paragraph (1)(B)(iii) from 2 or more sources, the agency shall ensure, either by direct payment to the expert involved or by reimbursement, that the employee is not required to pay for the expenses associated with obtaining certification from more than 1 of such sources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbfa6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employing agency shall approve or disapprove an application of a proposed leave recipient for leave under this subchapter, and, to the extent practicable, shall notify the proposed leave recipient (or other person acting on behalf of the proposed recipient, if appropriate) of the decision of the agency, in writing, within 10 days (excluding Saturdays, Sundays, and legal public holidays) after receiving such application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbfa7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbfa8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A leave recipient may use annual leave received under this subchapter in the same manner and for the same purposes as if such leave recipient had accrued that leave under section 6303, except that any annual leave, and any sick leave, accrued or accumulated by the leave recipient and available for the purpose involved must be exhausted before any transferred annual leave may be used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f0899-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89f089a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The requirement under paragraph (1) relating to exhaustion of annual and sick leave shall not apply in the case of a leave recipient who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb89f089b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustains a combat-related disability while a member of the armed forces, including a reserve component of the armed forces; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb89f089c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is undergoing medical treatment for that disability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89f089d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraph (A) shall apply to a member described in such subparagraph only so long as the member continues to undergo medical treatment for the disability, but in no event for longer than 5 years from the start of such treatment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89f089e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this paragraph—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb89f089f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “combat-related disability” has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1413a/e"},"text":"section 1413a(e) of title 10","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb89f08a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “medical treatment” has such meaning as the Office of Personnel Management shall by regulation prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89f08a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Transferred annual leave—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89f08a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may accumulate without regard to any limitation under section 6304; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f08a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6333/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be substituted retroactively for any period of leave without pay, or used to liquidate an indebtedness for any period of advanced leave, which began on or after a date fixed by the employing agency of the employee as the beginning of the medical emergency involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89f08a4-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/566/s2/a"},"text":"Pub. L. 100–566, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2834"},"text":"102 Stat. 2834","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXVI/s1675/a"},"text":"Pub. L. 110–181, div. A, title XVI, § 1675(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/484"},"text":"122 Stat. 484","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb89f08a5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89f08a6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb89f08a7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb89f08a8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb89f08a9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXVI/s1675/b"},"text":"Pub. L. 110–181, div. A, title XVI, § 1675(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/484"},"text":"122 Stat. 484","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/181/dA/tXVI/s1675/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":"], except that, in the case of a leave recipient who is undergoing medical treatment on such date of enactment, "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6333/b/2/B"},"text":"section 6333(b)(2)(B) of title 5","children":[],"tail":", United States Code (as amended by this section) shall be applied as if it had been amended by inserting ‘or the date of the enactment of this subsection [probably should be “paragraph”], whichever is later’ after ‘the start of such treatment’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
