{"tag":"section","attrib":{"id":"idb82c9848-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314"},"text":null,"children":[{"tag":"num","attrib":{"value":"4314"},"text":"§ 4314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ratings for performance appraisals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82c9849-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each performance appraisal system shall provide for annual summary ratings of levels of performance as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82c984a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one or more fully successful levels,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c984b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a minimally satisfactory level, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c984c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unsatisfactory level.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82c984d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each performance appraisal system shall provide that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82c984e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any appraisal and any rating under such system—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82c984f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are made only after review and evaluation by a performance review board established under subsection (c) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82c9850-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are conducted at least annually, subject to the limitation of subsection (c)(3) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82c9851-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a career appointee, may not be made within 120 days after the beginning of a new Presidential administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82c9852-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are based on performance during a performance appraisal period the duration of which shall be determined under guidelines established by the Office of Personnel Management, but which may be terminated in any case in which the agency making an appraisal determines that an adequate basis exists on which to appraise and rate the senior executive’s performance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c9853-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any career appointee receiving a rating at any of the fully successful levels under subsection (a)(1) of this section may be given a performance award under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5384"},"text":"section 5384 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c9854-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any senior executive receiving an unsatisfactory rating under subsection (a)(3) of this section shall be reassigned or transferred within the Senior Executive Service, or removed from the Senior Executive Service, but any senior executive who receives 2 unsatisfactory ratings in any period of 5 consecutive years shall be removed from the Senior Executive Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c9855-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any senior executive who twice in any period of 3 consecutive years receives less than fully successful ratings shall be removed from the Senior Executive Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82c9856-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82c9857-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each agency shall establish, in accordance with regulations prescribed by the Office, one or more performance review boards, as appropriate. It is the function of the boards to make recommendations to the appropriate appointing authority of the agency relating to the performance of senior executives in the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c9858-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The supervising official of the senior executive shall provide to the performance review board, an initial appraisal of the senior executive’s performance. Before making any recommendation with respect to the senior executive, the board shall review any response by the senior executive to the initial appraisal and conduct such further review as the board finds necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c9859-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Performance appraisals under this subchapter with respect to any senior executive shall be made by the appointing authority only after considering the recommendations by the performance review board with respect to such senior executive under paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c985a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of performance review boards shall be appointed in such a manner as to assure consistency, stability, and objectivity in performance appraisal. Notice of the appointment of an individual to serve as a member shall be published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c985b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4314/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an appraisal of a career appointee, more than one-half of the members of the performance review board shall consist of career appointees. The requirement of the preceding sentence shall not apply in any case in which the Office determines that there exists an insufficient number of career appointees available to comply with the requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82c985c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIV/s405/a"},"text":"Pub. L. 95–454, title IV, § 405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1169"},"text":"92 Stat. 1169","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tII/s2181/b"},"text":"Pub. L. 104–66, title II, § 2181(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/732"},"text":"109 Stat. 732","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82c985d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb82c985e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb82c985f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" struck out subsec. (d) which related to reports to Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82c9860-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb82c9861-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 9 months after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", and congressional review of provisions of sections 401 through 412 of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", see section 415(a)(1), (b), of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3131"},"text":"section 3131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
