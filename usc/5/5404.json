{"tag":"section","attrib":{"id":"idb8611525-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5404"},"text":null,"children":[{"tag":"num","attrib":{"value":"5404"},"text":"§ 5404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Human capital performance payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8611526-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8611527-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5404/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, the Office may authorize an agency to provide human capital performance payments to individual employees based on exceptional performance contributing to the achievement of the agency mission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8611528-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5404/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of employees in an agency receiving payments from the Fund, in any year, shall not be more than the number equal to 15 percent of the agency’s average total civilian full- and part-time permanent employment for the previous fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8611529-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb861152a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5404/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A human capital performance payment provided to an individual employee from the Fund, in any year, shall not exceed 10 percent of the employee’s rate of basic pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb861152b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5404/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate of an employee’s rate of basic pay, adjusted by any locality-based comparability payments, and human capital performance pay, as defined by regulation, may not exceed the rate of basic pay for Executive Level IV in any year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb861152c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5404/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any human capital performance payment provided to an employee from the Fund is in addition to any annual pay adjustment (under section 5303 or any similar provision of law) and any locality-based comparability payment that may apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb861152d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No monies from the Human Capital Performance Fund may be used to pay for a new position, for other performance-related payments, or for recruitment or retention incentives paid under sections 5753 and 5754.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb861152e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5404/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb861152f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5404/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency may finance initial human capital performance payments using monies from the Human Capital Performance Fund, as available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8611530-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5404/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In subsequent years, continuation of previously awarded human capital performance payments shall be financed from other agency funds available for salaries and expenses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8611531-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXI/s1129/a"},"text":"Pub. L. 108–136, div. A, title XI, § 1129(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1643"},"text":"117 Stat. 1643","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8611532-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8611533-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8611534-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Level IV, referred to in subsec. (b)(2), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8611535-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5404, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tV/s501"},"text":"Pub. L. 95–454, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1183"},"text":"92 Stat. 1183","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/tII/s201/a"},"text":"Pub. L. 98–615, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3210"},"text":"98 Stat. 3210","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/103/s3/a"},"text":"Pub. L. 101–103, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-09-30"},"text":"Sept. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/670"},"text":"103 Stat. 670","children":[],"tail":", related to merit increases, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/89/s3/a/1"},"text":"Pub. L. 103–89, § 3(a)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"Sept. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/981"},"text":"107 Stat. 981","children":[],"tail":", 983, eff. "},{"tag":"date","attrib":{"date":"1993-11-01"},"text":"Nov. 1, 1993","children":[],"tail":"."}],"tail":"\n"}]