{"tag":"section","attrib":{"id":"idb89f0979-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6373"},"text":null,"children":[{"tag":"num","attrib":{"value":"6373"},"text":"§ 6373.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to participate in both programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89f097a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6373/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall prescribe regulations under which an employee participating in a leave bank program under this subchapter may, subject to such terms or conditions as the Office may establish, also make or receive donations of leave under subchapter III.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89f097b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6373/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any provision of section 6337 or 6371, if an employee uses leave transferred to such employee under subchapter III and leave made available to such employee under this subchapter in connection with the same medical emergency, the maximum number of days of annual leave and sick leave, respectively, which may accrue to such employee in connection with such medical emergency shall be the same as if all of that leave had been made available to such employee under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89f097c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/566/s2/a"},"text":"Pub. L. 100–566, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2843"},"text":"102 Stat. 2843","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/103/s5/a/1"},"text":"Pub. L. 103–103, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-08"},"text":"Oct. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1023"},"text":"107 Stat. 1023","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb89f097d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89f097e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb89f097f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/103"},"text":"Pub. L. 103–103","children":[],"tail":" substituted “Authority to participate in both programs” for “Limitation on employee participation” in section catchline and amended text generally. Prior to amendment, text read as follows: “An employee in a unit of an agency that establishes a leave bank program under the provisions of this subchapter may not participate in a leave transfer program under the provisions of subchapter III.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb89f0980-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb89f0981-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/103"},"text":"Pub. L. 103–103","children":[],"tail":" effective as of the 120th day after "},{"tag":"date","attrib":{"date":"1993-10-08"},"text":"Oct. 8, 1993","children":[],"tail":", or such earlier date as the Office of Personnel Management may by regulation prescribe, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/103/s6"},"text":"section 6 of Pub. L. 103–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6331"},"text":"section 6331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
