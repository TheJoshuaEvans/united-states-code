{"tag":"section","attrib":{"id":"idb924b403-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9009"},"text":null,"children":[{"tag":"num","attrib":{"value":"9009"},"text":"§ 9009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost accounting standards","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The cost accounting standards issued pursuant to section 1502(a) and (b) of title 41 shall not apply with respect to a long-term care insurance contract under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb924b404-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/265/tI/s1002/a"},"text":"Pub. L. 106–265, title I, § 1002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-19"},"text":"Sept. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/769"},"text":"114 Stat. 769","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/a/19"},"text":"Pub. L. 111–350, § 5(a)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3842"},"text":"124 Stat. 3842","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb924b405-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb924b406-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb924b407-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":