{"tag":"section","attrib":{"id":"idb79fe854-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420"},"text":null,"children":[{"tag":"num","attrib":{"value":"420"},"text":"§ 420.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information on websites of Offices of Inspectors General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb79fe855-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Direct Links to Inspectors General Offices.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79fe856-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each Federal agency and designated Federal entity shall establish and maintain on the homepage of the website of that Federal agency or designated Federal entity, a direct link to the website of the Office of the Inspector General of that Federal agency or designated Federal entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79fe857-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accessibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The direct link under paragraph (1) shall be obvious and facilitate accessibility to the website of the Office of the Inspector General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79fe858-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Inspectors General Websites.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb79fe859-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Posting of reports and audits","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Inspector General of each Federal agency and designated Federal entity shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79fe85a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 3 days after any audit report, inspection report, or evaluation report (or portion of any such report) is submitted in final form to the head of the Federal agency or the head of the designated Federal entity, as applicable, post that report (or portion of that report) on the website of the Office of Inspector General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79fe85b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that any posted report (or portion of that report) described under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb79fe85c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is easily accessible from a direct link on the homepage of the website of the Office of the Inspector General;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79fe85d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a summary of the findings of the Inspector General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb79fe85e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is in a format that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb79fe85f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/b/1/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is searchable and downloadable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb79fe860-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/b/1/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitates printing by individuals of the public accessing the website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79fe861-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting of fraud, waste, and abuse.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb79fe862-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inspector General of each Federal agency and designated Federal entity shall establish and maintain a direct link on the homepage of the website of the Office of the Inspector General for individuals to report fraud, waste, and abuse. Individuals reporting fraud, waste, or abuse using the direct link established under this paragraph shall not be required to provide personally identifying information relating to that individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb79fe863-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Anonymity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inspector General of each Federal agency and designated Federal entity shall not disclose the identity of any individual making a report under this paragraph without the consent of the individual unless the Inspector General determines that such a disclosure is unavoidable during the course of the investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb79fe864-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection shall be construed as authorizing an Inspector General to publicly disclose information otherwise prohibited from disclosure by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79fe865-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s420/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms “designated Federal entity” and “head of the designated Federal entity” have the meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s415/a"},"text":"section 415(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb79fe866-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/b"},"text":"Pub. L. 117–286, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4251"},"text":"136 Stat. 4251","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb79fe867-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb79fe868-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb79fe869-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"420","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 U.S.C. App. (IGA § 8M)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/452/s8M"},"text":"Pub. L. 95–452, § 8M","children":[],"tail":", formerly § 8L, as added "},{"tag":"html:a","attrib":{"href":"/us/pl/110/409/s13/a"},"text":"Pub. L. 110–409, § 13(a)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/122/4315"},"text":"122 Stat. 4315","children":[],"tail":"; renumbered § 8M, "},{"tag":"html:a","attrib":{"href":"/us/pl/112/239/dA/tVIII/s848/1"},"text":"Pub. L. 112–239, div. A, title VIII, § 848(1)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/126/1851"},"text":"126 Stat. 1851","children":[],"tail":"; amended "},{"tag":"html:a","attrib":{"href":"/us/pl/114/317"},"text":"Pub. L. 114–317","children":[],"tail":", §§ 4(e), 7(b)(1)(A), (c), "},{"tag":"html:span","attrib":{},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/130/1602"},"text":"130 Stat. 1602","children":[],"tail":", 1605, 1606."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
