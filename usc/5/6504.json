{"tag":"section","attrib":{"id":"idb8a17a6f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504"},"text":null,"children":[{"tag":"num","attrib":{"value":"6504"},"text":"§ 6504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy and support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a17a70-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Consultation With the Office of Personnel Management","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each executive agency shall consult with the Office of Personnel Management in developing telework policies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a71-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance and Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Personnel Management shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a17a72-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide policy and policy guidance for telework in the areas of pay and leave, agency closure, performance management, official worksite, recruitment and retention, and accommodations for employees with disabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a73-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist each agency in establishing appropriate qualitative and quantitative measures and teleworking goals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a74-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17a75-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Emergency Management Agency on policy and policy guidance for telework in the areas of continuation of operations and long-term emergencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a76-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Services Administration on policy and policy guidance for telework in the areas of telework centers, travel, technology, equipment, and dependent care; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a77-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Archives and Records Administration on policy and policy guidance for telework in the areas of efficient and effective records management and the preservation of records, including Presidential and Vice-Presidential records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a78-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security Guidelines.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a17a79-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Management and Budget, in coordination with the Department of Homeland Security and the National Institute of Standards and Technology, shall issue guidelines not later than 180 days after the date of the enactment of this chapter to ensure the adequacy of information and security protections for information and information systems used while teleworking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a7a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Guidelines issued under this subsection shall, at a minimum, include requirements necessary to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17a7b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" control access to agency information and information systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a7c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect agency information (including personally identifiable information) and information systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a7d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" limit the introduction of vulnerabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a7e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect information systems not under the control of the agency that are used for teleworking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a7f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safeguard wireless and other telecommunications capabilities that are used for teleworking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a80-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent inappropriate use of official time or resources that violates subpart G of the Standards of Ethical Conduct for Employees of the Executive Branch by viewing, downloading, or exchanging pornography, including child pornography.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a81-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuity of Operations Plans.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a17a82-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incorporation into continuity of operations plans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each executive agency shall incorporate telework into the continuity of operations plan of that agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a83-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuity of operations plans supersede telework policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During any period that an executive agency is operating under a continuity of operations plan, that plan shall supersede any telework policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a84-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Telework Website","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Personnel Management shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a17a85-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a central telework website; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a86-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include on that website related—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17a87-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" telework links;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a88-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" announcements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a89-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance developed by the Office of Personnel Management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a8a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance submitted by the Federal Emergency Management Agency, and the General Services Administration to the Office of Personnel Management not later than 10 business days after the date of submission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a8b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6504/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policy Guidance on Purchasing Computer Systems","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days after the date of the enactment of this chapter, the Director of the Office of Management and Budget shall issue policy guidance requiring each executive agency when purchasing computer systems, to purchase computer systems that enable and support telework, unless the head of the agency determines that there is a mission-specific reason not to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a17a8c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/292/s2/a"},"text":"Pub. L. 111–292, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3167"},"text":"124 Stat. 3167","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a17a8d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a17a8e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8a17a8f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this chapter, referred to in subsecs. (c)(1) and (f), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/292"},"text":"Pub. L. 111–292","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
