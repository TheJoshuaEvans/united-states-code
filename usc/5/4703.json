{"tag":"section","attrib":{"id":"idb82f0974-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703"},"text":null,"children":[{"tag":"num","attrib":{"value":"4703"},"text":"§ 4703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Demonstration projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82f0975-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in this section, the Office of Personnel Management may, directly or through agreement or contract with one or more agencies and other public and private organizations, conduct and evaluate demonstration projects. Subject to the provisions of this section, the conducting of demonstration projects shall not be limited by any lack of specific authority under this title to take the action contemplated, or by any provision of this title or any rule or regulation prescribed under this title which is inconsistent with the action, including any law or regulation relating to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82f0976-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods of establishing qualification requirements for, recruitment for, and appointment to positions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f0977-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods of classifying positions and compensating employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f0978-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods of assigning, reassigning, or promoting employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f0979-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods of disciplining employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f097a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods of providing incentives to employees, including the provision of group or individual incentive bonuses or pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f097b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hours of work per day or per week;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f097c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods of involving employees, labor organizations, and employee organizations in personnel decisions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f097d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods of reducing overall agency staff and grade levels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f097e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before conducting or entering into any agreement or contract to conduct a demonstration project, the Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82f097f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop a plan for such project which identifies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82f0980-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f0981-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of employees or eligibles, categorized by occupational series, grade, or organizational unit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f0982-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees or eligibles to be included, in the aggregate and by category;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f0983-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methodology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f0984-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f0985-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training to be provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f0986-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f0987-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methodology and criteria for evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f0988-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specific description of any aspect of the project for which there is a lack of specific authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f0989-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specific citation to any provision of law, rule, or regulation which, if not waived under this section, would prohibit the conducting of the project, or any part of the project as proposed;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f098a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the plan in the Federal Register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f098b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the plan so published to public hearing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f098c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide notification of the proposed proj­ect, at least 180 days in advance of the date any project proposed under this section is to take effect—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82f098d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to employees who are likely to be affected by the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f098e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to each House of the Congress;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f098f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain approval from each agency involved of the final version of the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f0990-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide each House of the Congress with a report at least 90 days in advance of the date the project is to take effect setting forth the final version of the plan as so approved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f0991-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No demonstration project under this section may provide for a waiver of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82f0992-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of chapter 63 or subpart G of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f0993-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82f0994-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of law referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/b/1"},"text":"section 2302(b)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f0995-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any provision of law implementing any provision of law referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/b/1"},"text":"section 2302(b)(1) of this title","children":[],"tail":" by—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb82f0996-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for equal employment opportunity through affirmative action; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb82f0997-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing any right or remedy available to any employee or applicant for employment in the civil service;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f0998-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of chapter 15 or subchapter III of chapter 73 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f0999-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rule or regulation prescribed under any provision of law referred to in paragraph (1), (2), or (3) of this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f099a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of chapter 23 of this title, or any rule or regulation prescribed under this title, if such waiver is inconsistent with any merit system principle or any provision thereof relating to prohibited personnel practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f099b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82f099c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each demonstration project shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82f099d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve not more than 5,000 individuals other than individuals in any control groups necessary to validate the results of the proj­ect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f099e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminate before the end of the 5-year period beginning on the date on which the project takes effect, except that the project may continue beyond the date to the extent necessary to validate the results of the proj­ect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f099f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82f09a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), not more than 10 active demonstration projects may be in effect at any time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82f09a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any demonstration project authorized under this section that is active for a period greater than 10 years shall not count for purposes of applying the limitation in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f09a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to the terms of any written agreement or contract between the Office and an agency, a demonstration project involving the agency may be terminated by the Office, or the agency, if either determines that the project creates a substantial hardship on, or is not in the best interests of, the public, the Federal Government, employees, or eligibles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f09a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Employees within a unit with respect to which a labor organization is accorded exclusive recognition under chapter 71 of this title shall not be included within any project under subsection (a) of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82f09a4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the project would violate a collective bargaining agreement (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7103/8"},"text":"section 7103(8) of this title","children":[],"tail":") between the agency and the labor organization, unless there is another written agreement with respect to the project between the agency and the organization permitting the inclusion; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f09a5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the project is not covered by such a collective bargaining agreement, until there has been consultation or negotiation, as appropriate, by the agency with the labor organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f09a6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employees within any unit with respect to which a labor organization has not been accorded exclusive recognition under chapter 71 of this title shall not be included within any proj­ect under subsection (a) of this section unless there has been agency consultation regarding the project with the employees in the unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f09a7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall provide for an evaluation of the results of each demonstration project and its impact on improving public management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f09a8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon request of the Director of the Office of Personnel Management, agencies shall cooperate with and assist the Office, to the extent practicable, in any evaluation undertaken under subsection (h) of this section and provide the Office with requested information and reports relating to the conducting of demonstration projects in their respective agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f09a9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each agency at which a demonstration project authorized by this section is ongoing shall submit an annual report to the Office of Personnel Management, the Office and ","children":[{"tag":"ref","attrib":{"idref":"fn002081"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002081"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “of”."}],"tail":" Management and Budget, the Committee on Homeland Security and Governmental Affairs of the United States Senate, and the Committee on Oversight and Government Reform of the United States House of Representatives that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82f09aa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate performance appraisal ratings and compensation costs for employees under a demonstration project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f09ab-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the results of the demonstration project, including its impact on mission goals, employee recruitment, retention, and satisfaction, and which may include the results of the survey authorized under section 1128 of the National Defense Authorization Act for Fiscal Year 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Public Law 108–136","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7101"},"text":"5 U.S.C. 7101","children":[],"tail":" note), commonly referred to as the Federal Employee Viewpoint Survey, and performance management for employees; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f09ac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4703/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison of the items listed in (1) and (2) with employees not covered by the demonstration project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82f09ad-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVI/s601/a"},"text":"Pub. L. 95–454, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1186"},"text":"92 Stat. 1186","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXI/s1106"},"text":"Pub. L. 115–232, div. A, title XI, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2001"},"text":"132 Stat. 2001","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82f09ae-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb82f09af-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb82f09b0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1106/1"},"text":"Pub. L. 115–232, § 1106(1)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “Not more than 10 active demonstration projects may be in effect at any time.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232/s1106/2"},"text":"Pub. L. 115–232, § 1106(2)","children":[],"tail":", added subsec. (j)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb83179b1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb83179b2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb83179b3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb83179b4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority of Export-Import Bank To Conduct Demonstration Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/97/s2"},"text":"Pub. L. 104–97, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-11"},"text":"Jan. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/984"},"text":"109 Stat. 984","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/97/s2"},"text":"“Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4701/a/1/A"},"text":"section 4701(a)(1)(A) of title 5","children":[],"tail":", United States Code, the Export-Import Bank of the United States may conduct a demonstration project in accordance with section 4703 of such title.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
