{"tag":"section","attrib":{"id":"idb8100e8f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3313"},"text":null,"children":[{"tag":"num","attrib":{"value":"3313"},"text":"§ 3313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive service; registers of eligibles","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The names of applicants who have qualified in examinations for the competitive service shall be entered on appropriate registers or lists of eligibles in the following order—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8100e90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3313/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for scientific and professional positions in GS–9 or higher, in the order of their ratings, including points added under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3309"},"text":"section 3309 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8100e91-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3313/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for all other positions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8100e92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3313/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disabled veterans who have a compensable service-connected disability of 10 percent or more, in order of their ratings, including points added under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3309"},"text":"section 3309 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8100e93-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3313/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remaining applicants, in the order of their ratings, including points added under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3309"},"text":"section 3309 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The names of preference eligibles shall be entered ahead of others having the same rating.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8100e94-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/420"},"text":"80 Stat. 420","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8100e95-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8100e96-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8100e97-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s856"},"text":"5 U.S.C. 856","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"June 27, 1944","children":[],"tail":", 287, § 7, "},{"tag":"html:a","attrib":{"href":"/us/stat/58/389"},"text":"58 Stat. 389","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1953-08-14/ch485/s1/b"},"text":"Aug. 14, 1953, ch. 485, § 1(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/581"},"text":"67 Stat. 581","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The section is restated for clarity and conciseness. The words “for the competitive service” are added for clarity. Application of this section to the excepted service in the executive branch and to the government of the District of Columbia is carried into section 3320. The words “employment lists” are omitted as included in “appropriate registers or lists of eligibles”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1), the words “in GS–9 or higher” are substituted for “in grade 9 or higher of the General Schedule of the Classification Act of 1949, as amended” in view of the codification of the Act in this title, and, in specific sections 5104 and 5332.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (2)(A), the term “disabled veterans” is substituted for “preference eligibles” in view of the definition of “disabled veteran” in section 2108(2).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
