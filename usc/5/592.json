":"p","attrib":{},"text":"In paragraph (1), the words “subchapter II of this chapter” are substituted for “the Administrative Procedure Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1001–101"},"text":"5 U.S.C. 1001–101","children":[],"tail":"1)” to reflect the codification of the Act in this title. The word “naval” is omitted as included in “military”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (2), the words “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551/1"},"text":"section 551(1) of this title","children":[],"tail":"” are substituted for “section 2(a) of the Administrative Procedure Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1001/a"},"text":"5 U.S.C. 1001(a)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7bee128-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7bee129-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 592 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s582"},"text":"section 582 of this title","children":[],"tail":" and was subsequently repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7bee12a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href"