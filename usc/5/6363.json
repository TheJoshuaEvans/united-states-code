{"tag":"section","attrib":{"id":"idb89f0921-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6363"},"text":null,"children":[{"tag":"num","attrib":{"value":"6363"},"text":"§ 6363.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of leave banks","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each agency that establishes a leave bank program under section 6362 shall establish 1 or more leave banks in accordance with regulations prescribed by the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb89f0922-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/566/s2/a"},"text":"Pub. L. 100–566, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2839"},"text":"102 Stat. 2839","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
