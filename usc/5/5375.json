{"tag":"section","attrib":{"id":"idb85ecb13-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5375"},"text":null,"children":[{"tag":"num","attrib":{"value":"5375"},"text":"§ 5375.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Police force of the National Zoological Park","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Smithsonian Institution shall fix the annual rates of basic pay for positions on the police force of the National Zoological Park as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85ecb14-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5375/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Private, not more than the maximum annual rate of basic pay payable for grade GS–7 of the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecb15-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5375/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sergeant, not more than the maximum annual rate of basic pay payable for grade GS–8 of the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecb16-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5375/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Lieutenant, not more than the maximum annual rate of basic pay payable for grade GS–9 of the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecb17-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5375/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Captain, not more than the maximum annual rate of basic pay payable for grade GS–10 of the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb85ecb18-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/34/s1/a"},"text":"Pub. L. 91–34, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-06-30"},"text":"June 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/41"},"text":"83 Stat. 41","children":[],"tail":", § 5365; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/183/s2/20"},"text":"Pub. L. 94–183, § 2(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1058"},"text":"89 Stat. 1058","children":[],"tail":"; renumbered § 5375, "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVIII/s801/a/3/A/ii"},"text":"Pub. L. 95–454, title VIII, § 801(a)(3)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1221"},"text":"92 Stat. 1221","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/263/s1/a"},"text":"Pub. L. 101–263, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-04-04"},"text":"Apr. 4, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/125"},"text":"104 Stat. 125","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/33"},"text":"Pub. L. 102–378, § 2(33)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1350"},"text":"106 Stat. 1350","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb85ecb19-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb85ecb1a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb85ecb1b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"General Schedule, referred to in text, is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb85ecb1c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378"},"text":"Pub. L. 102–378","children":[],"tail":" substituted “GS–8” for “GS–8,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/263"},"text":"Pub. L. 101–263","children":[],"tail":" inserted “the” before “National” in section catchline and amended text generally. Prior to amendment, text read as follows: “The Secretary of the Smithsonian Institution shall fix the per annum rates of basic pay of positions on the police force of the National Zoological Park in accordance with the following provisions:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Private—not more than the rate for GS–7, Step 5;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Sergeant—not more than the rate for GS–8, Step 5;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) Lieutenant—not more than the rate for GS–9, Step 5;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) Captain—not more than the rate for GS–10, Step 5.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/183"},"text":"Pub. L. 94–183","children":[],"tail":" struck out designation “(a)” at beginning."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb85ecb1d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb85ecb1e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/263/s2"},"text":"Pub. L. 101–263, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-04-04"},"text":"Apr. 4, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/125"},"text":"104 Stat. 125","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/263/s2"},"text":"“The amendments made by section 1 [amending this section] shall apply with respect to pay periods beginning after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-04-04"},"text":"Apr. 4, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb85ecb1f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/34/s3/a"},"text":"Pub. L. 91–34, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-06-30"},"text":"June 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/41"},"text":"83 Stat. 41","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/34/s3/a"},"text":"“The foregoing provisions of this Act [enacting this section and amending sections 5102 and 5109 of this title and section 193n of former Title 40, Public Buildings, Property, and Works] shall become effective at the beginning of the first pay period which commences on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1969-06-30"},"text":"June 30, 1969","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb85ecb20-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reduction of Basic Pay Rate","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/34/s3/b"},"text":"Pub. L. 91–34, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-06-30"},"text":"June 30, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/41"},"text":"83 Stat. 41","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/34/s3/b"},"text":"“No rate of basic pay shall be reduced by reason of the enactment of this Act [enacting this section and amending sections 5102 and 5109 of this title and section 193n of former Title 40, Public Buildings, Property, and Works].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
