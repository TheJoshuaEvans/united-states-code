{"tag":"section","attrib":{"id":"idb8873b83-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5738"},"text":null,"children":[{"tag":"num","attrib":{"value":"5738"},"text":"§ 5738.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8873b84-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5738/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8873b85-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5738/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as specifically provided in this subchapter, the Administrator of General Services shall prescribe regulations necessary for the administration of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b86-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5738/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of General Services shall include in the regulations authority for the head of an agency or his designee to waive any limitation of this subchapter or in any implementing regulation for any employee relocating to or from a remote or isolated location who would suffer hardship if the limitation were not waived. A waiver of a limitation under authority provided in the regulations pursuant to this paragraph shall be effective notwithstanding any other provision of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8873b87-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5738/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content",