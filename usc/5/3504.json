{"tag":"section","attrib":{"id":"idb820b0cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3504"},"text":null,"children":[{"tag":"num","attrib":{"value":"3504"},"text":"§ 3504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preference eligibles; retention; physical qualifications; waiver","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb820b0cc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In determining qualifications of a preference eligible for retention in a position in the competitive service, an Executive agency, or the government of the District of Columbia, the Office of Personnel Management or other examining agency shall waive—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb820b0cd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements as to age, height, and weight, unless the requirement is essential to the performance of the duties of the position; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb820b0ce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical requirements if, in the opinion of the Office or other examining agency, after considering the recommendation of an accredited physician, the preference eligible is physically able to perform efficiently the duties of the position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb820b0cf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an examining agency determines that, on the basis of evidence before it, a preference eligible described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2108/3/C"},"text":"section 2108(3)(C) of this title","children":[],"tail":" who has a compensable service-connected disability of 30 percent or more is not able to fulfill the physical requirements of the position, the examining agency shall notify the Office of the determination and, at the same time, the examining agency shall notify the preference eligible of the reasons for the determination and of the right to respond, within 15 days of the date of the notification, to the Office. The Office shall require a demonstration by the appointing authority that the notification was timely sent to the preference eligible’s last known address and shall, before the selection of any other person for the position, make a final determination on the physical ability of the preference eligible to perform the duties of the position, taking into account any additional information provided in the response. When the Office has completed its review of the proposed disqualification on the basis of physical disability, it shall send its findings to the appointing authority and the preference eligible. The appointing authority shall comply with the findings of the Office. The functions of the Office under this subsection may not be delegated."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb820b0d0-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/429"},"text":"80 Stat. 429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIII/s307/g"},"text":"Pub. L. 95–454, title III, § 307(g)","children":[],"tail":", title IX, § 906(a)(2), (3), "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1149"},"text":"92 Stat. 1149","children":[],"tail":", 1224.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb820b0d1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb820b0d2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb820b0d3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s854"},"text":"5 U.S.C. 854","children":[],"tail":" (1st 2 sentences, so much as relates to retention)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1944-06-27/ch287/s5"},"text":"June 27, 1944, ch. 287, § 5","children":[],"tail":" (1st 2 sentences, so much as relates to retention), "},{"tag":"html:a","attrib":{"href":"/us/stat/58/388"},"text":"58 Stat. 388","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “in the competitive service, an Executive agency, or the government of the District of Columbia” are added on authority of former sections 851, 858, and 869 which are carried into this title. The words “preference eligible” are substituted for “veteran”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb820b0d4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","chi