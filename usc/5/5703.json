l}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s73b–2"},"text":"5 U.S.C. 73b–2","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch744/s5"},"text":"Aug. 2, 1946, ch. 744, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/808"},"text":"60 Stat. 808","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1955-07-28/ch424/s2"},"text":"July 28, 1955, ch. 424, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/69/394"},"text":"69 Stat. 394","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 14, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/139"},"text":"Pub. L. 87–139","children":[],"tail":", §§ 2, 8(b), "},{"tag":"html:a","attrib":{"href":"/us/stat/75/339"},"text":"75 Stat. 339","children":[],"tail":", 340."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is added on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch744/s18"},"text":"section 18 of the Act of Aug. 2, 1946, ch. 744","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/811"},"text":"60 Stat. 811","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “in lieu of subsistence” are omitted as unnecessary in view of the definition of “per diem allowance” in section 5701(4). The words “this subchapter” are substituted for “the Standardized Government Travel Regulations, Subsistence Expense Act of 1926, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s821–833"},"text":"5 U.S.C. 821–833","children":[],"tail":") and the Act of "},{"tag":"date","attrib":{"date":"1931-02-14"},"text":"February 14, 1931","children":[],"tail":", as amended by this Act” as the Subsistence Expense Act of 1926 and the Act of "},{"tag":"date","attrib":{"date":"1931-02-14"},"text":"February 14, 1931","children":[],"tail":", were repealed by section 9(a) of the Travel Expense Act of 1949, "},{"tag":"ref","attrib":{"href":"/us/stat/63/167"},"text":"63 Stat. 167","children":[],"tail":", part of which appeared in former section 842 and is carried into section 5708, and as the authority for the Standardized Government Travel Regulations in former section 840 is carried into section 5707."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “this subchapter” are substituted for “said regulations and said Act of ","children":[{"tag":"date","attrib":{"date":"1931-02-14"},"text":"February 14, 1931","children":[],"tail":", as so amended” as the Act of "},{"tag":"date","attrib":{"date":"1931-02-14"},"text":"February 14, 1931","children":[],"tail":", was repealed by section 9(a) of the Travel Expense Act of 1949, "},{"tag":"ref","attrib":{"href":"/us/stat/63/167"},"text":"63 Stat. 167","children":[],"tail":", part of which appeared in former section 842 and is carried into section 5708, and as the authority for the Standardized Government Travel Regulations in former section 840 is carried into section 5707. The words “in lieu of subsistence” are omitted as unnecessary in view of the definition of “per diem allowance” in section 5701(4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “Under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5707"},"text":"section 5707 of this title","children":[],"tail":"” are substituted for “in accordance with regulations promulgated by the Director, Bureau of the Budget, pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s840"},"text":"section 840 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8800e4a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8800e4b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/22"},"text":"Pub. L. 94–22","children":[],"tail":" struck out separate provisions for per diem allowances of employees serving as experts, consultants, or serving without pay or at $1 a year."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/114"},"text":"Pub. L. 91–114","children":[],"tail":" increased the per diem allowance for travel inside continental United States from not to exceed the rate of $16 to not to exceed the rate of $25."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/114"},"text":"Pub. L. 91–114","children":[],"tail":" in cl. (1) increased amount authorized to be named in travel authorization for each day in a travel status inside continental United States from not to exceed $30 to not to exceed $40, and in cl. (2) increased amount authorized to be named in travel authorization for each day in a travel status outside continental United States from not to exceed maximum per diem allowance plus $10 to not to exceed the maximum per diem allowance plus $18."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
