{"tag":"section","attrib":{"id":"idb8800e45-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5703"},"text":null,"children":[{"tag":"num","attrib":{"value":"5703"},"text":"§ 5703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Per diem, travel, and transportation expenses; experts and consultants; individuals serving without pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An employee serving intermittently in the Government service as an expert or consultant and paid on a daily when-actually-employed basis, or serving without pay or at $1 a year, may be allowed travel or transportation expenses, under this subchapter, while away from his home or regular place of business and at the place of employment or service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8800e46-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/499"},"text":"80 Stat. 499","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/114/s2"},"text":"Pub. L. 91–114, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-11-10"},"text":"Nov. 10, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/190"},"text":"83 Stat. 190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/22/s4"},"text":"Pub. L. 94–22, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-05-19"},"text":"May 19, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/85"},"text":"89 Stat. 85","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8800e47-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic