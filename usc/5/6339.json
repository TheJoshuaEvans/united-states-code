{"tag":"section","attrib":{"id":"idb89f08e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339"},"text":null,"children":[{"tag":"num","attrib":{"value":"6339"},"text":"§ 6339.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional leave transfer programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89f08e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89f08e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “excepted agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89f08e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Central Intelligence Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89f08ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Defense Intelligence Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89f08eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Security Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89f08ec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Bureau of Investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89f08ed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Geospatial-Intelligence Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89f08ee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as determined by the President, any Executive agency or unit thereof, the principal function of which is the conduct of foreign intelligence or counterintelligence activities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f08ef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “head of an excepted agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89f08f0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Central Intelligence Agency, the Director of Central Intelligence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89f08f1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Defense Intelligence Agency, the Director of the Defense Intelligence Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89f08f2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the National Security Agency, the Director of the National Security Agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89f08f3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Federal Bureau of Investigation, the Director of the Federal Bureau of Investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89f08f4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the National Geospatial-Intelligence Agency, the Director of the National Geospatial-Intelligence Agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89f08f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to an Executive agency designated under paragraph (1)(F), the head of such Executive agency, and with respect to a unit of an Executive agency designated under paragraph (1)(F), such individual as the President may determine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89f08f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89f08f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of an excepted agency shall, by regulation, establish a program under which annual leave accrued or accumulated by an employee of such agency may be transferred to the annual leave account of any other employee of such agency if such other employee requires additional leave because of a medical emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f08f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To the extent practicable, and consistent with the protection of intelligence sources and methods (if applicable), each program under this subsection shall be established—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89f08f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner consistent with the provisions of this subchapter applicable to the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89f08fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without regard to any provisions relating to transfers or restorations of leave between employees in different agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89f08fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89f08fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any provision of subsection (b), the head of an excepted agency may, at his sole discretion, by regulation establish a program under which an individual employed in or under such excepted agency may participate in a leave transfer program established under the provisions of this subchapter outside of this section, including provisions permitting the transfer of annual leave accrued or accumulated by such employee to, or permitting such employee to receive transferred leave from, an employee of any other agency (including another excepted agency having a program under this subsection).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f08fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent practicable and consistent with the protection of intelligence sources and methods, any program established under paragraph (1) shall be consistent with the provisions of this subchapter outside of this section and with any regulations issued by the Office of Personnel Management implementing this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89f08fe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6339/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall provide the head of an excepted agency with such advice and assistance as the head of such agency may request in order to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89f08ff-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/566/s2/a"},"text":"Pub. L. 100–566, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2838"},"text":"102 Stat. 2838","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/tV/s501/i"},"text":"Pub. L. 103–359, title V, § 501(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3429"},"text":"108 Stat. 3429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXI/s1122/a"},"text":"Pub. L. 104–201, div. A, title XI, § 1122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2687"},"text":"110 Stat. 2687","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/306/tIII/s322"},"text":"Pub. L. 107–306, title III, § 322","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-27"},"text":"Nov. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2391"},"text":"116 Stat. 2391","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title IX, § 931(a)(1), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4575"},"text":"122 Stat. 4575","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb89f0900-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89f0901-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb89f0902-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1)(E), (2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s322/a/1"},"text":"Pub. L. 107–306, § 322(a)(1)","children":[],"tail":", (2), redesignated subsec. (c) as (b) and struck out former subsec. (b) which read as follows: “Notwithstanding any other provision of this subchapter, neither an excepted agency nor any individual employed in or under an excepted agency may be included in a leave transfer program established under any of the preceding provisions of this subchapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s322/b/1"},"text":"Pub. L. 107–306, § 322(b)(1)","children":[],"tail":", substituted “under this subsection” for “under this section” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s322/a/3"},"text":"Pub. L. 107–306, § 322(a)(3)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/306/s322/b/2"},"text":"Pub. L. 107–306, § 322(b)(2)","children":[],"tail":", struck out “of Personnel Management” after “The Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1122/a/1"},"text":"Pub. L. 104–201, § 1122(a)(1)","children":[],"tail":", substituted “National Imagery and Mapping Agency” for “Central Imagery Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1122/a/2"},"text":"Pub. L. 104–201, § 1122(a)(2)","children":[],"tail":", substituted “National Imagery and Mapping Agency, the Director of the National Imagery and Mapping Agency” for “Central Imagery Office, the Director of the Central Imagery Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/359/s501/i/1"},"text":"Pub. L. 103–359, § 501(i)(1)","children":[],"tail":", added subpar. (E) and redesignated former subpar. (E) as (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/359/s501/i/2"},"text":"Pub. L. 103–359, § 501(i)(2)","children":[],"tail":", added subpar. (E), redesignated former subpar. (E) as (F), and substituted “paragraph (1)(F)” for “paragraph (1)(E)” in two places in subpar. (F)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb89f0903-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb89f0904-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the intelligence community deemed to be a reference to the Director of National Intelligence. Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the Central Intelligence Agency deemed to be a reference to the Director of the Central Intelligence Agency. See section 1081(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb89f0905-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1124"},"text":"section 1124 of Pub. L. 104–201","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s193"},"text":"section 193 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
