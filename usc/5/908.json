{"tag":"section","attrib":{"id":"idb7db91ad-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s908"},"text":null,"children":[{"tag":"num","attrib":{"value":"908"},"text":"§ 908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of Senate and House of Representatives on reorganization plans","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Sections 909 through 912 of this title are enacted by Congress—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7db91ae-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s908/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as an exercise of the rulemaking power of the Senate and the House of Representatives, respectively, and as such they are deemed a part of the rules of each House, respectively, but applicable only with respect to the procedure to be followed in that House in the case of resolutions with respect to any reorganization plans transmitted to Congress (in accordance with section 903(b) of this chapter ","children":[{"tag":"ref","attrib":{"idref":"fn002030"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002030"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “title”."}],"tail":") on or before "},{"tag":"date","attrib":{"date":"1984-12-31"},"text":"December 31, 1984","children":[],"tail":"; and they supersede other rules only to the extent that they are inconsistent therewith; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7db91af-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s908/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with full recognition of the constitutional right of either House to change the rules (so far as relating to the procedure of that House) at any time, in the same manner and to the same extent as in the case of any other rule of that House.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7db91b0-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/397"},"text":"80 Stat. 397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/17/s2"},"text":"Pub. L. 95–17, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-04-06"},"text":"Apr. 6, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/33"},"text":"91 Stat. 33","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/614/s2/b"},"text":"Pub. L. 98–614, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3192"},"text":"98 Stat. 3192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7db91b1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7db91b2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7db91b3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag