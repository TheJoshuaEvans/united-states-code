{"tag":"section","attrib":{"id":"idb8256c29-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704"},"text":null,"children":[{"tag":"num","attrib":{"value":"3704"},"text":"§ 3704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of employees from private sector organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8256c2a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An employee of a private sector organization assigned to an agency under this chapter is deemed, during the period of the assignment, to be on detail to such agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8256c2b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employee of a private sector organization assigned to an agency under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8256c2c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may continue to receive pay and benefits from the private sector organization from which he is assigned;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8256c2d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is deemed, notwithstanding subsection (a), to be an employee of the agency for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8256c2e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 73;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c2f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 201, 203, 205, 207, 208, 209, 603, 606, 607, 643, 654, 1905, and 1913 of title 18;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c30-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 1343, 1344, and 1349(b) of title 31;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c31-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Tort Claims Act and any other Federal tort liability statute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c32-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 131 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c33-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 1043 of the Internal Revenue Code of 1986; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8256c34-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 21 of title 41;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8256c35-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not have access to any trade secrets or to any other nonpublic information which is of commercial value to the private sector organization from which he is assigned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8256c36-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to such regulations as the President may prescribe.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The supervision of an employee of a private sector organization assigned to an agency under this chapter may be governed by agreement between the agency and the private sector organization concerned. Such an assignment may be made with or without reimbursement by the agency for the pay, or a part thereof, of the employee during the period of assignment, or for any contribution of the private sector organization to employee benefit systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8256c37-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Chapter","children":[],"tail":" 81.—"}],"tail":null},{"tag":"content","attrib":{},"text":"An employee of a private sector organization assigned to an agency under this chapter who suffers disability or dies as a result of personal injury sustained while performing duties during the assignment shall be treated, for the purpose of subchapter I of chapter 81, as an employee as defined by section 8101 who had sustained the injury in the performance of duty, except that, if the employee or the employee’s dependents receive from the private sector organization any payment under an insurance policy for which the premium is wholly paid by the private sector organization, or other benefit of any kind on account of the same injury or death, then, the amount of such payment or benefit shall be credited against any compensation otherwise payable under subchapter I of chapter 81.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8256c38-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition Against Charging Certain Costs to the Federal Government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A private sector organization may not charge the Federal Government, as direct or indirect costs under a Federal contract, the costs of pay or benefits paid by the organization to an employee assigned to an agency under this chapter for the period of the assignment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8256c39-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347/tII/s209/c/1"},"text":"Pub. L. 107–347, title II, § 209(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2928"},"text":"116 Stat. 2928","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/a/6"},"text":"Pub. L. 111–350, § 5(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3841"},"text":"124 Stat. 3841","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/8"},"text":"Pub. L. 117–286, § 4(c)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4354"},"text":"136 Stat. 4354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8256c3a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8256c3b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8256c3c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Tort Claims Act, referred to in subsec. (b)(2)(D), is title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch753"},"text":"act Aug. 2, 1946, ch. 753","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/842"},"text":"60 Stat. 842","children":[],"tail":", which was classified principally to chapter 20 (§§ 921, 922, 931–934, 941–946) of former Title 28, Judicial Code and Judiciary. Title IV of act "},{"tag":"date","attrib":{"date":"1946-08-02"},"text":"Aug. 2, 1946","children":[],"tail":", was substantially repealed and reenacted as sections 1346(b) and 2671 et seq. of Title 28, Judiciary and Judicial Procedure, by "},{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch646"},"text":"act June 25, 1948, ch. 646","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/992"},"text":"62 Stat. 992","children":[],"tail":", the first section of which enacted Title 28. The Federal Tort Claims Act is also commonly used to refer to chapter 171 of Title 28, Judiciary and Judicial Procedure. For complete classification of title IV to the Code, see Tables. For distribution of former sections of Title 28 into the revised Title 28, see Table at the beginning of Title 28."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1043 of the Internal Revenue Code of 1986, referred to in subsec. (b)(2)(F), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1043"},"text":"section 1043 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8256c3d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 131 of this title;” for “the Ethics in Government Act of 1978;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(2)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “chapter 21 of title 41” for “section 27 of the Office of Federal Procurement Policy Act”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8256c3e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8256c3f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 120 days after ","children":[{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s402/a"},"text":"section 402(a) of Pub. L. 107–347","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3601"},"text":"section 3601 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
