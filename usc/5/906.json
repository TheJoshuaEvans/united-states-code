{"tag":"section","attrib":{"id":"idb7db9193-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s906"},"text":null,"children":[{"tag":"num","attrib":{"value":"906"},"text":"§ 906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date and publication of reorganization plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7db9194-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided under subsection (c) of this section, a reorganization plan shall be effective upon approval by the President of a resolution (as defined in section 909) with respect to such plan, if such resolution is passed by the House of Representatives and the Senate, within the first period of 90 calendar days of continuous session of Congress after the date on which the plan is transmitted to Congress. Failure of either House to act upon such resolution by the end of such period shall be the same as disapproval of the resolution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7db9195-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7db9196-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s906/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuity of session is broken only by an adjournment of Congress sine die; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7db9197-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s906/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the days on which either House is not in session because of an adjournment of more than three days to a day certain are excluded in the computation of any period of time in which Congress is in continuous session.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7db9198-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under provisions contained in a reorganization plan, any provision thereof may be effective at a time later than the date on which the plan otherwise is effective.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7db9199-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s906/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A reorganization plan which is effective shall be printed (1) in the Statutes at Large in the same volume as the public laws and (2) in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7db919a-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/396"},"text":"80 Stat. 396","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/17/s2"},"text":"Pub. L. 95–17, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-04-06"},"text":"Apr. 6, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/32"},"text":"91 Stat. 32","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/614/s3/a"},"text":"Pub. L. 98–614, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3192"},"text":"98 Stat. 3192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7db919b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7db919c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7db919d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(a)–(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s133z–4"},"text":"5 U.S.C. 133z–4","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-20/ch226/s6"},"text":"June 20, 1949, ch. 226, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/205"},"text":"63 Stat. 205","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 4, 1957","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/286/s2"},"text":"Pub. L. 85–286, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/71/611"},"text":"71 Stat. 611","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s133z–9"},"text":"5 U.S.C. 133z–9","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-20/ch226/s11"},"text":"June 20, 1949, ch. 226, § 11","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/206"},"text":"63 Stat. 206","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7db919e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7db919f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/614/s3/a/1"},"text":"Pub. L. 98–614, § 3(a)(1)","children":[],"tail":", struck out “otherwise” before “provided under subsection (c)”, substituted “shall be” for “is” before “effective”, and substituted “upon approval by the President of a resolution (as defined in section 909) with respect to such plan, if such resolution is passed by the House of Representatives and the Senate, within the first period of 90 calendar days of continuous session of Congress after the date on which the plan is transmitted to Congress. Failure of either House to act upon such resolution by the end of such period shall be the same as disapproval of the resolution” for “at the end of the first period of sixty calendar days of continuous session of Congress after the date on which the plan is transmitted to it unless, between the date of transmittal and the end of the sixty-day period, either House passes a resolution stating in substance that the House does not favor the reorganization plan.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/614/s3/a/2"},"text":"Pub. L. 98–614, § 3(a)(2)","children":[],"tail":", struck out before period at end “or, if both Houses of Congress have defeated a resolution of disapproval, may be effective at a time earlier than the expiration of the sixty-day period required by subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/17"},"text":"Pub. L. 95–17","children":[],"tail":" substituted “sixty” for “60” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/17"},"text":"Pub. L. 95–17","children":[],"tail":" substituted in provisions preceding par. (1) “this chapter” for “subsection (a) of this section” and in par. (2) “any period of time in which Congress is in continuous session” for “the 60-day period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/17"},"text":"Pub. L. 95–17","children":[],"tail":" inserted provision that if both Houses of Congress have defeated a resolution of disapproval, the provision of a reorganization plan may be effective at a time earlier than the expiration of the sixty-day period required by subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/17"},"text":"Pub. L. 95–17","children":[],"tail":" reenacted subsec. (d) without change."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7db91a0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb7db91a1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Ratification and Affirmation of Prior Reorganization Plans as Law; Actions Taken Pursuant to Such Plans","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/532"},"text":"Pub. L. 98–532","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2705"},"text":"98 Stat. 2705","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/532"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“Section 1.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Congress hereby ratifies and affirms as law each reorganization plan that has, prior to the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":"], been implemented pursuant to the provisions of chapter 9 of title 5, United States Code, or any predecessor Federal reorganization statute."}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“Sec. 2.","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any actions taken prior to the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":"] pursuant to a reorganization plan that is ratified and affirmed by section 1 shall be considered to have been taken pursuant to a reorganization expressly approved by Act of Congress.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
