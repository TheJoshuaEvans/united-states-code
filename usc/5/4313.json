{"tag":"section","attrib":{"id":"idb82c983b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4313"},"text":null,"children":[{"tag":"num","attrib":{"value":"4313"},"text":"§ 4313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria for performance appraisals","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Appraisals of performance in the Senior Executive Service shall be based on both individual and organizational performance, taking into account such factors as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82c983c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4313/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvements in efficiency, productivity, and quality of work or service, including any significant reduction in paperwork;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c983d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4313/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c983e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4313/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" timeliness of performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c983f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4313/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other indications of the effectiveness, productivity, and performance quality of the employees for whom the senior executive is responsible;","children":[],"tail":"\n"}],"ta