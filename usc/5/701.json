{"tag":"section","attrib":{"id":"idb7d4665d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701"},"text":null,"children":[{"tag":"num","attrib":{"value":"701"},"text":"§ 701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application; definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7d4665e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This chapter applies, according to the provisions thereof, except to the extent that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7d4665f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statutes preclude judicial review; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7d46660-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agency action is committed to agency discretion by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7d46661-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7d46662-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “agency” means each authority of the Government of the United States, whether or not it is within or subject to review by another agency, but does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7d46663-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d46664-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the courts of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d46665-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the governments of the territories or possessions of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d46666-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d46667-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agencies composed of representatives of the parties or of representatives of organizations of the parties to the disputes determined by them;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d46668-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" courts martial and military commissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d46669-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military authority exercised in the field in time of war or in occupied territory; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d4666a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" functions conferred by sections 1738, 1739, 1743, and 1744 of title 12; subchapter II of chapter 471 of title 49; or sections 1884, 1891–1902, and former section 1641(b)(2), of title 50, appendix; ","children":[{"tag":"ref","attrib":{"idref":"fn002027"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002027"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7d4666b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person”, “rule”, “order”, “license”, “sanction”, “relief”, and “agency action” have the meanings given them by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551"},"text":"section 551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7d4666c-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/392"},"text":"80 Stat. 392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/a"},"text":"Pub. L. 103–272, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1373"},"text":"108 Stat. 1373","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/a/3"},"text":"Pub. L. 111–350, § 5(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3841"},"text":"124 Stat. 3841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7d4666d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7d4666e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7d4666f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s1009"},"text":"5 U.S.C. 1009","children":[],"tail":" (introductory clause)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-06-11/ch324/s10"},"text":"June 11, 1946, ch. 324, § 10","children":[],"tail":" (introductory clause), "},{"tag":"html:a","attrib":{"href":"/us/stat/60/243"},"text":"60 Stat. 243","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “This chapter applies, according to the provisions thereof,” are added to avoid the necessity of repeating the introductory clause of former section 1009 in sections 702–706.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is added on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-06-11/ch324/s2"},"text":"section 2 of the Act of June 11, 1946, ch. 324","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/237"},"text":"60 Stat. 237","children":[],"tail":", as amended, which is carried into "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s551"},"text":"section 551 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(G), the words “or naval” are omitted as included in “military”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(H), the words “functions which by law expire on the termination of present hostilities, within any fixed period thereafter, or before ","children":[{"tag":"date","attrib":{"date":"1947-07-01"},"text":"July 1, 1947","children":[],"tail":"” are omitted as executed. Reference to the “Selective Training and Service Act of 1940” is omitted as that Act expired on "},{"tag":"date","attrib":{"date":"1947-03-31"},"text":"Mar. 31, 1947","children":[],"tail":". Reference to the “Sugar Control Extension Act of 1947” is omitted as that Act expired on "},{"tag":"date","attrib":{"date":"1948-03-31"},"text":"Mar. 31, 1948","children":[],"tail":". References to the “Housing and Rent Act of 1947, as amended” and the “Veterans’ Emergency Housing Act of 1946” have been consolidated as they are related. The reference to former "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1641/b/2"},"text":"section 1641(b)(2) of title 50","children":[],"tail":", appendix, is retained notwithstanding its repeal by "},{"tag":"ref","attrib":{"href":"/us/act/1961-09-21/s111/a/1"},"text":"§ 111(a)(1) of the Act of Sept. 21, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/256"},"text":"Pub. L. 87–256","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/538"},"text":"75 Stat. 538","children":[],"tail":", since § 111(c) of the Act provides that a reference in other Acts to a provision of law repealed by § 111(a) shall be considered to be a reference to the appropriate provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/87/256"},"text":"Pub. L. 87–256","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7d6d670-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb7d6d671-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 1884 and 1891–1902 of title 50, appendix, referred to in subsec. (b)(1)(H), were a part of the various Housing and Rent Acts which were classified to section 1881 et seq. of the former Appendix to Title 50, War and National Defense, and had been repealed or omitted from the Code as executed prior to the elimination of the Appendix to Title 50. See Elimination of Title 50, Appendix note preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s1"},"text":"section 1 of Title 50","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s1641"},"text":"Section 1641 of title 50","children":[],"tail":", appendix, referred to in subsec. (b)(1)(H), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/87/256/s111/a/1"},"text":"Pub. L. 87–256, § 111(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-21"},"text":"Sept. 21, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/538"},"text":"75 Stat. 538","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7d6d672-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" struck out “chapter 2 of title 41;” after “title 12;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":" substituted “subchapter II of chapter 471 of title 49; or sections” for “or sections 1622,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
