{"tag":"section","attrib":{"id":"idb8a633e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7102"},"text":null,"children":[{"tag":"num","attrib":{"value":"7102"},"text":"§ 7102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees’ rights","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Each employee shall have the right to form, join, or assist any labor organization, or to refrain from any such activity, freely and without fear of penalty or reprisal, and each employee shall be protected in the exercise of such right. Except as otherwise provided under this chapter, such right includes the right—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a633e5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to act for a labor organization in the capacity of a representative and the right, in that capacity, to present the views of the labor organization to heads of agencies and other officials of the executive branch of the Government, the Congress, or other appropriate authorities, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a633e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to engage in collective bargaining with respect to conditions of employment through representatives chosen by employees under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a633e7-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVII/s701"},"text":"Pub. L. 95–454, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1192"},"text":"92 Stat. 1192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a633e8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a633e9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8a633ea-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7102, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/523"},"text":"80 Stat. 523","children":[],"tail":", related to right of employees to petition Congress, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7211"},"text":"section 7211 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a633eb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8a633ec-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8a633ed-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Partial Suspension of Federal Service Labor-Management Relations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Par. (2) of this section suspended with respect to any matter proposed for bargaining which would substantially impair the implementation by the United States Forces of any treaty or agreement, including any minutes or understandings thereto, between the United States and the Government of the host nation, see section 1(b) of Ex. Ord. No. 12391, ","children":[{"tag":"date","attrib":{"date":"1982-11-04"},"text":"Nov. 4, 1982","children":[],"tail":", 47 F.R. 50457, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7103"},"text":"section 7103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
