{"tag":"section","attrib":{"id":"idb89f0962-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6369"},"text":null,"children":[{"tag":"num","attrib":{"value":"6369"},"text":"§ 6369.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration of transferred leave","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Office of Personnel Management shall establish procedures under which any transferred leave remaining to the credit of a leave recipient when the medical emergency affecting the leave recipient terminates, shall be restored to the leave bank.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb89f0963-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/566/s2/a"},"text":"Pub. L. 100–566, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2842"},"text":"102 Stat. 2842","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
