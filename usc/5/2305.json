{"tag":"section","attrib":{"id":"idb7f840c0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2305"},"text":null,"children":[{"tag":"num","attrib":{"value":"2305"},"text":"§ 2305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility of the Government Accountability Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If requested by either House of the Congress (or any committee thereof), or if considered necessary by the Comptroller General, the Government Accountability Office shall conduct audits and reviews to assure compliance with the laws, rules, and regulations governing employment in the executive branch and in the competitive service and to assess the effectiveness and soundness of Federal personnel management.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7f840c1-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tI/s101/a"},"text":"Pub. L. 95–454, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1118"},"text":"92 Stat. 1118","children":[],"tail":", § 2304; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/6"},"text":"Pub. L. 102–378, § 2(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1346"},"text":"106 Stat. 1346","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tII/s2181/e"},"text":"Pub. L. 104–66, title II, § 2181(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/732"},"text":"109 Stat. 732","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; renumbered § 2305, "},{"tag":"ref","attrib":{"href":"/us/pl/112/199/tI/s109/a/1"},"text":"Pub. L. 112–199, title I, § 109(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-11-27"},"text":"Nov. 27, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1470"},"text":"126 Stat. 1470","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7f840c2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7f840c3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7f840c4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2305 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2306"},"text":"section 2306 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7f840c5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/199"},"text":"Pub. L. 112–199","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2304"},"text":"section 2304 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in section catchline and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" struck out subsec. (a) designation before “If requested by” and struck out subsec. (b) which read as follows: “The General Accounting Office shall prepare and submit an annual report to the President and the Congress on the activities of the Merit Systems Protection Board and the Office of Personnel Management. The report shall include a description of—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) significant actions taken by the Board to carry out its functions under this title; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) significant actions of the Office of Personnel Management, including an analysis of whether or not the actions of the Office are in accord with merit system principles and free from prohibited personnel practices.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378"},"text":"Pub. L. 102–378","children":[],"tail":" substituted “The” for “the” at beginning of first sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
