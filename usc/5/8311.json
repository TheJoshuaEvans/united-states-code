9f13-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c79f14-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s2281"},"text":"5 U.S.C. 2281","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 26, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/299/s1"},"text":"Pub. L. 87–299, § 1","children":[],"tail":" “Sec. 10”, "},{"tag":"html:a","attrib":{"href":"/us/stat/75/646"},"text":"75 Stat. 646","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3282"},"text":"section 3282 of Title 18","children":[],"tail":"” are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1)(A), the words “an employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":"” are coextensive with and substituted for “an officer or employee in or under the legislative, executive, or judicial branch of the Government of the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1)(B), the reference to “Resident Commissioner” is omitted as included in “Member of Congress” in view of the definition of “Member of Congress” in section 2106.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1)(C), the words “uniformed service” are coextensive with and substituted for “armed forces, the Coast and Geodetic Survey, or the Public Health Service” in view of the definition of “uniformed services” in section 2101.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (3), the words “uniformed service” are coextensive with and substituted for “armed forces, the Coast and Geodetic Survey, and the Public Health Service” in view of the definition of “uniformed services” in section 2101.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The definition of “armed forces” in former section 2281(4) is omitted as unnecessary in view of the definition of “armed forces” in section 2101.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c79f15-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8c79f16-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subchapter II of chapter 7 of title 42, referred to in par. (2), is classified to section 401 et seq. of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 228b, 228c(e), 228c–1, and 228e of title 45, referred to in par. (2), are references to sections 2, 3(e), 4, and 5 of the Railroad Retirement Act of 1937. That Act was amended in its entirety and completely revised by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/445"},"text":"Pub. L. 93–445","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-16"},"text":"Oct. 16, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1305"},"text":"88 Stat. 1305","children":[],"tail":". The Act, as thus amended and revised, was redesignated the Railroad Retirement Act of 1974, and is classified to subchapter IV (section 231 et seq.) of chapter 9 of Title 45, Railroads."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5 of the Uniformed Services Contingency Option Act of 1953 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/67/504"},"text":"67 Stat. 504","children":[],"tail":"), referred to in text, is covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1438"},"text":"section 1438 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c79f17-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Pars. (2)(A), (3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" substituted “Department of Veterans Affairs” for “Veterans’ Administration”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
