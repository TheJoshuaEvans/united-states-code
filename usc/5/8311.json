{"tag":"section","attrib":{"id":"idb8c79ef4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311"},"text":null,"children":[{"tag":"num","attrib":{"value":"8311"},"text":"§ 8311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c79ef5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c79ef6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79ef7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Member of Congress as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2106"},"text":"section 2106 of this title","children":[],"tail":" and a Delegate to Congress;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79ef8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member or former member of a uniformed service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79ef9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual employed by the government of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c79efa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “annuity” means a retirement benefit, including a disability insurance benefit and a dependent’s or survivor’s benefit under subchapter II of chapter 7 of title 42, and a monthly annuity under section 228b or 228e of title 45, payable by an agency of the Government of the United States or the government of the District of Columbia on the basis of service as a civilian employee and other service which is creditable to an employee toward the benefit under the statute, regulation, or agreement which provides the benefit, but does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c79efb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a benefit provided under statutes administered by the Department of Veterans Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79efc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay or compensation which may not be diminished under section 1 of Article III of the Constitution of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79efd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that portion of a benefit payable under subchapter II of chapter 7 of title 42 which would be payable without taking into account, for any of the purposes of that subchapter, including determinations of periods of disability under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s416/i"},"text":"section 416(i) of title 42","children":[],"tail":", pay for services as an employee;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79efe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monthly annuity awarded under section 228b or 228e of title 45 before ","children":[{"tag":"date","attrib":{"date":"1961-09-26"},"text":"September 26, 1961","children":[],"tail":", whether or not computed under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s228c/e"},"text":"section 228c(e) of title 45","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79eff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that portion of an annuity awarded under section 228b or 228e of title 45 after ","children":[{"tag":"date","attrib":{"date":"1961-09-25"},"text":"September 25, 1961","children":[],"tail":", which would be payable without taking into account military service creditable under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s228c–1"},"text":"section 228c–1 of title 45","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79f00-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a retirement benefit, including a disability insurance benefit and a dependent’s or survivor’s benefit under subchapter II of chapter 7 of title 42, awarded before ","children":[{"tag":"date","attrib":{"date":"1954-09-01"},"text":"September 1, 1954","children":[],"tail":", to an individual or his survivor or beneficiary, insofar as the individual, before "},{"tag":"date","attrib":{"date":"1954-09-01"},"text":"September 1, 1954","children":[],"tail":"—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb8c79f01-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was convicted of an offense named by subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8312"},"text":"section 8312 of this title","children":[],"tail":", to the extent provided by that subsection; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8c79f02-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violated section 8314 or 8315(a)(1) of this title; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79f03-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8311/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a retirement benefit, including a disability insurance benefit and a dependent’s or survivor’s benefit under subchapter II of chapter 7 of title 42, awarded before ","children":[{"tag":"date","attrib":{"date":"1961-09-26"},"text":"September 26, 1961","children":