":"date","attrib":{"date":"1952-04-05"},"text":"April 5, 1952","children":[],"tail":", by the "},{"tag":"ref","attrib":{"href":"/us/act/1953-07-31/ch283"},"text":"Act of July 31, 1953, ch. 283","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/240"},"text":"67 Stat. 240","children":[],"tail":", and the reenactment of the provisions of the Act of "},{"tag":"date","attrib":{"date":"1952-04-05"},"text":"April 5, 1952","children":[],"tail":", insofar as they relate to the Atomic Energy Commission as section 145 of the Atomic Energy Act of 1954 ("},{"tag":"ref","attrib":{"href":"/us/stat/68/942"},"text":"68 Stat. 942","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2165"},"text":"42 U.S.C. 2165","children":[],"tail":"). The references to "},{"tag":"ref","attrib":{"href":"/us/act/1947-05-22/s1/2"},"text":"section 1(2) of the Act of May 22, 1947","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/61/125"},"text":"61 Stat. 125","children":[],"tail":"), section 1 of the joint resolution of "},{"tag":"date","attrib":{"date":"1947-05-21"},"text":"May 21, 1947","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/61/125"},"text":"61 Stat. 125","children":[],"tail":"), and "},{"tag":"ref","attrib":{"href":"/us/act/1948-04-03/s110/c"},"text":"section 110(c) of the Act of April 3, 1948","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/62/137"},"text":"62 Stat. 137","children":[],"tail":") are omitted as these Acts were repealed by the "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-26/ch937"},"text":"Act of Aug. 26, 1954, ch. 937","children":[],"tail":" § 542(a) (1), (2), and (4), "},{"tag":"ref","attrib":{"href":"/us/stat/68/861"},"text":"68 Stat. 861","children":[],"tail":". Reference to section 510 of the Mutual Security Act of 1951 ("},{"tag":"ref","attrib":{"href":"/us/stat/65/381"},"text":"65 Stat. 381","children":[],"tail":") is omitted because this section was replaced by section 531 of the Mutual Security Act of 1954 ("},{"tag":"ref","attrib":{"href":"/us/stat/68/859"},"text":"68 Stat. 859","children":[],"tail":") and the latter was repealed by the Act of "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/195/s642/2"},"text":"Pub. L. 87–195, § 642(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/460"},"text":"75 Stat. 460","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the references to section 10(b)(5)(B)(i) and (ii) of the Atomic Energy Act of 1946, section 510 of the Mutual Security Act of 1951, a majority of the members of the Atomic Energy Commission, and the Director of Mutual Security (which was changed to Director of the International Cooperation Administration on authority of section 8 of 1953 Reorg. Plan No. 7, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/67/641"},"text":"67 Stat. 641","children":[],"tail":", and Executive Order 10610 of "},{"tag":"date","attrib":{"date":"1955-05-09"},"text":"May 9, 1955","children":[],"tail":") are omitted because of the disposition of the two sections as explained with reference to subsection (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “There is established” are omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the reference to statutes other than this section is omitted because nothing in those statutes affect the responsibility in question.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7ec3369-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb7ec336a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1874/c"},"text":"Section 1874(c) of title 42","children":[],"tail":", referred to in subsec. (a)(2), which related to clearance of National Science Foundation personnel, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/96/516/s21/b/1"},"text":"Pub. L. 96–516, § 21(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3010"},"text":"94 Stat. 3010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7ec336b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/80/s2/1"},"text":"Pub. L. 113–80, § 2(1)","children":[],"tail":", inserted “, and for the cost of audits, investigations, and oversight activities, conducted by the Inspector General of the Office, of the fund and the activities financed by the fund” before period at end of first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/80/s2/2"},"text":"Pub. L. 113–80, § 2(2)","children":[],"tail":", designated existing provisions as subpar. (A) and added subpars. (B) and (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" inserted “, including personnel management services performed at the request of individual agencies (which would otherwise be the responsibility of such agencies), or at the request of nonappropriated fund instrumentalities” before period at end of first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (e)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" struck out before period at end “at least once every three years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (e)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/437"},"text":"Pub. L. 103–437","children":[],"tail":" substituted “Committee on Governmental Affairs of the Senate and the Committee on Post Office and Civil Service of the House” for “Committees on Post Office and Civil Service of the Senate and House”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/224"},"text":"Pub. L. 98–224","children":[],"tail":" struck out cl. (i) designation and struck out cl. (ii) which provided that participation fees imposed by the President’s Commission on Executive Exchange for private sector participation in its Executive Exchange Program be collected and credited to the fund, and be available for the costs of education and related travel of exchanged executives, for printing without regard to "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s501"},"text":"section 501 of title 44","children":[],"tail":", and, in such amounts as specified in appropriations Acts, for entertainment expenses. See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s4109/d"},"text":"section 4109(d) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/412"},"text":"Pub. L. 97–412","children":[],"tail":" designated existing provisions as cl. (i) and added cl. (ii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/60"},"text":"Pub. L. 96–60","children":[],"tail":" struck out reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1434"},"text":"section 1434 of title 22","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsecs. (a) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Office of Personnel Management” for “Civil Service Commission” and “Office” for “Commission” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/648"},"text":"Pub. L. 91–648","children":[],"tail":" struck out in par. (1) “of $4,000,000” after “revolving fund” and inserted in par. (2)(A) “, which appropriations are hereby authorized”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1969—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/189/s1/a"},"text":"Pub. L. 91–189, § 1(a)","children":[],"tail":", increased the scope of reimbursable services for which the fund may be used, restricted reimbursement to services which were included in the budget estimates submitted to Congress for that fiscal year, inserted a list of components which comprise the fund, specifically listed those items that would be credited directly to the capital fund, required that a budget be prepared by the Commission, and directed the Comptroller General as a result of the activities financed to make recommendations to the committees on Post Office and Civil Service of the Senate and House of Representatives at least once every three years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/189/s1/b"},"text":"Pub. L. 91–189, § 1(b)","children":[],"tail":", authorized an agency to use available appropriations to reimburse the Commission or the Federal Bureau of Investigation for the cost of training and functions performed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7eea46c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb7eea46d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Governmental Affairs of Senate changed to Committee on Homeland Security and Governmental Affairs of Senate, effective ","children":[{"tag":"date","attrib":{"date":"2005-01-04"},"text":"Jan. 4, 2005","children":[],"tail":", by Senate Resolution No. 445, One Hundred Eighth Congress, "},{"tag":"date","attrib":{"date":"2004-10-09"},"text":"Oct. 9, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7eea46e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1983 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/412/s1/b"},"text":"Pub. L. 97–412, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-03"},"text":"Jan. 3, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2047"},"text":"96 Stat. 2047","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/412/s1/b"},"text":"“The authority granted in subsection (a) [amending this section] shall terminate on ","children":[{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":