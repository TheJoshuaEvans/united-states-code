{"tag":"section","attrib":{"id":"idb79400fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s410"},"text":null,"children":[{"tag":"num","attrib":{"value":"410"},"text":"§ 410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special provisions concerning the Nuclear Regulatory Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb79400fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s410/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chairman of the Commission may delegate the authority specified in the 2d sentence of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s403/a"},"text":"section 403(a) of this title","children":[],"tail":" to another member of the Nuclear Regulatory Commission, but shall not delegate such authority to any other officer or employee of the Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79400fe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s410/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraphs (7) and (8) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s406/a"},"text":"section 406(a) of this title","children":[],"tail":", the Inspector General of the Nuclear Regulatory Commission is authorized to select, appoint, and employ such officers and employees as may be necessary for carrying out the functions, powers, and duties of the Office of Inspector General and to obtain the temporary or intermittent services of experts or consultants or an organization of experts or consultants, subject to the applicable laws and regulations that govern such selections, appointments, and employment, and the obtaining of such services, within the Nuclear Regulatory Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb79671ff-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/b"},"text":"Pub. L. 117–286, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4228"},"text":"136 Stat. 4228","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7967200-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7967201-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7967202-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib"