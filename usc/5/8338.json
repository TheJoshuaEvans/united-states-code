:[],"tail":" substituted “Court of Appeals for the Armed Forces” for “Court of Military Appeals”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/94"},"text":"Pub. L. 98–94","children":[],"tail":" added subsec. (c), and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8df6cb9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idb8df6cba-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provisions Deferred Annuities Under Laws Repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83"},"text":"Pub. L. 90–83","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83/s10/a"},"text":"Pub. L. 90–83, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/222"},"text":"81 Stat. 222","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/83/s10/a"},"text":"“The right to a deferred annuity on satisfaction of the conditions attached thereto is continued notwithstanding the repeal by this Act of the law conferring the right.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
