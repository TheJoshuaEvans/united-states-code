ll}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1002(a) (3d sentence, less 1st 28 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1006 (2d sentence, as applicable to pay and allowances).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-03-07/ch166/s6"},"text":"Mar. 7, 1942, ch. 166, § 6","children":[],"tail":" (2d sentence, as applicable to pay and allowances); added"}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-12-24/ch828/s1"},"text":"Dec. 24, 1942, ch. 828, § 1","children":[],"tail":" (4th par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/56/1093"},"text":"56 Stat. 1093","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/428/s1/5/B"},"text":"Pub. L. 88–428, § 1(5)(B)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/437"},"text":"78 Stat. 437","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Only that portion of the source law which is applicable to civilian officers and employees and their dependents is codified in this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “An employee in a missing status” are substituted for the first 66 words of 50A U.S.C. 1002(a) to conform to the definitions in section 5561(2) and (5). The words “pay and allowances” are substituted for the enumeration of pay and allowances in the first sentence of 50A U.S.C. 1002(a) to conform to the definition in sections 5561(6). The words “or is performing full-time training duty, other full-time duty, or inactive duty training” and “except that the pay and allowances for a person who is performing full-time training duty or other full-time duty without pay, or inactive duty training with or without pay, shall be that to which he would have been entitled if he had been performing full-time active duty with pay;” are omitted as inapplicable to civilian officers and employees.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “under subsection (a) of this section” are inserted for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “United States” are substituted for “Government” to conform to the style of this title. The words “under subsection (a) of this section” are inserted for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “an employee in a missing status” are substituted for “a person missing under the conditions specified in section 2 of this Act” to conform to the definitions in section 5561(2) and (5).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8769839-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb876983a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1973-12-14"},"text":"December 14, 1973","children":[],"tail":",” for “the date of enactment of this sentence”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/181"},"text":"Pub. L. 93–181","children":[],"tail":" inserted provisions relating to employees in missing status on or after "},{"tag":"date","attrib":{"date":"1965-01-01"},"text":"January 1, 1965","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb876983b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb876983c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-07-12"},"text":"July 12, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/b"},"text":"section 2(b) of Pub. L. 96–54","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s305"},"text":"section 305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb876983d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Former Employees or Their Beneficiaries","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/181/s7/b"},"text":"Pub. L. 93–181, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-12-14"},"text":"Dec. 14, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/707"},"text":"87 Stat. 707","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/181/s7/b"},"text":"“The amendment made by subsection (a) of this section [amending subsec. (a) of this section] shall apply to former employees or their beneficiaries.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
