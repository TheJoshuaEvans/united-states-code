{"tag":"section","attrib":{"id":"idb884f0df-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5725"},"text":null,"children":[{"tag":"num","attrib":{"value":"5725"},"text":"§ 5725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation expenses; employees assigned to danger areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb884f0e0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When an employee of the Government is on duty, or is transferred or assigned to duty, at a place designated by the head of the agency concerned as inside a zone—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb884f0e1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5725/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from which his immediate family should be evacuated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb884f0e2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5725/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which they are not permitted to accompany him;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"because of military or other reasons which create imminent danger to life or property, or adverse living conditions which seriously affect the health, safety, or accommodations of the immediate family, Government funds may be used to transport his immediate family and household goods, personal effects, and family household pets, under regulations prescribed by the head of the agency, to a location designated by the employee. When circumstances prevent the employee from designating a location, or it is administratively impracticable to determine his intent, the immediate family may designate the location. When the designated location is inside a zone to which movement of families is prohibited under this subsection, the employee or his immediate family may designate an alternate location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb884f0e3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the employee is assigned to a duty station from which his immediate family is not excluded by the restrictions in subsection (a) of this section, Government funds may be used to transport his immediate family and household goods and personal effects from the designated or alternate location to the duty station.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb884f0e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5725/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb884f0e5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5725/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expenses authorized under subsection (a) shall, with respect to the transport of family household pets, include the expenses for the shipment of and the payment of any quarantine costs for such pets.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb884f0e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5725/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any payment or reimbursement under this section in connection with the transport of family household pets shall be subject to terms and conditions which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb884f0e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5725/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the agency shall by regulation prescribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb884f0e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5725/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, to the extent practicable, be the same as would apply under regulations prescribed under subsections (c) and (d) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s453"},"text":"section 453 of title 37","children":[],"tail":" in connection with the transport of family household pets of members of the uniformed services, including regulations relating to the types, size, and number of pets for which such payment or reimbursement may be provided."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb884f0e9-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/503"},"text":"80 Stat. 503","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/264/s6/6"},"text":"Pub. L. 105–264, § 6(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2356"},"text":"112 Stat. 2356","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tXI/s1106"},"text":"Pub. L. 112–239, div. A, title XI, § 1106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1973"},"text":"126 Stat. 1973","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/dA/tVI/s626/b/2"},"text":"Pub. L. 117–263, div. A, title VI, § 626(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2628"},"text":"136 Stat. 2628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb884f0ea-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb884f0eb-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb884f0ec-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"