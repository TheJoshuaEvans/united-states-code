ttrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s73b–3/a"},"text":"5 U.S.C. 73b–3(a)","children":[],"tail":" (4th proviso)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/858"},"text":"Pub. L. 85–858","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/1274"},"text":"72 Stat. 1274","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The first 14 words of subsections (a) and (b), and subsection (c), are added on authority of former section 73b–3(a) (less 3d–6th provisos), which is carried into section 5722.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8873b16-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8873b17-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/264"},"text":"Pub. L. 105–264","children":[],"tail":" substituted “an employee of the Government” for “an employee of the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsecs. (a) to (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1723/b/1"},"text":"Pub. L. 104–201, § 1723(b)(1)","children":[],"tail":", substituted “Under regulations prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5738"},"text":"section 5738 of this title","children":[],"tail":"” for “Under such regulations as the President may prescribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/253/s351/a"},"text":"Pub. L. 97–253, § 351(a)","children":[],"tail":", inserted “, Alaska, and Hawaii” after “continental United States” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/253/s351/b"},"text":"Pub. L. 97–253, § 351(b)","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8873b18-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8873b19-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1725/a"},"text":"section 1725(a) of Pub. L. 104–201","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5722"},"text":"section 5722 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8873b1a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/253/tIII/s351/c"},"text":"Pub. L. 97–253, title III, § 351(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/800"},"text":"96 Stat. 800","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/97/346/s3/m"},"text":"Pub. L. 97–346, § 3(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-15"},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1649"},"text":"96 Stat. 1649","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/346/s3/m"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the amendments made by subsection (a) [amending this section] shall take effect with respect to expenses incurred after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":"] for round-trip travel (commenced after such date) of an employee or transportation of his immediate family from his post of duty to the place of his actual residence at the time of appointment or transfer to the post of duty."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The amendments made by this section [amending this section] shall not apply to any employee who is serving a tour of duty at a post of duty in Alaska or Hawaii on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1982-09-08"},"text":"Sept. 8, 1982","children":[],"tail":"] during—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such tour of duty, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other consecutive tour of duty following such tour of duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of subsection (c), the term ‘employee’ shall have the same meaning as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5721/2"},"text":"section 5721(2) of title 5","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
