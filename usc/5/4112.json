{"tag":"section","attrib":{"id":"idb82a4d3b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4112"},"text":null,"children":[{"tag":"num","attrib":{"value":"4112"},"text":"§ 4112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Absorption of costs within funds available","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82a4d3c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President, to the extent he considers practicable, shall provide by regulation for the absorption of the costs of the training programs and plans under this chapter by the respective agencies from applicable appropriations or funds available for each fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82a4d3d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) of this section may not be held or considered to require—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82a4d3e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the separation of an individual from the service by reduction in force or other personnel action; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82a4d3f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the placement of an individual in a leave-without-pay status.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"