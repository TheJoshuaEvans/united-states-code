{"tag":"section","attrib":{"id":"idb7bc97d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s576"},"text":null,"children":[{"tag":"num","attrib":{"value":"576"},"text":"§ 576.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement of arbitration agreements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An agreement to arbitrate a matter to which this subchapter applies is enforceable pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t9/s4"},"text":"section 4 of title 9","children":[],"tail":", and no action brought to enforce such an agreement shall be dismissed nor shall relief therein be denied on the grounds that it is against the United States or that the United States is an indispensable party."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7bc97d3-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/552/s4/b"},"text":"Pub. L. 101–552, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2742"},"text":"104 Stat. 2742","children":[],"tail":", § 586; renumbered § 576, "},{"tag":"ref","attrib":{"href":"/us/pl/102/354/s3/b/2"},"text":"Pub. L. 102–354, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/944"},"text":"106 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7bc97d4-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7bc97d5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}