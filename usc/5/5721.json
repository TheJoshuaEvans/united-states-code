{"tag":"section","attrib":{"id":"idb882800f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721"},"text":null,"children":[{"tag":"num","attrib":{"value":"5721"},"text":"§ 5721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8828010-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8828011-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8828012-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a military department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8828013-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a court of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8828014-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrative Office of the United States Courts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8828015-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Library of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8828016-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Botanic Garden;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8828017-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Architect of the Capitol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8828018-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government Publishing Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8828019-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include a Government controlled corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb882801a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “employee” means an individual employed in or under an agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb882801b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “continental United States” means the several States and the District of Columbia, but does not include Alaska or Hawaii;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb882801c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Government” means the Government of the United States and the government of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb882801d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “appropriation” includes funds made available by statute under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9104"},"text":"section 9104 of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb882801e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States” means the several States, the District of Columbia, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, the territories and possessions of the United States, and the areas and installations in the Republic of Panama that are made available to the United States pursuant to the Panama Canal Treaty of 1977 and related agreements (as described in section 3(a) of the Panama Canal Act of 1979); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb882801f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5721/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Foreign Service of the United States” means the Foreign Service as constituted under the Foreign Service Act of 1980.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8828020-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/500"},"text":"80 Stat. 500","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/a/14"},"text":"Pub. L. 97–258, § 3(a)(14)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1063"},"text":"96 Stat. 1063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/264/s6/1"},"text":"Pub. L. 105–264, § 6(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2356"},"text":"112 Stat. 2356","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s1303/a"},"text":"Pub. L. 110–161, div. H, title I, § 1303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2242"},"text":"121 Stat. 2242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8828021-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8828022-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The section is based on sections 18 and 19 of the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch744"},"text":"Act of Aug. 2, 1946, ch. 744","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/811"},"text":"60 Stat. 811","children":[],"tail":", 812. Sections 18 and 19 of the Act of "},{"tag":"date","attrib":{"date":"1946-08-02"},"text":"Aug. 2, 1946","children":[],"tail":", are omitted from this title and transferred to other titles of the United States Code since such sections apply also to sections 9, 11, and 16(a) of the Act of "},{"tag":"date","attrib":{"date":"1946-08-02"},"text":"Aug. 2, 1946","children":[],"tail":", which sections appear in titles 31 and 41 of the United States Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8828023-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8828024-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":