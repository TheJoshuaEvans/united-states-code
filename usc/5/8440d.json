{"tag":"section","attrib":{"id":"idb90592dd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440d"},"text":null,"children":[{"tag":"num","attrib":{"value":"8440d"},"text":"§ 8440d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judges of the United States Court of Appeals for Veterans Claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb90592de-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90592df-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A judge of the United States Court of Appeals for Veterans Claims may elect to contribute to the Thrift Savings Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592e0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An election may be made under paragraph (1) as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432/b"},"text":"section 8432(b) of this title","children":[],"tail":" for individuals subject to this chapter."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90592e1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90592e2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this subsection, the provisions of this subchapter and subchapter VII of this chapter shall apply with respect to a judge making contributions to the Thrift Savings Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592e3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount contributed by a judge of the United States Court of Appeals for Veterans Claims for any pay period may not exceed the maximum percentage of such judge’s basic pay for such pay period allowable under section 8440f. Basic pay does not include any retired pay paid pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7296"},"text":"section 7296 of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No contributions may be made for the benefit of a judge under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432/c"},"text":"section 8432(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592e5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440d/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8433/b"},"text":"Section 8433(b) of this title","children":[],"tail":" applies with respect to a judge who elects to make contributions to the Thrift Savings Fund and retires under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7296/b"},"text":"section 7296(b) of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440d/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8433/b"},"text":"Section 8433(b) of this title","children":[],"tail":" applies in the case of a judge who elects to make contributions to the Thrift Savings Fund and thereafter ceases to serve as a judge of the United States Court of Appeals for Veterans Claims but does not retire under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7296/b"},"text":"section 7296(b) of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440d/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of section 8351(b)(7) ","children":[{"tag":"ref","attrib":{"idref":"fn002184"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002184"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title shall apply with respect to a judge who has elected to contribute to the Thrift Savings Fund under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb90592e8-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/82/s5/a/1"},"text":"Pub. L. 102–82, § 5(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-06"},"text":"Aug. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/376"},"text":"105 Stat. 376","children":[],"tail":", § 8440c; renumbered § 8440d, "},{"tag":"ref","attrib":{"href":"/us/pl/102/198/s7/c/4/A"},"text":"