{"tag":"section","attrib":{"id":"idb82c9804-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4304"},"text":null,"children":[{"tag":"num","attrib":{"value":"4304"},"text":"§ 4304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of the Office of Personnel Management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82c9805-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall make technical assistance available to agencies in the development of performance appraisal systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82c9806-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82c9807-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall review each performance appraisal system developed by any agency under this section and determine whether the performance appraisal system meets the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c9808-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General shall from time to time review on a selected basis performance appraisal systems established under this subchapter to determine the extent to which any such system meets the requirements of this subchapter and shall periodically report its findings to the Office and to the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c9809-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Office determines that a system does not meet the requirements of this subchapter (including regulations prescribed under section 4305), the Office shall direct the agency to implement an appropriate system or to correct operations under the system, and any such agency shall take any action so required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82c980a-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/440"},"text":"80 Stat. 440","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tII/s203/a"},"text":"Pub. L. 95–454, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1134"},"text":"92 Stat. 1134","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82c980b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb82c980c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb82c980d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},