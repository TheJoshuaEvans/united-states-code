{"tag":"section","attrib":{"id":"idb926fd83-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9206"},"text":null,"children":[{"tag":"num","attrib":{"value":"9206"},"text":"§ 9206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules of construction","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Nothing in this chapter may be construed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb926fd84-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9206/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize any officer or employee of an agency to request the disclosure of information described under subparagraphs (B) and (C) of section 9201(4); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd85-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9206/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" create a private right of action for any person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb926fd86-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI/s1122/a"},"text":"Pub. L. 116–92, div. A, title XI, § 1122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1607"},"text":"133 Stat. 1607","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
