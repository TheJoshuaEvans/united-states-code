{"tag":"section","attrib":{"id":"idb8b6fd92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7531"},"text":null,"children":[{"tag":"num","attrib":{"value":"7531"},"text":"§ 7531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter, “agency” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b6fd93-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7531/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd94-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7531/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd95-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7531/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Justice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd96-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7531/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd97-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7531/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a military department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd98-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7531/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd99-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7531/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Atomic Energy Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd9a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7531/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Aeronautics and Space Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd9b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7531/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other agency of the Government of the United States as the President designates in the best interests of national security.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The President shall report any designation to the Committees on the Armed Services of the Congress.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b6fd9c-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/528"},"text":"80 Stat. 528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b6fd9d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8b6fd9e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8b6fd9f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s22–3"},"text":"5 U.S.C. 22–3","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-08-26/ch823/s3"},"text":"Aug. 26, 1950, ch. 823, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/477"},"text":"64 Stat. 477","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraphs (1)–(8) are supplied on authority of former section 22–1, which is carried in part into section 7532. The references to “the Foreign Service of the United States” and “several field services” are omitted as unnecessary since they are within the agencies concerned. The words “military departments” are substituted for the enumeration of the military departments in view of the definition of “military department” in section 102.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The reference to the National Security Resources Board is omitted as the Board was abolished by 1953 Reorg. Plan No. 3, § 6, eff. ","children":[{"tag":"date","attrib":{"date":"1953-06-12"},"text":"June 12, 1953","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/636"},"text":"67 Stat. 636","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraph (9) is restated to conform to the style of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b6fda0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb8b6fda1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8b6fda2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Atomic Energy Commission","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Atomic Energy Commission abolished and functions transferred by sections 5814 and 5841 of Title 42, The Public Health and Welfare. See, also, Transfer of Functions notes set out under those sections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb8b6fda3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8b6fda4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Panama Canal and Panama Railroad Company","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 10237, ","children":[{"tag":"date","attrib":{"date":"1951-04-27"},"text":"Apr. 27, 1951","children":[],"tail":", 16 F.R. 3627, made the provisions of former sections 22–1 and 22–3 of this title [see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of this title","children":[],"tail":"] applicable to the Panama Canal Government and to the Panama Canal Company."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8b6fda5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Designation of National Security Agency, Defense Intelligence Agency, and Defense Mapping Agency as “Agencies”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of the President of the United States, ","children":[{"tag":"date","attrib":{"date":"1988-05-23"},"text":"May 23, 1988","children":[],"tail":", 53 F.R. 26023, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Secretary of Defense","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"I have reviewed the personnel security requirements of the National Security Agency, the Defense Intelligence Agency, and the Defense Mapping Agency and the termination provisions of 5 U.S.C. Section 7532. I have determined that these Agencies are sensitive agencies and that it is in the best interests of national security that they be designated “agencies” within the meaning of that section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Therefore, pursuant to the authority set forth in 5 U.S.C. Section 7531(9), I hereby designate the National Security Agency, the Defense Intelligence Agency, and the Defense Mapping Agency as “agencies” within the meaning of 5 U.S.C. Section 7532.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"You are hereby authorized and directed to report these designations to the Committees on Armed Services of the Congress and to publish this memorandum in the Federal Register.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Ronald Reagan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
