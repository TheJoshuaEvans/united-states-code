{"tag":"section","attrib":{"id":"idb78a8b78-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s323"},"text":null,"children":[{"tag":"num","attrib":{"value":"323"},"text":"§ 323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lead agency officials for Government service delivery","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb78a8b79-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibility for Government Service Delivery","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each agency shall be responsible for the Government service delivery of the agency which shall, at a minimum, include improving and enhancing Government services to better achieve the mission of the agency and build and maintain trust, transparency, and accountability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78a8b7a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lead Agency Service Delivery Officials","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than one year after the date of the enactment of this subchapter, the head of each agency shall designate or appoint a senior official of the agency (who may be the deputy head of the agency) to implement this subchapter who shall have the following duties and authorities:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb78a8b7b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s323/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Report directly to the head or deputy head of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b7c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s323/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Possess sufficient operational authority to effectuate implementation of Government service delivery improvements within the agency, particularly with respect to high impact service providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b7d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s323/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinate and execute, as appropriate, under the direction of the head of the agency, and in collaboration with relevant agency officials as appropriate, efforts to improve and enhance the Government service delivery and Government service delivery channels of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b7e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s323/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the direction of the Federal Government Service Delivery Lead, submit an implementation plan for improving agency Government service delivery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b7f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s323/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordinate the collection and reporting of the data and information required pursuant to section 322 and use such data and information to improve Government service delivery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b80-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s323/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Facilitate collaboration among and between offices, and components within the agency and with other agencies as appropriate, in coordination with the Federal Government Service Delivery Lead, to improve and enhance Government service delivery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b81-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s323/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assist with the implementation by the agency of the 21st Century Integrated Digital Experience Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3501"},"text":"15 U.S.C. 3501","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/115/336"},"text":"Public Law 115–336","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b82-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s323/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assist in the incorporation of the Government service delivery requirements established under this subchapter in agency plans (such as strategic plans or annual performance plans).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb78a8b83-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/231/s2/a"},"text":"Pub. L. 118–231, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2831"},"text":"138 Stat. 2831","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb78a8b84-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb78a8b85-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb78a8b86-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this subchapter, referred to in subsec. (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/231"},"text":"Pub. L. 118–231","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
