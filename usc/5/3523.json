{"tag":"section","attrib":{"id":"idb8232204-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523"},"text":null,"children":[{"tag":"num","attrib":{"value":"3523"},"text":"§ 3523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to provide voluntary separation incentive payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8232205-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A voluntary separation incentive payment under this subchapter may be paid to an employee only as provided in the plan of an agency established under section 3522.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8232206-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A voluntary incentive payment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8232207-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be offered to agency employees on the basis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8232208-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more organizational units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8232209-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more occupational series or levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb823220a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more geographical locations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb823220b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" skills, knowledge, or other factors related to a position;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb823220c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific periods of time during which eligible employees may elect a voluntary incentive payment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb823220d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any appropriate combination of such factors;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb823220e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be paid in a lump sum after the employee’s separation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb823220f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be equal to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8232210-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the amount the employee would be entitled to receive under section 5595(c) if the employee were entitled to payment under such section (without adjustment for any previous payment made); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8232211-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount determined by the agency head, not to exceed $25,000;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8232212-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be made only in the case of an employee who voluntarily separates (whether by retirement or resignation) under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8232213-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be a basis for payment, and shall not be included in the computation, of any other type of Government benefit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8232214-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be taken into account in determining the amount of any severance pay to which the employee may be entitled under section 5595, based on another other ","children":[{"tag":"ref","attrib":{"idref":"fn002069"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002069"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" separation; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8232215-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3523/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be paid from appropriations or funds available for the payment of the basic pay of the employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8232216-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1313/a/1/A"},"text":"Pub. L. 107–296, title XIII, § 1313(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2293"},"text":"116 Stat. 2293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8232217-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8232218-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8232219-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1313/a/4"},"text":"section 1313(a)(4) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3521"},"text":"section 3521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
