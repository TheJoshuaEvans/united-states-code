{"tag":"section","attrib":{"id":"idb7fcfbb7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3110"},"text":null,"children":[{"tag":"num","attrib":{"value":"3110"},"text":"§ 3110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of relatives; restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7fcfbb8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7fcfbb9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3110/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7fcfbba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3110/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fcfbbb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3110/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an office, agency, or other establishment in the legislative branch;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fcfbbc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3110/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an office, agency, or other establishment in the judicial branch; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fcfbbd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3110/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fcfbbe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3110/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “public official” means an officer (including the President and a Member of Congress), a member of the uniformed service, an employee and any other individual, in whom is vested the authority by law, rule, or regulation, or to whom the authority has been delegated, to appoint, employ, promote, or advance individuals, or to recommend individuals for appointment, employment, promotion, or advancement in connection with employment in an agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fcfbbf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3110/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “relative” means, with respect to a public official, an individual who is related to the public official as father, mother, son, daughter, brother, sister, uncle, aunt, first cousin, nephew, niece, husband, wife, father-in-law, mother-in-law, son-in-law, daughter-in-law, brother-in-law, sister-in-law, stepfather, stepmother, stepson, stepdaughter, stepbrother, stepsister, half brother, or half sister.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fcfbc0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A public official may not appoint, employ, promote, advance, or advocate for appointment, employment, promotion, or advancement, in or to a civilian position in the agency in which he is serving or over which he exercises jurisdiction or control any individual who is a relative of the public official. An individual may not be appointed, employed, promoted, or advanced in or to a civilian position in an agency if such appointment, employment, promotion, or advancement has been advocated by a public official, serving in or exercising jurisdiction or control over the agency, who is a relative of the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fcfbc1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual appointed, employed, promoted, or advanced in violation of this section is not entitled to pay, and money may not be paid from the Treasury as pay to an individual so appointed, employed, promoted, or advanced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fcfbc2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3110/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management may prescribe regulations authorizing the temporary employment, in the event of emergencies resulting from natural disasters or similar unforeseen events or circumstances, of individuals whose employment would otherwise be prohibited by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fcfbc3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3110/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not be construed to prohibit the appointment of an individual who is a preference eligible in any case in which the passing over of that individual on a certificate of eligibles furnished under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3317/a"},"text":"section 3317(a) of this title","children":[],"tail":" will result in the selection for appointment of an individual who is not a preference eligible."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7fcfbc4-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206/tII/s221/a"},"text":"Pub. L. 90–206, title II, § 221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/640"},"text":"81 Stat. 640","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/a/2"},"text":"Pub. L. 95–454, title IX, § 906(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1224"},"text":"92 Stat. 1224","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7fcfbc5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7fcfbc6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7fcfbc7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Office of Personnel Management” for “Civil Service Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7fcfbc8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7fcfbc9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb7fcfbca-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206/tII/s220/a/1"},"text":"Pub. L. 90–206, title II, § 220(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/639"},"text":"81 Stat. 639","children":[],"tail":", provided, except as otherwise expressly provided, that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/206/tII/s220/a/1"},"text":"“This section [enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8704"},"text":"section 8704 of this title","children":[],"tail":"] and sections 201 [enacting provisions set out as Short Title note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"], 207 [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5303"},"text":"section 5303 of this title","children":[],"tail":"], 212 [enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5303"},"text":"section 5303 of this title","children":[],"tail":"], 218 [enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"], 221 [enacting this section and provisions set out as a note under this section], 224(a) and (b) [amending sections 4101 and 8339 of this title], and 225 [enacting sections 351–361 of Title 2, The Congress] shall become effective on the date of enactment of this title ["},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"retroactiveDate","id":"idb7fcfbcb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Retroactive Effect","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206/tII/s221/c"},"text":"Pub. L. 90–206, title II, § 221(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/641"},"text":"81 Stat. 641","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/206/tII/s221/c"},"text":"“The amendments made by this section [enacting this section] do not apply to an appointment, employment, advancement, or promotion made or advocated by a public official of any individual who is a relative of the public official if, prior to the effective date of this section [see Effective Date note above], the individual was appointed by the public official, or received an appointment advocated by the public official, and is serving under the appointment on such effective date.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206/s221/c"},"text":"Section 221(c) of Pub. L. 90–206","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1967-12-16"},"text":"Dec. 16, 1967","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/206/s220/a/1"},"text":"section 220(a)(1) of Pub. L. 90–206","children":[],"tail":", set out as an Effective Date note above.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
