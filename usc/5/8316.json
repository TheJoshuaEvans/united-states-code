"tag":"p","attrib":{},"text":"This section is reorganized for clarity and conciseness.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3282"},"text":"section 3282 of Title 18","children":[],"tail":"” in former section 2284(a) are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c79f82-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8c79f83-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 5 of the Uniform Services Contingency Option Act of 1953 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/67/504"},"text":"67 Stat. 504","children":[],"tail":"), referred to in text, is covered by "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1438"},"text":"section 1438 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
