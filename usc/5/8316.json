{"tag":"section","attrib":{"id":"idb8c79f74-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8316"},"text":null,"children":[{"tag":"num","attrib":{"value":"8316"},"text":"§ 8316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of contributions and deposits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c79f75-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When payment of annuity or retired pay is denied under this subchapter because an individual was convicted of an offense named by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8312"},"text":"section 8312 of this title","children":[],"tail":", to the extent provided by that section, or violated section 8314 or 8315 of this title—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c79f76-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8316/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount, except employment taxes, contributed by the individual toward the annuity, less the amount previously refunded or paid as annuity benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c79f77-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8316/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deposits made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1438"},"text":"section 1438 of title 10","children":[],"tail":" or section 5 of the Uniformed Services Contingency Option Act of 1953 ("},{"tag":"ref","attrib":{"href":"/us/stat/67/504"},"text":"67 Stat. 504","children":[],"tail":") to provide the eligible beneficiary with annuity for any period, less the amount previously paid as retired pay benefits;"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be refunded, on appropriate application therefor—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79f78-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8316/a/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79f79-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8316/a/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the individual is dead, to the beneficiary designated to receive refunds by or under the statute, regulation, or agreement under which the annuity, the benefits of which are denied under this subchapter, would have been payable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79f7a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8316/a/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a beneficiary is not designated, in the order of precedence prescribed by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8342/c"},"text":"section 8342(c) of this title","children":[],"tail":" or "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2771"},"text":"section 2771 of title 10","children":[],"tail":", as the case may be."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c79f7b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A refund under subsection (a) of this section shall be made with interest at the rate and for the period provided under the statute, regulation, or agreement under which the annuity would have been payable. However, interest may not be computed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c79f7c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8316/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the individual was convicted of an offense named by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8312/b"},"text":"section 8312(b) of this title","children":[],"tail":", or violated section 8314 or 8315(a)(1) of this title, for the period after the conviction or commission of the violation, or after "},{"tag":"date","attrib":{"date":"1954-09-01"},"text":"September 1, 1954","children":[],"tail":", whichever is later; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c79f7d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8316/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the individual was convicted of an offense named by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8312/c"},"text":"section 8312(c) of this title","children":[],"tail":", or violated "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8315/a/2"},"text":"section 8315(a)(2) of this title","children":[],"tail":", for the period after the conviction or commission of the violation, or after "},{"tag":"date","attrib":{"date":"1961-09-26"},"text":"September 26, 1961","children":[],"tail":", whichever is later."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c79f7e-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/563"},"text":"80 Stat. 563","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c79f7f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c79f80-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c79f81-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],