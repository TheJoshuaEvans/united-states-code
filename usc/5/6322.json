{"tag":"section","attrib":{"id":"idb89a4e34-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6322"},"text":null,"children":[{"tag":"num","attrib":{"value":"6322"},"text":"§ 6322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Leave for jury or witness service; official duty status for certain witness service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89a4e35-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":" (except an individual whose pay is disbursed by the Secretary of the Senate or the Chief Administrative Officer of the House of Representatives) or an individual employed by the government of the District of Columbia is entitled to leave, without loss of, or reduction in, pay, leave to which he otherwise is entitled, credit for time or service, or performance of efficiency rating, during a period of absence with respect to which he is summoned, in connection with a judicial proceeding, by a court or authority responsible for the conduct of that proceeding, to serve—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89a4e36-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6322/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a juror; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89a4e37-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6322/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other than as provided in subsection (b) of this section, as a witness on behalf of any party in connection with any judicial proceeding to which the United States, the District of Columbia, or a State or local government is a party;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in the District of Columbia, a State, territory, or possession of the United States including the Commonwealth of Puerto Rico or the Trust Territory of the Pacific Islands. For the purpose of this subsection, “judicial proceeding” means any action, suit, or other judicial proceeding, including any condemnation, preliminary, informational, or other proceeding of a judicial nature, but does not include an administrative proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89a4e38-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":" (except an individual whose pay is disbursed by the Secretary of the Senate or the Chief Administrative Officer of the House of Representatives) or an individual employed by the government of the District of Columbia is performing official duty during the period with respect to which he is summoned, or assigned by his agency, to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89a4e39-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6322/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" testify or produce official records on behalf of the United States or the District of Columbia; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89a4e3a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6322/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" testify in his official capacity or produce official records on behalf of a party other than the United States or the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89a4e3b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management may prescribe regulations for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89a4e3c-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/522"},"text":"80 Stat. 522","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/563/s1/a"},"text":"Pub. L. 91–563, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-19"},"text":"Dec. 19, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1476"},"text":"84 Stat. 1476","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/310/s1"},"text":"Pub. L. 94–310, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-06-15"},"text":"June 15, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/687"},"text":"90 Stat. 687","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/a/2"},"text":"Pub. L. 95–454, title IX, § 906(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1224"},"text":"92 Stat. 1224","children":[],"tail":"