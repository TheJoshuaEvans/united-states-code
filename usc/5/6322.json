ildren":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89a4e40-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb89a4e41-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":", in concluding provisions, substituted “Puerto Rico or” for “Puerto Rico,” and struck out “, or the Republic of Panama” after “Pacific Islands”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer” for “Clerk” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer” for “Clerk”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70"},"text":"Pub. L. 96–70","children":[],"tail":" substituted “the Trust Territory of the Pacific Islands, or the Republic of Panama” for “the Canal Zone, or the Trust Territory of the Pacific Islands”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Office of Personnel Management” for “Civil Service Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/310"},"text":"Pub. L. 94–310","children":[],"tail":" substituted “other than as provided in subsection (b) of this section, as a witness on behalf of any party in connection with any judicial proceeding to which the United States, the District of Columbia, or a State or local government is a party” for “as a witness on behalf of a party other than the United States, the District of Columbia, or a private party”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/563"},"text":"Pub. L. 91–563","children":[],"tail":" included witness service and official duty status for certain witness service in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/563"},"text":"Pub. L. 91–563","children":[],"tail":" designated existing provisions as subsec. (a) and expanded such provisions to authorize leave for jury service in courts in the District of Columbia and in territories and possessions of the United States, to permit leave for persons summoned as witnesses in behalf of a party other than the United States, the District of Columbia, or a private party, defined “judicial proceeding”, and excepted individuals whose pay is disbursed by the Secretary of the Senate or the Clerk of the House of Representatives."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/563"},"text":"Pub. L. 91–563","children":[],"tail":" added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb89a4e42-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb89a4e43-5e84-11f1-a692-ec26