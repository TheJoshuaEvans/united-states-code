{"tag":"section","attrib":{"id":"idb8a17a06-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6385"},"text":null,"children":[{"tag":"num","attrib":{"value":"6385"},"text":"§ 6385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition of coercion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a17a07-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6385/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee shall not directly or indirectly intimidate, threaten, or coerce, or attempt to intimidate, threaten, or coerce, any other employee for the purpose of interfering with the exercise of any rights which such other employee may have under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a08-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6385/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a17a09-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6385/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “intimidate, threaten, or coerce” includes promising to confer or conferring any benefit (such as appointment, promotion, or compensation), or taking or threatening to take any reprisal (such as deprivation of appointment, promotion, or compensation); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a0a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6385/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employee” means any “employee”, as defined by section 2105.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a17a0b-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3/tII/s201/a/1"},"text":"Pub. L. 103–3, title II, § 201(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/22"},"text":"107 Stat. 22","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a17a0c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a17a0d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8a17a0e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 6 months after ","children":[{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/3/s405/b/1"},"text":"section 405(b)(1) of Pub. L. 103–3","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
