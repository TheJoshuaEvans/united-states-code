{"tag":"section","attrib":{"id":"idb89cbe7a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6325"},"text":null,"children":[{"tag":"num","attrib":{"value":"6325"},"text":"§ 6325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Absence resulting from hostile action abroad","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Leave may not be charged to the account of an employee for absence, not to exceed one year, due to an injury—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbe7b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6325/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incurred while serving abroad and resulting from war, insurgency, mob violence, or similar hostile action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbe7c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6325/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not due to vicious habits, intemperance, or willful misconduct on the part of the employee.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The preceding provisions of this section shall apply in the case of an alien employee referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6301/2/viii"},"text":"section 6301(2)(viii) of this title","children":[],"tail":" with respect to any leave granted to such alien employee under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6310"},"text":"section 6310 of this title","children":[],"tail":" or section 408 of the Foreign Service Act of 1980."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89cbe7d-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/221/s3/a"},"text":"Pub. L. 90–221, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-23"},"text":"Dec. 23, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/671"},"text":"81 Stat. 671","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/41"},"text":"Pub. L. 96–54, § 2(a)(41)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/383"},"text":"93 Stat. 383","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/399/tVIII/s804"},"text":"Pub. L. 99–399, title VIII, § 804","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-08-27"},"text":"Aug. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/883"},"text":"100 Stat. 883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb89cbe7e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89cbe7f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb89cbe80-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 408 of the Foreign Service Act of 1980, referred to in text, is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3968"},"text":"section 3968 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb89cbe81-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/399"},"text":"Pub. L. 99–399","children":[],"tail":" inserted sentence at end relating to alien employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" substituted provisions relating to leave charged to an account of an employee for absence, for provisions relating to leave charged to an account of any officer or employee for absence, and designated qualifying provisions as cls. (1) and (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb89cbe82-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb89cbe83-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-07-12"},"text":"July 12, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/b"},"text":"section 2(b) of Pub. L. 96–54","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s305"},"text":"section 305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb89cbe84-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/221/s3/c"},"text":"Pub. L. 90–221, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-12-23"},"text":"Dec. 23, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/671"},"text":"81 Stat. 671","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/221/s3/c"},"text":"“The amendment made by subsection (a) of this section [enacting this section] shall take effect as of the first day of the first pay period which began on or after ","children":[{"tag":"date","attrib":{"date":"1965-01-01"},"text":"January 1, 1965","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
