{"tag":"section","attrib":{"id":"idb8173b84-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3332"},"text":null,"children":[{"tag":"num","attrib":{"value":"3332"},"text":"§ 3332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officer affidavit; no consideration paid for appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An officer, within 30 days after the effective date of his appointment, shall file with the oath of office required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3331"},"text":"section 3331 of this title","children":[],"tail":" an affidavit that neither he nor anyone acting in his behalf has given, transferred, promised, or paid any consideration for or in the expectation or hope of receiving assistance in securing the appointment."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8173b85-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/424"},"text":"80 Stat. 424","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8173b86-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8173b87-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8173b88-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"