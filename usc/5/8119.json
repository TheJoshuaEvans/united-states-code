en":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s767"},"text":"5 U.S.C. 767","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-09-07/ch458/s17"},"text":"Sept. 7, 1916, ch. 458, § 17","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/746"},"text":"39 Stat. 746","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(2) is added on authority of former section 770, which is carried into section 8122, to complete the coverage of this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Administration of this subchapter was transferred to the Secretary of Labor by section 1 of 1950 Reorg. Plan No. 19, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1271"},"text":"64 Stat. 1271","children":[],"tail":" (see section 8145)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c073a0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c073a1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416"},"text":"Pub. L. 93–416","children":[],"tail":" substituted “or death” for “; failure to give” in section catchline, struck out designation of subsec. (a), redesignated cls. (1) to (7) as (a) to (g), and, as so redesignated, inserted provisions relating to notice of death and substituted “30 days” for “48 hours” in cl. (a), and struck out subsec. (b) relating to allowance of compensation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c073a2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8c073a3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416"},"text":"Pub. L. 93–416","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", and applicable to any injury or death occurring on or after "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s28/a"},"text":"section 28(a) of Pub. L. 93–416","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
