ch17/s1/b"},"text":"Apr. 4, 1953, ch. 17, § 1(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/21"},"text":"67 Stat. 21","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/428/s1/5"},"text":"Pub. L. 88–428, § 1(5)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/437"},"text":"78 Stat. 437","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1014 (as applicable to § 1006 (1st sentence)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-03-07/ch166/s14"},"text":"Mar. 7, 1942, ch. 166, § 14","children":[],"tail":" (as applicable to § 6 (1st sentence)), "},{"tag":"html:a","attrib":{"href":"/us/stat/56/147"},"text":"56 Stat. 147","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1953-04-04/ch17/s1/e"},"text":"Apr. 4, 1953, ch. 17, § 1(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/21"},"text":"67 Stat. 21","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1006 (2d sentence, as applicable to allotments).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(h)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50A U.S.C. 1007.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-03-07/ch166"},"text":"Mar. 7, 1942, ch. 166","children":[],"tail":" § 7, "},{"tag":"html:a","attrib":{"href":"/us/stat/56/145"},"text":"56 Stat. 145","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/428/s1/6"},"text":"Pub. L. 88–428, § 1(6)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/437"},"text":"78 Stat. 437","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Only that portion of the source law which is applicable to civilian officers and employees and their dependents is codified in this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “employee . . . in a missing status” are substituted for the reference to “person . . . entitled under section 2 of this Act to receive or be credited with pay and allowances” to conform to the definitions in section 5561(2) and (5). The words “except as otherwise provided herein” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “head of the agency concerned, he or his designee” are substituted for “head of the department concerned . . . head of the department concerned, or such subordinate as he may designate”. The word “employee” is substituted for “person” to conform to the definition in section 5561(2).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “in effect” are omitted as surplusage. The words “employee in a missing status” are substituted for “absent person” to conform to the definitions in section 5561(2) and (5).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “United States” are substituted for “Government” to conform to the style of this title. The word “employee” is substituted for “person” to conform to the definition in section 5561(2).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “head of the agency concerned or his designee” are substituted for “head of the department concerned, or such subordinates as he may designate”. The words “employee in a missing status” are substituted for “person entitled to receive or be credited with pay and allowances under section 2 of this Act” to conform to the definitions in section 5561(2) and (5). The words “United States” are substituted for “Government” to conform to the style of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (f) and (g), the words “employee in a missing status” are substituted for “person missing under the conditions specified in section 2 of this Act” to conform to the definitions in section 5561(2) and (5).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (h), the words “employee in a missing status” are substituted for “persons entitled under section 2 or 14 of this Act to receive pay and allowances” to conform to the definitions in section 5561(2) and (5). In paragraph (2), the words “heretofore or hereafter” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
