{"tag":"section","attrib":{"id":"idb8b21b8c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7313"},"text":null,"children":[{"tag":"num","attrib":{"value":"7313"},"text":"§ 7313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Riots and civil disorders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b21b8d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual convicted by any Federal, State, or local court of competent jurisdiction of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b21b8e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7313/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inciting a riot or civil disorder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21b8f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7313/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizing, promoting, encouraging, or participating in a riot or civil disorder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21b90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7313/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aiding or abetting any person in committing any offense specified in clause (1) or (2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21b91-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7313/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any offense determined by the head of the employing agency to have been committed in furtherance of, or while participating in, a riot or civil disorder;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall, if the offense for which he is convicted is a felony, be ineligible to accept or hold any position in the Government of the United States or in the government of the District of Columbia for the five years immediately following the date upon which his conviction becomes final. Any such individual holding a position in the Government of the United States or the government of the District of Columbia on the date his conviction becomes final shall be removed from such position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b21b92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, “felony” means any offense for which imprisonment is authorized for a term exceeding one year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b21b93-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tV/s1001/a"},"text":"Pub. L. 90–351, title V, § 1001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/235"},"text":"82 Stat. 235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b21b94-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b21b95-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8b21b96-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/351/tV/s1002"},"text":"Pub. L. 90–351, title V, § 1002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/235"},"text":"82 Stat. 235","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/351/tV/s1002"},"text":"“The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1001/a"},"text":"section 1001(a) of this title","children":[],"tail":" [enacting this section] shall apply only with respect to acts referred to in section 7313(a)(1)–(4) of title 5, United States Code, as added by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1001"},"text":"section 1001 of this title","children":[],"tail":", which are committed after the date of enactment of this title ["},{"tag":"date","attrib":{"date":"1968-06-19"},"text":"June 19, 1968","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8b21b97-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Receipt of Benefits Under Laws Providing Relief for Disaster Victims","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/448/tXI/s1106/e"},"text":"Pub. L. 90–448, title XI, § 1106(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-08-01"},"text":"Aug. 1, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/567"},"text":"82 Stat. 567","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/448/tXI/s1106/e"},"text":"“No person who has been convicted of committing a felony during and in connection with a riot or civil disorder shall be permitted, for a period of one year after the date of his conviction, to receive any benefit under any law of the United States providing relief for disaster victims.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
