{"tag":"section","attrib":{"id":"idb823221a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3524"},"text":null,"children":[{"tag":"num","attrib":{"value":"3524"},"text":"§ 3524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of subsequent employment with the Government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb823221b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3524/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “employment”—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb823221c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3524/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in subsection (b) includes employment under a personal services contract (or other direct contract) with the United States Government (other than an entity in the legislative branch); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb823221d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3524/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in subsection (c) does not include employment under such a contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb823221e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3524/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual who has received a voluntary separation incentive payment under this subchapter and accepts any employment for compensation with the Government of the United States with ","children":[{"tag":"ref","attrib":{"idref":"fn002070"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002070"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “within”."}],"tail":" 5 years after the date of the separation on which the payment is based shall be required to pay, before the individual’s first day of employment, the entire amount of the incentive payment to the agency that paid the incentive payment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb823221f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3524/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8232220-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3524/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the employment under this section is with an agency, other than the Government Accountability Office, the United States Postal Service, or the Postal Regulatory Commission, the Director of the Office of Personnel Management may, at the request of the head of the agency, may ","children":[{"tag":"ref","attrib":{"idref":"fn002071"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002071"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" waive the repayment if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8232221-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3524/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual involved possesses unique abilities and is the only qualified applicant available for the position; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8232222-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3524/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in case of an emergency involving a direct threat to life or property, the individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8232223-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3524/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has skills directly related to resolving the emergency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8232224-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3524/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will serve on a temporary basis only so long as that individual’s services are made necessary by the emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8232225-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3524/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the employment under this section is with an entity in the legislative branch, the head of the entity or the appointing official may waive the repayment if the individual involved possesses unique abilities and is the only qualified applicant available for the position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8232226-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3524/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the employment under this section is with the judicial branch, the Director of the Administrative Office of the United States Courts may waive the repayment if the individual involved possesses unique abilities and is the only qualified applicant available for the position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8232227-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1313/a/1/A"},"text":"Pub. L. 107–296, title XIII, § 1313(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2293"},"text":"116 Stat. 2293","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tVI/s604/f"},"text":"Pub. L. 109–435, title VI, § 604(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3242"},"text":"120 Stat. 3242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8232228-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8232229-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb823222a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435"},"text":"Pub. L. 109–435","children":[],"tail":" substituted “Postal Regulatory Commission” for “Postal Rate Commission” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb823222b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb823222c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 60 days after ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1313/a/4"},"text":"section 1313(a)(4) of Pub. L. 107–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3521"},"text":"section 3521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
