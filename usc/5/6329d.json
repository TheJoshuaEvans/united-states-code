{"tag":"section","attrib":{"id":"idb89cbf7e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329d"},"text":null,"children":[{"tag":"num","attrib":{"value":"6329d"},"text":"§ 6329d.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parental bereavement leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89cbf7f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329d/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbf80-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329d/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “employee” and “son or daughter” have the meanings given those terms in section 6381; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbf81-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329d/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “paid leave” means, with respect to an employee, leave without loss of or reduction in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89cbf82-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329d/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89cbf83-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329d/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leave to which the employee is otherwise entitled under law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89cbf84-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329d/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credit for time or service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbf85-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329d/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bereavement Leave.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbf86-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329d/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraphs (2) and (3), an employee shall be entitled to a total of 2 administrative workweeks of paid leave during any 12-month period because of the death of a son or daughter of the employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbf87-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329d/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Leave under paragraph (1) may not be taken by an employee intermittently or on a reduced leave schedule unless the employee and the employing agency of the employee agree otherwise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbf88-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329d/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any case in which the necessity for leave under this subsection is foreseeable, the employee shall provide the employing agency with such notice as is reasonable and practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89cbf89-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXI/s1111/a"},"text":"Pub. L. 117–81, div. A, title XI, § 1111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1953"},"text":"135 Stat. 1953","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
