28, 1945, ch. 328, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/503"},"text":"59 Stat. 503","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/767/s205"},"text":"Pub. L. 86–767, § 205","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/908"},"text":"74 Stat. 908","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last sentence of the Act of ","children":[{"tag":"date","attrib":{"date":"1922-06-13"},"text":"June 13, 1922","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/650"},"text":"42 Stat. 650","children":[],"tail":", is omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Administration of this subchapter was transferred to the Secretary of Labor by section 1 of 1950 Reorg. Plan No. 19, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1271"},"text":"64 Stat. 1271","children":[],"tail":" (see section 8145)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c073ca-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c073cb-5e84-11f1-a692-ec