hildren":[],"tail":", substituted “(a) and (b)” for “(a)–(c)”, and added cl. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c073ce-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8c073cf-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416"},"text":"Pub. L. 93–416","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", and applicable to any injury or death occurring on or after "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s23/a"},"text":"section 23(a) of Pub. L. 93–416","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8c073d0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Personnel Not Affected by 1967 Increase","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Increases authorized under amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/57"},"text":"section 1(57) of Pub. L. 90–83","children":[],"tail":" not applicable to specified personnel, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s7"},"text":"section 7 of Pub. L. 90–83","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"hre