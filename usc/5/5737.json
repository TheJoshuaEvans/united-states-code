{"tag":"section","attrib":{"id":"idb8873b63-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737"},"text":null,"children":[{"tag":"num","attrib":{"value":"5737"},"text":"§ 5737.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relocation expenses of an employee who is performing an extended assignment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8873b64-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5738"},"text":"section 5738 of this title","children":[],"tail":", an agency may pay to or on behalf of an employee assigned from the employee’s official station to a duty station for a period of not less than six months and not greater than 30 months, the following expenses in lieu of payment of expenses authorized under subchapter I of this chapter:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8873b65-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Travel expenses to and from the assignment location in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724"},"text":"section 5724 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b66-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Transportation expenses of the immediate family and household goods and personal effects to and from the assignment location in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724"},"text":"section 5724 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b67-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A per diem allowance for en route travel of the employee’s immediate family to and from the assignment location in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724a/a"},"text":"section 5724a(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b68-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Travel and transportation expenses of the employee and spouse to seek new residence quarters at the assignment location in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724a/b"},"text":"section 5724a(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b69-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsistence expenses of the employee and the employee’s immediate family while occupying temporary quarters upon commencement and termination of the assignment in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724a/c"},"text":"section 5724a(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b6a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An amount, in accordance with section 5724a(f), to be used by the employee for miscellaneous expenses of this title.","children":[{"tag":"ref","attrib":{"idref":"fn002119"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002119"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b6b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The expenses of transporting a privately owned motor vehicle or vehicles to the assignment location in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5727"},"text":"section 5727 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b6c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An allowance as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724b"},"text":"section 5724b of this title","children":[],"tail":" for Federal, State, and local income taxes incurred on reimbursement of expenses paid under this section or on services provided in kind under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b6d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expenses of nontemporary storage of household goods and personal effects as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5726/a"},"text":"section 5726(a) of this title","children":[],"tail":", subject to the limitation that the weight of the household goods and personal effects stored, together with the weight of property transported under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724/a"},"text":"section 5724(a) of this title","children":[],"tail":", may not exceed the total maximum weight which could be transported in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724/a"},"text":"section 5724(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b6e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Expenses of property management services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8873b6f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency shall not make payment under this section to or on behalf of the employee for expenses incurred after termination of the temporary assignment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8873b70-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVII/s1716"},"text":"Pub. L. 104–201, div. A, title XVII, § 1716","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2756"},"text":"110 Stat. 2756","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8873b71-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8873b72-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8873b73-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1725/a"},"text":"section 1725(a) of Pub. L. 104–201","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5722"},"text":"section 5722 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
