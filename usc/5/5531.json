{"tag":"section","attrib":{"id":"idb86840e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5531"},"text":null,"children":[{"tag":"num","attrib":{"value":"5531"},"text":"§ 5531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5533"},"text":"section 5533 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86840ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5531/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “member” has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101/23"},"text":"section 101(23) of title 37","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86840eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5531/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “position” means a civilian office or position (including a temporary, part-time, or intermittent position), appointive or elective, in the legislative, executive, or judicial branch of the Government of the United States (including a Government corporation, but excluding a nonappropriated fund instrumentality under the jurisdiction of the armed forces) or in the government of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86840ec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5531/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “retired or retainer pay” means retired pay, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8311/3"},"text":"section 8311(3) of this title","children":[],"tail":", determined without regard to subparagraphs (B) through (D) of such section 8311(3); except that such term does not include an annuity payable to an eligible beneficiary of a member or former member of a uniformed service under chapter 73 of title 10;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86840ed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5531/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “agency in the legislative branch” means the Government Accountability Office, the Government Publishing Office, the Library of Congress, the Office of Technology Assessment, the Office of the Architect of the Capitol, the United States Botanic Garden, the Congressional Budget Office, and the United States Capitol Police;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86840ee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5531/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “employee of the House of Representatives” means a congressional employee whose pay is disbursed by the Chief Administrative Officer of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86840ef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5531/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “employee of the Senate” means a congressional employee whose pay is disbursed by the Secretary of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86840f0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5531/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text