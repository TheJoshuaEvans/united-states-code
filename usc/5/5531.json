ef":"/us/pl/111/145"},"text":"Pub. L. 111–145","children":[],"tail":" substituted “the Congressional Budget Office, and the United States Capitol Police” for “and the Congressional Budget Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" substituted “section” for “sections 5532 and” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer” for “Clerk”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Pars. (4) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" added pars. (4) to (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “ ‘member’ ” for “ ‘officer’ ” in par. (1) and added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb86840f7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb86840f8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” in par. (4) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb86840f9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/145"},"text":"Pub. L. 111–145","children":[],"tail":" effective as though enacted as part of "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/s1018"},"text":"section 1018 of Pub. L. 108–7","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/145/s7/d"},"text":"section 7(d) of Pub. L. 111–145","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2107"},"text":"section 2107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb86840fa-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb86840fb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Dual Pay Requirements for Pay Periods Subsequent to Enactment of Civil Service Act of 1978","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIII/s308/g"},"text":"Pub. L. 95–454, title III, § 308(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1151"},"text":"92 Stat. 1151","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/454/tIII/s308/g"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, the amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5532"},"text":"section 5532 of this title","children":[],"tail":"] shall apply only with respect to pay periods beginning after the effective date of this Act [see Effective Date note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"] and only with respect to members of the uniformed services who first receive retired or retainer pay (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5531/3"},"text":"section 5531(3) of title 5","children":[],"tail":", United States Code (as amended by this section)), after the effective date of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such amendments shall not apply to any individual employed in a position on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":"] so long as the individual continues to hold any such position (disregarding any break in service of 3 days or less) if the individual, on that date, would have been entitled to retired or retainer pay but for the fact the individual does not satisfy any applicable age requirement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5532"},"text":"section 5532 of title 5","children":[],"tail":", United States Code, as in effect immediately before the effective date of this Act, shall apply with respect to any retired officer of a regular component of the uniformed services who is receiving retired pay on or before such date, or any individual to whom paragraph (2) applies, in the same manner and to the same extent as if the preceding subsections of this section had not been enacted.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
