this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8be298e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Personnel Not Affected by 1967 Increase","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83/s7"},"text":"Pub. L. 90–83, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/222"},"text":"81 Stat. 222","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/90/83/s7"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in this or any other Act makes the increases authorized by section 1(49)—(52) [amending this section and sections 8107, 8108, and 8109 of this title], 53(B) and (C) [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8110"},"text":"section 8110 of this title","children":[],"tail":"], (54)—(58) [amending section 8111, 8112, 8116, 8122, and 8124 of this title], (60) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8131"},"text":"section 8131 of this title","children":[],"tail":"], (61) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8132"},"text":"section 8132 of this title","children":[],"tail":"], (62) (B) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8133/e"},"text":"section 8133(e) of this title","children":[],"tail":"], (63) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8135"},"text":"section 8135 of this title","children":[],"tail":"], (67) [adding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8146a"},"text":"section 8146a of this title","children":[],"tail":"], (68) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8147"},"text":"section 8147 of this title","children":[],"tail":"], and (71) [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8149"},"text":"section 8149 of this title","children":[],"tail":"] of this Act applicable to—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee or individual not within the definition of ‘employee’ in section 8101(1)(A), (B), or (D) of title 5, United States Code;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Metropolitan Police or the Fire Department of the District of Columbia who is pensioned or pensionable under sections 521—535 of title 4, District of Columbia Code; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of a uniformed service.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
