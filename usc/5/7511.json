{"tag":"section","attrib":{"id":"idb8b48d09-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511"},"text":null,"children":[{"tag":"num","attrib":{"value":"7511"},"text":"§ 7511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions; application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b48d0a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b48d0b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b48d0c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an individual in the competitive service—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8b48d0d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is not serving a probationary or trial period under an initial appointment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8b48d0e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has completed 1 year of current continuous service under other than a temporary appointment limited to 1 year or less;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b48d0f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a preference eligible in the excepted service who has completed 1 year of current continuous service in the same or similar positions—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8b48d10-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an Executive agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8b48d11-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the United States Postal Service or Postal Regulatory Commission; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b48d12-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an individual in the excepted service (other than a preference eligible)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8b48d13-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is not serving a probationary or trial period under an initial appointment pending conversion to the competitive service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8b48d14-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has completed 2 years of current continuous service in the same or similar positions in an Executive agency under other than a temporary appointment limited to 2 years or less;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48d15-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “suspension” has the same meaning as set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7501/2"},"text":"section 7501(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48d16-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “grade” means a level of classification under a position classification system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48d17-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “pay” means the rate of basic pay fixed by law or administrative action for the position held by an employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48d18-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “furlough” means the placing of an employee in a temporary status without duties and pay because of lack of work or funds or other nondisciplinary reasons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48d19-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This subchapter does not apply to an employee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b48d1a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose appointment is made by and with the advice and consent of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd1b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whose position has been determined to be of a confidential, policy-determining, policy-making or policy-advocating character by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b6fd1c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President for a position that the President has excepted from the competitive service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b6fd1d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Personnel Management for a position that the Office has excepted from the competitive service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b6fd1e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President or the head of an agency for a position excepted from the competitive service by statute;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd1f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose appointment is made by the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd20-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is receiving an annuity from the Civil Service Retirement and Disability Fund, or the Foreign Service Retirement and Disability Fund, based on the service of such employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"status":"repealed","id":"idb8b6fd21-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"[(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s512/c"},"text":"Pub. L. 114–328, div. A, title V, § 512(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2112"},"text":"130 Stat. 2112","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd22-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a member of the Foreign Service, as described in section 103 of the Foreign Service Act of 1980;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd23-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose position is within the Central Intelligence Agency or the Government Accountability Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd24-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose position is within the United States Postal Service, the Postal Regulatory Commission, the Panama Canal Commission, the Tennessee Valley Authority, the Federal Bureau of Investigation, an intelligence component of the Department of Defense (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1614"},"text":"section 1614 of title 10","children":[],"tail":"), or an intelligence activity of a military department covered under subchapter I of chapter 83 of title 10, unless subsection (a)(1)(B) of this section or "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s1005/a"},"text":"section 1005(a) of title 39","children":[],"tail":" is the basis for this subchapter’s applicability;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd25-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5102/c/11"},"text":"section 5102(c)(11) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b6fd26-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who holds a position within the Veterans Health Administration which has been excluded from the competitive service by or under a provision of title 38, unless such employee was appointed to such position under section 7401(3) of such title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b6fd27-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office may provide for the application of this subchapter to any position or group of positions excepted from the competitive service by regulation of the Office which is not otherwise covered by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b6fd28-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tII/s204/a"},"text":"Pub. L. 95–454, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1135"},"text":"92 Stat. 1135","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/376/s2/a"},"text":"Pub. L. 101–376, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-08-17"},"text":"Aug. 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/461"},"text":"104 Stat. 461","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s6/a"},"text":"Pub. L. 102–378, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1358"},"text":"106 Stat. 1358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/359/tV/s501"},"text":"Pub. L. 103–359, title V, § 501","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1994-10-14"},"text":"Oct. 14, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3430"},"text":"108 Stat. 3430","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1634/b"},"text":"Pub. L. 104–201, div. A, title XVI, § 1634(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2752"},"text":"110 Stat. 2752","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tVI/s604/b"},"text":"Pub. L. 109–435, title VI, § 604(b)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3241"},"text":"120 Stat. 3241","children":[],"tail":", 3242; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tXI/s1105/c/4"},"text":"Pub. L. 114–92, div. A, title XI, § 1105(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1024"},"text":"129 Stat. 1024","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tV/s512/c"},"text":"Pub. L. 114–328, div. A, title V, § 512(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2112"},"text":"130 Stat. 2112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXI/s1106/b/2/D"},"text":"Pub. L. 117–81, div. A, title XI, § 1106(b)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1950"},"text":"135 Stat. 1950","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b6fd29-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b6fd2a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8b6fd2b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 103 of the Foreign Service Act of 1980, referred to in subsec. (b)(6), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3903"},"text":"section 3903 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8b6fd2c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7511, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/528"},"text":"80 Stat. 528","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/183/s2/30"},"text":"Pub. L. 94–183, § 2(30)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1058"},"text":"89 Stat. 1058","children":[],"tail":", defined “preference eligible employee” and “adverse action” for purposes of this subchapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s204/a"},"text":"Pub. L. 95–454, § 204(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8b6fd2d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" struck out “except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599e"},"text":"section 1599e of title 10","children":[],"tail":",” before “who has completed 1 year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" struck out par. (5) which read as follows: “who is described in section 8337(h)(1), relating to technicians in the National Guard;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" inserted “except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599e"},"text":"section 1599e of title 10","children":[],"tail":",” before “who”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s604/b"},"text":"Pub. L. 109–435, § 604(b)","children":[],"tail":", substituted “Postal Regulatory Commission” for “Postal Rate Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435/s604/f"},"text":"Pub. L. 109–435, § 604(f)","children":[],"tail":", substituted “Postal Regulatory Commission” for “Postal Rate Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" substituted “an intelligence component of the Department of Defense (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1614"},"text":"section 1614 of title 10","children":[],"tail":"), or an intelligence activity of a military department covered under subchapter I of chapter 83 of title 10” for “the National Security Agency, the Defense Intelligence Agency, the Central Imagery Office, or an intelligence activity of a military department covered under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1590"},"text":"section 1590 of title 10","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/359"},"text":"Pub. L. 103–359","children":[],"tail":" inserted “the Central Imagery Office,” after “Defense Intelligence Agency,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378/s6/a/1"},"text":"Pub. L. 102–378, § 6(a)(1)","children":[],"tail":", amended par. (7) generally. Prior to amendment, par. (7) read as follows: “whose position is with the Central Intelligence Agency, the General Accounting Office, or the Veterans Health Services and Research Administration;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378/s6/a/2"},"text":"Pub. L. 102–378, § 6(a)(2)","children":[],"tail":"–(4), added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/376"},"text":"Pub. L. 101–376","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) For the purpose of this subchapter—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ‘employee’ means—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) an individual in the competitive service who is not serving a probationary or trial period under an initial appointment or who has completed 1 year of current continuous employment under other than a temporary appointment limited to 1 year or less; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) a preference eligible in an Executive agency in the excepted service, and a preference eligible in the United States Postal Service or the Postal Rate Commission, who has completed 1 year of current continuous service in the same or similar positions;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ‘suspension’ has the meaning as set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7501/2"},"text":"section 7501(2) of this title","children":[],"tail":";"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) ‘grade’ means a level of classification under a position classification system;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) ‘pay’ means the rate of basic pay fixed by law or administrative action for the position held by an employee; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) ‘furlough’ means the placing of an employee in a temporary status without duties and pay because of lack of work or funds or other nondisciplinary reasons.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) This subchapter does not apply to an em­ployee—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) whose appointment is made by and with the advice and consent of the Senate;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) whose position has been determined to be of a confidential, policy-determining, policy-making or policy-advocating character by—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the Office of Personnel Management for a position that it has excepted from the competitive service; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the President or the head of an agency for a position which is excepted from the competitive service by statute.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) The Office may provide for the application of this subchapter to any position or group of positions excepted from the competitive service by regulation of the Office.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b6fd2e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b6fd2f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" applied as if effective "},{"tag":"date","attrib":{"date":"2022-12-31"},"text":"Dec. 31, 2022","children":[],"tail":", to correspond to the effective date of the repeal of "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599e"},"text":"section 1599e of Title 10","children":[],"tail":", Armed Forces, to reflect the probable intent of Congress. See Effective Date of Repeal note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599e"},"text":"section 1599e of Title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b6fd30-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1635"},"text":"section 1635 of Pub. L. 104–201","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1593"},"text":"section 1593 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b6fd31-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378/s6/b"},"text":"Pub. L. 102–378, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1359"},"text":"106 Stat. 1359","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/378/s6/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by subsection (a) [amending this section] shall apply with respect to any personnel action taking effect on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of an employee or former employee of the Veterans Health Administration (or predecessor agency in name)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" against whom an adverse personnel action was taken before the date of enactment of this Act,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, as a result of the enactment of the Civil Service Due Process Amendments (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7501"},"text":"5 U.S.C. 7501","children":[],"tail":" note) ["},{"tag":"ref","attrib":{"href":"/us/pl/101/376"},"text":"Pub. L. 101–376","children":[],"tail":"], became ineligible to appeal such action to the Merit Systems Protection Board,"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as to whom that appeal right is restored as a result of the enactment of subsection (a), or would have been restored but for the passage of time, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is not precluded, by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7121/e/1"},"text":"section 7121(e)(1) of title 5","children":[],"tail":", United States Code, from appealing to the Merit Systems Protection Board,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the deadline for bringing an appeal under section 7513(d) or section 4303(e) of such title with respect to such action shall be the latter of—","children":[],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 60th day after the date of enactment of this Act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deadline which would otherwise apply if this paragraph had not been enacted.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b6fd32-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/376"},"text":"Pub. L. 101–376","children":[],"tail":" applicable with respect to any personnel action taking effect on or after "},{"tag":"date","attrib":{"date":"1990-08-17"},"text":"Aug. 17, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/376/s2/c"},"text":"section 2(c) of Pub. L. 101–376","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s4303"},"text":"section 4303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8b6fd33-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
