{"tag":"section","attrib":{"id":"idb8fc1c9c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8431"},"text":null,"children":[{"tag":"num","attrib":{"value":"8431"},"text":"§ 8431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain transfers to be treated as a separation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8fc1c9d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subchapter, separation from Government employment includes a transfer from a position that is subject to one of the retirement systems described in subsection (b) to a position that is not subject to any of them.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fc1c9e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The retirement systems described in this subsection are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fc1c9f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8431/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retirement system under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fc1ca0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8431/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the retirement system under subchapter III of chapter 83; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fc1ca1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8431/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other retirement system under which individuals may contribute to the Thrift Savings Fund through withholdings from pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fc1ca2-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/168/tII/s203/a/1"},"text":"Pub. L. 106–168, title II, § 203(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-12"},"text":"Dec. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1820"},"text":"113 Stat. 1820","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fc1ca3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8fc1ca4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8fc1ca5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 8431, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/541"},"text":"100 Stat. 541","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s101/b/6/B"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 101(b)(6)(B)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1440, provided a definition of “basic pay” for this subchapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/f/tVI/tII/s206/a/2"},"text":"Pub. L. 104–208, div. A, title I, § 101(f) [title VI, § 659 [title II, §§ 206(a)(2), 207]","children":[],"tail":"], "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-314"},"text":"110 Stat. 3009–314","children":[],"tail":", 3009–372, 3009–378, effective "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8fc1ca6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8fc1ca7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/168/tII/s203/c"},"text":"Pub. L. 106–168, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-12"},"text":"Dec. 12, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1820"},"text":"113 Stat. 1820","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/168/tII/s203/c"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8351"},"text":"section 8351 of this title","children":[],"tail":"] shall apply with respect to transfers occurring before, on, or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1999-12-12"},"text":"Dec. 12, 1999","children":[],"tail":"], except that, for purposes of applying such amendments with respect to any transfer occurring before such date of enactment, the date of such transfer shall be considered to be the date of the enactment of this Act. The Executive Director (within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8401/13"},"text":"section 8401(13) of title 5","children":[],"tail":", United States Code) may prescribe any regulations necessary to carry out this subsection.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
