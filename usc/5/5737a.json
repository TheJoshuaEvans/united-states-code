{"tag":"section","attrib":{"id":"idb8873b74-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5737a"},"text":"§ 5737a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employees temporarily deployed in contingency operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8873b75-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8873b76-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered employee” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8873b77-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an employee of an Executive agency or a military department, excluding a Government controlled corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8873b78-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assigned on a temporary change of station in support of a contingency operation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b79-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “temporary change of station”, as used with respect to an employee, means an assignment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8873b7a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the employee’s official duty station to a temporary duty station; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8873b7b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which such employee is eligible for expenses under section 5737; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b7c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “contingency operation” has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1482a/c"},"text":"section 1482a(c) of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8873b7d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarters and Rations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency may provide quarters and rations, without charge, to any covered employee of such agency during the period of such employee’s temporary assignment (as described in subsection (a)(1)(B)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8873b7e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Storage of Motor Vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of an agency may provide for the storage, without charge, or for the reimbursement of the cost of storage, of a motor vehicle that is owned or leased by a covered employee of such agency (or by a dependent of such an employee) and that is for the personal use of the covered employee. This subsection shall apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8873b7f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to storage during the period of the employee’s temporary assignment (as described in subsection (a)(1)(B)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b80-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a covered employee, with respect to not more than one motor vehicle as of any given time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8873b81-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5737a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Benefits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any benefits under this section shall be in addition to (and not in lieu of) any other benefits for which the covered employee is otherwise eligible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8873b82-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXI/s1104/a"},"text":"Pub. L. 110–181, div. A, title XI, § 1104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/346"},"text":"122 Stat. 346","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
