{"tag":"section","attrib":{"id":"idb90804b0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8464a"},"text":"§ 8464a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship between annuity and workers’ compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb90804b1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90804b2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual is not entitled to receive—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb90804b3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an annuity under subchapter II or V, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90804b4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation for injury to, or disability of, such individual under subchapter I of chapter 81, other than compensation payable under section 8107,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"covering the same period of time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90804b5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual is not entitled to receive an annuity under subchapter IV and a concurrent benefit under subchapter I of chapter 81 on account of the death of the same person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90804b6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (1) and (2) do not bar the right of a claimant to the greater benefit conferred by either this chapter or subchapter I of chapter 81.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90804b7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If an individual is entitled to an annuity under subchapter II, IV, or V, and the individual receives a lump-sum payment for compensation under section 8135 based on the disability or death of the same person, so much of the compensation as has been paid for a period extended beyond the date payment of the annuity commences, as determined by the Department of Labor, shall be refunded to that Department for credit to the Employees’ Compensation Fund. Before the individual may receive the annuity, the individual shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90a74b8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refund to the Department of Labor the amount representing the commuted compensation payments for the extended period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90a74b9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8464a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the deduction of the amount from the annuity.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Deductions from the annuity may be made from accrued or accruing payments. The amounts deducted and withheld from the annuity shall be transmitted to the Department of Labor for reimbursement to the Employees’ Compensation Fund. When the Department of Labor finds that the financial circumstances of an individual entitled to an annuity under subchapter II, IV, or V warrant deferred refunding, deductions from the annuity may be prorated against and paid from accruing payments in such manner as the Department determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb90a74ba-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238/tI/s124/a/1/B"},"text":"Pub. L. 100–238, title I, § 124(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1755"},"text":"101 Stat. 1755","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb90a74bb-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb90a74bc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb90a74bd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8456"},"text":"section 8456 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/100/238"},"text":"Pub. L. 100–238","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb90a74be-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb90a74bf-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", and applicable with respect to benefits payable based on a death or disability occurring on or after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/238/s124/c"},"text":"section 124(c) of Pub. L. 100–238","children":[],"tail":" set out as an Effective Date of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8337"},"text":"section 8337 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
