{"tag":"section","attrib":{"id":"idb7ba270c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564"},"text":null,"children":[{"tag":"num","attrib":{"value":"564"},"text":"§ 564.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication of notice; applications for membership on committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7ba270d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication of Notice","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, after considering the report of a convener or conducting its own assessment, an agency decides to establish a negotiated rulemaking committee, the agency shall publish in the Federal Register and, as appropriate, in trade or other specialized publications, a notice which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ba270e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an announcement that the agency intends to establish a negotiated rulemaking committee to negotiate and develop a proposed rule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba270f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the subject and scope of the rule to be developed, and the issues to be considered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba2710-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the interests which are likely to be significantly affected by the rule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba2711-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the persons proposed to represent such interests and the person or persons proposed to represent the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba2712-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposed agenda and schedule for completing the work of the committee, including a target date for publication by the agency of a proposed rule for notice and comment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba2713-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of administrative support for the committee to be provided by the agency, including technical assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba2714-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a solicitation for comments on the proposal to establish the committee, and the proposed membership of the negotiated rulemaking committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba2715-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of how a person may apply or nominate another person for membership on the committee, as provided under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ba2716-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications for Membership or ","children":[],"tail":null},{"tag":"ref","attrib":{"idref":"fn002021"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002021"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “on”."}],"tail":null},{"tag":"inline","attrib":{},"text":" Committee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Persons who will be significantly affected by a proposed rule and who believe that their interests will not be adequately represented by any person specified in a notice under subsection (a)(4) may apply for, or nominate another person for, membership on the negotiated rulemaking committee to represent such interests with respect to the proposed rule. Each application or nomination shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ba2717-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the applicant or nominee and a description of the interests such person shall represent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba2718-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence that the applicant or nominee is authorized to represent parties related to the interests the person proposes to represent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba2719-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written commitment that the applicant or nominee shall actively participate in good faith in the development of the rule under consideration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba271a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons that the persons specified in the notice under subsection (a)(4) do not adequately represent the interests of the person submitting the application or nomination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ba271b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s564/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period for Submission of Comments and Applications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The agency shall provide for a period of at least 30 calendar days for the submission of comments and applications under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7ba271c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/648/s3/a"},"text":"Pub. L. 101–648, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4971"},"text":"104 Stat. 4971","children":[],"tail":", § 584; renumbered § 564, "},{"tag":"ref","attrib":{"href":"/us/pl/102/354/s3/a/2"},"text":"Pub. L. 102–354, § 3(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/944"},"text":"106 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7ba271d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7ba271e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7ba271f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/354"},"text":"Pub. L. 102–354","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s584"},"text":"section 584 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
