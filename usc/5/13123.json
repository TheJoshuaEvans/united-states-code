{"tag":"section","attrib":{"id":"idb937c5b0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13123"},"text":null,"children":[{"tag":"num","attrib":{"value":"13123"},"text":"§ 13123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb937c5b1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance to Director","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the request of the Director, each executive agency is directed to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb937c5b2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13123/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make its services, personnel, and facilities available to the Director to the greatest practicable extent for the performance of functions under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5b3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13123/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except when prohibited by law, furnish to the Director all information and records in its possession which the Director may determine to be necessary for the performance of the Director’s duties.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The authority of the Director under this section includes the authority to request assistance from the inspector general of an agency in conducting investigations pursuant to the Office of Government Ethics responsibilities under this chapter. The head of any agency may detail such personnel and furnish such services, with or without reimbursement, as the Director may request to carry out the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb937c5b4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gift Acceptance Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb937c5b5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director is authorized to accept and utilize on behalf of the United States, any gift, donation, bequest, or devise of money, use of facilities, personal property, or services for the purpose of aiding or facilitating the work of the Office of Government Ethics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5b6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No gift may be accepted—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb937c5b7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13123/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that attaches conditions inconsistent with applicable laws or regulations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb937c5b8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13123/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is conditioned upon or will require the expenditure of appropriated funds that are not available to the Office of Government Ethics.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb937c5b9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13123/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for determining appropriateness of gift acceptance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall establish written rules setting forth the criteria to be used in determining whether the acceptance of contributions of money, services, use of facilities, or personal property under this subsection would reflect unfavorably upon the ability of the Office of Government Ethics, or any employee of such Office, to carry out its responsibilities or official duties in a fair and objective manner, or would compromise the integrity or the appearance of the integrity of its programs or any official involved in those programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb937c5ba-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/c"},"text":"Pub. L. 117–286, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4301"},"text":"136 Stat. 4301","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb937c5bb-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb937c5bc-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb937c5bd-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"13123","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 U.S.C. App. (EGA § 403)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/521/tIV/s403"},"text":"Pub. L. 95–521, title IV, § 403","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1863"},"text":"92 Stat. 1863","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/98/150/s5"},"text":"Pub. L. 98–150, § 5","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 11, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/97/960"},"text":"97 Stat. 960","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/100/598/s9"},"text":"Pub. L. 100–598, § 9","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 3, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/3035"},"text":"102 Stat. 3035","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/179/s2"},"text":"Pub. L. 104–179, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/1566"},"text":"110 Stat. 1566","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
