{"tag":"section","attrib":{"id":"idb924b34d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8990"},"text":null,"children":[{"tag":"num","attrib":{"value":"8990"},"text":"§ 8990.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies, reports, and audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb924b34e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8990/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each contract shall contain provisions requiring the qualified company to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb924b34f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8990/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish such reasonable reports as the Office determines to be necessary to enable it to carry out its functions under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b350-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8990/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the Office and representatives of the Government Accountability Office to examine such records of the qualified company as may be necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b351-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8990/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Federal agency shall keep such records, make such certifications, and furnish the Office, the qualified company, or both, with such information and reports as the Office may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b352-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8990/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall conduct periodic reviews of plans under this chapter, including a comparison of the vision benefits available under chapter 89, to ensure the competitiveness of plans under this chapter. The Office shall cooperate with the Government Accountability Office to provide periodic evaluations of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb924b353-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/496/s3"},"text":"Pub. L. 108–496, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/4010"},"text":"118 Stat. 4010","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb924b354-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb924b355-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb924b356-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", and applicable to contracts that take effect with respect to the calendar year 2006, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/496/s7"},"text":"section 7 of Pub. L. 108–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8951"},"text":"section 8951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
