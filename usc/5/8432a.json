{"tag":"section","attrib":{"id":"idb8fe8d11-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8432a"},"text":"§ 8432a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of lost earnings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8fe8d12-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fe8d13-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Director shall prescribe regulations under which an employing agency shall be required to pay to the Thrift Savings Fund amounts representing lost earnings resulting from errors (including errors of omission) made by such agency in carrying out this subchapter, subject to paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d14-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the error involves an employing agency’s failure to deduct from basic pay contributions (in whole or in part) on behalf of an individual in accordance with section 8432(a), the regulations shall not provide for the payment of any lost earnings which would be attributable to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fe8d15-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contributions that the agency failed to deduct from basic pay in accordance with section 8432(a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fe8d16-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any related contributions under section 8432(c)(2) that the employing agency is not required (by statute or otherwise) to make up.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fe8d17-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fe8d18-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fe8d19-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for computing lost earnings; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fe8d1a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures under which amounts paid to the Thrift Savings Fund under this section shall be credited to appropriate accounts;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d1b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide for exceptions from the requirements of this section to the extent that correction of an error is not administratively feasible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d1c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may require an employing agency to reimburse the Thrift Savings Fund for costs incurred by the Thrift Savings Fund in implementing corrections of employing agency errors under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d1d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include such other provisions as the Executive Director determines appropriate to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fe8d1e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amounts required to be paid by an employing agency under this section shall be paid from the appropriation or fund available to the employing agency for payment of salaries of the participant’s office or establishment. If a participant in the legislative branch is paid by the Chief Administrative Officer of the House of Representatives, the Chief Administrative Officer may pay from the applicable accounts of the House of Representatives the amount required to be paid to correct errors relating to the Thrift Savings Fund that otherwise would be paid from the appropriation or fund used to pay the participant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fe8d1f-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/335/s2/a/1"},"text":"Pub. L. 101–335, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-17"},"text":"July 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/319"},"text":"104 Stat. 319","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s215/17"},"text":"Pub. L. 104–186, title II, § 215(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1746"},"text":"110 Stat. 1746","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fe8d20-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8fe8d21-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8fe8d22-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer of the House of Representatives, the Chief Administrative Officer may pay from the applicable accounts” for “Clerk of the House of Representatives, the Clerk may pay from the contingent fund”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8fe8d23-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8fe8d24-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/335/s2/b"},"text":"Pub. L. 101–335, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-07-17"},"text":"July 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/320"},"text":"104 Stat. 320","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/335/s2/b"},"text":"“The amendments made by this section [enacting this section] shall apply with respect to lost earnings attributable to errors made before, on, or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-07-17"},"text":"July 17, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
