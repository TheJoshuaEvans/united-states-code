{"tag":"section","attrib":{"id":"idb871ddff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5546a"},"text":"§ 5546a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Differential pay for certain employees of the Federal Aviation Administration and the Department of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb871de00-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator of the Federal Aviation Administration (hereafter in this section referred to as the “Administrator”) and the Secretary of Defense (hereafter in this section referred to as the “Secretary”) may pay premium pay at the rate of 5 per centum of the applicable rate of basic pay to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb871de01-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any employee of the Federal Aviation Administration or the Department of Defense who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb871de02-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occupying a position in the air traffic controller series classified not lower than GS–9 and located in an air traffic control center or terminal or in a flight service station;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb871de03-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assigned to a position classified not lower than GS–09 or WG–10 located in an airway facilities sector; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb871de04-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assigned to a flight inspection crew-member position classified not lower than GS–11 located in a flight inspection field office,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the duties of whose position are determined by the Administrator or the Secretary to be directly involved in or responsible for the operation and maintenance of the air traffic control system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb871de05-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee of the Federal Aviation Administration or the Department of Defense who is assigned to a flight test pilot position classified not lower than GS-12 located in a region or center, the duties of whose position are determined by the Administrator or the Secretary to be unusually taxing, physically or mentally, and to be critical to the advancement of aviation safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb871de06-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee of the Federal Aviation Administration who occupies a position at the Federal Aviation Administration Academy, Oklahoma City, Oklahoma, the duties of which are determined by the Administrator to require the individual to be actively engaged in or directly responsible for training employees to perform the duties of a position described in subparagraph (a); (b); or (c) or paragraph (1) of this subsection, and who, immediately prior to assuming such position at such Academy, occupied a position referred to in subparagraph (a), (b), or (c) of paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb871de07-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The premium pay payable under any subsection of this section is in addition to basic pay and to premium pay payable under any other subsection of this section and any other provision of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb871de08-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb871de09-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator or the Secretary may pay premium pay to any employee of the Federal Aviation Administration or the Department of Defense who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb871de0a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an air traffic controller located in an air traffic control center or terminal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb871de0b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not required as a condition of employment to be certified by the Administrator or the Secretary as proficient and medically qualified to perform duties including the separation and control of air traffic; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb871de0c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is so certified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb871de0d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Premium pay paid under paragraph (1) of this subsection shall be paid at the rate of 1.6 per centum of the applicable rate of basic pay for so long as such employee is so certified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb871de0e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb871de0f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator or the Secretary may pay premium pay to any air traffic controller of the Federal Aviation Administration or the Department of Defense who is assigned by the Administrator or the Secretary to provide on-the-job training to another air traffic controller while such other air traffic controller is directly involved in the separation and control of live air traffic.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb871de10-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Premium pay paid under paragraph (1) of this subsection shall be paid at the rate of 10 per centum of the applicable hourly rate of basic pay times the number of hours and portion of an hour during which the air traffic controller of the Federal Aviation Administration or the Department of Defense provides on-the-job training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb871de11-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb871de12-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator or the Secretary may pay premium pay to any air traffic controller or flight service station specialist of the Federal Aviation Administration or the Department of Defense who, while working a regularly scheduled eight-hour period of service, is required by his supervisor to work during the fourth through sixth hour of such period without a break of thirty minutes for a meal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb871de13-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Premium pay paid under paragraph (1) of this subsection shall be paid at the rate of 50 per centum of one-half of the applicable hourly rate of basic pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb871de14-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb871de15-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator or the Secretary shall prescribe standards for determining which air traffic controllers and other employees of the Federal Aviation Administration or the Department of Defense are to be paid premium pay under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb871de16-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5546a/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator and the Secretary may prescribe such rules as he determines are necessary to carry out the provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb871de17-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/276/s151/c/1"},"text":"Pub. L. 97–276, § 151(c)(1)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1982-10-02"},"text":"Oct. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1200"},"text":"96 Stat. 1200","children":[],"tail":", 1201; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/377/tI/s145/a"},"text":"Pub. L. 97–377, title I, § 145(a)","children":[],"tail":", formerly § 145, "},{"tag":"date","attrib":{"date":"1982-12-21"},"text":"Dec. 21, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1917"},"text":"96 Stat. 1917","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/98/78/tIII/s320/1"},"text":"Pub. L. 98–78, title III, § 320(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-15"},"text":"Aug. 15, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/473"},"text":"97 Stat. 473","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/tXV/s1537/c/1"},"text":"Pub. L. 98–525, title XV, § 1537(c)(1)","children":[],"tail":"–(6)(A), "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2635"},"text":"98 Stat. 2635","children":[],"tail":", 2636.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb871de18-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb871de19-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb871de1a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1537/c/6/A"},"text":"Pub. L. 98–525, § 1537(c)(6)(A)","children":[],"tail":", inserted “and the Department of Defense” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1537/c/1/A"},"text":"Pub. L. 98–525, § 1537(c)(1)(A)","children":[],"tail":", inserted “and the Secretary of Defense (hereafter in this section referred to as the ‘Secretary’)” in provisions preceding par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1537/c/1/B"},"text":"Pub. L. 98–525, § 1537(c)(1)(B)","children":[],"tail":", inserted “or the Department of Defense” in provisions preceding subpar. (A) and “or the Secretary” in provisions following subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1537/c/1/C"},"text":"Pub. L. 98–525, § 1537(c)(1)(C)","children":[],"tail":", inserted “or the Department of Defense” and “or the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c)(1), (d), (e)(1), (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1537/c/2"},"text":"Pub. L. 98–525, § 1537(c)(2)","children":[],"tail":"–(5)(A), inserted “or the Secretary” after “Administrator” wherever appearing, and “or the Department of Defense” after “Administration” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1537/c/5/B"},"text":"Pub. L. 98–525, § 1537(c)(5)(B)","children":[],"tail":", inserted “and the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/377"},"text":"Pub. L. 97–377","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb871de1b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb871de1c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/525"},"text":"Pub. L. 98–525","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"Oct. 1, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/525/s1537/f"},"text":"section 1537(f) of Pub. L. 98–525","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s4109"},"text":"section 4109 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb871de1d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/377/tI/s145/b"},"text":"Pub. L. 97–377, title I, § 145(b)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/98/78/tIII/s320/2"},"text":"Pub. L. 98–78, title III, § 320(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-08-15"},"text":"Aug. 15, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/473"},"text":"97 Stat. 473","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/78/tIII/s320/2"},"text":"“The amendment made by subsection (a) of this section [amending this section] shall be effective as of 5 o’clock ante meridian eastern daylight time, ","children":[{"tag":"date","attrib":{"date":"1981-08-03"},"text":"August 3, 1981","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb871de1e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/276/s151/h/1"},"text":"Pub. L. 97–276, § 151(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-02"},"text":"Oct. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1202"},"text":"96 Stat. 1202","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/276/s151/h/1"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by subsections 152 [151] (b), (c), (e), and (g) of this joint resolution [enacting subsecs. (a) and (b) of this section and amending sections 5532, 5547, and 8344 of this title] shall take effect at 5 o’clock ante meridian eastern daylight time, ","children":[{"tag":"date","attrib":{"date":"1981-08-03"},"text":"August 3, 1981","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by subsection 152 [151] (a) and subsection 152 [151] (d) of this joint resolution [enacting subsecs. (c)–(f) of this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4109"},"text":"section 4109 of this title","children":[],"tail":"] shall take effect on the first day of the first applicable pay period beginning after the date of the enactment of this joint resolution ["},{"tag":"date","attrib":{"date":"1982-10-02"},"text":"Oct. 2, 1982","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
