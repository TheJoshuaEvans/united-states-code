":"/us/stat/65/681"},"text":"65 Stat. 681","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s2061a/b"},"text":"5 U.S.C. 2061a(b)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1953-07-02/ch178/s2/b"},"text":"July 2, 1953, ch. 178, § 2(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/137"},"text":"67 Stat. 137","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “the head of the agency concerned” are substituted for “the heads of the various departments and independent establishments”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8980365-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8980366-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":" inserted “or section 3595” after “chapter 35”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/519"},"text":"Pub. L. 95–519","children":[],"tail":" substituted “6301(2)(x)–(xiii)” for “6301(2)(x)–(xii)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/181"},"text":"Pub. L. 93–181","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8980367-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8980368-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/519"},"text":"Pub. L. 95–519","children":[],"tail":" effective beginning on first day of first applicable pay period beginning on or after "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/519/s4/a"},"text":"section 4(a) of Pub. L. 95–519","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5551"},"text":"section 5551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8980369-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Temporary Authority To Transfer Leave","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/237/tII/s206/b/2"},"text":"Pub. L. 101–237, title II, § 206(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/2068"},"text":"103 Stat. 2068","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/237/tII/s206/b/2"},"text":"“The authority of the Department of Veterans Affairs under section 618 of the Treasury, Postal Service and General Government Appropriations Act, 1989 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/440"},"text":"Pub. L. 100–440","children":[],"tail":", set out below], to operate a leave-transfer program for employees subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4108"},"text":"section 4108 of title 38","children":[],"tail":", United States Code, is extended until the programs provided for in subsection (e) of such section 4108 (as added by subsection (a) of this section) are implemented, but not later than "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/144/tV/s518"},"text":"Pub. L. 101–144, title V, § 518","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-09"},"text":"Nov. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/874"},"text":"103 Stat. 874","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/110/s1/d"},"text":"Pub. L. 101–110, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-10-06"},"text":"Oct. 6, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/682"},"text":"103 Stat. 682","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/440/tVI/s618"},"text":"Pub. L. 100–440, title VI, § 618","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-22"},"text":"Sept. 22, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1755"},"text":"102 Stat. 1755","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/440/tVI/s618"},"text":"“In order to ensure that the experimental use of voluntary leave transfers established under Public Laws 99–500, 99–591 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/m/tVII"},"text":"Pub. L. 99–500, § 101(m) [title VII]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-308"},"text":"100 Stat. 1783–308","children":[],"tail":", 1783–334, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/m/tVII"},"text":"Pub. L. 99–591, § 101(m) [title VII]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-308"},"text":"100 Stat. 3341–308","children":[],"tail":", 3341–334], and 100–202 ["},{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/m/tVI/s625"},"text":"Pub. L. 100–202, § 101(m) [title VI, § 625]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-390"},"text":"101 Stat. 1329–390","children":[],"tail":", 1329–430] may continue and may cover additional employees in fiscal year 1989, the Office of Personnel Management may continue to operate by regulation, notwithstanding chapter 63 of title 5, United States Code, a program under which the unused accrued annual leave of officers or employees of the Federal Government may be transferred for use by other officers or employees who need such leave due to a personal emergency as defined in the regulations. The Office may provide by regulation for such exceptions from the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7351"},"text":"section 7351 of title 5","children":[],"tail":" as the Office may determine appropriate for the transfer of leave under this section. The Veterans’ Administration may operate a similar program for employees subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4108"},"text":"section 4108 of title 38","children":[],"tail":", United States Code. The programs operated under this section shall expire at the end of fiscal year 1989, but any leave that has been transferred to an officer or employee under the programs shall remain available for use until the personal emergency has ended, and any remaining unused transferred leave shall, to the extent administratively feasible, be restored to the leave accounts of the officers or employees from whose accounts it was originally transferred.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriations act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/202/s101/m/tVI/s625"},"text":"Pub. L. 100–202, § 101(m) [title VI, § 625]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1987-12-22"},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1329-390"},"text":"101 Stat. 1329–390","children":[],"tail":", 1329–430."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For provisions ratifying any actions of the Secretary of Veterans Affairs in carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/440/s618"},"text":"section 618 of Pub. L. 100–440","children":[],"tail":", set out above, during the period "},{"tag":"date","attrib":{"date":"1989-12-01"},"text":"Dec. 1, 1989","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"1989-12-18"},"text":"Dec. 18, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/237/s604"},"text":"section 604 of Pub. L. 101–237","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720B"},"text":"section 1720B of Title 38","children":[],"tail":", Veterans’ Benefits. Similar provisions for the period "},{"tag":"date","attrib":{"date":"1989-10-01"},"text":"Oct. 1, 1989","children":[],"tail":", to "},{"tag":"date","attrib":{"date":"1989-10-06"},"text":"Oct. 6, 1989","children":[],"tail":", were contained in "},{"tag":"ref","attrib":{"href":"/us/pl/101/110/s3/b"},"text":"section 3(b) of Pub. L. 101–110","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1720B"},"text":"section 1720B of Title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
