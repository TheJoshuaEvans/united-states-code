{"tag":"section","attrib":{"id":"idb8ad6007-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201"},"text":null,"children":[{"tag":"num","attrib":{"value":"7201"},"text":"§ 7201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Antidiscrimination policy; minority recruitment program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8ad6008-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8ad6009-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “underrepresentation” means a situation in which the number of members of a minority group designation (determined by the Equal Employment Opportunity Commission in consultation with the Office of Personnel Management, on the basis of the policy set forth in subsection (b) of this section) within a category of civil service employment constitutes a lower percentage of the total number of employees within the employment category than the percentage that the minority constituted within the labor force of the United States, as determined under the most recent decennial or mid-decade census, or current population survey, under title 13, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ad600a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “category of civil service employment” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8ad600b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each grade of the General Schedule described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5104"},"text":"section 5104 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8ad600c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each position subject to subchapter IV of chapter 53 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8ad600d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such occupational, professional, or other groupings (including occupational series) within the categories established under subparagraphs (A) and (B) of this paragraph as the Office determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8ad600e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the policy of the United States to insure equal employment opportunities for employees without discrimination because of race, color, religion, sex, or national origin. The President shall use his existing authority to carry out this policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8ad600f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 180 days after the date of the enactment of the Civil Service Reform Act of 1978, the Office of Personnel Management shall, by regulation, implement a minority recruitment program which shall provide, to the maximum extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8ad6010-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that each Executive agency conduct a continuing program for the recruitment of members of minorities for positions in the agency to carry out the policy set forth in subsection (b) in a manner designed to eliminate underrepresentation of minorities in the various categories of civil service employment within the Federal service, with special efforts directed at recruiting in minority communities, in educational institutions, and from other sources from which minorities can be recruited; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ad6011-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that the Office conduct a continuing program of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8ad6012-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assistance to agencies in carrying out programs under paragraph (1) of this subsection, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8ad6013-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluation and oversight and such recruitment programs to determine their effectiveness in eliminating such minority underrepresentation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8ad6014-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 60 days after the date of the enactment of the Civil Service Reform Act of 1978, the Equal Employment Opportunity Commission shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8ad6015-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish the guidelines proposed to be used in carrying out the program required under subsection (c) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ad6016-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make determinations of underrepresentation which are proposed to be used initially under such program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8ad6017-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmit to the Executive agencies involved, to the Office of Personnel Management, and to the Congress the determinations made under paragraph (2) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8ad6018-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7201/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than January 31 of each year, the Office shall prepare and transmit to each House of the Congress a report on the activities of the Office and of Executive agencies under subsection (c) of this section, including the affirmative action plans submitted under section 717 of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e–16"},"text":"42 U.S.C. 2000e–16","children":[],"tail":"), the personnel data file maintained by the Office of Personnel Management, and any other data necessary to evaluate the effectiveness of the program for each category of civil service employment and for each minority group designation, for the preceding fiscal year, together with recommendations for administrative or legislative action the Office considers appropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8ad6019-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/523"},"text":"80 Stat. 523","children":[],"tail":", § 7151; renumbered § 7201 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIII/s310"},"text":"Pub. L. 95–454, title III, § 310","children":[],"tail":", title VII, § 703(a)(1), "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1152"},"text":"92 Stat. 1152","children":[],"tail":", 1216.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8ad601a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8ad601b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8ad601c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s2000e/b"},"text":"42 U.S.C. 2000e(b)","children":[],"tail":" (2d proviso)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 2, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/352/s701/b"},"text":"Pub. L. 88–352, § 701(b)","children":[],"tail":" (2d proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/78/254"},"text":"78 Stat. 254","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “Federal” is omitted as unnecessary in view of the definition of “employee” in section 2105.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8ad601d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8ad601e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (a)(2)(A), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of the Civil Service Reform Act of 1978, referred to in subsecs. (c) and (d), is the date of the enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8ad601f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s703/a/1"},"text":"Pub. L. 95–454, § 703(a)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7151"},"text":"section 7151 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s310/1"},"text":"Pub. L. 95–454, § 310(1)","children":[],"tail":", substituted “Antidiscrimination policy; minority recruitment program” for “Policy” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s310/2"},"text":"Pub. L. 95–454, § 310(2)","children":[],"tail":"–(4), added subsec. (a), designated existing provisions as subsec. (b), and added subsecs. (c) to (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8ad6020-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8ad6021-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s310"},"text":"section 310 of Pub. L. 95–454","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8ad6022-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of reporting provisions in subsec. (e) of this section, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of Title 31","children":[],"tail":", Money and Finance, and page 187 of House Document No. 103–7."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8ad6023-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Workplace Policies Prohibiting Discrimination and Sexual Harassment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dD/tVII/s716"},"text":"Pub. L. 110–161, div. D, title VII, § 716","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2023"},"text":"121 Stat. 2023","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/161/dD/tVII/s716"},"text":"“Hereafter, no department, agency, or instrumentality of the United States receiving appropriated funds under this or any other Act shall obligate or expend any such funds, unless such department, agency, or instrumentality has in place, and will continue to administer in good faith, a written policy designed to ensure that all of its workplaces are free from discrimination and sexual harassment and that all of its workplaces are not in violation of title VII of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/352"},"text":"Public Law 88–352","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/241"},"text":"78 Stat. 241","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000e"},"text":"42 U.S.C. 2000e","children":[],"tail":" et seq.], the Age Discrimination in Employment Act of 1967 ("},{"tag":"ref","attrib":{"href":"/us/pl/90/202"},"text":"Public Law 90–202","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/602"},"text":"81 Stat. 602","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s621"},"text":"29 U.S.C. 621","children":[],"tail":" et seq.], and the Rehabilitation Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/pl/93/112"},"text":"Public Law 93–112","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/355"},"text":"87 Stat. 355","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8ad6024-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Discrimination Prohibited in Employment of Civilian Personnel at Facilities Operated by the Department of Defense in Foreign Countries","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/129/tI/s106"},"text":"Pub. L. 92–129, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-09-28"},"text":"Sept. 28, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/355"},"text":"85 Stat. 355","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/129/tI/s106"},"text":"“Unless prohibited by treaty, no person shall be discriminated against by the Department of Defense or by any officer or employee thereof, in the employment of civilian personnel at any facility or installation operated by the Department of Defense in any foreign country because such person is a citizen of the United States or is a dependent of a member of the Armed Forces of the United States. As used in this section, the term ‘facility or installation operated by the Department of Defense’ shall include, but shall not be limited to, any officer’s club, non-commissioned officers’ club, post exchange, or commissary store.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
