le 18","children":[],"tail":"” are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c79fbb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8c79fbc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Retroactive Restoration of Annuity and Retired Pay; Redeposits of Contributions and Offsets","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/299/s2"},"text":"Section 2 of Pub. L. 87–299","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-26"},"text":"Sept. 26, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/648"},"text":"75 Stat. 648","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/87/299/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subsection (b) of this section, any person, including his survivor or beneficiary, to whom annuity or retired pay is not payable under the Act of ","children":[{"tag":"date","attrib":{"date":"1954-09-01"},"text":"September 1, 1954","children":[],"tail":" [this subchapter], as in effect at any time prior to the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1961-09-26"},"text":"Sept. 26, 1961","children":[],"tail":"], by reason of any conviction of an offense, any commission of a violation, any refusal to answer, or any absence under indictment, or under charges, for any offense, shall be restored the right to receive such annuity or retired pay for any and all periods for which he would have had the right to receive such annuity or retired pay if the Act of "},{"tag":"date","attrib":{"date":"1954-09-01"},"text":"September 1, 1954","children":[],"tail":" [this subchapter], had not been enacted, unless, under the amendment made by the first section of this Act [amending former chapter 31 of this title, now this subchapter, and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3282"},"text":"section 3282 of Title 18","children":[],"tail":", Crimes and Criminal Procedure], such annuity or retired pay remains nonpayable to such person, including his survivor or beneficiary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No annuity accrued or accruing, prior to, on, or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1961-09-26"},"text":"Sept. 26, 1961","children":[],"tail":"], on account of the restoration, by reason of the amendment made by the first section of this Act [amending former chapter 31 of this title, now this subchapter, and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3282"},"text":"section 3282 of Title 18","children":[],"tail":"] and by reason of subsection (a) of this section, of the right to receive such annuity, shall be paid until any sum refunded under "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-01/s3"},"text":"section 3 of the Act of September 1, 1954","children":[],"tail":" [former "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2284"},"text":"section 2284 of this title","children":[],"tail":", now "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8316"},"text":"section 8316 of this title","children":[],"tail":", prior to amendment "},{"tag":"date","attrib":{"date":"1961-09-26"},"text":"Sept. 26, 1961","children":[],"tail":"], as in effect prior to the date of enactment of such amendment ["},{"tag":"date","attrib":{"date":"1961-09-26"},"text":"Sept. 26, 1961","children":[],"tail":"], is deposited or is collected by offset against the annuity.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
