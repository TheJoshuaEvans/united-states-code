{"tag":"section","attrib":{"id":"idb8198553-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3349a"},"text":"§ 3349a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Presidential inaugural transitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8198554-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “transitional inauguration day” means the date on which any person swears or affirms the oath of office as President, if such person is not the President on the date preceding the date of swearing or affirming such oath of office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8198555-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to any vacancy that exists during the 60-day period beginning on a transitional inauguration day, the 210-day period under section 3346 or 3348 shall be deemed to begin on the later of the date occurring—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8198556-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 days after such transitional inauguration day; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198557-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 days after the date on which the vacancy occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8198558-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s151/b"},"text":"Pub. L. 105–277, div. C, title I, § 151(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-615"},"text":"112 Stat. 2681–615","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8198559-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb819855a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb819855b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 30 days after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", and applicable to any office that becomes vacant after such effective date, with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s151/d"},"text":"section 151(d) of Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3345"},"text":"section 3345 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
