{"tag":"section","attrib":{"id":"idb7db9181-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s905"},"text":null,"children":[{"tag":"num","attrib":{"value":"905"},"text":"§ 905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7db9182-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A reorganization plan may not provide for, and a reorganization under this chapter may not have the effect of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7db9183-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s905/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating a new executive department or renaming an existing executive department, abolishing or transferring an executive department or independent regulatory agency, or all the functions thereof, or consolidating two or more executive departments or two or more independent regulatory agencies, or all the functions thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7db9184-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s905/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing an agency beyond the period authorized by law for its existence or beyond the time when it would have terminated if the reorganization had not been made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7db9185-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s905/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing a function beyond the period authorized by law for its exercise or beyond the time when it would have terminated if the reorganization had not been made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7db9186-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s905/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizing an agency to exercise a function which is not expressly authorized by law at the time the plan is transmitted to Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7db9187-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s905/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating a new agency which is not a component or part of an existing executive department or independent agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7db9188-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s905/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the term of an office beyond that provided by law for the office; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7db9189-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s905/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dealing with more than one logically consistent subject matter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7db918a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag"