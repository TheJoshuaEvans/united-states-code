"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2602"},"text":"130 Stat. 2602","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1599f"},"text":"section 1599f of Title 10","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 559 and 1101 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":", referred to in subsec. (c)(4), are "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s559"},"text":"section 559 of Pub. L. 115–91","children":[],"tail":", div. A, title V, "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1406"},"text":"131 Stat. 1406","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1792"},"text":"section 1792 of Title 10","children":[],"tail":", Armed Forces, and "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1101"},"text":"section 1101 of Pub. L. 115–91","children":[],"tail":", div. A, title XI, "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1627"},"text":"131 Stat. 1627","children":[],"tail":", which is set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1580"},"text":"section 1580 of Title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92e298e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2023—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1104/1"},"text":"Pub. L. 118–31, § 1104(1)","children":[],"tail":", inserted “, 3307,” after “3303”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(12), (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1104/2"},"text":"Pub. L. 118–31, § 1104(2)","children":[],"tail":", added pars. (12) and (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1250B/i/1"},"text":"Pub. L. 118–31, § 1250B(i)(1)","children":[],"tail":", added par. (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/s1250B/i/2"},"text":"Pub. L. 118–31, § 1250B(i)(2)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2030-09-30"},"text":"September 30, 2030","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"September 30, 2025","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added par. (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1109/a/1/A"},"text":"Pub. L. 116–92, § 1109(a)(1)(A)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “Any position involved with cybersecurity.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1109/a/1/B"},"text":"Pub. L. 116–92, § 1109(a)(1)(B)","children":[],"tail":", added pars. (5) to (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s1109/a/2"},"text":"Pub. L. 116–92, § 1109(a)(2)","children":[],"tail":", added subsecs. (b) and (c) and struck out former subsec. (b) which provided that effective on "},{"tag":"date","attrib":{"date":"2025-09-30"},"text":"Sept. 30, 2025","children":[],"tail":", the authority provided under subsec. (a) would expire."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
