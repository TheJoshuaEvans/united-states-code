{"tag":"section","attrib":{"id":"idb92e2972-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905"},"text":null,"children":[{"tag":"num","attrib":{"value":"9905"},"text":"§ 9905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct hire authority for certain personnel of the Department of Defense","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92e2973-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Defense may appoint, without regard to the provisions of subchapter I of chapter 33 (other than sections 3303, 3307, and 3328 of such chapter), qualified candidates to any of the following positions in the competitive service in the Department of Defense:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e2974-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any position involved with Department maintenance activities, including depot-level maintenance and repair.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2975-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any cyber workforce position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2976-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any individual in the acquisition workforce that manages any services contracts necessary to the operation and maintenance of programs of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2977-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any science, technology, or engineering position, including any such position at the Major Range and Test Facilities Base, in order to allow development of new systems and provide for the maintenance of legacy systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2978-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any scientific, technical, engineering, or mathematics positions, including technicians, within the defense acquisition workforce, or any category of acquisition positions within the Department designated by the Secretary as a shortage or critical need category.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2979-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any scientific, technical, engineering, or mathematics position, except any such position within any defense Scientific and Technology Reinvention Laboratory, for which a qualified candidate is required to possess a bachelor’s degree or an advanced degree, or for which a veteran candidate is being considered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e297a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any category of medical or health professional positions within the Department designated by the Secretary as a shortage category or critical need occupation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e297b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any childcare services position for which there is a critical hiring need and a shortage of childcare providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e297c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any financial management, accounting, auditing, actuarial, cost estimation, operational research, or business or business administration position for which a qualified candidate is required to possess a finance, accounting, management or actuarial science degree or a related degree, or a related degree of equivalent experience.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e297d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any position, as determined by the Secretary, for the purpose of assisting and facilitating the efforts of the Department in business transformation and management innovation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e297e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any position in the military housing office of a military installation whose primary function is supervision of military housing covered by subchapter IV of chapter 169 of title 10.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e297f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any position in support of aircraft operations for which the Secretary determines there is a critical hiring need or shortage of candidates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2980-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any position in support of the safety of the public, law enforcement, or first response for which the Secretary determines there is a critical hiring need or shortage of candidates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2981-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any position in support of Special Inspector General for Operation Atlantic Resolve for which the Secretary determines there is a critical hiring need and shortage of candidates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e2982-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e2983-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), effective on ","children":[{"tag":"date","attrib":{"date":"2030-09-30"},"text":"September 30, 2030","children":[],"tail":", the authority provided under subsection (a) shall expire."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2984-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall not apply to the authority provided under subsection (a) to make appointments to positions described under paragraph (5) of such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e2985-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension of Other Hiring Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"During the period beginning on the effective date of the regulations issued to carry out the hiring authority with respect to positions described in paragraphs (5) through (10) of subsection (a) and ending on the date described in subsection (b)(1), the Secretary of Defense may not exercise or otherwise use any hiring authority provided under the following provisions of law:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e2986-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 1599c(a)(2) and 1705(h) of title 10.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2987-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 1112 and 1113 of the National Defense Authorization Act for Fiscal Year 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Public Law 114–92","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/129/1033"},"text":"129 Stat. 1033","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2988-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 1110 and 1643(a)(3) of the National Defense Authorization Act for Fiscal Year 2017 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Public Law 114–328","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/130/2450"},"text":"130 Stat. 2450","children":[],"tail":" and 2602)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2989-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9905/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sections 559 and 1101 of the National Defense Authorization Act for Fiscal Year 2018 (","children":[{"tag":