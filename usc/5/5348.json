{"tag":"section","attrib":{"id":"idb859e9da-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5348"},"text":null,"children":[{"tag":"num","attrib":{"value":"5348"},"text":"§ 5348.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crews of vessels","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb859e9db-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5348/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided by subsection (c), the pay of officers and members of crews of vessels excepted from chapter 51 of this title by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5102/c/8"},"text":"section 5102(c)(8) of this title","children":[],"tail":" shall be fixed and adjusted from time to time as nearly as is consistent with the public interest in accordance with prevailing rates and practices in the maritime industry, not to exceed the rate of pay for the Vice President under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s104"},"text":"section 104 of title 3","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb859e9dc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5348/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aggregate pay limitation prescribed under section 5307 shall not apply to an employee whose pay is fixed under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb859e9dd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5348/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Vessel employees in an area where inadequate maritime industry practice exists and vessel employees of the Corps of Engineers shall have their pay fixed and adjusted under the provisions of this subchapter other than this section, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb859e9de-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/471"},"text":"80 Stat. 471","children":[],"tail":", § 5348, formerly § 5342; renumbered and amended "},{"tag":"ref","attrib":{"href":"/us/pl/92/392/s1/a"},"text":"Pub. L. 92–392, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-19"},"text":"Aug. 19, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/572"},"text":"86 Stat. 572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/70/tIII/s3302/e/1"},"text":"Pub. L. 96–70, title III, § 3302(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/498"},"text":"93 Stat. 498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dC/tXXXV/s3548/a/3/C"},"text":"Pub. L. 104–201, div. C, title XXXV, § 3548(a)(3)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2868"},"text":"110 Stat. 2868","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dA/tXI/s1104"},"text":"Pub. L. 119–60, div. A, title XI, § 1104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1073"},"text":"139 Stat. 1073","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb85c59df-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb85c59e0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb85c59e1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1104/1"},"text":"Pub. L. 119–60, § 1104(1)","children":[],"tail":", substituted “subsection (c)” for “subsection (b) of this section” and inserted “, not to exceed the rate of pay for the Vice President under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s104"},"text":"section 104 of title 3","children":[],"tail":"” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60/s1104/2"},"text":"Pub. L. 119–60, § 1104(2)","children":[],"tail":", (3), added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s3548/a/3/C/iii"},"text":"Pub. L. 104–201, § 3548(a)(3)(C)(iii)","children":[],"tail":", substituted “subsection (b)” for “subsections (b) and (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s3548/a/3/C/i"},"text":"Pub. L. 104–201, § 3548(a)(3)(C)(i)","children":[],"tail":", (ii), redesignated subsec. (c) as (b) and struck out former subsec. (b) which read as follows: “Vessel employees of the Panama Canal Commission may be paid in accordance with the wage practices of the maritime industry.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70"},"text":"Pub. L. 96–70","children":[],"tail":" substituted “Commission” for “Company”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/392"},"text":"Pub. L. 92–392","children":[],"tail":" inserted reference to subsection (c) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/392"},"text":"Pub. L. 92–392","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb85c59e2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb85c59e3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70"},"text":"Pub. L. 96–70","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-10-01"},"text":"Oct. 1, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/70/s3304"},"text":"section 3304 of Pub. L. 96–70","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3601"},"text":"section 3601 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb85c59e4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/392"},"text":"Pub. L. 92–392","children":[],"tail":" effective on first day of first applicable pay period beginning on or after 90th day after "},{"tag":"date","attrib":{"date":"1972-08-19"},"text":"Aug. 19, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/392/s15/a"},"text":"section 15(a) of Pub. L. 92–392","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5341"},"text":"section 5341 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb85c59e5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Pay Adjustments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions limiting the adjustment of salary or basic pay of employees covered by this section, see provisions set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5343"},"text":"section 5343 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
