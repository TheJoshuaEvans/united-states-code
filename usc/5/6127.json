{"tag":"section","attrib":{"id":"idb89592d8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6127"},"text":null,"children":[{"tag":"num","attrib":{"value":"6127"},"text":"§ 6127.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compressed schedules; agencies authorized to use","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89592d9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6127/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6101"},"text":"section 6101 of this title","children":[],"tail":", each agency may establish programs which use a 4-day workweek or other compressed schedule."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89592da-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6127/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89592db-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6127/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee in a unit with respect to which an organization of Government employees has not been accorded exclusive recognition shall not be required to participate in any program under subsection (a) unless a majority of the employees in such unit who, but for this paragraph, would be included in such program have voted to be so included.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89592dc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6127/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon written request to any agency by an employee, the agency, if it determines that participation in a program under subsection (a) would impose a personal hardship on such employee, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89592dd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6127/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except such employee from such program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89592de-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6127/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reassign such employee to the first position within the agency—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb89592df-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6127/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which becomes vacant after such determination,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb89592e0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6127/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is not included within such program,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb89592e1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6127/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which such employee is qualified, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb89592e2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6127/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is acceptable to the employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"A determination by an agency under this paragraph shall be made not later than 10 days after the day on which a written request for such determination is received by the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89592e3-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/221/s2/a/2"},"text":"Pub. L. 97–221, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-23"},"text":"July 23, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/230"},"text":"96 Stat. 230","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
