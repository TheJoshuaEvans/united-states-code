{"tag":"section","attrib":{"id":"idb8c79f63-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8315"},"text":null,"children":[{"tag":"num","attrib":{"value":"8315"},"text":"§ 8315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Falsifying employment applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c79f64-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual, or his survivor or beneficiary, may not be paid annuity or retired pay on the basis of the service of the individual which is creditable toward the annuity or retired pay, subject to the exceptions in section 8311(2) and (3) of this title, if the individual knowingly and willfully made or makes a false, fictitious, or fraudulent statement or representation, or knowingly and willfully concealed or conceals a material fact—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c79f65-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8315/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" before, on, or after ","children":[{"tag":"date","attrib":{"date":"1954-09-01"},"text":"September 1, 1954","children":[],"tail":", concerning his—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c79f66-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8315/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" past or present membership in, affiliation or association with, or support of the Communist Party, or a chapter, branch, or subdivision thereof, in or outside the United States, or other organization, party, or group advocating—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8c79f67-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8315/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the overthrow, by force, violence, or other unconstitutional means, of the Government of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8c79f68-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8315/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment, by force, violence, or other unconstitutional means, of a Communist totalitarian dictatorship in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8c79f69-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8315/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the right to strike against the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79f6a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8315/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conviction of an offense named by subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8312"},"text":"section 8312 of this title","children":[],"tail":", to the extent provided by that subsection; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79f6b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8315/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure or refusal to appear, testify, or produce a book, paper, record, or other document, as specified by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8314"},"text":"section 8314 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c79f6c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8315/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before, on, or after ","children":[{"tag":"date","attrib":{"date":"1961-09-26"},"text":"September 26, 1961","children":[],"tail":", concerning his conviction of an offense named by subsection (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8312"},"text":"section 8312 of this title","children":[],"tail":", to the extent provided by that subsection;"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"in a document executed by the individual in connection with his employment in, or application for, a civilian or military office or position in or under the legislative, executive, or judicial branch of the Government of the United States or the government of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c79f6d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The prohibition on the payment of annuity or retired pay applies—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c79f6e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8315/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to matters specified by subsection (a)(1) of this section, to the period after the statement, representation, or concealment of fact is made or occurs, or after ","children":[{"tag":"date","attrib":{"date":"1954-09-01"},"text":"September 1, 1954","children":[],"tail":", whichever is later; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c79f6f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8315/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to matters specified by subsection (a)(2) of this section, to the period after the statement, representation, or concealment of fact is made or occurs, or after ","children":[{"tag":"date","attrib":{"date":"1961-09-26"},"text":"September 26, 1961","children":[],"tail":", whichever is later."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c79f70-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/562"},"text":"80 Stat. 562","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c79f71-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c79f72-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c79f73-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{