tml:span","attrib":{},"text":"Sept. 23, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/377/s4/b"},"text":"Pub. L. 86–377, § 4(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/701"},"text":"73 Stat. 701","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb913ea07-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb913ea08-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/311/s6/1/A"},"text":"Pub. L. 105–311, § 6(1)(A)","children":[],"tail":", substituted “Subject to subsection (c)(2), during” for “During”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/311/s6/1/B"},"text":"Pub. L. 105–311, § 6(1)(B)","children":[],"tail":", substituted “Subject to subsection (c)(2), whenever” for “Whenever”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/311/s6/1/C"},"text":"Pub. L. 105–311, § 6(1)(C)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/427"},"text":"Pub. L. 96–427","children":[],"tail":" designated first sentence of existing section as subsec. (a) and substituted “a policy purchased” for “a policy of insurance purchased” and “the employee’s pay a share of the cost” for “the pay of the employee his share of the cost”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/427"},"text":"Pub. L. 96–427","children":[],"tail":" added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/427"},"text":"Pub. L. 96–427","children":[],"tail":" designated second sentence of existing section as subsec. (c) and inserted reference to pay, annuity, or compensation of each employee."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/427"},"text":"Pub. L. 96–427","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Office of Personnel Management” and “Office” for “Civil Service Commission” and “Commission”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206"},"text":"Pub. L. 90–206","children":[],"tail":" struck out reference to the Civil Service Commission’s function of determining the amount to be withheld for group insurance and substituted provisions setting a rate of 66⅔ percent of the level cost of each $1,000 of insurance as determined by the Commission for provisions setting a limit of 25 cents biweekly for each $1,000 of group life insurance and directing the withholding of the amount from employees paid on other than a biweekly basis at a proportional rate adjusted to the nearest cent."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb913ea09-5e84-11f1-a692-ec26948f6fea"},"text":null