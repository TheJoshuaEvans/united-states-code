{"tag":"section","attrib":{"id":"idb8611515-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5403"},"text":null,"children":[{"tag":"num","attrib":{"value":"5403"},"text":"§ 5403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Human Capital Performance Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8611516-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is hereby established the Human Capital Performance Fund, to be administered by the Office for the purpose of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8611517-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8611518-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8611519-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5403/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency shall submit a plan as described in section 5406 to be eligible for consideration by the Office for an allocation under this section. An allocation shall be made only upon approval by the Office of an agency’s plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb861151a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5403/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb861151b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5403/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the reduction for training required under section 5408, ninety percent of the remaining amount appropriated to the Fund may be allocated by the Office to the agencies. Of the amount to be allocated, an agency’s pro rata distribution may not exceed its pro rata share of Executive branch payroll.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb861151c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5403/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Office does not allocate an agency’s full pro rata share, the undistributed amount remaining from that share will become available for distribution to other agencies, as provided in subparagraph (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb861151d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5403/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb861151e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5403/b/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the reduction for training under section 5408, ten percent of the remaining amount appropriated to the Fund, as well as the amount of the pro rata share not distributed because of an agency’s failure to submit a satisfactory plan, shall be allocated among agencies with exceptionally high-quality plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb861151f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5403/b/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency with an exceptionally high-quality plan is eligible to receive an additional distribution in addition to its full pro rata distribution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8611520-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each agency is required to provide to the Office such payroll information as the Office specifies necessary to determine the Executive branch payroll.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8611521-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXI/s1129/a"},"text":"Pub. L. 108–136, div. A, title XI, § 1129(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1642"},"text":"117 Stat. 1642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8611522-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8611523-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8611524-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5403, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tV/s501"},"text":"Pub. L. 95–454, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1182"},"text":"92 Stat. 1182","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/tII/s201/a"},"text":"Pub. L. 98–615, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3209"},"text":"98 Stat. 3209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s101/b/4/C"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 101(b)(4)(C)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1439; "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/38"},"text":"Pub. L. 102–378, § 2(38)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1351"},"text":"106 Stat. 1351","children":[],"tail":", related to general pay increases, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/89/s3/a/1"},"text":"Pub. L. 103–89, § 3(a)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"Sept. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/981"},"text":"107 Stat. 981","children":[],"tail":", 983, eff. "},{"tag":"date","attrib":{"date":"1993-11-01"},"text":"Nov. 1, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
