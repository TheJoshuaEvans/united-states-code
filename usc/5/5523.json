{"tag":"section","attrib":{"id":"idb86840a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5523"},"text":null,"children":[{"tag":"num","attrib":{"value":"5523"},"text":"§ 5523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duration of payments; rates; active service period","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb86840a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5523/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of each agency may provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86840a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5523/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the payment of monetary amounts covering a period of not more than 60 days to or for the account of each employee of the agency (or, under emergency circumstances and on a reimbursable basis, an employee of another agency) whose departure (or that of the employee’s dependents or immediate family, as the case may be) is authorized or ordered under section 5522(a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86840a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5523/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination of payment of the monetary amounts.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The President, with respect to the Executive agencies, may extend the 60-day period for not more than 120 additional days if he determines that the extension of the period is in the interest of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86840a4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5523/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to adjustment of the account of an employee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5524"},"text":"section 5524 of this title","children":[],"tail":" and other applicable statute, each payment under this section is at rates of pay, allowances, and differentials, or any of them, currently authorized with respect to the employee on the date payment is made under agency procedures governing payments under this section. The rates so authorized may not exceed the rates to which the employee was entitled immediately before issuance of the departure order. An employee in an Executive agency may be granted such additional allowance payments as the President determines necessary to offset the direct added expenses incident to the departure."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86840a5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5523/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each period for which payment of amounts is made under this section to or for the account of an employee is deemed, for all purposes with respect to the employee, a period of active service, without break in service, performed by the employee in the employment of the Government of the United States or the government of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86840a6-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/480"},"text":"80 Stat. 480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2303/c"},"text":"Pub. L. 96–465, title II, § 2303(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2165"},"text":"94 Stat. 2165","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s147/a"},"text":"Pub. L. 102–138, title I, § 147(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/669"},"text":"105 Stat. 669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb86840a7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb86840a8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb86840a9-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s3073"},"text":"5 U.S.C. 3073","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 26, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/304/s3"},"text":"Pub. L. 87–304, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/663"},"text":"75 Stat. 663","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb86840aa-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb86840ab-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138"},"text":"Pub. L. 102–138","children":[],"tail":" substituted “agency) whose departure (or that of the employee’s dependents or immediate family, as the case may be) is authorized or ordered under section 5522(a); and” for “agency)—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) whose departure is authorized or ordered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5522/a"},"text":"section 5522(a) of this title","children":[],"tail":"; and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) who is prevented, by circumstances beyond his control and beyond the control of the Government of the United States or the government of the District of Columbia, or both, as the case may be, from performing the duties of the position which he held immediately before issuance of the departure order; and”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2303/c"},"text":"Pub. L. 96–465, § 2303(c)","children":[],"tail":", in subpar. (A) substituted “whose departure is authorized or ordered under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5522/a"},"text":"section 5522(a) of this title","children":[],"tail":"; and” for “whose evacuation from a place inside or outside the United States is ordered for military or other reasons which create imminent danger to the life of the employee; and”, and in subpar. (B) substituted “departure” for “evacuation” after “issuance of the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2303/d"},"text":"Pub. L. 96–465, § 2303(d)","children":[],"tail":", substituted “departure” for “evacuation” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb86840ac-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb86840ad-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-02-15"},"text":"Feb. 15, 1981","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2403"},"text":"section 2403 of Pub. L. 96–465","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
