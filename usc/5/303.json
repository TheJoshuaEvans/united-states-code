{"tag":"section","attrib":{"id":"idb785a8ba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s303"},"text":null,"children":[{"tag":"num","attrib":{"value":"303"},"text":"§ 303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oaths to witnesses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb785a8bb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee of an Executive department lawfully assigned to investigate frauds on or attempts to defraud the United States, or irregularity or misconduct of an employee or agent of the United States, may administer an oath to a witness attending to testify or depose in the course of the investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb785a8bc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee of the Department of Defense lawfully assigned to investigative duties may administer oaths to witnesses in connection with an official investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb785a8bd-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/379"},"text":"80 Stat. 379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/213"},"text":"Pub. L. 94–213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-02-13"},"text":"Feb. 13, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/179"},"text":"90 Stat. 179","c