children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s93"},"text":"5 U.S.C. 93","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 183.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1901-03-02/ch809/s3"},"text":"Mar. 2, 1901, ch. 809, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/31/951"},"text":"31 Stat. 951","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1911-02-13/ch43"},"text":"Feb. 13, 1911, ch. 43","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/36/898"},"text":"36 Stat. 898","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “employee” is substituted for “officer or clerk” in view of the definition in section 2105. The words “Executive department” are substituted for “departments” as the definition of “department” applicable to this section is coextensive with the definition of “Executive department” in section 101. So much as related to the Armed Forces is omitted as superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s636"},"text":"section 636 of title 14","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s936/b"},"text":"section 936(b) of title 10","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section was part of title IV of the Revised Statutes. The ","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-26/ch343/s201/d"},"text":"Act of July 26, 1947, ch. 343, § 201(d)","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1949-08-10/ch412/s4"},"text":"Aug. 10, 1949, ch. 412, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/63/579"},"text":"63 Stat. 579","children":[],"tail":" (formerly "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s171–1"},"text":"5 U.S.C. 171–1","children":[],"tail":"), which provides “Except to the extent inconsistent with the provisions of this Act [National Security Act of 1947], the provisions of title IV of the Revised Statutes as now or hereafter amended shall be applicable to the Department of Defense” is omitted from this title but is not repealed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb785a8c1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb785a8c2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/213"},"text":"Pub. L. 94–213","children":[],"tail":" designated existing provisions as subsec. (a) and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
