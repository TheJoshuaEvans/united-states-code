{"tag":"section","attrib":{"id":"idb7bc97e0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s578"},"text":null,"children":[{"tag":"num","attrib":{"value":"578"},"text":"§ 578.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of the arbitrator","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An arbitrator to whom a dispute is referred under this subchapter may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7bc97e1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s578/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regulate the course of and conduct arbitral hearings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc97e2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s578/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer oaths and affirmations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc97e3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s578/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compel the attendance of witnesses and production of evidence at the hearing under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t9/s7"},"text":"section 7 of title 9","children":[],"tail":" only to the extent the agency involved is otherwise authorized by law to do so; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc97e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s578/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make awards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceC