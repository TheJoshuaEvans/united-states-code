{"tag":"section","attrib":{"id":"idb819851e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348"},"text":null,"children":[{"tag":"num","attrib":{"value":"3348"},"text":"§ 3348.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacant office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb819851f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8198520-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “action” includes any agency action as defined under section 551(13); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198521-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “function or duty” means any function or duty of the applicable office that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8198522-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8198523-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established by statute; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8198524-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required by statute to be performed by the applicable officer (and only that officer); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8198525-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8198526-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8198527-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established by regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8198528-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required by such regulation to be performed by the applicable officer (and only that officer); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8198529-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a function or duty to which clause (i)(I) and (II) applies, and the applicable regulation is in effect at any time during the 180-day period preceding the date on which the vacancy occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb819852a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Unless an officer or employee is performing the functions and duties in accordance with sections 3345, 3346, and 3347, if an officer of an Executive agency (including the Executive Office of the President, and other than the Government Accountability Office) whose appointment to office is required to be made by the President, by and with the advice and consent of the Senate, dies, resigns, or is otherwise unable to perform the functions and duties of the office—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb819852b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the office shall remain vacant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb819852c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an office other than the office of the head of an Executive agency (including the Executive Office of the President, and other than the Government Accountability Office), only the head of such Executive agency may perform any function or duty of such office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb819852d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the last day of any 210-day period under section 3346 is a day on which the Senate is not in session, the second day the Senate is next in session and receiving nominations shall be deemed to be the last day of such period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb819852e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb819852f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An action taken by any person who is not acting under section 3345, 3346, or 3347, or as provided by subsection (b), in the performance of any function or duty of a vacant office to which this section and sections 3346, 3347, 3349, 3349a, 3349b, and 3349c apply shall have no force or effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198530-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An action that has no force or effect under paragraph (1) may not be ratified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8198531-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8198532-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Counsel of the National Labor Relations Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198533-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Counsel of the Federal Labor Relations Authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198534-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Inspector General appointed by the President, by and with the advice and consent of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198535-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Chief Financial Officer appointed by the President, by and with the advice and consent of the Senate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198536-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3348/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an office of an Executive agency (including the Executive Office of the President, and other than the Government Accountability Office) if a statutory provision expressly prohibits the head of the Executive agency from performing the functions and duties of such office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8198537-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s151/b"},"text":"Pub. L. 105–277, div. C, title I, § 151(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-613"},"text":"112 Stat. 2681–613","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8198538-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8198539-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb819853a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3348, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/426"},"text":"80 Stat. 426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/398/s7/b"},"text":"Pub. L. 100–398, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-08-17"},"text":"Aug. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/988"},"text":"102 Stat. 988","children":[],"tail":", provided for time limitations relating to details, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s151/b"},"text":"Pub. L. 105–277, div. C, title I, § 151(b)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-611"},"text":"112 Stat. 2681–611","children":[],"tail":", 2681–616, effective 30 days after "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3346"},"text":"section 3346 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb819853b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb819853c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb819853d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 30 days after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", and applicable to any office that becomes vacant after such effective date, with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s151/d"},"text":"section 151(d) of Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3345"},"text":"section 3345 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
