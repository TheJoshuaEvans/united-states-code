{"tag":"section","attrib":{"id":"idb8125930-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3324"},"text":null,"children":[{"tag":"num","attrib":{"value":"3324"},"text":"§ 3324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointments to positions classified above GS–15","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8125931-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An appointment to a position classified above GS–15 pursuant to section 5108 may be made only on approval of the qualifications of the proposed appointee by the Director of the Office of Personnel Management on the basis of qualification standards developed by the agency involved in accordance with criteria specified in regulations prescribed by the Director. This section does not apply to a position—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8125932-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3324/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which appointment is made by the Chief Judge of the United States Tax Court;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8125933-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3324/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which appointment is made by the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8125934-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3324/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which appointment is made by the Librarian of Congress; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8125935-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3324/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the incumbent of which is paid from—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8125936-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3324/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriations for the Executive Office of the President under the heading “The White House Office”, “Special Proj­ects”, “Council of Economic Advisers”, or “National Security Council”; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8125937-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3324/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds appropriated to the President under the heading “Emergency Fund for the President” by the Treasury, Post Office, and Executive Office Appropriation Act, 1966, or a later statute making appropriations for the same purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8125938-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office may prescribe regulations necessary for the administration of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8125939-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail"