{"tag":"section","attrib":{"id":"idb89cbf68-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c"},"text":null,"children":[{"tag":"num","attrib":{"value":"6329c"},"text":"§ 6329c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Weather and safety leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89cbf69-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbf6a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “agency”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89cbf6b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means an Executive agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89cbf6c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the Department of Veterans Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89cbf6d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the Government Accountability Office; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbf6e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “employee”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89cbf6f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term in section 2105; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89cbf70-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include an intermittent employee who does not have an established regular tour of duty during the administrative workweek.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbf71-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Leave for Weather and Safety Issues","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agency may approve the provision of leave under this section to an employee or a group of employees without loss of or reduction in the pay of the employee or employees, leave to which the employee or employees are otherwise entitled, or credit to the employee or employees for time or service only if the employee or group of employees is prevented from safely traveling to or performing work at an approved location due to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbf72-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act of God;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbf73-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a terrorist attack; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbf74-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another condition that prevents the employee or group of employees from safely traveling to or performing work at an approved location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbf75-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An agency shall record leave provided under this section separately from leave authorized under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbf76-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 270 days after the date of enactment of this section, the Director of the Office of Personnel Management shall prescribe regulations to carry out this section, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbf77-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance to agencies regarding the appropriate purposes for providing leave under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbf78-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proper recording of leave provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbf79-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329c/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relation to Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7421"},"text":"section 7421 of title 38","children":[],"tail":", this section shall apply to an employee described in subsection (b) of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89cbf7a-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXI/s1138/e/1"},"text":"Pub. L. 114–328, div. A, title XI, § 1138(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2469"},"text":"130 Stat. 2469","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb89cbf7b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89cbf7c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb89cbf7d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, subsec. (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
