{"tag":"section","attrib":{"id":"idb8b48c6b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7351"},"text":null,"children":[{"tag":"num","attrib":{"value":"7351"},"text":"§ 7351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts to superiors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b48c6c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7351/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b48c6d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7351/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit a contribution from another employee for a gift to an official superior;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48c6e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7351/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make a donation as a gift or give a gift to an official superior; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48c6f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7351/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept a gift from an employee receiving less pay than himself.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48c70-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7351/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee who violates this section shall be subject to appropriate disciplinary action by the employing agency or entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48c71-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7351/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each supervising ethics office (as defined in section 7353(d)(1)) is authorized to issue regulations implementing this section, including regulations exempting voluntary gifts or contributions that are given or received for special occasions such as marriage or retirement or under other circumstances in which gifts are traditionally given or exchanged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b48c72-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/527"},"text":"80 Stat. 527","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/tIII/s301"},"text":"Pub. L. 101–194, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1745"},"text":"103 Stat. 1745","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/a"},"text":"Pub. L. 101–280, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-04"},"text":"May 4, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/157"},"text":"104 Stat. 157","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b48c73-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8b48c74-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8b48c75-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s113"},"text":"5 U.S.C. 113","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 1784.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The application of the section is confined to employees, since the President and Members of Congress, though officers, could not have been intended to be “summarily discharged”, and members of uniformed services are not covered by this statute. In the last sentence, the word “removed” is substituted for “summarily discharged” because of the provisions of the Lloyd-LaFollette Act, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/37/555"},"text":"37 Stat. 555","children":[],"tail":", as amended, and the Veterans’ Preference Act of 1944, "},{"tag":"ref","attrib":{"href":"/us/stat/58/387"},"text":"58 Stat. 387","children":[],"tail":", as amended, which are carried into this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b48c76-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8b48c77-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/a/1"},"text":"Pub. L. 101–280, § 4(a)(1)","children":[],"tail":", inserted “or give a gift” after “donation as a gift”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/a/2"},"text":"Pub. L. 101–280, § 4(a)(2)","children":[],"tail":", substituted “Each supervising ethics office (as defined in section 7353(d)(1))” for “The Office of Government Ethics” and “circumstances in which gifts are traditionally given or exchanged” for “similar circumstances”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194"},"text":"Pub. L. 101–194","children":[],"tail":" designated existing provisions as subsec. (a), struck out “An employee who violates this section shall be removed from the service.” at end, and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b48c78-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8b48c79-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inapplicability to Transfers of Unused Accrued Annual Leave by Federal Employees; Exception","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/284"},"text":"Pub. L. 100–284","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-04-07"},"text":"Apr. 7, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/81"},"text":"102 Stat. 81","children":[],"tail":", provided that "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7351"},"text":"section 7351 of this title","children":[],"tail":" would not apply to leave transfers under certain programs covering Federal employees during fiscal year ending on "},{"tag":"date","attrib":{"date":"1988-09-30"},"text":"Sept. 30, 1988","children":[],"tail":", except as the Office of Personnel Management may by regulation prescribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
