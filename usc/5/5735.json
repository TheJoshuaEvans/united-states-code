{"tag":"section","attrib":{"id":"idb8873b53-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5735"},"text":null,"children":[{"tag":"num","attrib":{"value":"5735"},"text":"§ 5735.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel, transportation, and relocation expenses of employees transferring to the United States Postal Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8873b54-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5735/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, employees of the Department of Defense described in subsection (b) may be authorized travel, transportation, and relocation expenses and allowances in connection with appointments referred to in such subsection under the same conditions and to the same extent authorized by this subchapter for transferred employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8873b55-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5735/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Employees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) applies to any employee of the Department of Defense who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8873b56-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5735/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is scheduled for separation from the Department, other than for cause;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b57-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5735/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is selected for appointment to a continuing position with the United States Postal Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b58-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5735/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accepts the appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8873b59-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIII/s345/a/1"},"text":"Pub. L. 103–337, div. A, title III, § 345(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2723"},"text":"108 Stat. 2723","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8873b5a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8873b5b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8873b5c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tIII/s345/b"},"text":"Pub. L. 103–337, div. A, title III, § 345(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2724"},"text":"108 Stat. 2724","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/337/dA/tIII/s345/b"},"text":"“The amendments made by subsection (a) [enacting this section] shall apply to persons separated from employment with the Department of Defense on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
