{"tag":"section","attrib":{"id":"idb81bf653-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3382"},"text":null,"children":[{"tag":"num","attrib":{"value":"3382"},"text":"§ 3382.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Involuntary separation for retirement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An air traffic controller who is eligible for immediate retirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8336"},"text":"section 8336 of this title","children":[],"tail":" may be separated involuntarily from the service if the Secretary determines that the separation of the controller is necessary in the interest of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81bf654-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3382/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aviation safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81bf655-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3382/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the efficient control of air traffic; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81bf656-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3382/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preservation of the physical or mental health of the controller.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Chapter 75 of this title does not apply to a determination or action under this section. Separation under this section shall not become final, without the consent of the controller, until the last day of the second month following the day the controller receives a notification of the determination by the Secretary under this section, or, if a review is requested under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3383"},"text":"section 3383 of this title","children":[],"tail":", the last day of the month in which a final decision is issued by a board of review under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3383/c"},"text":"section 3383(c) of this title","children":[],"tail":", whichever is later. A controller who is to be separated under this section is entitled to training under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3381"},"text":"section 3381 of this title","children":[],"tail":". Separation of such a controller who elects to receive training under section 3381 shall not become final until the last day of the month following the completion of his training."}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb81bf657-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/297/s3/a"},"text":"Pub. L. 92–297, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-16"},"text":"May 16, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/142"},"text":"86 Stat. 142","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/347/s1/b"},"text":"Pub. L. 96–347, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-12"},"text":"Sept. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1150"},"text":"94 Stat. 1150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb81bf658-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb81bf659-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb81bf65a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of Secretary, referred to in text, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2109"},"text":"section 2109 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb81bf65b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/347"},"text":"Pub. L. 96–347","children":[],"tail":" in provisions preceding par. (1) substituted “Secretary determines” for “Secretary of Transportation determines”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb81bf65c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb81bf65d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/347"},"text":"Pub. L. 96–347","children":[],"tail":" effective on 90th day after "},{"tag":"date","attrib":{"date":"1980-09-12"},"text":"Sept. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/347/s3"},"text":"section 3 of Pub. L. 96–347","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2109"},"text":"section 2109 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb81e665e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on 90th day after ","children":[{"tag":"date","attrib":{"date":"1972-05-16"},"text":"May 16, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/297/s10"},"text":"section 10 of Pub. L. 92–297","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3381"},"text":"section 3381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
