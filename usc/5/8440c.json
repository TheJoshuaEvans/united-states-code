{"tag":"section","attrib":{"id":"idb90592c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c"},"text":null,"children":[{"tag":"num","attrib":{"value":"8440c"},"text":"§ 8440c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Court of Federal Claims judges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb90592c4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90592c5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A judge of the United States Court of Federal Claims who is covered by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s178"},"text":"section 178 of title 28","children":[],"tail":" may elect to contribute an amount of such individual’s basic pay to the Thrift Savings Fund."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592c6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An election may be made under paragraph (1) as provided under section 8432(b) for individuals subject to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90592c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90592c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this subsection, the provisions of this subchapter and subchapter VII shall apply with respect to Court of Federal Claims judges who make contributions to the Thrift Savings Fund under subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount contributed by a Court of Federal Claims judge for any pay period shall not exceed the maximum percentage of such judge’s basic pay for such pay period allowable under section 8440f.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No contributions shall be made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432/c"},"text":"section 8432(c) of this title","children":[],"tail":" for the benefit of a Court of Federal Claims judge making contributions under subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb90592cc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8433/b"},"text":"Section 8433(b) of this title","children":[],"tail":" applies to a Court of Federal Claims judge who elects to make contributions to the Thrift Savings Fund under subsection (a) of this section and who retires entitled to an annuity under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s178"},"text":"section 178 of title 28","children":[],"tail":" (including a disability annuity under subsection (c) of such section)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90592cd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8433/b"},"text":"Section 8433(b) of this title","children":[],"tail":" applies to any Court of Federal Claims judge who elects to make contributions to the Thrift Savings Fund under subsection (a) of this section and who retires before becoming entitled to an annuity under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s178"},"text":"section 178 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592ce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With respect to Court of Federal Claims judges to whom this section applies, any of the actions described in paragraph (4)(A) or (B) shall be considered a separation from service for purposes of this subchapter and subchapter VII.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592cf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the terms “retirement” and “retire” include removal from office under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s178/c"},"text":"section 178(c) of title 28","children":[],"tail":" on the sole ground of mental or physical disability."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592d0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a Court of Federal Claims judge who receives a distribution from the Thrift Savings Plan and who later receives an annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s178"},"text":"section 178 of title 28","children":[],"tail":", such annuity shall be offset by an amount equal to the amount of the distribution which represents the Government’s contribution to that person’s Thrift Savings Account, without regard to earnings attributable to that amount. Where such an offset would exceed 50 percent of the annuity to be received in the first year, the offset may be divided equally over the first 2 years in which that person receives the annuity."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90592d1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440c/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding paragraph (4), if any Court of Federal Claims judge retires under circumstances making such judge eligible to make an election under section 8433(b), and such judge’s nonforfeitable account balance is less than an amount that the Executive Director prescribes by regulation, the Executive Director shall pay the nonforfeitable account balance to the participant in a single payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb90592d2-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s306/d/1"},"text":"Pub. L. 101–650, title III, § 306(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/5110"},"text":"104 Stat. 5110","children":[],"tail":", § 8440b; renumbered § 8440c and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/198/s7/c/1"},"text":"Pub. L. 102–198, § 7(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-09"},"text":"Dec. 9, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1624"},"text":"105 Stat. 1624","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/b"},"text":"Pub. L. 102–572, title IX, § 902(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/226/s9/g"},"text":"Pub. L. 103–226, § 9(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-30"},"text":"Mar. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/121"},"text":"108 Stat. 121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/f/tVI/tII/s205/c"},"text":"Pub. L. 104–208, div. A, title I, § 101(f) [title VI, § 659 [title II, § 205(c)]","children":[],"tail":"], "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-314"},"text":"110 Stat. 3009–314","children":[],"tail":", 3009–372, 3009–378; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s138/a/4"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 138(a)(4)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–233; "},{"tag":"ref","attrib":{"href":"/us/pl/108/469/s1/d/6"},"text":"Pub. L. 108–469, § 1(d)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-21"},"text":"Dec. 21, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3892"},"text":"118 Stat. 3892","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb90592d3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb90592d4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb90592d5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 8440c was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8440d"},"text":"section 8440d of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb90592d6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/469"},"text":"Pub. L. 108–469","children":[],"tail":" substituted “as” for “only during a period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" substituted “the maximum percentage of such judge’s basic pay for such pay period allowable under section 8440f.” for “5 percent of basic pay for such pay period.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s101/f/tVI/tII/s205/c/1"},"text":"Pub. L. 104–208, § 101(f) [title VI, § 659 [title II, § 205(c)(1)]","children":[],"tail":"], inserted “of the distribution” after “equal to the amount”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s101/f/tVI/tII/s205/c/2"},"text":"Pub. L. 104–208, § 101(f) [title VI, § 659 [title II, § 205(c)(2)]","children":[],"tail":"], substituted “less than an amount that the Executive Director prescribes by regulation” for “$3,500 or less” and struck out “unless the judge elects, at such time and otherwise in such manner as the Executive Director prescribes, one of the options available under section 8433(b)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226/s9/g/1"},"text":"Pub. L. 103–226, § 9(g)(1)","children":[],"tail":", substituted “Section 8433(b)” for “Section 8433(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226/s9/g/2"},"text":"Pub. L. 103–226, § 9(g)(2)","children":[],"tail":", substituted “any of the actions described in paragraph (4)(A) or (B) shall be considered” for “retirement under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s178"},"text":"section 178 of title 28","children":[],"tail":" is”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8), (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226/s9/g/3"},"text":"Pub. L. 103–226, § 9(g)(3)","children":[],"tail":", (4), redesignated par. (9) as (8), substituted “Notwithstanding paragraph (4)” for “Notwithstanding paragraph (4)(A)”, and struck out former par. (8) which read as follows: “Notwithstanding paragraph (4)(B), if any Court of Federal Claims judge who elects to make contributions to the Thrift Savings Fund under subsection (a) retires before becoming entitled to an annuity under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s178"},"text":"section 178 of title 28","children":[],"tail":", and such judge’s nonforfeitable account balance is $3,500 or less, the Executive Director shall pay the nonforfeitable account balance to the participant in a single payment unless the judge elects, at such time and otherwise in such manner as the Executive Director prescribes, to have the nonforfeitable account balance transferred to an eligible retirement plan as provided in section 8433(e).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572/s902/b/2"},"text":"Pub. L. 102–572, § 902(b)(2)","children":[],"tail":", substituted “Court of Federal Claims” for “Claims Court” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572/s902/b/1"},"text":"Pub. L. 102–572, § 902(b)(1)","children":[],"tail":", substituted “United States Court of Federal Claims” for “United States Claims Court”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1) to (5), (7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572/s902/b/2"},"text":"Pub. L. 102–572, § 902(b)(2)","children":[],"tail":", substituted “Court of Federal Claims” for “Claims Court” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/198/s7/c/1/A"},"text":"Pub. L. 102–198, § 7(c)(1)(A)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8440b"},"text":"section 8440b of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/198/s7/c/1/B/i"},"text":"Pub. L. 102–198, § 7(c)(1)(B)(i)","children":[],"tail":", substituted “subsection (c)” for “subsection (d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/198/s7/c/1/B/ii"},"text":"Pub. L. 102–198, § 7(c)(1)(B)(ii)","children":[],"tail":", redesignated par. (8) as (7) and struck out former par. (7) which read as follows: “Sums contributed pursuant to this section by Claims Court judges, as well as all previous contributions to the Thrift Savings Fund by those judges, and earnings attributable to such sums and contributions, may be invested and reinvested only in the Government Securities Investment Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8438/b/1/A"},"text":"section 8438(b)(1)(A) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/198/s7/c/1/B/ii"},"text":"Pub. L. 102–198, § 7(c)(1)(B)(ii)","children":[],"tail":", (iii) added par. (8) and redesignated former par. (8) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/198/s7/c/1/B/iii"},"text":"Pub. L. 102–198, § 7(c)(1)(B)(iii)","children":[],"tail":", added par. (9)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb90592d7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90592d8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", and withdrawals and elections as provided under such amendment to be made at earliest practicable date as determined by Executive Director in regulations, see section 101(f) [title VI, § 659 [title II, § 207]] of "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5545a"},"text":"section 5545a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90592d9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226"},"text":"Pub. L. 103–226","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1995-03-10"},"text":"Mar. 10, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/226/s9/j"},"text":"section 9(j) of Pub. L. 103–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8351"},"text":"section 8351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90592da-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s911"},"text":"section 911 of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90592db-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/198/s7/c/3"},"text":"Section 7(c)(3) of Pub. L. 102–198","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/b/2"},"text":"Pub. L. 102–572, title IX, § 902(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/572/tIX/s902/b/2"},"text":"“Paragraphs (8) and (9) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8440c/b"},"text":"section 8440c(b) of title 5","children":[],"tail":", United States Code (as added by paragraph (1)) shall be effective as of "},{"tag":"date","attrib":{"date":"1991-01-01"},"text":"January 1, 1991","children":[],"tail":", and shall apply to any Court of Federal Claims judge retiring on or after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb90592dc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to judges of, and senior judges in active service with, the United States Court of Federal Claims on or after ","children":[{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/s306/f"},"text":"section 306(f) of Pub. L. 101–650","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8331"},"text":"section 8331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
