{"tag":"section","attrib":{"id":"idb937c605-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13145"},"text":null,"children":[{"tag":"num","attrib":{"value":"13145"},"text":"§ 13145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb937c606-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13145/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General may bring a civil action in any appropriate United States district court against any individual who violates any provision of section 13143 or 13144 of this title. The court in which such action is brought may assess against such individual a civil penalty of not more than $10,000 or the amount of compensation, if any, which the individual received for the prohibited conduct, whichever is greater.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb937c607-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13145/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory Opinions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any entity described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s13142"},"text":"section 13142 of this title","children":[],"tail":" may render advisory opinions interpreting this subchapter, in writing, to individuals covered by this subchapter. Any individual to whom such an advisory opinion is rendered and any other individual covered by this subchapter who is involved in a fact situation which is indistinguishable in all material aspects, and who, after the issuance of such advisory opinion, acts in good faith in accordance with its provisions and findings shall not, as a result of such actions, be subject to any sanction under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb937c608-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/c"},"text":"Pub. L. 117–286, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4304"},"text":"136 Stat. 4304","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb937c609-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb937c60a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb937c60b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib"