{"tag":"section","attrib":{"id":"idb91b15f3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8903a"},"text":"§ 8903a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional health benefits plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91b15f4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to any plan under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8903"},"text":"section 8903 of this title","children":[],"tail":", the Office of Personnel Management may contract for or approve one or more health benefits plans under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91b15f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A plan under this section may not be contracted for or approved unless it—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91b15f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is sponsored or underwritten, and administered, in whole or substantial part, by an employee organization described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8901/8/B"},"text":"section 8901(8)(B) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91b15f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers benefits of the types named by paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8904"},"text":"section 8904 of this title","children":[],"tail":" or both;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91b15f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for benefits only by paying for, or providing reimbursement for, the cost of such benefits (as provided for under paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8903"},"text":"section 8903 of this title","children":[],"tail":") or a combination thereof; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91b15f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is available only to individuals who, at the time of enrollment, are full members of the organization and to members of their families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91b15fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A contract for a plan approved under this section shall require the carrier—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91b15fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enter into an agreement approved by the Office with an underwriting subcontractor licensed to issue group health insurance in all the States and the District of Columbia; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91b15fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate ability to meet reasonable minimum financial standards prescribed by the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91b15fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, an individual shall be considered a full member of an organization if such individual is eligible to exercise all rights and privileges incident to full membership in such organization (determined without regard to the right to hold elected office).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91b15fe-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/53/s1/b/1"},"text":"Pub. L. 99–53, § 1(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-06-17"},"text":"June 17, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/93"},"text":"99 Stat. 93","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
