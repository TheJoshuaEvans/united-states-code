{"tag":"section","attrib":{"id":"idb889acbc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5902"},"text":null,"children":[{"tag":"num","attrib":{"value":"5902"},"text":"§ 5902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase in maximum uniform allowance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Office of Personnel Management may, from time to time, by regulation adjust the maximum amount for the cost of uniforms and the maximum allowance for uniforms under section 5901.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb889acbd-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/40/A"},"text":"Pub. L. 90–83, § 1(40)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/206"},"text":"81 Stat. 206","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tII/s202/b"},"text":"Pub. L. 101–509, title V, § 529 [title II, § 202(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1456.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb889acbe-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb889acbf-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb889acc0-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 5","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5902","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 App.: 2134.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 18, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/504/s407/b"},"text":"Pub. L. 89–504, § 407(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/299"},"text":"80 Stat. 299","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “any other provision of” following “Notwithstanding” are omitted as unnecessary. The words “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5901"},"text":"section 5901 of this title","children":[],"tail":"” are substituted for “this title” in three places to reflect the codification of that title in title 5, United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb889acc1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb889acc2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5901"},"text":"section 5901 of this title","children":[],"tail":", each of the respective maximum uniform allowances in effect on "},{"tag":"date","attrib":{"date":"1966-04-01"},"text":"April 1, 1966","children":[],"tail":", for the respective categories of employees to whom uniform allowances are paid under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5901"},"text":"section 5901 of this title","children":[],"tail":" are increased, subject to the maximum allowance authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5901"},"text":"section 5901 of this title","children":[],"tail":", as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) If the maximum uniform allowance is $100 or more, it is increased by 25 percent.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) If the maximum uniform allowance is $75 or more but less than $100, it is increased by 30 percent.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) If the maximum uniform allowance is $50 or more but less than $75, it is increased by 35 percent.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) If the maximum uniform allowance is less than $50, it is increased by 40 percent.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The maximum uniform allowances, as in effect on ","children":[{"tag":"date","attrib":{"date":"1966-04-01"},"text":"April 1, 1966","children":[],"tail":", and as increased by this section, may not be reduced.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb889acc3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb889acc4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" effective on such date as the President shall determine, but not earlier than 90 days, and not later than 180 days, after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see section 529 [title III, § 305] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
