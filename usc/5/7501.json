{"tag":"section","attrib":{"id":"idb8b48cdf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7501"},"text":null,"children":[{"tag":"num","attrib":{"value":"7501"},"text":"§ 7501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b48ce0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “employee” means an individual in the competitive service who is not serving a probationary or trial period under an initial appointment or who has completed 1 year of current continuous employment in the same or similar positions under other than a temporary appointment limited to 1 year or less; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48ce1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “suspension” means the placing of an employee, for disciplinary reasons, in a temporary status without duties and pay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b48ce2-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tII/s204/a"},"text":"Pub. L. 95–454, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1134"},"text":"92 Stat. 1134","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tXI/s1105/c/3"},"text":"Pub. L. 114–92, div. A, title XI, § 1105(c)(3)","children":[],"tail":", "},{"tag":"date","attr