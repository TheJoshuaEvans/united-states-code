{"tag":"section","attrib":{"id":"idb8611541-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406"},"text":null,"children":[{"tag":"num","attrib":{"value":"5406"},"text":"§ 5406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8611542-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To be eligible for consideration by the Office for an allocation under this section, an agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8611543-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop a plan that incorporates the following elements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8611544-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adherence to merit principles set forth in section 2301;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8611545-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fair, credible, and transparent employee performance appraisal system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8611546-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a link between the pay-for-performance system, the employee performance appraisal system, and the agency’s strategic plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8611547-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a means for ensuring employee involvement in the design and implementation of the system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8611548-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate training and retraining for supervisors, managers, and employees in the implementation and operation of the pay-for-performance system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8611549-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process for ensuring ongoing performance feedback and dialogue between supervisors, managers, and employees throughout the appraisal period, and setting timetables for review;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb861154a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective safeguards to ensure that the management of the system is fair and equitable and based on employee performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb861154b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a means for ensuring that adequate agency resources are allocated for the design, implementation, and administration of the pay-for-performance system;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb861154c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon approval, receive an allocation of funding from the Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb861154d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make payments to individual employees in accordance with the agency’s approved plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb861154e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such information to the Office regarding payments made and use of funds received under this section as the Office may specify.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb861154f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office, in consultation with the Chief Human Capital Officers Council, shall review and approve an agency’s plan before the agency is eligible to receive an allocation of funding from the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8611550-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Human Capital Officers Council shall include in its annual report to Congress under section 1303(d) of the Homeland Security Act of 2002 an evaluation of the formulation and implementation of agency performance management systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8611551-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXI/s1129/a"},"text":"Pub. L. 108–136, div. A, title XI, § 1129(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1644"},"text":"117 Stat. 1644","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8611552-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8611553-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8611554-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 1303(d) of the Homeland Security Act of 2002, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1303/d"},"text":"section 1303(d) of Pub. L. 107–296","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1401"},"text":"section 1401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8611555-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5406, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615/tII/s201/a"},"text":"Pub. L. 98–615, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3211"},"text":"98 Stat. 3211","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/103/s4"},"text":"Pub. L. 101–103, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-09-30"},"text":"Sept. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/671"},"text":"103 Stat. 671","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/22/s2/b"},"text":"Pub. L. 102–22, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-03-28"},"text":"Mar. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/71"},"text":"105 Stat. 71","children":[],"tail":", related to performance awards, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/89/s3/a/1"},"text":"Pub. L. 103–89, § 3(a)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"Sept. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/981"},"text":"107 Stat. 981","children":[],"tail":", 983, eff. "},{"tag":"date","attrib":{"date":"1993-11-01"},"text":"Nov. 1, 1993","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
