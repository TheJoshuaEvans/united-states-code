{"tag":"section","attrib":{"id":"idb82c98a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4503"},"text":null,"children":[{"tag":"num","attrib":{"value":"4503"},"text":"§ 4503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency awards","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The head of an agency may pay a cash award to, and incur necessary expense for the honorary recognition of, an employee who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82c98a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4503/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by his suggestion, invention, superior accomplishment, or other personal effort contributes to the efficiency, economy, or other improvement of Government operations or achieves a significant reduction in paperwork; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c98a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4503/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs a special act or service in the public interest in connection with or related to his official employment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82c98a4-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/443"},"text":"80 Stat. 443","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tV/s502/a"},"text":"Pub. L. 95–454, title V, § 502(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"