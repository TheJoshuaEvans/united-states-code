{"tag":"section","attrib":{"id":"idb9224206-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8911"},"text":null,"children":[{"tag":"num","attrib":{"value":"8911"},"text":"§ 8911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Office of Personnel Management shall appoint a committee composed of five members, who serve without pay, to advise the Office regarding matters of concern to employees under this chapter. Each member of the committee shall be an employee enrolled under this chapter or an elected official of an employee organization.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb9224207-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/607"},"text":"80 Stat. 607","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/a/1"},"text":"Pub. L. 95–454, title IX, § 906(a)(1)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1224"},"text":"92 Stat. 1224","children":[],"tail":", 1225.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9224208-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb9224209-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb922420a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":