{"tag":"section","attrib":{"id":"idb889ac0e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754"},"text":null,"children":[{"tag":"num","attrib":{"value":"5754"},"text":"§ 5754.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Retention bonuses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb889ac0f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb889ac10-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section may be applied to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb889ac11-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees covered by the General Schedule pay system established under subchapter III of chapter 53; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889ac12-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees in a category approved by the Office of Personnel Management at the request of the head of an Executive agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac13-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A bonus may not be paid under this section to an individual who is appointed to or who holds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb889ac14-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position to which an individual is appointed by the President, by and with the advice and consent of the Senate, excluding members of the Foreign Service other than chiefs of mission and ambassadors at large;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889ac15-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position in the Senior Executive Service as a noncareer appointee (as such term is defined under section 3132(a)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889ac16-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position which has been excepted from the competitive service by reason of its confidential, policy-determining, policy-making, or policy-advocating character.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac17-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “employee” has the meaning given that term in section 2105, except that such term also includes an employee described in subsection (c) of that section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac18-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office of Personnel Management may authorize the head of an agency to pay a retention bonus to an employee if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb889ac19-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unusually high or unique qualifications of the employee or a special need of the agency for the employee’s services makes it essential to retain the employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac1a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the agency determines that, in the absence of a retention bonus, the employee would be likely to leave—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb889ac1b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889ac1c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a different position in the Federal service under conditions described in regulations of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac1d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office may authorize the head of an agency to pay retention bonuses to a group of employees in 1 or more categories of positions in 1 or more geographic areas, subject to the requirements of subsection (b)(1) and regulations prescribed by the Office, if there is a high risk that a significant portion of employees in the group would be likely to leave in the absence of retention bonuses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac1e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb889ac1f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment of a retention bonus is contingent upon the employee entering into a written service agreement with the agency to complete a period of employment with the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac20-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb889ac21-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The agreement shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb889ac22-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of the required service period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb889ac23-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the bonus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb889ac24-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method of payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb889ac25-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other terms and conditions under which the bonus is payable, subject to the requirements of this section and regulations of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889ac26-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The terms and conditions for paying a bonus, as specified in the service agreement, shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb889ac27-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions under which the agreement may be terminated before the agreed-upon service period has been completed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb889ac28-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of the termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac29-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb889ac2a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding paragraph (1), a written service agreement is not required if the agency pays a retention bonus in biweekly installments and sets the installment payment at the full bonus percentage rate established for the employee with no portion of the bonus deferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889ac2b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an agency pays a retention bonus in accordance with subparagraph (A) and makes a determination to terminate the payments, the agency shall provide written notice to the employee of that determination. Except as provided in regulations of the Office, the employee shall continue to be paid the retention bonus through the end of the pay period in which such written notice is provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac2c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A retention bonus for an employee may not be based on any period of such service which is the basis for a recruitment or relocation bonus under section 5753.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac2d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb889ac2e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (f), a retention bonus, which shall be stated as a percentage of the employee’s basic pay for the service period associated with the bonus, may not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb889ac2f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent of the employee’s basic pay if paid under subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889ac30-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of an employee’s basic pay if paid under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac31-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb889ac32-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A retention bonus may be paid to an employee in installments after completion of specified periods of service or in a single lump sum at the end of the full period of service required by the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889ac33-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An installment payment is derived by multiplying the amount of basic pay earned in the installment period by a percentage not to exceed the bonus percentage rate established for the employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889ac34-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the installment payment percentage established for the employee is less than the bonus percentage rate established for the employee, the accrued but unpaid portion of the bonus is payable as part of the final installment payment to the employee after completion of the full service period under the terms of the service agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889ac35-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this paragraph, the bonus percentage rate established for an employee means the bonus percentage rate established for such employee in accordance with paragraph (1) or subsection (f), as the case may be.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac36-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A retention bonus is not part of the basic pay of an employee for any purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac37-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the request of the head of an agency, the Office may waive the limit established under subsection (e)(1) and permit the agency head to pay an otherwise eligible employee or category of employees retention bonuses of up to 50 percent of basic pay, based on a critical agency need.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac38-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall require that, before paying any bonuses under this section, an agency shall establish a plan for the payment of any such bonuses, subject to regulations prescribed by the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac39-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5754/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office may prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb889ac3a-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/411/tI/s101/a/1"},"text":"Pub. L. 108–411, title I, § 101(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2307"},"text":"118 Stat. 2307","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/323/tIV/s412/2"},"text":"Pub. L. 114–323, title IV, § 412(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1932"},"text":"130 Stat. 1932","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb889ac3b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb889ac3c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb889ac3d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (a)(1)(A), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb889ac3e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5754, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tII/s208/a"},"text":"Pub. L. 101–509, title V, § 529 [title II, § 208(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1459, which related to retention allowances, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/108/411/tI/s101/a/1"},"text":"Pub. L. 108–411, title I, § 101(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2305"},"text":"118 Stat. 2305","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb889ac3f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323"},"text":"Pub. L. 114–323","children":[],"tail":" inserted “, excluding members of the Foreign Service other than chiefs of mission and ambassadors at large” before semicolon at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb889ac40-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb889ac41-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the first day of the first applicable pay period beginning on or after the 180th day after ","children":[{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", with exception for payment of certain retention allowances, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/411/s101/d"},"text":"section 101(d) of Pub. L. 108–411","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5753"},"text":"section 5753 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
