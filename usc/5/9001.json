{"tag":"section","attrib":{"id":"idb924b365-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001"},"text":null,"children":[{"tag":"num","attrib":{"value":"9001"},"text":"§ 9001.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb924b366-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb924b367-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee as defined by section 8901(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b368-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual described in section 2105(e);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b369-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual employed by the Tennessee Valley Authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b36a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of a nonappropriated fund instrumentality of the Department of Defense described in section 2105(c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b36b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of the District of Columbia courts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b36c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annuitant","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “annuitant” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb924b36d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual who would satisfy the requirements of paragraph (3) of section 8901 if, for purposes of such paragraph, the term “employee” were considered to have the meaning given to it under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b36e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any individual who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb924b36f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfies all requirements for title to an annuity under subchapter III of chapter 83, chapter 84, or any other retirement system for employees of the Government (whether based on the service of such individual or otherwise), and files application therefor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb924b370-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is at least 18 years of age; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb924b371-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not (but for this subparagraph) otherwise satisfy the requirements of this paragraph; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b372-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any former employee who, on the basis of his or her service, would meet all requirements for being considered an “annuitant” within the meaning of subchapter III of chapter 83, chapter 84, or any other retirement system for employees of the Government, but for the fact that such former employee has not attained the minimum age for title to annuity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b373-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Member of the uniformed services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “member of the uniformed services” means a member of the uniformed services, other than a retired member of the uniformed services, who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb924b374-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on active duty or full-time National Guard duty for a period of more than 30 days; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b375-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Selected Reserve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b376-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retired member of the uniformed services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “retired member of the uniformed services” means a member or former member of the uniformed services entitled to retired or retainer pay, and a member who has been transferred to the Retired Reserve and who would be entitled to retired pay under chapter 1223 of title 10 but for not having attained the age of 60 and who satisfies such eligibility requirements as the Office of Personnel Management prescribes under section 9008.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b377-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified relative","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualified relative” means each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb924b378-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The spouse of an individual described in paragraph (1), (2), (3), or (4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b379-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A parent, stepparent, or parent-in-law of an individual described in paragraph (1) or (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b37a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A child (including an adopted child, a stepchild, or, to the extent the Office of Personnel Management by regulation provides, a foster child) of an individual described in paragraph (1), (2), (3), or (4), if such child is at least 18 years of age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b37b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual having such other relationship to an individual described in paragraph (1), (2), (3), or (4) as the Office may by regulation prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b37c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible individual","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “eligible individual” refers to an individual described in paragraph (1), (2), (3), (4), or (5).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b37d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “qualified carrier” means an insurance company (or consortium of insurance companies) that is licensed to issue long-term care insurance in all States, taking any subsidiaries of such a company into account (and, in the case of a consortium, considering the member companies and any subsidiaries thereof, collectively).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b37e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” includes the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b37f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified long-term care insurance contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “qualified long-term care insurance contract” has the meaning given such term by section 7702B of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b380-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate Secretary” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb924b381-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise provided in this paragraph, the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b382-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the Coast Guard when it is not operating as a service of the Navy, the Secretary of Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b383-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the commissioned corps of the National Oceanic and Atmospheric Administration, the Secretary of Commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b384-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9001/10/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the commissioned corps of the Public Health Service, the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb924b385-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/265/tI/s1002/a"},"text":"Pub. L. 106–265, title I, § 1002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-19"},"text":"Sept. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/762"},"text":"114 Stat. 762","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/104/s1"},"text":"Pub. L. 107–104, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1001"},"text":"115 Stat. 1001","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tX/s1048/i/6"},"text":"Pub. L. 107–107, div. A, title X, § 1048(i)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1229"},"text":"115 Stat. 1229","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tXI/s1101/a"},"text":"Pub. L. 107–314, div. A, title XI, § 1101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2660"},"text":"116 Stat. 2660","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dC/tIII/s138/a"},"text":"Pub. L. 108–7, div. C, title III, § 138(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/129"},"text":"117 Stat. 129","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tV/s561"},"text":"Pub. L. 108–136, div. A, title V, § 561","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1482"},"text":"117 Stat. 1482","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/241/tIX/s902/a/3"},"text":"Pub. L. 109–241, title IX, § 902(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-07-11"},"text":"July 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/566"},"text":"120 Stat. 566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/356/tI/s117/a/3"},"text":"Pub. L. 109–356, title I, § 117(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-16"},"text":"Oct. 16, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2027"},"text":"120 Stat. 2027","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb924b386-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb924b387-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb924b388-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 7702B of the Internal Revenue Code of 1986, referred to in par. (9), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s7702B"},"text":"section 7702B of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb924b389-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Par. (1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/356"},"text":"Pub. L. 109–356","children":[],"tail":" added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (10)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/241"},"text":"Pub. L. 109–241","children":[],"tail":" substituted “Secretary of Homeland Security” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s561/a"},"text":"Pub. L. 108–136, § 561(a)","children":[],"tail":", substituted a period for a comma at end of subpar. (D) and struck out concluding provisions which read: “but does not include an individual employed by the government of the District of Columbia (other than an employee of the District of Columbia Courts).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" inserted “(other than an employee of the District of Columbia Courts)” before period at end of concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s561/d"},"text":"Pub. L. 108–136, § 561(d)","children":[],"tail":", struck out “of this subsection” after “paragraph (1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s561/b"},"text":"Pub. L. 108–136, § 561(b)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s561/c"},"text":"Pub. L. 108–136, § 561(c)","children":[],"tail":", substituted “and a member who has been transferred to the Retired Reserve and who would be entitled to retired pay under chapter 1223 of title 10 but for not having” for “including a member or former member retired under chapter 1223 of title 10 who has”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Par. (1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/314"},"text":"Pub. L. 107–314","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/104"},"text":"Pub. L. 107–104","children":[],"tail":" amended heading and text of par. (2) generally. Prior to amendment, text read as follows: “The term ‘annuitant’ has the meaning such term would have under paragraph (3) of section 8901 if, for purposes of such paragraph, the term ‘employee’ were considered to have the meaning given to it under paragraph (1) of this subsection.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “or” for “and” after semicolon."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb924b38a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb924b38b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/104/s3"},"text":"Pub. L. 107–104, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1002"},"text":"115 Stat. 1002","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/104/s3"},"text":"“The amendments made by this Act [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s9005"},"text":"section 9005 of this title","children":[],"tail":"] shall take effect as if included in the enactment of section 1002 of the Long-Term Care Security Act ("},{"tag":"ref","attrib":{"href":"/us/pl/106/265"},"text":"Public Law 106–265","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/114/762"},"text":"114 Stat. 762","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb924b38c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/265/tI/s1003"},"text":"Pub. L. 106–265, title I, § 1003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-19"},"text":"Sept. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/770"},"text":"114 Stat. 770","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/265/tI/s1003"},"text":"“The Office of Personnel Management shall take such measures as may be necessary to ensure that long-term care insurance coverage under title 5, United States Code, as amended by this title [enacting this chapter], may be obtained in time to take effect not later than the first day of the first applicable pay period of the first fiscal year which begins after the end of the 18-month period beginning on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-09-19"},"text":"Sept. 19, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb924b38d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/265/tI/s1001"},"text":"Pub. L. 106–265, title I, § 1001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-19"},"text":"Sept. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/762"},"text":"114 Stat. 762","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/265/tI/s1001"},"text":"“This title [enacting this chapter] may be cited as the ‘Long-Term Care Security Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idb924b38e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
