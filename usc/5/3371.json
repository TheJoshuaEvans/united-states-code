{"tag":"section","attrib":{"id":"idb81bf5b9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3371"},"text":null,"children":[{"tag":"num","attrib":{"value":"3371"},"text":"§ 3371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81bf5ba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3371/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81bf5bb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3371/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Trust Territory of the Pacific Islands, and a territory or possession of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81bf5bc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3371/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an instrumentality or authority of a State or States as defined in subparagraph (A) of this paragraph (1) and a Federal-State authority or instrumentality;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81bf5bd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3371/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “local government” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81bf5be-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3371/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any political subdivision, instrumentality, or authority of a State or States as defined in subparagraph (A) of paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81bf5bf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3371/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any general or special purpose agency of such a political subdivision, instrumentality, or authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81bf5c0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3371/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Indian tribe, band, nation, or other organized group or community, including any Alaska Native village as defined in the Alaska Native Claims Settlement Act (","children":[{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":"), which is recognized as eligible for the special programs and services provided by the United States to Indians because of their status as Indians and includes any tribal organization as defined in section 4 of the Indian Self-Determination and Education Assistance Act;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81bf5c1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3371/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal agency” means an Executive agency, military department, a court of the United States, the Administrative Office of the United States Courts, the Library of Congress, the Botanic Garden, the Government Publishing Office, the Congressional Budget Office, the United States Postal Service, the Postal Regulatory Commission, the Office of the Architect of the Capitol, the Office of Technology Assessment, and such other similar agencies of the legislative and judicial branches as determined appropriate by the Office of Personnel Management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81bf5c2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3371/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “other organization” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81bf5c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3371/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national, regional, State-wide, area-wide, or metropolitan organization representing member State or local governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81bf5c4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3371/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an association of State or local public officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81bf5c5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3371/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization which has as one of its principal functions the offering of professional advisory, research, educational, or development services, or related services, to governments or universities concerned with public management; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81bf5c6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3371/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a federally funded research and development center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb81bf5c7-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/648/tIV/s402/a"},"text":"Pub. L. 91–648, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-05"},"text":"Jan. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1920"},"text":"84 Stat. 1920","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/638/tI/s104/a"},"text":"Pub. L. 93–638, title I, § 104(a)","children":[],"tail":", formerly § 105(a), "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2208"},"text":"88 Stat. 2208","children":[],"tail":", renumbered § 104(a), "},{"tag":"ref","attrib":{"href":"/us/pl/100/472/tII/s203/a"},"text":"Pub. L. 100–472, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-05"},"text":"Oct. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2290"},"text":"102 Stat. 2290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVI/s603/a"},"text":"Pub. L. 95–454, title VI, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1189"},"text":"92 Stat. 1189","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/472/tII/s203/b"},"text":"Pub. L. 100–472, title II, § 203(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-05"},"text":"Oct. 5, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2290"},"text":"102 Stat. 2290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/301/s2/c"},"text":"Pub. L. 101–301, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-24"},"text":"May 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/207"},"text":"104 Stat. 207","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX/s1068/a"},"text":"Pub. L. 103–337, div. A, title X, § 1068(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2852"},"text":"108 Stat. 2852","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tVI/s604/b"},"text":"Pub. L. 109–435, title VI, § 604(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3241"},"text":"120 Stat. 3241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb81bf5c8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb81bf5c9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb81bf5ca-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Alaska Native Claims Settlement Act, referred to in par. (2)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4 of the Indian Self-Determination and Education Assistance Act, referred to in par. (2)(C), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of Title 25","children":[],"tail":", Indians."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb81bf5cb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/435"},"text":"Pub. L. 109–435","children":[],"tail":" substituted “Postal Regulatory Commission” for “Postal Rate Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337"},"text":"Pub. L. 103–337","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Par. (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/301"},"text":"Pub. L. 101–301","children":[],"tail":" substituted “section 4” for “section 4(m)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/472/s203/b"},"text":"Pub. L. 100–472, § 203(b)","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", by substituting “section 4(m)” for “section 4(c)” in the provision it added as par. (2)(C) of this section. See 1975 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s603/a/1"},"text":"Pub. L. 95–454, § 603(a)(1)","children":[],"tail":", inserted reference to the Trust Territory of the Pacific Islands."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s603/a/2"},"text":"Pub. L. 95–454, § 603(a)(2)","children":[],"tail":", added pars. (3) and (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Par. (2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/638"},"text":"Pub. L. 93–638","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/472/s203/b"},"text":"Pub. L. 100–472, § 203(b)","children":[],"tail":", added par. (2)(C)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb81bf5cc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb81bf5cd-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” in par. (3) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb81bf5ce-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb81bf5cf-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/648/tIV/s404"},"text":"Pub. L. 91–648, title IV, § 404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-05"},"text":"Jan. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1925"},"text":"84 Stat. 1925","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/91/648/tIV/s404"},"text":"“This title [enacting this subchapter and repealing sections 1881 to 1888 of Title 7, Agriculture, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s869b"},"text":"section 869b of Title 20","children":[],"tail":", Education, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s246/f"},"text":"section 246(f) of Title 42","children":[],"tail":", The Public Health and Welfare, (less applicability to commissioned officers of the Public Health Service)] shall become effective sixty days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1971-01-05"},"text":"Jan. 5, 1971","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb81bf5d0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Employee Exchange Program Between Federal Employees and Employees of State and Local Governments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/196/s3"},"text":"Pub. L. 108–196, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-19"},"text":"Dec. 19, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2896"},"text":"117 Stat. 2896","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/196/s3"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘employing agency’ means the Federal, State, or local government agency with which the participating employee was employed before an assignment under the Program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘participating employee’ means an employee who is participating in the Program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Program’ means the employee exchange program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall establish an employee exchange program between Federal agencies that perform law enforcement functions and agencies of State and local governments that perform law enforcement functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conduct of Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Program shall be conducted in accordance with subchapter VI of chapter 33 of title 5, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An employee of an employing agency who performs law enforcement functions may be selected to participate in the Program if the employee—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been employed by that employing agency for a period of more than 3 years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has had appropriate training or experience to perform the work required by the assignment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has had an overall rating of satisfactory or higher on performance appraisals from the employing agency during the 3-year period before being assigned to another agency under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to return to the employing agency after completing the assignment for a period not less than the length of the assignment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An employee shall enter into a written agreement regarding the terms and conditions of the assignment before beginning the assignment with another agency.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb81bf5d1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Declaration of Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/648/tIV/s401"},"text":"Pub. L. 91–648, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-05"},"text":"Jan. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1920"},"text":"84 Stat. 1920","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVI/s602/b"},"text":"Pub. L. 95–454, title VI, § 602(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1189"},"text":"92 Stat. 1189","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/454/tVI/s602/b"},"text":"“The purpose of this title [see Effective Date note above] is to provide for the temporary assignment of personnel between the Federal Government and State and local governments, institutions of higher education, and other organizations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb81bf5d2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb81bf5d3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
