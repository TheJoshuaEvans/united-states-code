{"tag":"section","attrib":{"id":"idb82f0947-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4523"},"text":null,"children":[{"tag":"num","attrib":{"value":"4523"},"text":"§ 4523.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Award authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82f0948-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4523/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency may pay a cash award, up to 5 percent of basic pay, to any law enforcement officer employed in or under such agency who possesses and makes substantial use of 1 or more foreign languages in the performance of official duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82f0949-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4523/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Awards under this section shall be paid under regulations prescribed by the head of the agency involved (or designee thereof). Regulations prescribed by an agency head (or designee) under this subsecton ","children":[{"tag":"ref","attrib":{"idref":"fn002080"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002080"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection”."}],"tail":" shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82f094a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4523/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures under which foreign language proficiency shall be ascertained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f094b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4523/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria for the selection of individuals for recognition under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f094c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4523/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other provisions which may be necessary to carry out the purposes of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82f094d-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tIV/s408/a"},"text":"Pub. L. 101–509, title V, § 529 [title IV, § 408(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1467.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82f094e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82f094f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb82f0950-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1992-01-01"},"text":"Jan. 1, 1992","children":[],"t