{"tag":"section","attrib":{"id":"idb889abdc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753"},"text":null,"children":[{"tag":"num","attrib":{"value":"5753"},"text":"§ 5753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recruitment and relocation bonuses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb889abdd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb889abde-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section may be applied to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb889abdf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees covered by the General Schedule pay system established under subchapter III of chapter 53; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889abe0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees in a category approved by the Office of Personnel Management at the request of the head of an Executive agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889abe1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A bonus may not be paid under this section to an individual who is appointed to or who holds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb889abe2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position to which an individual is appointed by the President, by and with the advice and consent of the Senate, excluding members of the Foreign Service other than chiefs of mission and ambassadors at large;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889abe3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position in the Senior Executive Service as a noncareer appointee (as such term is defined under section 3132(a)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889abe4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position which has been excepted from the competitive service by reason of its confidential, policy-determining, policy-making, or policy-advocating character.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889abe5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “employee” has the meaning given that term in section 2105, except that such term also includes an employee described in subsection (c) of that section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889abe6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office of Personnel Management may authorize the head of an agency to pay a bonus under this section to an individual only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb889abe7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the position to which such individual is appointed (as described in paragraph (2)(A)) or to which such individual moves or must relocate (as described in paragraph (2)(B)) is likely to be difficult to fill in the absence of such a bonus; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889abe8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb889abe9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is newly appointed as an employee of the Federal Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889abea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb889abeb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is currently employed by the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb889abec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb889abed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" moves to a new position in the same geographic area under circumstances described in regulations of the Office; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb889abee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must relocate to accept a position in a different geographic area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889abef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb889abf0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment of a bonus under this section shall be contingent upon the employee entering into a written service agreement to complete a period of employment with the agency, not longer than 4 years. The Office may, by regulation, prescribe a minimum service period for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889abf1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb889abf2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The agreement shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb889abf3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the commencement and termination dates of the required service period (or provisions for the determination thereof);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb889abf4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the bonus;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb889abf5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the method of payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb889abf6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other terms and conditions under which the bonus is payable, subject to the requirements of this section and regulations of the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889abf7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The terms and conditions for paying a bonus, as specified in the service agreement, shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb889abf8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions under which the agreement may be terminated before the agreed-upon service period has been completed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb889abf9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of the termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889abfa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The required service period shall commence upon the commencement of service with the agency or movement to a new position or geographic area, as applicable, unless the service agreement provides for a later commencement date in circumstances and to the extent allowable under regulations of the Office, such as when there is an initial period of formal basic training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889abfb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb889abfc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (e), a bonus under this section shall not exceed 25 percent of the annual rate of basic pay of the employee at the beginning of the service period multiplied by the number of years (including a fractional part of a year, as determined under regulations of the Office) in the required service period of the employee involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889abfd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A bonus under this section may be paid as an initial lump sum, in installments, as a final lump sum upon the completion of the full period of service required by the agreement, or in a combination of these forms of payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889abfe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A bonus under this section is not part of the basic pay of an employee for any purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889abff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations of the Office, a recruitment bonus under this section may be paid to an eligible individual before that individual enters on duty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac00-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office may authorize the head of an agency to waive the limitation under subsection (d)(1) based on a critical agency need, subject to regulations prescribed by the Office. Under such a waiver, the maximum bonus allowable shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb889ac01-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be equal to the maximum that would be determined if subsection (d)(1) were applied by substituting “50” for “25”; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac02-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in no event exceed 100 percent of the annual rate of basic pay of the employee at the beginning of the service period.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Nothing in this subsection shall be considered to permit the waiver of any requirement under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac03-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall require that an agency establish a plan for the payment of recruitment bonuses before paying any such bonuses, and a plan for the payment of relocation bonuses before paying any such bonuses, subject to regulations prescribed by the Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac04-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5753/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office may prescribe regulations to carry out this section, including regulations relating to the repayment of a bonus under this section in appropriate circumstances when the agreed-upon service period has not been completed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb889ac05-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/411/tI/s101/a/1"},"text":"Pub. L. 108–411, title I, § 101(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2305"},"text":"118 Stat. 2305","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/323/tIV/s412/1"},"text":"Pub. L. 114–323, title IV, § 412(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1932"},"text":"130 Stat. 1932","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb889ac06-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb889ac07-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb889ac08-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (a)(1)(A), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb889ac09-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5753, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tII/s208/a"},"text":"Pub. L. 101–509, title V, § 529 [title II, § 208(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1458, which related to recruitment and relocation bonuses, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/108/411/tI/s101/a/1"},"text":"Pub. L. 108–411, title I, § 101(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2305"},"text":"118 Stat. 2305","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb889ac0a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/323"},"text":"Pub. L. 114–323","children":[],"tail":" inserted “, excluding members of the Foreign Service other than chiefs of mission and ambassadors at large” before semicolon at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb889ac0b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb889ac0c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/411/tI/s101/d"},"text":"Pub. L. 108–411, title I, § 101(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2310"},"text":"118 Stat. 2310","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/411/tI/s101/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided under paragraphs (2) and (3), this section [enacting this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5754"},"text":"section 5754 of this title","children":[],"tail":", repealing former sections 5753 and 5754 of this title, and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5305"},"text":"section 5305 of this title","children":[],"tail":"] shall take effect on the first day of the first applicable pay period beginning on or after the 180th day after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null}