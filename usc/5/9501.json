{"tag":"section","attrib":{"id":"idb926fd8a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9501"},"text":null,"children":[{"tag":"num","attrib":{"value":"9501"},"text":"§ 9501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Internal Revenue Service personnel flexibilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb926fd8b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any flexibilities provided by sections 9502 through 9510 of this chapter shall be exercised in a manner consistent with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb926fd8c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 23 (relating to merit system principles and prohibited personnel practices);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd8d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provisions relating to preference eligibles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd8e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9501/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise specifically provided, section 5307 (relating to the aggregate limitation on pay);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd8f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9501/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise specifically provided, chapter 71 (relating to labor-management relations); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9501/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subsections (b) and (c) of section 1104, as though such authorities were delegated to the Secretary of the Treasury under section 1104(a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb926fd91-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall provide the Office of Personnel Management with any information that Office requires in carrying out its responsibilities under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb926fd92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employees within a unit to which a labor organization is accorded exclusive recognition under chapter 71 shall not be subject to any flexibility provided by sections 9507 through 9510 of this chapter unless the exclusive representative and the Internal Revenue Service have entered into a written agreement which specifically provides for the exercise of that flexibility. Such written agreement may be imposed by the Federal Services Impasses Panel under section 7119.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb926fd93-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tI/s1201/a"},"text":"Pub. L. 105–206, title I, § 1201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/712"},"text":"112 Stat. 712","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
