{"tag":"section","attrib":{"id":"idb820b0bf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3503"},"text":null,"children":[{"tag":"num","attrib":{"value":"3503"},"text":"§ 3503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of functions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb820b0c0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When a function is transferred from one agency to another, each competing employee in the function shall be transferred to the receiving agency for employment in a position for which he is qualified before the receiving agency may make an appointment from another source to that position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb820b0c1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When one agency is replaced by another, each competing employee in the agency to be replaced shall be transferred to the replacing agency for employment in a position for which he is qualified before the replacing agency may make an appointment from another source to that position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb820b0c2-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/429"},"text":"80 Stat. 429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIII/s307/f"},"text":"Pub. L. 95–454, title III, § 307(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1149"},"text":"92 Stat. 1149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/18"},"text":"Pub. L. 96–54, § 2(a)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/382"},"text":"93 Stat. 382","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb820b0c3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb820b0c4-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb820b0c5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s861/a"},"text":"5 U.S.C. 861(a)","children":[],"tail":" (3d proviso)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1944-06-27/ch287/s12"},"text":"June 27, 1944, ch. 287, § 12","children":[],"tail":" (3d proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/58/390"},"text":"58 Stat. 390","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “a function” are substituted for “any or all of the functions”. The word “receiving” is substituted for “replacing” in the phrase “receiving agency” to avoid confusion with subsection (b).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the word “first” in the phrase “shall first be transferred” is omitted as redundant in view of the subsequent limitation imposed by the words following “before”. The words “make an appointment from another source to that position” are substituted for “appoint additional employees from any other source for such position”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb820b0c6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb820b0c7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" substituted “competing employee” for “preference eligible employed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" which directed the substitution of “competing employee” for “preference eligible employee” was impossible to execute literally because the text contained reference to “preference eligible employed”. See 1979 Amendment note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb820b0c8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb820b0c9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","chil