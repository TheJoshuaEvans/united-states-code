":{"href":"/us/stat/54/174"},"text":"54 Stat. 174","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-13/ch957/s1131/64"},"text":"Aug. 13, 1946, ch. 957, § 1131(64)","children":[],"tail":", 60 Stat. Stat. 1040."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(b)–(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s73b–1/f"},"text":"5 U.S.C. 73b–1(f)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 6, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/707/s321"},"text":"Pub. L. 86–707, § 321","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/797"},"text":"74 Stat. 797","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Feb. 5, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/266"},"text":"Pub. L. 88–266","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/8"},"text":"78 Stat. 8","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the proviso in former section 73c is omitted as superseded by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2634"},"text":"section 2634 of title 10","children":[],"tail":", and by former section 73b–1(f), which is carried into subsections (b)–(e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “including a new appointee and a student trainee to the extent authorized by sections 5722 and 5723 of this title” are substituted for “including any new appointee, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s73b–3"},"text":"section 73b–3 of this title","children":[],"tail":"” for clarity and reflect the codification of former section 73b–3 in this title. The words “at Government expense” are inserted for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last sentence of subsection (f) of former section 73b–1 which provided that for the purposes of that subsection and subsection (e), which is carried into section 5726, Alaska shall be considered to be outside the continental limits of the United States is omitted as unnecessary in view of the definition of “continental United States” in section 5721(4).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8873b04-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8873b05-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s403e"},"text":"Section 403e of title 50","children":[],"tail":", referred to in subsec. (f)(2), was editorially reclassified to "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3505"},"text":"section 3505 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8873b06-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/264"},"text":"Pub. L. 105–264","children":[],"tail":" substituted “continental United States” for “United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1723/b/1"},"text":"Pub. L. 104–201, § 1723(b)(1)","children":[],"tail":", in introductory provisions, substituted “Under regulations prescribed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5738"},"text":"section 5738 of this title","children":[],"tail":"” for “Under such regulations as the President may prescribe”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1715/a/2"},"text":"Pub. L. 104–201, § 1715(a)(2)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1715/a/1"},"text":"Pub. L. 104–201, § 1715(a)(1)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1715/a/3"},"text":"Pub. L. 104–201, § 1715(a)(3)","children":[],"tail":", inserted “or (c)” after “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1715/a/1"},"text":"Pub. L. 104–201, § 1715(a)(1)","children":[],"tail":", redesignated subsec. (d) as (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1715/a/1"},"text":"Pub. L. 104–201, § 1715(a)(1)","children":[],"tail":", redesignated subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403e/4"},"text":"section 403e(4) of title 50","children":[],"tail":"” for “(A) "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s1138"},"text":"section 1138 of title 22","children":[],"tail":"; or” and struck out “(B) "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s403e/4"},"text":"section 403e(4) of title 50","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8873b07-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8873b08-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1725/a"},"text":"section 1725(a) of Pub. L. 104–201","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5722"},"text":"section 5722 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8873b09-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465"},"text":"Pub. L. 96–465","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1981-02-15"},"text":"Feb. 15, 1981","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2403"},"text":"section 2403 of Pub. L. 96–465","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
