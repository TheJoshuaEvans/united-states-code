{"tag":"section","attrib":{"id":"idb7d92009-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s808"},"text":null,"children":[{"tag":"num","attrib":{"value":"808"},"text":"§ 808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective date of certain rules","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 801—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7d9200a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s808/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rule that establishes, modifies, opens, closes, or conducts a regulatory program for a commercial, recreational, or subsistence activity related to hunting, fishing, or camping, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7d9200b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s808/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rule which an agency for good cause finds (and incorporates the finding and a brief statement of reasons therefor in the rule issued) that notice and public procedure thereon are impracticable, unnecessary, or contrary to the public interest,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall take effect at such time as the Federal agency promulgating the rule determines.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7d9200c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/121/tII/s251"},"text":"Pub. L. 104–121, title II, § 251","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-29"},"text":"Mar. 29, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/874"},"text":"110 Stat. 874","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
