{"tag":"section","attrib":{"id":"idb8873b8d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739"},"text":null,"children":[{"tag":"num","attrib":{"value":"5739"},"text":"§ 5739.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for relocation expenses test programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8873b8e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8873b8f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this subchapter, under a test program which the Administrator of General Services determines to be in the interest of the Government and approves, an agency may pay through the proper disbursing official any necessary relocation expenses in lieu of any payment otherwise authorized or required under this subchapter. An agency shall include in any request to the Administrator for approval of such a test program an analysis of the expected costs and benefits and a set of criteria for evaluating the effectiveness of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any test program conducted under this section shall be designed to enhance cost savings or other efficiencies that accrue to the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8873b91-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall transmit a copy of any test program approved or extended by the Administrator under this section to the appropriate committees of the Congress at least 30 days before the effective date of the program or extension.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8873b92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8873b93-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency authorized to conduct a test program under subsection (a) shall annually submit a report on the results of the program to date to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b94-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 3 months after completion of a test program, the agency conducting the program shall submit a final report on the results of the program to the Administrator and the appropriate committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8873b95-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No more than 12 test programs under this section may be conducted simultaneously.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8873b96-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8873b97-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may not approve any test program for an initial period of more than 4 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b98-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8873b99-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the request of the agency administering a test program, the Administrator may extend the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8873b9a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An extension under subparagraph (A) may not exceed 4 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8873b9b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5739/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may exercise more than 1 extension under subparagraph (A) with respect to any test program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8873b9c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/264/s5/b"},"text":"Pub. L. 105–264, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2355"},"text":"112 Stat. 2355","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/325/s1/a"},"text":"Pub. L. 109–325, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-11"},"text":"Oct. 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1760"},"text":"120 Stat. 1760","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/112/s1/a"},"text":"Pub. L. 111–112, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-30"},"text":"Nov. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3024"},"text":"123 Stat. 3024","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8873b9d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8873b9e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8873b9f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/112/s1/a/1"},"text":"Pub. L. 111–112, § 1(a)(1)","children":[],"tail":", struck out par. (3) which read as follows: “Nothing in this section is intended to limit the authority of any agency to conduct test programs.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/112/s1/a/2"},"text":"Pub. L. 111–112, § 1(a)(2)","children":[],"tail":", inserted “or extended” after “approved” and “or extension” after “of the program”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/112/s1/a/3"},"text":"Pub. L. 111–112, § 1(a)(3)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which read as follows: “An agency authorized to conduct a test program under subsection (a) shall provide to the Administrator and the appropriate committees of the Congress a report on the results of the program no later than 3 months after completion of the program.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/112/s1/a/4"},"text":"Pub. L. 111–112, § 1(a)(4)","children":[],"tail":", substituted “12” for “10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/112/s1/a/5"},"text":"Pub. L. 111–112, § 1(a)(5)","children":[],"tail":", added subsec. (e) and struck out former subsec. (e) which read as follows: “The authority to conduct test programs under this section shall expire 11 years after the date of the enactment of the Travel and Transportation Reform Act of 1998.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/325/s1/a/1"},"text":"Pub. L. 109–325, § 1(a)(1)","children":[],"tail":", struck out “for a period not to exceed 24 months” after “disbursing official”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/325/s1/a/2"},"text":"Pub. L. 109–325, § 1(a)(2)","children":[],"tail":", substituted “11 years” for “7 years”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8873ba0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8873ba1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2009 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/112/s1/b"},"text":"Pub. L. 111–112, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-30"},"text":"Nov. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3025"},"text":"123 Stat. 3025","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/112/s1/b"},"text":"“This section [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"2009-12-18"},"text":"December 18, 2009","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8873ba2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/325/s1/b"},"text":"Pub. L. 109–325, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-11"},"text":"Oct. 11, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1760"},"text":"120 Stat. 1760","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/325/s1/b"},"text":"“The amendments made by this section [amending this section] shall take effect as though enacted as part of the Travel and Transportation Reform Act of 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/264"},"text":"Public Law 105–264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/112/2350"},"text":"112 Stat. 2350","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
