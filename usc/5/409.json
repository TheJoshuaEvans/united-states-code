l:a","attrib":{"href":"/us/stat/112/2681-792"},"text":"112 Stat. 2681–792","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/114/317/s7/d/2/E"},"text":"Pub. L. 114–317, § 7(d)(2)(E)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/130/1606"},"text":"130 Stat. 1606","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"409(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 U.S.C. App. (IGA § 8A(e))","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/452/s8A/e"},"text":"Pub. L. 95–452, § 8A(e)","children":[],"tail":", formerly (g), as added "},{"tag":"html:a","attrib":{"href":"/us/pl/97/113/tVII/s705/a/3"},"text":"Pub. L. 97–113, title VII, § 705(a)(3)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 29, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/1545"},"text":"95 Stat. 1545","children":[],"tail":"; redesignated (e), "},{"tag":"html:a","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XIV, § 1422(b)(2)(C), "},{"tag":"html:span","attrib":{},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/112/2681-792"},"text":"112 Stat. 2681–792","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the reference to “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s406/a/7"},"text":"section 406(a)(7) of this title","children":[],"tail":"” is substituted for “section 6(a)(6) of this Act” for clarity and to correct an error in the law. In the source law (section 8A(c) of the Inspector General Act of 1978), the reference to “section 6(a)(6) of this Act” is incorrect. Section 6(a)(6) of the Inspector General Act of 1978 was redesignated as section 6(a)(7) of that Act by section 107(1) of the Inspector General Act Amendments of 1988 ("},{"tag":"ref","attrib":{"href":"/us/pl/100/504"},"text":"Public Law 100–504","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2528"},"text":"102 Stat. 2528","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “overseas personnel ceilings” are substituted for “overseas personnel ceilings established under the Monitoring Overseas Direct Employment policy” to eliminate obsolete language. The Monitoring Overseas Direct Employment (MODE) policy was superseded by National Security Decision Directive No. 38 (NSDD–38) (","children":[{"tag":"date","attrib":{"date":"1982-06-02"},"text":"June 2, 1982","children":[],"tail":"). (See https://www.state.gov/m/pri/nsdd/45148.htm, last visited "},{"tag":"date","attrib":{"date":"2017-12-14"},"text":"December 14, 2017","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb79400fa-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb79400fb-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Foreign Assistance Act of 1961, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/195"},"text":"Pub. L. 87–195","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-09-04"},"text":"Sept. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/424"},"text":"75 Stat. 424","children":[],"tail":". Part I of the Act is classified generally to subchapter I (§ 2151 et seq.) of chapter 32 of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"section 2151 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
