{"tag":"section","attrib":{"id":"idb79400f1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s409"},"text":null,"children":[{"tag":"num","attrib":{"value":"409"},"text":"§ 409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special provisions concerning the Agency for International Development","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb79400f2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Agency for International Development","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As used in this chapter, the term “Agency for International Development” includes any successor agency primarily responsible for administering part I of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2151"},"text":"22 U.S.C. 2151","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79400f3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members of Foreign Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to the officers and employees provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s406/a/7"},"text":"section 406(a)(7) of this title","children":[],"tail":", members of the Foreign Service may, at the request of the Inspector General of the Agency for International Development, be assigned as employees of the Inspector General. Members of the Foreign Service so assigned shall be responsible solely to the Inspector General, and the Inspector General (or the Inspector General’s designee) shall prepare the performance evaluation reports for the members assigned as employees of the Inspector General."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79400f4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s409/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Field Offices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In establishing and staffing field offices pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s406/d"},"text":"section 406(d) of this title","children":[],"tail":", the Administrator of the Agency for International Development shall not be bound by overseas personnel ceilings."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb79400f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s409/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inspector General of the Agency for International Development shall be in addition to the officers provided for in section 624(a) of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2384/a"},"text":"22 U.S.C. 2384(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb79400f6-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/b"},"text":"Pub. L. 117–286, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4227"},"text":"136 Stat. 4227","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb79400f7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb79400f8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb79400f9-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"tex