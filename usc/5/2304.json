{"tag":"section","attrib":{"id":"idb7f840b4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2304"},"text":null,"children":[{"tag":"num","attrib":{"value":"2304"},"text":"§ 2304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited personnel practices affecting the Transportation Security Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7f840b5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, any individual holding or applying for a position within the Transportation Security Administration shall be covered by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f840b6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of section 2302(b)(1), (8), and (9);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f840b7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any provision of law implementing section 2302(b)(1), (8), or (9) by providing any right or remedy available to an employee or applicant for employment in the civil service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f840b8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rule or regulation prescribed under any provision of law referred to in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f840b9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to affect any rights, apart from those described in subsection (a), to which an individual described in subsection (a) might otherwise be entitled under law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7f840ba-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/199/tI/s109/a/2"},"text":"Pub. L. 112–199, title I, § 109(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-11-27"},"text":"Nov. 27, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1470"},"text":"126 Stat. 1470","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7f840bb-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7f840bc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7f840bd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2304 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2305"},"text":"section 2305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7f840be-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb7f840bf-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/199/tI/s109/c"},"text":"Pub. L. 112–199, title I, § 109(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-11-27"},"text":"Nov. 27, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1471"},"text":"126 Stat. 1471","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/199/tI/s109/c"},"text":"“The amendments made by this section [enacting this section and renumbering sections 2304 and 2305 of this title as sections 2305 and 2306, respectively, of this title] shall take effect on the date of enactment of this section [","children":[{"tag":"date","attrib":{"date":"2012-11-27"},"text":"Nov. 27, 2012","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
