{"tag":"section","attrib":{"id":"idb820b0dc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521"},"text":null,"children":[{"tag":"num","attrib":{"value":"3521"},"text":"§ 3521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb820b0dd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “agency” means an Executive agency as defined under section 105 (other than the Government Accountability Office); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb820b0de-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb820b0df-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means an employee as defined under section 2105 employed by an agency and an individual employed by a county committee established under section 8(b)(5) of the Soil Conservation and Domestic Allotment Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s590h/b/5"},"text":"16 U.S.C. 590h(b)(5)","children":[],"tail":") who—"}],"tail":null},{"tag":"clause","attrib":{"id":"idb820b0e0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving under an appointment without time limitation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb820b0e1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been currently employed for a continuous period of at least 3 years; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb820b0e2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb820b0e3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reemployed annuitant under subchapter III of chapter 83 or 84 or another retirement system for employees of the Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb820b0e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee having a disability on the basis of which such employee is or would be eligible for disability retirement under subchapter III of chapter 83 or 84 or another retirement system for employees of the Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb820b0e5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee who is in receipt of a decision notice of involuntary separation for misconduct or unacceptable performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb820b0e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee who has previously received any voluntary separation incentive payment from the Federal Government under this subchapter or any other authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb820b0e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee covered by statutory reemployment rights who is on transfer employment with another organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb820b0e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/2/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any employee who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb820b0e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/2/B/vi/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 36-month period preceding the date of separation of that employee, performed service for which a student loan repayment benefit was or is to be paid under section 5379;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb820b0ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/2/B/vi/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 24-month period preceding the date of separation of that employee, performed service for which a recruitment or relocation bonus was or is to be paid under section 5753; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb820b0eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3521/2/B/vi/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 12-month period preceding the date of separation of that employee, performed service for which a retention bonus was or is to be paid under section 5754.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb820b0ec-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1313/a/1/A"},"text":"Pub. L. 107–296, title XIII, § 1313(a)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2291"},"text":"116 Stat. 2291","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/dG/tI/s1401/b"},"text":"Pub. L. 112–74, div. G, title I, § 1401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-23"},"text":"Dec. 23, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1134"},"text":"125 Stat. 1134","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb820b0ed-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb820b0ee-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb820b0ef-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74"},"text":"Pub. L. 112–74","children":[],"tail":" substituted “section 105 (other than the Government Accountability Office)” for “section 105”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb820b0f0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb820b0f1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/74"},"text":"Pub. L. 112–74","children":[],"tail":" applicable to voluntary separation incentive payments made during fiscal year 2012 or any succeeding fiscal year, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/74/s1401/c"},"text":"section 1401(c) of Pub. L. 112–74","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s4505"},"text":"section 4505 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb820b0f2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1313/a/4"},"text":"Pub. L. 107–296, title XIII, § 1313(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2294"},"text":"116 Stat. 2294","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/296/tXIII/s1313/a/4"},"text":"“This subsection [enacting this subchapter and provisions set out as notes under this section] shall take effect 60 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb820b0f3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Smithsonian Institution Employees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/72/s5"},"text":"Pub. L. 108–72, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-08-15"},"text":"Aug. 15, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/889"},"text":"117 Stat. 889","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/72/s5"},"text":"“The Secretary of the Smithsonian Institution may establish a program for making voluntary separation incentive payments for employees of the Smithsonian Institution which is substantially similar to the program established under subchapter II of chapter 35 of title 5, United States Code (as added by section 1313(a) of the Homeland Security Act of 2002 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":"]).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb820b0f4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Judicial Branch Employees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1313/a/2"},"text":"Pub. L. 107–296, title XIII, § 1313(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2294"},"text":"116 Stat. 2294","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/296/tXIII/s1313/a/2"},"text":"“The Director of the Administrative Office of the United States Courts may, by regulation, establish a program substantially similar to the program established under paragraph (1) [enacting this subchapter] for individuals serving in the judicial branch.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb820b0f5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continuation of Other Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1313/a/3"},"text":"Pub. L. 107–296, title XIII, § 1313(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2294"},"text":"116 Stat. 2294","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/296/tXIII/s1313/a/3"},"text":"“Any agency exercising any voluntary separation incentive authority in effect on the effective date of this subsection [see Effective Date note above] may continue to offer voluntary separation incentives consistent with that authority until that authority expires.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb820b0f6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sense of Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1313/c"},"text":"Pub. L. 107–296, title XIII, § 1313(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2296"},"text":"116 Stat. 2296","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/296/tXIII/s1313/c"},"text":"“It is the sense of Congress that the implementation of this section [enacting this subchapter, amending sections 8336 and 8414 of this title, enacting provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8336"},"text":"section 8336 of this title","children":[],"tail":", and repealing provisions set out as notes under sections 8336 and 8414 of this title] is intended to reshape the Federal workforce and not downsize the Federal workforce.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
