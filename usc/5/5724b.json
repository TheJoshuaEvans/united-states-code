s already authorized to be appropriated for such agencies, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/151/s118/b"},"text":"section 118(b) of Pub. L. 98–151","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5724"},"text":"section 5724 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
