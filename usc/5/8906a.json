{"tag":"section","attrib":{"id":"idb91fd18a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8906a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8906a"},"text":"§ 8906a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91fd18b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8906a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91fd18c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8906a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall prescribe regulations to provide for offering health benefits plans to temporary employees (who meet the requirements of paragraph (2)) under the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91fd18d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8906a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To be eligible to participate in a health benefits plan offered under this section a temporary employee shall have completed 1 year of current continuous employment, excluding any break in service of 5 days or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91fd18e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8906a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding the provisions of section 8906—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91fd18f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8906a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any temporary employee enrolled in a health benefits plan under this section shall have an amount withheld from the pay of such employee, as determined by the Office of Personnel Management, equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb91fd190-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8906a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount withheld from the pay of an employee under the provisions of section 8906; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb91fd191-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8906a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the Government contribution for an employee under section 8906; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91fd192-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8906a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employing agency of any such temporary employee shall not pay the Government contribution under the provisions of section 8906.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91fd193-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/654/tIII/s301/a"},"text":"Pub. L. 100–654, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-14"},"text":"Nov. 14, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3846"},"text":"102 Stat. 3846","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91fd194-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91fd195-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb91fd196-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/654/tIII/s301/d"},"text":"Pub. L. 100–654, title III, § 301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-14"},"text":"Nov. 14, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3847"},"text":"102 Stat. 3847","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/654/tIII/s301/d"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8913"},"text":"section 8913 of this title","children":[],"tail":"] shall be effective 120 days after the date of enactment of this section ["},{"tag":"date","attrib":{"date":"1988-11-14"},"text":"Nov. 14, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
