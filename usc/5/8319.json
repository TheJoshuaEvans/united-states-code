{"tag":"section","attrib":{"id":"idb8c79f9e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8319"},"text":null,"children":[{"tag":"num","attrib":{"value":"8319"},"text":"§ 8319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Removal of members of the uniformed services from rolls; restoration; reappointment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c79f9f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8319/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may drop from the rolls a member of a uniformed service who is deprived of retired pay under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c79fa0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8319/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President may restore—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c79fa1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8319/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" military status to an individual dropped from the rolls to whom retired pay is restored under this subchapter or under ","children":[{"tag":"ref","attrib":{"href":"/us/act/1961-09-26/s2"},"text":"section 2 of the Act of September 26, 1961","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/75/648"},"text":"75 Stat. 648","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c79fa2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8319/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all rights and privileges to the individual and his beneficiaries of which he or they were deprived because his name was dropped from the rolls.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c79fa3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8319/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the individual restored was a commissioned officer, the President alone may reappoint him to the grade and position on the retired list held when his name was dropped from the rolls.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c79fa4-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/564"},"text":"80 Stat. 564","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c79fa5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c79fa6-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c79fa7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","chi