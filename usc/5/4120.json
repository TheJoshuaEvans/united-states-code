{"tag":"section","attrib":{"id":"idb82a4d8d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4120"},"text":null,"children":[{"tag":"num","attrib":{"value":"4120"},"text":"§ 4120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training for employees of the Capitol Police","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82a4d8e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4120/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief of the Capitol Police may, by regulation, make applicable such provisions of this chapter as the Chief determines necessary to provide for training of employees of the Capitol Police. The regulations shall provide for training which, in the determination of the Chief, is consistent with the training provided by agencies under the preceding sections of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82a4d8f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4120/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall provide the Chief of the Capitol Police with such advice and assistance as the Chief may request in order to enable the Chief to carry out the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82a4d90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4120/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee of the Capitol Police may receive training under this section outside of the United States only with the prior approval of the Capitol Police Board. In this subsection, the term “United States” means each of the several States of the United States, the District of Columbia, and the territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82a4d91-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dH/tI/s1010/a"},"text":"Pub. L. 108–7, div. H, title I, § 1010(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/360"},"text":"117 Stat. 360","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/119/37/dC/tI/s118/a"},"text":"Pub. L. 119–37, div. C, title I, § 118(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/573"},"text":"139 Stat. 573","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82a4d92-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb82a4d93-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb82a4d94-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37"},"text":"Pub. L. 119–37","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82a4d95-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82a4d96-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/37/dC/tI/s118/b"},"text":"Pub. L. 119–37, div. C, title I, § 118(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-11-12"},"text":"Nov. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/573"},"text":"139 Stat. 573","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/37/dC/tI/s118/b"},"text":"“The amendment made by subsection (a) [amending this section] shall apply with respect to fiscal year 2026 and each succeeding fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
