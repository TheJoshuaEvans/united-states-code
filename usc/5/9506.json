{"tag":"section","attrib":{"id":"idb926fdc1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9506"},"text":null,"children":[{"tag":"num","attrib":{"value":"9506"},"text":"§ 9506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited appointments to career reserved Senior Executive Service positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb926fdc2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the application of section 3132, a “career reserved position” in the Internal Revenue Service means a position designated under section 3132(b) which may be filled only by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb926fdc3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a career appointee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fdc4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a limited emergency appointee or a limited term appointee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb926fdc5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9506/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, immediately upon entering the career reserved position, was serving under a career or career-conditional appointment outside the Senior Executive Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb926fdc6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9506/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose limited emergency or limited term appointment is approved in advance by the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb926fdc7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb926fdc8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of positions described under subsection (a) which are filled by an appointee as described under paragraph (2) of such subsection may not exceed 10 percent of the total number of Senior Executive Service positions in the Internal Revenue Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fdc9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding section 3132—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb926fdca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9506/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term of an appointee described under subsection (a)(2) may be for any period not to exceed 3 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb926fdcb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9506/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such an appointee may serve—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb926fdcc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9506/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two such terms; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb926fdcd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9506/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two such terms in addition to any unexpired term applicable at the time of appointment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb926fdce-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206/tI/s1201/a"},"text":"Pub. L. 105–206, title I, § 1201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/714"},"text":"112 Stat. 714","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
