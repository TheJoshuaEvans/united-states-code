{"tag":"section","attrib":{"id":"idb926fd68-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9203"},"text":null,"children":[{"tag":"num","attrib":{"value":"9203"},"text":"§ 9203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency policies; complaint procedures","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director of the Office of Personnel Management shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb926fd69-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9203/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop, implement, and publish a policy to assist employees of agencies in complying with section 9202 and the regulations issued pursuant to such section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd6a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9203/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and publish procedures under which an applicant for an appointment to a position in the civil service may submit a complaint, or any other information, relating to compliance by an employee of an agency with section 9202.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb926fd6b-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI/s1122/a"},"text":"Pub. L. 116–92, div. A, title XI, § 1122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1606"},"text":"133 Stat. 1606","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
