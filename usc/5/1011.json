{"tag":"section","attrib":{"id":"idb7de027e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1011"},"text":null,"children":[{"tag":"num","attrib":{"value":"1011"},"text":"§ 1011.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fiscal and administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7de027f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1011/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each agency shall keep records that fully disclose the disposition of any funds which may be at the disposal of its advisory committees and the nature and extent of their activities. The General Services Administration, or such other agency as the President may designate, shall maintain financial records with respect to Presidential advisory committees. The Comptroller General of the United States, or any authorized representative of the Comptroller General, shall have access to the records for the purpose of audit and examination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7de0280-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1011/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each agency shall be responsible for providing support services for each advisory committee established by or reporting to it unless the establishing authority provides otherwise. If an advisory committee reports to more than one agency, only one agency at a time shall be responsible for support services. In the case of Presidential advisory committees, support services may be provided by the General Services Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7de0281-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/a"},"text":"Pub. L. 117–286, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4203"},"text":"136 Stat. 4203","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7de0282-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7de0283-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7de0284-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},