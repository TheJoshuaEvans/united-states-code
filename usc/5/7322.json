{"tag":"section","attrib":{"id":"idb8b21ba5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7322"},"text":null,"children":[{"tag":"num","attrib":{"value":"7322"},"text":"§ 7322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b21ba6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7322/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee” means any individual, other than the President and the Vice President, employed or holding office in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b21ba7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7322/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive agency other than the Government Accountability Office; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b21ba8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7322/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position within the competitive service which is not in an Executive agency;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include a member of the uniformed services or an individual employed or holding office in the government of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21ba9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7322/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “partisan political office” means any office for which any candidate is nominated or elected as representing a party any of whose candidates for Presidential elector received votes in the last preceding election at which Presidential electors were selected, but shall exclude any office or position within a political party or affiliated organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21baa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7322/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “political contribution”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b21bab-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7322/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means any gift, subscription, loan, advance, or deposit of money or anything of value, made for any political purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b21bac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7322/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any contract, promise, or agreement, express or implied, whether or not legally enforceable, to make a contribution for any political purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b21bad-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7322/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any payment by any person, other than a candidate or a political party or affiliated organization, of compensation for the personal services of another person which are rendered to any candidate or political party or affiliated organization without charge for any political purpose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b21bae-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7322/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the provision of personal services for any political purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b21baf-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/94/s2/a"},"text":"Pub. L. 103–94, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-06"},"text":"Oct. 6, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1001"},"text":"107 Stat. 1001","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/230/s3/e"},"text":"Pub. L. 112–230, § 3(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-28"},"text":"Dec. 28, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1617"},"text":"126 Stat. 1617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b21bb0-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b21bb1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8b21bb2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7322, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/525"},"text":"80 Stat. 525","children":[],"tail":", prohibited employees in Executive agencies or competitive service from using official authority or influence to coerce political actions of persons or bodies, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/94"},"text":"Pub. L. 103–94","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8b21bb3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/230/s3/e/4"},"text":"Pub. L. 112–230, § 3(e)(4)","children":[],"tail":", substituted “services or an individual employed or holding office in the government of the District of Columbia;” for “services;” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/230/s3/e/1"},"text":"Pub. L. 112–230, § 3(e)(1)","children":[],"tail":"–(3), inserted “or” at end of subpar. (A), struck out “or” at end of subpar. (B), and struck out subpar. (C) which read as follows: “the government of the District of Columbia, other than the Mayor or a member of the City Council or the Recorder of Deeds;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b21bb4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b21bb5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/230"},"text":"Pub. L. 112–230","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"2012-12-28"},"text":"Dec. 28, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/230/s5/a"},"text":"section 5(a) of Pub. L. 112–230","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1501"},"text":"section 1501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
