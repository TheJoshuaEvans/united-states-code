{"tag":"section","attrib":{"id":"idb88e6666-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5927"},"text":null,"children":[{"tag":"num","attrib":{"value":"5927"},"text":"§ 5927.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advances of pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb88e6667-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5927/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Up to three months’ pay may be paid in advance—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb88e6668-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5927/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an employee upon the assignment of the employee to a post in a foreign area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb88e6669-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5927/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to an employee, other than an employee appointed under section 303 of the Foreign Service Act of 1980 (and employed under section 311 of such Act), who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb88e666a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5927/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a citizen of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb88e666b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5927/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is officially stationed or located outside the United States pursuant to Government authorization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb88e666c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5927/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires (or has a family member who requires) medical treatment outside the United States, in circumstances specified by the President in regulations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb88e666d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5927/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to an employee compensated pursuant to section 408 of the Foreign Service Act of 1980, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb88e666e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5927/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to United States Government authorization is located outside the country of employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb88e666f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5927/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires medical treatment outside the country of employment in circumstances specified by the President in regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb88e6670-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5927/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, the term “country of employment”, as used with respect to an individual under subsection (a)(3), means the country (or other area) outside the United States where such individual is hired (as described in subsection (a)(3)) by the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb88e6671-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/465/tII/s2310/a"},"text":"Pub. L. 96–465, title II, § 2310(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-17"},"text":"Oct. 17, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2166"},"text":"94 Stat. 2166","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/7/dA/tIII/s337"},"text":"Pub. L. 106–113, div. B, § 1000(a)(7) [div. A, title III, § 337]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–442; "},{"tag":"ref","attrib":{"href":"/us/pl/107/228/dA/tIII/s320"},"text":"Pub. L. 107–228, div. A, title III, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1380"},"text":"116 Stat. 1380","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb88e6672-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb88e6673-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb88e6674-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 303, 311, and 408 of the Foreign Service Act of 1980, referred to in subsec. (a)(2), (3), are classified to sections 3943, 3951, and 3968, respectively, of Title 22, Foreign Relations and Intercourse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb88e6675-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s320/1"},"text":"Pub. L. 107–228, § 320(1)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “to a foreign national employee appointed under section 303 of the Foreign Service Act of 1980, or a nonfamily member United States citizen appointed under such section 303 (and employed under section 311 of such Act) for service at such nonfamily member’s post of residence, who—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) is located outside the country of employment of such foreign national employee or nonfamily member (as the case may be) pursuant to Government authorization; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) requires medical treatment outside the country of employment of such foreign national employee or nonfamily member (as the case may be), in circumstances specified by the President in regulations.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/228/s320/2"},"text":"Pub. L. 107–228, § 320(2)","children":[],"tail":", substituted “hired” for “appointed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows: “Up to three months’ pay may be paid in advance to an employee upon the assignment of the employee to a post in a foreign area.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb88e6676-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb88e6677-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1981-02-15"},"text":"Feb. 15, 1981","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/465/s2403"},"text":"section 2403 of Pub. L. 96–465","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3901"},"text":"section 3901 of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
