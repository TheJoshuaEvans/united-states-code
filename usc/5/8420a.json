{"tag":"section","attrib":{"id":"idb8f9ab97-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8420a"},"text":"§ 8420a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative forms of annuities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8f9ab98-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall prescribe regulations under which any employee or Member who has a life-threatening affliction or other critical medical condition may, at the time of retiring under this subchapter, elect annuity benefits under this section instead of any other benefits under this subchapter, and any benefits under subchapter IV of this chapter, based on the service of the employee or Member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f9ab99-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsection (c), the Office shall by regulation provide for such alternative forms of annuities as the Office considers appropriate, except that among the alternatives offered shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f9ab9a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an alternative which provides for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f9ab9b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of the lump-sum credit (excluding interest) to the employee or Member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f9ab9c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of an annuity to the employee or Member for life; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f9ab9d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an employee or Member who is married at the time of retirement, an alternative which provides for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f9ab9e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of the lump-sum credit (excluding interest) to the employee or Member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f9ab9f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of an annuity to the employee or Member for life, with a survivor annuity payable for the life of a surviving spouse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f9aba0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each alternative provided for under subsection (b) shall, to the extent practicable, be designed such that the present value of the benefits provided under such alternative (including any lump-sum credit) is actuarially equivalent to the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f9aba1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present value of the annuity which would otherwise be provided under this subchapter, as computed under section 8415; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f9aba2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the present value of the annuity supplement which would otherwise be provided (if any) under section 8421.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f9aba3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee or Member who, at the time of retiring under this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f9aba4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is married, shall be ineligible to make an election under this section unless a waiver is made under section 8416(a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f9aba5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a former spouse, shall be ineligible to make an election under this section if the former spouse is entitled to benefits under section 8445 or 8467 (based on the service of the employee or Member) under the terms of a decree of divorce or annulment, or a court order or court-approved property settlement incident to any such decree, with respect to which the Office has been duly notified.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f9aba6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8420a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee or Member who is married at the time of retiring under this subchapter and who makes an election under this section may, during the 18-month period beginning on the date of retirement, make the election provided for under section 8416(d), subject to the deposit requirement thereunder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8f9aba7-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/532"},"text":"100 Stat. 532","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVII/s7001/a/1"},"text":"Pub. L. 101–508, title VII, § 7001(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-327"},"text":"104 Stat. 1388–327","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/tXI/s11002/a"},"text":"Pub. L. 103–66, title XI, § 11002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-10"},"text":"Aug. 10, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/409"},"text":"107 Stat. 409","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8f9aba8-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8f9aba9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8f9abaa-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s11002/a/1"},"text":"Pub. L. 103–66, § 11002(a)(1)","children":[],"tail":", substituted “any employee or Member who has a life-threatening affliction or other critical medical condition” for “an employee or Member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66/s11002/a/2"},"text":"Pub. L. 103–66, § 11002(a)(2)","children":[],"tail":", struck out subsec. (f) which prohibited election of alternative form of annuity where commencement date would be after "},{"tag":"date","attrib":{"date":"1990-12-01"},"text":"Dec. 1, 1990","children":[],"tail":", with certain exceptions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8f9abab-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8f9abac-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/66"},"text":"Pub. L. 103–66","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-10-01"},"text":"Oct. 1, 1994","children":[],"tail":", and applicable with respect to any annuity commencing on or after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/66/s11002/d"},"text":"section 11002(d) of Pub. L. 103–66","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8343a"},"text":"section 8343a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8f9abad-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of Sections 8343a(f) and 8420a(f) to Individuals Called to or Performing Duty in Connection With Operation Desert Shield","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to application of subsec. (f) of this section to certain members of Armed Forces who were called or ordered to active duty in connection with Operation Desert Shield and to certain employees of Department of Defense who are certified to have performed duties essential for support of Operation Desert Shield, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508/s7001/a/4"},"text":"section 7001(a)(4) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8343a"},"text":"section 8343a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8f9abae-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Partial Deferred Payment of Lump-Sum Credit for Certain Individuals Electing Alternative Forms of Annuities","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions relating to deferred payment of lump-sum credit for certain individuals electing alternative forms of annuities, see notes set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8343a"},"text":"section 8343a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
