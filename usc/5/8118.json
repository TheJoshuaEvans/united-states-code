break in time unless controverted under regulations of the Secretary;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416"},"text":"Pub. L. 93–416","children":[],"tail":" inserted in section catchline the reference to continuation of pay, added subsecs. (a), (b), (d) and (e), designated existing provisions as subsec. (c), and in subsec. (c) as so designated, substituted “until termination of pay as set forth in subsections (a) and (b) or the use of annual or sick leave ends” for “until the use of the annual or sick leave ends”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c07392-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8c07393-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s28/b"},"text":"Pub. L. 93–416, § 28(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1151"},"text":"88 Stat. 1151","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/416/s28/b"},"text":"“Section 11 of this Act [amending this section] shall become effective 60 days from enactment [","children":[{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":"] and be applicable to any injury occurring on or after such effective date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
