{"tag":"section","attrib":{"id":"idb8c07383-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8118"},"text":null,"children":[{"tag":"num","attrib":{"value":"8118"},"text":"§ 8118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Continuation of pay; election to use annual or sick leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c07384-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States shall authorize the continuation of pay of an employee, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101/1"},"text":"section 8101(1) of this title","children":[],"tail":" (other than those referred to in clause (B) or (E)), who has filed a claim for a period of wage loss due to a traumatic injury with his immediate superior on a form approved by the Secretary of Labor within the time specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8122/a/2"},"text":"section 8122(a)(2) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c07385-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Continuation of pay under this subchapter shall be furnished—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c07386-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8118/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without a break in time, except as provided under section 8117(b), unless controverted under regulations of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c07387-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8118/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period not to exceed 45 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c07388-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8118/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under accounting procedures and such other regulations as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c07389-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8118/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee may use annual or sick leave to his credit at the time the disability begins, but his compensation for disability does not begin, and the time periods specified by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8117"},"text":"section 8117 of this title","children":[],"tail":" do not begin to run, until termination of pay as set forth in subsections (a) and (b) or the use of annual or sick leave ends."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c0738a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8118/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a claim under subsection (a) is denied by the Secretary, payments under this section shall, at the option of the employee, be charged to sick or annual leave or shall be deemed overpayments of pay within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5584"},"text":"section 5584 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c0738b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8118/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payments under this section shall not be considered as compensation as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101/12"},"text":"section 8101(12) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c0738c-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/543"},"text":"80 Stat. 543","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s11"},"text":"Pub. L. 93–416, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1145"},"text":"88 Stat. 1145","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tIX/s901/b"},"text":"Pub. L. 109–435, title IX, § 901(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3254"},"text":"120 Stat. 3254","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c0738d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c0738e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c0738f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"child