{"tag":"section","attrib":{"id":"idb81bf631-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3376"},"text":null,"children":[{"tag":"num","attrib":{"value":"3376"},"text":"§ 3376.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The President may prescribe regulations for the administration of this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb81bf632-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/648/tIV/s402/a"},"text":"Pub. L. 91–648, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-01-05"},"text":"Jan. 5, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1925"},"text":"84 Stat. 1925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb81bf633-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb81bf634-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb81bf635-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective sixty days after ","children":[{"tag":"date","attrib":{"date":"1971-01-05"},"text":"Jan. 5, 1971","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/91/648/s404"},"text":"section 404 of Pub. L. 91–648","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3371"},"text":"section 3371 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb81bf636-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb81bf637-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 11589. Delegation of Functions to Office of Personnel Management","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 11589, ","children":[{"tag":"date","attrib":{"date":"1971-04-01"},"text":"Apr. 1, 1971","children":[],"tail":", 36 F.R. 6343, as amended by Ex. Ord. No. 12107, "},{"tag":"date","attrib":{"date":"1978-12-28"},"text":"Dec. 28, 1978","children":[],"tail":", 44 F.R. 1055, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By virtue of the authority vested in me by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":" of the United States Code, and as President of the United States, it is ordered as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. The Office of Personnel Management is hereby designated and empowered to exercise, without the approval, ratification, or other action of the President, the following:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(a) The authority of the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3376"},"text":"section 3376 of title 5","children":[],"tail":" of the United States Code [this section] to prescribe regulations for the administration of subchapter VI, “Assignments to and from States,” of chapter 33 of that title [this chapter]."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) The authority of the President under section 205 (a)(4) of the Federal Civil Defense Act of 1950, as amended ([former] 50 U.S.C. App. 2286(a)(4)), and as affected by Reorganization Plan No. 1 of 1958 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/72/1799"},"text":"72 Stat. 1799","children":[],"tail":") [set out in the Appendix to this title], relating to the establishment and maintenance of personnel standards on the merit basis."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. To the extent that section 1(b) of this order is inconsistent with the provisions of Executive Order No. 10952 of "},{"tag":"date","attrib":{"date":"1961-07-20"},"text":"July 20, 1961","children":[],"tail":", as amended, section 1(b) shall control."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
