{"tag":"section","attrib":{"id":"idb81258fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3321"},"text":null,"children":[{"tag":"num","attrib":{"value":"3321"},"text":"§ 3321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive service; probationary period","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb81258fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President may take such action, including the issuance of rules, regulations, and directives, as shall provide as nearly as conditions of good administration warrant for a period of probation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81258fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3321/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before an appointment in the competitive service becomes final; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81258fe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3321/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before initial appointment as a supervisor or manager becomes final.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81258ff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8125900-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has been transferred, assigned, or promoted from a position to a supervisory or managerial position, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8125901-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who does not satisfactorily complete the probationary period under subsection (a)(2) of this section,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be returned to a position of no lower grade and pay than the position from which the individual was transferred, assigned, or promoted. Nothing in this section prohibits an agency from taking an action against an individual serving a probationary period under subsection (a)(2) of this section for cause unrelated to supervisory or managerial performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8125902-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (a) and (b) of this section shall not apply with respect to appointments in the Senior Executive Service or the Federal Bureau of Investigation and Drug Enforcement Administration Senior Executive Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8125903-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/422"},"text":"80 Stat. 422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us