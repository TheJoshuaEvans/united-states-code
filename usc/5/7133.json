{"tag":"section","attrib":{"id":"idb8ad5fe3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7133"},"text":null,"children":[{"tag":"num","attrib":{"value":"7133"},"text":"§ 7133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compilation and publication of data","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8ad5fe4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Authority shall maintain a file of its proceedings and copies of all available agreements and arbitration decisions, and shall publish the texts of its decisions and the actions taken by the Panel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7119"},"text":"section 7119 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8ad5fe5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All files maintained under subsection (a) of this section shall be open to inspection and reproduction in accordance with the provisions of sections 552 and 552a of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8ad5fe6-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVII/s701"},"text":"Pub. L. 95–454, title VII, § 701","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1215"},"text":"92 Stat. 1215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8ad5fe7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topi