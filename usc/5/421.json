],"tail":", "},{"tag":"html:span","attrib":{},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/130/1604"},"text":"130 Stat. 1604","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb79fe872-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb79fe873-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Atomic Energy Act of 1954, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-01/ch724"},"text":"act Aug. 1, 1946, ch. 724","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/act/1954-08-30/ch1073/s1"},"text":"act Aug. 30, 1954, ch. 1073, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/919"},"text":"68 Stat. 919","children":[],"tail":". Chapter 12 of the Act is classified generally to subchapter XI (§ 2161 et seq.) of chapter 23 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2011"},"text":"section 2011 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
