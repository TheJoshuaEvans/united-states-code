{"tag":"section","attrib":{"id":"idb8f761c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414"},"text":null,"children":[{"tag":"num","attrib":{"value":"8414"},"text":"§ 8414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Early retirement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8f761c4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f761c5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Senior Executive Service who is removed from the Senior Executive Service for less than fully successful executive performance (as determined under subchapter II of chapter 43 of this title) after completing 25 years of service, or after becoming 50 years of age and completing 20 years of service, is entitled to an annuity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761c6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Defense Intelligence Senior Executive Service or the Senior Cryptologic Executive Service who is removed from such service for failure to be recertified as a senior executive or for less than fully successful executive performance after completing 25 years of service, or after becoming 50 years of age and completing 20 years of service, is entitled to an annuity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Federal Bureau of Investigation and Drug Enforcement Administration Senior Executive Service who is removed from such service for failure to be recertified as a senior executive or for less than fully successful executive performance after completing 25 years of service or after becoming 50 years of age and completing 20 years of service is entitled to an annuity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f761c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f761c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraphs (2) and (3), an employee who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f761ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is separated from the service involuntarily, except by removal for cause on charges of misconduct or delinquency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f761cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8f761cc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been employed continuously, by the agency in which the employee is serving, for at least the 31-day period ending on the date on which such agency requests the determination referred to in clause (iv);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f761cd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving under an appointment that is not time limited;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f761ce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been duly notified that such employee is to be involuntarily separated for misconduct or unacceptable performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f761cf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is separate ","children":[{"tag":"ref","attrib":{"idref":"fn002176"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002176"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “separated”."}],"tail":" from the service voluntarily during a period in which, as determined by the Office of Personnel Management (upon request of the agency) under regulations prescribed by the Office—"}],"tail":null},{"tag":"subclause","attrib":{"id":"idb8f761d0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such agency (or, if applicable, the component in which the employee is serving) is undergoing substantial delayering, substantial reorganization, substantial reductions in force, substantial transfer of function, or other substantial workforce restructuring (or shaping);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8f761d1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a significant percentage of employees serving in such agency (or component) are likely to be separated or subject to an immediate reduction in the rate of basic pay (without regard to subchapter VI of chapter 53, or comparable provisions); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8f761d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B/iv/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identified as being in positions which are becoming surplus or excess to the agency’s future ability to carry out its mission effectively; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f761d3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as determined by the agency under regulations prescribed by the Office, is within the scope of the offer of voluntary early retirement, which may be made on the basis of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb8f761d4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B/v/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more organizational units;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8f761d5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B/v/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more occupational series or levels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8f761d6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B/v/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 or more geographical locations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8f761d7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B/v/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific periods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8f761d8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B/v/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" skills, knowledge, or other factors related to a position; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb8f761d9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/1/B/v/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any appropriate combination of such factors.","children":[{"tag":"ref","attrib":{"idref":"fn002177"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002177"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be a semicolon."}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"after completing 25 years of service, or after becoming 50 years of age and completing 20 years of service, is entitled to an annuity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761da-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee under paragraph (1) who is separated as described in subparagraph (A) of such paragraph is not entitled to an annuity under this subsection if the employee has declined a reasonable offer of another position in the employee’s agency for which the employee is qualified, and the offered position is not lower than 2 grades (or pay levels) below the employee’s grade (or pay level) and is within the employee’s commuting area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761db-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) shall not apply to an employee entitled to an annuity under subsection (d)(1) or (e) of section 8412.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f761dc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f761dd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee who was hired as a military reserve technician on or before ","children":[{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":" (under the provisions of this title in effect before that date), and who is separated from technician service, after becoming 50 years of age and completing 25 years of service, by reason of being separated from the Selected Reserve of the employee’s reserve component or ceasing to hold the military grade specified by the Secretary concerned for the position held by the employee is entitled to an annuity."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761de-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee who is initially hired as a military technician (dual status) after ","children":[{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":", and who is separated from the Selected Reserve or ceases to hold the military grade specified by the Secretary concerned for the position held by the technician—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f761df-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after completing 25 years of service as a military technician (dual status), or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f761e0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after becoming 50 years of age and completing 20 years of service as a military technician (dual status),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is entitled to an annuity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8f761e1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8f761e2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Defense may, during fiscal years 2002 and 2003, carry out a program under which an employee of the Department of Defense may be separated from the service entitled to an immediate annuity under this subchapter if the employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f761e3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8f761e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completed 25 years of service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f761e5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" become 50 years of age and completed 20 years of service; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f761e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is eligible for the annuity under paragraph (2) or (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f761e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of paragraph (1), an employee referred to in that paragraph is eligible for an immediate annuity under this paragraph if the employee—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8f761e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is separated from the service involuntarily other than for cause; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f761ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not declined a reasonable offer of another position in the Department of Defense for which the employee is qualified, which is not lower than 2 grades (or pay levels) below the employee’s grade (or pay level), and which is within the employee’s commuting area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f761eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of paragraph (2)(A)(i), a separation for failure to accept a directed reassignment to a position outside the commuting area of the employee concerned or to accompany a position outside of such area pursuant to a transfer of function may not be considered to be a removal for cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761ec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of paragraph (1), an employee referred to in that paragraph is eligible for an immediate annuity under this paragraph if the employee satisfies all of the following conditions:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f761ed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee is separated from the service voluntarily during a period in which the organization within the Department of Defense in which the employee is serving is undergoing a major organizational adjustment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f761ee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee has been employed continuously by the Department of Defense for more than 30 days before the date on which the head of the employee’s organization requests the determinations required under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f761ef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee is serving under an appointment that is not limited by time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f761f0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employee is not in receipt of a decision notice of involuntary separation for misconduct or unacceptable performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f761f1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The employee is within the scope of an offer of voluntary early retirement, as defined on the basis of one or more of the following objective criteria:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8f761f2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/3/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One or more organizational units.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f761f3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/3/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One or more occupational groups, series, or levels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f761f4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/3/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One or more geographical locations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f761f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/3/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other similar objective and nonpersonal criteria that the Office of Personnel Management determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed by the Office of Personnel Management, the determinations of whether an employee meets—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f761f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of subparagraph (A) of paragraph (3) shall be made by the Office upon the request of the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f761f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of subparagraph (E) of such paragraph shall be made by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A determination of which employees are within the scope of an offer of early retirement shall be made only on the basis of consistent and well-documented application of the relevant criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8f761fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection, the term “major organizational adjustment” means any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8f761fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A major reorganization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f761fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A major reduction in force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f761fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A major transfer of function.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8f761fe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A workforce restructuring—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8f761ff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/6/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet mission needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f76200-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/6/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve one or more reductions in strength;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f76201-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/6/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to correct skill imbalances; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8f76202-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8414/d/6/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the number of high-grade, managerial, supervisory, or similar positions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8f76203-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/526"},"text":"100 Stat. 526","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/325/s2/m"},"text":"Pub. L. 100–325, § 2(m)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-30"},"text":"May 30, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/583"},"text":"102 Stat. 583","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/tV/s506/b/9"},"text":"Pub. L. 101–194, title V, § 506(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1759"},"text":"103 Stat. 1759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tXI/s1109/b"},"text":"Pub. L. 105–261, div. A, title XI, § 1109(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2144"},"text":"112 Stat. 2144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/58/tVI/s651/b"},"text":"Pub. L. 106–58, title VI, § 651(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-09-29"},"text":"Sept. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/480"},"text":"113 Stat. 480","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tV/s522/b"},"text":"Pub. L. 106–65, div. A, title V, § 522(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/597"},"text":"113 Stat. 597","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1152(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–321; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII"},"text":"Pub. L. 107–296, title XIII","children":[],"tail":", §§ 1313(b)(2), 1321(a)(5)(A), "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2295"},"text":"116 Stat. 2295","children":[],"tail":", 2297; "},{"tag":"ref","attrib":{"href":"/us/pl/117/225/s3/b/2/A/i"},"text":"Pub. L. 117–225, § 3(b)(2)(A)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-09"},"text":"Dec. 9, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2295"},"text":"136 Stat. 2295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8f76204-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8f76205-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8f76206-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/225"},"text":"Pub. L. 117–225","children":[],"tail":" inserted “(1)” after “subsection (d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1321/a/5/A"},"text":"Pub. L. 107–296, § 1321(a)(5)(A)","children":[],"tail":", struck out “for failure to be recertified as a senior executive under section 3393a or” before “for less than fully”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1313/b/2"},"text":"Pub. L. 107–296, § 1313(b)(2)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “except in the case of an employee who is separated from the service under a program carried out under subsection (d), while serving in a geographic area designated by the Director, is separated from the service voluntarily during a period in which (as determined by the Director)—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) the agency in which the employee is serving is undergoing a major reorganization, a major reduction in force, or a major transfer of function; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) a significant percentage of the total number of employees serving in such agency will be separated or subject to an immediate reduction in the rate of basic pay (without regard to subchapter VI of chapter 53 of this title or comparable provisions);”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1152(b)(1)], inserted “except in the case of an employee who is separated from the service under a program carried out under subsection (d),” before “while serving” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1152(b)(2)], added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/58"},"text":"Pub. L. 106–58","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/s1109/b/1"},"text":"Pub. L. 105–261, § 1109(b)(1)","children":[],"tail":". See 1998 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “A military reserve technician who is separated from technician service, after becoming 50 years of age and completing 25 years of service, by reason of ceasing to satisfy the condition described in section 8401(30)(B) is entitled to an annuity.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/58"},"text":"Pub. L. 106–58","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/s1109/b/2"},"text":"Pub. L. 105–261, § 1109(b)(2)","children":[],"tail":". See 1998 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s1109/b/1"},"text":"Pub. L. 105–261, § 1109(b)(1)","children":[],"tail":", which directed insertion of “except in the case of an employee described in subsection (d)(1),” after “(B)”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/58"},"text":"Pub. L. 106–58","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s1109/b/2"},"text":"Pub. L. 105–261, § 1109(b)(2)","children":[],"tail":", which directed addition of subsec. (d), relating to authority of Department of Defense to offer employees voluntary early retirement, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/58"},"text":"Pub. L. 106–58","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194/s506/b/9/A"},"text":"Pub. L. 101–194, § 506(b)(9)(A)","children":[],"tail":", substituted “for failure to be recertified as a senior executive under section 3393a or for” for “for”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194/s506/b/9/B"},"text":"Pub. L. 101–194, § 506(b)(9)(B)","children":[],"tail":", (C), substituted “for failure to be recertified as a senior executive or for” for “for”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/325"},"text":"Pub. L. 100–325","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8f76207-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8f76208-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/225"},"text":"Pub. L. 117–225","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2022-12-09"},"text":"Dec. 9, 2022","children":[],"tail":", and applicable to an individual who suffers an illness or injury described in certain Code provisions on or after the date that is 2 years after "},{"tag":"date","attrib":{"date":"2022-12-09"},"text":"Dec. 9, 2022","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/225/s3/f"},"text":"section 3(f) of Pub. L. 117–225","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8336"},"text":"section 8336 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8f76209-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see