{"tag":"section","attrib":{"id":"idb878e30d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5582"},"text":null,"children":[{"tag":"num","attrib":{"value":"5582"},"text":"§ 5582.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of beneficiary; order of precedence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb878e30e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5582/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The employing agency shall notify each employee of his right to designate a beneficiary or beneficiaries to receive money due, and of the disposition of money due if a beneficiary is not designated. An employee may change or revoke a designation at any time under regulations promulgated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb878e30f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5582/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Director of the Office of Personnel Management or his designee, in the case of an employee of an executive agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb878e310-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5582/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" jointly by the President pro tempore of the Senate and the Speaker of the House of Representatives, or their designee, in the case of an employee of the legislative branch; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb878e311-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5582/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the Chief Justice of the United States or his or her designee, in the case of an employee of the judicial branch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb878e312-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5582/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In order to facilitate the settlement of the accounts of deceased employees, money due an employee at the time of his death shall be paid to the person or persons surviving at the date of death, in the following order of precedence, and the payment bars recovery by another person of amounts so paid:","children":[{"tag":"p","attrib":{"role":"listItem"},"text":"First, to the beneficiary or beneficiaries designated by the employee in a writing received in the employing agency before his death.","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Second, if there is no designated beneficiary, to the widow or widower of the employee.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Third, if none of the above, to the child or children of the employee and descendants of deceased children by representation.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Fourth, if none of the above, to the parents of the employee or the survivor of them.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Fifth, if none of the above, to the duly appointed legal representative of the estate of the employee.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sixth, if none of the above, to the person or persons entitled under the laws of the domicile of the employee at the time of his death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb878e313-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/495"},"text":"80 Stat. 495","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s103/c"},"text":"Pub. L. 104–316, title I, § 103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3828"},"text":"110 Stat. 3828","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb878e314-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb878e315-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb878e316-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s61j"},"text":"5 U.S.C. 61j","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-08-03/ch518/s5"},"text":"Aug. 3, 1950, ch. 518, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/396"},"text":"64 Stat. 396","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s61f"},"text":"5 U.S.C. 61f","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-08-03/ch518/s1"},"text":"Aug. 3, 1950, ch. 518, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/395"},"text":"64 Stat. 395","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is restated for clarity. The word “officers” is omitted as included in “employee”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), so much of the first 35 words of former section 61f as states the application is carried into the definition of “employee” in section 5581(1). The word “officer” is omitted as included in “employee”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb878e317-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb878e318-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" substituted “An employee may change or revoke a designation at any time under regulations promulgated—” for “An employee may change or revoke a designation at any time under such regulations as the Comptroller General of the United States may prescribe.” in introductory provisions and added pars. (1) to (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
