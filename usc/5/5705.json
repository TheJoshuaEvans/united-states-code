{"tag":"section","attrib":{"id":"idb8800e5d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5705"},"text":null,"children":[{"tag":"num","attrib":{"value":"5705"},"text":"§ 5705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advancements and deductions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An agency may advance, through the proper disbursing official, to an employee entitled to per diem or mileage allowances under this subchapter, a sum considered advisable with regard to the character and probable duration of the travel to be performed. A sum advanced and not used for allowable travel expenses is recoverable from the employee or his estate by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8800e5e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5705/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setoff against accrued pay, retirement credit, or other amount due the employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8800e5f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5705/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deduction from an amount due from the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8800e60-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5705/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other method as is provided by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8800e61-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","at