{"tag":"section","attrib":{"id":"idb80d9e32-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3305"},"text":null,"children":[{"tag":"num","attrib":{"value":"3305"},"text":"§ 3305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Competitive service; examinations; when held","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb80d9e33-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall hold examinations for the competitive service at least twice a year in each State and territory or possession of the United States where there are individuals to be examined.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb80d9e34-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall hold an examination for a position to which an appointment has been made within the preceding 3 years, on the application of an individual who qualifies as a preference eligible under section 2108(3)(C)–(G) of this title. The examination shall be held during the quarter following the application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb80d9e35-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/418"},"text":"80 Stat. 418","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/8"},"text":"Pub. L. 90–83, § 1(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11