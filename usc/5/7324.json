{"tag":"section","attrib":{"id":"idb8b21be4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7324"},"text":null,"children":[{"tag":"num","attrib":{"value":"7324"},"text":"§ 7324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Political activities on duty; prohibition","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b21be5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee may not engage in political activity—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b21be6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7324/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while the employee is on duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21be7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7324/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any room or building occupied in the discharge of official duties by an individual employed or holding office in the Government of the United States or any agency or instrumentality thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21be8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7324/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while wearing a uniform or official insignia identifying the office or position of the employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21be9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7324/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using any vehicle owned or leased by the Government of the United States or any agency or instrumentality thereof.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b21bea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b21beb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7324/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee described in paragraph (2) of this subsection may engage in political activity otherwise prohibited by subsection (a) if the costs associated with that political activity are not paid for by money derived from the Treasury of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b21bec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7324/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) applies to an employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b21bed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7324/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duties and responsibilities of whose position continue outside normal duty hours and while away from the normal duty post; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b21bee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7324/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8b21bef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7324/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee paid from an appropriation for the Executive Office of the President; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8b21bf0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7324/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee appointed by the President, by and with the advice and consent of the Senate, whose position is located within the United States, who determines policies to be pursued by the United States in relations with foreign powers or in the nationwide administration of Federal laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b21bf1-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/94/s2/a"},"text":"Pub. L. 103–94, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-06"},"text":"Oct. 6, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1003"},"text":"107 Stat. 1003","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b21bf2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b21bf3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8b21bf4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 7324, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/525"},"text":"80 Stat. 525","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/268/s4/a"},"text":"Pub. L. 93–268, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-04-17"},"text":"Apr. 17, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/87"},"text":"88 Stat. 87","children":[],"tail":", prohibited Executive agency employees and employees of the District of Columbia from influencing elections or taking part in political campaigns, prior to the general revision of this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/94"},"text":"Pub. L. 103–94","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
