{"tag":"section","attrib":{"id":"idb87427d0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5550a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5550a"},"text":"§ 5550a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensatory time off for religious observances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb87427d1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5550a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than 30 days after the date of the enactment of this section, the Office of Personnel Management shall prescribe regulations providing for work schedules under which an employee whose personal religious beliefs require the abstention from work during certain periods of time, may elect to engage in overtime work for time lost for meeting those religious requirements. Any employee who so elects such overtime work shall be granted equal compensatory time off from his scheduled tour of duty (in lieu of overtime pay) for such religious reasons, notwithstanding any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb87427d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5550a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any agency described in subparagraphs (C) through (G) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5541/1"},"text":"section 5541(1) of this title","children":[],"tail":", the head of such agency (in lieu of the Office) shall prescribe the regulations referred to in subsection (a) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb87427d3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5550a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulations under this section may provide for such exceptions as may be necessary to efficiently carry out the mission of the agency or agencies involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb87427d4-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/390/tIV/s401/a"},"text":"Pub. L. 95–390, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-09-29"},"text":"Sept. 29, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/762"},"text":"92 Stat. 762","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/14"},"text":"Pub. L. 96–54, § 2(a)(14)","children":[],"tail":", (15), "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/382"},"text":"93 Stat. 382","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb87427d5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb87427d6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb87427d7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/390"},"text":"Pub. L. 95–390","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1978-09-29"},"text":"Sept. 29, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb87427d8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1979—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" substituted “Office of Personnel Management” for “Civil Service Commission” and “Office” for “Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb87427d9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb87427da-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1979-07-12"},"text":"July 12, 1979","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/b"},"text":"section 2(b) of Pub. L. 96–54","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s305"},"text":"section 305 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
