stat/58/845"},"text":"58 Stat. 845","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1953-07-02/ch178/s4/a"},"text":"July 2, 1953, ch. 178, § 4(a)","children":[],"tail":" (1st and 5th sentences), "},{"tag":"html:a","attrib":{"href":"/us/stat/67/137"},"text":"67 Stat. 137","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s2061a/a"},"text":"5 U.S.C. 2061a(a)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1953-07-02/ch178/s2/a"},"text":"July 2, 1953, ch. 178, § 2(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/136"},"text":"67 Stat. 136","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “An employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":"” are coextensive with and substituted for “civilian officer or employee of the Federal Government”. Reference to “section 1474 of Appendix to Title 50, is omitted in view of the repeal of that section by the "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-24/ch671/s5/a/3"},"text":"Act of July 24, 1956, ch. 671, § 5(a)(3)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/606"},"text":"70 Stat. 606","children":[],"tail":". The words “and shall not be subject to retirement deductions” are omitted and carried into section 8331(3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), reference to the limitation imposed by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-07-02/ch178/s5"},"text":"section 5 of the Act of July 2, 1953, ch. 178","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/67/138"},"text":"67 Stat. 138","children":[],"tail":", is omitted as obsolete since the limitation was eliminated by the Act of "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/914/s1"},"text":"Pub. L. 85–914, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1761"},"text":"72 Stat. 1761","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb87427f1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb87427f2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/518"},"text":"Pub. L. 106–518","children":[],"tail":" substituted “, is transferred to a position described under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6301/2/B/xiii"},"text":"section 6301(2)(B)(xiii) of this title","children":[],"tail":", or elects” for “or elects” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138"},"text":"Pub. L. 102–138","children":[],"tail":" inserted “(excluding any differential under section 5925 and any allowance under section 5928)” after “pay” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" inserted at end “For the purposes of this subsection, movement to employment described in section 2105(c) shall not be deemed separation from the service in the case of an employee whose annual leave is transferred under section 6308(b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/499"},"text":"Pub. L. 96–499","children":[],"tail":" provided that the period of leave used for calculating the lump-sum payment was not to be extended due to any holiday occurring after separation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/519"},"text":"Pub. L. 95–519","children":[],"tail":" substituted “6301(2)(x)–(xiii)” for “6301(2)(x)–(xii)” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1973—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/181"},"text":"Pub. L. 93–181","children":[],"tail":" struck out exception clause that the lump-sum payment may not exceed pay for a period of annual or vacation leave in excess of 30 days or the number of days carried over to his credit at the beginning of the leave year in which entitlement to payment occurs, whichever is greater."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/181"},"text":"Pub. L. 93–181","children":[],"tail":" struck out second exception clause that the payment is made without regard to the limitation in subsec. (a) of this section on the amount of leave compensable."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb87427f3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb87427f4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1611/b"},"text":"Pub. L. 104–201, div. A, title XVI, § 1611(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2739"},"text":"110 Stat. 2739","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tXVI/s1611/b"},"text":"“Subsection (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5551"},"text":"section 5551 of title 5","children":[],"tail":", United States Code (as added by subsection (a)), shall apply with respect to transfers described in such subsection (c) that take effect on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb87427f5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s147/b/2"},"text":"Pub. L. 102–138, title I, § 147(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/669"},"text":"105 Stat. 669","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/138/tI/s147/b/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall apply with respect to service as part of a tour of duty or extension thereof commencing on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb87427f6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" applicable with respect to any individual who, on or after "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"Jan. 1, 1987","children":[],"tail":", moves from employment in nonappropriated fund instrumentality of Department of Defense or Coast Guard, that is described in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105/c"},"text":"section 2105(c) of this title","children":[],"tail":", to employment in Department or Coast Guard, that is not described in section 2105(c), or who moves from employment in Department or Coast Guard, that is not described in section 2105(c), to employment in nonappropriated fund instrumentality of Department or Coast Guard, that is described in section 2105(c), see "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/s7202/m/1"},"text":"section 7202(m)(1) of Pub. L. 101–508","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb87427f7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/499/tIV/s402/b"},"text":"Pub. L. 96–499, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-05"},"text":"Dec. 5, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2605"},"text":"94 Stat. 2605","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/499/tIV/s402/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1980-12-05"},"text":"Dec. 5, 1980","children":[],"tail":"] and shall apply to employees separating from the service on or after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb87427f8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/519/s4"},"text":"Pub. L. 95–519, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1819"},"text":"92 Stat. 1819","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/519/s4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by the first section and section 2 of this Act [amending this section and sections 6301, 6302, and 6306 of this title] shall take effect beginning on the first day of the first applicable pay period beginning on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendment made by section 3 of this Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8339"},"text":"section 8339 of this title","children":[],"tail":"] shall apply only with respect to employees who retire or die on or after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1978-10-25"},"text":"Oct. 25, 1978","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
