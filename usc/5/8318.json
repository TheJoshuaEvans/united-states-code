"children":[],"tail":", (b)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 26, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/299/s1"},"text":"Pub. L. 87–299, § 1","children":[],"tail":" “Sec. 6(a), (b)”, "},{"tag":"html:a","attrib":{"href":"/us/stat/75/645"},"text":"75 Stat. 645","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The section is reorganized for clarity and conciseness.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3282"},"text":"section 3282 of Title 18","children":[],"tail":"” are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c79f9b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8c79f9c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this subsection, referred to in subsec. (e), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/93"},"text":"Pub. L. 104–93","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1996-01-06"},"text":"Jan. 6, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"