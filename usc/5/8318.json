{"tag":"section","attrib":{"id":"idb8c79f8d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8318"},"text":null,"children":[{"tag":"num","attrib":{"value":"8318"},"text":"§ 8318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration of annuity or retired pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c79f8e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If an individual who was convicted, before, on, or after ","children":[{"tag":"date","attrib":{"date":"1954-09-01"},"text":"September 1, 1954","children":[],"tail":", of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c79f8f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8318/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense named by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8312"},"text":"section 8312 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c79f90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8318/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offense constituting a violation of section 8314 or 8315 of this title;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is pardoned by the President, the right of the individual and his survivor or beneficiary to receive annuity or retired pay previously denied under this subchapter is restored as of the date of the pardon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c79f91-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may restore, effective as of the date he prescribes, the right to receive annuity or retired pay which is denied, before, on, or after ","children":[{"tag":"date","attrib":{"date":"1954-09-01"},"text":"September 1, 1954","children":[],"tail":", under section 8314 or 8315 of this title, to the individual and to his survivor or beneficiary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c79f92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8318/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Payment of annuity or retired pay which results from pardon or restoration by the President under subsection (a) or (b) of this section may not be made for a period before—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c79f93-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8318/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of pardon referred to by subsection (a) of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c79f94-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8318/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date of restoration referred to by subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c79f95-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8318/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Credit for a period of service covered by a refund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8316"},"text":"section 8316 of this title","children":[],"tail":" is allowed only after the amount refunded has been redeposited."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c79f96-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8318/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The spouse of an individual whose annuity or retired pay is forfeited under section 8312 or 8313 after the date of enactment of this subsection shall be eligible for spousal pension benefits if the Attorney General of the United States determines that the spouse fully cooperated with Federal authorities in the conduct of a criminal investigation and subsequent prosecution of the individual which resulted in such forfeiture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c79f97-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/563"},"text":"80 Stat. 563","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/93/tIII/s305"},"text":"Pub. L. 104–93, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-01-06"},"text":"Jan. 6, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/965"},"text":"109 Stat. 965","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c79f98-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c79f99-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c79f9a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag