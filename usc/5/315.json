{"tag":"section","attrib":{"id":"idb78a8b3f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315"},"text":null,"children":[{"tag":"num","attrib":{"value":"315"},"text":"§ 315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Committee on Data for Evidence Building","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb78a8b40-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director, or the head of an agency designated by the Director, shall establish an Advisory Committee on Data for Evidence Building (in this section referred to as the “Advisory Committee”) to review, analyze, and make recommendations on how to promote the use of Federal data for evidence building.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78a8b41-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The members of the Advisory Committee shall consist of the Chief Statistician of the United States, who shall serve as the Chair of the Advisory Committee, and other members appointed by the Director as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb78a8b42-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member who is an agency Chief Information Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b43-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member who is an agency Chief Privacy Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b44-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member who is an agency Chief Performance Officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b45-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members who are agency Chief Data Officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b46-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members who are agency Evaluation Officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b47-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Three members who are members of the Interagency Council for Statistical Policy ","children":[{"tag":"ref","attrib":{"idref":"fn002006"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Interagency Council on Statistical Policy”."}],"tail":" established under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3504/e/8"},"text":"section 3504(e)(8) of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b48-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At least 10 members who are representatives of State and local governments and nongovernmental stakeholders with expertise in government data policy, privacy, technology, transparency policy, evaluation and research methodologies, and other relevant subjects, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb78a8b49-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one shall have expertise in transparency policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb78a8b4a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one shall have expertise in privacy policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb78a8b4b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one shall have expertise in statistical data use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb78a8b4c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/b/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one shall have expertise in information management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb78a8b4d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/b/7/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one shall have expertise in information technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb78a8b4e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/b/7/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least one shall be from the research and evaluation community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78a8b4f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term of Service.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb78a8b50-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Advisory Committee shall serve for a term of 2 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b51-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any member appointed to fill a vacancy occurring before the expiration of the term for which the member’s predecessor was appointed shall be appointed only for the remainder of that term. A vacancy in the Commission shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78a8b52-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of the Advisory Committee shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78a8b53-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb78a8b54-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Director in carrying out the duties of the Director under part D of subchapter III of chapter 35 of title 44;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b55-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate and provide recommendations to the Director on how to facilitate data sharing, enable data linkage, and develop privacy enhancing techniques; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b56-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the coordination of data sharing or availability for evidence building across all agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78a8b57-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Committee shall submit to the Director and make publicly available an annual report on the activities and findings of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78a8b58-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s315/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Committee shall terminate not later than two years after the date of the first meeting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb78a8b59-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/tI/s101/a/2"},"text":"Pub. L. 115–435, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5531"},"text":"132 Stat. 5531","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb78a8b5a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb78a8b5b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb78a8b5c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/435/s403"},"text":"section 403 of Pub. L. 115–435","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
