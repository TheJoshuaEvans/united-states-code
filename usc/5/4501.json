{"tag":"section","attrib":{"id":"idb82c9870-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501"},"text":null,"children":[{"tag":"num","attrib":{"value":"4501"},"text":"§ 4501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82c9871-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82c9872-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82c9873-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Library of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82c9874-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Architect of the Capitol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82c9875-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Botanic Garden;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82c9876-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government Publishing Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82c9877-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the government of the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82c9878-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Sentencing Commission;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include—","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb82c9879-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501/1/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Tennessee Valley Authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb82c987a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501/1/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Central Bank for Cooperatives;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c987b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb82c987c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee as defined by section 2105; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb82c987d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual employed by the government of the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82c987e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Government” means the Government of the United States and the government of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82c987f-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/442"},"text":"80 Stat. 442","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tV/s503/a"},"text":"Pub. L. 95–454, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1183"},"text":"92 Stat. 1183","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXVII/s1703/b/2"},"text":"Pub. L. 97–35, title XVII, § 1703(b)(2)","children":[],"tail":", 