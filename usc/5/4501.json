il":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s2122"},"text":"5 U.S.C. 2122","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-09-01/ch1208/s303"},"text":"Sept. 1, 1954, ch. 1208, § 303","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1113"},"text":"68 Stat. 1113","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 18, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/168/s202/d"},"text":"Pub. L. 86–168, § 202(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/389"},"text":"73 Stat. 389","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1), the term “Executive agency” is coextensive with and substituted for “executive department or independent agency in the executive branch of the Government including a Government-owned or controlled corporation” in view of the definition of “Executive agency” in section 105. Application to the General Accounting Office (included in the term “Executive agency”) is based on former section 933a.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraph (2) is supplied because the definition of “employee” in section 2105 does not encompass individuals employed by the government of the District of Columbia.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Paragraph (3) is supplied for clarity and convenience.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb82c9883-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb82c9884-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/89"},"text":"Pub. L. 103–89","children":[],"tail":" amended subpar. (A) generally. Prior to amendment, subpar. (A) read as follows: “an employee as defined by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":", but does not include an employee covered by the performance management and recognition system established under chapter 54 of this title; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/474"},"text":"Pub. L. 101–474","children":[],"tail":" redesignated subpars. (C) to (H) as (B) to (G), respectively, and struck out former subpar. (B) which included Administrative Office of United States Courts within definition of “agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690"},"text":"Pub. L. 100–690","children":[],"tail":" added subpar. (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" substituted “the performance management and recognition system established under chapter 54” for “the merit pay system established under section 5402”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted “subchapter” for “chapter” in provision preceding par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" inserted reference to an employee covered by merit pay system established under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5402"},"text":"section 5402 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82c9885-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb82c9886-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” in par. (1)(E) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82c9887-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/89"},"text":"Pub. L. 103–89","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-11-01"},"text":"Nov. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/89/s3/c"},"text":"section 3(c) of Pub. L. 103–89","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3372"},"text":"section 3372 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82c9888-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615/s205"},"text":"Section 205 of Pub. L. 98–615","children":[],"tail":" provided that amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" was effective "},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"Oct. 1, 1984","children":[],"tail":", and applicable with respect to pay periods commencing on or after that date, with certain exceptions and qualifications."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82c9889-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1981 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXVII/s1703/c"},"text":"Pub. L. 97–35, title XVII, § 1703(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/756"},"text":"95 Stat. 756","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/35/tXVII/s1703/c"},"text":"“The amendments made by this section [enacting subchapter II of this chapter, designating this section and sections 4502 to 4507 of this title as subchapter I, and amending this section and sections 4502, 4505, and 4506 of this title] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1981-10-01"},"text":"October 1, 1981","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82c988a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tV/s504/a"},"text":"Pub. L. 95–454, title V, § 504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1184"},"text":"92 Stat. 1184","children":[],"tail":", provided that amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" was effective on first day of first applicable pay period which began on or after "},{"tag":"date","attrib":{"date":"1981-10-01"},"text":"Oct. 1, 1981","children":[],"tail":", except it could take effect with respect to any category or categories of positions before such day to extent prescribed by Director of Office of Personnel Management."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb82c988b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb82c988c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 12976. Compensation Practices of Government Corporations","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 12976, ","children":[{"tag":"date","attrib":{"date":"1995-10-05"},"text":"Oct. 5, 1995","children":[],"tail":", 60 F.R. 52829, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By the authority vested in me as President by the Constitution and the laws of the United States of America, including ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of title 3","children":[],"tail":", United States Code, and sections 1105, 1108, and 1111 of title 31, United States Code, it is hereby ordered as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 1. "},{"tag":"i","attrib":{},"text":"Statement of Presidential Principles.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Government corporations subject to this order should not pay bonuses in excess of those authorized by sections 4501 through 4507 of title 5, United States Code, except as otherwise specifically provided by law.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 2. "},{"tag":"i","attrib":{},"text":"Administration Review","children":[],"tail":". (a) Before taking action to approve any bonus in excess of those authorized in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s4502"},"text":"section 4502 of title 5","children":[],"tail":", United States Code, each corporation subject to this section (as provided in section 6 of this order) shall submit information to the Director of the Office of Management and Budget (OMB) relating to such bonuses as provided in subsection (b). Such corporation shall refrain from approving any such bonus until the Director of OMB has had an opportunity to review the information provided by the corporation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) The Director of OMB shall issue instructions to the corporations subject to this section specifying when information is to be submitted, and the content and form of such information.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 3. "},{"tag":"i","attrib":{},"text":"Information Reporting Requirements","children":[],"tail":". (a) Government corporations subject to this order will provide information to the Director of OMB relating to the compensation practices for senior executives of such corporations as provided in subsection (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(b) Information submitted shall include the following with respect to senior executives of each corporation subject to this section:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) the compensation plan, procedures, and structure of such corporation;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) base salary levels, annual bonuses, and other compensation; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(3) information supporting the senior executive compensation plan and levels.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(c) The Director of OMB shall issue instructions to the corporations subject to this section specifying when information is to be submitted, and the content and form of such information.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 4. "},{"tag":"i","attrib":{},"text":"Review","children":[],"tail":". (a) OMB, in consultation with the Department of Labor, will review the information submitted pursuant to section 3, taking into consideration:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) consistency with statutory requirements;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) consistency with corporate mission;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(3) standards of Federal management and efficiency; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(4) equivalent private sector compensation practices.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 5. "},{"tag":"i","attrib":{},"text":"Public Dissemination Requirement","children":[],"tail":". Government corporations subject to this order shall make available through public dissemination the information submitted pursuant to section 3 of this order."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 6. "},{"tag":"i","attrib":{},"text":"Coverage","children":[],"tail":". This order will apply to all mixed-ownership and wholly owned corporations listed in section 9101(2) and (3) of title 31, United States Code. Section 2 shall apply only to wholly owned corporations except such corporations that have specific authority to approve bonuses in excess of those authorized under sections 4501 through 4507 of title 5, United States Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 7. "},{"tag":"i","attrib":{},"text":"Administration","children":[],"tail":". All corporations subject to this order shall provide any information in the manner and form, and at the time, requested pursuant to this order by the Director of OMB."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"Sec","children":[],"tail":". 8. This order is intended only to improve the internal management of the executive branch and is not intended to create any right or benefit, substantive or procedural, enforceable at law by a party against the United States, its agencies, its officers, or any other person."}],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"William J. Clinton.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
