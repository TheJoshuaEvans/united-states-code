{"tag":"section","attrib":{"id":"idb863865b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5408"},"text":null,"children":[{"tag":"num","attrib":{"value":"5408"},"text":"§ 5408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appropriations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There is authorized to be appropriated $500,000,000 for fiscal year 2004, and, for each subsequent fiscal year, such sums as may be necessary to carry out the provisions of this chapter. In the first year of implementation, up to 10 percent of the amount appropriated to the Fund shall be available to participating agencies to train supervisors, managers, and other individuals involved in the appraisal process on using performance management systems to make meaningful distinctions in employee performance and on the use of the Fund.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb863865c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXI/s1129/a"},"text":"Pub. L. 108–136, div. A, title XI, § 1129(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1645"},"text":"117 Stat. 1645","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb863865d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb863865e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb863865f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provi