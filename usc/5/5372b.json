{"tag":"section","attrib":{"id":"idb85ecae7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372b"},"text":null,"children":[{"tag":"num","attrib":{"value":"5372b"},"text":"§ 5372b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative appeals judges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb85ecae8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85ecae9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “administrative appeals judge position” means a position the duties of which primarily involve reviewing decisions of administrative law judges appointed under section 3105; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecaea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “agency” means an Executive agency, as defined by section 105, but does not include the Government Accountability Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85ecaeb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to such regulations as the Office of Personnel Management may prescribe, the head of the agency concerned shall fix the rate of basic pay for each administrative appeals judge position within such agency which is not classified above GS–15 pursuant to section 5108.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85ecaec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A rate of basic pay fixed under this section shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85ecaed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than the minimum rate of basic pay for level AL–3 under section 5372; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecaee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5372b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not greater than the maximum rate of basic pay for level AL–3 under section 5372.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb85ecaef-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/3/tVI/s645/a/1"},"text":"Pub. L. 106–554, § 1(a)(3) [title VI, § 645(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–169; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb85ecaf0-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb85ecaf1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb85ecaf2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"GS–15, referred to in subsec. (b), is contained in the General Schedule which is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb85ecaf3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb85ecaf4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb85ecaf5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/3/tVI/s645/b"},"text":"Pub. L. 106–554, § 1(a)(3) [title VI, § 645(b)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–170, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/3/tVI/s645/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendment made by subsection (a)(1) [enacting this section] shall apply with respect to pay for service performed on or after the first day of the first applicable pay period beginning on or after—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 120th day after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if earlier, the effective date of regulations prescribed by the Office of Personnel Management to carry out such amendment.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
