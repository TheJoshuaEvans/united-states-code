{"tag":"section","attrib":{"id":"idb82a4cf9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4108"},"text":null,"children":[{"tag":"num","attrib":{"value":"4108"},"text":"§ 4108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee agreements; service after training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82a4cfa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee selected for training for more than a minimum period prescribed by the head of the agency shall agree in writing with the Government before assignment to training that he will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82a4cfb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4108/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue in the service of his agency after the end of the training period for a period at least equal to three times the length of the training period unless he is involuntarily separated from the service of his agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82a4cfc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4108/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay to the Government the amount of the additional expenses incurred by the Government in connection with his training if he is voluntarily separated from the service of his agency before the end of the period for which he has agreed to continue in the service of his agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82a4cfd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The payment agreed to under subsection (a)(2) of this section may not be required of an employee who leaves the service of his agency to enter into the service of another agency in any branch of the Government unless the head of the agency that authorized the training notifies the employee before the effective date of his entrance into the service of the other agency that payment will be required under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb82a4cfe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If an employee, except an employee relieved of liability under subsection (b) of this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4102/b"},"text":"section 4102(b) of this title","children":[],"tail":", fails to fulfill his agreement to pay to the Government the additional expenses incurred by the Government in connection with his training, a sum equal to the amount of the additional expenses of training is recoverable by the Government from the employee or his estate by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82a4cff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4108/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setoff against accrued pay, compensation, amount of retirement credit, or other amount due the employee from the Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82a4d00-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4108/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other method as is provided by law for the recovery of amounts owing to the Government.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The head of the agency concerned, under the regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4118"},"text":"section 4118 of this title","children":[],"tail":", may waive in whole or in part a right of recovery under this subsection, if it is shown that the recovery would be against equity and good conscience or against the public interest."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82a4d01-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/435"},"text":"80 Stat. 435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/224/s5/a"},"text":"Pub. L. 98–224, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-03-02"},"text":"Mar. 2, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/48"},"text":"98 Stat. 48","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/226/s2/a/6"},"text":"Pub. L. 103–226, § 2(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-30"},"text":"Mar. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/112"},"text":"108 Stat. 112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/tII/s209/g/1/B"},"text":"Pub. L. 107–347, title II, § 209(g)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2932"},"text":"116 Stat. 2932","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82a4d02-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb82a4d03-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb82a4d04-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s2310"},"text":"5 U.S.C. 2310","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/507/s11"},"text":"Pub. L. 85–507, § 11","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/332"},"text":"72 Stat. 332","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the last sentence of former section 2310(a) is omitted as included in the first sentence of the revised subsection.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words, “another agency in any branch of the Government” are coextensive with and substituted for “another department or of any other agency in any branch of the Government”. This is so because “agency in any branch of the Government” is broader than “agency” as defined for the purpose of this chapter in section 4101(1).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb82a4d05-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb82a4d06-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Pub. L. 107–347","children":[],"tail":" struck out subsec. (d) which read as follows: “For purposes of this section, ‘training’ includes a private sector assignment of an employee participating in the Executive Exchange Program of the President’s Commission on Executive Exchange.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226"},"text":"Pub. L. 103–226","children":[],"tail":" substituted “for more than a minimum period prescribed by the head of the agency” for “by, in, or through a non-Government facility under this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/224"},"text":"Pub. L. 98–224","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82a4d07-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82a4d08-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Pub. L. 107–347","children":[],"tail":" effective 120 days after "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s402/a"},"text":"section 402(a) of Pub. L. 107–347","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3601"},"text":"section 3601 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb82a4d09-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Department of Homeland Security","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Exception from provisions of this section of those elements of the Department of Homeland Security that are supervised by the Under Secretary of Homeland Security for Information Analysis and Infrastructure Protection through the Department’s Assistant Secretary for Information Analysis, see Ex. Ord. No. 13286, § 86, ","children":[{"tag":"date","attrib":{"date":"2003-02-28"},"text":"Feb. 28, 2003","children":[],"tail":", 68 F.R. 10632, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s111"},"text":"section 111 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb82a4d0a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Central Intelligence Agency","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Exception of Central Intelligence Agency from provisions of this section, see Ex. Ord. No. 10805, ","children":[{"tag":"date","attrib":{"date":"1959-02-18"},"text":"Feb. 18, 1959","children":[],"tail":", 24 F.R. 1301, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s4102"},"text":"section 4102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
