{"tag":"section","attrib":{"id":"idb878e319-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5583"},"text":null,"children":[{"tag":"num","attrib":{"value":"5583"},"text":"§ 5583.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of money due; settlement of accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb878e31a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5583/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under such regulations as the Director of the Office of Personnel Management may prescribe, the employing agency shall pay money due a deceased employee to the beneficiary designated by the employee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5582/b"},"text":"section 5582(b) of this title","children":[],"tail":", or, if none, to the widow or widower of the employee."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb878e31b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5583/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director may by regulation prescribe the method for settlement of accounts payable under subsection (a) of this section. However—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb878e31c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5583/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accounts of employees of the government of the District of Columbia shall be paid by the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb878e31d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5583/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accounts of employees of Government corporations or mixed ownership Government corporations may be paid by the corporations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb878e31e-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/496"},"text":"80 Stat. 496","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/70/tIII/s3302/e/7"},"text":"Pub. L. 96–70, title III, § 3302(e)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/498"},"text":"93 Stat. 498","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tII/s202/b"},"text":"Pub. L. 104–316, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3842"},"text":"110 Stat. 3842","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb878e31f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb878e320-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb878e321-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"ta