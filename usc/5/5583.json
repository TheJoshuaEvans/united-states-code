":"64 Stat. 396","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-04-30/ch177/s1"},"text":"Apr. 30, 1954, ch. 177, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/64"},"text":"68 Stat. 64","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “officer” is omitted as included in “employee”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb878e322-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb878e323-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s202/b/1"},"text":"Pub. L. 104–316, § 202(b)(1)","children":[],"tail":", substituted “Director of the Office of Personnel Management” for “Comptroller General of the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/s202/b/2"},"text":"Pub. L. 104–316, § 202(b)(2)","children":[],"tail":", substituted “The Director may by regulation prescribe the method for settlement of accounts payable under subsection (a) of this section.” for “Except as the Comptroller General may by regulation otherwise authorize or direct, accounts not payable under subsection (a) of th