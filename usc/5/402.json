{"tag":"section","attrib":{"id":"idb78cd492-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s402"},"text":null,"children":[{"tag":"num","attrib":{"value":"402"},"text":"§ 402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose of Offices of Inspector General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb78cd493-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb78cd494-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s402/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), in each of the establishments listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s401/1"},"text":"section 401(1) of this title","children":[],"tail":", there is established an Office of Inspector General."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78cd495-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s402/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department of the treasury","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the establishment of the Department of the Treasury, there is established—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb78cd496-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s402/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Office of Inspector General of the Department of the Treasury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb78cd497-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s402/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Office of Treasury Inspector General for Tax Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78cd498-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The offices established under subsection (a) are established in order to create independent and objective units—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb78cd499-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s402/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct and supervise audits and investigations relating to the programs and operations of the establishments listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s401/1"},"text":"section 401(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78cd49a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s402/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide leadership and coordination and recommend policies for activities designed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb78cd49b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s402/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote economy, efficiency, and effectiveness in the administration of those programs and operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb78cd49c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s402/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent and detect fraud and abuse in those programs and operations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78cd49d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s402/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a means for keeping the head of the establishments and Congress fully and currently informed about problems and deficiencies relating to the administration of those programs and operations and the necessity for and progress of corrective action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb78cd49e-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/b"},"text":"Pub. L. 117–286, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4208"},"text":"136 Stat. 4208","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb78cd49f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb78c