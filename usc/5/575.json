{"tag":"section","attrib":{"id":"idb7bc97c1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s575"},"text":null,"children":[{"tag":"num","attrib":{"value":"575"},"text":"§ 575.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of arbitration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7bc97c2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s575/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7bc97c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s575/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Arbitration may be used as an alternative means of dispute resolution whenever all parties consent. Consent may be obtained either before or after an issue in controversy has arisen. A party may agree to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7bc97c4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s575/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit only certain issues in controversy to arbitration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7bc97c5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s575/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arbitration on the condition that the award must be within a range of possible outcomes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc97c6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s575/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The arbitration agreement that sets forth the subject matter submitted to the arbitrator shall be in writing. Each such arbitration agreement shall specify a maximum award that may be issued by the arbitrator and may specify other conditions limiting the range of possible outcomes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc97c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s575/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency may not require any person to consent to arbitration as a condition of entering into a contract or obtaining a benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7bc97c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s575/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer or employee of an agency shall not offer to use arbitration for the resolution of issues in controversy unless such officer or employee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7bc97c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s575/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would otherwise have authority to enter into a settlement concerning the matter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7bc97ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s575/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is otherwise specifically authorized by the agency to consent to the use of arbitration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7bc97cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s575/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Prior to using binding arbitration under this subchapter, the head of an agency, in consultation with the Attorney General and after taking into account the factors in section 572(b), shall issue guidance on the appropriate use of binding arbitration and when an officer or employee of the agency has authority to settle an issue in controversy through binding arbitration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7bc97cc-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/552/s4/b"},"text":"Pub. L. 101–552, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2742"},"text":"104 Stat. 2742","children":[],"tail":", § 585; renumbered § 575, "},{"tag":"ref","attrib":{"href":"/us/pl/102/354/s3/b/2"},"text":"Pub. L. 102–354, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/944"},"text":"106 Stat. 944","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/320/s8/c"},"text":"Pub. L. 104–320, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3872"},"text":"110 Stat. 3872","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7bc97cd-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7bc97ce-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb7bc97cf-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 575 of former Title 5, Executive Departments and Government Officers and Employees, was transferred to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s2259"},"text":"section 2259 of Title 7","children":[],"tail":", Agriculture."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7bc97d0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 575 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s595"},"text":"section 595 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7bc97d1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/320/s8/c/1"},"text":"Pub. L. 104–320, § 8(c)(1)","children":[],"tail":", (2), substituted “The” for “Any” and inserted at end “Each such arbitration agreement shall specify a maximum award that may be issued by the arbitrator and may specify other conditions limiting the range of possible outcomes.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/320/s8/c/3"},"text":"Pub. L. 104–320, § 8(c)(3)","children":[],"tail":", in introductory provisions substituted “shall not offer to use arbitration for the resolution of issues in controversy unless” for “may offer to use arbitration for the resolution of issues in controversy, if”, and in par. (1) substituted “would otherwise have authority” for “has authority”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/320/s8/c/4"},"text":"Pub. L. 104–320, § 8(c)(4)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/354"},"text":"Pub. L. 102–354","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s585"},"text":"section 585 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
