{"tag":"section","attrib":{"id":"idb8552e8f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5332a"},"text":"§ 5332a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special base rates of pay for wildland firefighters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8552e90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8552e91-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “firefighter” means an employee who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8552e92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a firefighter within the meaning of section 8331(21) or section 8401(14);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8552e93-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee who holds a supervisory or administrative position and is subject to subchapter III of chapter 83, but who does not qualify to be considered a firefighter within the meaning of section 8331(21), would otherwise qualify if the employee had transferred directly to that position after serving as a firefighter within the meaning of that section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8552e94-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee who holds a supervisory or administrative position and is subject to chapter 84, but who does not qualify to be considered a firefighter within the meaning of section 8401(14), would otherwise qualify if the employee had transferred directly to that position after performing duties described in section 8401(14)(A) for at least 3 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8552e95-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee who is not subject to subchapter III of chapter 83 or chapter 84, holds a position that the Office of Personnel Management determines would satisfy subparagraph (A), (B), or (C) if the employee were subject to subchapter III of chapter 83 or chapter 84;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8552e96-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “General Schedule base rate” means an annual rate of basic pay established under section 5332 before any additions, such as a locality-based comparability payment under section 5304 or 5304a or a special rate supplement under section 5305;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8552e97-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “special base rate” means an annual rate of basic pay payable to a wildland firefighter, before any additions or reductions, that replaces the General Schedule base rate otherwise applicable to the wildland firefighter and that is administered in the same manner as a General Schedule base rate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8552e98-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “wildland firefighter” means a firefighter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8552e99-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is employed by the Forest Service or the Department of the Interior; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8552e9a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duties of the position of whom primarily relate to fires occurring in forests, range lands, or other wildlands, as opposed to structural fires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8552e9b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Base Rates of Pay.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8552e9c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entitlement to special rate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 5332, a wildland firefighter is entitled to a special base rate at grades 1 through 15, which shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8552e9d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" replace the otherwise applicable General Schedule base rate for the wildland firefighter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8552e9e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be basic pay for all purposes, including the purpose of computing a locality-based comparability payment under section 5304 or 5304a; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8552e9f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be computed as described in paragraph (2) and adjusted at the time of adjustments in the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8552ea0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computation","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8552ea1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The special base rate for a wildland firefighter shall be derived by increasing the otherwise applicable General Schedule base rate for the wildland firefighter by the following applicable percentage for the grade of the wildland firefighter and rounding the result to the nearest whole dollar:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8552ea2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–1, 42 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8552ea3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–2, 39 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8552ea4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–3, 36 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8552ea5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–4, 33 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8552ea6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–5, 30 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8552ea7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–6, 27 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8552ea8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–7, 24 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8552ea9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–8, 21 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8552eaa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–9, 18 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8552eab-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–10, 15 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8552eac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–11, 12 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8552ead-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–12, 9 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8552eae-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/xiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiii"},"text":"(xiii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–13, 6 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8552eaf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/xiv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiv"},"text":"(xiv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–14, 3 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8552eb0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/A/xv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xv"},"text":"(xv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For GS–15, 1.5 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8552eb1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5332a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hourly, daily, weekly, or biweekly rates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the special base rate with respect to a wildland firefighter is expressed as an hourly, daily, weekly, or biweekly rate, the special base rate shall be computed from the appropriate annual rate of basic pay derived under subparagraph (A) in accordance with the rules under section 5504(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8579eb2-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/4/dA/tVIII/s1807"},"text":"Pub. L. 119–4, div. A, title VIII, § 1807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-03-15"},"text":"Mar. 15, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/30"},"text":"139 Stat. 30","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8579eb3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8579eb4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb8579eb5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 456(a) of H.R. 8998, from the 118th Congress (Department of the Interior, Environment, and Related Congress, Agencies Appropriations Act, 2025), as passed by the House of Representatives on ","children":[{"tag":"date","attrib":{"date":"2024-07-24"},"text":"July 24, 2024","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/119/4/dA/s1807"},"text":"section 1807 of div. A of Pub. L. 119–4","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8579eb6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8579eb7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 456(d) of H.R. 8998, from the 118th Congress, as passed by the House of Representatives on ","children":[{"tag":"date","attrib":{"date":"2024-07-24"},"text":"July 24, 2024","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/119/4/dA/tVIII/s1807"},"text":"Pub. L. 119–4, div. A, title VIII, § 1807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-03-15"},"text":"Mar. 15, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/30"},"text":"139 Stat. 30","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/4/dA/tVIII/s1807"},"text":"“The amendments made by this section [enacting this section, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5343"},"text":"section 5343 of this title","children":[],"tail":", and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t16/s6592"},"text":"section 6592 of Title 16","children":[],"tail":", Conservation] shall take effect on the first day of the first applicable pay period beginning on or after either "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"October 1, 2024","children":[],"tail":" or the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2025-03-15"},"text":"Mar. 15, 2025","children":[],"tail":"], whichever is later.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
