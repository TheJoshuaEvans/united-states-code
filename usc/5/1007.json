{"tag":"section","attrib":{"id":"idb7de0244-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1007"},"text":null,"children":[{"tag":"num","attrib":{"value":"1007"},"text":"§ 1007.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities of agency heads","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7de0245-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1007/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Guidelines and Management Controls","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each agency head shall establish uniform administrative guidelines and management controls for advisory committees established by that agency, which shall be consistent with directives of the Administrator under sections 1006 and 1009 of this title. Each agency shall maintain systematic information on the nature, functions, and operations of each advisory committee within its jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7de0246-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1007/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory Committee Management Officer","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each agency that has an advisory committee shall designate an Advisory Committee Management Officer who shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7de0247-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1007/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exercise control and supervision over the establishment, procedures, and accomplishments of advisory committees established by the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7de0248-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1007/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assemble and maintain the reports, records, and other papers of any advisory committee established by the agency during the advisory committee’s existence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7de0249-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1007/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out, on behalf of the agency, the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of this title","children":[],"tail":" with respect to such reports, records, and other papers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7de024a-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/a"},"text":"Pub. L. 117–286, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4201"},"text":"136 Stat. 4201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7de024b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7de024c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7de024d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1007","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 U.S.C. App. (FACA § 8)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/92/463/s8"},"text":"Pub. L. 92–463, § 8","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/773"},"text":"86 Stat. 773","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “Administrator” is substituted for “Director” (meaning the Director of the Office of Management and Budget) because of section 5F of Reorganization Plan No. 1 of 1977 (5 U.S.C. App.).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
