{"tag":"section","attrib":{"id":"idb924b2e1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8982"},"text":null,"children":[{"tag":"num","attrib":{"value":"8982"},"text":"§ 8982.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of vision benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb924b2e2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8982/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall establish and administer a program through which an eligible individual may obtain vision coverage to supplement coverage available through chapter 89.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b2e3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8982/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall determine, in the exercise of its reasonable discretion, the financial requirements for qualified companies to participate in the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b2e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8982/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall be construed to prohibit the availability of vision benefits provided by health benefits plans under chapter 89.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb924b2e5-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/496/s3"},"text":"Pub. L. 108–496, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/4007"},"text":"118 Stat. 4007","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb924b2e6-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb924b2e7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb924b2e8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", and applicable to contracts that take effect with respect to the calendar year 2006, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/496/s7"},"text":"section 7 of Pub. L. 108–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8951"},"text":"section 8951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
