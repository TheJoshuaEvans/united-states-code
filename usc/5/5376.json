{"tag":"section","attrib":{"id":"idb85ecb21-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5376"},"text":null,"children":[{"tag":"num","attrib":{"value":"5376"},"text":"§ 5376.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay for certain senior-level positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb85ecb22-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5376/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section applies to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85ecb23-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5376/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" positions that are classified above GS–15 pursuant to section 5108; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecb24-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5376/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scientific or professional positions established under section 3104;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not apply to—","children":[],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85ecb25-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5376/a/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any Senior Executive Service position under section 3132; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85ecb26-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5376/a/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any position in the Federal Bureau of Investigation and Drug Enforcement Administration Senior Executive Service under section 3151.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85ecb27-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5376/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85ecb28-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5376/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to such regulations as the Office of Personnel Management prescribes, the head of the agency concerned shall fix the rate of basic pay for any position within such agency to which this section applies. A rate fixed under this section shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb85ecb29-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5376/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 120 percent of the minimum rate of basic pay payable for GS–15 of the General Schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85ecb2a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5376/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to paragraph (3), not greater than the rate of basic pay payable for level III of the Executive Schedule.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The payment of a rate of basic pay under this section shall not be subject to the pay limitation of section 5306(e) or 5373.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecb2b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5376/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (1), effective at the beginning of the first applicable pay period commencing on or after the first day of the month in which an adjustment takes effect under section 5303 in the rates of pay under the General Schedule, each rate of pay established under this section for positions within an agency shall be adjusted by such amount as the head of such agency considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecb2c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5376/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an agency which has a performance appraisal system which, as designed and applied, is certified under section 5307(d) as making meaningful distinctions based on relative performance, paragraph (1)(B) shall apply as if the reference to “level III” were a reference to “level II”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecb2d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5376/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No employee may suffer a reduction in pay by reason of transfer from an agency with an applicable maximum rate of pay prescribed under paragraph (3) to an agency with an applicable maximum rate of pay prescribed under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb85ecb2e-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s102/a/1"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 102(a)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1443; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/372/s2/b"},"text":"Pub. L. 110–372, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4044"},"text":"122 Stat. 4044","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb85ecb2f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb85ecb30-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb85ecb31-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (b), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Levels II and III of the Executive Schedule, referred to in subsec. (b), are set out in sections 5313 and 5314 of this title, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb85ecb32-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/372/s2/b/1"},"text":"Pub. L. 110–372, § 2(b)(1)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “not greater than the rate of basic pay payable for level IV of the Executive Schedule.”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/372/s2/b/2"},"text":"Pub. L. 110–372, § 2(b)(2)","children":[],"tail":", added pars. (3) and (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb85ecb33-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb85ecb34-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/372/s2/d"},"text":"Pub. L. 110–372, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4044"},"text":"122 Stat. 4044","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/372/s2/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section and sections 3104, 3324, 3325, 5108 and 5304 of this title] shall take effect on the first day of the first pay period beginning on or after the 180th day following the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-08"},"text":"Oct. 8, 2008","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No reductions in rates of pay.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section may not result, at the time such amendments take effect, in a reduction in the rate of basic pay for an individual holding a position to which ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":", United States Code, applies."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of rate of pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of subparagraph (A), the rate of basic pay for an individual described in that subparagraph shall be deemed to be the rate of basic pay set for the individual under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":", United States Code, plus any applicable locality pay paid to that individual on the day before the effective date under paragraph (1), subject to regulations that the Director of the Office of Personnel Management may prescribe."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References to maximum rates","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided by law, any reference in a provision of law to the maximum rate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":", United States Code—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as provided before the effective date of the amendments made by this section, shall be considered a reference to the rate of basic pay for level IV of the Executive Schedule [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"5 U.S.C. 5315","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" as provided on or after the effective date of the amendments made by this section, shall be considered a reference to—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rate of basic pay for level III of the Executive Schedule [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"5 U.S.C. 5314","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the head of the agency responsible for administering the applicable pay system certifies that the employees are covered by a performance appraisal system meeting the certification criteria established by regulation under section 5307(d), level II of the Executive Schedule [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"5 U.S.C. 5313","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb85ecb35-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on such date as the President shall determine, but not earlier than 90 days, and not later than 180 days, after ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see section 529 [title III, § 305] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb85ecb36-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates; Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s101/c"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 101(c), (d)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1442, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/509/tV/s529/tI/s101/c"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other References","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until otherwise provided by law—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any reference in a provision of law (which is outside title 5, United States Code, and in effect immediately before this section takes effect [see Effective Date of 1990 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5301"},"text":"section 5301 of this title","children":[],"tail":"], excluding any reference in a provision of law amended by this Act [see Short Title of 1990 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5301"},"text":"section 5301 of this title","children":[],"tail":"])—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the rate of pay for grade GS–18 of the General Schedule, or to the maximum rate of pay under the General Schedule, shall be considered a reference to the maximum rate payable under section 5376 of such title (as amended by section 102(a));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the minimum rate of pay for grade GS–16 of the General Schedule shall be considered a reference to the minimum rate payable under section 5376 of such title (as amended by section 102(a)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a rate of pay for grade GS–16 or 17 of the General Schedule shall (except as provided in clause (ii)) be considered a reference to a rate of pay for a position classified above GS–15 pursuant to section 5108 of such title (as amended by section 102(b)(2)); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a rate of pay under the General Schedule shall not include any comparability payment payable under section 5304 of such title (as amended by this section) or any geographic adjustment payable under section 302 [section 529 [title III, § 302] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5304"},"text":"section 5304 of this title","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any authority granted by a provision of law (which is outside such title, and in effect immediately before this section takes effect) to fix pay in accordance with chapter 51 and subchapter III of chapter 53 of such title—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be considered to include any authority under section 5304 of such title (as amended by this section) or section 302; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be considered to include authority under section 5376 of such title (as amended by section 102(a)), if applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office of Personnel Management may prescribe regulations, consistent with subsection (c)(1)(B) and section 303 [section 529 [title III, § 303] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5301"},"text":"section 5301 of this title","children":[],"tail":"], governing the conversion or adjustment of rates of pay, where necessary because of the abolishment of grades GS–16, 17, and 18 of the General Schedule.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For reference to maximum rate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of this title","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/372/s2/d/3"},"text":"section 2(d)(3) of Pub. L. 110–372","children":[],"tail":", set out as an Effective Date of 2008 Amendment note under this section.]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
