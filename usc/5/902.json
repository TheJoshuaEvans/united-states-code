n":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s133z–5"},"text":"5 U.S.C. 133z–5","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-20/ch226/s7"},"text":"June 20, 1949, ch. 226, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/205"},"text":"63 Stat. 205","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s133z–6"},"text":"5 U.S.C. 133z–6","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-20/ch226/s8"},"text":"June 20, 1949, ch. 226, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/206"},"text":"63 Stat. 206","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1)(A), the words “an Executive agency or part thereof” are coextensive with and substituted for “any executive department, commission, council, independent establishment, Government corporation, board, bureau, division, service, . . . authority, administration, or other establishment, in the executive branch of the Government” and to conform to the definition in section 105.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In paragraph (1)(B), the words “an office or officer in the civil service or uniformed services in or under an Executive agency” are substituted for “office, officer, . . . in the executive branch of the Government” to conform to the definitions in sections 105, 2101, and 2104.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7db915c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1967 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This section amends ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s902"},"text":"section 902 of title 5","children":[],"tail":", United States Code, so as to preserve the application of the source statute for section 902 (sec. 7 of the Reorganization Act of 1949). In the codification of title 5 by "},{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Public Law 89–554","children":[],"tail":", that application was inadvertently restricted due to the operation of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2104"},"text":"section 2104 of title 5","children":[],"tail":", providing a title-wide definition of “officer.” Briefly, that section defines “officer” as a civil appointive officer of the Federal Government. In the Reorganization Act of 1949, the word “officer” was not defined, and has been construed to include not only civil appointive officers, but uniformed officers, the President, and officers of the government of the District of Columbia. Thus, this section amends "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s902"},"text":"section 902 of title 5","children":[],"tail":" by inserting a paragraph providing that the title-wide definition of officer is inapplicable to chapter 9 of title 5. Also, paragraph (1)(B) of section 902 is amended so that the wording thereof is identical to that formerly appearing in section 7 of the Reorganization Act of 1949."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7db915d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb7db915e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 902(a) of former Title 5, Executive Departments and Government Officers and Employees, was transferred to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s60e–2/b"},"text":"section 60e–2(b) of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7db915f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Par. (1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/17"},"text":"Pub. L. 95–17","children":[],"tail":" struck out subpar. (C) which defined “agency” as any and all parts of the government of the District of Columbia other than the courts thereof."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7db9160-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7db9161-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1967 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83"},"text":"Pub. L. 90–83","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", for all purposes, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s9/h"},"text":"section 9(h) of Pub. L. 90–83","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5102"},"text":"section 5102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
