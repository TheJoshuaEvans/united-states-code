{"tag":"section","attrib":{"id":"idb85c5a46-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362"},"text":null,"children":[{"tag":"num","attrib":{"value":"5362"},"text":"§ 5362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grade retention following a change of positions or reclassification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb85c5a47-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any employee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85c5a48-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is placed as a result of reduction-in-force procedures from a position subject to this subchapter to another position which is subject to this subchapter and which is in a lower grade than the previous position, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a49-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has served for 52 consecutive weeks or more in one or more positions subject to this subchapter at a grade or grades higher than that of the new position,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is entitled, to the extent provided in subsection (c) of this section, to have the grade of the position held immediately before such placement be considered to be the retained grade of the employee in any position he holds for the 2-year period beginning on the date of such placement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85c5a4a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85c5a4b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any employee who is in a position subject to this subchapter and whose position has been reduced in grade is entitled, to the extent provided in subsection (c) of this section, to have the grade of such position before reduction be treated as the retained grade of such employee for the 2-year period beginning on the date of the reduction in grade.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a4c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of paragraph (1) of this subsection shall not apply with respect to any reduction in the grade of a position which had not been classified at the higher grade for a continuous period of at least one year immediately before such reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85c5a4d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the 2-year period referred to in subsections (a) and (b) of this section, the retained grade of an employee under such subsection (a) or (b) shall be treated as the grade of the employee’s position for all purposes (including pay and pay administration under this chapter and chapter 55 of this title, retirement and life insurance under chapters 83, 84, and 87 of this title, and eligibility for training and promotion under this title) except—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85c5a4e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of subsection (a) of this section,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a4f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for purposes of applying any reduction-in-force procedures, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a50-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for such other purposes as the Office of Personnel Management may provide by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85c5a51-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The foregoing provisions of this section shall cease to apply to an employee who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85c5a52-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a break in service of one workday or more;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a53-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is demoted (determined without regard to this section) for personal cause or at the employee’s request;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a54-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is placed in, or declines a reasonable offer of, a position the grade of which is equal to or higher than the retained grade; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a55-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5362/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elects in writing to have the benefits of this section terminate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb85c5a56-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVIII/s801/a/1"},"text":"Pub. L. 95–454, title VIII, § 801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1219"},"text":"92 Stat. 1219","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/tII/s204/a/1"},"text":"Pub. L. 98–615, title II, § 204(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3216"},"text":"98 Stat. 3216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/89/s3/b/1/K"},"text":"Pub. L. 103–89, § 3(b)(1)(K)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"Sept. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/982"},"text":"107 Stat. 982","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb85c5a57-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb85c5a58-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb85c5a59-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5362, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/473"},"text":"80 Stat. 473","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/95/251/s2/a/1"},"text":"Pub. L. 95–251, § 2(a)(1)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1978-03-27"},"text":"Mar. 27, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/183"},"text":"92 Stat. 183","children":[],"tail":", which related to hearing examiners, was renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5372"},"text":"section 5372 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVIII/s801/a/3/A/ii"},"text":"Pub. L. 95–454, title VIII, § 801(a)(3)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1221"},"text":"92 Stat. 1221","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb85c5a5a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/89"},"text":"Pub. L. 103–89","children":[],"tail":" substituted “chapter 55 of this title, retirement and life insurance under chapters 83, 84, and 87” for “chapters 54 and 55 of this title, retirement and life insurance under chapters 83 and 87” in introductory provisions, redesignated par. (4) as (3), and struck out former par. (3) which read as follows: “for purposes of determining whether the employee is covered by the performance management and recognition system established under chapter 54 of this title, or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" substituted “performance management and recognition system established under chapter 54” for “merit pay system established under section 5402”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb85c5a5b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb85c5a5c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/89"},"text":"Pub. L. 103–89","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-11-01"},"text":"Nov. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/89/s3/c"},"text":"section 3(c) of Pub. L. 103–89","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3372"},"text":"section 3372 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb85c5a5d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615/s205"},"text":"Section 205 of Pub. L. 98–615","children":[],"tail":" provided that amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" was effective "},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"Oct. 1, 1984","children":[],"tail":", and applicable with respect to pay periods commencing on or after that date, with certain exceptions and qualifications."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb85c5a5e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Additional Pay and Benefits for Employees Reduced in Grade On or After ","children":[{"tag":"date","attrib":{"date":"1977-01-01"},"text":"January 1, 1977","children":[],"tail":", Etc."}],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVIII/s801/b"},"text":"Pub. L. 95–454, title VIII, § 801(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1222"},"text":"92 Stat. 1222","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/454/tVIII/s801/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations prescribed by the Office of Personnel Management, any employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose grade was reduced on or after ","children":[{"tag":"date","attrib":{"date":"1977-01-01"},"text":"January 1, 1977","children":[],"tail":", and before the effective date of the amendments made by subsection (a) of this section [see Effective Date note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5361"},"text":"section 5361 of this title","children":[],"tail":"] under circumstances which would have entitled the employee to coverage under the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5362"},"text":"section 5362 of title 5","children":[],"tail":", United States Code (as amended by subsection (a) of this section) if such amendments had been in effect at the time of the reduction; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who has remained employed by the Federal Government from the date of the reduction in grade to the effective date of the amendments made by subsection (a) of this section without a break in service of one workday or more;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be entitled—","children":[],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive the additional pay and benefits which such employee would have been entitled to receive if the amendments made by subsection (a) of this section had been in effect during the period beginning on the effective date of such reduction in grade and ending on the day before the effective date of such amendments, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to have the amendments made by subsection (a), of this section apply to such employee as if the reduction in grade had occurred on the effective date of such amendments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No employee covered by this subsection whose reduction in grade resulted in an increase in pay shall have such pay reduced by reason of the amendments made by subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection, the requirements under paragraph (1)(B) of this subsection, relating to continuous employment following reduction in grade, shall be considered to be met in the case of any employee—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who separated from service with a right to an immediate annuity under chapter 83 of title 5, United States Code, or under another retirement system for Federal employees; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who died.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts payable by reason of subparagraph (A) of this paragraph in the case of the death of an employee shall be paid in accordance with the provisions of subchapter VIII of chapter 55 of title 5, United States Code, relating to settlement of accounts in the case of deceased employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall have the same authority to prescribe regulations under this subsection as it has under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5365"},"text":"section 5365 of title 5","children":[],"tail":", United States Code, with respect to subchapter VI of chapter 53 of such title, as added by subsection (a) of this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
