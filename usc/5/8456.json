{"tag":"section","attrib":{"id":"idb908041c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456"},"text":null,"children":[{"tag":"num","attrib":{"value":"8456"},"text":"§ 8456.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military reserve technicians","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb908041d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb908041e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2) or (3), an individual shall be retired under this subchapter if the individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb908041f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is separated from employment as a military reserve technician by reason of a disability that disqualifies the individual from membership in a reserve component of the Armed Forces specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s10101"},"text":"section 10101 of title 10","children":[],"tail":" or from holding the military grade required for such employment;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9080420-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not considered to be disabled under section 8451(a)(1)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9080421-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not appointed to a position in the Government (whether under subsection (b) or otherwise); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9080422-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not declined an offer of an appointment to a position in the Government under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9080423-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Payment of any annuity for an individual pursuant to this section terminates—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9080424-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the date the individual is appointed to a position in the Government (whether pursuant to subsection (b) or otherwise);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9080425-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the date the individual declines an offer of appointment to a position in the Government under subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9080426-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as provided under section 8455(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9080427-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual eligible to retire under section 8414(c) shall not be eligible to retire under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9080428-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any individual applying for or receiving any annuity pursuant to this section shall, in accordance with regulations prescribed by the Office, be considered by any agency of the Government before any vacant position in the agency is filled if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9080429-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the position is located within the commuting area of the individual’s former position;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb908042a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual is qualified to serve in such position, as determined by the head of the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb908042b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8456/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the position is at the same grade or equivalent level as the position from which the individual was separated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb908042c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/570"},"text":"100 Stat. 570","children":[],"tail":", § 8457; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/556/tI/s118"},"text":"Pub. L. 99–556, title I, § 118","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3134"},"text":"100 Stat. 3134","children":[],"tail":"; renumbered § 8456, "},{"tag":"ref","attrib":{"href":"/us/pl/100/238/tI/s124/b/1/B"},"text":"Pub. L. 100–238, title I, § 124(b)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1756"},"text":"101 Stat. 1756","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tXVI/s1677/a/4"},"text":"Pub. L. 103–337, div. A, title XVI, § 1677(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3019"},"text":"108 Stat. 3019","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb908042d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"