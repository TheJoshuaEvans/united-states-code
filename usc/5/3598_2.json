{"tag":"section","attrib":{"id":"idb8256be7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3598"},"text":null,"children":[{"tag":"num","attrib":{"value":"3598"},"text":"§ 3598.","children":[{"tag":"ref","attrib":{"idref":"fn002073"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002073"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" Another section 3598 is set out preceding this section."}],"tail":null}],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Bureau of Investigation Reserve Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8256be8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3598/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Federal Bureau of Investigation may provide for the establishment and training of a Federal Bureau of Investigation Reserve Service (hereinafter in this section referred to as the “FBI Reserve Service”) for temporary reemployment of employees in the Bureau during periods of emergency, as determined by the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8256be9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3598/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Membership in the FBI Reserve Service shall be limited to individuals who previously served as full-time employees of the Bureau.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8256bea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3598/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annuitants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an individual receiving an annuity from the Civil Service Retirement and Disability Fund on the basis of such individual’s service becomes temporarily reemployed pursuant to this section, such annuity shall not be discontinued thereby. An individual so reemployed shall not be considered an employee for the purposes of chapter 83 or 84.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8256beb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3598/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Impact on Bureau Personnel Ceiling","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"FBI Reserve Service members reemployed on a temporary basis pursuant to this section shall not count against any personnel ceiling applicable to the Bureau.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8256bec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3598/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director may provide members of the FBI Reserve Service transportation and per diem in lieu of subsistence, in accordance with applicable provisions of this title, for the purpose of participating in any training that relates to service as a member of the FBI Reserve Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8256bed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3598/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Membership","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Membership of the FBI Reserve Service is not to exceed 500 members at any given time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8256bee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3598/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Duration of Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual may not be reemployed under this section for more than 180 days in connection with any particular emergency unless, in the judgment of the Director, the public interest so requires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8256bef-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/tII/s2004/a"},"text":"Pub. L. 108–458, title II, § 2004(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3703"},"text":"118 Stat. 3703","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
