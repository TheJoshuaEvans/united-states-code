{"tag":"section","attrib":{"id":"idb8bbb7f0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906"},"text":null,"children":[{"tag":"num","attrib":{"value":"7906"},"text":"§ 7906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Services of post-combat case coordinators","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8bbb7f1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bbb7f2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “employee”, “agency”,","children":[{"tag":"ref","attrib":{"idref":"fn002142"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002142"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The definition of “agency” does not appear in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of this title","children":[],"tail":"."}],"tail":" “injury”, “war-risk hazard”, and “hostile force or individual” have the meanings given those terms in section 8101; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bbb7f3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “qualified employee” means an employee as described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bbb7f4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each agency shall, in a manner consistent with the guidelines prescribed under subsection (c), provide for the assignment of a post-combat case coordinator in the case of any employee of such agency who suffers an injury or disability incurred, or an illness contracted, while in the performance of such employee’s duties, as a result of a war-risk hazard or during or as a result of capture, detention, or other restraint by a hostile force or individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bbb7f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Personnel Management shall, after such consultation as the Office considers appropriate, prescribe guidelines for the operation of this section. Under the guidelines, the responsibilities of a post-combat case coordinator shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bbb7f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting as the main point of contact for qualified employees seeking administrative guidance or assistance relating to benefits under chapter 81 or 89;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bbb7f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting qualified employees in the collection of documentation or other supporting evidence for the expeditious processing of claims under chapter 81 or 89;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bbb7f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting qualified employees in connection with the receipt of prescribed medical care and the coordination of benefits under chapter 81 or 89;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bbb7f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resolving problems relating to the receipt of benefits under chapter 81 or 89; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bbb7fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensuring that qualified employees are properly screened and receive appropriate treatment—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8bbb7fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for post-traumatic stress disorder or other similar disorder stemming from combat trauma; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8bbb7fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for suicidal or homicidal thoughts or behaviors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8bbb7fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The services of a post-combat case coordinator shall remain available to a qualified employee until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8bbb7fe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such employee accepts or declines a reasonable offer of employment in a position in the employee’s agency for which the employee is qualified, which is not lower than 2 grades (or pay levels) below the employee’s grade (or pay level) before the occurrence or onset of the injury, disability, or illness (as referred to in subsection (a)), and which is within the employee’s commuting area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8bbb7ff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7906/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such employee gives written notice, in such manner as the employing agency prescribes, that those services are no longer desired or necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8bbb800-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tXI/s1106/a"},"text":"Pub. L. 112–81, div. A, title XI, § 1106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1613"},"text":"125 Stat. 1613","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
