{"tag":"section","attrib":{"id":"idb9224279-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8955"},"text":null,"children":[{"tag":"num","attrib":{"value":"8955"},"text":"§ 8955.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information to individuals eligible to enroll","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb922427a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8955/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The qualified companies ","children":[{"tag":"ref","attrib":{"idref":"fn002195"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002195"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" at the direction and with the approval of the Office, shall make available to each individual eligible to enroll in a dental benefits plan information on services and benefits (including maximums, limitations, and exclusions), that the Office considers necessary to enable the individual to make an informed decision about electing coverage."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb922427b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8955/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall make available to each individual eligible to enroll in a dental benefits plan, information on services and benefits provided by qualified companies participating under chapter 89.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb922427c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/496/s2"},"text":"Pub. L. 108–496, § 2","children":[],"tail":", "},{"tag":"date","attri