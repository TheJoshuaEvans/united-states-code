{"tag":"section","attrib":{"id":"idb8c52e98-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8171"},"text":null,"children":[{"tag":"num","attrib":{"value":"8171"},"text":"§ 8171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for work injuries; generally","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c52e99-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8171/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Longshore and Harbor Workers’ Compensation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s901"},"text":"33 U.S.C. 901","children":[],"tail":" et seq.) applies with respect to disability or death resulting from injury, as defined by section 2(2) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s902/2"},"text":"33 U.S.C. 902(2)","children":[],"tail":"), occurring to an employee of a nonappropriated fund instrumentality described by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105/c"},"text":"section 2105(c) of this title","children":[],"tail":", or to a volunteer providing such an instrumentality with services accepted under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1588"},"text":"section 1588 of title 10","children":[],"tail":", who is—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c52e9a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8171/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States citizen or a permanent resident of the United States or a territory or possession of the United States employed outside the continental United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c52e9b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8171/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employed inside the continental United States.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"However, that part of section 3(a) of such Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s903/a"},"text":"33 U.S.C. 903(a)","children":[],"tail":") which follows the second comma does not apply to such an employee."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c52e9c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8171/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this subchapter, the term “employer” in section 2(4) of the Longshore and Harbor Workers’ Compensation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s902/4"},"text":"33 U.S.C. 902(4)","children":[],"tail":") includes the nonappropriated fund instrumentalities described by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105/c"},"text":"section 2105(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c52e9d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8171/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Labor may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c52e9e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8171/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend compensation districts established under section 39(b) of the Longshore and Harbor Workers’ Compensation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s939/b"},"text":"33 U.S.C. 939(b)","children":[],"tail":"), or establish new districts to include the areas outside the continental United States; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c52e9f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8171/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assign to each district one or more deputy commissioners as the Secretary considers advisable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c52ea0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8171/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Judicial proceedings under sections 18 and 21 of the Longshore and Harbor Workers’ Compensation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s918"},"text":"33 U.S.C. 918","children":[],"tail":" and 921) with respect to an injury or death occurring outside the continental United States shall be instituted in the district court within the territorial jurisdiction of which is located the office of the deputy commissioner having jurisdiction with respect to the injury or death."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c52ea1-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/555"},"text":"80 Stat. 555","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/337/dA/tX"},"text":"Pub. L. 103–337, div. A, title X","children":[],"tail":", §§ 1061(c), 1070(d)(8)(A), "},{"tag":"date","attrib":{"date":"1994-10-05"},"text":"Oct. 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2847"},"text":"108 Stat. 2847","children":[],"tail":", 2858; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tXV/s1505/b/1"},"text":"Pub. L. 104–106, div. A, title XV, § 1505(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/514"},"text":"110 Stat. 514","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c52ea2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c52ea3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c52ea4-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 U.S.C. 150k–1(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1952-06-19/ch444/s2"},"text":"June 19, 1952, ch. 444, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/139"},"text":"66 Stat. 139","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 18, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/538/s1"},"text":"Pub. L. 85–538, § 1","children":[],"tail":" “Sec. 2(a)”, "},{"tag":"html:a","attrib":{"href":"/us/stat/72/397"},"text":"72 Stat. 397","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “civilian” is omitted as unnecessary as the definition of “employee” in section 2105 includes only civilians.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the reference to “the United States District Court for the District of Columbia” is omitted as included in the words “district court”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c52ea5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8c52ea6-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Longshore and Harbor Workers’ Compensation Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1927-03-04/ch509"},"text":"act Mar. 4, 1927, ch. 509","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/1424"},"text":"44 Stat. 1424","children":[],"tail":", which is classified generally to chapter 18 (§ 901 et seq.) of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t33/s901"},"text":"section 901 of Title 33","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c52ea7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1505/b/1/A"},"text":"Pub. L. 104–106, § 1505(b)(1)(A)","children":[],"tail":", substituted “903(a))” for “903(3))” in concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1505/b/1/B"},"text":"Pub. L. 104–106, § 1505(b)(1)(B)","children":[],"tail":", inserted “section” before “39(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1505/b/1/C"},"text":"Pub. L. 104–106, § 1505(b)(1)(C)","children":[],"tail":", substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s918"},"text":"33 U.S.C. 918","children":[],"tail":" and 921)” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s18"},"text":"33 U.S.C. 18","children":[],"tail":" and 21, respectively)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1070/d/8/A/i/III"},"text":"Pub. L. 103–337, § 1070(d)(8)(A)(i)(III)","children":[],"tail":", substituted “section 3(a) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s903/3"},"text":"33 U.S.C. 903(3)","children":[],"tail":") which follows the second comma” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t33/s903/a"},"text":"section 903(a) of title 33","children":[],"tail":" which follows the first comma” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1070/d/8/A/i/I"},"text":"Pub. L. 103–337, § 1070(d)(8)(A)(i)(I)","children":[],"tail":", (II), substituted “The Longshore and Harbor Workers’ Compensation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s901"},"text":"33 U.S.C. 901","children":[],"tail":" et seq.)” for “Chapter 18 of title 33” and “section 2(2) of such Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s902/2"},"text":"33 U.S.C. 902(2)","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t33/s902/2"},"text":"section 902(2) of title 33","children":[],"tail":"”, in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1061/c"},"text":"Pub. L. 103–337, § 1061(c)","children":[],"tail":", inserted “, or to a volunteer providing such an instrumentality with services accepted under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1588"},"text":"section 1588 of title 10","children":[],"tail":",” after “described by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105/c"},"text":"section 2105(c) of this title","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1070/d/8/A/ii"},"text":"Pub. L. 103–337, § 1070(d)(8)(A)(ii)","children":[],"tail":", substituted “section 2(4) of the Longshore and Harbor Workers’ Compensation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s902/4"},"text":"33 U.S.C. 902(4)","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t33/s902/4"},"text":"section 902(4) of title 33","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1070/d/8/A/iii"},"text":"Pub. L. 103–337, § 1070(d)(8)(A)(iii)","children":[],"tail":", substituted “39(b) of the Longshore and Harbor Workers’ Compensation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s939/b"},"text":"33 U.S.C. 939(b)","children":[],"tail":")” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t33/s939/b"},"text":"section 939(b) of title 33","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/337/s1070/d/8/A/iv"},"text":"Pub. L. 103–337, § 1070(d)(8)(A)(iv)","children":[],"tail":", substituted “sections 18 and 21 of the Longshore and Harbor Workers’ Compensation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s18"},"text":"33 U.S.C. 18","children":[],"tail":" and 21, respectively)” for “sections 918 and 921 of title 33”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
