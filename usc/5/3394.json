{"tag":"section","attrib":{"id":"idb81e66c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3394"},"text":null,"children":[{"tag":"num","attrib":{"value":"3394"},"text":"§ 3394.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noncareer and limited appointments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb81e66c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3394/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each noncareer appointee, limited term appointee, and limited emergency appointee shall meet the qualifications of the position to which appointed, as determined in writing by the appointing authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81e66c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3394/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual may not be appointed as a limited term appointee or as a limited emergency appointee without the prior approval of the exercise of such appointing authority by the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb81e66ca-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIV/s403/a"},"text":"Pub. L. 95–454, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1162"},"text":"92 Stat. 1162","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb81e66cb-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb81e66cc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb81e66cd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3394, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/437/s3/a"},"text":"Pub. L. 95–437, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1057"},"text":"92 Stat. 1057","children":[],"tail":", which related to personnel ceilings, was renumbered as "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3404"},"text":"section 3404 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/c/1/B"},"text":"Pub. L. 95–454, title IX, § 906(c)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1226"},"text":"92 Stat. 1226","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb81e66ce-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb81e66cf-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 9 months after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", and congressional review of provisions of sections 401 through 412 of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", see section 415(a)(1), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3131"},"text":"section 3131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
