{"tag":"section","attrib":{"id":"idb7de01c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s911"},"text":null,"children":[{"tag":"num","attrib":{"value":"911"},"text":"§ 911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discharge of committee considering resolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the committee to which is referred a resolution introduced pursuant to subsection (a) of section 910 (or, in the absence of such a resolution, the first resolution introduced with respect to the same reorganization plan) has not reported such resolution or identical resolution at the end of 75 calendar days of continuous session of Congress after its introduction, such committee shall be deemed to be discharged from further consideration of such resolution and such resolution shall be placed on the appropriate calendar of the House involved.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7de01ca-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/397"},"text":"80 Stat. 397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/179/s5"},"text":"Pub. L. 92–179, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-10"},"text":"Dec. 10, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/576"},"text":"85 Stat. 576","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/17/s2"},"text":"Pub. L. 95–17, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-04-06"},"text":"Apr. 6, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/34"},"text":"91 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/614/s3/b/4"},"text":"Pub. L. 98–614, § 3(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3192"},"text":"98 Stat. 3192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7de01cb-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7de01cc-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7de01cd-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s133z–13"},"text":"5 U.S.C. 133z–13","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-06-20/ch226/s204"},"text":"June 20, 1949, ch. 226, § 204","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/207"},"text":"63 Stat. 207","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “at the end of 10 calendar days . . . it is” are substituted for “before the expiration of ten calendar days . . . it shall then (but not before) be”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “A motion to discharge” are substituted for “Such motion”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7de01ce-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7de01cf-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/614"},"text":"Pub. L. 98–614","children":[],"tail":" substituted “75 calendar days” for “45 calendar days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/17"},"text":"Pub. L. 95–17","children":[],"tail":" substituted provisions deeming the committee discharged from further consideration of a resolution where that committee has not reported the resolution within 45 days of continuous session of Congress after the resolution’s introduction for provisions permitting a motion to discharge a committee where the committee considering a resolution has not reported the resolution within 20 calendar days after the resolution’s introduction, provisions permitting a motion to discharge to be made only by an individual favoring the resolution and limiting debate to 1 hour, and provisions prohibiting a renewal of a motion to discharge where the original motion was agreed to or disagreed to or the making of another motion with respect to a resolution from the same reorganization plan."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1971—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/179"},"text":"Pub. L. 92–179","children":[],"tail":" substituted “20 calendar days” for “10 calendar days”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
