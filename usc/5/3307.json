{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-06-27/ch452/s302"},"text":"June 27, 1956, ch. 452, § 302","children":[],"tail":" (less proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/70/355"},"text":"70 Stat. 355","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The prohibition is restated in positive form. The word “officers” is omitted as included in “employees” in view of the definition of “employee” in section 2105.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb80d9e55-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb80d9e56-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of Secretary, referred to in subsec. (b), see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2109"},"text":"section 2109 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb80d9e57-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" designated existing provisions as par. (1), substituted “Except as provided in paragraph (2), the” for “The”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161"},"text":"Pub. L. 110–161","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s3154/a/1"},"text":"Pub. L. 105–261, § 3154(a)(1)","children":[],"tail":", substituted “(d), (e), and (f)” for “and (d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s3154/a/2"},"text":"Pub. L. 105–261, § 3154(a)(2)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238/s103/a/1/A"},"text":"Pub. L. 100–238, § 103(a)(1)(A)","children":[],"tail":", substituted “may” for “may, with the concurrence of such agent as the President may designate,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238/s103/a/1/B"},"text":"Pub. L. 100–238, § 103(a)(1)(B)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/347"},"text":"Pub. L. 96–347","children":[],"tail":" substituted “Secretary” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/350/s1/1"},"text":"Pub. L. 93–350, § 1(1)","children":[],"tail":", inserted reference to subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/350/s1/2"},"text":"Pub. L. 93–350, § 1(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/297"},"text":"Pub. L. 92–297","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb80d9e58-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb80d9e59-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment; Transition Rules","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dE/tV/s535/e"},"text":"Pub. L. 110–161, div. E, title V, § 535(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2077"},"text":"121 Stat. 2077","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/161/dE/tV/s535/e"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this section [amending this section and sections 8331, 8334 to 8336, 8401, 8412, 8415, 8422, 8423, and 8425 of this title] shall become effective on the later of ","children":[{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", or the first day of the first pay period beginning at least 6 months after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition rules.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability of mandatory separation provisions to certain individuals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsections (a)(3) and (b)(6) [amending sections 8335 and 8425 of this title], respectively, shall not apply to an individual first appointed as a customs and border protection officer before the effective date under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of prior cbpo service","children":[],"tail":".—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in clause (ii), nothing in this section [amending this section and sections 8331, 8334 to 8336, 8401, 8412, 8415, 8422, 8423, and 8425 of this title and enacting provisions set out as a note under this section] or any amendment made by this section shall be considered to apply with respect to any service performed as a customs and border protection officer before the effective date under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Service described in section 8331(31) or 8401(36) of title 5, United States Code (as amended by this section) rendered before the effective date under paragraph (1) may be taken into account to determine if an individual who is serving on or after such effective date then qualifies as a customs and border protection officer by virtue of holding a supervisory or administrative position in the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum annuity amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The annuity of an individual serving as a customs and border protection officer on the effective date under paragraph (1) pursuant to an appointment made before that date shall, to the extent that its computation is based on service rendered as a customs and border protection officer on or after that date, be at least equal to the amount that would be payable—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent that such service is subject to the Civil Service Retirement System, by applying ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8339/d"},"text":"section 8339(d) of title 5","children":[],"tail":", United States Code, with respect to such service; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent such service is subject to the Federal Employees’ Retirement System, by applying section 8415(d) [now 8415(e)] of title 5, United States Code, with respect to such service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in the amendment made by subsection (c) [amending this section] shall be considered to apply with respect to any appointment made before the effective date under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incumbent defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this paragraph, the term ‘incumbent’ means an individual who is serving as a customs and border protection officer on the date of the enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the date of the enactment of this Act, the Director of the Office of Personnel Management shall take measures reasonably designed to ensure that incumbents are notified as to their election rights under this paragraph, and the effect of making or not making a timely election.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election available to incumbents.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An incumbent may elect, for all purposes, either—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be treated in accordance with the amendments made by subsection (a) or (b) [amending sections 8331, 8334 to 8336, 8401, 8412, 8415, 8422, 8423, and 8425 of this title], as applicable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be treated as if subsections (a) and (b) had never been enacted.","children":[{"tag":"p","attrib":{},"text":"  “Failure to make a timely election under this paragraph shall be treated in the same way as an election made under subclause (I) on the last day allowable under clause (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An election under this paragraph shall not be effective unless it is made at least 14 days before the effective date under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, the term ‘customs and border protection officer’ has the meaning given such term by section 8331(31) or 8401(36) of title 5, United States Code (as amended by this section).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusion","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section or any amendment made by this section shall be considered to afford any election or to otherwise apply with respect to any individual who, as of the day before the date of the enactment of this Act—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds a position within U.S. Customs and Border Protection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is considered a law enforcement officer for purposes of subchapter III of chapter 83 or chapter 84 of title 5, United States Code, by virtue of such position.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8100e5a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238/tI/s103/f"},"text":"Pub. L. 100–238, title I, § 103(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1745"},"text":"101 Stat. 1745","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/238/tI/s103/f"},"text":"“This section, and the amendments made by this section [amending this section and sections 8401 and 8704 of this title and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8334"},"text":"section 8334 of this title","children":[],"tail":"], shall be effective as of "},{"tag":"date","attrib":{"date":"1987-01-01"},"text":"January 1, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8100e5b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/347"},"text":"Pub. L. 96–347","children":[],"tail":" effective on 90th day after "},{"tag":"date","attrib":{"date":"1980-09-12"},"text":"Sept. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/347/s3"},"text":"section 3 of Pub. L. 96–347","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2109"},"text":"section 2109 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8100e5c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/93/350/s7"},"text":"Pub. L. 93–350, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/356"},"text":"88 Stat. 356","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/93/350/s7"},"text":"“The amendments made by the first section [amending this section], and sections 2(b), 5, and 6 [amending sections 8331, 8336, and 8339 of this title], of this Act shall become effective on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":"]. The amendments made by sections 2(a) and 3 [amending sections 8331 and 8334 of this title] of this Act shall become effective at the beginning of the first applicable pay period which begins after "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"December 31, 1974","children":[],"tail":". The amendment made by section 4 of this Act [amending "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8335"},"text":"section 8335 of this title","children":[],"tail":"] shall become effective on "},{"tag":"date","attrib":{"date":"1978-01-01"},"text":"January 1, 1978","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8100e5d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1972 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/297"},"text":"Pub. L. 92–297","children":[],"tail":" effective on 90th day after "},{"tag":"date","attrib":{"date":"1972-05-16"},"text":"May 16, 1972","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/92/297/s10"},"text":"section 10 of Pub. L. 92–297","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3381"},"text":"section 3381 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8100e5e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dE/tV/s535/d"},"text":"Pub. L. 110–161, div. E, title V, § 535(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2077"},"text":"121 Stat. 2077","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/161/dE/tV/s535/d"},"text":"“Any regulations necessary to carry out the amendments made by this section [amending this section and sections 8331, 8334 to 8336, 8401, 8412, 8415, 8422, 8423, and 8425 of this title] shall be prescribed by the Director of the Office of Personnel Management in consultation with the Secretary of Homeland Security.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8100e5f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"United States Park Police; Age Limits for Original Appointments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/73"},"text":"Pub. L. 91–73","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1969-09-26"},"text":"Sept. 26, 1969","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/116"},"text":"83 Stat. 116","children":[],"tail":", which provided for age limits for appointments to the United States Park Police, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/92/297/s11"},"text":"Pub. L. 92–297, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-16"},"text":"May 16, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/145"},"text":"86 Stat. 145","children":[],"tail":", effective at the end of the 89th day after "},{"tag":"date","attrib":{"date":"1972-05-16"},"text":"May 16, 1972","children":[],"tail":". The Secretary of the Interior may fix age limits for appointment under subsec. (c) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb8100e60-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idb8100e61-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Ex. Ord. No. 11817. Office of Personnel Management Designated Agent To Concur With Agency Determination Fixing Age Limits for Making Original Appointments Respecting Law Enforcement Officer and Firefighter Positions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 11817, ","children":[{"tag":"date","attrib":{"date":"1974-11-05"},"text":"Nov. 5, 1974","children":[],"tail":", 39 F.R. 39427, as amended by Ex. Ord. No. 12107, "},{"tag":"date","attrib":{"date":"1978-12-28"},"text":"Dec. 28, 1978","children":[],"tail":", 44 F.R. 1055, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"By virtue of the authority vested in me by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3307/d"},"text":"section 3307(d) of title 5","children":[],"tail":" of the United States Code, as added by the first section of the Act of "},{"tag":"date","attrib":{"date":"1974-07-12"},"text":"July 12, 1974","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/93/350"},"text":"Public Law 93–350","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/88/355"},"text":"88 Stat. 355","children":[],"tail":"), I hereby designate the Office of Personnel Management as the agency to concur with determinations made by agencies to fix the minimum and maximum limits of age within which an original appointment may be made to a position as a law enforcement officer or firefighter, as defined by section 8331(20) and (21), respectively, of title 5 of the United States Code. The designation made by this order shall be effective as of "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"October 15, 1974","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
