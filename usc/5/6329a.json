{"tag":"section","attrib":{"id":"idb89cbeba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6329a"},"text":"§ 6329a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative leave","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89cbebb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbebc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “administrative leave” means leave—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89cbebd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" without loss of or reduction in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb89cbebe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb89cbebf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leave to which an employee is otherwise entitled under law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb89cbec0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credit for time or service; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89cbec1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not authorized under any other provision of law;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbec2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “agency”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89cbec3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means an Executive agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89cbec4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the Department of Veterans Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89cbec5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the Government Accountability Office; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbec6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “employee”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89cbec7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term in section 2105; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89cbec8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include an intermittent employee who does not have an established regular tour of duty during the administrative workweek.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbec9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Leave.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbeca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During any calendar year, an agency may place an employee in administrative leave for a period of not more than a total of 10 work days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbecb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An agency shall record administrative leave separately from leave authorized under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbecc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89cbecd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"OPM regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 270 calendar days after the date of enactment of this section, the Director of the Office of Personnel Management shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89cbece-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe regulations to carry out this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89cbecf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prescribe regulations that provide guidance to agencies regarding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb89cbed0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acceptable agency uses of administrative leave; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb89cbed1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the proper recording of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb89cbed2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/c/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative leave; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb89cbed3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/c/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other leave authorized by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89cbed4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 270 calendar days after the date on which the Director of the Office of Personnel Management prescribes regulations under paragraph (1), each agency shall revise and implement the internal policies of the agency to meet the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89cbed5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6329a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relation to Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7421"},"text":"section 7421 of title 38","children":[],"tail":", this section shall apply to an employee described in subsection (b) of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89cbed6-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXI/s1138/c/1"},"text":"Pub. L. 114–328, div. A, title XI, § 1138(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2461"},"text":"130 Stat. 2461","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb89cbed7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89cbed8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb89cbed9-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (c)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb89cbeda-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb89cbedb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Sense of Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXI/s1138/b"},"text":"Pub. L. 114–328, div. A, title XI, § 1138(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2460"},"text":"130 Stat. 2460","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dA/tXI/s1138/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“It is the sense of Congress that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" agency use of administrative leave, and leave that is referred to incorrectly as administrative leave in agency recording practices, has exceeded reasonable amounts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in contravention of—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" established precedent of the Comptroller General of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" guidance provided by the Office of Personnel Management; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resulting in significant cost to the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative leave should be used sparingly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prior to the use of paid leave to address personnel issues, an agency should consider other actions, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" temporary reassignment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an agency should prioritize and expeditiously conclude an investigation in which an employee is placed in administrative leave so that, not later than the conclusion of the leave period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee is returned to duty status; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate personnel action is taken with respect to the employee;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" data show that there are too many examples of employees placed in administrative leave for 6 months or longer, leaving the employees without any available recourse to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" return to duty status; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" challenge the decision of the agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency should ensure accurate and consistent recording of the use of administrative leave so that administrative leave can be managed and overseen effectively; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other forms of excused absence authorized by law should be recorded separately from administrative leave, as defined by the amendments made by this section [see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1138a"},"text":"section 1138a of Pub. L. 114–328","children":[],"tail":" set out as a Short Title of 2016 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s101"},"text":"section 101 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb89cbedc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"GAO Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXI/s1138/d/2"},"text":"Pub. L. 114–328, div. A, title XI, § 1138(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2468"},"text":"130 Stat. 2468","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dA/tXI/s1138/d/2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 5 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":"], and every 5 years thereafter, the Comptroller General of the United States shall submit to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Oversight and Government Reform [now Committee on Oversight and Accountability] of the House of Representatives a report on the results of an evaluation of the implementation of the authority provided under sections 6329a and 6329b of title 5, United States Code, as added by subsection (c)(1) of this section and paragraph (1) of this subsection, respectively, including—"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of times that an agency, under subsection (c)(1) of such section 6329b—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consulted with the investigator responsible for conducting the investigation to which an employee was subject with respect to the decision of the agency to grant an extension under that subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" did not have a consultation described in clause (i), including the reasons that the agency failed to have such a consultation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the use of the authority provided under subsection (d) of such section 6329b by agencies, including data regarding the number and length of extensions granted under that subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the compliance with the requirements of subsection (f) of such section 6329b by agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of the practice of agency placement of an employee in investigative or notice leave under subsection (b) of such section 6329b because of a determination under subsection (b)(2)(A)(iv) of that section that the employee jeopardized legitimate Government interests, including the extent to which such determinations were supported by evidence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the effectiveness of subsection (g) of such section 6329b in preventing and correcting the use of extended investigative leave as a tool of reprisal for making a protected disclosure or engaging in protected activity as described in paragraph (8) or (9) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2302/b"},"text":"section 2302(b) of title 5","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
