{"tag":"section","attrib":{"id":"idb83179c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4802"},"text":null,"children":[{"tag":"num","attrib":{"value":"4802"},"text":"§ 4802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Securities and Exchange Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb83179ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, the term “Commission” means the Securities and Exchange Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb83179cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission may appoint and fix the compensation of such officers, attorneys, economists, examiners, and other employees as may be necessary for carrying out its functions under the securities laws as defined under section 3 of the Securities Exchange Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78c"},"text":"15 U.S.C. 78c","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb83179cc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4802/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rates of basic pay for all employees of the Commission may be set and adjusted by the Commission without regard to the provisions of chapter 51 or subchapter III of chapter 53.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb83179cd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4802/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission may provide additional compensation and benefits to employees of the Commission if the same type of compensation or benefits are then being provided by any agency referred to under section 1206 of the Financial Institutions Reform, Recovery, and Enforcement Act of 1989 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1833b"},"text":"12 U.S.C. 1833b","children":[],"tail":") or, if not then being provided, could be provided by such an agency under applicable provisions of law, rule, or regulation. In setting and adjusting the total amount of compensation and benefits for employees, the Commission shall consult with, and seek to maintain comparability with, the agencies referred to under section 1206 of the Financial Institutions Reform, Recovery, and Enforcement Act of 1989 ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1833b"},"text":"12 U.S.C. 1833b","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb83179ce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4802/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall consult with the Office of Personnel Management in the implementation of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb83179cf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4802/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall be administered consistent with merit system principles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb83179d0-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/123/s8/a"},"text":"Pub. L. 107–123, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-16"},"text":"Jan. 16, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2398"},"text":"115 Stat. 2398","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb83179d1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb83179d2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb83179d3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2001-10-01"},"text":"Oct. 1, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/123/s11"},"text":"section 11 of Pub. L. 107–123","children":[],"tail":", set out as an Effective Date of 2002 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78ee"},"text":"section 78ee of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb83179d4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Employees Represented by Labor Organizations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/123/s8/b"},"text":"Pub. L. 107–123, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-16"},"text":"Jan. 16, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2398"},"text":"115 Stat. 2398","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/123/s8/b"},"text":"“To the extent that any employee of the Securities and Exchange Commission is represented by a labor organization with exclusive recognition in accordance with chapter 71 of title 5, United States Code, no reduction in base pay of such employee shall be made by reason of enactment of this section [enacting this chapter, amending sections 3132 and 5373 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1833b"},"text":"section 1833b of Title 12","children":[],"tail":", Banks and Banking, and "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78d"},"text":"section 78d of Title 15","children":[],"tail":", Commerce and Trade, and enacting provisions set out as a note under this section] (including the amendments made by this section).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb83179d5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation Plan and Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/123/s8/c"},"text":"Pub. L. 107–123, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-01-16"},"text":"Jan. 16, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/2398"},"text":"115 Stat. 2398","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/123/s8/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation plan.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Securities and Exchange Commission shall develop a plan to implement ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4802"},"text":"section 4802 of title 5","children":[],"tail":", United States Code, as added by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion in annual performance plan and report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Securities and Exchange Commission shall include—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan developed under this paragraph in the annual program performance plan submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1115"},"text":"section 1115 of title 31","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effects of implementing the plan developed under this paragraph in the annual program performance report submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1116"},"text":"section 1116 of title 31","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation report.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before implementing the plan developed under paragraph (1), the Securities and Exchange Commission shall submit a report to the Committee on Governmental Affairs [now Committee on Homeland Security and Governmental Affairs] and the Committee on Banking, Housing, and Urban Affairs of the Senate, the Committee on Government Reform [now Committee on Oversight and Accountability] and the Committee on Financial Services of the House of Representatives, and the Office of Personnel Management on the details of the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under this paragraph shall include—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evidence and supporting documentation justifying the plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" budgeting projections on costs and benefits resulting from the plan.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
