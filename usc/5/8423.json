{"tag":"section","attrib":{"id":"idb8fc1c3a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423"},"text":null,"children":[{"tag":"num","attrib":{"value":"8423"},"text":"§ 8423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government contributions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8fc1c3b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fc1c3c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each employing agency having any employees or Members subject to section 8422(a) shall contribute to the Fund an amount equal to the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fc1c3d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8fc1c3e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the normal-cost percentage, as determined for employees (other than employees covered by subparagraph (B)), multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8fc1c3f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of basic pay payable by the agency, for the period involved, to employees (under clause (i)) who are within such agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fc1c40-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the product of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8fc1c41-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the normal-cost percentage, as determined for Members, Congressional employees (including a separate normal-cost percentage for Congressional employees that are members of the Capitol Police covered under subsection (d) of section 8412 and subsection (c) of section 8425), law enforcement officers, members of the Supreme Court Police, firefighters, nuclear materials couriers, customs and border protection officers, air traffic controllers, military reserve technicians, and employees under sections 302 and 303 of the Central Intelligence Agency Retirement Act, multiplied by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8fc1c42-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aggregate amount of basic pay payable by the agency, for the period involved, to employees and Members (under clause (i)) who are within such agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fc1c43-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fc1c44-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In determining any normal-cost percentage to be applied under this subsection, amounts provided for under section 8422 shall be taken into account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fc1c45-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb8fc1c46-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to clauses (ii) and (iii), for purposes of any period in any year beginning after ","children":[{"tag":"date","attrib":{"date":"2013-12-31"},"text":"December 31, 2013","children":[],"tail":", the normal-cost percentage under this subsection shall be determined and applied as if section 401(b) of the Bipartisan Budget Act of 2013 had not been enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8fc1c47-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any contributions under this subsection in excess of the amounts which (but for clause (i)) would otherwise have been payable shall be applied toward reducing the unfunded liability of the Civil Service Retirement System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8fc1c48-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After the unfunded liability of the Civil Service Retirement System has been eliminated, as determined by the Office, Government contributions under this subsection shall be determined and made disregarding this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8fc1c49-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The preceding provisions of this subparagraph shall be disregarded for purposes of determining the contributions payable by the United States Postal Service and the Postal Regulatory Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fc1c4a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Contributions under this subsection shall be paid—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fc1c4b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of law enforcement officers, members of the Supreme Court Police, firefighters, nuclear materials couriers, customs and border protection officers, air traffic controllers, military reserve technicians, and other employees, from the appropriation or fund used to pay such law enforcement officers, members of the Supreme Court Police, firefighters, nuclear materials couriers, customs and border protection officers, air traffic controllers, military reserve technicians, or other employees, respectively;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fc1c4c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of elected officials, from an appropriation or fund available for payment of other salaries of the same office or establishment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fc1c4d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of employees of the legislative branch paid by the Chief Administrative Officer of the House of Representatives, from the applicable accounts of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fc1c4e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contribution to the Fund under this subsection shall be deposited under such procedures as the Comptroller General of the United States may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fc1c4f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fc1c50-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office shall compute—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fc1c51-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the supplemental liability of the Fund with respect to individuals other than those to whom subparagraph (B) relates, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fc1c52-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the supplemental liability of the Fund with respect to current or former employees of the United States Postal Service (and the Postal Regulatory Commission) and their survivors;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"as of the close of each fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"1987-09-30"},"text":"September 30, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fc1c53-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of any supplemental liability computed under paragraph (1)(A) or (1)(B) shall be amortized in 30 equal annual installments, with interest computed at the rate used in the most recent valuation of the System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fc1c54-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At the end of each fiscal year, the Office shall notify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fc1c55-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury of the amount of the installment computed under this subsection for such year with respect to individuals under paragraph (1)(A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fc1c56-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Postmaster General of the United States of the amount of the installment computed under this subsection for such year with respect to individuals under paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fc1c57-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fc1c58-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before closing the accounts for a fiscal year, the Secretary of the Treasury shall credit to the Fund, as a Government contribution, out of any money in the Treasury of the United States not otherwise appropriated, the amount under paragraph (3)(A) for such year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fc1c59-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon receiving notification under paragraph (3)(B), the United States Postal Service shall pay the amount specified in such notification to the Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fc1c5a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of carrying out paragraph (1) with respect to any fiscal year, the Office may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fc1c5b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the Board of Actuaries of the Civil Service Retirement System to make actuarial determinations and valuations, make recommendations, and maintain records in the same manner as provided in section 8347(f); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fc1c5c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the latest actuarial determinations and valuations made by such Board of Actuaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fc1c5d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8423/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Office, the head of an agency may request reconsideration of any amount determined to be payable with respect to such agency under subsection (a) or (b). Any such request shall be referred to the Board of Actuaries of the Civil Service Retirement System. The Board of Actuaries shall review the computations of the Office and may make any adjustment with respect to any such amount which the Board determines appropriate. A determination by the Board of Actuaries under this subsection shall be final.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fc1c5e-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/537"},"text":"100 Stat. 537","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/66"},"text":"Pub. L. 102–378, § 2(66)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1354"},"text":"106 Stat. 1354","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/496/tVIII/s803/c"},"text":"Pub. L. 102–496, title VIII, § 803(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3253"},"text":"106 Stat. 3253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s215/15"},"text":"Pub. L. 104–186, title II, § 215(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1746"},"text":"110 Stat. 1746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dC/tXXXI/s3154/j"},"text":"Pub. L. 105–261, div. C, title XXXI, § 3154(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2256"},"text":"112 Stat. 2256","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/553/s1/a/2/tIII/s308/c/4"},"text":"Pub. L. 106–553, § 1(a)(2) [title III, § 308(c)(4)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2762"},"text":"114 Stat. 2762","children":[],"tail":", 2762A–87; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tVI/s604/b"},"text":"Pub. L. 109–435, title VI, § 604(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3241"},"text":"120 Stat. 3241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dE/tV/s535/b/5"},"text":"Pub. L. 110–161, div. E, title V, § 535(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2076"},"text":"121 Stat. 2076","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/tIV/s401/c"},"text":"Pub. L. 113–67, div. A, title IV, § 401(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-12-26"},"text":"Dec. 26, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/127/1184"},"text":"127 Stat. 1184","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/94/dE/tII/s211"},"text":"Pub. L. 116–94, div. E, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2773"},"text":"133 Stat. 2773","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fc1c5f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8fc1c60-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8fc1c61-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 302 and 303 of the Central Intelligence Agency Retirement Act, referred to in subsec. (a)(1)(B)(i), are classified to sections 2152 and 2153, respectively, of Title 50, War and National Defense.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 401(b) of the Bipartisan Budget Act of 2013, referred to in subsec. (a)(2)(B)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67/dA/s401/b"},"text":"section 401(b) of div. A of Pub. L. 113–67","children":[],"tail":", which amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8422"},"text":"section 8422 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8fc1c62-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1)(B)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94"},"text":"Pub. L. 116–94","children":[],"tail":" inserted “(including a separate normal-cost percentage for Congressional employees that are members of the Capitol Police covered under subsection (d) of section 8412 and subsection (c) of section 8425)” after “Congressional employees”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/67"},"text":"Pub. L. 113–67","children":[],"tail":" designated existing provisions as subpar. (A) and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(1)(B)(i), (3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161"},"text":"Pub. L. 110–161","childr