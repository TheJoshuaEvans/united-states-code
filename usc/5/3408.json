{"tag":"section","attrib":{"id":"idb820b05e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3408"},"text":null,"children":[{"tag":"num","attrib":{"value":"3408"},"text":"§ 3408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee organization representation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If an employee organization has been accorded exclusive recognition with respect to a unit within an agency, then the employee organization shall be entitled to represent all employees within that unit employed on a part-time career employment basis.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb820b05f-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/437/s3/a"},"text":"Pub. L. 95–437, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1058"},"text":"92 Stat. 1058","children":[],"tail":", § 3398; renumbered § 3408, "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/c/1/B"},"text":"Pub. L. 95–454, title IX, § 906(c)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1226"},"text":"92 Stat. 1226","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb820b060-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb820b061-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb820b062-5e84-11f1-a692-ec26948f6fea"},"text":null,"ch