{"tag":"section","attrib":{"id":"idb8fe8d25-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b"},"text":null,"children":[{"tag":"num","attrib":{"value":"8432b"},"text":"§ 8432b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contributions of persons who perform military service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8fe8d26-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section applies to any employee who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fe8d27-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separates or enters leave-without-pay status in order to perform military service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d28-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subsequently restored to or reemployed in a position which is subject to this chapter, pursuant to chapter 43 of title 38.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fe8d29-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fe8d2a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each employee to whom this section applies may contribute to the Thrift Savings Fund, in accordance with this subsection, an amount not to exceed the amount described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d2b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The maximum amount which an employee may contribute under this subsection is equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fe8d2c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contributions under section 8432(a) which would have been made, over the period beginning on date of separation or commencement of leave-without-pay status (as applicable) and ending on the day before the date of restoration or reemployment (as applicable); reduced by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fe8d2d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contributions under section 8432(a) or 8440e actually made by such employee over the period described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d2e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Contributions under this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fe8d2f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made at the same time and in the same manner as would any contributions under section 8432(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fe8d30-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made over the period of time specified by the employee under paragraph (4)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fe8d31-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in addition to any contributions then actually being made under section 8432(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d32-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Executive Director shall prescribe the time, form, and manner in which an employee may specify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fe8d33-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount such employee wishes to contribute under this subsection with respect to any particular period referred to in paragraph (2)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fe8d34-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of time over which the employee wishes to make contributions under this subsection.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The employing agency may place a maximum limit on the period of time referred to in subparagraph (B), which cannot be shorter than two times the period referred to in paragraph (2)(B) and not longer than four times such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fe8d35-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fe8d36-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If an employee makes contributions under subsection (b), the employing agency shall make contributions to the Thrift Savings Fund on such employee’s behalf—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fe8d37-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the same manner as would be required under section 8432(c)(2) if the employee contributions were being made under section 8432(a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fe8d38-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disregarding any contributions then actually being made under section 8432(a) and any agency contributions relating thereto.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d39-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee to whom this section applies is entitled to have contributed to the Thrift Savings Fund on such employee’s behalf an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fe8d3a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total contributions to which that individual would have been entitled under section 8432(c)(2), based on the amounts contributed by such individual under section 8440e (other than under subsection (d)(2) thereof) with respect to the period referred to in subsection (b)(2)(B), if those amounts had been contributed by such individual under section 8432(a); reduced by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fe8d3b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contributions actually made on such employee’s behalf under section 8432(c)(2) with respect to the period referred to in subsection (b)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fe8d3c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee to whom this section applies is entitled to have contributed to the Thrift Savings Fund on such employee’s behalf an amount equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fe8d3d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 percent of such employee’s basic pay (as determined under subsection (e)) for the period referred to in subsection (b)(2)(B); reduced by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d3e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any contributions actually made on such employee’s behalf under section 8432(c)(1) with respect to the period referred to in subsection (b)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fe8d3f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of any computation under this section, an employee shall, with respect to the period referred to in subsection (b)(2)(B), be considered to have been paid at the rate which would have been payable over such period had such employee remained continuously employed in the position which such employee last held before separating or entering leave-without-pay status to perform military service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fe8d40-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fe8d41-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The employing agency may be required to pay lost earnings on contributions made pursuant to subsections (c) and (d). Such earnings, if required, shall be calculated retroactively to the date the contribution would have been made had the employee not separated or entered leave without pay status to perform military service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d42-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Procedures for calculating and crediting the earnings payable pursuant to paragraph (1) shall be prescribed by the Executive Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fe8d43-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts paid under subsection (c), (d), or (f) shall be paid—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fe8d44-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the agency to which the employee is restored or in which such employee is reemployed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d45-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from the same source as would be the case under section 8432(e) with respect to sums required under section 8432(c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d46-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the time prescribed by the Executive Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fe8d47-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8fe8d48-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of section 8432(g), in the case of an employee to whom this section applies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fe8d49-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a separation from civilian service in order to perform the military service on which the employee’s restoration or reemployment rights are based shall be disregarded; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fe8d4a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such employee shall be credited with a period of civilian service equal to the period referred to in subsection (b)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8fe8d4b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8fe8d4c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee to whom this section applies may elect, for purposes of subsection (d) or (f) of section 8433, as the case may be, to have such employee’s separation (described in subsection (a)(1)) treated as if it had never occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8fe8d4d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An election under this paragraph shall be made within such period of time after restoration or reemployment (as the case may be) and otherwise in such manner as the Executive Director prescribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8fe8d4e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8432b/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Director shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8fe8d4f-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/353/s4/a/1"},"text":"Pub. L. 103–353, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3170"},"text":"108 Stat. 3170","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s661/a/3/A"},"text":"Pub. L. 106–65, div. A, title VI, § 661(a)(3)(A)","children":[],"tail":", (C), "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/671"},"text":"113 Stat. 671","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tVI/s632/e/2"},"text":"Pub. L. 114–92, div. A, title VI, § 632(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/847"},"text":"129 Stat. 847","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/84/s2/e"},"text":"Pub. L. 115–84, § 2(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-11-17"},"text":"Nov. 17, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1273"},"text":"131 Stat. 1273","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8fe8d50-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8fe8d51-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8fe8d52-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—Subsec. (h)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/84"},"text":"Pub. L. 115–84","children":[],"tail":" substituted “subsection (d) or (f) of section 8433” for “section 8433(d), or paragraph (1) or (2) of section 8433(h)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" struck out “(including pursuant to an agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s211/d"},"text":"section 211(d) of title 37","children":[],"tail":")” before “with respect to the period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s661/a/3/A"},"text":"Pub. L. 106–65, § 661(a)(3)(A)","children":[],"tail":", inserted “or 8440e” after “section 8432(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65/s661/a/3/C"},"text":"Pub. L. 106–65, § 661(a)(3)(C)","children":[],"tail":", designated existing provisions as par. (1), redesignated former pars. (1) and (2) as subpars. (A) and (B), respectively, of par. (1), and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8fe8d53-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8fe8d54-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/84/s2/g"},"text":"Pub. L. 115–84, § 2(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-11-17"},"text":"Nov. 17, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1273"},"text":"131 Stat. 1273","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/84/s2/g"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8433"},"text":"section 8433 of this title","children":[],"tail":"] shall take effect on the date on which the regulations prescribed under subsection (f) ["},{"tag":"ref","attrib":{"href":"/us/pl/115/84/s2/f"},"text":"section 2(f) of Pub. L. 115–84","children":[],"tail":", set out as a Regulations note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8433"},"text":"section 8433 of this title","children":[],"tail":"] take effect ["},{"tag":"date","attrib":{"date":"2019-09-15"},"text":"Sept. 15, 2019","children":[],"tail":"; see 84 F.R. 46419].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8fe8d55-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment; Implementation","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2018-01-01"},"text":"Jan. 1, 2018","children":[],"tail":", with certain implementation requirements, see "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/s635"},"text":"section 635 of Pub. L. 114–92","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432"},"text":"section 8432 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8fe8d56-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", unless postponed, see "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s663"},"text":"section 663 of Pub. L. 106–65","children":[],"tail":", as amended, set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8440e"},"text":"section 8440e of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8fe8d57-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/353/s4/e"},"text":"Pub. L. 103–353, § 4(e)","children":[],"tail":", (f), "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3172"},"text":"108 Stat. 3172","children":[],"tail":", 3173, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/353/s4/e"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date; Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section [enacting this section and amending sections 8351, 8432, and 8433 of this title] and the amendments made by this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall apply to any employee whose release from military service, discharge from hospitalization, or other similar event making the individual eligible to seek restoration or reemployment under chapter 43 of title 38, United States Code, occurs on or after ","children":[{"tag":"date","attrib":{"date":"1990-08-02"},"text":"August 2, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rules for Applying Amendments to Employees Restored or Reemployed Before Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any employee (described in subsection (e)(2)) who is reemployed or restored (in the circumstances described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432b/a"},"text":"section 8432b(a) of title 5","children":[],"tail":", United States Code, as amended by this section) before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":"], the amendments made by this section [enacting this section and amending sections 8351, 8432, and 8433 of this title] shall apply to such employee, in accordance with their terms, subject to the following:"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The employee shall be deemed not to have been reemployed or restored until—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of enactment of this Act, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first day following such employee’s reemployment or restoration on which such employee is or was eligible to make an election relating to contributions to the Thrift Savings Fund,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whichever occurs or occurred first.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the employee changed agencies during the period between the date of actual reemployment or restoration and the date of enactment of this Act, the employing agency as of such date of enactment shall be considered the reemploying or restoring agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of any computation under section 8432b of such title, pay shall be determined in accordance with subsection (e) of such section, except that, with respect to the period described in subparagraph (B), actual pay attributable to such period shall be used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The period described in this subparagraph is the period beginning on the first day of the first applicable pay period beginning on or after the date of the employee’s actual reemployment or restoration and ending on the day before the date determined under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Deem section 8432b(b)(2)(A) of such title to be amended by striking ‘ending on the day before the date of restoration or reemployment (as applicable)’ and inserting ‘ending on the date determined under section 4(f)(1) of the Uniformed Services Employment and Reemployment Rights Act of 1994’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
