{"tag":"section","attrib":{"id":"idb81bf639-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381"},"text":null,"children":[{"tag":"num","attrib":{"value":"3381"},"text":"§ 3381.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb81bf63a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An air traffic controller with 5 years of service as a controller who is to be removed as a controller because the Secretary has determined—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81bf63b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he is medically disqualified for duties as a controller;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81bf63c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" he is unable to maintain technical proficiency as a controller; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81bf63d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such removal is necessary for the preservation of the physical or mental health of the controller;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is entitled to not more than the full-time equivalent of 2 years of training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81bf63e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" During a period of training under this section, a controller shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81bf63f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retained at his last assigned grade and rate of basic pay as a controller;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81bf640-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" entitled to each increase in rate of basic pay provided under law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81bf641-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" excluded from staffing limitations otherwise applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81bf642-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Upon completion of training under this section, a controller may be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81bf643-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assigned to other duties in the Executive agency in which the controller is employed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81bf644-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" released for transfer to another Executive agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81bf645-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involuntarily separated from the service.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The involuntary separation of a controller under this subsection is not a removal for cause on charges of misconduct, delinquency, or inefficiency for purposes of section 5595 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8336"},"text":"section 8336 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81bf646-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, without regard to section 3324(a) and (b) of title 31, may pay, or reimburse a controller for, all or part of the necessary expenses of training provided under this section, including expenses authorized to be paid under chapter 41 and subchapter I of chapter 57 of this title, and the costs of other services or facilities directly related to the training of a controller.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81bf647-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided by subsection (d) of this section, the provisions of chapter 41 of this title, other than sections 4105, 4107(a) and (b),","children":[{"tag":"ref","attrib":{"idref":"fn002060"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002060"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and 4111, shall not apply to training under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81bf648-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3381/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this section shall not otherwise affect the authority of the Secretary to provide training under chapter 41 of this title or under any other provision of law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb81bf649-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/297/s3/a"},"text":"Pub. L. 92–297, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-16"},"text":"May 16, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/142"},"text":"86 Stat. 142","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/347/s1/b"},"text":"Pub. L. 96–347, § 1(b)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"1980-09-12"},"text":"Sept. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1150"},"text":"94 Stat. 1150","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/a/7"},"text":"Pub. L. 97–258, § 3(a)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1063"},"text":"96 Stat. 1063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/226/s2/b/1"},"text":"Pub. L. 103–226, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-30"},"text":"Mar. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/112"},"text":"108 Stat. 112","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb81bf64a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb81bf64b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb81bf64c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of Secretary, referred to in subsec. (a), see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2109"},"text":"section 2109 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4107"},"text":"section 4107 of this title","children":[],"tail":", referred to in subsec. (e), were struck out, and subsecs. (c) and (d) of section 4107 were redesignated (a) and (b), respectively, by "},{"tag":"ref","attrib":{"href":"/us/pl/103/226/s2/a/5/B"},"text":"Pub. L. 103–226, § 2(a)(5)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-30"},"text":"Mar. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/112"},"text":"108 Stat. 112","children":[],"tail":". Subsequently, section 4107 was amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1331/a"},"text":"Pub. L. 107–296, title XIII, § 1331(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2298"},"text":"116 Stat. 2298","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb81bf64d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226"},"text":"Pub. L. 103–226","children":[],"tail":" substituted “4105,” for “4105(a),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":" substituted “section 3324(a) and (b)” for “section 529”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/347/s1/b"},"text":"Pub. L. 96–347, § 1(b)","children":[],"tail":", substituted “Secretary” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/347/s1/c/1"},"text":"Pub. L. 96–347, § 1(c)(1)","children":[],"tail":", substituted “in the Executive agency in which the controller is employed” for “in the Department of Transportation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb81bf64e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb81bf64f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226/s2/c"},"text":"Pub. L. 103–226, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-30"},"text":"Mar. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/112"},"text":"108 Stat. 112","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/226/s2/c"},"text":"“The amendments made by this section [amending this section and sections 4101, 4103, 4105, 4107, 4108, 4113, and 4118 of this title and repealing sections 4106 and 4114 of this title] shall become effective on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-03-30"},"text":"Mar. 30, 1994","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb81bf650-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/347"},"text":"Pub. L. 96–347","children":[],"tail":" effective on 90th day after "},{"tag":"date","attrib":{"date":"1980-09-12"},"text":"Sept. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/347/s3"},"text":"section 3 of Pub. L. 96–347","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2109"},"text":"section 2109 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb81bf651-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/297/s10"},"text":"Pub. L. 92–297, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-16"},"text":"May 16, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/145"},"text":"86 Stat. 145","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/92/297/s10"},"text":"“This Act [enacting this subchapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2109"},"text":"section 2109 of this title","children":[],"tail":", amending sections 3307, 8332, 8334 to 8336, 8339, 8341, 8344 of this title, enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8335"},"text":"section 8335 of this title","children":[],"tail":", and repealing provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3307"},"text":"section 3307 of this title","children":[],"tail":"] shall become effective at the beginning of the ninetieth day after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1972-05-16"},"text":"May 16, 1972","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb81bf652-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congress","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/92/297/s9"},"text":"Pub. L. 92–297, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-16"},"text":"May 16, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/145"},"text":"86 Stat. 145","children":[],"tail":", directed the Secretary of Transportation to report to Congress no later than 5 years after "},{"tag":"date","attrib":{"date":"1972-05-16"},"text":"May 16, 1972","children":[],"tail":", concerning his operations under the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/92/297"},"text":"Pub. L. 92–297","children":[],"tail":", including a detailed statement of the effectiveness of "},{"tag":"ref","attrib":{"href":"/us/pl/92/297"},"text":"Pub. L. 92–297","children":[],"tail":" in meeting the needs of the Air Traffic Controller career program and of the air traffic control system plus recommendations for the management of the program or the system."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
