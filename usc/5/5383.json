{"tag":"section","attrib":{"id":"idb86114a6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5383"},"text":null,"children":[{"tag":"num","attrib":{"value":"5383"},"text":"§ 5383.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Setting individual senior executive pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb86114a7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5383/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each appointing authority shall determine, in accordance with criteria established by the Office of Personnel Management, which of the rates within a range established under section 5382 shall be paid to each senior executive under such appointing authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86114a8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5383/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Senior Executive Service shall be subject to the limitation under section 5307.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86114a9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5383/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in regulations prescribed by the Office under section 5385, the rate of basic pay for any senior executive may not be adjusted more than once during any 12-month period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86114aa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5383/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rate of basic pay for any career appointee may be reduced from any rate of basic pay to any lower rate of basic pay only if the career appointee receives a written notice of the reduction at least 15 days in advance of the reduction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86114ab-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5383/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86114ac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5383/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This subsection applies to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86114ad-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5383/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any individual who, after serving at least 5 years of current continuous service in 1 or more positions in the competitive service, is appointed, without any break in service, as a career appointee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86114ae-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5383/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any individual who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb86114af-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5383/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holds a position which is converted from the competitive service to a career reserved position in the Senior Executive Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb86114b0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5383/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of the conversion date, has at least 5 years of current continuous service in 1 or more positions in the competitive service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86114b1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5383/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86114b2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5383/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The initial rate of pay for a career appointee who is appointed under the circumstances described in paragraph (1)(A) may not be less than the rate of basic pay last payable to that individual immediately before being so appointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86114b3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5383/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The initial rate of pay for a career appointee following the position’s conversion (as described in paragraph (1)(B)) may not be less than the rate of basic pay last payable to that individual immediately before such position’s conversion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86114b4-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIV/s407/a"},"text":"Pub. L. 95–454, title IV, § 407(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1171"},"text":"92 Stat. 1171","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/166/s3"},"text":"Pub. L. 96–166, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-12-29"},"text":"Dec. 29, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/1273"},"text":"93 Stat. 1273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/tIII/s305"},"text":"Pub. L. 98–615, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3219"},"text":"98 Stat. 3219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s101/b/7"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 101(b)(7)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1440; "},{"tag":"ref","attrib":{"href":"/us/pl/102/175/s2"},"text":"Pub. L. 102–175, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-02"},"text":"Dec. 2, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1222"},"text":"105 Stat. 1222","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/35"},"text":"Pub. L. 102–378, § 2(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1351"},"text":"106 Stat. 1351","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXI/s1125/a/3"},"text":"Pub. L. 108–136, div. A, title XI, § 1125(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1639"},"text":"117 Stat. 1639","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb86114b5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb86114b6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb86114b7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1125/a/3/A"},"text":"Pub. L. 108–136, § 1125(a)(3)(A)","children":[],"tail":", substituted “which of the rates within a range established under section 5382” for “which of the rates established under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1125/a/3/B"},"text":"Pub. L. 108–136, § 1125(a)(3)(B)","children":[],"tail":", substituted “as provided in regulations prescribed by the Office under section 5385” for “for any pay adjustment under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5382"},"text":"section 5382 of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378"},"text":"Pub. L. 102–378","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, subsec. (b) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) In no event may the aggregate amount paid to a senior executive during any fiscal year under sections 4507, 5382, 5384, and 5948 of this title exceed the annual rate payable for positions at level I of the Executive Schedule in effect at the end of such fiscal year.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2)(A) Any amount which is not paid to a senior executive during a fiscal year because of the limitation under paragraph (1) of this subsection shall be paid to that individual in a lump sum at the beginning of the following fiscal year.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) Any amount paid under this paragraph during a fiscal year shall be taken into account for purposes of applying the limitation under paragraph (1) of this subsection with respect to such fiscal year.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) The Office of Personnel Management shall prescribe regulations, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5582"},"text":"section 5582 of this title","children":[],"tail":", under which payment under this paragraph shall be made in the case of any individual whose death precludes payment under subparagraph (A) of this paragraph.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/175"},"text":"Pub. L. 102–175","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", which directed that “5304(j),” be struck out after the reference to section 4507, could not be executed because “5304(j),” does not appear in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/166"},"text":"Pub. L. 96–166","children":[],"tail":" inserted reference to section 5948."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb86114b8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb86114b9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" effective on first day of first pay period beginning on or after "},{"tag":"date","attrib":{"date":"2004-01-01"},"text":"Jan. 1, 2004","children":[],"tail":", but not to result in reduction in rate of basic pay for any senior executive during first year after effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1125/c"},"text":"section 1125(c) of Pub. L. 108–136","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5304"},"text":"section 5304 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb86114ba-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" effective following expiration of 90-day period beginning on "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/s307"},"text":"section 307 of Pub. L. 98–615","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393"},"text":"section 3393 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb86114bb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 9 months after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", and congressional review of provisions of sections 401 through 412 of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", see section 415(a)(1), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3131"},"text":"section 3131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb86114bc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Senior Executive Service; Maximum Aggregate Amount Payable, Etc.; Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/168/tIII/s301/a"},"text":"Pub. L. 98–168, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-11-29"},"text":"Nov. 29, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1112"},"text":"97 Stat. 1112","children":[],"tail":", required Office of Personnel Management to study and, within 12 months after "},{"tag":"date","attrib":{"date":"1983-11-29"},"text":"Nov. 29, 1983","children":[],"tail":", submit to each House of Congress a report on effect which "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5383/b"},"text":"5 U.S.C. 5383(b)","children":[],"tail":" (relating to maximum aggregate amount payable to a member of Senior Executive Service in a fiscal year) has had with respect to recruitment, retention, and morale of career appointees in Senior Executive Service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
