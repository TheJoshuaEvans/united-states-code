{"tag":"section","attrib":{"id":"idb78a8b5e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s321"},"text":null,"children":[{"tag":"num","attrib":{"value":"321"},"text":"§ 321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb78a8b5f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s321/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “agency” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3502"},"text":"section 3502 of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b60-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s321/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Director” means the Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b61-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s321/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Government service delivery","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Government service delivery” means any action by an agency related to providing a benefit or service to an individual, business, or organization (such as a grantee or State, local, or Tribal entity), including any such action of a contractor or nonprofit organization acting on behalf of the agency or administering a federally-funded program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b62-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s321/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Government service delivery channel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Government service delivery channel” means the format or medium of an interaction or transaction with the Federal Government, including in-person, through the mail, through a digital service, by telephone, through a contact center, on a website, through outreach and communication, and through collaboration with a third party, or through other ways in which an individual or entity significantly interacts with the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b63-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s321/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"High impact service provider","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “high impact service provider” means an agency program identified by the Director due to the scale and impact of the public-facing services of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb78a8b64-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/231/s2/a"},"text":"Pub. L. 118–231, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2829"},"text":"138 Stat. 2829","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
