{"tag":"section","attrib":{"id":"idb8c0743a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133"},"text":null,"children":[{"tag":"num","attrib":{"value":"8133"},"text":"§ 8133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation in case of death","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c0743b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If death results from an injury sustained in the performance of duty, the United States shall pay a monthly compensation equal to a percentage of the monthly pay of the deceased employee in accordance with the following schedule:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c0743c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the widow or widower, if there is no child, 50 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c0743d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the widow or widower, if there is a child, 45 percent and in addition 15 percent for each child not to exceed a total of 75 percent for the widow or widower and children.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c0743e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the children, if there is no widow or widower, 40 percent for one child and 15 percent additional for each additional child not to exceed a total of 75 percent, divided among the children share and share alike.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c0743f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To the parents, if there is no widow, widower, or child, as follows—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c07440-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent if one parent was wholly dependent on the employee at the time of death and the other was not dependent to any extent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c07441-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 percent to each if both were wholly dependent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c07442-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proportionate amount in the discretion of the Secretary of Labor if one or both were partly dependent.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If there is a widow, widower, or child, so much of the percentages are payable as, when added to the total percentages payable to the widow, widower, and children, will not exceed a total of 75 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c07443-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To the brothers, sisters, grandparents, and grandchildren, if there is no widow, widower, child, or dependent parent, as follows—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c07444-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 percent if one was wholly dependent on the employee at the time of death;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c07445-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 percent if more than one was wholly dependent, divided among the dependents share and share alike; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c07446-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent if no one is wholly dependent but one or more is partly dependent, divided among the dependents share and share alike.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"If there is a widow, widower, child, or dependent parent, so much of the percentages are payable as, when added to the total percentages payable to the widow, widower, children, and dependent parents, will not exceed a total of 75 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c07447-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The compensation payable under subsection (a) of this section is paid from the time of death until—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c07448-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a widow, or widower dies or remarries before reaching age 55;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c07449-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a child, a brother, a sister, or a grandchild dies, marries, or becomes 18 years of age, or if over age 18 and incapable of self-support becomes capable of self-support; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e44a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a parent or grandparent dies, marries, or ceases to be dependent.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Notwithstanding paragraph (2) of this subsection, compensation payable to or for a child, a brother or sister, or grandchild that would otherwise end because the child, brother or sister, or grandchild has reached 18 years of age shall continue if he is a student as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of this title","children":[],"tail":" at the time he reaches 18 years of age for so long as he continues to be such a student or until he marries. A widow or widower who has entitlements to benefits under this title derived from more than one husband or wife shall elect one entitlement to be utilized."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c2e44b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On the cessation of compensation under this section to or on account of an individual, the compensation of the remaining individuals entitled to compensation for the unexpired part of the period during which their compensation is payable, is that which they would have received if they had been the only individuals entitled to compensation at the time of the death of the employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c2e44c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When there are two or more classes of individuals entitled to compensation under this section and the apportionment of compensation under this section would result in injustice, the Secretary may modify the apportionment to meet the requirements of the case.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c2e44d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In computing compensation under this section, the monthly pay is deemed not less than the minimum rate of basic pay for GS–2. However, the total monthly compensation may not exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c2e44e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the monthly pay computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8114"},"text":"section 8114 of this title","children":[],"tail":", except for increases authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8146a"},"text":"section 8146a of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c2e44f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent of the monthly pay of the maximum rate of basic pay for GS–15.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c2e450-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8133/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any funeral and burial expenses paid under section 8134, there shall be paid a sum of $200 to the personal representative of a deceased employee within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101/1"},"text":"section 8101(1) of this title","children":[],"tail":" for reimbursement of the costs of termination of the decedent’s status as an employee of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c2e451-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/547"},"text":"80 Stat. 547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/62"},"text":"Pub. L. 90–83, § 1(62)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/211"},"text":"81 Stat. 211","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/416"},"text":"Pub. L. 93–416","children":[],"tail":", §§ 16(a), 17, 18, "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1147"},"text":"88 Stat. 1147","children":[],"tail":", 1149; "},{"tag":"ref","attrib":{"href":"/us/pl/101/303/s3/1"},"text":"Pub. L. 101–303, § 3(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-29"},"text":"May 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/251"},"text":"104 Stat. 251","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c2e452-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c2e453-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c2e454-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1966 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s760"},"text":"5 U.S.C. 760","children":[],"tail":" (less last 23 words of 1st sentence in (B); and less (H) and (L))."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-09-07/ch458/s10"},"text":"Sept. 7, 1916, ch. 458, § 10","children":[],"tail":" (less last 15 words of 1st sentence in (B); and less (H) and (L)), "},{"tag":"html:a","attrib":{"href":"/us/stat/39/744"},"text":"39 Stat. 744","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1927-02-12/ch110/s3"},"text":"Feb. 12, 1927, ch. 110, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/44/1087"},"text":"44 Stat. 1087","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-07-28/ch328"},"text":"July 28, 1945, ch. 328","children":[],"tail":", §§ 2 (less last 24 words), 3, "},{"tag":"html:a","attrib":{"href":"/us/stat/59/503"},"text":"59 Stat. 503","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-14/ch691/s106"},"text":"Oct. 14, 1949, ch. 691, § 106","children":[],"tail":" (less last 23 words of 1st sentence in “(B)” of (c); and less (e)), "},{"tag":"html:a","attrib":{"href":"/us/stat/63/859"},"text":"63 Stat. 859","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/767/s102"},"text":"Pub. L. 86–767, § 102","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/906"},"text":"74 Stat. 906","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “an injury sustained in the performance of duty” are substituted for “the injury” to clearly identify the type of injury to which the section refers.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Administration of this subchapter was transferred to the Secretary of Labor by section 1 of 1950 Reorg. Plan. No. 19, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1271"},"text":"64 Stat. 1271","children":[],"tail":" (see section 8145)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c2e455-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c2e456-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1967 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 5","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"8133(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 App.: 760(G) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 4, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/488/s7/a"},"text":"Pub. L. 89–488, § 7(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/253"},"text":"80 Stat. 253","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":