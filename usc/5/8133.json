provided in section 12” to reflect the codification of that section in title 5."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c2e457-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c2e458-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/303"},"text":"Pub. L. 101–303","children":[],"tail":" substituted “age 55” for “age 60”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s16/a"},"text":"Pub. L. 93–416, § 16(a)","children":[],"tail":", substituted “50” for “45”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s16/a"},"text":"Pub. L. 93–416, § 16(a)","children":[],"tail":", substituted “45” for “40”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s16/a"},"text":"Pub. L. 93–416, § 16(a)","children":[],"tail":", substituted “40” for “35”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s16/a"},"text":"Pub. L. 93–416, § 16(a)","children":[],"tail":", inserted “before reaching age 60” after “remarries” in par. (1), struck out par. (2) referring to widower who dies, remarries or becomes capable of self-support, redesignated pars. (3) and (4) as (2) and (3), respectively, changed the reference in closing paragraph from paragraph (3) of this subsection to paragraph (2) of this subsection, and inserted provision for election by widower or widow of benefits derived from more than one husband or wife."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s17"},"text":"Pub. L. 93–416, § 17","children":[],"tail":", inserted “, except for increases authorized by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8146a"},"text":"section 8146a of this title","children":[],"tail":"” before “; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s18"},"text":"Pub. L. 93–416, § 18","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c2e459-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8c2e45a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1974 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by sections 16(a) and 17 of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416"},"text":"Pub. L. 93–416","children":[],"tail":" applicable to cases where injury or death occurred prior to "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":" but only to a period beginning on or after "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s28/a"},"text":"section 28(a) of Pub. L. 93–416","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s18"},"text":"section 18 of Pub. L. 93–416","children":[],"tail":" effective on "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", and applicable to any injury or death occurring on or after "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s28/a"},"text":"section 28(a) of Pub. L. 93–416","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8c2e45b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Gratuity for Death of Civilian Employee From Injury Sustained in Line of Duty","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/f/tVI/s651"},"text":"Pub. L. 104–208, div. A, title I, § 101(f) [title VI, § 651]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-314"},"text":"110 Stat. 3009–314","children":[],"tail":", 3009–368, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/208/dA/tI/s101/f/tVI/s651"},"text":"“Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8116"},"text":"section 8116 of title 5","children":[],"tail":", United States Code, and in addition to any payment made under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"5 U.S.C. 8101","children":[],"tail":" et seq., beginning in fiscal year 1997 and thereafter, the head of any department or agency is authorized to pay from appropriations made available to the department or agency a death gratuity to the personal representative (as that term is defined by applicable law) of a civilian employee of that department or agency whose death resulted from an injury sustained in the line of duty on or after "},{"tag":"date","attrib":{"date":"1990-08-02"},"text":"August 2, 1990","children":[],"tail":": "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That payments made pursuant to this section, in combination with the payments made pursuant to sections 8133(f) and 8134(a) of such title 5 and "},{"tag":"ref","attrib":{"href":"/us/pl/103/332/s312"},"text":"section 312 of Public Law 103–332","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/108/2537"},"text":"108 Stat. 2537","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8134"},"text":"5 U.S.C. 8134","children":[],"tail":" note], may not exceed a total of $10,000 per employee.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8c2e45c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Personnel Not Affected by 1967 Increase","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Increases authorized under amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/62/B"},"text":"section 1(62)(B) of Pub. L. 90–83","children":[],"tail":" not applicable to specified personnel, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s7"},"text":"section 7 of Pub. L. 90–83","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8103"},"text":"section 8103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
