{"tag":"section","attrib":{"id":"idb86ab247-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5537"},"text":null,"children":[{"tag":"num","attrib":{"value":"5537"},"text":"§ 5537.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for jury and witness service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb86ab248-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5537/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":" (except an individual whose pay is disbursed by the Secretary of the Senate, the Chief Administrative Officer of the House of Representatives, or the Chief of the Capitol Police) or an individual employed by the government of the District of Columbia may not receive fees for service—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86ab249-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5537/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a juror in a court of the United States or the District of Columbia; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86ab24a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5537/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as a witness on behalf of the United States or the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86ab24b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5537/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An official of a court of the United States or the District of Columbia may not receive witness fees for attendance before a court, commissioner, or magistrate judge where he is officiating.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86ab24c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5537/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, “court of the United States” has the meaning given it by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s451"},"text":"section 451 of title 28","children":[],"tail":" and includes the District Court of Guam and the District Court of the Virgin Islands."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86ab24d-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/484"},"text":"80 Stat. 484","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/623/s1/12"},"text":"Pub. L. 90–623, § 1(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1312"},"text":"82 Stat. 1312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/91/563/s3/a"},"text":"Pub. L. 91–563, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-19"},"text":"Dec. 19, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1477"},"text":"84 Stat. 1477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/650/tIII/s321"},"text":"Pub. L. 101–650, title III, § 321","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-12-01"},"text