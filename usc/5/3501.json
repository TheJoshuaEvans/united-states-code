{"tag":"section","attrib":{"id":"idb820b069-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3501"},"text":null,"children":[{"tag":"num","attrib":{"value":"3501"},"text":"§ 3501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions; application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb820b06a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this subchapter, except section 3504—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb820b06b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “active service” has the meaning given it by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s101"},"text":"section 101 of title 37","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb820b06c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “a retired member of a uniformed service” means a member or former member of a uniformed service who is entitled, under statute, to retired, retirement, or retainer pay on account of his service as such a member; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb820b06d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3501/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a preference eligible employee who is a retired member of a uniformed service is considered a preference eligible only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb820b06e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3501/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" his retirement was based on disability—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb820b06f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3501/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resulting from injury or disease received in line of duty as a direct result of armed conflict; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb820b070-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3501/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" caused by an instrumentality of war and incurred in the line of duty during a period of war as defined by sections 101 and 1101 of title 38;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb820b071-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3501/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" his service does not include twenty or more years of full-time active service, regardless of when performed but not including periods of active duty for training; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb820b072-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3501/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on ","children":[{"tag":"date","attrib":{"date":"1964-11-30"},"text":"November 30, 1964","children":[],"tail":", he was employed in a position to which this subchapter applies and thereafter he continued to be so employed without a break in service of more than 30 days."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb820b073-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided by this subsection and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3504"},"text":"section 3504 of this title","children":[],"tail":", this subchapter applies to each employee in or under an Executive agency. This subchapter does not apply to an employee whose appointment is required by Congress to be confirmed by, or made with the advice and consent of, the Senate or to a member of the Senior Executive Service or the Federal Bureau of Investigation and Drug Enforcement Administration Senior Executive Service."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb820b074-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/428"},"text":"80 Stat. 428","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/183/s2/8"},"text":"Pub. L. 94–183, § 2(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1057"},"text":"89 Stat. 1057","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIV/s404/a"},"text":"Pub. L. 95–454, title IV, § 404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us