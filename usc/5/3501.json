l,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s861/b"},"text":"5 U.S.C. 861(b)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1944-06-27/ch287/s12/b"},"text":"June 27, 1944, ch. 287, § 12(b)","children":[],"tail":"; added "},{"tag":"html:span","attrib":{},"text":"Aug. 19, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/448/s202/4"},"text":"Pub. L. 88–448, § 202(4)","children":[],"tail":" (“(b)”), "},{"tag":"html:a","attrib":{"href":"/us/stat/78/486"},"text":"78 Stat. 486","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the definitions of “uniformed services” and “armed forces” are omitted as unnecessary in view of the definitions in section 2101. The definition of “civilian office” is omitted as unnecessary as subsection (b) of this section states the application of this subchapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “Notwithstanding any other provision of this Act” are omitted as unnecessary. The words “preference eligible employee” are coextensive with and substituted for “employee * * * included under section 2 of this Act” in view of the definition of preference eligible in section 2108. In paragraph (3)(C), the words “on ","children":[{"tag":"date","attrib":{"date":"1964-11-30"},"text":"November 30, 1964","children":[],"tail":", he was employed in a position to which this subchapter applies and thereafter he continued to be so employed” are substituted for “immediately prior to the effective date of this subsection, he was employed in a civilian office to which this Act applies and, on and after such date, he continues to be employed in any such office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is supplied on authority of sections 2, 12, and 20 of the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1944-06-27/ch287"},"text":"Act of June 27, 1944, ch. 287","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/387"},"text":"58 Stat. 387","children":[],"tail":", 391, which are carried into this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preference to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb820b078-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb820b079-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(3)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/83"},"text":"Pub. L. 102–83","children":[],"tail":" substituted reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s1101"},"text":"section 1101 of title 38","children":[],"tail":" for reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s301"},"text":"section 301 of title 38","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/325"},"text":"Pub. L. 100–325","children":[],"tail":" inserted reference to Federal Bureau of Investigation and Drug Enforcement Administration Senior Executive Service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" inserted reference to a member of Senior Executive Service."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/183"},"text":"Pub. L. 94–183","children":[],"tail":" struck out “, except an employee whose appointment is made under "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s3311"},"text":"section 3311 of title 39","children":[],"tail":"” after “or made with the advice and consent of, the Senate”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb820b07a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb820b07b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 9 months after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", and congressional review of provisions of sections 401 through 412 of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s415"},"text":"section 415 of Pub. L. 95–454","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3131"},"text":"section 3131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
