{"tag":"section","attrib":{"id":"idb85c5a2c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5361"},"text":null,"children":[{"tag":"num","attrib":{"value":"5361"},"text":"§ 5361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85c5a2d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5361/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “employee” means an employee to whom chapter 51 of this title applies, and a prevailing rate employee, as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5342/a/2"},"text":"section 5342(a)(2) of this title","children":[],"tail":", whose employment is other than on a temporary or term basis;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a2e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5361/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “agency” has the meaning given it by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5102"},"text":"section 5102 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a2f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5361/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “retained grade” means the grade used for determining benefits to which an employee to whom ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5362"},"text":"section 5362 of this title","children":[],"tail":" applies is entitled;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a30-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5361/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “rate of basic pay” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb85c5a31-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5361/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the rate of basic pay payable to an employee under law or regulations before any deductions or additions of any kind, but including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb85c5a32-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5361/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable locality-based comparability payment under section 5304 or similar provision of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb85c5a33-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5361/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any applicable special pay under section 5305 or similar provision of law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb85c5a34-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5361/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to such regulations as the Office of Personnel Management may prescribe, any applicable existing retained rate of pay established under section 5363 or similar provision of law; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85c5a35-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5361/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a prevailing rate employee, the scheduled rate of pay determined under section 5343;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a36-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5361/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “covered pay schedule” means the General Schedule, any prevailing rate schedule established under subchapter IV of this chapter, or a special occupational pay system under subchapter IX;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a37-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5361/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “position subject to this subchapter” means any position under a covered pay schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a38-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5361/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “reduction-in-force procedures” means procedures applied in carrying out any reduction in force due to a reorganization, due to lack of funds or curtailment of work, or due to any other factor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a39-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5361/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “retained rate” means the rate of basic pay to which an employee is entitled under section 5363(b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb85c5a3a-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVIII/s801/a/1"},"text":"Pub. L. 95–454, title VIII, § 801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1218"},"text":"92 Stat. 1218","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/tII/s204/a/2"},"text":"Pub. L. 98–615, title II, § 204(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3216"},"text":"98 Stat. 3216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s105/b/1"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 105(b)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1448; "},{"tag":"ref","attrib":{"href":"/us/pl/103/89/s3/b/1/J"},"text":"Pub. L. 103–89, § 3(b)(1)(J)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"Sept. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/982"},"text":"107 Stat. 982","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/411/tIII/s301/a/4"},"text":"Pub. L. 108–411, title III, § 301(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2315"},"text":"118 Stat. 2315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb85c5a3b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb85c5a3c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb85c5a3d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in par. (5), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb85c5a3e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5361, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/473"},"text":"80 Stat. 473","children":[],"tail":", which related to scientific and professional positions, was renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5371"},"text":"section 5371 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVIII/s801/a/3/A/ii"},"text":"Pub. L. 95–454, title VIII, § 801(a)(3)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1221"},"text":"92 Stat. 1221","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb85c5a3f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/411/s301/a/4/A"},"text":"Pub. L. 108–411, § 301(a)(4)(A)","children":[],"tail":", amended par. (4) generally. Prior to amendment, par. (4) read as follows: “ ‘rate of basic pay’ means, in the case of a prevailing rate employee, the scheduled rate of pay determined under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5343"},"text":"section 5343 of this title","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/411/s301/a/4/B"},"text":"Pub. L. 108–411, § 301(a)(4)(B)","children":[],"tail":"–(D), added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/89"},"text":"Pub. L. 103–89","children":[],"tail":" substituted “or a special occupational pay system under subchapter IX” for “a special occupational pay system under subchapter IX, or the performance management and recognition system under chapter 54 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" inserted “a special occupational pay system under subchapter IX,” before “or the performance”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" substituted “performance management and recognition system” for “merit pay system”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb85c5a40-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb85c5a41-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/411"},"text":"Pub. L. 108–411","children":[],"tail":" effective on the first day of the first applicable pay period beginning on or after the 180th day after "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", with provisions relating to conversion rules, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/411/s301/d"},"text":"section 301(d) of Pub. L. 108–411","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5363"},"text":"section 5363 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb85c5a42-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/89"},"text":"Pub. L. 103–89","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1993-11-01"},"text":"Nov. 1, 1993","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/89/s3/c"},"text":"section 3(c) of Pub. L. 103–89","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3372"},"text":"section 3372 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb85c5a43-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":" effective on such date as the President shall determine, but not earlier than 90 days, and not later than 180 days, after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see section 529 [title III, § 305] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb85c5a44-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615/tII/s205"},"text":"Pub. L. 98–615, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3217"},"text":"98 Stat. 3217","children":[],"tail":", provided that amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" was effective "},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"Oct. 1, 1984","children":[],"tail":", and applicable with respect to pay periods commencing on or after that date, with certain exceptions and qualifications."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb85c5a45-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVIII/s801/a/4"},"text":"Pub. L. 95–454, title VIII, § 801(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1222"},"text":"92 Stat. 1222","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/454/tVIII/s801/a/4"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amendments made by this subsection [enacting sections 5361 to 5366 of this title and redesignating former sections 5361 to 5366 as sections 5371 to 5375 of this title, amending sections 559, 1305, 3104, 5102, 5107, 5334, 5349, and 8704 of this title, sections 4540, 7212, and 9540 of Title 10, Armed Forces, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1715"},"text":"section 1715 of Title 15","children":[],"tail":", Commerce and Trade, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3608"},"text":"section 3608 of Title 42","children":[],"tail":", The Public Health and Welfare, and repealing sections 5337 and 5345 of this title] shall take effect on the first day of the first applicable pay period beginning on or after the 90th day after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee who was receiving pay under the provisions of section 5334(d), 5337, or 5345 of title 5, United States Code, on the day before the effective date prescribed in subparagraph (A) of this paragraph shall not have such pay reduced or terminated by reason of the amendments made by this subsection and, unless section 5362 of such title 5 (as amended by subsection (a)(1) of this section) applies, such an employee is entitled to continue to receive pay as authorized by those provisions (as in effect on such date).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
