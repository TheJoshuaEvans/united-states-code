{"tag":"section","attrib":{"id":"idb924b357-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8991"},"text":null,"children":[{"tag":"num","attrib":{"value":"8991"},"text":"§ 8991.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Jurisdiction of courts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The district courts of the United States have original jurisdiction, concurrent with the United States Court of Federal Claims, of a civil action or claim against the United States under this chapter after such administrative remedies as required under section 8983(d) have been exhausted, but only to the extent judicial review is not precluded by any dispute resolution or other remedy under this chapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb924b358-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/496/s3"},"text":"Pub. L. 108–496, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/4010"},"text":"118 Stat. 4010","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb924b359-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb924b35a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb924b35b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", and applicable to contracts that take effect with respect to the calendar year 2006, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/496/s7"},"text":"section 7 of Pub. L. 108–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8951"},"text":"section 8951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
