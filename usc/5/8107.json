{"tag":"section","attrib":{"id":"idb8be29af-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107"},"text":null,"children":[{"tag":"num","attrib":{"value":"8107"},"text":"§ 8107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation schedule","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8be29b0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If there is permanent disability involving the loss, or loss of use, of a member or function of the body or involving disfigurement, the employee is entitled to basic compensation for the disability, as provided by the schedule in subsection (c) of this section, at the rate of 66⅔ percent of his monthly pay. The basic compensation is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8be29b1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payable regardless of whether the cause of the disability originates in a part of the body other than that member;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29b2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payable regardless of whether the disability also involves another impairment of the body; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29b3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in addition to compensation for temporary total or temporary partial disability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be29b4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to any period after payments under subsection (a) of this section have ended, an employee is entitled to compensation as provided by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8be29b5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8105"},"text":"section 8105 of this title","children":[],"tail":" if the disability is total; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29b6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8106"},"text":"section 8106 of this title","children":[],"tail":" if the disability is partial."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be29b7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The compensation schedule is as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8be29b8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Arm lost, 312 weeks’ compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29b9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Leg lost, 288 weeks’ compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29ba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Hand lost, 244 weeks’ compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29bb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Foot lost, 205 weeks’ compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29bc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Eye lost, 160 weeks’ compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29bd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Thumb lost, 75 weeks’ compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29be-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" First finger lost, 46 weeks’ compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29bf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Great toe lost, 38 weeks’ compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29c0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Second finger lost, 30 weeks’ compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29c1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Third finger lost, 25 weeks’ compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29c2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Toe other than great toe lost, 16 weeks’ compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fourth finger lost, 15 weeks’ compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29c4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Loss of hearing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8be29c5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete loss of hearing of one ear, 52 weeks’ compensation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8be29c6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete loss of hearing of both ears, 200 weeks’ compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation for loss of binocular vision or for loss of 80 percent or more of the vision of an eye is the same as for loss of the eye.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation for loss of more than one phalanx of a digit is the same as for loss of the entire digit. Compensation for loss of the first phalanx is one-half of the compensation for loss of the entire digit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, in the case of an arm or a leg, the member is amputated above the wrist or ankle, compensation is the same as for loss of the arm or leg, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation for loss of use of two or more digits, or one or more phalanges of each of two or more digits, of a hand or foot, is proportioned to the loss of use of the hand or foot occasioned thereby.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation for permanent total loss of use of a member is the same as for loss of the member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29cc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation for permanent partial loss of use of a member may be for proportionate loss of use of the member. The degree of loss of vision or hearing under this schedule is determined without regard to correction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29cd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In case of loss of use of more than one member or parts of more than one member as enumerated by this schedule, the compensation is for loss of use of each member or part thereof, and the awards run consecutively. However, when the injury affects only two or more digits of the same hand or foot, paragraph (17) of this subsection applies, and when partial bilateral loss of hearing is involved, compensation is computed on the loss as affecting both ears.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29ce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For serious disfigurement of the face, head, or neck of a character likely to handicap an individual in securing or maintaining employment, proper and equitable compensation not to exceed $3,500 shall be awarded in addition to any other compensation payable under this schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29cf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8107/c/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For permanent loss or loss of use of any other important external or internal organ of the body as determined by the Secretary, proper and equitable compensation not to exceed 312 weeks’ compensation for each organ so determined shall be paid in addition to any other compensation payable under this schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8be29d0-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/536"},"text":"80 Stat. 536","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/50"},"text":"Pub. L. 90–83, § 1(50)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/210"},"text":"81 Stat. 210","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/416"},"text":"Pub. L. 93–416","children":[],"tail":", §§ 4, 5, "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1144"},"text":"88 Stat. 1144","children":[],"tail":", 1145.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8be29d1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8be29d2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8be29d3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1966 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s755/a"},"text":"5 U.S.C. 755(a)","children":[],"tail":", (b)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-09-07/ch458/s5"},"text":"Sept. 7, 1916, ch. 458, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/743"},"text":"39 Stat. 743","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":