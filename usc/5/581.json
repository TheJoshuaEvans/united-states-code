{"tag":"section","attrib":{"id":"idb7bc9809-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s581"},"text":null,"children":[{"tag":"num","attrib":{"value":"581"},"text":"§ 581.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial Review ","children":[{"tag":"ref","attrib":{"idref":"fn002023"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002023"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"idb7bc980a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s581/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, any person adversely affected or aggrieved by an award made in an arbitration proceeding conducted under this subchapter may bring an action for review of such award only pursuant to the provisions of sections 9 through 13 of title 9.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7bc980b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s581/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A decision by an agency to use or not to use a dispute resolution proceeding under this subchapter shall be committed to the discretion of the agency and shall not be subject to judicial review, except that arbitration shall be subject to judicial review under section 10(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002024"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002024"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of title 9."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7bc980c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/552/s4/b"},"text":"Pub. L. 101–552, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2744"},"text":"104 Stat. 2744","children":[],"tail":", § 591; renumbered § 581 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/354/s3/b/2"},"text":"Pub. L. 102–354, § 3(b)(2)","children":[],"tail":", (4), "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/944"},"text":"106 Stat. 944","children":[],"tail":", 945; "},{"tag":"ref","attrib":{"href":"/us/pl/104/320/s8/b"},"text":"Pub. L. 104–320, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3872"},"text":"110 Stat. 3872","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7bc980d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7bc980e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb7bc980f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t9/s10/b"},"text":"Section 10(b) of title 9","children":[],"tail":", referred to in subsec. (b), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t9/s10/c"},"text":"section 10(c) of title 9","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/107/169/s1/4"},"text":"Pub. L. 107–169, § 1(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-05-07"},"text":"May 7, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/132"},"text":"116 Stat. 132","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb7bc9810-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 581 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s571"},"text":"section 571 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 581 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s561"},"text":"section 561 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7bc9811-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/320"},"text":"Pub. L. 104–320","children":[],"tail":", which directed that "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s581/d"},"text":"section 581(d) of this title","children":[],"tail":" be amended by striking “(1)” after “(b)” and by striking par. (2), was executed to subsec. (b) of this section to reflect the probable intent of Congress. Prior to amendment, par. (2) read as follows: “A decision by the head of an agency under section 580 to terminate an arbitration proceeding or vacate an arbitral award shall be committed to the discretion of the agency and shall not be subject to judicial review.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/354/s3/b/2"},"text":"Pub. L. 102–354, § 3(b)(2)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s591"},"text":"section 591 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/354/s3/b/4"},"text":"Pub. L. 102–354, § 3(b)(4)","children":[],"tail":", substituted “section 580” for “section 590”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
