{"tag":"section","attrib":{"id":"idb9309a61-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10210"},"text":null,"children":[{"tag":"num","attrib":{"value":"10210"},"text":"§ 10210.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirement","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after the date of the enactment of this chapter, the Secretary shall prepare and transmit to Congress a report on the operation of this chapter. The report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9309a62-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10210/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the effectiveness of this chapter with respect to efforts of the Secretary to recruit and retain well-qualified personnel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a63-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10210/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for any legislation or administrative action which the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9309a64-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/282/s2/a"},"text":"Pub. L. 111–282, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3038"},"text":"124 Stat. 3038","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9309a65-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb9309a66-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb9309a67-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this chapter, referred to in text, is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/282"},"text":"Pub. L. 111–282","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9309a68-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9309a69-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of first pay period which begins after ","children":[{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/282/s5"},"text":"section 5 of Pub. L. 111–282","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5102"},"text":"section 5102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
