{"tag":"section","attrib":{"id":"idb801b70d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3152"},"text":null,"children":[{"tag":"num","attrib":{"value":"3152"},"text":"§ 3152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on pay","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Members of the FBI–DEA Senior Executive Service shall be subject to the limitation under section 5307.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb801b70e-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/325/s1/a"},"text":"Pub. L. 100–325, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-05-30"},"text":"May 30, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/581"},"text":"102 Stat. 581","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/9"},"text":"Pub. L. 102–378, § 2(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1347"},"text":"106 Stat. 1347","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb801b70f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb801b710-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb801b711-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378"},"text":"Pub. L. 102–378","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “Nothing in this subchapter shall be construed to allow the aggregate amount payable to a member of the FBI–DEA Senior Executive Service under this subchapter during any fiscal year to exceed the annual rate payable for positions at level I of the Executive Schedule in effect at the end of such year. This section shall be applied in a manner consistent with paragraphs (1) and (2) of section 5383(b).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
