{"tag":"section","attrib":{"id":"idb86386c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5512"},"text":null,"children":[{"tag":"num","attrib":{"value":"5512"},"text":"§ 5512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding pay; individuals in arrears","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb86386c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The pay of an individual in arrears to the United States shall be withheld until he has accounted for and paid into the Treasury of the United States all sums for which he is liable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86386c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When pay is withheld under subsection (a) of this section, the employing agency, on request of the individual, his agent, or his attorney, shall report immediately to the Attorney General the balance due; and the Attorney General, within 60 days, shall order suit to be commenced against the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86386ca-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/477"},"text":"80 Stat. 477","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/310/tII/s202"},"text":"Pub. L. 92–310, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-06-06"},"text":"June 6, 1972","children":[],"tail":", "},{