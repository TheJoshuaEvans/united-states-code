{"tag":"section","attrib":{"id":"idb9355563-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13121"},"text":null,"children":[{"tag":"num","attrib":{"value":"13121"},"text":"§ 13121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment; appointment of Director","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb9355564-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established an executive agency to be known as the Office of Government Ethics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9355565-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There shall be at the head of the Office of Government Ethics a Director (hereinafter referred to as the “Director”), who shall be appointed by the President, by and with the advice and consent of the Senate. Effective with respect to any individual appointed or reappointed by the President as Director on or after ","children":[{"tag":"date","attrib":{"date":"1983-10-01"},"text":"October 1, 1983","children":[],"tail":", the term of service of the Director shall be 5 years."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9355566-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Director","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9355567-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13121/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint officers and employees, including attorneys, in accordance with chapter 51 and subchapter III of chapter 53 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9355568-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s13121/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contract for financial and administrative services (including those related to budget and accounting, financial reporting, personnel, and procurement) with the General Services Administration, or such other Federal agency as the Director determines appropriate, for which payment shall be made in advance, or by reimbursement, from funds of the Office of Government Ethics in such amounts as may be agreed upon by the Director and the head of the agency providing such services.","children":[{"tag":"p","attrib":{},"text":"Contract authority under paragraph (2) shall be effective for any fiscal year only to the extent that appropriations are available for that purpose.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9355569-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/c"},"text":"Pub. L. 117–286, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4296"},"text":"136 Stat. 4296","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb935556a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb935556b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb935556c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"13121","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 U.S.C. App. (EGA § 401)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/95/521/tIV/s401"},"text":"Pub. L. 95–521, title IV, § 401","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 26, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1862"},"text":"92 Stat. 1862","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/98/150/s2"},"text":"Pub. L. 98–150, § 2","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 11, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/97/959"},"text":"97 Stat. 959","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/100/598/s3"},"text":"Pub. L. 100–598, § 3","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Nov. 3, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/3031"},"text":"102 Stat. 3031","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/104/179/s4/b/2/A"},"text":"Pub. L. 104–179, § 4(b)(2)(A)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Aug. 6, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/1567"},"text":"110 Stat. 1567","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
