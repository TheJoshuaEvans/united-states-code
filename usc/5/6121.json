{"tag":"section","attrib":{"id":"idb89321a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6121"},"text":null,"children":[{"tag":"num","attrib":{"value":"6121"},"text":"§ 6121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89321a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6121/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “agency” means any Executive agency, any military department, the Government Publishing Office, the Library of Congress, the Architect of the Capitol, and the Botanic Garden;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89321a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6121/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “employee” has the meaning given the term in subsection (a) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":", except that such term also includes an employee described in subsection (c) of that section;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89321a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6121/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “basic work requirement” means the number of hours, excluding overtime hours, which an employee is required to work or is required to account for by leave or otherwise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89321a4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6121/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “credit hours” means any hours, within a flexible schedule established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6122"},"text":"section 6122 of this title","children":[],"tail":", which are in excess of an employee’s basic work requirement and which the employee elects to work so as to vary the length of a workweek or a workday;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89321a5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6121/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “compressed schedule” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89321a6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6121/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a full-time employee, an 80-hour biweekly basic work requirement which is scheduled for less than 10 workdays, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89321a7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6121/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a part-time employee, a biweekly basic work requirement of less than 80 hours which is scheduled for less than 10 workdays;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89592a8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6121/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “overtime hours”, when used with respect to flexible schedule programs under sections 6122 through 6126 of this title, means all hours in excess of 8 hours in a day or 40 hours in a week which are officially ordered in advance, but does not include credit hours;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89592a9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6121/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “overtime hours”, when used with respect to compressed schedule programs under sections 6127 and 6128 of this title, means any hours in excess of those specified hours which constitute the compressed schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89592aa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6121/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “collective bargaining”, “collective bargaining agreement”, and “exclusive representative” have the same meanings given such terms—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89592ab-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6121/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by section 7103(a)(12), (8), and (16) of this title, respectively, in the case of any unit covered by chapter 71 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89592ac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6121/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other unit, by the corresponding provisions applicable under the personnel system covering this unit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89592ad-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/221/s2/a/2"},"text":"Pub. L. 97–221, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-23"},"text":"July 23, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/227"},"text":"96 Stat. 227","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/163/tIII/s312"},"text":"Pub. L. 101–163, title III, § 312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-21"},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1065"},"text":"103 Stat. 1065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1041"},"text":"Pub. L. 104–106, div. A, title X, § 1041","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/433"},"text":"110 Stat. 433","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/68/dA/tI/s1302/1"},"text":"Pub. L. 111–68, div. A, title I, § 1302(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2034"},"text":"123 Stat. 2034","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb89592ae-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89592af-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb89592b0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2009—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/68"},"text":"Pub. L. 111–68","children":[],"tail":" substituted “the Library of Congress, the Architect of the Capitol, and the Botanic Garden” for “and the Library of Congress”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “ ‘employee’ has the meaning given it by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/163"},"text":"Pub. L. 101–163","children":[],"tail":" inserted “the Government Printing Office,” after “military department,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb89592b1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb89592b2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” in par. (1) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
