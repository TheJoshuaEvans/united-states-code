{"tag":"section","attrib":{"id":"idb924b3db-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9005"},"text":null,"children":[{"tag":"num","attrib":{"value":"9005"},"text":"§ 9005.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb924b3dc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9005/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contractual Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms of any contract under this chapter which relate to the nature, provision, or extent of coverage or benefits (including payments with respect to benefits) shall supersede and preempt any State or local law, or any regulation issued thereunder, which relates to long-term care insurance or contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b3dd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9005/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Premiums.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb924b3de-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9005/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No tax, fee, or other monetary payment may be imposed or collected, directly or indirectly, by any State, the District of Columbia, or the Commonwealth of Puerto Rico, or by any political subdivision or other governmental authority thereof, on, or with respect to, any premium paid for an insurance policy under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b3df-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9005/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall not be construed to exempt any company or other entity issuing a policy of insurance under this chapter from the imposition, payment, or collection of a tax, fee, or other monetary payment on the net income or profit accruing to or realized by such entity from business conducted under this chapter, if that tax, fee, or payment is applicable to a broad range of business activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb924b3e0-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/265/tI/s1002/a"},"text":"Pub. L. 106–265, title I, § 1002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-09-19"},"text":"Sept. 19, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/768"},"text":"114 Stat. 768","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/104/s2"},"text":"Pub. L. 107–104, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-27"},"text":"Dec. 27, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1001"},"text":"115 Stat. 1001","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb924b3e1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb924b3e2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb924b3e3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/104"},"text":"Pub. L. 107–104","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb924b3e4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb924b3e5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/104"},"text":"Pub. L. 107–104","children":[],"tail":" effective as if included in the enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/106/265/s1002"},"text":"section 1002 of Pub. L. 106–265","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/104/s3"},"text":"section 3 of Pub. L. 107–104","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s9001"},"text":"section 9001 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
