{"tag":"section","attrib":{"id":"idb8be2a37-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8113"},"text":null,"children":[{"tag":"num","attrib":{"value":"8113"},"text":"§ 8113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Increase or decrease of basic compensation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8be2a38-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8be2a39-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was a minor or employed in a learner’s capacity at the time of injury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be2a3a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was not physically or mentally handicapped before the injury;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary of Labor, on review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8128"},"text":"section 8128 of this title","children":[],"tail":" after the time the wage-earning capacity of the individual would probably have increased but for the injury, shall recompute prospectively the monetary compensation payable for disability on the basis of an assumed monthly pay corresponding to the probable increased wage-earning capacity."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be2a3b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an individual without good cause fails to apply for and undergo vocational rehabilitation when so directed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8104"},"text":"section 8104 of this title","children":[],"tail":", the Secretary, on review under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8128"},"text":"section 8128 of this title","children":[],"tail":" and after finding that in the absence of the failure the wage-earning capacity of the individual would probably have substantially increased, may reduce prospectively the monetary compensation of the individual in accordance with what would probably have been his wage-earning capacity in the absence of the failure, until the individual in good faith complies with the direction of the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8be2a3c-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/540"},"text":"80 Stat. 540","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/100"},"text":"Pub. L. 90–83, § 1(100)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/220"},"text":"81 Stat. 220","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s8/a"},"text":"Pub. L. 93–416, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1145"},"text":"88 Stat. 1145","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8be2