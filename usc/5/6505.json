{"tag":"section","attrib":{"id":"idb8a17a90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6505"},"text":null,"children":[{"tag":"num","attrib":{"value":"6505"},"text":"§ 6505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telework Managing Officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a17a91-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each executive agency shall designate an employee of the agency as the Telework Managing Officer. The Telework Managing Officer shall be established within the Office of the Chief Human Capital Officer or a comparable office with similar functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Telework Managing Officer shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a17a93-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be devoted to policy development and implementation related to agency telework programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a94-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serve as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17a95-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6505/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an advisor for agency leadership, including the Chief Human Capital Officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a96-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6505/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a resource for managers and employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a97-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6505/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a primary agency point of contact for the Office of Personnel Management on telework matters; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a98-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6505/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform other duties as the applicable delegating authority may assign.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a99-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status Within Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Telework Managing Officer of an agency shall be a senior official of the agency who has direct access to the head of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a9a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction Regarding Status of Telework Managing Officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to prohibit an individual who holds another office or position in an agency from serving as the Telework Managing Officer for the agency under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a17a9b-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/292/s2/a"},"text":"Pub. L. 111–292, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3168"},"text":"124 Stat. 3168","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
