{"tag":"section","attrib":{"id":"idb8c79f84-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8317"},"text":null,"children":[{"tag":"num","attrib":{"value":"8317"},"text":"§ 8317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repayment of annuity or retired pay properly paid; waiver","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c79f85-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual, or his survivor or beneficiary, to whom payment of annuity is denied under this subchapter is not thereafter required to repay that part of the annuity otherwise properly paid to the individual, or to his survivor or beneficiary on the basis of the service of the individual, which is in excess of the aggregate amount of the contributions of the individual toward the annuity, with applicable interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c79f86-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual, including an eligible beneficiary under chapter 73 of title 10 or section 5 of the Uniformed Services Contingency Option Act of 1953 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/67/504"},"text":"67 Stat. 504","children":[],"tail":"), to whom payment of retired pay is denied under this subchapter is not thereafter required to repay retired pay otherwise properly paid to the individual or beneficiary which is paid in violation of this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c79f87-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},