{"tag":"section","attrib":{"id":"idb82322d4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3595a"},"text":null,"children":[{"tag":"num","attrib":{"value":"3595a"},"text":"§ 3595a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Furlough in the Senior Executive Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb82322d5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3595a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this section, “furlough” means the placement of a senior executive in a temporary status in which the senior executive has no duties and is not paid when the placement in such status is by reason of insufficient work or funds or for other nondisciplinary reasons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8256bc6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3595a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency may furlough a career appointee only in accordance with regulations issued by the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8256bc7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3595a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A career appointee who is furloughed is entitled to appeal to the Merit Systems Protection Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7701"},"text":"section 7701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8256bc8-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615/tIII/s306/c/1"},"text":"Pub. L. 98–615, title III, § 306(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3220"},"text":"98 Stat. 3220","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8256bc9-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8256bca-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8256bcb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective following expiration of 90-day period beginning on ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/s307"},"text":"section 307 of Pub. L. 98–615","children":[],"tail":", set out as an Effective Date of 1984 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393"},"text":"section 3393 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
