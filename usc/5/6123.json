{"tag":"section","attrib":{"id":"idb89592bc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6123"},"text":null,"children":[{"tag":"num","attrib":{"value":"6123"},"text":"§ 6123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flexible schedules; computation of premium pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89592bd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of determining compensation for overtime hours in the case of an employee participating in a program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6122"},"text":"section 6122 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89592be-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6123/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of an agency may, on request of the employee, grant the employee compensatory time off in lieu of payment for such overtime hours, whether or not irregular or occasional in nature and notwithstanding the provisions of sections 5542(a), 5543(a)(1) and section ","children":[{"tag":"ref","attrib":{"idref":"fn002126"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002126"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “section” probably should not appear."}],"tail":" 5544(a) of this title, "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7453/e"},"text":"section 7453(e) of title 38","children":[],"tail":", section 7 of the Fair Labor Standards Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s207"},"text":"29 U.S.C. 207","children":[],"tail":"), or any other provision of law; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89592bf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6123/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee shall be compensated for such overtime hours in accordance with such provisions, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89592c0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provisions of law referred to in subsection (a)(1) of this section, an employee shall not be entitled to be compensated for credit hours worked except to the extent authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6126"},"text":"section 6126 of this title","children":[],"tail":" or to the extent such employee is allowed to have such hours taken into account with respect to the employee’s basic work requirement."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89592c1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6123/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89592c2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6123/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5545/a"},"text":"section 5545(a) of this title","children":[],"tail":", premium pay for nightwork will not be paid to an employee otherwise subject to such section solely because the employee elects to work credit hours, or elects a time of arrival or departure, at a time of day for which such premium pay is otherwise authorized, except that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89592c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6123/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if an employee is on a flexible schedule under which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb89592c4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6123/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of hours during which such employee must be present for work, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb89592c5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6123/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of hours during which such employee may elect to work credit hours or elect the time of arrival at and departure from work,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"which occur outside of the nightwork hours designated in or under such section 5545(a) total less than 8 hours, such premium pay shall be paid for those hours which, when combined with such total, do not exceed 8 hours, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89592c6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6123/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if an employee is on a flexible schedule under which the hours that such employee must be present for work include any hours designated in or under such section 5545(a), such premium pay shall be paid for such hours so designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89592c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6123/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5343/f"},"text":"section 5343(f) of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s7453/b"},"text":"section 7453(b) of title 38","children":[],"tail":", night differential will not be paid to any employee otherwise subject to either of such sections solely because such employee elects to work credit hours, or elects a time of arrival or departure, at a time of day for which night differential is otherwise authorized, except that such differential shall be paid to an employee on a flexible schedule under this subchapter—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb89592c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6123/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee subject to subsection (f) of such section 5343, for which all or a majority of the hours of such schedule for any day fall between the hours specified in such subsection, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb89592c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6123/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an employee subject to subsection (b) of such section 7453, for which 4 hours of such schedule fall between the hours specified in such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89592ca-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/221/s2/a/2"},"text":"Pub. L. 97–221, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-07-23"},"text":"July 23, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/228"},"text":"96 Stat. 228","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/40/tIV/s403/c/2"},"text":"Pub. L. 102–40, title IV, § 403(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-05-07"},"text":"May 7, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/240"},"text":"105 Stat. 240","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/44/D"},"text":"Pub. L. 102–378, § 2(44)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1352"},"text":"106 Stat. 1352","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb89592cb-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89592cc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb89592cd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378"},"text":"Pub. L. 102–378","children":[],"tail":" substituted “5543(a)(1) and section 5544(a)” for “5543(a)(1), 5544(a), and 5550”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/c/2/A"},"text":"Pub. L. 102–40, § 403(c)(2)(A)","children":[],"tail":", substituted “section 7453(e)” for “section 4107(e)(5)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/40/s403/c/2/B"},"text":"Pub. L. 102–40, § 403(c)(2)(B)","children":[],"tail":", in introductory provisions substituted “section 7453(b)” for “section 4107(e)(2)” and in subpar. (B) substituted “subsection (b) of such section 7453” for “subsection (e)(2) of such section 4107”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
