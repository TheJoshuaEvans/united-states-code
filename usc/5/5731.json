{"tag":"section","attrib":{"id":"idb8873b30-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5731"},"text":null,"children":[{"tag":"num","attrib":{"value":"5731"},"text":"§ 5731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses limited to lowest first-class rate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8873b31-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The allowance for actual expenses for transportation may not exceed the lowest first-class rate by the transportation facility used unless it is certified, in accordance with regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5738"},"text":"section 5738 of this title","children":[],"tail":", that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8873b32-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5731/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lowest first-class accommodations are not available; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8873b33-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5731/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of a compartment or other accommodation authorized or approved by the head of the agency concerned or his designee is required for security purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8873b34-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Instead of the maximum fixed by subsection (a) of this section, the allowance to an employee of the Government for actual expenses for transportation on an inter-island steamship in Hawaii may not exceed the rate for accommodations on the steamship that is equivalent as nearly as possible to the rate for the lowest first-class accommodations on trans-pacific steamships.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8873b35-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/506"},"text":"80 Stat. 506","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVII/s1723/b/4"},"text":"Pub. L. 104–201, div. A, title XVII, § 1723(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2759"},"text":"110 Stat. 2759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/264/s6/10"},"text":"Pub. L. 105–264, § 6(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2356"},"text":"112 Stat. 2356","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8873b36-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8873b37-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8873b38-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":