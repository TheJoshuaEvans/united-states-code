{"tag":"section","attrib":{"id":"idb89f0906-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6340"},"text":null,"children":[{"tag":"num","attrib":{"value":"6340"},"text":"§ 6340.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inapplicability of certain provisions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except to the extent that the Office of Personnel Management may prescribe regulations, nothing in section 7351 shall apply with respect to a solicitation, donation, or acceptance of leave under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb89f0907-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/566/s2/a"},"text":"Pub. L. 100–566, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2838"},"text":"102 Stat. 2838","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
