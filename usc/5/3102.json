{"tag":"section","attrib":{"id":"idb7fa8b3e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102"},"text":null,"children":[{"tag":"num","attrib":{"value":"3102"},"text":"§ 3102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment of personal assistants for handicapped employees, including blind and deaf employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7fa8b3f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7fa8b40-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7fa8b41-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Executive agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fa8b42-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Library of Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fa8b43-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an office, agency, or other establishment in the judicial branch;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fa8b44-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “handicapped employee” means an individual employed by an agency who is blind or deaf or who otherwise qualifies as a handicapped individual within the meaning of section 501 of the Rehabilitation Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s794"},"text":"29 U.S.C. 794","children":[],"tail":"); "},{"tag":"ref","attrib":{"idref":"fn002049"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002049"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s791"},"text":"29 U.S.C. 791","children":[],"tail":");”."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fa8b45-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “nonprofit organization” means an organization determined by the Secretary of the Treasury to be an organization described in section 501(c) of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"26 U.S.C. 501(c)","children":[],"tail":") which is exempt from taxation under section 501(a) of such Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fa8b46-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7fa8b47-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of each agency may employ one or more personal assistants who the head of the agency determines are necessary to enable a handicapped employee of that agency to perform the employee’s official duties and who shall serve without pay from the agency, without regard to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7fa8b48-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provisions of this title governing appointment in the competitive service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fa8b49-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 51 and subchapter III of chapter 53 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fa8b4a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such employment may include the employing of a reading assistant or assistants for a blind employee or an interpreting assistant or assistants for a deaf employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fa8b4b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A personal assistant, including a reading or interpreting assistant, employed under this subsection may receive pay for services performed by the assistant from the handicapped employee or a nonprofit organization, without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s209"},"text":"section 209 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fa8b4c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of each agency may also employ or assign one or more personal assistants who the head of the agency determines are necessary to enable a handicapped employee of that agency to perform the employee’s official duties. Such employment may include the employing of a reading assistant or assistants for a blind employee or an interpreting assistant or assistants for a deaf employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fa8b4d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7fa8b4e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any handicapped employee (including a blind or deaf employee) traveling on official business, the head of the agency may authorize the payment to an individual to accompany or assist (or both) the handicapped employee for all or a portion of the travel period involved. Any payment under this subsection to such an individual may be made either directly to that individual or by advancement or reimbursement to the handicapped employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fa8b4f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to any individual paid to accompany or assist a handicapped employee under paragraph (1) of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7fa8b50-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount paid to that individual shall not exceed the limit or limits which the Office of Personnel Management shall prescribe by regulation to ensure that the payment does not exceed amounts (including pay and, if appropriate, travel expenses and per diem allowances) which could be paid to an employee assigned to accompany or assist the handicapped employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fa8b51-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that individual shall be considered an employee, but only for purposes of chapter 81 of this title (relating to compensation for injury) and sections 2671 through 2680 of title 28 (relating to tort claims).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fa8b52-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3102/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section may not be held or considered to prevent or limit in any way the assignment to a handicapped employee (including a blind or deaf employee) by an agency of clerical or secretarial assistance, at the expense of the agency under statutes and regulations currently applicable at the time, if that assistance normally is provided, or authorized to be provided, in that manner under currently applicable statutes and regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7fa8b53-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/414"},"text":"80 Stat. 414","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/623/s1/3"},"text":"Pub. L. 90–623, § 1(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1312"},"text":"82 Stat. 1312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIII/s302/a"},"text":"Pub. L. 95–454, title III, § 302(a)","children":[],"tail":", (b)(2), "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1145"},"text":"92 Stat. 1145","children":[],"tail":", 1146; "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/11"},"text":"Pub. L. 96–54, § 2(a)(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/382"},"text":"93 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/523/s1/a"},"text":"Pub. L. 96–523, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3039"},"text":"94 Stat. 3039","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/a/3"},"text":"Pub. L. 97–258, § 3(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1063"},"text":"96 Stat. 1063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/518/tIII/s311"},"text":"Pub. L. 106–518, title III, § 311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2421"},"text":"114 Stat. 2421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/553/s1/a/2/tIII/s307"},"text":"Pub. L. 106–553, § 1(a)(2) [title III, § 307]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2762"},"text":"114 Stat. 2762","children":[],"tail":", 2762A–86.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7fa8b54-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7fa8b55-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7fa8b56-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s43a"},"text":"5 U.S.C. 43a","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 29, 1962","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/614"},"text":"Pub. L. 87–614","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/76/408"},"text":"76 Stat. 408","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the word “agency” is substituted for “department”. The words “Executive agency” are coextensive with and substituted for “each executive department of the Federal Government, each agency or independent establishment in the executive branch of such Government, each corporation wholly owned or controlled by such Government, and the General Accounting Office” in view of the definition of “Executive agency” in section 105.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “individual employed” are substituted for “employee” so as to include individuals employed by the government of the District of Columbia who are not employees as defined by section 2105.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “may” is substituted for “is authorized” and the words “in his discretion” are omitted as unnecessary in view of the permissive nature of the authority. The words “in the provisions of this title governing appointment in the competitive service” are substituted for “the civil service rules”. The words “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s209"},"text":"section 209 of title 18","children":[],"tail":"” are substituted for “"},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1914"},"text":"section 1914 of title 18","children":[],"tail":"” on authority of the Act of "},{"tag":"date","attrib":{"date":"1962-10-24"},"text":"Oct. 24, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/849/s2"},"text":"Pub. L. 87–849, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/1126"},"text":"76 Stat. 1126","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7fa8b57-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7fa8b58-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/518"},"text":"Pub. L. 106–518","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/106/553"},"text":"Pub. L. 106–553","children":[],"tail":" amended par. (1) identically, adding subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":"” for “section 3679(b) of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s665/b"},"text":"31 U.S.C. 665(b)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/523"},"text":"Pub. L. 96–523","children":[],"tail":" amended section generally and, among other changes, in section catchline substituted “personal assistants for handicapped employees, including blind and” for “reading assistants for blind employees and interpreting assistants for”, in subsec. (a) substituted applicability to handicapped employees for applicability to blind and deaf employees omitted applicability to the government of the District of Columbia, in subsec. (b) substituted applicability to personal assistants for applicability to reading and interpreting assistants for blind and deaf employees, respectively, redesignated former subsec. (d) as (c) and made changes in phraseology, added subsec. (d), and redesignated former subsec. (c) as (e) and made changes in phraseology."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" substituted “Mayor” for “Commissioner”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s302/b/2"},"text":"Pub. L. 95–454, § 302(b)(2)","children":[],"tail":", substituted “reading assistants for blind employees and interpreting assistants for deaf employees” for “readers for blind employees” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s302/a/1"},"text":"Pub. L. 95–454, § 302(a)(1)","children":[],"tail":", added par. (4) and redesignated former par. (4) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s302/a/2"},"text":"Pub. L. 95–454, § 302(a)(2)","children":[],"tail":", inserted provisions respecting applicability to employment and compensation for interpreting assistant or assistants for deaf employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s302/a/3"},"text":"Pub. L. 95–454, § 302(a)(3)","children":[],"tail":", inserted “or deaf” after “blind”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s302/a/4"},"text":"Pub. L. 95–454, § 302(a)(4)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/623"},"text":"Pub. L. 90–623","children":[],"tail":" substituted “Commissioner” for “Board of Commissioners”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7fa8b59-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7fa8b5a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/523/s3"},"text":"Pub. L. 96–523, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3040"},"text":"94 Stat. 3040","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/523/s3"},"text":"“The amendments made by this Act [amending this section, section 7 of the Federal Advisory Committee Act, formerly set out in the Appendix to this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s604"},"text":"section 604 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure, and "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s410"},"text":"section 410 of Title 39","children":[],"tail":", Postal Service] shall take effect sixty days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1980-12-12"},"text":