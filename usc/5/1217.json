{"tag":"section","attrib":{"id":"idb7ec32be-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1217"},"text":null,"children":[{"tag":"num","attrib":{"value":"1217"},"text":"§ 1217.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmittal of information to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7ec32bf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1217/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Special Counsel or any employee of the Special Counsel designated by the Special Counsel, shall transmit to the Congress on the request of any committee or subcommittee thereof, by report, testimony, or otherwise, information and the Special Counsel’s views on functions, responsibilities, or other matters relating to the Office. Such information shall be transmitted concurrently to the President and any other appropriate agency in the executive branch.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ec32c0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1217/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Report Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ec32c1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1217/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an allegation submitted to the Special Counsel is resolved by an agreement between an agency and an individual, the Special Counsel shall submit to Congress and each congressional committee with jurisdiction over the agency a report regarding the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ec32c2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1217/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any report required under paragraph (1) shall identify, with respect to an agreement described in that paragraph—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7ec32c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1217/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency that entered into the agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ec32c4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1217/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the position and employment location of the employee who submitted the allegation that formed the basis of the agreement, provided the information is not so specific as to be reasonably likely to identify the employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ec32c5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1217/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the position and employment location of any employee alleged by an employee described in subparagraph (B) to have committed a prohibited personnel practice, as defined in section 2302(a)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ec32c6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1217/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the allegation described in subparagraph (B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ec32c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1217/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the agency that entered into the agreement has agreed to pursue any disciplinary action as a result of the allegation described in subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7ec32c8-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/12/s3/a/13"},"text":"Pub. L. 101–12, § 3(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-04-10"},"text":"Apr. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/28"},"text":"103 Stat. 28","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1097/h/3"},"text":"Pub. L. 115–91, div. A, title X, § 1097(h)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1625"},"text":"131 Stat. 1625","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7ec32c9-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7ec32ca-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7ec32cb-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
