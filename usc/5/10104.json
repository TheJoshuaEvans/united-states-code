{"tag":"section","attrib":{"id":"idb92e29c2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104"},"text":null,"children":[{"tag":"num","attrib":{"value":"10104"},"text":"§ 10104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recruitment bonuses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92e29c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may pay a bonus to an individual in order to recruit the individual for a position within the Agency that would otherwise be difficult to fill in the absence of such a bonus. Upon completion of the strategic human capital plan, such bonuses shall be paid in accordance with that plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e29c4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bonus Amount.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e29c5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of a bonus under this section shall be determined by the Administrator, but may not exceed 25 percent of the annual rate of basic pay of the position involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e29c6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form of payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus under this section shall be paid in the form of a lump-sum payment and shall not be considered to be part of basic pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e29c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payment of a bonus under this section shall be contingent upon the employee entering into a written service agreement with the Agency. The agreement shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e29c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of service the individual shall be required to complete in return for the bonus; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e29c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions under which the agreement may be terminated before the agreed-upon service period has been completed, and the effect of the termination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e29ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A bonus under this section may not be paid to an individual who is appointed to or holds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e29cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position to which an individual is appointed by the President, by and with the advice and consent of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e29cc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position in the Senior Executive Service as a noncareer appointee (as defined in section 3132(a)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e29cd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position which has been excepted from the competitive service by reason of its confidential, policy-determining, policy-making, or policy-advocating character.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e29ce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to pay bonuses under this section shall terminate 5 years after the date of enactment of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e29cf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e29d0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Agency shall submit to the appropriate committees of Congress, annually for each of the 5 years during which this section is in effect, a report on the operation of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e29d1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report submitted under this subsection shall include, with respect to the period covered by such report, a description of how the authority to pay bonuses under this section was used by the Agency, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92e29d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and dollar amount of bonuses paid to individuals holding positions within each pay grade, pay level, or other pay classification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92e29d3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10104/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination of the extent to which such bonuses furthered the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92e29d4-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s621/a"},"text":"Pub. L. 109–295, title VI, § 621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1414"},"text":"120 Stat. 1414","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92e29d5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92e29d6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb92e29d7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this chapter, referred to in subsec. (e), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
