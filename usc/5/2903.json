en":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s18"},"text":"5 U.S.C. 18","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 1758.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s16a/a"},"text":"5 U.S.C. 16a(a)","children":[],"tail":" (less 1st 9 words after last comma)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1943-06-26/ch145/s206"},"text":"June 26, 1943, ch. 145, § 206","children":[],"tail":" (less 1st 9 words after last comma), "},{"tag":"html:a","attrib":{"href":"/us/stat/57/196"},"text":"57 Stat. 196","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s16a/b"},"text":"5 U.S.C. 16a(b)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 30, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/332"},"text":"Pub. L. 87–332","children":[],"tail":" (par. under “General Provision”), "},{"tag":"html:a","attrib":{"href":"/us/stat/75/743"},"text":"75 Stat. 743","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s92a"},"text":"5 U.S.C. 92a","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1926-07-03/ch752"},"text":"July 3, 1926, ch. 752","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/44/830"},"text":"44 Stat. 830","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “On and after ","children":[{"tag":"date","attrib":{"date":"1943-06-26"},"text":"June 26, 1943","children":[],"tail":"” are omitted as executed, and the word “officer” is omitted as included in “employee”. The words “Executive agency” are coextensive with and substituted for “executive departments or independent establishments, including any agency the majority of the stock of which is owned by the Government of the United States” because of the definition of “Executive agency” in section 105. The words “or the Secretary of a military department with respect to an employee of his department” are inserted to preserve the application of the source law. Before enactment of the National Security Act Amendments of 1949 ("},{"tag":"ref","attrib":{"href":"/us/stat/63/578"},"text":"63 Stat. 578","children":[],"tail":"), the Department of the Army, the Department of the Navy, and the Department of the Air Force were Executive departments. The National Security Act Amendments of 1949 established the Department of Defense as an Executive Department including the Department of the Army, the Department of the Navy, and the Department of the Air Force as military departments, not as Executive departments. However, the source law for this section, which was in effect in 1949, remained applicable to the Secretaries of the military departments by virtue of section 12(g) of the National Security Act Amendments of 1949 ("},{"tag":"ref","attrib":{"href":"/us/stat/63/591"},"text":"63 Stat. 591","children":[],"tail":"), which is set out in the reviser’s note for section 301. The words “of the Federal Government” and “and to have the same force and effect as oaths administered by officers having seals” are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “Constitution” is omitted because “laws”, as used in this title, encompasses the Constitution. In subsection (c)(1), the words “of the United States” are omitted as unnecessary. In subsection (c)(2), the words “an individual authorized by local law to administer oaths in the State, District, or territory, or possession of the United States where the oath is administered” are coextensive with and substituted for “notaries public duly appointed in any State, District, or Territory of the United States, by clerks and prothonotaries of courts of record of any such State, District, or Territory, by the deputies of such clerks and prothonotaries, and by all magistrates authorized by the laws of or pertaining to any such State, District, or Territory to administer oaths”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
