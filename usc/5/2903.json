{"tag":"section","attrib":{"id":"idb7f840e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2903"},"text":null,"children":[{"tag":"num","attrib":{"value":"2903"},"text":"§ 2903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oath; authority to administer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7f840e5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The oath of office required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3331"},"text":"section 3331 of this title","children":[],"tail":" may be administered by an individual authorized by the laws of the United States or local law to administer oaths in the State, District, or territory or possession of the United States where the oath is administered."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f840e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An employee of an Executive agency designated in writing by the head of the Executive agency, or the Secretary of a military department with respect to an employee of his department, may administer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f840e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the oath of office required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3331"},"text":"section 3331 of this title","children":[],"tail":", incident to entrance into the executive branch; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f840e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other oath required by law in connection with employment in the executive branch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f840e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An oath authorized or required under the laws of the United States may be administered by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f840ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Vice President; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f840eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual authorized by local law to administer oaths in the State, District, or territory or possession of the United States where the oath is administered.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7f840ec-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/411"},"text":"80 Stat. 411","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7f840ed-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","