{"tag":"section","attrib":{"id":"idb924b2e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983"},"text":null,"children":[{"tag":"num","attrib":{"value":"8983"},"text":"§ 8983.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracting authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb924b2ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb924b2eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall contract with a reasonable number of qualified companies for a policy or policies of benefits described under section 8984 without regard to section 6101(b) to (d) of title 41 or any other statute requiring competitive bidding. An employee organization may contract with a qualified company for the purpose of participating with that qualified company in any contract between the Office and that qualified company.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b2ec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall ensure that each resulting contract is awarded on the basis of contractor qualifications, price, and reasonable competition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b2ed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each contract under this section shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb924b2ee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements under section 8902(d), (f), and (i) made applicable to contracts under this section by regulations prescribed by the Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b2ef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of the enrollment period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b2f0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other terms and conditions as may be mutually agreed to by the Office and the qualified company involved, consistent with the requirements of this chapter and regulations prescribed by the Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b2f1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this chapter shall, in the case of an individual electing vision supplemental benefit coverage under this chapter after the expiration of such individual’s first opportunity to enroll, preclude the application of waiting periods more stringent than those that would have applied if that opportunity had not yet expired.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b2f2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb924b2f3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each contract under this chapter shall require the qualified company to agree—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb924b2f4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide payments or benefits to an eligible individual if such individual is entitled thereto under the terms of the contract; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b2f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to disputes regarding claims for payments or benefits under the terms of the contract—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb924b2f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish internal procedures designed to expeditiously resolve such disputes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb924b2f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish, for disputes not resolved through procedures under clause (i), procedures for 1 or more alternative means of dispute resolution involving independent third-party review under appropriate circumstances by entities mutually acceptable to the Office and the qualified company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b2f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A determination by a qualified company as to whether or not a particular individual is eligible to obtain coverage under this chapter shall be subject to review only to the extent and in the manner provided in the applicable contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb924b2f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of applying the Contract Disputes Act of 1978 ","children":[{"tag":"ref","attrib":{"idref":"fn002196"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002196"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" to disputes arising under this chapter between a qualified company and the Office—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb924b2fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency board having jurisdiction to decide an appeal relative to such a dispute shall be such board of contract appeals as the Director of the Office of Personnel Management shall specify in writing (after appropriate arrangements, as described in section 8(c) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of such Act); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb924b2fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the district courts of the United States shall have original jurisdiction, concurrent with the United States Court of Federal Claims, of any action described in section 10(a)(1) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of such Act relative to such a dispute."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b2fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section shall be considered to grant authority for the Office or third-party reviewer to change the terms of any contract under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb924b2fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8983/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Contracts under this chapter shall be for a uniform term of 7 years and may not be renewed automatically.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb924b2fe-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/496/s3"},"text":"Pub. L. 108–496, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/4007"},"text":"118 Stat. 4007","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5/a/17"},"text":"Pub. L. 111–350, § 5(a)(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3842"},"text":"124 Stat. 3842","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb924b2ff-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb924b300-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb924b301-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Contract Disputes Act of 1978, referred to in subsec. (d)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/563"},"text":"Pub. L. 95–563","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-01"},"text":"Nov. 1, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2383"},"text":"92 Stat. 2383","children":[],"tail":", which was classified principally to chapter 9 (§ 601 et seq.) of former Title 41, Public Contracts, and was substantially repealed and restated as chapter 71 (§ 7101 et seq.) of Title 41, Public Contracts, by "},{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", §§ 3, 7(b), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3677"},"text":"124 Stat. 3677","children":[],"tail":", 3855. Sections 8(c) and 10(a)(1) of the Act, which were classified to sections 607(c) and 609(a)(1), respectively, of former Title 41, were repealed and restated as section 7105(d), (e)(1)(C) and section 7104(b)(1), respectively, of Title 41. For complete classification of this Act to the Code, see Tables. For disposition of sections of former Title 41, see Disposition Table preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s101"},"text":"section 101 of Title 41","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb924b302-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “section 6101(b) to (d) of title 41” for “"},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"section 5 of title 41","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb924b303-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb924b304-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2004-12-23"},"text":"Dec. 23, 2004","children":[],"tail":", and applicable to contracts that take effect with respect to the calendar year 2006, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/496/s7"},"text":"section 7 of Pub. L. 108–496","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8951"},"text":"section 8951 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
