{"tag":"section","attrib":{"id":"idb7fcfc0b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114"},"text":null,"children":[{"tag":"num","attrib":{"value":"3114"},"text":"§ 3114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment of candidates to certain positions in the competitive service by the Securities and Exchange Commission","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7fcfc0c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies with respect to any position of accountant, economist, and securities compliance examiner at the Commission that is in the competitive service, and any position at the Commission in the competitive service that requires specialized knowledge of financial and capital market formation or regulation, financial market structures or surveillance, or information technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fcfc0d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7fcfc0e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Commission may appoint candidates to any position described in subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7fcfc0f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with the statutes, rules, and regulations governing appointments in the excepted service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7fcfc10-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any statutes, rules, and regulations governing appointments in the competitive service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7fcfc11-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The appointment of a candidate to a position under authority of this subsection shall not be considered to cause such position to be converted from the competitive service to the excepted service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7fcfc12-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No later than 90 days after the end of fiscal year 2003 (for fiscal year 2003) and 90 days after the end of fiscal year 2005 (for fiscal years 2004 and 2005), the Commission shall submit a report with respect to its exercise of the authority granted by subsection (b) during such fiscal years to the Committee on Government Reform and the Committee on Financial Services of the House of Representatives and the Committee on Governmental Affairs and the Committee on Banking, Housing, and Urban Affairs of the Senate. Such reports shall describe the changes in the hiring process authorized by such subsection, including relevant information related to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ff4603-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of candidates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4604-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedures used by the Commission to select candidates through the streamlined hiring process;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4605-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the numbers, types, and grades of employees hired under the authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4606-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any benefits or shortcomings associated with the use of the authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4607-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of the exercise of the authority on the hiring of veterans and other demographic groups; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ff4608-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the way in which managers were trained in the administration of the streamlined hiring system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7ff4609-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3114/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commission Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “Commission” means the Securities and Exchange Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7ff460a-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/44/s2/a"},"text":"Pub. L. 108–44, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-07-03"},"text":"July 3, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/842"},"text":"117 Stat. 842","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIX/s929G/a"},"text":"Pub. L. 111–203, title IX, § 929G(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1855"},"text":"124 Stat. 1855","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7ff460b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7ff460c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7ff460d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" substituted “Appointment of candidates to certain positions in the competitive service by the Securities and Exchange Commission” for “Appointment of accountants, economists, and examiners by the Securities and Exchange Commission” in section catchline, added subsec. (a), and struck out former subsec. (a). Prior to amendment, text read as follows: “This section applies with respect to any position of accountant, economist, and securities compliance examiner at the Commission that is in the competitive service.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7ff460e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb7ff460f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Government Reform of House of Representatives changed to Committee on Oversight and Government Reform of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Governmental Affairs of Senate changed to Committee on Homeland Security and Governmental Affairs of Senate, effective ","children":[{"tag":"date","attrib":{"date":"2005-01-04"},"text":"Jan. 4, 2005","children":[],"tail":", by Senate Resolution No. 445, One Hundred Eighth Congress, "},{"tag":"date","attrib":{"date":"2004-10-09"},"text":"Oct. 9, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7ff4610-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/203"},"text":"Pub. L. 111–203","children":[],"tail":" effective 1 day after "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/s4"},"text":"section 4 of Pub. L. 111–203","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s5301"},"text":"section 5301 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
