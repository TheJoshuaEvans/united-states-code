{"tag":"section","attrib":{"id":"idb8873b4e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5734"},"text":null,"children":[{"tag":"num","attrib":{"value":"5734"},"text":"§ 5734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel, transportation, and relocation expenses of employees transferred from the Postal Service","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding the provisions of any other law, officers and employees of the United States Postal Service promoted or transferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s1006"},"text":"section 1006 of title 39","children":[],"tail":", United States Code, from the Postal Service to an agency (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5721"},"text":"section 5721 of this title","children":[],"tail":"), for permanent duty may be authorized travel, transportation, and relocation expenses and allowances under the same conditions and to the same extent authorized by this subchapter for other transferred employees within the meaning of this chapter."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8873b4f-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/234/tI/s106/a"},"text":"Pub. L. 99–234, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-01-02"},"text":"Jan. 2, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1758"},"text":"99 Stat. 1758","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8873b50-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8873b51-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8873b52-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective (1) on effective date of regulations to be promulgated not later than 150 days after ","children":[{"tag":"date","attrib":{"date":"1986-01-02"},"text":"Jan. 2, 1986","children":[],"tail":", or (2) 180 days after "},{"tag":"date","attrib":{"date":"1986-01-02"},"text":"Jan. 2, 1986","children":[],"tail":", whichever occurs first, see "},{"tag":"ref","attrib":{"href":"/us/pl/99/234/s301/a"},"text":"section 301(a) of Pub. L. 99–234","children":[],"tail":", set out as an Effective Date of 1986 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5701"},"text":"section 5701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
