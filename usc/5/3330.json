{"tag":"section","attrib":{"id":"idb8125997-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3330"},"text":null,"children":[{"tag":"num","attrib":{"value":"3330"},"text":"§ 3330.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government-wide list of vacant positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8125998-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3330/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, the term “agency” means an Executive agency, excluding the Government Accountability Office and any agency (or unit thereof) whose principal function is the conduct of foreign intelligence or counterintelligence activities, as determined by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8125999-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3330/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall establish and keep current a comprehensive list of all announcements of vacant positions in the competitive service within each agency that are to be filled by appointment for more than one year and for which applications are being (or will soon be) accepted from outside the agency’s work force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb812599a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3330/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Included for any position listed shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb812599b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3330/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief description of the position, including its title, tenure, location, and rate of pay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb812599c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3330/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" application procedures, including the period within which applications may be submitted and procedures for obtaining additional information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb812599d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3330/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information which the Office considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb812599e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3330/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The list shall be available to members of the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb812599f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3330/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office shall prescribe such regulations as may be necessary to carry out this section. Any requirement under this section that agencies notify the Office as to the availability of any vacant positions shall be designed so as to avoid any duplication of information otherwise required to be furnished under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3327"},"text":"section 3327 of this title","children":[],"tail":" or any other provision of law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81259a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3330/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office may, to the extent it determines appropriate, charge such fees to agencies for services provided under this section and for related Federal employment information. The Office shall retain such fees to pay the costs of providing such services and information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb81259a1-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dD/tXLIV/s4431/a"},"text":"Pub. L. 102–484, div. D, title XLIV, § 4431(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2719"},"text":"106 Stat. 2719","children":[],"tail":", § 3329; renumbered § 3330 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/52/tIV/s4/1"},"text":"Pub. L. 104–52, title IV, § 4(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"Nov. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/490"},"text":"109 Stat. 490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1037/b/1"},"text":"Pub. L. 104–106, div. A, title X, § 1037(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/432"},"text":"110 Stat. 432","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb81259a2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb81259a3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb81259a4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":", which directed renumbering of the "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3329"},"text":"section 3329 of this title","children":[],"tail":" that was added by "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/s4431"},"text":"Pub. L. 102–484, § 4431","children":[],"tail":", as "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3330"},"text":"section 3330 of this title","children":[],"tail":", could not be executed because of the intervening renumbering of that section by "},{"tag":"ref","attrib":{"href":"/us/pl/104/52/s4/1/A"},"text":"Pub. L. 104–52, § 4(1)(A)","children":[],"tail":". See 1995 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/52/s4/1/A"},"text":"Pub. L. 104–52, § 4(1)(A)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3329"},"text":"section 3329 of this title","children":[],"tail":", relating to government-wide list of vacant positions, as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/52/s4/1/B"},"text":"Pub. L. 104–52, § 4(1)(B)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
