{"tag":"section","attrib":{"id":"idb8c79ece-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193"},"text":null,"children":[{"tag":"num","attrib":{"value":"8193"},"text":"§ 8193.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c79ecf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions and Rules of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c79ed0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Attorney General” includes any person to whom the Attorney General has delegated any function pursuant to subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c79ed1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary of Labor” includes any person to whom the Secretary of Labor has delegated any function pursuant to subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c79ed2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c79ed3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General may delegate to any division, officer, or employee of the Department of Justice any function conferred upon the Attorney General by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c79ed4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Labor may delegate to any bureau, officer, or employee of the Department of Labor any function conferred upon the Secretary of Labor by this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c79ed5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application for any benefit under this subchapter may be made only—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c79ed6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Secretary of Labor","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c79ed7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8c79ed8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any eligible officer or survivor of an eligible officer,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79ed9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any guardian, personal representative, or other person legally authorized to act on behalf of an eligible officer, his estate, or any of his survivors, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8c79eda-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any association of law enforcement officers which is acting on behalf of an eligible officer or any of his survivors;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c79edb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within five years after the injury or death; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c79edc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in such form as the Secretary of Labor may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c79edd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation With Attorney General and Other Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Labor may refer any application received by him pursuant to this subchapter to the Attorney General for his assistance, comments and advice as to any determination required to be made pursuant to paragraph (1), (2), or (3) of section 8191. To insure that all Federal assistance under this subchapter is carried out in a coordinated manner, the Secretary of Labor is authorized to request any Federal department or agency to supply any statistics, data, or any other materials he deems necessary to carry out his functions under this subchapter. Each such department or agency is authorized to cooperate with the Secretary of Labor and, to the extent permitted by law, to furnish such materials to him.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c79ede-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation With State Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Labor shall cooperate fully with the appropriate State and local officials, and shall take all other practicable measures, to assure that the benefits of this subchapter are made available to eligible officers and their survivors with a minimum of delay and difficulty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c79edf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8193/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c79ee0-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/291/s1/a"},"text":"Pub. L. 90–291, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-04-19"},"text":"Apr. 19, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/99"},"text":"82 Stat. 99","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/94/183/s2/31"},"text":"Pub. L. 94–183, § 2(31)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1058"},"text":"89 Stat. 1058","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c79ee1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c79ee2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c79ee3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1975—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/183"},"text":"Pub. L. 94–183","children":[],"tail":" redesignated subsec. (e), relating to appropriations, as subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c79ee4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8c79ee5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective only with respect to personal injuries sustained on or after ","children":[{"tag":"date","attrib":{"date":"1968-04-19"},"text":"Apr. 19, 1968","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/90/291/s2"},"text":"section 2 of Pub. L. 90–291","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8191"},"text":"section 8191 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
