{"tag":"section","attrib":{"id":"idb85c5a8e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5365"},"text":null,"children":[{"tag":"num","attrib":{"value":"5365"},"text":"§ 5365.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb85c5a8f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5365/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall prescribe regulations to carry out the purpose of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85c5a90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5365/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under such regulations, the Office may provide for the application of all or portions of the provisions of this subchapter (subject to any conditions or limitations the Office may establish)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85c5a91-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5365/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any individual reduced to a grade of a covered pay schedule from a position not subject to this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5365/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to individuals to whom such provisions do not otherwise apply; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85c5a93-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5365/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to situations the application to which is justified for purposes of carrying out the mission of the agency or agencies involved.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Individuals with respect to whom authority under paragraph (2) may be exercised include individuals who are moved without a break in service of more than 3 days from employment in nonappropriated fund instrumentalities of the Department of Defense or the Coast Guard described in section 2105(c) to employment in the Department of Defense or the Coast Guard, respectively, that is not described in section 2105(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb85c5a94-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVIII/s801/a/1"},"text":"Pub. L. 95–454, title VIII, § 801(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1220"},"text":"92 Stat. 1220","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tVII/s7202/f"},"text":"Pub. L. 101–508, title VII, § 7202(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-336"},"text":"104 Stat. 1388–336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/411/tIII/s301/a/6"},"text":"Pub. L. 108–411, title III, § 301(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2317"},"text":"118 Stat. 2317","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attr