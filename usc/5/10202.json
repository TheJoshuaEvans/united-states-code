{"tag":"section","attrib":{"id":"idb92e2a11-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10202"},"text":null,"children":[{"tag":"num","attrib":{"value":"10202"},"text":"§ 10202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92e2a12-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary is authorized to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e2a13-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10202/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fix and adjust rates of basic pay for members of the United States Secret Service Uniformed Division, subject to the requirements of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2a14-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10202/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine what constitutes an acceptable level of competence for the purposes of section 10205;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2a15-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10202/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and determine the positions at the Officer and Sergeant ranks to be included as technician positions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph"