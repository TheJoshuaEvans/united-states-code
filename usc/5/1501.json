{"tag":"section","attrib":{"id":"idb7eea4af-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1501"},"text":null,"children":[{"tag":"num","attrib":{"value":"1501"},"text":"§ 1501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7eea4b0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means a State or territory or possession of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eea4b1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State or local agency” means the executive branch of a State, municipality, or other political subdivision of a State, or an agency or department thereof, or the executive branch of the District of Columbia, or an agency or department thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eea4b2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal agency” means an Executive agency or other agency of the United States, but does not include a member bank of the Federal Reserve System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eea4b3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “State or local officer or employee” means an individual employed by a State or local agency whose principal employment is in connection with an activity which is financed in whole or in part by loans or grants made by the United States or a Federal agency, but does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7eea4b4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1501/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who exercises no functions in connection with that activity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7eea4b5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1501/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an individual employed by an educational or research institution, establishment, agency, or system which is supported in whole or in part by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7eea4b6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1501/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State or political subdivision thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7eea4b7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1501/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7eea4b8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1501/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a recognized religious, philanthropic, or cultural organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7eea4b9-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/403"},"text":"80 Stat. 403","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/443/tIV/s401/c"},"text":"Pub. L. 93–443, title IV, § 401(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-15"},"text":"Oct. 15, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1290"},"text":"88 Stat. 1290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/230/s3/a"},"text":"Pub. L. 112–230, § 3(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2012-12-28"},"text":"Dec. 28, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1616"},"text":"126 Stat. 1616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7eea4ba-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7eea4bb-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7eea4bc-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","att