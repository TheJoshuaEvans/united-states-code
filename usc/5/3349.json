{"tag":"section","attrib":{"id":"idb819853e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349"},"text":null,"children":[{"tag":"num","attrib":{"value":"3349"},"text":"§ 3349.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting of vacancies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb819853f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of each Executive agency (including the Executive Office of the President, and other than the Government Accountability Office) shall submit to the Comptroller General of the United States and to each House of Congress—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8198540-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notification of a vacancy in an office to which this section and sections 3345, 3346, 3347, 3348, 3349a, 3349b, 3349c, and 3349d apply and the date such vacancy occurred immediately upon the occurrence of the vacancy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198541-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of any person serving in an acting capacity and the date such service began immediately upon the designation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198542-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of any person nominated to the Senate to fill the vacancy and the date such nomination is submitted immediately upon the submission of the nomination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198543-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of a rejection, withdrawal, or return of any nomination immediately upon such rejection, withdrawal, or return.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8198544-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Comptroller General of the United States makes a determination that an officer is serving longer than the 210-day period including the applicable exceptions to such period under section 3346 or section 3349a, the Comptroller General shall report such determination immediately to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8198545-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Governmental Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198546-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Government Reform and Oversight of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198547-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committees on Appropriations of the Senate and House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198548-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate committees of jurisdiction of the Senate and House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8198549-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb819854a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3349/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb819854b-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s151/b"},"text":"Pub. L. 105–277, div. C, title I, § 151(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-614"},"text":"112 Stat. 2681–614","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb819854c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb819854d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb819854e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3349, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/426"},"text":"80 Stat. 426","children":[],"tail":", provided for restrictions relating to details to fill vacancies, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s151/b"},"text":"Pub. L. 105–277, div. C, title I, § 151(b)","children":[],"tail":", (d)(1), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-611"},"text":"112 Stat. 2681–611","children":[],"tail":", 2681–616, effective 30 days after "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3347"},"text":"section 3347 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb819854f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8198550-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb8198551-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Governmental Affairs of Senate changed to Committee on Homeland Security and Governmental Affairs of Senate, effective ","children":[{"tag":"date","attrib":{"date":"2005-01-04"},"text":"Jan. 4, 2005","children":[],"tail":", by Senate Resolution No. 445, One Hundred Eighth Congress, "},{"tag":"date","attrib":{"date":"2004-10-09"},"text":"Oct. 9, 2004","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Government Reform and Oversight of House of Representatives changed to Committee on Government Reform of House of Representatives by House Resolution No. 5, One Hundred Sixth Congress, ","children":[{"tag":"date","attrib":{"date":"1999-01-06"},"text":"Jan. 6, 1999","children":[],"tail":". Committee on Government Reform of House of Representatives changed to Committee on Oversight and Government Reform of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, "},{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8198552-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 30 days after ","children":[{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", and applicable to any office that becomes vacant after such effective date, with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/s151/d"},"text":"section 151(d) of Pub. L. 105–277","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3345"},"text":"section 3345 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
