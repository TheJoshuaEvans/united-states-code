{"tag":"section","attrib":{"id":"idb92bb850-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9811"},"text":null,"children":[{"tag":"num","attrib":{"value":"9811"},"text":"§ 9811.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Travel and transportation expenses of certain new appointees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92bb851-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9811/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, the term “new appointee” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92bb852-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9811/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person newly appointed or reinstated to Federal service to the Administration to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92bb853-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9811/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a career or career-conditional appointment or an excepted service appointment to a continuing position;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92bb854-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9811/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a term appointment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92bb855-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9811/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an excepted service appointment that provides for noncompetitive conversion to a career or career-conditional appointment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92bb856-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9811/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a career or limited term Senior Executive Service appointment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92bb857-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9811/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appointment made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s20113/b/1"},"text":"section 20113(b)(1) of title 51","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92bb858-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9811/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appointment to a position established under section 3104; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92bb859-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9811/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appointment to a position established under section 5108; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92bb85a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9811/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a student trainee who, upon completion of academic work, is converted to an appointment in the Administration that is identified in paragraph (1) in accordance with an appropriate authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92bb85b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9811/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may pay the travel, transportation, and relocation expenses of a new appointee to the same extent, in the same manner, and subject to the same conditions as the payment of such expenses under sections 5724, 5724a, 5724b, and 5724c to an employee transferred in the interests of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92bb85c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/201/s3/a"},"text":"Pub. L. 108–201, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-02-24"},"text":"Feb. 24, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/472"},"text":"118 Stat. 472","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/a"},"text":"Pub. L. 111–314, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-18"},"text":"Dec. 18, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3440"},"text":"124 Stat. 3440","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92bb85d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92bb85e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb92bb85f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314"},"text":"Pub. L. 111–314","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t51/s20113/b/1"},"text":"section 20113(b)(1) of title 51","children":[],"tail":"” for “section 203(c)(2)(A) of the National Aeronautics and Space Act of 1958 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2473/c/2/A"},"text":"42 U.S.C. 2473(c)(2)(A)","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
