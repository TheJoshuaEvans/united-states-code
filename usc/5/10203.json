l,"children":[{"tag":"html:span","attrib":{},"text":"Assistant Chief","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{"colspan":"13"},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"The rate of basic pay ","children":[{"tag":"html:a","attrib":{"href":"#TAB_573_0"},"text":null,"children":[{"tag":"html:sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":" the Assistant Chief position will be equal to 95 percent of the rate of pay for level V of the Executive Schedule."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Chief","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{"colspan":"13"},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"The rate of basic pay ","children":[{"tag":"html:a","attrib":{"href":"#TAB_573_0"},"text":null,"children":[{"tag":"html:sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":" the Chief position will be equal to the rate of pay for level V of the Executive Schedule."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e2a20-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Schedule Adjustment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e2a21-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10203/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92e2a22-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10203/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effective at the beginning of the first pay period commencing on or after the first day of the month in which an adjustment in the rates of basic pay under the General Schedule takes effect under section 5303 or other authority, the schedule of annual rates of basic pay of members (except the Deputy Chiefs, Assistant Chief and Chief) shall be adjusted by the Secretary by a percentage amount corresponding to the percentage adjustment made in the rates of pay under the General Schedule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92e2a23-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10203/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may establish a methodology of schedule adjustment that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb92e2a24-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10203/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results in uniform fixed-dollar step increments within any given rank; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb92e2a25-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10203/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserves the established percentage differences among rates of different ranks at the same step position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2a26-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10203/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding paragraph (1), the payable annual rate of basic pay for positions at the Lieutenant, Captain, and Inspector ranks after adjustment under paragraph (1) may not exceed 95 percent of the rate of pay for level V of the Executive Schedule under subchapter II of chapter 53.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e2a27-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10203/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Locality-based comparability payments authorized under section 5304 shall be applicable to the basic pay for all ranks under this section, except locality-based comparability payments may not be paid at a rate which, when added to the rate of basic pay otherwise payable to the member, would cause the total to exceed the rate of basic pay payable for level IV of the Executive Schedule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92e2a28-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/282/s2/a"},"text":"Pub. L. 111–282, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3034"},"text":"124 Stat. 3034","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92e2a29-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92e2a2a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb92e2a2b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Levels IV and V of the Executive Schedule, referred to in subsecs. (a) and (b)(2), (3), are set out in sections 5315 and 5316, respectively, of this title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (b)(1)(A), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb92e2a2c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb92e2a2d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of first pay period which begins after ","children":[{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/282/s5"},"text":"section 5 of Pub. L. 111–282","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5102"},"text":"section 5102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
