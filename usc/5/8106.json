{"tag":"section","attrib":{"id":"idb8be29a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8106"},"text":null,"children":[{"tag":"num","attrib":{"value":"8106"},"text":"§ 8106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Partial disability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8be29a4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the disability is partial, the United States shall pay the employee during the disability monthly monetary compensation equal to 66⅔ percent of the difference between his monthly pay and his monthly wage-earning capacity after the beginning of the partial disability, which is known as his basic compensation for partial disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be29a5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Labor may require a partially disabled employee to report his earnings from employment or self-employment, by affidavit or otherwise, in the manner and at the times the Secretary specifies. The employee shall include in the affidavit or report the value of housing, board, lodging, and other advantages which are part of his earnings in employment or self-employment and which can be estimated in money. An employee who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8be29a6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fails to make an affidavit or report when required; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29a7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly omits or understates any part of his earnings;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"forfeits his right to compensation with respect to any period for which the affidavit or report was required. Compensation forfeited under this subsection, if already paid, shall be recovered by a deduction from the compensation payable to the employee or otherwise recovered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8129"},"text":"section 8129 of this title","children":[],"tail":", unless recovery is waived under that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be29a8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A partially disabled employee who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8be29a9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuses to seek suitable work; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be29aa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuses or neglects to work after suitable work is offered to, procured by, or secured for him;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is not entitled to compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8be29ab-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/536"},"text":"80 Stat. 536","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8be29ac-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8be29ad-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8be29ae-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s754"},"text":"5 U.S.C. 754","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-09-07/ch458/s4"},"text":"Sept. 7, 1916, ch. 458, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/743"},"text":"39 Stat. 743","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-14/ch691/s103/a"},"text":"Oct. 14, 1949, ch. 691, § 103(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/855"},"text":"63 Stat. 855","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Except as otherwise provided in sections 751–756, 757–781, 783–791, and 793 of this title” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “remuneration” is omitted as covered by the word “earnings”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Administration of this subchapter was transferred to the Secretary of Labor by section 1 of 1950 Reorg. Plan No. 19, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1271"},"text":"64 Stat. 1271","children":[],"tail":" (see section 8145)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
