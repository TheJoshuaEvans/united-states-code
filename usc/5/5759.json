{"tag":"section","attrib":{"id":"idb889ac7b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5759"},"text":null,"children":[{"tag":"num","attrib":{"value":"5759"},"text":"§ 5759.","children":[{"tag":"ref","attrib":{"idref":"fn002123"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002123"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No section 5758 has been enacted."}],"tail":null}],"tail":null},{"tag":"heading","attrib":{},"text":" Retention and relocation bonuses for the Federal Bureau of Investigation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb889ac7c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5759/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Federal Bureau of Investigation, after consultation with the Director of the Office of Personnel Management, may pay, on a case-by-case basis, a bonus under this section to an employee of the Bureau if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb889ac7d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5759/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb889ac7e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5759/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the unusually high or unique qualifications of the employee or a special need of the Bureau for the employee’s services makes it essential to retain the employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb889ac7f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5759/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Director of the Federal Bureau of Investigation determines that, in the absence of such a bonus, the employee would be likely to leave—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb889ac80-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5759/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb889ac81-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5759/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a different position in the Federal service; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac82-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5759/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual is subject to a mobility agreement and is transferred to a position in a different geographical area in which there is a shortage of critical skills (as determined by the Director of the Federal Bureau of Investigation).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac83-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5759/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Payment of a bonus under this section is contingent upon the employee entering into a written service agreement with the Bureau to complete a period of service with the Bureau. Such agreement shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb889ac84-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5759/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the period of service the individual shall be required to complete in return for the bonus; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac85-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5759/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conditions under which the agreement may be terminated before the agreed-upon service period has been completed, and the effect of the termination, including requirements for a bonus recipient’s repayment of a bonus in circumstances determined by the Director of the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac86-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5759/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus paid under this section may not exceed 50 percent of the employee’s annual rate of basic pay. The bonus may be paid in a lump sum or installments linked to completion of periods of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac87-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5759/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Impact on Basic Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A bonus paid under this section is not part of the basic pay of an employee for any purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb889ac88-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dB/tI/s113/a"},"text":"Pub. L. 108–447, div. B, title I, § 113(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2868"},"text":"118 Stat. 2868","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/117/dB/tII/s217"},"text":"Pub. L. 111–117, div. B, title II, § 217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-12-16"},"text":"Dec. 16, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3141"},"text":"123 Stat. 3141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIV/s443"},"text":"Pub. L. 111–259, title IV, § 443","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2733"},"text":"124 Stat. 2733","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb889ac89-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb889ac8a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb889ac8b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s443/1"},"text":"Pub. L. 111–259, § 443(1)","children":[],"tail":", substituted “is subject to a mobility agreement and is transferred to a position in a different geographical area in which there is a shortage of critical skills” for “is transferred to a different geographic area with a higher cost of living”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s443/2"},"text":"Pub. L. 111–259, § 443(2)","children":[],"tail":", substituted “, including requirements for a bonus recipient’s repayment of a bonus in circumstances determined by the Director of the Federal Bureau of Investigation.” for the period."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s443/3"},"text":"Pub. L. 111–259, § 443(3)","children":[],"tail":", substituted “annual rate of basic pay. The bonus may be paid in a lump sum or installments linked to completion of periods of service.” for “basic pay.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259/s443/4"},"text":"Pub. L. 111–259, § 443(4)","children":[],"tail":", substituted “bonus paid under this section” for “retention bonus”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/117"},"text":"Pub. L. 111–117","children":[],"tail":" struck out subsec. (e). Text read as follows: “The authority to grant bonuses under this section shall cease to be available after "},{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
