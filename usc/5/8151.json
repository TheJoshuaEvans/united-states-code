{"tag":"section","attrib":{"id":"idb8c52e86-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8151"},"text":null,"children":[{"tag":"num","attrib":{"value":"8151"},"text":"§ 8151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil service retention rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8c52e87-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event the individual resumes employment with the Federal Government, the entire time during which the employee was receiving compensation under this chapter shall be credited to the employee for the purposes of within-grade step increases, retention purposes, and other rights and benefits based upon length of service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8c52e88-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations issued by the Office of Personnel Management—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c52e89-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8151/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the department or agency which was the last employer shall immediately and unconditionally accord the employee, if the injury or disability has been overcome within one year after the date of commencement of compensation or from the time compensable disability recurs if the recurrence begins after the injured employee resumes regular full-time employment with the United States, the right to resume his former or an equivalent position, as well as all other attendant rights which the employee would have had, or acquired, in his former position had he not been injured or disabled, including the rights to tenure, promotion, and safeguards in reductions-in-force procedures, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c52e8a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8151/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the department or agency which was the last employer shall, if the injury or disability is overcome within a period of more than one year after the date of commencement of compensation, make all reasonable efforts to place, and accord priority to placing, the employee in his former or equivalent position within such department or agency, or within any other department or agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c52e8b-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/416/s22"},"text":"Pub. L. 93–416, § 22","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1149"},"text":"88 Stat. 1149","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/a/2"},"text":"Pub. L. 95–454, title IX, § 906(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1224"},"text":"92 Stat. 1224","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c52e8c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8c52e8d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8c52e8e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Office of Personnel Management” for “Civil Service Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8c52e8f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8c52e90-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb8c52e91-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to cases where injury or death occurred prior to ","children":[{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", but only to a period beginning on or after "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s28/a"},"text":"section 28(a) of Pub. L. 93–416","children":[],"tail":", set out as an Effective Date of 1974 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8101"},"text":"section 8101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
