{"tag":"section","attrib":{"id":"idb8f4f0d6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8410"},"text":null,"children":[{"tag":"num","attrib":{"value":"8410"},"text":"§ 8410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eligibility for annuity","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of this chapter, an employee or Member must complete at least 5 years of civilian service creditable under section 8411 in order to be eligible for an annuity under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8f4f0d7-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/335/tI/s101/a"},"text":"Pub. L. 99–335, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-06-06"},"text":"June 6, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/522"},"text":"100 Stat. 522","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
