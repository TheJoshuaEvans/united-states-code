{"tag":"section","attrib":{"id":"idb890d7ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5943"},"text":null,"children":[{"tag":"num","attrib":{"value":"5943"},"text":"§ 5943.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign currency appreciation allowances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb890d7cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5943/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President, under such regulations as he may prescribe, may meet losses sustained by employees and members of the uniformed services while serving in a foreign country due to the appreciation of foreign currency in its relation to the American dollar. Allowances and expenditures under this section are not subject to income taxes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb890d7cc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5943/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Annual appropriations are authorized to carry out subsection (a) of this section and to cover any deficiency in the accounts of the Secretary of the Treasury, including interest, arising out of the arrangement approved by the President on ","children":[{"tag":"date","attrib":{"date":"1933-07-27"},"text":"July 27, 1933","children":[],"tail":", for the conversion into foreign currency of checks and drafts of employees and members of the uniformed services for pay and expenses."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb890d7cd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5943/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Payment under subsection (a) of this section may not be made to an employee or member of a uniformed service for a period during which his check or draft was converted into foreign currency under the arrangement referred to by subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb890d7ce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5943/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall report annually to Congress all expenditures made under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb890d7cf-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/513"},"text":"80 Stat. 513","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/37"},"text":"Pub. L. 96–54, § 2(a)(37)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/383"},"text":"93 Stat. 383","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb890d7d0-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb890d7d1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb890d7d2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html: