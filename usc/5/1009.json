{"tag":"section","attrib":{"id":"idb7de0269-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1009"},"text":null,"children":[{"tag":"num","attrib":{"value":"1009"},"text":"§ 1009.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory committee procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7de026a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1009/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Committee Meetings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7de026b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1009/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Open to public","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each advisory committee meeting shall be open to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7de026c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1009/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except when the President determines otherwise for reasons of national security, timely notice of each meeting shall be published in the Federal Register, and the Administrator shall prescribe regulations to provide for other types of public notice to insure that all interested persons are notified of each meeting in advance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7de026d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1009/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Interested persons shall be permitted to attend, appear before, or file statements with any advisory committee, subject to such reasonable rules or regulations as the Administrator may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7de026e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1009/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Inspection and Copying of Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of this title","children":[],"tail":", the records, reports, transcripts, minutes, appendixes, working papers, drafts, studies, agenda, or other documents which were made available to or prepared for or by each advisory committee shall be available for public inspection and copying at a single location in the offices of the advisory committee or the agency to which the advisory committee reports until the advisory committee ceases to exist."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7de026f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1009/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minutes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Detailed minutes of each meeting of each advisory committee shall be kept and shall contain a record of the persons present, a complete and accurate description of matters discussed and conclusions reached, and copies of all reports received, issued, or approved by the advisory committee. The accuracy of all minutes shall be certified by the chairman of the advisory committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7de0270-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1009/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Closed Sessions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraphs (1) and (3) of subsection (a) shall not apply to any portion of an advisory committee meeting for which the President, or the head of the agency to which the advisory committee reports, determines that such portion of the meeting may be closed to the public in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b/c"},"text":"section 552b(c) of this title","children":[],"tail":". Any such determination shall be in writing and shall contain the reasons for the determination. If such a determination is made, the advisory committee shall issue a report, at least annually, setting forth a summary of its activities and such related matters as would be informative to the public consistent with the policy of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7de0271-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1009/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designated Officer or Employee of Federal Government","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There shall be designated an officer or employee of the Federal Government to chair or attend each meeting of each advisory committee. The officer or employee so designated is authorized, whenever the officer or employee determines it to be in the public interest, to adjourn any such meeting. An advisory committee shall not conduct any meeting in the absence of that designated officer or employee of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7de0272-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1009/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Call for Meeting or Advance Approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Advisory committees shall not hold any meetings except at the call of, or with the advance approval of, a designated officer or employee of the Federal Government, and in the case of advisory committees (other than Presidential advisory committees), with an agenda approved by such officer or employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7de0273-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s3/a"},"text":"Pub. L. 117–286, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4202"},"text":"136 Stat. 4202","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7de0274-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7de0275-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7de0276-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1009","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 U.S.C. App. (FACA § 10)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/pl/92/463/s10"},"text":"Pub. L. 92–463, § 10","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Oct. 6, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/774"},"text":"86 Stat. 774","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/pl/94/409/s5/c"},"text":"Pub. L. 94–409, § 5(c)","children":[],"tail":", "},{"tag":"html:span","attrib":{},"text":"Sept. 13, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1247"},"text":"90 Stat. 1247","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), in paragraphs (2) and (3), the word “Administrator” is substituted for “Director” (meaning the Director of the Office of Management and Budget) because of section 5F of Reorganization Plan No. 1 of 1977 (5 U.S.C. App.).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
