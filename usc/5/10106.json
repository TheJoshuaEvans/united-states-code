{"tag":"section","attrib":{"id":"idb92e29f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10106"},"text":null,"children":[{"tag":"num","attrib":{"value":"10106"},"text":"§ 10106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarterly report on vacancy rate in employee positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92e29f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial Report.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e29f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 3 months after the date of enactment of this chapter, the Administrator shall develop and submit to the appropriate committees of Congress a report on the vacancies in employee positions of the Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92e29f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under this subsection shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb92e29f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10106/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vacancies of each category of employee position;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92e29fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10106/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of applicants for each vacancy for which public notice has been given;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92e29fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10106/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the length of time that each vacancy has been pending;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92e29fc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10106/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hiring-cycle time for each vacancy that has been filled; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb92e29fd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10106/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for reducing the hiring-cycle time and reducing the current and anticipated vacancies with highly-qualified personnel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92e29fe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly Updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 3 months after submission of the initial report, and every 3 months thereafter until 5 years after the date of enactment of this chapter, the Administrator shall submit to the appropriate committees of Congress an update of the report under subsection (a), including an assessment by the Administrator of the progress of the Agency in filling vacant employee positions of the Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92e29ff-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295/tVI/s621/a"},"text":"Pub. L. 109–295, title VI, § 621(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1416"},"text":"120 Stat. 1416","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb92e2a00-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb92e2a01-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb92e2a02-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this chapter, referred to in subsecs. (a)(1) and (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/295"},"text":"Pub. L. 109–295","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2006-10-04"},"text":"Oct. 4, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
