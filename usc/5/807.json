{"tag":"section","attrib":{"id":"idb7d92007-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s807"},"text":null,"children":[{"tag":"num","attrib":{"value":"807"},"text":"§ 807.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption for monetary policy","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall apply to rules that concern monetary policy proposed or implemented by the Board of Governors of the Federal Reserve System or the Federal Open Market Committee.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7d92008-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/121/tII/s251"},"text":"Pub. L. 104–121, title II, § 251","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-29"},"text":"Mar. 29, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/874"},"text":"110 Stat. 874","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
