{"tag":"section","attrib":{"id":"idb87427db-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5550b"},"text":null,"children":[{"tag":"num","attrib":{"value":"5550b"},"text":"§ 5550b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensatory time off for travel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb87427dc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5550b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any provision of section 5542(b)(2) or 5544(a), each hour spent by an employee in travel status away from the official duty station of the employee, that is not otherwise compensable, shall be treated as an hour of work or employment for purposes of calculating compensatory time off.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb87427dd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5550b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee who has any hours treated as hours of work or employment for purposes of calculating compensatory time under subsection (a), shall not be entitled to payment for any such hours that are unused as compensatory time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb87427de-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/411/tII/s203/a"},"text":"Pub. L. 108–411, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2313"},"text":"118 Stat. 2313","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXI/s1111/a"},"text":"Pub. L. 110–181, div. A, title XI, § 1111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/360"},"text":"122 Stat. 360","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb87427df-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb87427e0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb87427e1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" substituted “any provision of section 5542(b)(2) or 5544(a),” for “section 5542(b)(2),”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb87427e2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb87427e3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" effective on the earlier of the effective date of any regulations prescribed to carry out amendments by "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1111"},"text":"section 1111 of Pub. L. 110–181","children":[],"tail":" or the 90th day after "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/s1111/c"},"text":"section 1111(c) of Pub. L. 110–181","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5541"},"text":"section 5541 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb87427e4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/411/tII/s203/c"},"text":"Pub. L. 108–411, title II, § 203(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2313"},"text":"118 Stat. 2313","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/411/tII/s203/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by this section [enacting this section] shall take effect on the earlier of—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date of any regulations prescribed to carry out such amendments; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 90th day after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb87427e5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Compensatory Time Off for Travel for Department of Justice Attorneys","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/425/s1"},"text":"Pub. L. 109–425, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2910"},"text":"120 Stat. 2910","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/425/s1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Attorneys employed by the Department of Justice (including assistant United States attorneys) shall be eligible for compensatory time off for travel under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5550b"},"text":"section 5550b of title 5","children":[],"tail":", United States Code, without regard to any provision of section 115 of the Departments of Commerce, Justice, and State, the Judiciary, and Related Agencies Appropriations Act, 2000 (as enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/s1000/a/1"},"text":"section 1000(a)(1) of Public Law 106–113","children":[],"tail":" and reenacted by section 111 of the Department of Justice Appropriations Act, 2001 (as enacted into law by appendix B of "},{"tag":"ref","attrib":{"href":"/us/pl/106/553"},"text":"Public Law 106–553","children":[],"tail":") [set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5541"},"text":"section 5541 of this title","children":[],"tail":"])."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall apply with respect to time spent in travel status on or after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
