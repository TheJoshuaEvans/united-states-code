ren":[],"tail":", (d) (last 27 words, less applicability to subsection (b))."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-06-30/ch212/s604/d"},"text":"June 30, 1945, ch. 212, § 604(d)","children":[],"tail":", (e) (last 27 words, less applicability to subsection (b)), "},{"tag":"html:a","attrib":{"href":"/us/stat/59/303"},"text":"59 Stat. 303","children":[],"tail":", 304."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-28/ch782/s1203"},"text":"Oct. 28, 1949, ch. 782, § 1203","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/973"},"text":"63 Stat. 973","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"June 20, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/462/s15"},"text":"Pub. L. 85–462, § 15","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/214"},"text":"72 Stat. 214","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 14, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/426/s103/c"},"text":"Pub. L. 88–426, § 103(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/402"},"text":"78 Stat. 402","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Beginning not later than ","children":[{"tag":"date","attrib":{"date":"1945-10-01"},"text":"October 1, 1945","children":[],"tail":"” are omitted as executed. Paragraphs (1) and (3) are substituted for the words “all officers and employees of the organizations referred to in subsection (a) of this section”. In paragraph (A), the words “Canal Zone Government” and “Panama Canal Company” are substituted for “The Panama Canal” and “Panama Railroad Company” on authority of the "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-26/ch1049/s2/a"},"text":"Act of Sept. 26, 1950, ch. 1049, § 2(a)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1038"},"text":"64 Stat. 1038","children":[],"tail":". Paragraph (B) is added on authority of former section 902, which is carried into section 5541."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the exception in the last sentence is added on authority of former section 902, which is carried into section 5541.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is added on authority of former section 945, which is carried into section 5548. The words “an Executive agency” are substituted for “the executive branch of the Government” to conform to the definition in section 105. Applicability of this section to employees of the General Accounting Office is based on former section 933a.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8638695-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1967 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This section amends ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5504"},"text":"5 U.S.C. 5504","children":[],"tail":" to reflect the amendment to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6101"},"text":"5 U.S.C. 6101","children":[],"tail":" by section 1(43) of this bill."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8638696-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8638697-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1124/a/2"},"text":"Pub. L. 108–136, § 1124(a)(2)","children":[],"tail":", struck out last sentence which defined “employee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1124/a/3"},"text":"Pub. L. 108–136, § 1124(a)(3)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1124/a/1"},"text":"Pub. L. 108–136, § 1124(a)(1)","children":[],"tail":", (b), redesignated subsec. (c) as (d), inserted “(1)” after “(d)”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" struck out first sentence which provided that for pay computation purposes affecting an employee, the annual rate of basic pay established by or under statute is deemed payment for employment during 52 basic administrative workweeks of 40 hours, inserted “, in the case of an employee,” after “When” in second sentence, substituted “2,087” for “2,080” in par. (1), and inserted “other than an employee or individual excluded by "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5541/2/xvi"},"text":"section 5541(2)(xvi) of this title","children":[],"tail":"” at end of last sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (a)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/70"},"text":"Pub. L. 96–70","children":[],"tail":" substituted “Panama Canal Commission” for “Canal Zone Government or the Panama Canal Company”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" substituted “(xvi) of this title” for “(xvi) of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s408/a/1"},"text":"Pub. L. 95–454, § 408(a)(1)","children":[],"tail":", in par. (B) inserted reference to an employee or individual excluded by section 5541(2)(xvi)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/s906/a/2"},"text":"Pub. L. 95–454, § 906(a)(2)","children":[],"tail":", substituted “Office of Personnel Management” for “Civil Service Commission”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8638698-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8638699-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text