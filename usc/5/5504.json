{"tag":"section","attrib":{"id":"idb863867f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504"},"text":null,"children":[{"tag":"num","attrib":{"value":"5504"},"text":"§ 5504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biweekly pay periods; computation of pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8638680-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The pay period for an employee covers two administrative workweeks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8638681-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When, in the case of an employee, it is necessary for computation of pay under this subsection to convert an annual rate of basic pay to a basic hourly, daily, weekly, or biweekly rate, the following rules govern:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8638682-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To derive an hourly rate, divide the annual rate by 2,087.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8638683-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To derive a daily rate, multiply the hourly rate by the number of daily hours of service required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8638684-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To derive a weekly or biweekly rate, multiply the hourly rate by 40 or 80, as the case may be.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Rates are computed to the nearest cent, counting one-half and over as a whole cent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8638685-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purposes of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8638686-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8638687-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee in or under an Executive agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8638688-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee in or under the Office of the Architect of the Capitol, the Botanic Garden, and the Library of Congress, for whom a basic administrative workweek is established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6101/a/5"},"text":"section 6101(a)(5) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8638689-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual employed by the government of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb863868a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “employee” does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb863868b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee on the Isthmus of Panama in the service of the Panama Canal Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb863868c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee or individual excluded from the definition of employee in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5541/2"},"text":"section 5541(2) of this title","children":[],"tail":" other than an employee or individual excluded by clauses (ii), (iii), and (xiv) through (xvii) of such section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb863868d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding paragraph (2), an individual who otherwise would be excluded from the definition of employee shall be deemed to be an employee for purposes of this section if the individual’s employing agency so elects, under guidelines in regulations promulgated by the Office of Personnel Management under subsection (d)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb863868e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb863868f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management may prescribe regulations, subject to the approval of the President, necessary for the administration of this section insofar as this section affects employees in or under an Executive agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8638690-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5504/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall provide guidelines by regulation for exemptions to be made by the heads of agencies under subsection (c)(3). Such guidelines shall provide for such exemptions only under exceptional circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8638691-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/475"},"text":"80 Stat. 475","childr