{"tag":"section","attrib":{"id":"idb88bf628-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5923"},"text":null,"children":[{"tag":"num","attrib":{"value":"5923"},"text":"§ 5923.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarters allowances","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb88bf629-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5923/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When Government owned or rented quarters are not provided without charge for an employee in a foreign area, one or more of the following quarters allowances may be granted when applicable:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb88bf62a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5923/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A temporary subsistence allowance for the reasonable cost of temporary quarters (including meals and laundry expenses) incurred by the employee and his family—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb88bf62b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5923/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period not in excess of 90 days after first arrival at a new post of assignment in a foreign area or a period ending with the occupation of residence quarters, whichever is shorter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb88bf62c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5923/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period of not more than 30 days immediately before final departure from the post after the necessary evacuation of residence quarters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb88bf62d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5923/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A living quarters allowance for rent, heat, light, fuel, gas, electricity, and water, without regard to section 3324(a) and (b) of title 31.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb88bf62e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5923/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under unusual circumstances, payment or reimbursement for extraordinary, necessary, and reasonable expenses, not otherwise compensated for, incurred in initial repairs, alterations, and improvements to the privately leased residence of an employee at a post of assignment in a foreign area, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb88bf62f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5923/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expenses are administratively approved in advance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb88bf630-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5923/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the duration and terms of the lease justify payment of the expenses by the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb88bf631-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5923/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The 90-day period under subsection (a)(1)(A) and the 30-day period under subsection (a)(1)(B) may each be extended for not more than 60 additional days if the head of the agency concerned or his designee determines that there are compelling reasons beyond the control of the employee for the continued occupancy of temporary quarters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb88bf632-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/511"},"text":"80 Stat. 511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/258/s3/a/15"},"text":"Pub. L. 97–258, § 3(a)(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1063"},"text":"96 Stat. 1063","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/138/tI/s147/d"},"text":"Pub. L. 102–138, title I, § 147(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-28"},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/669"},"text":"105 Stat. 669","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb88bf633-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb88bf634-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb88bf635-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s3036"},"text":"5 U.S.C. 3036","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 6, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/707/s211"},"text":"Pub. L. 86–707, § 211","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/793"},"text":"74 Stat. 793","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb88bf636-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb88bf637-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/138"},"text":"Pub. L. 102–138","children":[],"tail":" designated existing provisions as subsec. (a), substituted “subsistence” for “lodging” and inserted “(including meals and laundry expenses)” after “quarters” in par. (1), substituted “90 days” for “3 months” in par. (1)(A), substituted “30 days” for “1 month” in par. (1)(B), and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":" substituted “section 3324(a) and (b)” for “section 529”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
