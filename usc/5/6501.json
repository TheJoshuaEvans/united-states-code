{"tag":"section","attrib":{"id":"idb8a17a2e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6501"},"text":null,"children":[{"tag":"num","attrib":{"value":"6501"},"text":"§ 6501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a17a2f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “employee” has the meaning given that term under section 2105.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a30-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in section 6506, the term “executive agency” has the meaning given that term under section 105.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a31-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Telework","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “telework” or “teleworking” refers to a work flexibility arrangement under which an employee performs the duties and responsibilities of such employee’s position, and other authorized activities, from an approved worksite other than the location from which the employee would otherwise work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a17a32-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/292/s2/a"},"text":"Pub. L. 111–292, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3165"},"text":"124 Stat. 3165","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a17a33-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8a17a34-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8a17a35-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Telework Research","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/292/s4"},"text":"Pub. L. 111–292, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3173"},"text":"124 Stat. 3173","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/292/s4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research by OPM on Telework","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Office of Personnel Management shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research the utilization of telework by public and private sector entities that identify best practices and recommendations for the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the outcomes associated with an increase in telework, including the effects of telework on energy consumption, job creation and availability, urban transportation patterns, and the ability to anticipate the dispersal of work during periods of emergency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make any studies or reviews performed under this subsection available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Contract To Carry Out Research","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Personnel Management may carry out subsection (a) under a contract entered into by the Director using competitive procedures under section 303 of the Federal Property and Administrative Services Act of 1949 ([former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s253"},"text":"41 U.S.C. 253","children":[],"tail":") [see "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s3105"},"text":"41 U.S.C. 3105","children":[],"tail":", 3301, 3303 to 3305]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Other Federal Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The heads of Federal agencies with relevant jurisdiction over the subject matters in subsection (a)(2) shall work cooperatively with the Director of the Office of Personnel Management to carry out that subsection, if the Director determines that coordination is necessary to fulfill obligations under that subsection.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8a17a36-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of Telecommuting Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dB/tVI/s623"},"text":"Pub. L. 108–7, div. B, title VI, § 623","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/103"},"text":"117 Stat. 103","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/292/s2/b/2/A"},"text":"Pub. L. 111–292, § 2(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3170"},"text":"124 Stat. 3170","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/292/s2/b/2/A"},"text":"“Of the funds appropriated in this Act [div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":", see Tables for classification] for the Departments of Commerce, Justice, and State, the Judiciary, and the Small Business Administration, $100,000 shall be available to each Department or agency only to implement telecommuting programs: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That, 6 months after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":"] and every 6 months thereafter, each Department or agency shall provide a report to the Committees on Appropriations on the status of telecommuting programs, including the number of Federal employees eligible for, and participating in, such programs: "},{"tag":"i","attrib":{},"text":"Provided further","children":[],"tail":", That each Department or agency shall designate a Telework Managing Officer to be responsible for overseeing the implementation of telecommuting programs and serve as a point of contact on such programs for the Committees on Appropriations.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/108/tVI/s617"},"text":"Pub. L. 109–108, title VI, § 617","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-11-22"},"text":"Nov. 22, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2340"},"text":"119 Stat. 2340","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/292/s2/b/2/D"},"text":"Pub. L. 111–292, § 2(b)(2)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3171"},"text":"124 Stat. 3171","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dB/tVI/s622"},"text":"Pub. L. 108–447, div. B, title VI, § 622","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2919"},"text":"118 Stat. 2919","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/292/s2/b/2/C"},"text":"Pub. L. 111–292, § 2(b)(2)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3171"},"text":"124 Stat. 3171","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/dB/tVI/s627"},"text":"Pub. L. 108–199, div. B, title VI, § 627","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/99"},"text":"118 Stat. 99","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/292/s2/b/2/B"},"text":"Pub. L. 111–292, § 2(b)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3171"},"text":"124 Stat. 3171","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8a17a37-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Telecommuting in Executive Agencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/346/s101/a/tIII/s359"},"text":"Pub. L. 106–346, § 101(a) [title III, § 359]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-23"},"text":"Oct. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1356"},"text":"114 Stat. 1356","children":[],"tail":", 1356A–36, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/346/s101/a/tIII/s359"},"text":"“Each executive agency shall establish a policy under which eligible employees of the agency may participate in telecommuting to the maximum extent possible without diminished employee performance. Not later than 6 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-10-23"},"text":"Oct. 23, 2000","children":[],"tail":"], the Director of the Office of Personnel Management shall provide that the requirements of this section are applied to 25 percent of the Federal workforce, and to an additional 25 percent of such workforce each year thereafter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb8a17a38-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8a17a39-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Return to In-Person Work","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum of President of the United States, ","children":[{"tag":"date","attrib":{"date":"2025-01-20"},"text":"Jan. 20, 2025","children":[],"tail":", 90 F.R. 8251, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Memorandum for the Heads of Executive Departments and Agencies","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Heads of all departments and agencies in the executive branch of Government shall, as soon as practicable, take all necessary steps to terminate remote work arrangements and require employees to return to work in-person at their respective duty stations on a full-time basis, provided that the department and agency heads shall make exemptions they deem necessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This memorandum shall be implemented consistent with applicable law.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Donald J. Trump.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
