{"tag":"section","attrib":{"id":"idb890d82e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5949"},"text":null,"children":[{"tag":"num","attrib":{"value":"5949"},"text":"§ 5949.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hostile fire pay","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb890d82f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5949/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of an Executive agency may pay an employee hostile fire pay at the rate of $150 for any month in which the employee was—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb890d830-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5949/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to hostile fire or explosion of hostile mines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb890d831-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5949/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on duty in an area in which the employee was in imminent danger of being exposed to hostile fire or explosion of hostile mines and in which, during the period on duty in that area, other employees were subject to hostile fire or explosion of hostile mines; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb890d832-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5949/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" killed, injured, or wounded by hostile fire, explosion of a hostile mine, or any other hostile action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb890d833-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5949/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee covered by subsection (a)(3) who is hospitalized for the treatment of his or her injury or wound may be paid hostile fire pay under this section for not more than three additional months during which the employee is so hospitalized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb890d834-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5949/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee may be paid hostile fire pay under this section in addition to other pay and allowances to which entitled, except that an employee may not be paid hostile fire pay under this section for periods of time during which the employee receives payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5925"},"text":"section 5925 of this title","children":[],"tail":" because of exposure to political violence or payment under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5928"},"text":"section 5928 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb890d835-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXI/s1111/a"},"text":"Pub. L. 107–107, div. A, title XI, § 1111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1238"},"text":"115 Stat. 1238","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb890d836-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb890d837-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb890d838-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXI/s1111/c"},"text":"Pub. L. 107–107, div. A, title XI, § 1111(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1238"},"text":"115 Stat. 1238","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tX/s1084/h/3"},"text":"Pub. L. 108–375, div. A, title X, § 1084(h)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2064"},"text":"118 Stat. 2064","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/375/dA/tX/s1084/h/3"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5949"},"text":"Section 5949 of title 5","children":[],"tail":", United States Code, as added by subsection (a), is effective as if enacted into law on "},{"tag":"date","attrib":{"date":"2001-09-11"},"text":"September 11, 2001","children":[],"tail":", and may be applied with respect to any hostile action that took place on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
