{"tag":"section","attrib":{"id":"idb91b15ff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903b"},"text":null,"children":[{"tag":"num","attrib":{"value":"8903b"},"text":"§ 8903b.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to readmit an employee organization plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb91b1600-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903b/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the event that a plan described by section 8903(3) or 8903a is discontinued under this chapter (other than in the circumstance described in section 8909(d)), that discontinuation shall be disregarded, for purposes of any determination as to that plan’s eligibility to be considered an approved plan under this chapter, but only for purposes of any contract year later than the third contract year beginning after such plan is so discontinued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb91b1601-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903b/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A contract for a plan approved under this section shall require the carrier—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb91b1602-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903b/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to demonstrate experience in service delivery within a managed care system (including provider networks) throughout the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb91b1603-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8903b/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the carrier involved would not otherwise be subject to the requirement set forth in section 8903a(c)(1), to satisfy such requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb91b1604-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/266/s6/a/1"},"text":"Pub. L. 105–266, § 6(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2368"},"text":"112 Stat. 2368","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb91b1605-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91b1606-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb91b1607-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/266/s6/a/3"},"text":"Pub. L. 105–266, § 6(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2369"},"text":"112 Stat. 2369","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/266/s6/a/3"},"text":"\n","children":[{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by this subsection [enacting this section] shall apply as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":"], including with respect to any plan which has been discontinued as of such date."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transition rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of applying ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8903b/a"},"text":"section 8903b(a) of title 5","children":[],"tail":", United States Code (as amended by this subsection) with respect to any plan seeking to be readmitted for purposes of any contract year beginning before "},{"tag":"date","attrib":{"date":"2000-01-01"},"text":"January 1, 2000","children":[],"tail":", such section shall be applied by substituting ‘second contract year’ for ‘third contract year’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
