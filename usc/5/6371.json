{"tag":"section","attrib":{"id":"idb89f0968-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6371"},"text":null,"children":[{"tag":"num","attrib":{"value":"6371"},"text":"§ 6371.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accrual of leave","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"While using leave made available to an employee from a leave bank, annual and sick leave shall accrue to the credit of such employee and shall become available for use by such employee in the same manner as provided for under section 6337.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb89f0969-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/566/s2/a"},"text":"Pub. L. 100–566, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2843"},"text":"102 Stat. 2843","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
