{"tag":"section","attrib":{"id":"idb86f6db6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c"},"text":null,"children":[{"tag":"num","attrib":{"value":"5545c"},"text":"§ 5545c.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incident response premium pay for employees engaged in wildland firefighting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb86f6db7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86f6db8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86f6db9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86f6dba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Oversight and Accountability of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86f6dbb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86f6dbc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Natural Resources of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86f6dbd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86f6dbe-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86f6dbf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Natural Resources of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86f6dc0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Agriculture, Nutrition, and Forestry of the Senate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86f6dc1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “covered employee” means an employee of the Forest Service or the Department of the Interior who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86f6dc2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a wildland firefighter, as defined in section 5332a(a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86f6dc3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified by the applicable agency to perform wildland fire incident-related duties during the period that employee is deployed to respond to a qualifying incident;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86f6dc4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “incident response premium pay” means pay to which a covered employee is entitled under subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86f6dc5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “prescribed fire incident” means a wildland fire originating from a planned ignition in accordance with applicable laws, policies, and regulations to meet specific objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86f6dc6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “qualifying incident”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86f6dc7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb86f6dc8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a wildfire incident, a prescribed fire incident, or a severity incident; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb86f6dc9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an incident that the Secretary of Agriculture or the Secretary of the Interior determines is similar in nature to an incident described in clause (i); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86f6dca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include an initial response incident that is contained within 36 hours; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86f6dcb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “severity incident” means an incident in which a covered employee is pre-positioned in an area in which conditions indicate there is a high risk of wildfires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86f6dcc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered employee is eligible for incident response premium pay under this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86f6dcd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the covered employee is deployed to respond to a qualifying incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86f6dce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the deployment described in paragraph (1) is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86f6dcf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outside of the official duty station of the covered employee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86f6dd0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the official duty station of the covered employee and the covered employee is assigned to an incident-adjacent fire camp or other designated field location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86f6dd1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entitlement to Incident Response Premium Pay.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86f6dd2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A covered employee who satisfies the conditions under subsection (b) is entitled to premium pay for the period in which the covered employee is deployed to respond to the applicable qualifying incident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86f6dd3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Computation.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86f6dd4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Formula","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subparagraphs (B) and (C), premium pay under paragraph (1) shall be paid to a covered employee at a daily rate of 450 percent of the hourly rate of basic pay of the covered employee for each day that the covered employee satisfies the requirements under subsection (b), rounded to the nearest whole cent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86f6dd5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Premium pay under this subsection may not be paid—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb86f6dd6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a covered employee for whom the annual rate of basic pay is greater than that for step 10 of GS–10, at a daily rate that exceeds the daily rate established under subparagraph (A) for step 10 of GS–10; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb86f6dd7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a covered employee in a total amount that exceeds $9,000 in any calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86f6dd8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustments.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idb86f6dd9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Agriculture and the Secretary of the Interior shall assess the difference between the average total amount of compensation that was paid to covered employees, by grade, in fiscal years 2023 and 2024.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb86f6dda-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date that is 1 year after the effective date of this section, the Secretary of Agriculture and the Secretary of the Interior shall jointly publish a report on the results of the assessment conducted under clause (i).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb86f6ddb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After publishing the report required under clause (ii), the Secretary of Agriculture and the Secretary of the Interior, in consultation with the Director of the Office of Personnel Management, may, in the sole and exclusive discretion of the Secretaries acting jointly, administratively adjust the amount of premium pay paid under this subsection (or take other administrative action) to ensure that the average annual amount of total compensation paid to covered employees, by grade, is more consistent with such amount that was paid to those employees in fiscal year 2023.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb86f6ddc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 3 days after an adjustment made, or other administrative action taken, under clause (iii) becomes final, the Secretary of Agriculture and the Secretary of the Interior shall jointly submit to the appropriate committees of Congress a notification regarding that adjustment or other administrative action, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86f6ddd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Incident Response Premium Pay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Incident response premium pay under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86f6dde-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not considered part of the basic pay of a covered employee for any purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86f6ddf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be considered in determining a covered employee’s lump-sum payment for accumulated and accrued annual leave under section 5551 or section 5552;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86f6de0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be used in determining pay under section 8114 (relating to compensation for work injuries);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86f6de1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be considered in determining pay for hours of paid leave or other paid time off during which the premium pay is not payable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86f6de2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5545c/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be disregarded in determining the minimum wage and overtime pay to which a covered employee is entitled under the Fair Labor Standards Act of 1938 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"29 U.S.C. 201","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86f6de3-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/4/dA/tVIII/s1807"},"text":"Pub. L. 119–4, div. A, title VIII, § 1807","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-03-15"},"text":"Mar. 15, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/30"},"text":"139 Stat. 30","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb86f6de4-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb86f6de5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb86f6de6-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For the effective date of this section, referred to in subsec. (c)(2)(C)(ii), see Effective Date note below.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Fair Labor Standards Act of 1938, referred to in subsec. (d)(5), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch676"},"text":"act June 25, 1938, ch. 676","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1060"},"text":"52 Stat. 1060","children":[],"tail":", which is classified generally to chapter 8 (§ 201 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"section 201 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb86f6de7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 457(a) of H.R. 8998, from the 118th Congress (Department of the Interior, Environment, and Related Congress, Agencies Appropriations Act, 2025), as passed by the House of Representatives on ","children":[{"tag":"date","attrib":{"date":"2024-07-24"},"text":"July 24, 2024","children":[],"tail":", which was enacted into law by "},{"tag":"ref","attrib":{"href":"/us/pl/119/4/dA/s1807"},"text":"section 1807 of div. A of Pub. L. 119–4","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb86f6de8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb86f6de9-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Accountability of the House of Representatives changed to the Committee on Oversight and Government Reform of the House of Representatives by House Resolution No. 5, One Hundred Nineteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2025-01-03"},"text":"Jan. 3, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb86f6dea-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective the first day of the first applicable pay period beginning on or after ","children":[{"tag":"date","attrib":{"date":"2025-03-15"},"text":"Mar. 15, 2025","children":[],"tail":", see section 457(d) of H.R. 8998 from the 118th Congress, as passed by the House of Representatives on "},{"tag":"date","attrib":{"date":"2024-07-24"},"text":"July 24, 2024","children":[],"tail":", set out as an Effective Date of 2025 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5544"},"text":"section 5544 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
