{"tag":"section","attrib":{"id":"idb889ac61-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5757"},"text":null,"children":[{"tag":"num","attrib":{"value":"5757"},"text":"§ 5757.","children":[{"tag":"ref","attrib":{"idref":"fn002121"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002121"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" Another section 5757 is set out after this section."}],"tail":null}],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of expenses to obtain professional credentials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb889ac62-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5757/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agency may use appropriated funds or funds otherwise available to the agency to pay for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb889ac63-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5757/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expenses for employees to obtain professional credentials, including expenses for professional accreditation, State-imposed and professional licenses, and professional certification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb889ac64-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5757/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examinations to obtain such credentials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb889ac65-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5757/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority under subsection (a) may not be exercised on behalf of any employee occupying or seeking to qualify for appointment to any position that is excepted from the competitive service because of the confidential, policy-determining, policy-making, or policy-advocating character of the position.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb889ac66-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXI/s1112/a"},"text":"Pub. L. 107–107, div. A, title XI, § 1112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1238"},"text":"115 Stat. 1238","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
