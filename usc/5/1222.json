{"tag":"section","attrib":{"id":"idb7ec3322-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1222"},"text":null,"children":[{"tag":"num","attrib":{"value":"1222"},"text":"§ 1222.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of other remedies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as provided in section 1221(i), nothing in this chapter or chapter 23 shall be construed to limit any right or remedy available under a provision of statute which is outside of both this chapter and chapter 23.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb7ec3323-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/12/s3/a/13"},"text":"Pub. L. 101–12, § 3(a)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-04-10"},"text":"Apr. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/31"},"text":"103 Stat. 31","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
