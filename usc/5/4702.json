{"tag":"section","attrib":{"id":"idb82f096b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4702"},"text":null,"children":[{"tag":"num","attrib":{"value":"4702"},"text":"§ 4702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research programs","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Office of Personnel Management shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb82f096c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain (and assist in the establishment and maintenance of) research programs to study improved methods and technologies in Federal personnel management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f096d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the research programs established under paragraph (1) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f096e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain a program for the collection and public dissemination of information relating to personnel management research and for encouraging and facilitating the exchange of information among interested persons and entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb82f096f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the preceding functions directly or through agreement or contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb82f0970-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tVI/s601/a"},"text":"Pub. L. 95–454, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1185"},"text":"92 Stat. 1185","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb82f0971-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82f0972-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb82f0973-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 90 days after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1101"},"text":"section 1101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
