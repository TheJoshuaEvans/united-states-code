ail":null},{"tag":"p","attrib":{},"text":"2022—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/108"},"text":"Pub. L. 117–108","children":[],"tail":" substituted “at least 2 levels of benefits for enrollees under this chapter generally and at least 2 levels of benefits for enrollees under the Postal Service Health Benefits Program established under section 8903c” for “two levels of benefits”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/266"},"text":"Pub. L. 105–266","children":[],"tail":" substituted “plan, which may be underwritten by participating affiliates licensed in any number of States,” for “plan,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/654"},"text":"Pub. L. 100–654","children":[],"tail":" substituted “former spouses, or persons having continued coverage under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8905a"},"text":"section 8905a of this title","children":[],"tail":",” for “or former spouses,” and “former spouse, or person having continued coverage under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8905a"},"text":"section 8905a of this title","children":[],"tail":".” for “or former spouse.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Par. (4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/251/s102"},"text":"Pub. L. 99–251, § 102","children":[],"tail":", amended second sentence generally, substituting “at least 3 physicians” for “physicians representing at least three major medical specialties” and inserted “and who represent 1 or more medical specialties appropriate and necessary for the population proposed to be served by the plan”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/251/s111"},"text":"Pub. L. 99–251, § 111","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/53"},"text":"Pub. L. 99–53","children":[],"tail":" inserted “described in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8901/8/A"},"text":"section 8901(8)(A) of this title","children":[],"tail":"” after “employee organizations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615/s3/3"},"text":"Pub. L. 98–615, § 3(3)","children":[],"tail":", substituted “employees, annuitants, members of their families, or former spouses” for “employees or annuitants, or members of their families” and “employee, annuitant, family member, or former spouse” for “employee or annuitant or member of his family”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Office of Personnel Management” and “Office” for “Civil Service Commission” and “Commission”, respectively, wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb91b15ef-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb91b15f0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/654"},"text":"Pub. L. 100–654","children":[],"tail":" applicable with respect to any calendar year beginning, and contracts entered into or renewed for any calendar year beginning, after end of 9-month period beginning "},{"tag":"date","attrib":{"date":"1988-11-14"},"text":"Nov. 14, 1988","children":[],"tail":", and with respect to any qualifying event occurring on or after first day of first calendar year beginning after end of such 9-month period, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/654/s203"},"text":"section 203 of Pub. L. 100–654","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8902"},"text":"section 8902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb91b15f1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-05-07"},"text":"May 7, 1985","children":[],"tail":", with enumerated exceptions, and applicable to any individual who is married to an employee or annuitant on or after that date, see "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/s4/a/2"},"text":"section 4(a)(2) of Pub. L. 98–615","children":[],"tail":", as amended, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8341"},"text":"section 8341 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb91b15f2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 90 days after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s907"},"text":"section 907 of Pub. L. 95–454","children"