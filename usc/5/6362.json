{"tag":"section","attrib":{"id":"idb89f0918-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6362"},"text":null,"children":[{"tag":"num","attrib":{"value":"6362"},"text":"§ 6362.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any provision of subchapter I, and subject to the provisions of this subchapter, the Office of Personnel Management shall establish a program under which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89f0919-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6362/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annual leave accrued or accumulated by an employee may be contributed to a leave bank established by the employing agency of such employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f091a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6362/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leave from such a leave bank may be made available to an employee who requires such leave because of a medical emergency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89f091b-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/566/s2/a"},"text":"Pub. L. 100–566, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2839"},"text":"102 Stat. 2839","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/103/s5/b"},"text":"Pub. L. 103–103, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-08"},"text":"Oct. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1023"},"text":"107 Stat. 1023","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb89f091c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89f091d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb89f091e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/103"},"text":"Pub. L. 103–103","children":[],"tail":" struck out subsec. (a) designation and struck out subsec. (b) which read as follows: “To test voluntary leave bank programs under the provisions of this subchapter, the Office of Personnel Management shall establish a demonstration project in at least 3 Executive agencies, of which—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) one such agency shall include approximately, but not less than, the equivalent of 100,000 full-time positions;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) one such agency shall include approximately, but not less than, the equivalent of 25,000 full-time positions; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) one such agency shall include approximately, but not less than, the equivalent of 1,000 full-time positions.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb89f091f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb89f0920-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/103"},"text":"Pub. L. 103–103","children":[],"tail":" effective as of the 120th day after "},{"tag":"date","attrib":{"date":"1993-10-08"},"text":"Oct. 8, 1993","children":[],"tail":", or such earlier date as the Office of Personnel Management may by regulation prescribe, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/103/s6"},"text":"section 6 of Pub. L. 103–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6331"},"text":"section 6331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
