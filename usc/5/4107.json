{"tag":"section","attrib":{"id":"idb827dce0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107"},"text":null,"children":[{"tag":"num","attrib":{"value":"4107"},"text":"§ 4107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Academic degree training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb827dce1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subsection (b), an agency may select and assign an employee to academic degree training and may pay or reimburse the costs of academic degree training from appropriated or other available funds if such training—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb827dce2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" contributes significantly to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb827dce3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meeting an identified agency training need;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb827dce4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resolving an identified agency staffing problem; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb827dce5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accomplishing goals in the strategic plan of the agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb827dce6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is part of a planned, systemic, and coordinated agency employee development program linked to accomplishing the strategic goals of the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb827dce7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accredited and is provided by a college or university that is accredited by a nationally recognized body.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb827dce8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In exercising authority under subsection (a), an agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb827dce9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consistent with the merit system principles set forth in paragraphs (2) and (7) of section 2301(b), take into consideration the need to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb827dcea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a balanced workforce in which women, members of racial and ethnic minority groups, and persons with disabilities are appropriately represented in Government service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb827dceb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide employees effective education and training to improve organizational and individual performance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb827dcec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assure that the training is not for the sole purpose of providing an employee an opportunity to obtain an academic degree or qualify for appointment to a particular position for which the academic degree is a basic requirement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb827dced-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assure that no authority under this subsection is exercised on behalf of any employee occupying or seeking to qualify for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb827dcee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a noncareer appointment in the senior Executive Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb827dcef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appointment to any position that is excepted from the competitive service because of its confidential policy-determining, policy-making or policy-advocating character; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb827dcf0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s4107/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the greatest extent practicable, facilitate the use of online degree training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb827dcf1-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/435"},"text":"80 Stat. 435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXII/s1206/a"},"text":"Pub. L. 101–510, div. A, title XII, § 1206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1659"},"text":"104 Stat. 1659","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/226/s2/a/5"},"text":"Pub. L. 103–226, § 2(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-03-30"},"text":"Mar. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/112"},"text":"108 Stat. 112","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1121], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–315; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1331/a"},"text":"Pub. L. 107–296, title XIII, § 1331(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2298"},"text":"116 Stat. 2298","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb827dcf2-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb827dcf3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb827dcf4-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s2313"},"text":"5 U.S.C. 2313","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/507/s14"},"text":"Pub. L. 85–507, § 14","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/334"},"text":"72 Stat. 334","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s2318/d"},"text":"5 U.S.C. 2318(d)","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/507/s19/d"},"text":"Pub. L. 85–507, § 19(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/336"},"text":"72 Stat. 336","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s2312"},"text":"5 U.S.C. 2312","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 7, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/507/s13"},"text":"Pub. L. 85–507, § 13","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/334"},"text":"72 Stat. 334","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The prohibitions are restated in positive form.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “Executive order” are substituted for “Executive orders of the President”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “under authority of this chapter” and “by the Government” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb827dcf5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb827dcf6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" amended section catchline and text generally, substituting provisions authorizing selection and assignment of employees for academic degree training and payment or reimbursement of costs, for provisions relating to restrictions on degree training or the payment or reimbursement of the costs of training and provisions setting forth exceptions and special rules with respect to employees of the Department of Defense."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1121(1)], substituted “subsections (b) and (c)” for “subsection (b)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1121(2)], substituted “subsection (a) or (c)” for “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title XI, § 1121(3)], added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226/s2/a/5/A"},"text":"Pub. L. 103–226, § 2(a)(5)(A)","children":[],"tail":", substituted “Restriction on degree training” for “Non-Government facilities; restrictions” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226/s2/a/5/B"},"text":"Pub. L. 103–226, § 2(a)(5)(B)","children":[],"tail":", (C), redesignated subsec. (c) as (a), in introductory provisions substituted “subsection (b)” for “subsection (d)” and struck out “by, in, or through a non-Government facility” after “employee for training”, and struck out former subsec. (a) which read as follows: “Appropriations or other funds available to an agency are not available for payment for training an employee—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) by, in or through a non-Government facility which teaches or advocates the overthrow of the Government of the United States by force or violence; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) by or through an individual concerning whom determination has been made by a proper Government administrative or investigatory authority that, on the basis of information or evidence developed in investigations and procedures authorized by law or Executive order, there exists a reasonable doubt of his loyalty to the United States.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226/s2/a/5/B"},"text":"Pub. L. 103–226, § 2(a)(5)(B)","children":[],"tail":", (D), redesignated subsec. (d) as (b), substituted “subsection (a)” for “subsection (c)” in par. (1), and struck out former subsec. (b) which read as follows: “This chapter does not authorize training an employee by, in, or through a non-Government facility a substantial part of the activities of which is—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) carrying on propaganda, or otherwise attempting, to influence legislation; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) participating or intervening, including publishing or distributing statements, in a political campaign on behalf of a candidate for public office.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226/s2/a/5/B"},"text":"Pub. L. 103–226, § 2(a)(5)(B)","children":[],"tail":", redesignated subsecs. (c) and (d) as (a) and (b), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1206/a/1"},"text":"Pub. L. 101–510, § 1206(a)(1)","children":[],"tail":", substituted “Except as provided in subsection (d) of this section, this” for “This” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1206/a/2"},"text":"Pub. L. 101–510, § 1206(a)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb82a4cf7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb82a4cf8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
