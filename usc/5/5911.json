[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s3126"},"text":"5 U.S.C. 3126","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 20, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/459/s6"},"text":"Pub. L. 88–459, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/558"},"text":"78 Stat. 558","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s3127"},"text":"5 U.S.C. 3127","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 20, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/459/s7"},"text":"Pub. L. 88–459, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/558"},"text":"78 Stat. 558","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the term “Executive agency” is coextensive with and substituted for “each executive department of the Government”, “each agency or independent establishment in the executive branch of the Government”, “each corporation owned or controlled by the Government”, and “the General Accounting Office” in view of the definition of “Executive agency” in section 105.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the term “employee” is substituted for “civilian officer or employee” in view of the definition of “employee” in section 2105.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(7) of former section 3121 is omitted as unnecessary in view of the definition of “uniformed services” in section 2101.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb88bf5d5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb88bf5d6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" added subsec. (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb88bf5d7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb88bf5d8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/145"},"text":"Pub. L. 99–145","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/145/s813"},"text":"section 813 of Pub. L. 99–145","children":[],"tail":", formerly set out in a Military Family Policy and Programs note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s113"},"text":"section 113 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb88bf5d9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Government Lodging Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tIX/s914"},"text":"Pub. L. 113–291, div. A, title IX, § 914","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3474"},"text":"128 Stat. 3474","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tX/s1051/t/2"},"text":"Pub. L. 115–91, div. A, title X, § 1051(t)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1566"},"text":"131 Stat. 1566","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tVI/s642"},"text":"Pub. L. 116–92, div. A, title VI, § 642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1431"},"text":"133 Stat. 1431","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tVI/s642"},"text":"Pub. L. 116–283, div. A, title VI, § 642","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3684"},"text":"134 Stat. 3684","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dA/tVI/s652"},"text":"Pub. L. 118–159, div. A, title VI, § 652","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1939"},"text":"138 Stat. 1939","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dA/tVI/s652"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5911"},"text":"section 5911 of title 5","children":[],"tail":", United States Code, the Secretary of Defense may establish and carry out a Government lodging program to provide Government or commercial lodging for employees of the Department of Defense or members of the uniformed services under the Secretary’s jurisdiction performing duty on official travel, and may require such travelers to occupy adequate quarters on a rental basis when available."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary Exclusion of Certain Shipyard Employees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out a Government lodging program under subsection (a), the Secretary shall exclude from the requirements of the program employees who are traveling for the performance of mission functions of a public shipyard of the Department if the Secretary determines such requirements would adversely affect the purpose or mission of such travel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection shall terminate on ","children":[{"tag":"date","attrib":{"date":"2029-09-30"},"text":"September 30, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefings required.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2025-02-01"},"text":"February 1, 2025","children":[],"tail":", and annually thereafter through "},{"tag":"date","attrib":{"date":"2030-02-01"},"text":"February 1, 2030","children":[],"tail":", the Secretary shall brief the congressional defense committees [Committees on Armed Services and Appropriations of the Senate and the House of Representatives] on the exclusion under paragraph (1) from the requirements of a Government lodging program carried out under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each briefing required by subparagraph (A) shall include, for the year preceding the briefing, the following:","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the instances in which the exclusion under paragraph (1) was used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the lodging used under that exclusion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A statement of the difference in cost between lodging used under that exclusion and lodging provided under a Government lodging program carried out under subsection (a) in each location where lodging under the exclusion was used.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other matters as the Secretary considers relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Government lodging program developed under the authority in subsection (a), and a requirement under subsection (a) with respect to an employee of the Department of Defense, may not be construed to be subject to a duty to negotiate under chapter 71 of title 5, United States Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb88bf5da-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deposit in Special Fund of Rents and Charges Collected for Use or Occupancy of Quarters","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473/tI/s101/c/tIII/s320"},"text":"Pub. L. 98–473, title I, § 101(c) [title III, § 320]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1837"},"text":"98 Stat. 1837","children":[],"tail":", 1874, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/100/446/tIII/s316"},"text":"Pub. L. 100–446, title III, § 316","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-27"},"text":"Sept. 27, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1826"},"text":"102 Stat. 1826","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/121/tIII/s317"},"text":"Pub. L. 101–121, title III, § 317","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-10-23"},"text":"Oct. 23, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/745"},"text":"103 Stat. 745","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/121/tIII/s317"},"text":"“Notwithstanding title 5 of the United States Code or any other provision of law, after ","children":[{"tag":"date","attrib":{"date":"1984-09-30"},"text":"September 30, 1984","children":[],"tail":", rents and charges collected by payroll deduction or otherwise for the use or occupancy of quarters of agencies funded by this Act [probably means Department of the Interior and Related Agencies Appropriation Act, 1985, as set forth in "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/s101/c"},"text":"section 101(c) of Pub. L. 98–473","children":[],"tail":"] shall thereafter be deposited in a special fund in each agency, to remain available until expended, for the maintenance and operation of the quarters of that agency: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That nothing contained herein shall prohibit an agreement between an Indian tribe or tribal organization and the Secretary of the Interior or the Secretary of Health and Human Services, pursuant to the Indian Self-Determination Act, as amended ("},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450"},"text":"25 U.S.C. 450","children":[],"tail":" et seq.) [former "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450f"},"text":"25 U.S.C. 450f","children":[],"tail":" et seq., now "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5321"},"text":"25 U.S.C. 5321","children":[],"tail":" et seq.], under which such tribe or tribal organization may retain rents and charges for the operation, maintenance, and repair of such quarters.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb88bf5db-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idb88bf5dc-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Authority of President under subsec. (f) of this section to issue regulations provided for therein (relating to provision, occupancy, and availability of quarters and facilities, determination of rates and charges therefor, and other related matters, as are necessary and appropriate to carry out provisions of this section) delegated to Director of Office of Management and Budget, see section 9(1) of Ex. Ord. No. 11609, ","children":[{"tag":"date","attrib":{"date":"1971-07-22"},"text":"July 22, 1971","children":[],"tail":", 36 F.R. 13747, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of Title 3","children":[],"tail":", The President."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
