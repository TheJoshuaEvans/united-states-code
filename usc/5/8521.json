{"tag":"section","attrib":{"id":"idb90f2f18-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8521"},"text":null,"children":[{"tag":"num","attrib":{"value":"8521"},"text":"§ 8521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions; application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb90f2f19-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8521/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90f2f1a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8521/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Federal service” means active service (not including active duty in a reserve status unless for a continuous period of 180 days or more) in the armed forces or the Commissioned Corps of the National Oceanic and Atmospheric Administration if with respect to that service—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb90f2f1b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8521/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual was discharged or released under honorable conditions (and, if an officer, did not resign for the good of the service); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb90f2f1c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8521/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb90f2f1d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8521/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual was discharged or released after completing his first full term of active service which the individual initially agreed to serve, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb90f2f1e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8521/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the individual was discharged or released before completing such term of active service—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb90f2f1f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8521/a/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the convenience of the Government under an early release program,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb90f2f20-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8521/a/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of medical disqualification, pregnancy, parenthood, or any service-incurred injury or disability,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb90f2f21-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8521/a/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of hardship (including pursuant to a sole survivorship discharge, as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174/i"},"text":"section 1174(i) of title 10","children":[],"tail":"), or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb90f2f22-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8521/a/1/B/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of personality disorders or inaptitude but only if the service was continuous for 365 days or more;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90f2f23-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8521/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal wages” means all pay and allowances, in cash and in kind, for Federal service, computed on the basis of the pay and allowances for the pay grade of the individual at the time of his latest discharge or release from Federal service as specified in the schedule applicable at the time he files his first claim for compensation for the benefit year. The Secretary of Labor shall issue, from time to time, after consultation with the Secretary of Defense, schedules specifying the pay and allowances for each pay grade of servicemen covered by this subchapter, which reflect representative amounts for appropriate elements of the pay and allowances whether in cash or in kind; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90f2f24-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8521/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means the several States, the District of Columbia, the Commonwealth of Puerto Rico, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90f2f25-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8521/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of subchapter I of this chapter, subject to the modifications made by this subchapter, apply to individuals who have had Federal service as defined by subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb90f2f26-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/590"},"text":"80 Stat. 590","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/89"},"text":"Pub. L. 90–83, § 1(89)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/218"},"text":"81 Stat. 218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/566/tI/s116/e/4"},"text":"Pub. L. 94–566, title I, § 116(e)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-20"},"text":"Oct. 20, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2673"},"text":"90 Stat. 2673","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/215/s4/b"},"text":"Pub. L. 96–215, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-03-25"},"text":"Mar. 25, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/124"},"text":"94 Stat. 124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/364/tIV/s415/a"},"text":"Pub. L. 96–364, title IV, § 415(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-26"},"text":"Sept. 26, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1310"},"text":"94 Stat. 1310","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXXIV/s2405/a"},"text":"P