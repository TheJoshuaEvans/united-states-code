null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s1371"},"text":"42 U.S.C. 1371","children":[],"tail":" (a)–(c)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 28, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/848/s3"},"text":"Pub. L. 85–848, § 3","children":[],"tail":" “Sec. 1511(a)–(c)”, "},{"tag":"html:a","attrib":{"href":"/us/stat/72/1088"},"text":"72 Stat. 1088","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “armed forces” are coextensive with and substituted for “Army, Navy, Air Force, Marine Corps, or Coast Guard of the United States” in view of the definition of “armed forces” in section 2101. The words “after ","children":[{"tag":"date","attrib":{"date":"1958-10-27"},"text":"October 27, 1958","children":[],"tail":"” are substituted for “after the sixtieth day after "},{"tag":"date","attrib":{"date":"1958-08-28"},"text":"August 28, 1958","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “with respect to weeks of unemployment ending after the sixtieth day after ","children":[{"tag":"date","attrib":{"date":"1958-08-28"},"text":"August 28, 1958","children":[],"tail":"” are omitted as obsolete because the law is here stated with prospective effect."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb90f2f2a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1967 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This incorporates into ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8521"},"text":"5 U.S.C. 8521","children":[],"tail":" the definition of “State” which is applicable to the source statute of that section by virtue of "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1301/a/1"},"text":"section 1301(a)(1) of title 42","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb90f2f2b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb90f2f2c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/107/s8"},"text":"Section 8 of Pub. L. 102–107","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-08-17"},"text":"Aug. 17, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/546"},"text":"105 Stat. 546","children":[],"tail":", which contained provisions substantially identical to those of "},{"tag":"ref","attrib":{"href":"/us/pl/102/164/s301"},"text":"section 301 of Pub. L. 102–164","children":[],"tail":", amending this section and enacting provisions set out below, did not become effective pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/102/107/s10/b"},"text":"section 10(b) of Pub. L. 102–107","children":[],"tail":", because the President did not take the action required by that section by "},{"tag":"date","attrib":{"date":"1991-08-17"},"text":"Aug. 17, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb90f2f2d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92"},"text":"Pub. L. 114–92","children":[],"tail":" substituted “180 days” for “90 days” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1)(B)(ii)(III). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/317"},"text":"Pub. L. 110–317","children":[],"tail":" substituted “hardship (including pursuant to a sole survivorship discharge, as that term is defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s1174/i"},"text":"section 1174(i) of title 10","children":[],"tail":"),” for “hardship,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/164/s301/b"},"text":"Pub. L. 102–164, § 301(b)","children":[],"tail":", substituted “90 days” for “180 days” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/164/s301/a"},"text":"Pub. L. 102–164, § 301(a)","children":[],"tail":", struck out subsec. (c) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) An individual shall not be entitled to compensation under this subchapter for any week before the fifth week beginning after the week in which the individual was discharged or released.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The aggregate amount of compensation payable on the basis of Federal service (as defined in subsection (a)) to any individual with respect to any benefit year shall not exceed 13 times the individual’s weekly benefit amount for total unemployment.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/362/s201/a"},"text":"Pub. L. 97–362, § 201(a)","children":[],"tail":", substituted provision that “Federal service” means active service (not including active duty in a reserve status unless for a continuous period of 180 days or more) in the armed forces or the Commissioned Corps of the National Oceanic and Atmospheric Administration if with respect to that service the individual was discharged or released under honorable conditions (and, if an officer, did not resign for the good of the service), and the individual was discharged or released after completing his first full term of active service which the individual initially agreed to serve, or the individual was discharged or released before completing such term of active service for the convenience of the Government under an early release program, because of medical disqualification, pregnancy, parenthood, or any service-incurred injury or disability, because of hardship, or because of personality disorders or inaptitude but only if the service was continuous for 365 days or more, for provision that “Federal service” meant active service, including active duty for training purposes, in the armed forces or the Commissioned Corps of the National Oceanic and Atmospheric Administration which either began after "},{"tag":"date","attrib":{"date":"1955-01-31"},"text":"January 31, 1955","children":[],"tail":", or terminated after "},{"tag":"date","attrib":{"date":"1958-10-27"},"text":"October 27, 1958","children":[],"tail":", if that service was continuous for 365 days or more, or was terminated earlier because of an actual service-incurred injury or disability, and with respect to that service, the individual was discharged or released under honorable conditions, did not resign or voluntarily leave the service, and was not released or discharged for cause as defined by the Department of Defense."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/362/s201/b"},"text":"Pub. L. 97–362, § 201(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1981—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":" substituted “honorable conditions;” for “conditions other than dishonorable; and” in cl. (i), and “did not resign or voluntarily leave the service; and” for “was not given a bad conduct discharge, or, if an officer, did not resign for the good of the service;” in cl. (ii), and added cl. (iii)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/215"},"text":"Pub. L. 96–215","children":[],"tail":" inserted “or the Commissioned Corps of the National Oceanic and Atmospheric Administration” after “armed forces” in provisions preceding subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/364"},"text":"Pub. L. 96–364","children":[],"tail":" substituted “365” for “90”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/566"},"text":"Pub. L. 94–566","children":[],"tail":" added the Virgin Islands to definition of “State”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb90f2f2e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90f2f2f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tV/s513/b"},"text":"Pub. L. 114–92, div. A, title V, § 513(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/809"},"text":"129 Stat. 809","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/92/dA/tV/s513/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":"], and shall apply with respect to periods of Federal service commencing on or after that date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90f2f30-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/317"},"text":"Pub. L. 110–317","children":[],"tail":" applicable with respect to any sole survivorship discharge granted after "},{"tag":"date","attrib":{"date":"2008-08-29"},"text":"Aug. 29, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/317/s10"},"text":"section 10 of Pub. L. 110–317","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2108"},"text":"section 2108 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90f2f31-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/164/tIII/s301/c"},"text":"Pub. L. 102–164, title III, § 301(c)","children":[],"tail":", "},{"ta