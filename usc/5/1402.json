{"tag":"section","attrib":{"id":"idb7eea49c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1402"},"text":null,"children":[{"tag":"num","attrib":{"value":"1402"},"text":"§ 1402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority and functions of agency Chief Human Capital Officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7eea49d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1402/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The functions of each Chief Human Capital Officer shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7eea49e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1402/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setting the workforce development strategy of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eea49f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1402/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing workforce characteristics and future needs based on the agency’s mission and strategic plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eea4a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1402/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aligning the agency’s human resources policies and programs with organization mission, strategic goals, and performance outcomes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eea4a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1402/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and advocating a culture of continuous learning to attract and retain employees with superior abilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eea4a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1402/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying best practices and benchmarking studies,","children":[{"tag":"ref","attrib":{"idref":"fn002036"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002036"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should be a semicolon."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eea4a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1402/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applying methods for measuring intellectual capital and identifying links of that capital to organizational performance and growth.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7eea4a4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1402/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to the authority otherwise provided by this section, each agency Chief Human Capital Officer—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7eea4a5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1402/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall have access to all records, reports, audits, reviews, documents, papers, recommendations, or other material that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7eea4a6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1402/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are the property of the agency or are available to the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7eea4a7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1402/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relate to programs and operations with respect to which that agency Chief Human Capital Officer has responsibilities under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7eea4a8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1402/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may request such information or assistance as may be necessary for carrying out the duties and responsibilities provided by this chapter from any Federal, State, or local governmental entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7eea4a9-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1302/a"},"text":"Pub. L. 107–296, title XIII, § 1302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2288"},"text":"116 Stat. 2288","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
