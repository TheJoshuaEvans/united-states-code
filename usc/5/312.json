{"tag":"section","attrib":{"id":"idb78a8b1a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s312"},"text":null,"children":[{"tag":"num","attrib":{"value":"312"},"text":"§ 312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agency evidence-building plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb78a8b1b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each agency shall include in the strategic plan required under section 306 a systematic plan for identifying and addressing policy questions relevant to the programs, policies, and regulations of the agency. Such plan shall contain the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb78a8b1c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of policy-relevant questions for which the agency intends to develop evidence to support policymaking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b1d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of data the agency intends to collect, use, or acquire to facilitate the use of evidence in policymaking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b1e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s312/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of methods and analytical approaches that may be used to develop evidence to support policymaking.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b1f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s312/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of any challenges to developing evidence to support policymaking, including any statutory or other restrictions to accessing relevant data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b20-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s312/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the steps the agency will take to accomplish paragraphs (1) and (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b21-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s312/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information as required by guidance issued by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78a8b22-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluation Plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each agency shall issue in conjunction with the performance plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1115/b"},"text":"section 1115(b) of title 31","children":[],"tail":", an evaluation plan describing activities the agency plans to conduct pursuant to subsection (a) of this section during the fiscal year following the year in which the performance plan is submitted. Such plan shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb78a8b23-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe key questions for each significant evaluation study that the agency plans to begin in the next fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b24-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe key information collections or acquisitions the agency plans to begin in the next fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb78a8b25-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s312/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any ","children":[{"tag":"ref","attrib":{"idref":"fn002005"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" other information included in guidance issued by the Director under subsection (a)(6)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb78a8b26-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing the plan required under subsection (a), the head of an agency shall consult with stakeholders, including the public, agencies, State and local governments, and representatives of non-governmental researchers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb78a8b27-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/tI/s101/a/2"},"text":"Pub. L. 115–435, title I, § 101(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5530"},"text":"132 Stat. 5530","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb78a8b28-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb78a8b29-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb78a8b2a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/435/s403"},"text":"section 403 of Pub. L. 115–435","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
