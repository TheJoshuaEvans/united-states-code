{"tag":"section","attrib":{"id":"idb7f1153e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2102"},"text":null,"children":[{"tag":"num","attrib":{"value":"2102"},"text":"§ 2102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" The competitive service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7f1153f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The “competitive service” consists of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7f11540-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" all civil service positions in the executive branch, except—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7f11541-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2102/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" positions which are specifically excepted from the competitive service by or under statute;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7f11542-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2102/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" positions to which appointments are made by nomination for confirmation by the Senate, unless the Senate otherwise directs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7f11543-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2102/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" positions in the Senior Executive Service;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f11544-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" civil service positions not in the executive branch which are specifically included in the competitive service by statute; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7f11545-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" positions in the government of the District of Columbia which are specifically included in the competitive service by statute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f11546-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsection (a)(1)(B) of this section, the “competitive service” includes positions to which appointments are made by nomination for confirmation by the Senate when specifically included therein by statute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7f11547-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s2102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As used in other Acts of Congress, “classified civil service” or “classified service” means the “competitive service”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7f11548-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/408"},"text":"80 Stat. 408","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIV/s401/b"},"text":"Pub. L. 95–454, title IV, § 401(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1154"},"text":"92 Stat. 1154","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7f11549-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb7f1154a-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb7f1154b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s638"},"text":"5 U.S.C. 638","children":[],"tail":" (less applicability to appointment and promotion)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1883-01-16/ch27/s7"},"text":"Jan. 16, 1883, ch. 27, § 7","children":[],"tail":" (less applicability to appointment and promotion), "},{"tag":"html:a","attrib":{"href":"/us/stat/22/406"},"text":"22 Stat. 406","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is restated in the form of a definition.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(1) is based on former section 638, which placed positions in the executive branch of the Government generally in the competitive service by the requirement that employment be predicated on passing an examination or being exempted from examination, and ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-11-26/ch919/s1"},"text":"section 1 of the Act of Nov. 26, 1940, ch. 919","children":[],"tail":", title I, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1211"},"text":"54 Stat. 1211","children":[],"tail":" (see table III), which authorized the President, subject to certain exceptions, to place in the classified civil service positions in the Executive departments, independent establishments, and other agencies of the Government. In that Act the word “executive” has been construed to modify “departments”, “independent establishments”; and “other agency”. This construction is supported by the language of the Act of "},{"tag":"date","attrib":{"date":"1883-01-16"},"text":"Jan. 16, 1883","children":[],"tail":", and is embodied in Civil Service Rule I. Acting under this statute, the President has placed all but a comparatively few of the positions covered by the Act of "},{"tag":"date","attrib":{"date":"1940-11-26"},"text":"Nov. 26, 1940","children":[],"tail":", in the competitive service. The remainder are covered by the exceptions contained in the Civil Service Rules and Regulations. The authority of the President conferred by the Act of "},{"tag":"date","attrib":{"date":"1940-11-26"},"text":"Nov. 26, 1940","children":[],"tail":", has been superseded in part by exceptions created by statutes enacted after that date. The effect of these exceptions and the power conferred on the President by former section 633(2)8 (last sentence) to make exceptions to the Civil Service Rules are preserved by the words “positions which are specifically excepted from the competitive service by or under statute”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(B), the words “or to pass an examination” are omitted as covered by the exclusion from the “competitive service”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(2) preserves the exception stated in former section 638 modified to recognize the several statutory exceptions to this exception that have been enacted. The language of former section 638 relative to examination is codified in sections 3304(b) and 3361. The reference to veterans’ preference is omitted because the statute referred to, R.S. § 1754, was superseded by sections 3 and 21 of the ","children":[{"tag":"ref","attrib":{"href":"/us/act/1929-06-18/ch28"},"text":"Act of June 18, 1929, ch. 28","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/46/21"},"text":"46 Stat. 21","children":[],"tail":". "},{"tag":"ref","attrib":{"href":"/us/act/1929-06-18/s3"},"text":"Section 3 of the Act of June 18, 1929","children":[],"tail":", was superseded by the "},{"tag":"ref","attrib":{"href":"/us/act/1944-06-27/ch287"},"text":"Act of June 27, 1944, ch. 287","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/387"},"text":"58 Stat. 387","children":[],"tail":", as amended, which is carried into this title. Rights preserved by "},{"tag":"ref","attrib":{"href":"/us/act/1944-06-27/s18"},"text":"section 18 of the Act of June 27, 1944","children":[],"tail":", are further preserved by technical section 8. The exception for laborers and workmen was superseded by the Act of "},{"tag":"date","attrib":{"date":"1940-11-26"},"text":"Nov. 26, 1940","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is added because of the provisions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s3311"},"text":"section 3311 of title 39","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is supplied for conformity inasmuch as the terms are coextensive by definition.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7f1154c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7f1154d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" added cl. (C)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7f1154e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7f1154f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" effective 9 months after "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", and congressional review of provisions of sections 401 through 412 of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/s415"},"text":"section 415 of Pub. L. 95–454","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3131"},"text":"section 3131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
