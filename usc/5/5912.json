{"tag":"section","attrib":{"id":"idb88bf5dd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5912"},"text":null,"children":[{"tag":"num","attrib":{"value":"5912"},"text":"§ 5912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Quarters in Government owned or rented buildings; employees in foreign countries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the head of the agency concerned and approved by the President, an employee who is a citizen of the United States permanently stationed in a foreign country may be furnished, without cost to him, living quarters, including heat, fuel, and light, in a Government owned or rented building. The rented quarters may be furnished only within the limits of appropriations made therefor.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb88bf5de-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/509"},"text":"80 Stat. 509","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb88bf5df-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb88bf5e0-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb88bf5e1-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"t