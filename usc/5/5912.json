46 Stat. 818","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 6, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/707/s511/c/6"},"text":"Pub. L. 86–707, § 511(c)(6)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/801"},"text":"74 Stat. 801","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “which appropriations are hereby authorized” are omitted as unnecessary in view of section 5509.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
