{"tag":"section","attrib":{"id":"idb8a17a5e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6503"},"text":null,"children":[{"tag":"num","attrib":{"value":"6503"},"text":"§ 6503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training and monitoring","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8a17a5f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each executive agency shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8a17a60-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an interactive telework training program is provided to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17a61-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6503/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees eligible to participate in the telework program of the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a62-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6503/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all managers of teleworkers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a63-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided under subsection (b), an employee has successfully completed the interactive telework training program before that employee enters into a written agreement to telework described under section 6502(b)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a64-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6503/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" teleworkers and nonteleworkers are treated the same for purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8a17a65-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6503/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodic appraisals of job performance of employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a66-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6503/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training, rewarding, reassigning, promoting, reducing in grade, retaining, and removing employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a67-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6503/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work requirements; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8a17a68-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6503/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other acts involving managerial discretion; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8a17a69-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6503/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when determining what constitutes diminished employee performance, the agency shall consult the performance management guidelines of the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8a17a6a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training Requirement Exemptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an executive agency may provide for an exemption from the training requirements under subsection (a), if the head of that agency determines that the training would be unnecessary because the employee is already teleworking under a work arrangement in effect before the date of enactment of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8a17a6b-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/292/s2/a"},"text":"Pub. L. 111–292, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3166"},"text":"124 Stat. 3166","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8a17a6c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8a17a6d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb8a17a6e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this chapter, referred to in subsec. (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/292"},"text":"Pub. L. 111–292","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2010-12-09"},"text":"Dec. 9, 2010","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
