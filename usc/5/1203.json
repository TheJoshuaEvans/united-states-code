{"tag":"section","attrib":{"id":"idb7e77858-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1203"},"text":null,"children":[{"tag":"num","attrib":{"value":"1203"},"text":"§ 1203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairman; Vice Chairman","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7e77859-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall from time to time appoint, by and with the advice and consent of the Senate, one of the members of the Merit Systems Protection Board as the Chairman of the Board. The Chairman is the chief executive and administrative officer of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7e7785a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall from time to time designate one of the members of the Board as Vice Chairman of the Board. During the absence or disability of the Chairman, or when the office of Chairman is vacant, the Vice Chairman shall perform the functions vested in the Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7e7785b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s1203/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the absence or disability of both the Chairman and the Vice Chairman, or when the offices of Chairman and Vice Chairman are vacant, the remaining Board member shall perform the functions vested in the Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7e7785c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tII/s202/a"},"text":"Pub. L. 95–454, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1122"},"text":"92 Stat. 1122","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/12/s3/a/4"},"text":"Pub. L. 101–12, § 3(a)(4)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"1989-04-10"},"text":"Apr. 10, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/17"},"text":"103 Stat. 17","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7e7785d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7e7785e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7e7785f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/12/s3/a/4"},"text":"Pub. L. 101–12, § 3(a)(4)","children":[],"tail":", struck out the comma after “time” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/12/s3/a/5"},"text":"Pub. L. 101–12, § 3(a)(5)","children":[],"tail":", substituted “the Chairman and the Vice Chairman” for “the Chairman and Vice Chairman” after “both”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7e77860-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7e77861-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1989 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/12"},"text":"Pub. L. 101–12","children":[],"tail":" effective 90 days following "},{"tag":"date","attrib":{"date":"1989-04-10"},"text":"Apr. 10, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/12/s11"},"text":"section 11 of Pub. L. 101–12","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1201"},"text":"section 1201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
