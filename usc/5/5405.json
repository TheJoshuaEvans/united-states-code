{"tag":"section","attrib":{"id":"idb8611536-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5405"},"text":null,"children":[{"tag":"num","attrib":{"value":"5405"},"text":"§ 5405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Office shall issue such regulations as it determines to be necessary for the administration of this chapter, including the administration of the Fund. The Office’s regulations shall include criteria governing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8611537-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5405/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency plan under section 5406;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8611538-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5405/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the allocation of monies from the Fund to agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8611539-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5405/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature, extent, duration, and adjustment of, and approval processes for, payments to individual employees under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb861153a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5405/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship to this chapter of agency performance management systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb861153b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5405/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training of supervisors, managers, and other individuals involved in the process of making performance distinctions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb861153c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5405/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the circumstances under which funds may be allocated by the Office to an agency in amounts below or in excess of the agency’s pro rata share.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb861153d-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXI/s1129/a"},"text":"Pub. L. 108–136, div. A, title XI, § 1129(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1643"},"text":"117 Stat. 1643","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb861153e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb861153f-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb8611540-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5405, added