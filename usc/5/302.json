{"tag":"section","attrib":{"id":"idb785a8af-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s302"},"text":null,"children":[{"tag":"num","attrib":{"value":"302"},"text":"§ 302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb785a8b0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, “agency” has the meaning given it by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5721"},"text":"section 5721 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb785a8b1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to the authority to delegate conferred by other law, the head of an agency may delegate to subordinate officials the authority vested in him—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb785a8b2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by law to take final action on matters pertaining to the employment, direction, and general administration of personnel under his agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb785a8b3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3702"},"text":"section 3702 of title 44","children":[],"tail":" to authorize the publication of advertisements, notices, or proposals."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb785a8b4-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/379"},"text":"80 Stat. 379","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/183/s2/1"},"text":"Pub. L. 94–183, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-12-31"},"text":"Dec. 31, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/1057"},"text":"89 Stat. 1057","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb785a8b5-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb785a8b6-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb785a8b7-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s22a"},"text":"5 U.S.C. 22a","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-08-02/ch744/s12"},"text":"Aug. 2, 1946, ch. 744, § 12","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/809"},"text":"60 Stat. 809","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (2) of former section 22a is omitted because of the repeal of R.S. § 3683 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s675"},"text":"31 U.S.C. 675","children":[],"tail":") by the "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-12/ch946/s301/76"},"text":"Act of Sept. 12, 1950, ch. 946, § 301(76)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/843"},"text":"64 Stat. 843","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “agency” is substituted for “department” and defined to conform to the definition of “department” in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-08-02/ch744/s18"},"text":"section 18 of the Act of Aug. 2, 1946, ch. 744","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/811"},"text":"60 Stat. 811","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “In addition to the authority to delegate conferred by other law,” are added for clarity and in recognition of the various reorganization plans which generally have transferred all functions of the departments and agencies to the heads thereof and have authorized them to delegate the functions to subordinates.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb785a8b8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb785a8b9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1975—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/183"},"text":"Pub. L. 94–183","children":[],"tail":" substituted “3702” for “324”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
