{"tag":"section","attrib":{"id":"idb8be2947-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102"},"text":null,"children":[{"tag":"num","attrib":{"value":"8102"},"text":"§ 8102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation for disability or death of employee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8be2948-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States shall pay compensation as specified by this subchapter for the disability or death of an employee resulting from personal injury sustained while in the performance of his duty, unless the injury or death is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8be2949-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" caused by willful misconduct of the employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be294a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" caused by the employee’s intention to bring about the injury or death of himself or of another; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be294b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proximately caused by the intoxication of the injured employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8be294c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Disability or death from a war-risk hazard or during or as a result of capture, detention, or other restraint by a hostile force or individual, suffered by an employee who is employed outside the continental United States or in Alaska or in the areas and installations in the Republic of Panama made available to the United States pursuant to the Panama Canal Treaty of 1977 and related agreements (as described in section 3(a) of the Panama Canal Act of 1979), is deemed to have resulted from personal injury sustained while in the performance of his duty, whether or not the employee was engaged in the course of employment when the disability or disability resulting in death occurred or when he was taken by the hostile force or individual. This subsection does not apply to an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8be294d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose residence is at or in the vicinity of the place of his employment and who was not living there solely because of the exigencies of his employment, unless he was injured or taken while engaged in the course of his employment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8be294e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a prisoner of war or a protected individual under the Geneva Conventions of 1949 and is detained or utilized by the United States.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"This subsection does not affect the payment of compensation under this subchapter derived otherwise than under this subsection, but compensation for disability or death does not accrue for a period for which pay, other benefit, or gratuity from the United States accrues to the disabled individual or his dependents on account of detention by the enemy or because of the same disability or death, unless that pay, benefit, or gratuity is refunded or renounced.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8be294f-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/534"},"text":"80 Stat. 534","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/70/tI/s1231/d"},"text":"Pub. L. 96–70, title I, § 1231(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-09-27"},"text":"Sept. 27, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/470"},"text":"93 Stat. 470","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8be2950-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8be2951-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8be2952-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib