{"tag":"section","attrib":{"id":"idb89f0959-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6368"},"text":null,"children":[{"tag":"num","attrib":{"value":"6368"},"text":"§ 6368.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of medical emergency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb89f095a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6368/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The medical emergency affecting a leave recipient shall, for purposes of this subchapter, be considered to have terminated on the date as of which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89f095b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6368/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leave recipient notifies the Leave Bank Board in writing, that the medical emergency no longer exists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f095c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6368/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Leave Bank Board of such leave recipient determines, after written notice and opportunity for the leave recipient (or, if appropriate, another person acting on behalf of the leave recipient) to answer orally or in writing, that the medical emergency no longer exists; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f095d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6368/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leave recipient is separated from service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb89f095e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6368/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89f095f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6368/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Leave Bank Board of a recipient shall, consistent with guidelines prescribed by the Office of Personnel Management, establish procedures to ensure that a leave recipient is not permitted to use or receive any transferred leave under this subchapter after the medical emergency terminates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f0960-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6368/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in section 5551, 5552, or 6306 shall apply with respect to any annual leave transferred to a leave recipient under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89f0961-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/566/s2/a"},"text":"Pub. L. 100–566, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2842"},"text":"102 Stat. 2842","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
