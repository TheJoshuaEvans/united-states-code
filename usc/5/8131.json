":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s791"},"text":"5 U.S.C. 791","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-09-07/ch458/s41"},"text":"Sept. 7, 1916, ch. 458, § 41","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/750"},"text":"39 Stat. 750","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the first 45 words of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-09-07/s41"},"text":"section 41 of the Act of Sept. 7, 1916","children":[],"tail":", are omitted as executed. The words “Panama Canal Company” are substituted for “Panama Railroad Company” on authority of the "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-26/ch1049/s2/a"},"text":"Act of Sept. 26, 1950, ch. 1049, § 2(a)","children":[],"tail":" (2), "},{"tag":"ref","attrib":{"href":"/us/stat/64/1038"},"text":"64 Stat. 1038","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Administration of this subchapter was transferred to the Secretary of Labor by section 1 of 1950 Reorg. Plan. No. 19, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/64/1271"},"text":"64 Stat. 1271","children":[],"tail":" (see section 8145)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c07427-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8c07428-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"tex