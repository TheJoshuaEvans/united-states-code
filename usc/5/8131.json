b":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8c0742d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Personnel Not Affected by 1967 Increase","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Increases authorized under amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83"},"text":"Pub. L. 90–83","children":[],"tail":" not applicable to specified personnel, see "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s7"},"text":"section 7 of Pub. L. 90–83","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8103"},"text":"section 8103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
