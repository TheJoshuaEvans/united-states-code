{"tag":"section","attrib":{"id":"idb8611556-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5407"},"text":null,"children":[{"tag":"num","attrib":{"value":"5407"},"text":"§ 5407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nature of payment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any payment to an employee under this section shall be part of the employee’s basic pay for the purposes of subchapter III of chapter 83, and chapters 84 and 87, and for such other purposes (other than chapter 75) as the Office shall determine by regulation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb8638657-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXI/s1129/a"},"text":"Pub. L. 108–136, div. A, title XI, § 1129(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1645"},"text":"117 Stat. 1645","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8638658-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8638659-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb863865a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5407, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615/tII/s201/a"},"text":"Pub. L. 98–615, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11