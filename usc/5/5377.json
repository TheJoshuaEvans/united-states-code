{"tag":"section","attrib":{"id":"idb85ecb37-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377"},"text":null,"children":[{"tag":"num","attrib":{"value":"5377"},"text":"§ 5377.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pay authority for critical positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb85ecb38-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For the purpose of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85ecb39-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “agency” has the meaning given it by section 5102; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecb3a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “position” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb85ecb3b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position to which chapter 51 applies, including a position in the Senior Executive Service or the Federal Bureau of Investigation and Drug Enforcement Administration Senior Executive Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85ecb3c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position under the Executive Schedule under sections 5312–5317;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85ecb3d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position to which section 5372 applies (or would apply, but for this section);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85ecb3e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position to which section 5372a applies (or would apply, but for this section);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85ecb3f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position established under section 3104;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85ecb40-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position in a category as to which a designation is in effect under subsection (i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85ecb41-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a position at the Federal Bureau of Investigation, the primary duties and responsibilities of which relate to intelligence functions (as determined by the Director of the Federal Bureau of Investigation).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85ecb42-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Authority under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85ecb43-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may be granted or exercised only with respect to a position—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb85ecb44-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which requires expertise of an extremely high level in a scientific, technical, professional, or administrative field; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb85ecb45-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which is critical to the agency’s successful accomplishment of an important mission; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecb46-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be granted or exercised only to the extent necessary to recruit or retain an individual exceptionally well qualified for the position.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85ecb47-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management, in consultation with the Office of Management and Budget, may, upon the request of the head of an agency, grant authority to fix the rate of basic pay for 1 or more positions in such agency in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85ecb48-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85ecb49-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rate of basic pay fixed under this section by an agency head may not be less than the rate of basic pay (including any comparability payments) which would then otherwise be payable for the position involved if this section had never been enacted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecb4a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Basic pay may not be fixed under this section at a rate greater than the rate payable for level I of the Executive Schedule, except upon written approval of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85ecb4b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The authority to fix the rate of basic pay under this section for a position shall terminate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85ecb4c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whenever the Office of Personnel Management determines (in accordance with such procedures and subject to such terms or conditions as such Office by regulation prescribes) that 1 or more of the requirements of subsection (b) are no longer met; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecb4d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as of such date as such Office may otherwise specify, except that termination under this paragraph may not take effect before the authority has been available for such position for at least 1 calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85ecb4e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management may not authorize the exercise of authority under this section with respect to more than 800 positions at any time, of which not more than 30 may, at any such time, be positions the rate of basic pay for which would otherwise be determined under subchapter II.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85ecb4f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall consult with the Office of Management and Budget before making any decision to grant or terminate any authority under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85ecb50-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Office of Personnel Management shall report to the Committee on Government Reform of the House of Representatives and the Committee on Governmental Affairs of the Senate each year, in writing, on the operation of this section. Each report under this subsection shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85ecb51-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of positions, in the aggregate and by agency, for which higher rates of pay were authorized or paid under this section during any part of the period covered by such report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecb52-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of each employee to whom a higher rate of pay was paid under this section during any portion of the period covered by such report, the rate on ","children":[{"tag":"ref","attrib":{"idref":"fn002100"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002100"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “or”."}],"tail":" rates paid under this section during such period, the dates between which each such higher rate was paid, and the rate or rates that would have been paid but for this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb85ecb53-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb85ecb54-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this subsection, the term “position” means the work, consisting of the duties and responsibilities, assignable to an employee, except that such term does not include any position under subsection (a)(2)(A)–(E).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb85ecb55-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5377/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the request of an agency head, the President may designate 1 or more categories of positions within such agency to be treated, for purposes of this section, as positions within the meaning of subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb85ecb56-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s103/a"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 103(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1444; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/34"},"text":"Pub. L. 102–378, § 2(34)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1350"},"text":"106 Stat. 1350","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/411/tI/s102"},"text":"Pub. L. 108–411, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2311"},"text":"118 Stat. 2311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dB/tI/s115"},"text":"Pub. L. 108–447, div. B, title I, § 115","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2870"},"text":"118 Stat. 2870","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb85ecb57-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb85ecb58-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb85ecb59-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Level I of the Executive Schedule, referred to in subsec. (d)(2), is set out in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5312"},"text":"section 5312 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb85ecb5a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447"},"text":"Pub. L. 108–447","children":[],"tail":" added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/411/s102/1"},"text":"Pub. L. 108–411, § 102(1)","children":[],"tail":", (2), substituted “Office of Management and Budget” for “Office of Personnel Management” and “Office of Personnel Management” for “Office of Management and Budget”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/411/s102/2"},"text":"Pub. L. 108–411, § 102(2)","children":[],"tail":", substituted “Office of Personnel Management” for “Office of Management and Budget”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/411/s102/1"},"text":"Pub. L. 108–411, § 102(1)","children":[],"tail":"–(3), substituted “Office of Personnel Management” for “Office of Management and Budget” and “Office of Management and Budget” for “Office of Personnel Management” and struck out “prescribing regulations under this section or” before “making any decision”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/411/s102/2"},"text":"Pub. L. 108–411, § 102(2)","children":[],"tail":", (4), in introductory provisions, substituted “Office of Personnel Management” for “Office of Management and Budget” and “Committee on Government Reform” for “Committee on Post Office and Civil Service”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a)(2)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/34/A"},"text":"Pub. L. 102–378, § 2(34)(A)","children":[],"tail":", added subpars. (E) and (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/34/B"},"text":"Pub. L. 102–378, § 2(34)(B)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb85ecb5b-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb85ecb5c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Government Reform of House of Representatives changed to Committee on Oversight and Government Reform of House of Representatives by House Resolution No. 6, One Hundred Tenth Congress, ","children":[{"tag":"date","attrib":{"date":"2007-01-05"},"text":"Jan. 5, 2007","children":[],"tail":". Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Governmental Affairs of Senate changed to Committee on Homeland Security and Governmental Affairs of Senate, effective ","children":[{"tag":"date","attrib":{"date":"2005-01-04"},"text":"Jan. 4, 2005","children":[],"tail":", by Senate Resolution No. 445, One Hundred Eighth Congress, "},{"tag":"date","attrib":{"date":"2004-10-09"},"text":"Oct. 9, 2004","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb85ecb5d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on such date as the President shall determine, but not earlier than 90 days, and not later than 180 days, after ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see section 529 [title III, § 305] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idb85ecb5e-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"delegationOfFunctions","id":"idb85ecb5f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Delegation of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of President under this section assigned to the Director of the Office of Personnel Management by section 1 of Ex. Ord. No. 13415, ","children":[{"tag":"date","attrib":{"date":"2006-12-01"},"text":"Dec. 1, 2006","children":[],"tail":", 71 F.R. 70641, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s4505a"},"text":"section 4505a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
