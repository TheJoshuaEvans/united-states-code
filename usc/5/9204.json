{"tag":"section","attrib":{"id":"idb926fd6c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204"},"text":null,"children":[{"tag":"num","attrib":{"value":"9204"},"text":"§ 9204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Adverse action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb926fd6d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"First Violation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Director of the Office of Personnel Management determines, after notice and an opportunity for a hearing on the record, that an employee of an agency has violated section 9202, the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb926fd6e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue to the employee a written warning that includes a description of the violation and the additional penalties that may apply for subsequent violations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd6f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file such warning in the employee’s official personnel record file.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb926fd70-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent Violations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Director of the Office of Personnel Management determines, after notice and an opportunity for a hearing on the record, that an employee that was subject to subsection (a) has committed a subsequent violation of section 9202, the Director may take the following action:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb926fd71-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For a second violation, suspension of the employee for a period of not more than 7 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd72-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For a third violation, suspension of the employee for a period of more than 7 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd73-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For a fourth violation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb926fd74-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension of the employee for a period of more than 7 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb926fd75-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civil penalty against the employee in an amount that is not more than $250.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd76-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For a fifth violation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb926fd77-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension of the employee for a period of more than 7 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb926fd78-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civil penalty against the employee in an amount that is not more than $500.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb926fd79-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For any subsequent violation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb926fd7a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension of the employee for a period of more than 7 days; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb926fd7b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s9204/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civil penalty against the employee in an amount that is not more than $1,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb926fd7c-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/dA/tXI/s1122/a"},"text":"Pub. L. 116–92, div. A, title XI, § 1122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/1606"},"text":"133 Stat. 1606","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
