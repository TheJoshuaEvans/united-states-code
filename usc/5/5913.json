{"tag":"section","attrib":{"id":"idb88bf5e2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5913"},"text":null,"children":[{"tag":"num","attrib":{"value":"5913"},"text":"§ 5913.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Official residence expenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb88bf5e3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5913/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of this section, “agency” has the meaning given it by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5721"},"text":"section 5721 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb88bf5e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5913/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under such regulations as the President may prescribe, funds available to an agency for administrative expenses may be allotted to posts in foreign countries to defray the unusual expenses incident to the operation and maintenance of official residences suitable for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb88bf5e5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5913/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chief representatives of the United States at the posts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb88bf5e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5913/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other senior officials of the Government of the United States a