:{"href":"/us/usc/t5/s921"},"text":"5 U.S.C. 921","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-06-30/ch212/s301"},"text":"June 30, 1945, ch. 212, § 301","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/298"},"text":"59 Stat. 298","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-05-24/ch270/s10"},"text":"May 24, 1946, ch. 270, § 10","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/218"},"text":"60 Stat. 218","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-09-01/ch1208/s206"},"text":"Sept. 1, 1954, ch. 1208, § 206","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1110"},"text":"68 Stat. 1110","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t5/s926"},"text":"5 U.S.C. 926","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-09-01/ch1208/s208/a"},"text":"Sept. 1, 1954, ch. 1208, § 208(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1111"},"text":"68 Stat. 1111","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 18, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/525"},"text":"Pub. L. 85–525","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/363"},"text":"72 Stat. 363","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “head of an agency” are substituted for “head of any department, independent establishment, or agency, including Government-owned or controlled corporations” because of the definition of “agency” and the application stated in section 5541. The words “the United States” are substituted for “the several States and the District of Columbia”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “head of an agency” are substituted for “head of any department, independent establishment, or agency, including Government-owned or controlled corporations, or of the municipal government of the District of Columbia” because of the definition of “agency” and the application stated in section 5541. The word “officer” is omitted as included in “employee”. The word “scheduled” is omitted since ","children":[{"tag":"ref","attrib":{"href":"/us/act/1962-10-11/s603"},"text":"section 603 of the Act of Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/793"},"text":"Pub. L. 87–793","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/847"},"text":"76 Stat. 847","children":[],"tail":", eliminated the necessity of referring to rates as scheduled or longevity. Reference to the “Classification Act of 1949, as amended” is omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb86f6d43-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb86f6d44-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1967 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 5","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5545(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 App.: 926.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 18, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/504"},"text":"Pub. L. 89–504","children":[],"tail":" §§ 404(c), 405(d), (e), "},{"tag":"html:a","attrib":{"href":"/us/stat/80/297"},"text":"80 Stat. 297","children":[],"tail":", 298."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5545(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 App.: 1134.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 19, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/512/s1"},"text":"Pub. L. 89–512, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/318"},"text":"80 Stat. 318","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the second sentence of subsection (d), the words “Under such regulations as the Commission may prescribe, and for such minimum periods as it determines appropriate” are substituted for clauses (3) and (4) of the third sentence of 5 App. U.S.C. 1134. That requirement in clause (4) that the Commission prescribe regulations is codified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5548/b"},"text":"5 U.S.C. 5548(b)","children":[],"tail":" by section 1 (32) of this bill. The words “an employee to whom chapter 51 and subchapter III of chapter 53 of this title applies is entitled to be paid the appropriate differential” are substituted for “The appropriate differential shall be paid to any officer or employee to whom this Act applies” to reflect the codification of that act (Classification Act of 1949) in title 5, United States Code, and to conform with the definitions applicable."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1), the words “does not apply to an employee” are substituted for “shall not be applicable with respect to any officer or employee.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2), the words “may not . . . applicable to the employee” are substituted for “shall not . . . applicable with respect to such officer or employee”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb86f6d45-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb86f6d46-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"GS–10, referred to in subsec. (c)(1), is contained in the General Schedule which is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Occupational Safety and Health Act of 1970, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596"},"text":"Pub. L. 91–596","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1590"},"text":"84 Stat. 1590","children":[],"tail":", which is classified principally to chapter 15 (§ 651 et seq.) of Title 29, Labor. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"section 651 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb86f6d47-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" substituted “except—” and subpars. (A) and (B) for “except in such circumstances as the Office may by regulation prescribe; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136"},"text":"Pub. L. 108–136","children":[],"tail":" inserted before period at end of first sentence “, and for any hardship or hazard related to asbestos, such differentials shall be determined by applying occupational safety and health standards consistent with the permissible exposure limit promulgated by the Secretary of Labor under the Occupational Safety and Health Act of 1970”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378"},"text":"Pub. L. 102–378","children":[],"tail":" made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/s529/tII/s203"},"text":"Pub. L. 101–509, § 529 [title II, § 203]","children":[],"tail":". See 1990 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/s529/tI/s101/b/3/E"},"text":"Pub. L. 101–509, § 529 [title I, § 101(b)(3)(E)]","children":[],"tail":", inserted “(including any applicable locality-based comparability payment under section 5304 or similar provision of law and any applicable special rate of pay under section 5305 or similar provision of law)” after “GS–10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/s529/tII/s203"},"text":"Pub. L. 101–509, § 529 [title II, § 203]","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/378"},"text":"Pub. L. 102–378","children":[],"tail":", struck out “irregular or intermittent” before “duty involving unusual” in first sentence and inserted “, except in such circumstances as the Office may by regulation prescribe” after “thereof” in par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/173"},"text":"Pub. L. 101–173","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “an employee in a position in which the hours of duty cannot be controlled administratively, and which requires substantial amounts of irregular, unscheduled, overtime duty with the employee generally being responsible for recognizing, without supervision, circumstances which require him to remain on duty, shall receive premium pay for this duty on an annual basis instead of premium pay provided by other provisions of this subchapter, except for regularly scheduled overtime, night, and Sunday duty, and for holiday duty. Premium pay under this paragraph is determined as an appropriate percentage, not less than 10 percent nor more than 25 percent, of such part of the rate of basic pay for the position as does not exceed the minimum rate of basic pay for GS–10, by taking into consideration the frequency and duration of irregular unscheduled overtime duty required in the position.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1982—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":" substituted “section 5141” for “section 180”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/54"},"text":"Pub. L. 96–54","children":[],"tail":" substituted “percent” for “per centum” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1978—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":" substituted “Office of Personnel Management” for “Civil Service Commission” and “Office” for “Commission” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1975—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/183"},"text":"Pub. L. 94–183","children":[],"tail":" struck out “Sunday,” after “Night,” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/231"},"text":"Pub. L. 91–231","children":[],"tail":" corrected the system of premium compensation of employees whose work schedules cannot be administratively controlled by providing for separate treatment for irregular, unscheduled, and overtime duty on one hand and for duty at night, on Sundays, and on holidays on the other."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1968—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/556"},"text":"Pub. L. 90–556","children":[],"tail":" inserted “(or, for a position described in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5542/a/3"},"text":"section 5542(a)(3) of this title","children":[],"tail":", of the basic pay of the position)” after “GS–10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1967—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/206"},"text":"Pub. L. 90–206","children":[],"tail":" substituted “not less than 10 percent nor more than 25 percent” for “not in excess of 15 percent”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb86f6d48-5e84-11f1-a692-ec26948f6fea"}