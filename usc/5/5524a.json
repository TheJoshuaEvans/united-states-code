{"tag":"section","attrib":{"id":"idb86840b7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5524a"},"text":"§ 5524a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance payments for new appointees and employees relocating within the United States and its territories","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb86840b8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86840b9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of each agency may provide for the advance payment of basic pay, covering not more than 2 pay periods, to any individual who is newly appointed to a position in the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86840ba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of each agency may provide for the advance payment of basic pay, covering not more than 4 pay periods, to an employee who is assigned to a position in the agency that is located—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86840bb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outside of the employee’s commuting area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86840bc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the United States, the Commonwealth of Puerto Rico, the Commonwealth of the Northern Mariana Islands, or any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86840bd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86840be-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to adjustment of the account of an employee under paragraph (2) and other applicable statutes, the advance payment of basic pay shall be made, under agency procedures governing advance payments under this section, at the initial rate of basic pay to be payable to the employee upon the commencement of service in the position to which appointed or assigned.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86840bf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of each agency shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86840c0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524a/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the review of the account of each employee of the agency in receipt of any payment under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86840c1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524a/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adjustment of the amount of any such payment on the basis of the rate of basic pay to which the employee would have been entitled under applicable statute other than this section for the respective periods covered by the payments, if the employee had performed active service under the terms of such employee’s appointment or assignment during each period in the position to which appointed or assigned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86840c2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An advance payment under this section is recoverable by the Government of the United States or the government of the District of Columbia, as the case may be, from the employee or such employee’s estate by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86840c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" setoff against accrued pay, amount of retirement credit, or other amount due to the employee from the Government of the United States or the government of the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86840c4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5524a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other method as is provided by law.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The head of the agency concerned may waive in whole or in part a right of recovery of an advance payment under this section if it is shown that the recovery would be against equity and good conscience or against the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86840c5-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/s107/a"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 107(a)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1449; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tXI/s1134/a"},"text":"Pub. L. 114–328, div. A, title XI, § 1134(a)","children":[],"tail":"–(c)(1), "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2459"},"text":"130 Stat. 2459","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb86840c6-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb86840c7-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb86840c8-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1134/c/1"},"text":"Pub. L. 114–328, § 1134(c)(1)","children":[],"tail":", inserted “and employees relocating within the United States and its territories” after “appointees” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1134/a"},"text":"Pub. L. 114–328, § 1134(a)","children":[],"tail":", designated existing provisions as par. (1) and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1134/b/1"},"text":"Pub. L. 114–328, § 1134(b)(1)","children":[],"tail":", inserted “or assigned” after “appointed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1134/b/2"},"text":"Pub. L. 114–328, § 1134(b)(2)","children":[],"tail":", inserted “or assignment” after “appointment” and “or assigned” after “appointed”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb86840c9-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb86840ca-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on such date as the President shall determine, but not earlier than 90 days, and not later than 180 days, after ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see section 529 [title III, § 305] of "},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out as an Effective Date of 1990 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5301"},"text":"section 5301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
