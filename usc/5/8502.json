{"tag":"section","attrib":{"id":"idb90cbea3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8502"},"text":null,"children":[{"tag":"num","attrib":{"value":"8502"},"text":"§ 8502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation under State agreement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb90cbea4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Labor, on behalf of the United States, may enter into an agreement with a State, or with an agency administering the unemployment compensation law of a State, under which the State agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90cbea5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay, as agent of the United States, compensation under this subchapter to Federal employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90cbea6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise cooperate with the Secretary and with other State agencies in paying compensation under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90cbea7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The agreement shall provide that compensation will be paid by the State to a Federal employee in the same amount, on the same terms, and subject to the same conditions as the compensation which would be payable to him under the unemployment compensation law of the State if his Federal service and Federal wages assigned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8504"},"text":"section 8504 of this title","children":[],"tail":" to the State had been included as employment and wages under that State law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"status":"repealed","id":"idb90cbea8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"[(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/86/B"},"text":"Pub. L. 90–83, § 1(86)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/218"},"text":"81 Stat. 218","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90cbea9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A determination by a State agency with respect to entitlement to compensation under an agreement is subject to review in the same manner and to the same extent as determinations under the State unemployment compensation law, and only in that manner and to that extent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90cbeaa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each agreement shall provide the terms and conditions on which it may be amended or terminated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb90cbeab-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/586"},"text":"80 Stat. 586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/86"},"text":"Pub. L. 90–83, § 1(86)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/218"},"text":"81 Stat. 218","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb90cbeac-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb90cbead-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb90cbeae-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1966 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Derivation","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Statutes and","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Statutes at Large","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/usc/t42/s1362"},"text":"42 U.S.C. 1362","children":[],"tail":"."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-09-01/ch1212/s4/a"},"text":"Sept. 1, 1954, ch. 1212, § 4(a)","children":[],"tail":" “Sec. 1502”, "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1131"},"text":"68 Stat. 1131","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/778/s542/b/1/A"},"text":"Pub. L. 86–778, § 542(b)(1)(A)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/985"},"text":"74 Stat. 985","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “under this subchapter” are substituted for “on the basis provided in subsection (b) of this section”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “with respect to unemployment after ","children":[{"tag":"date","attrib":{"date":"1954-12-31"},"text":"December 31, 1954","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “with respect to unemployment after ","children":[{"tag":"date","attrib":{"date":"1960-12-31"},"text":"December 31, 1960","children":[],"tail":"” are omitted as obsolete. In the last sentence, the application to section 8503(b) is omitted and carried into that section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb90cbeaf-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"1967 ","children":[{"tag":"inline","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This section amends ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8502"},"text":"5 U.S.C. 8502","children":[],"tail":" to eliminate certain provisions that are now obsolete. The obsolete provisions were based on "},{"tag":"ref","attrib":{"href":"/us/act/1960-09-13/s542/b/1/A"},"text":"section 542(b)(1)(A) of the act of September 13, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/985"},"text":"74 Stat. 985","children":[],"tail":", that amended section 1502(b) of the Social Security Act effective "},{"tag":"date","attrib":{"date":"1961-01-01"},"text":"January 1, 1961","children":[],"tail":", but only in the case of weeks of unemployment beginning before "},{"tag":"date","attrib":{"date":"1966-01-01"},"text":"January 1, 1966","children":[],"tail":". Any existing rights are preserved by section 7 of this bill."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
