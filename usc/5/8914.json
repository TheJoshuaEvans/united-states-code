{"tag":"section","attrib":{"id":"idb922422d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8914"},"text":null,"children":[{"tag":"num","attrib":{"value":"8914"},"text":"§ 8914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect of other statutes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any provision of law outside of this chapter which provides coverage or any other benefit under this chapter to any individuals who (based on their being employed by an entity other than the Government) would not otherwise be eligible for any such coverage or benefit shall not apply with respect to any individual appointed, transferred, or otherwise commencing that type of employment on or after ","children":[{"tag":"date","attrib":{"date":"1988-10-01"},"text":"October 1, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb922422e-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/238/tI/s108/a/3/A"},"text":"Pub. L. 100–238, title I, § 108(a)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-01-08"},"text":"Jan. 8, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1747"},"text":"101 Stat. 1747","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
