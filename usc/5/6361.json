{"tag":"section","attrib":{"id":"idb89f0909-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6361"},"text":null,"children":[{"tag":"num","attrib":{"value":"6361"},"text":"§ 6361.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb89f090a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6361/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “employee” means an employee as defined by section 6301(2), but shall exclude any individual employed by the government of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f090b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6361/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “executive agency” means any executive agency or any administrative unit thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f090c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6361/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “leave bank” means a leave bank established under section 6363;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f090d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6361/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “leave contributor” means an employee who contributes leave to an agency leave bank under section 6365;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f090e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6361/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “leave recipient” means an employee whose application under section 6367 to receive contributions of leave from a leave bank is approved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb89f090f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6361/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “medical emergency” means a medical condition of an employee or a family member of such employee that is likely to require the prolonged absence of such employee from duty and to result in a substantial loss of income to such employee because of the unavailability of paid leave (disregarding any advanced leave).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb89f0910-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/566/s2/a"},"text":"Pub. L. 100–566, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-31"},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2839"},"text":"102 Stat. 2839","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/103/s3/a"},"text":"Pub. L. 103–103, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-10-08"},"text":"Oct. 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1022"},"text":"107 Stat. 1022","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb89f0911-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb89f0912-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb89f0913-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1993—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/103"},"text":"Pub. L. 103–103","children":[],"tail":" inserted before period at end “(disregarding any advanced leave)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb89f0914-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb89f0915-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/103"},"text":"Pub. L. 103–103","children":[],"tail":" effective as of the 120th day after "},{"tag":"date","attrib":{"date":"1993-10-08"},"text":"Oct. 8, 1993","children":[],"tail":", or such earlier date as the Office of Personnel Management may by regulation prescribe, see "},{"tag":"ref","attrib":{"href":"/us/pl/103/103/s6"},"text":"section 6 of Pub. L. 103–103","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s6331"},"text":"section 6331 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb89f0916-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Leave Bank for Judicial Branch Employees of Federal Government in Reserves Who Were Activated During Persian Gulf War","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/58/s3"},"text":"Pub. L. 102–58, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-18"},"text":"June 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/299"},"text":"105 Stat. 299","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/58/s3"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judicial Branch Employees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director of the Administrative Office of the United States Courts shall establish a leave bank program under which—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of the Judicial Branch may (during a period specified by the Director of the Administrative Office) donate any unused annual leave from the employee’s annual leave account to a leave bank established by the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount of annual leave that has been donated under paragraph (1) shall be divided equally among the annual leave accounts of all employees who have been members of the Armed Forces serving on active duty during the Persian Gulf conflict pursuant to an order issued under section 672(a) [now 12301(a)], 672(g) [now 12301(g)], 673 [now 12302], 673b [now 12304], 674 [now 12306], 675 [now 12307], or 688 of title 10, United States Code, and who return to employment with the Judicial Branch; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such Persian Gulf conflict participants who have returned to Judicial Branch employment may use such annual leave, after it is credited to their leave accounts, in the same manner as any other annual leave to their credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of subsection (a), the term ‘employee’ means an employee as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6301/2"},"text":"section 6301(2) of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-06-18"},"text":"June 18, 1991","children":[],"tail":"], the Director of the Administration [Administrative] Office shall prescribe regulations necessary for the administration of subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb89f0917-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Leave Bank for Federal Civilian Employees in Reserves Who Were Activated During Persian Gulf War","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/25/tIII/s361"},"text":"Pub. L. 102–25, title III, § 361","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/92"},"text":"105 Stat. 92","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1054/c/1"},"text":"Pub. L. 102–484, div. A, title X, § 1054(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2502"},"text":"106 Stat. 2502","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/484/dA/tX/s1054/c/1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Service Employees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Personnel Management shall establish a leave bank program under which—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee in any executive agency may (during a period specified by the Office of Personnel Management) donate any unused annual leave from the employee’s annual leave account to a leave bank established by the Office of Personnel Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total annual leave that has been donated under paragraph (1) shall be divided equally among the annual leave accounts of all employees who have been members of the Armed Forces serving on active duty during the Persian Gulf conflict pursuant to an order issued under section 672(a) [now 12301(a)], 672(g) [now 12301(g)], 673 [now 12302], 673b [now 12304], 674 [now 12306], 675 [now 12307], or 688 of title 10, United States Code, and who return to civilian employment with their agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such Persian Gulf concflict [sic] participants who have returned to civilian employment may use such annual leave, after it is credited to their leave accounts, in the same manner as any other annual leave to their credit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of subsection (a), the term ‘employee’ means an employee as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6361/1"},"text":"section 6361(1) of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 30 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1991-04-06"},"text":"Apr. 6, 1991","children":[],"tail":"], the Office of Personnel Management shall prescribe regulations necessary for the administration of subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department of Veterans Affairs Health-Care Professionals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Veterans Affairs shall establish a program similar to that established under subsection (a) for the benefit of health-care professionals covered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s7423/e"},"text":"section 7423(e) of title 38","children":[],"tail":", United States Code. Such program shall be as similar and [as] practicable to the program established under subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
