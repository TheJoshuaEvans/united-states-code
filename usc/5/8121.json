{"tag":"section","attrib":{"id":"idb8c073ac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8121"},"text":null,"children":[{"tag":"num","attrib":{"value":"8121"},"text":"§ 8121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Claim","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Compensation under this subchapter may be allowed only if an individual or someone on his behalf makes claim therefor. The claim shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8c073ad-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8121/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made in writing within the time specified by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8122"},"text":"section 8122 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c073ae-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8121/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be delivered to the office of the Secretary of Labor or to an individual whom the Secretary may designate by regulation, or deposited in the mail properly stamped and addressed to the Secretary or his designee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c073af-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8121/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be on a form approved by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c073b0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8121/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain all information required by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c073b1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8121/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be sworn to by the individual entitled to compensation or someone on his behalf; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8c073b2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8121/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except in case of death, be accompanied by a certificate of the physician of the employee stating the nature of the injury and the nature and probable extent of the disability.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary may waive paragraphs (3)–(6) of this section for reasonable cause shown.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8c073b3-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/543"},"text":"80 Stat. 543","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/416/s13"},"text":"Pub. L. 93–416, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-09-07"},"text":"Sept. 7, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1147"},"text":"88 Stat. 1147","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8c073b4-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb8c0