{"tag":"section","attrib":{"id":"idb7ba26e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s562"},"text":null,"children":[{"tag":"num","attrib":{"value":"562"},"text":"§ 562.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this subchapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7ba26e5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s562/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “agency” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551/1"},"text":"section 551(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s562/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “consensus” means unanimous concurrence among the interests represented on a negotiated rulemaking committee established under this subchapter, unless such committee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7ba26e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s562/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees to define such term to mean a general but not unanimous concurrence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7ba26e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s562/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agrees upon another specified definition;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s562/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “convener” means a person who impartially assists an agency in determining whether establishment of a negotiated rulemaking committee is feasible and appropriate in a particular rulemaking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s562/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “facilitator” means a person who impartially aids in the discussions and negotiations among the members of a negotiated rulemaking committee to develop a proposed rule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s562/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “interest” means, with respect to an issue or matter, multiple parties which have a similar point of view or which are likely to be affected in a similar manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26ec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s562/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “negotiated rulemaking” means rulemaking through the use of a negotiated rulemaking committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26ed-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s562/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “negotiated rulemaking committee” or “committee” means an advisory committee established by an agency in accordance with this subchapter and chapter 10 of this title to consider and discuss issues for the purpose of reaching a consensus in the development of a proposed rule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26ee-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s562/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “party” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551/3"},"text":"section 551(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26ef-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s562/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551/2"},"text":"section 551(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26f0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s562/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “rule” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551/4"},"text":"section 551(4) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7ba26f1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s562/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “rulemaking” means “rule making” as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551/5"},"text":"section 551(5) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7ba26f2-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/648/s3/a"},"text":"Pub. L. 101–648, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-29"},"text":"Nov. 29, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4970"},"text":"104 Stat. 4970","children":[],"tail":", § 582; renumbered § 562, "},{"tag":"ref","attrib":{"href":"/us/pl/102/354/s3/a/2"},"text":"Pub. L. 102–354, § 3(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-08-26"},"text":"Aug. 26, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/944"},"text":"106 Stat. 944","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/5"},"text":"Pub. L. 117–286, § 4(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4305"},"text":"136 Stat. 4305","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7ba26f3-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7ba26f4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7ba26f5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 10 of this title” for “the Federal Advisory Committee Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/354"},"text":"Pub. L. 102–354","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s582"},"text":"section 582 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
