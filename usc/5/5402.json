{"tag":"section","attrib":{"id":"idb8611503-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5402"},"text":null,"children":[{"tag":"num","attrib":{"value":"5402"},"text":"§ 5402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8611504-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “agency” means an Executive agency under section 105, but does not include the Government Accountability Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8611505-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8611506-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5402/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual paid under a statutory pay system defined in section 5302(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8611507-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5402/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prevailing rate employee, as defined in section 5342(a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8611508-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5402/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a category of employees included by the Office of Personnel Management following the review of an agency plan under section 5403(b)(1);","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include—","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb8611509-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5402/2/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual paid at an annual rate of basic pay for a level of the Executive Schedule, under subchapter II of chapter 53, or at a rate provided for one of those levels under another provision of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb861150a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5402/2/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the Senior Executive Service paid under subchapter VIII of chapter 53, or an equivalent system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb861150b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5402/2/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administrative law judge paid under section 5372;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb861150c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5402/2/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract appeals board member paid under section 5372a;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb861150d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5402/2/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administrative appeals judge paid under section 5372b; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb861150e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5402/2/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual in a position which is excepted from the competitive service because of its confidential, policy-determining, policy-making, or policy-advocating character; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb861150f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5402/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Office” means the Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8611510-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXI/s1129/a"},"text":"Pub. L. 108–136, div. A, title XI, § 1129(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1642"},"text":"117 Stat. 1642","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8611511-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{