{"tag":"section","attrib":{"id":"idb7d6d69c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801"},"text":null,"children":[{"tag":"num","attrib":{"value":"801"},"text":"§ 801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb7d6d69d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7d6d69e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7d6d69f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before a rule can take effect, the Federal agency promulgating such rule shall submit to each House of the Congress and to the Comptroller General a report containing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7d6d6a0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of the rule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7d6d6a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a concise general statement relating to the rule, including whether it is a major rule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7d6d6a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed effective date of the rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d6d6a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On the date of the submission of the report under subparagraph (A), the Federal agency promulgating the rule shall submit to the Comptroller General and make available to each House of Congress—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7d6d6a4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete copy of the cost-benefit analysis of the rule, if any;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7d6d6a5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency’s actions relevant to sections 603, 604, 605, 607, and 609;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7d6d6a6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency’s actions relevant to sections 202, 203, 204, and 205 of the Unfunded Mandates Reform Act of 1995; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7d6d6a7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant information or requirements under any other Act and any relevant Executive orders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d6d6a8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon receipt of a report submitted under subparagraph (A), each House shall provide copies of the report to the chairman and ranking member of each standing committee with jurisdiction under the rules of the House of Representatives or the Senate to report a bill to amend the provision of law under which the rule is issued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d6d6a9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For any rule submitted under subparagraph (A), if the Federal agency promulgating the rule, in whole or in part, revokes, suspends, replaces, amends, or otherwise makes the rule ineffective, or the rule is made ineffective for any other reason, the Federal agency shall submit to the Comptroller General a report containing—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7d6d6aa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the title of the rule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7d6d6ab-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Register citation for the rule, if any;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7d6d6ac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which rule was submitted to the Comptroller General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7d6d6ad-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the provisions of the rule that are being revoked, suspended, replaced, amended, or otherwise made ineffective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7d6d6ae-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7d6d6af-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General shall provide a report on each major rule to the committees of jurisdiction in each House of the Congress by the end of 15 calendar days after the submission or publication date as provided in section 802(b)(2). The report of the Comptroller General shall include an assessment of the agency’s compliance with procedural steps required by paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d6d6b0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal agencies shall cooperate with the Comptroller General by providing information relevant to the Comptroller General’s report under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7d6d6b1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A major rule relating to a report submitted under paragraph (1) shall take effect on the latest of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7d6d6b2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the later of the date occurring 60 days after the date on which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7d6d6b3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Congress receives the report submitted under paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7d6d6b4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rule is published in the Federal Register, if so published;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d6d6b5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Congress passes a joint resolution of disapproval described in section 802 relating to the rule, and the President signs a veto of such resolution, the earlier date—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7d6d6b6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which either House of Congress votes and fails to override the veto of the President; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7d6d6b7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occurring 30 session days after the date on which the Congress received the veto and objections of the President; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d6d6b8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the rule would have otherwise taken effect, if not for this section (unless a joint resolution of disapproval under section 802 is enacted).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7d6d6b9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except for a major rule, a rule shall take effect as otherwise provided by law after submission to Congress under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7d6d6ba-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding paragraph (3), the effective date of a rule shall not be delayed by operation of this chapter beyond the date on which either House of Congress votes to reject a joint resolution of disapproval under section 802.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7d6d6bb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7d6d6bc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A rule shall not take effect (or continue), if the Congress enacts a joint resolution of disapproval, described under section 802, of the rule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7d6d6bd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A rule that does not take effect (or does not continue) under paragraph (1) may not be reissued in substantially the same form, and a new rule that is substantially the same as such a rule may not be issued, unless the reissued or new rule is specifically authorized by a law enacted after the date of the joint resolution disapproving the original rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7d6d6be-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7d6d6bf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of this section (except subject to paragraph (3)), a rule that would not take effect by reason of subsection (a)(3) may take effect, if the President makes a determination under paragraph (2) and submits written notice of such determination to the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7d6d6c0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) applies to a determination made by the President by Executive order that the rule should take effect because such rule is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7d6d6c1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary because of an imminent threat to health or safety or other emergency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d6d6c2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary for the enforcement of criminal laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d6d6c3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary for national security; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d6d6c4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued pursuant to any statute implementing an international trade agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7d6d6c5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An exercise by the President of the authority under this subsection shall have no effect on the procedures under section 802 or the effect of a joint resolution of disapproval under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7d6d6c6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7d6d6c7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to the opportunity for review otherwise provided under this chapter, in the case of any rule for which a report was submitted in accordance with subsection (a)(1)(A) during the period beginning on the date occurring—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7d6d6c8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the Senate, 60 session days, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d6d6c9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the House of Representatives, 60 legislative days,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"before the date the Congress adjourns a session of Congress through the date on which the same or succeeding Congress first convenes its next session, section 802 shall apply to such rule in the succeeding session of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7d6d6ca-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7d6d6cb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In applying section 802 for purposes of such additional review, a rule described under paragraph (1) shall be treated as though—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb7d6d6cc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such rule were published in the Federal Register (as a rule that shall take effect) on—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb7d6d6cd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/d/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the Senate, the 15th session day, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb7d6d6ce-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/d/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of the House of Representatives, the 15th legislative day,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"after the succeeding session of Congress first convenes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb7d6d6cf-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report on such rule were submitted to Congress under subsection (a)(1) on such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d6d6d0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this paragraph shall be construed to affect the requirement under subsection (a)(1) that a report shall be submitted to Congress before a rule can take effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7d6d6d1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A rule described under paragraph (1) shall take effect as otherwise provided by law (including other subsections of this section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7d6d6d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb7d6d6d3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, section 802 shall also apply to any major rule promulgated between ","children":[{"tag":"date","attrib":{"date":"1996-03-01"},"text":"March 1, 1996","children":[],"tail":", and the date of the enactment of this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7d6d6d4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In applying section 802 for purposes of Congressional review, a rule described under paragraph (1) shall be treated as though—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb7d6d6d5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such rule were published in the Federal Register on the date of enactment of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb7d6d6d6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report on such rule were submitted to Congress under subsection (a)(1) on such date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb7d6d6d7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The effectiveness of a rule described under paragraph (1) shall be as otherwise provided by law, unless the rule is made of no force or effect under section 802.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7d6d6d8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any rule that takes effect and later is made of no force or effect by enactment of a joint resolution under section 802 shall be treated as though such rule had never taken effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb7d6d6d9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s801/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Congress does not enact a joint resolution of disapproval under section 802 respecting a rule, no court or agency may infer any intent of the Congress from any action or inaction of the Congress with regard to such rule, related statute, or joint resolution of disapproval.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb7d6d6da-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/121/tII/s251"},"text":"Pub. L. 104–121, title II, § 251","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-29"},"text":"Mar. 29, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/868"},"text":"110 Stat. 868","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/5/dB/tIII/s270"},"text":"Pub. L. 118–5, div. B, title III, § 270","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-06-03"},"text":"June 3, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/33"},"text":"137 Stat. 33","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/97/s2"},"text":"Pub. L. 118–97, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1573"},"text":"138 Stat. 1573","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb7d6d6db-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idb7d6d6dc-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Subsection (a)(1)(D)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/97/s2/b"},"text":"Pub. L. 118–97, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1574"},"text":"138 Stat. 1574","children":[],"tail":", provided that, effective 6 years after "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", subsection (a)(1) of this section is amended by striking subparagraph (D). See 2024 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb7d6d6dd-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb7d6d6de-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 202, 203, 204, and 205 of the Unfunded Mandates Reform Act of 1995, referred to in subsec. (a)(1)(B)(iii), are classified to sections 1532, 1533, 1534, and 1535, respectively, of Title 2, The Congress.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this chapter, referred to in subsec. (e)(1), (2), is the date of the enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/121"},"text":"Pub. L. 104–121","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1996-03-29"},"text":"Mar. 29, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb7d6d6df-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/97/s2/b"},"text":"Pub. L. 118–97, § 2(b)","children":[],"tail":", struck out subpar. (D) which required Federal agencies to submit to the Comptroller General a report on rules that are revoked, suspended, replaced, amended, or otherwise made ineffective."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/97/s2/a"},"text":"Pub. L. 118–97, § 2(a)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/5"},"text":"Pub. L. 118–5","children":[],"tail":", §§ 268, 270, temporarily inserted “, and shall in addition include an assessment of the agency’s compliance with such requirements of the Administrative Pay-As-You-Go Act of 2023 as may be applicable” after “compliance with procedural steps required by paragraph (1)(B)”. See Termination Date of 2023 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb7d6d6e0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb7d6d6e1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/97/s2/b"},"text":"Pub. L. 118–97, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1574"},"text":"138 Stat. 1574","children":[],"tail":", provided that the amendment made by section 2(b) is effective on the date that is 6 years after "},{"tag":"date","attrib":{"date":"2024-10-01"},"text":"Oct. 1, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"terminationDate","id":"idb7d6d6e2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination Date of 2023 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/5"},"text":"Pub. L. 118–5","children":[],"tail":" expires on "},{"tag":"date","attrib":{"date":"2024-12-31"},"text":"Dec. 31, 2024","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/118/5/s268"},"text":"section 268 of Pub. L. 118–5","children":[],"tail":", set out in a Statutory Administrative Pay-As-You-Go note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s551"},"text":"section 551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb7d6d6e3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/121/tII/s252"},"text":"Pub. L. 104–121, title II, § 252","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-03-29"},"text":"Mar. 29, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/874"},"text":"110 Stat. 874","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/121/tII/s252"},"text":"“The amendment made by section 351 [probably means section 251, enacting this chapter] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-03-29"},"text":"Mar. 29, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idb7d6d6e4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter is popularly known as the “Congressional Review Act”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb7d6d6e5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Truth in Regulating","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/312"},"text":"Pub. L. 106–312","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1248"},"text":"114 Stat. 1248","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/271/s8/b"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“SECTION 1.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SHORT TITLE.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“This Act may be cited as the ‘Truth in Regulating Act of 2000’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“SEC. 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PURPOSES.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“The purposes of this Act are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the transparency of important regulatory decisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote effective congressional oversight to ensure that agency rules fulfill statutory requirements in an efficient, effective, and fair manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase the accountability of Congress and the agencies to the people they serve.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“SEC. 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DEFINITIONS.","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“In this Act, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ‘agency’ has the meaning given such term under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551/1"},"text":"section 551(1) of title 5","children":[],"tail":", United States Code;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ‘economically significant rule’ means any proposed or final rule, including an interim or direct final rule, that may have an annual effect on the economy of $100,000,000 or more or adversely affect in a material way the economy, a sector of the economy, productivity, competition, jobs, the environment, public health or safety, or State, local, or tribal governments or communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ‘independent evaluation’ means a substantive evaluation of the agency’s data, methodology, and assumptions used in developing the economically significant rule, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of how any strengths or weaknesses in those data, methodology, and assumptions support or detract from conclusions reached by the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implications, if any, of those strengths or weaknesses for the rulemaking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“SEC. 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" PILOT PROJECT FOR REPORT ON RULES.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Request for review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When an agency publishes an economically significant rule, a chairman or ranking member of a committee of jurisdiction of either House of Congress may request the Comptroller General of the United States to review the rule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall submit a report on each economically significant rule selected under paragraph (4) to the committees of jurisdiction in each House of Congress not later than 180 calendar days after a committee request is received. The report shall include an independent evaluation of the economically significant rule by the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independent evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The independent evaluation of the economically significant rule by the Comptroller General under paragraph (2) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the agency’s analysis of the potential benefits of the rule, including any beneficial effects that cannot be quantified in monetary terms and the identification of the persons or entities likely to receive the benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the agency’s analysis of the potential costs of the rule, including any adverse effects that cannot be quantified in monetary terms and the identification of the persons or entities likely to bear the costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of the agency’s analysis of alternative approaches set forth in the notice of proposed rulemaking and in the rulemaking record, as well as of any regulatory impact analysis, federalism assessment, or other analysis or assessment prepared by the agency or required for the economically significant rule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the results of the evaluation of the Comptroller General and the implications of those results.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures for priorities of requests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall have discretion to develop procedures for determining the priority and number of requests for review under paragraph (1) for which a report will be submitted under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Comptroller General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each agency shall promptly cooperate with the Comptroller General in carrying out this Act. Nothing in this Act is intended to expand or limit the authority of the Government Accountability Office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“SEC. 5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" AUTHORIZATION OF APPROPRIATIONS.","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"“There are authorized to be appropriated to the Government Accountability Office to carry out this Act $5,200,000 for each of fiscal years 2000 through 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“SEC. 6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" EFFECTIVE DATE AND DURATION OF PILOT PROJECT.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This Act and the amendments made by this Act shall take effect 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-10-17"},"text":"Oct. 17, 2000","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration of Pilot Project","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The pilot project under this Act shall continue for a period of 3 years, if in each fiscal year, or portion thereof included in that period, a specific annual appropriation not less than $5,200,000 or the pro-rated equivalent thereof shall have been made for the pilot project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before the conclusion of the 3-year period, the Comptroller General shall submit to Congress a report reviewing the effectiveness of the pilot project and recommending whether or not Congress should permanently authorize the pilot project.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
