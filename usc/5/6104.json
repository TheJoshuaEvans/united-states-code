{"tag":"section","attrib":{"id":"idb8932179-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6104"},"text":null,"children":[{"tag":"num","attrib":{"value":"6104"},"text":"§ 6104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Holidays; daily, hourly, and piece-work basis employees","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When a regular employee as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of this title","children":[],"tail":" or an individual employed regularly by the government of the District of Columbia, whose pay is fixed at a daily or hourly rate, or on a piece-work basis, is relieved or prevented from working on a day—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb893217a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6104/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which agencies are closed by Executive order, or, for individuals employed by the government of the District of Columbia, by order of the Mayor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb893217b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6104/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by administrative order under regulations issued by the President, or, for individuals employed by the government of the District of Columbia, by the Council of the District of Columbia; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb893217c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s6104/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solely because of the occurrence of a legal public holiday under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6103"},"text":"section 6103 of this title","children":[],"tail":", or a day declared a holiday by Federal statute, Executive order, or, for individuals employed by the government of the District of Columbia, by order of the Mayor;"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"he is entitled to the same pay for that day as for a day on which an ordinary day’s work is performed.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb893217d-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/516"},"text":"80 Stat. 516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/623/s1/15"},"text":"Pub. L. 90–623, § 1(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1313"},"text":"82 Stat. 1313","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/54/s2/a/38"},"text":"Pub. L. 96–54, § 2(a)(38)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-08-14"},"text":"Aug. 14, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/383"},"text":"93 Stat. 383","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb893217e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb893217f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb8932180-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col"