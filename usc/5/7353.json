{"tag":"section","attrib":{"id":"idb8b48c7f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353"},"text":null,"children":[{"tag":"num","attrib":{"value":"7353"},"text":"§ 7353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts to Federal employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8b48c80-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as permitted by subsection (b), no Member of Congress or officer or employee of the executive, legislative, or judicial branch shall solicit or accept anything of value from a person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b48c81-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seeking official action from, doing business with, or (in the case of executive branch officers and employees) conducting activities regulated by, the individual’s employing entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48c82-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose interests may be substantially affected by the performance or nonperformance of the individual’s official duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48c83-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b48c84-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each supervising ethics office is authorized to issue rules or regulations implementing the provisions of this section and providing for such reasonable exceptions as may be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48c85-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b48c86-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to subparagraph (B), a Member, officer, or employee may accept a gift pursuant to rules or regulations established by such individual’s supervising ethics office pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b48c87-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No gift may be accepted pursuant to subparagraph (A) in return for being influenced in the performance of any official act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48c88-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section precludes a Member, officer, or employee from accepting gifts on behalf of the United States Government or any of its agencies in accordance with statutory authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48c89-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this section precludes an employee of a private sector organization, while assigned to an agency under chapter 37, from continuing to receive pay and benefits from such organization in accordance with such chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48c8a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Member of Congress or an officer or employee who violates this section shall be subject to appropriate disciplinary and other remedial action in accordance with any applicable laws, Executive orders, and rules or regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8b48c8b-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8b48c8c-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “supervising ethics office” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8b48c8d-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Standards of Official Conduct of the House of Representatives or the House of Representatives as a whole, for Members, officers, and employees of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b48c8e-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Select Committee on Ethics of the Senate, or the Senate as a whole, for Senators, officers, and employees of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b48c8f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Judicial Conference of the United States for judges and judicial branch officers and employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b48c90-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Government Ethics for all executive branch officers and employees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8b48c91-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of legislative branch officers and employees other than those specified in subparagraphs (A) and (B), the committee referred to in either such subparagraph to which reports filed by such officers and employees under subchapter I of chapter 131 of this title are transmitted under such subchapter, except that the authority of this section may be delegated by such committee with respect to such officers and employees; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8b48c92-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s7353/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “officer or employee” means an individual holding an appointive or elective position in the executive, legislative, or judicial branch of Government, other than a Member of Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb8b48c93-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/194/tIII/s303/a"},"text":"Pub. L. 101–194, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1746"},"text":"103 Stat. 1746","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/d"},"text":"Pub. L. 101–280, § 4(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-05-04"},"text":"May 4, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/158"},"text":"104 Stat. 158","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/tII/s209/g/1/C"},"text":"Pub. L. 107–347, title II, § 209(g)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2932"},"text":"116 Stat. 2932","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/9"},"text":"Pub. L. 117–286, § 4(c)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4354"},"text":"136 Stat. 4354","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb8b48c94-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb8b48c95-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb8b48c96-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (d)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “subchapter I of chapter 131 of this title are transmitted under such subchapter,” for “title I of the Ethics in Government Act of 1978 are transmitted under such title,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Pub. L. 107–347","children":[],"tail":" added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/d/1/A"},"text":"Pub. L. 101–280, § 4(d)(1)(A)","children":[],"tail":", substituted “branch” for “branches” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/d/1/B"},"text":"Pub. L. 101–280, § 4(d)(1)(B)","children":[],"tail":", substituted “by, the” for “by the” and “entity” for “agency”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/d/2"},"text":"Pub. L. 101–280, § 4(d)(2)","children":[],"tail":", substituted “A Member of Congress or an officer or employee” for “An employee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/d/3/A/i"},"text":"Pub. L. 101–280, § 4(d)(3)(A)(i)","children":[],"tail":", substituted “officers,” for “officers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/d/3/A/ii"},"text":"Pub. L. 101–280, § 4(d)(3)(A)(ii)","children":[],"tail":", amended subpar. (E) generally. Prior to amendment, subpar. (E) read as follows: “the ethics committee with which the officer or employee is required to file financial disclosure forms, for all legislative branch officers and employees other than those specified in subparagraphs (A) and (B), except that such authority may be delegated; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/280/s4/d/3/B"},"text":"Pub. L. 101–280, § 4(d)(3)(B)","children":[],"tail":", substituted “Government,” for “Government”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb8b48c97-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idb8b48c98-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Standards of Official Conduct of House of Representatives changed to Committee on Ethics of House of Representatives by House Resolution No. 5, One Hundred Twelfth Congress, ","children":[{"tag":"date","attrib":{"date":"2011-01-05"},"text":"Jan. 5, 2011","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb8b48c99-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Pub. L. 107–347","children":[],"tail":" effective 120 days after "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/347/s402/a"},"text":"section 402(a) of Pub. L. 107–347","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3601"},"text":"section 3601 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idb8b48c9a-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Limitation on Acceptance of Honorary Club Memberships","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/402/s2"},"text":"Pub. L. 110–402, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4255"},"text":"122 Stat. 4255","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/c/10"},"text":"Pub. L. 117–286, § 4(c)(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4354"},"text":"136 Stat. 4354","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/286/s4/c/10"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gift","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘gift’ has the meaning given under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s13101/5"},"text":"section 13101(5) of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judicial officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘judicial officer’ has the meaning given under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s13101/10"},"text":"section 13101(10) of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Acceptance of Honorary Club Memberships","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A judicial officer may not accept a gift of an honorary club membership with a value of more than $50 in any calendar year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
