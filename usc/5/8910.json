{"tag":"section","attrib":{"id":"idb92241f5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8910"},"text":null,"children":[{"tag":"num","attrib":{"value":"8910"},"text":"§ 8910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Studies, reports, and audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92241f6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management shall make a continuing study of the operation and administration of this chapter, including surveys and reports on health benefits plans available to employees and on the experience of the plans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92241f7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each contract entered into under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8902"},"text":"section 8902 of this title","children":[],"tail":" shall contain provisions requiring carriers to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92241f8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8910/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" furnish such reasonable reports as the Office determines to be necessary to enable it to carry out its functions under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb92241f9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8910/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit the Office and representatives of the Government Accountability Office to examine records of the carriers as may be necessary to carry out the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92241fa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8910/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each Government agency shall keep such records, make such certifications, and furnish the Office with such information and reports as may be necessary to enable the Office to carry out its functions under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb92241fb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8910/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office, in consultation with the Department of Health and Human Services, shall develop and implement a system through which the carrier for an approved health benefits plan described by section 8903 or 8903a will be able to identify those annuitants or other individuals covered by such plan who are entitled to benefits under part A or B of title XVIII of the Social Security Act in order to ensure that payments under coordination of benefits with Medicare do not exceed the statutory maximums which physicians may charge Medicare enrollees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb92241fc-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/606"},"text":"80 Stat. 606","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/t