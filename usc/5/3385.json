{"tag":"section","attrib":{"id":"idb81e6679-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3385"},"text":null,"children":[{"tag":"num","attrib":{"value":"3385"},"text":"§ 3385.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"This subchapter shall not limit the authority of the Secretary to reassign temporarily an air traffic controller to other duties with or without notice, in the interest of the safe or efficient separation and control of air traffic or the physical or mental health of a controller; or to reassign permanently or separate a controller under any other provision of law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idb81e667a-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/297/s3/a"},"text":"Pub. L. 92–297, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-05-16"},"text":"May 16, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/143"},"text":"86 Stat. 143","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/347/s1/b"},"text":"Pub. L. 96–347, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-09-12"},"text":"Sept. 12, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1150"},"text":"94 Stat. 1150","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb81e667b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb81e667c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText"