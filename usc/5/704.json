"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-06-11/ch324/s10/c"},"text":"June 11, 1946, ch. 324, § 10(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/243"},"text":"60 Stat. 243","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface of this report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
