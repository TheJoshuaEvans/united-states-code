{"tag":"section","attrib":{"id":"idb86cfbff-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5543"},"text":null,"children":[{"tag":"num","attrib":{"value":"5543"},"text":"§ 5543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensatory time off","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb86cfc00-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5543/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The head of an agency may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86cfc01-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5543/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on request of an employee, grant the employee compensatory time off from his scheduled tour of duty instead of payment under section 5542 or section 7 of the Fair Labor Standards Act of 1938 for an equal amount of time spent in irregular or occasional overtime work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86cfc02-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5543/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that an employee whose rate of basic pay is in excess of the maximum rate of basic pay for GS–10 (including any applicable locality-based comparability payment under section 5304 or similar provision of law and any applicable special rate of pay under section 5305 or similar provision of law) shall be granted compensatory time off from his scheduled tour of duty equal to the amount of time spent in irregular or occasional overtime work instead of being paid for that work under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5542"},"text":"section 5542 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86cfc03-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5543/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of an agency may, on request of an employee, grant the employee compensatory time off from the employee’s scheduled tour of duty instead of payment under section 5544 or section 7 of the Fair Labor Standards Act of 1938 for an equal amount of time spent in irregular or occasional overtime work. An agency head may not require an employee to be compensated for overtime work with an equivalent amount of compensatory time-off from the employee’s tour of duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86cfc04-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5543/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Architect of the Capitol may grant an employee paid on an annual basis compensatory time off from duty instead of overtime pay for overtime work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb86cfc05-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5543/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb86cfc06-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5543/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The appropriate Secretary may, on request of an employee of a nonappropriated fund instrumentality of the Department of Defense or the Coast Guard described in section 2105(c), grant such employee compensatory time off from duty instead of overtime pay for overtime work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb86cfc07-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5543/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection, the term “appropriate Secretary” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb86cfc08-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5543/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to an employee of a nonappropriated fund instrumentality of the Department of Defense, the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb86cfc09-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s5543/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to an employee of a nonappropriated fund instrumentality of the Coast Guard, the Secretary of the Executive department in which it is operating.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb86cfc0a-5e84-11f1-a692-ec26948f6fea"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/554"},"text":"Pub. L. 89–554","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-09-06"},"text":"Sept. 6, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/486"},"text":"80 Stat. 486","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/90/83/s1/25"},"text":"Pub. L. 90–83, § 1(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1967-09-11"},"text":"Sept. 11, 1967","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/81/200"},"text":"81 Stat. 200","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/509/tV/s529/tI/tII/s210/2"},"text":"Pub. L. 101–509, title V, § 529 [title I, § 101(b)(3)(E), title II, § 210(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1427"},"text":"104 Stat. 1427","children":[],"tail":", 1439, 1460; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVI/s1610/a"},"text":"Pub. L. 104–201, div. A, title XVI, § 1610(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2738"},"text":"110 Stat. 2738","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tVI/s674"},"text":"Pub. L. 109–163, div. A, title VI, § 674","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3319"},"text":"119 Stat. 3319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb86cfc0b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb86cfc0c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb86cfc0d-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Histo