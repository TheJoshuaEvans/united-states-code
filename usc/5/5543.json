hildren":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/297"},"text":"59 Stat. 297","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-05-24/ch270/s9"},"text":"May 24, 1946, ch. 270, § 9","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/218"},"text":"60 Stat. 218","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-09-01/ch1208/s204"},"text":"Sept. 1, 1954, ch. 1208, § 204","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/1109"},"text":"68 Stat. 1109","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “head of an agency” are substituted for “head of any department, independent establishment, or agency, including Government-owned or controlled corporations, or of the municipal government of the District of Columbia, or the head of any legislative or judicial agency to which this subchapter applies” because of the definition of “agency” and the application stated in section 5541.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the word “officer” is omitted as included in “employee”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “at his own discretion” are omitted as unnecessary in view of the permissive nature of the authority. The word “officer” is omitted as included in “employee”. The word “scheduled” is omitted since ","children":[{"tag":"ref","attrib":{"href":"/us/act/1962-10-11/s603"},"text":"section 603 of the Act of Oct. 11, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/793"},"text":"Pub. L. 87–793","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/847"},"text":"76 Stat. 847","children":[],"tail":", eliminated the necessity of referring to rates as scheduled or longevity. Reference to the “Classification Act of 1949, as amended” is omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “in his discretion” are omitted as unnecessary in view of the permissive nature of the authority. The words “overtime work” are substituted for “any work in excess of forty hours in any regularly scheduled administrative workweek” because of the definition of “overtime work” in section 5542(a).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Standard changes are made to conform with the definitions applicable and the style of this title as outlined in the preface to the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idb86cfc0e-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idb86cfc0f-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1967 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section of title 5","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5543(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5 App.: 912.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 18, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/504/s404/b"},"text":"Pub. L. 89–504, § 404(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/297"},"text":"80 Stat. 297","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb86cfc10-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idb86cfc11-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 7 of the Fair Labor Standards Act of 1938, referred to in subsecs. (a)(1) and (b), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s207"},"text":"section 207 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"GS–10, referred to in subsec. (a)(2), is contained in the General Schedule which is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb86cfc12-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163"},"text":"Pub. L. 109–163","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" added subsec. (b) and redesignated former subsec. (b) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/s529/tII/s210/2"},"text":"Pub. L. 101–509, § 529 [title II, § 210(2)]","children":[],"tail":", inserted “under section 5542 or section 7 of the Fair Labor Standards Act of 1938” after “payment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/s529/tI/s101/b/3/E"},"text":"Pub. L. 101–509, § 529 [title I, § 101(b)(3)(E)]","children":[],"tail":", inserted “(including any applicable locality-based comparability payment under section 5304 or similar provision of law and any applicable special rate of pay under section 5305 or similar provision of law)” after “GS–10”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb86cfc13-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"childr