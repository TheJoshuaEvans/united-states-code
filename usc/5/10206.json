{"tag":"section","attrib":{"id":"idb92e2a3f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10206"},"text":null,"children":[{"tag":"num","attrib":{"value":"10206"},"text":"§ 10206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Technician positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb92e2a40-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10206/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb92e2a41-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10206/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member whose position is determined under section 10202(a)(3) to be included as a technician position shall, on or after such date, receive, in addition to the member’s scheduled rate of basic pay, an amount equal to 6 percent of the sum of such member’s rate of basic pay and the applicable locality-based comparability payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a42-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10206/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member described in this subsection shall receive the additional compensation authorized by this subsection until such time as the member’s position is determined under section 10202(a)(3) not to be a technician position, or until the member no longer occupies such position, whichever occurs first.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a43-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10206/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The additional compensation authorized by this subsection shall be paid to a member in the same manner and at the same time as the member’s basic pay is paid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb9309a44-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10206/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idb9309a45-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10206/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the additional compensation authorized by subsection (a)(1) shall be considered as basic pay for all purposes, including section 8401(4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a46-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10206/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The additional compensation authorized by subsection (a)(1) shall not be considered as basic pay for the purposes of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb9309a47-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10206/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 5304; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb9309a48-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10206/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 7511(a)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb9309a49-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s10206/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The loss of the additional compensation authorized by subsection (a)(1) shall not constitute an adverse action for the purposes of section 7512.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb9309a4a-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/282/s2/a"},"text":"Pub. L. 111–282, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3037"},"text":"124 Stat. 3037","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb9309a4b-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb9309a4c-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb9309a4d-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on first day of first pay period which begins after ","children":[{"tag":"date","attrib":{"date":"2010-10-15"},"text":"Oct. 15, 2010","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/111/282/s5"},"text":"section 5 of Pub. L. 111–282","children":[],"tail":", set out as an Effective Date of 2010 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5102"},"text":"section 5102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
