{"tag":"section","attrib":{"id":"idb823228f-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3593"},"text":null,"children":[{"tag":"num","attrib":{"value":"3593"},"text":"§ 3593.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reinstatement in the Senior Executive Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb8232290-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3593/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A former career appointee may be reinstated, without regard to section 3393(b) and (c) of this title, to any Senior Executive Service position for which the appointee is qualified if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8232291-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3593/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appointee has successfully completed the probationary period established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393/d"},"text":"section 3393(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb8232292-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3593/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appointee left the Senior Executive Service for reasons other than misconduct, neglect of duty, malfeasance, or less than fully successful executive performance as determined under subchapter II of chapter 43.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8232293-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3593/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A career appointee who is appointed by the President to any civil service position outside the Senior Executive Service and who leaves the position for reasons other than misconduct, neglect of duty, or malfeasance shall be entitled to be placed in the Senior Executive Service if the appointee applies to the Office of Personnel Management within 90 days after separation from the Presidential appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb8232294-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3593/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb8232295-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3593/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A former career appointee shall be reinstated, without regard to section 3393(b) and (c) of this title, to any vacant Senior Executive Service position in an agency for which the appointee is qualified if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb8232296-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3593/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual was a career appointee on ","children":[{"tag":"date","attrib":{"date":"1981-05-31"},"text":"May 31, 1981","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8232297-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3593/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appointee was removed from the Senior Executive Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3595"},"text":"section 3595 of this title","children":[],"tail":" before "},{"tag":"date","attrib":{"date":"1984-10-01"},"text":"October 1, 1984","children":[],"tail":", due to a reduction in force in that agency;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8232298-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3593/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before the removal occurred, the appointee successfully completed the probationary period established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393/d"},"text":"section 3393(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb8232299-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3593/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appointee applies for that vacant position within one year after the Office receives certification regarding that appointee pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3595/b/3/B"},"text":"section 3595(b)(3)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb823229a-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3593/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A career appointee is entitled to appeal to the Merit Systems Protection Board under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7701"},"text":"section 7701 of this title","children":[],"tail":" any determination by the agency that the appointee is not qualified for a position for which the appointee applies under paragraph (1) of this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb823229b-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIV/s404/b"},"text":"Pub. L. 95–454, title IV, § 404(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1166"},"text":"92 Stat. 1166","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/35/tXVII/s1704/b"},"text":"Pub. L. 97–35, title XVII, § 1704(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1981-08-13"},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/757"},"text":"95 Stat. 757","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/tIII/s303/a"},"text":"Pub. L. 98–615, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3217"},"text":"98 Stat. 3217","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/194/tV/s506/b/4"},"text":"Pub. L. 101–194, title V, § 506(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-30"},"text":"Nov. 30, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1758"},"text":"103 Stat. 1758","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIII/s1321/a/2/B"},"text":"Pub. L. 107–296, title XIII, § 1321(a)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2297"},"text":"116 Stat. 2297","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb823229c-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb823229d-5e84-11f1