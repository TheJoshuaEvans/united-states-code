{"tag":"section","attrib":{"id":"idb90348a1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440a"},"text":null,"children":[{"tag":"num","attrib":{"value":"8440a"},"text":"§ 8440a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Justices and judges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb90348a2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90348a3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A justice or judge of the United States as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s451"},"text":"section 451 of title 28","children":[],"tail":" may elect to contribute an amount of such individual’s basic pay to the Thrift Savings Fund. Basic pay does not include an annuity or salary received by a justice or judge who has retired under section 371(a) or (b) or "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s372/a"},"text":"section 372(a) of title 28","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90348a4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An election may be made under paragraph (1) as provided under section 8432(b) for individuals subject to this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb90348a5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb90348a6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as otherwise provided in this subsection, the provisions of this subchapter and subchapter VII shall apply with respect to justices and judges making contributions to the Thrift Savings Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90348a7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount contributed by a justice or judge for any pay period shall not exceed the maximum percentage of such justice’s or judge’s basic pay for such pay period allowable under section 8440f.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90348a8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440a/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No contributions shall be made for the benefit of a justice or judge under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432/c"},"text":"section 8432(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90348a9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440a/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8433/b"},"text":"Section 8433(b) of this title","children":[],"tail":" applies with respect to elections available to any justice or judge who retires under section 371(a) or (b) or "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s372/a"},"text":"section 372(a) of title 28","children":[],"tail":". Retirement under section 371(a) or (b) or "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s372/a"},"text":"section 372(a) of title 28","children":[],"tail":" is a separation from service for the purposes of subchapters III and VII of chapter 84 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90348aa-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440a/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8433/b"},"text":"Section 8433(b) of this title","children":[],"tail":" applies to any justice or judge who resigns without having met the age and service requirements set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s371/c"},"text":"section 371(c) of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90348ab-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440a/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8351/b/5"},"text":"section 8351(b)(5) of this title","children":[],"tail":" shall govern the rights of spouses of justices or judges contributing to the Thrift Savings Fund under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb90348ac-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s8440a/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding paragraphs (4) and (5), if any justice or judge retires under subsection (a) or (b) of section 371 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s372/a"},"text":"section 372(a) of title 28","children":[],"tail":", or resigns without having met the age and service requirements set forth under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s371/c"},"text":"section 371(c) of title 28","children":[],"tail":", and such justice’s or judge’s nonforfeitable account balance is less than an amount that the Executive Director prescribes by regulation, the Executive Director shall pay the nonforfeitable account balance to the participant in a single payment."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb90348ad-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/654/tIV/s401/a"},"text":"Pub. L. 100–654, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-14"},"text":"Nov. 14, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3847"},"text":"102 Stat. 3847","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/101/335"},"text":"Pub. L. 101–335","children":[],"tail":", §§ 3(b)(2), 6(b)(2), "},{"tag":"date","attrib":{"date":"1990-07-17"},"text":"July 17, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/320"},"text":"104 Stat. 320","children":[],"tail":", 323; "},{"tag":"ref","attrib":{"href":"/us/pl/102/378/s2/70"},"text":"Pub. L. 102–378, § 2(70)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-02"},"text":"Oct. 2, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1355"},"text":"106 Stat. 1355","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/226/s9/e"},"text":"Pub. L. 103–226, § 9(e)","children":[],"tail":", (i)(17), "},{"tag":"date","attrib":{"date":"1994-03-30"},"text":"Mar. 30, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/120"},"text":"108 Stat. 120","children":[],"tail":", 122; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/f/tVI/tII/s205/a"},"text":"Pub. L. 104–208, div. A, title I, § 101(f) [title VI, § 659 [title II, § 205(a)]","children":[],"tail":"], "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-314"},"text":"110 Stat. 3009–314","children":[],"tail":", 3009–372, 3009–377; "},{"tag":"ref","attrib":{"href":"/us/pl/106/361/s2/b/6"},"text":"Pub. L. 106–361, § 2(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-27"},"text":"Oct. 27, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1401"},"text":"114 Stat. 1401","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/4/dB/tI/s138/a/2"},"text":"Pub. L. 106–554, § 1(a)(4) [div. B, title I, § 138(a)(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–233; "},{"tag":"ref","attrib":{"href":"/us/pl/108/469/s1/d/4"},"text":"Pub. L. 108–469, § 1(d)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-21"},"text":"Dec. 21, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3892"},"text":"118 Stat. 3892","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb90348ae-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb90348af-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idb90348b0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 8440a was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8440b"},"text":"section 8440b of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb90348b1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/469"},"text":"Pub. L. 108–469","children":[],"tail":" substituted “as” for “only during a period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/361"},"text":"Pub. L. 106–361","children":[],"tail":" substituted “this chapter” for “chapter 84 of this title: "},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That a justice or judge may make the first such election within 60 days of the effective date of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “The amount contributed by a justice or judge shall not exceed 5 percent of basic pay.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" substituted “less than an amount that the Executive Director prescribes by regulation” for “$3,500 or less” and struck out “unless the justice or judge elects, at such time and otherwise in such manner as the Executive Director prescribes, one of the options available under section 8433(b)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226/s9/e/1"},"text":"Pub. L. 103–226, § 9(e)(1)","children":[],"tail":", substituted “Section 8433(b)” for “Section 8433(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226/s9/i/17"},"text":"Pub. L. 103–226, § 9(i)(17)","children":[],"tail":", substituted “section 8351(b)(5)” for “section 8351(b)(7)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226/s9/e/2"},"text":"Pub. L. 103–226, § 9(e)(2)","children":[],"tail":", added par. (7) and struck out former pars. (7) and (8) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(7) Notwithstanding paragraph (5), if any justice or judge who elects to make contributions to the Thrift Savings Fund under subsection (a) resigns without having met the age and service requirements set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s371/c"},"text":"section 371(c) of title 28","children":[],"tail":", and such justice’s or judge’s nonforfeitable account balance is $3,500 or less, the Executive Director shall pay the nonforfeitable account balance to the participant in a single payment unless the justice or judge elects, at such time and otherwise in such manner as the Executive Director prescribes, to have the nonforfeitable account balance transferred to an eligible retirement plan as provided in section 8433(e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(8) Notwithstanding paragraph (4), if any justice or judge retires under subsection (a) or (b) of section 371 or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s372/a"},"text":"section 372(a) of title 28","children":[],"tail":", and such justice’s or judge’s nonforfeitable account balance is $3,500 or less, the Executive Director shall pay the nonforfeitable account balance to the participant in a single payment unless the justice or judge elects, at such time and otherwise in such manner as the Executive Director prescribes, one of the options available under section 8433(b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/378"},"text":"Pub. L. 102–378","children":[],"tail":" substituted “this subchapter and subchapter VII” for “subchapters III and VII of chapter 84 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/335/s3/b/2"},"text":"Pub. L. 101–335, § 3(b)(2)","children":[],"tail":", redesignated par. (7) as (6) and struck out former par. (6) which read as follows: “Sums contributed under this section and earnings attributable to such sums may be invested and reinvested only in the Government Securities Investment Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8438/b/1/A"},"text":"section 8438(b)(1)(A) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/335/s6/b/2"},"text":"Pub. L. 101–335, § 6(b)(2)","children":[],"tail":", added pars. (7) and (8). Former par. (7) redesignated (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb90348b2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90348b3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/361"},"text":"Pub. L. 106–361","children":[],"tail":" effective at the earliest practicable date after "},{"tag":"date","attrib":{"date":"2000-09-30"},"text":"Sept. 30, 2000","children":[],"tail":", as determined by the Executive Director in regulations, see "},{"tag":"ref","attrib":{"href":"/us/pl/106/361/s2/c/1"},"text":"section 2(c)(1) of Pub. L. 106–361","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432"},"text":"section 8432 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90348b4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", and withdrawals and elections as provided under such amendment to be made at earliest practicable date as determined by Executive Director in regulations, see section 101(f) [title VI, § 659 [title II, § 207]] of "},{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5545a"},"text":"section 5545a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90348b5-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/226"},"text":"Pub. L. 103–226","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1995-03-10"},"text":"Mar. 10, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/226/s9/j"},"text":"section 9(j) of Pub. L. 103–226","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8351"},"text":"section 8351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb90348b6-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/335/s3/b/2"},"text":"section 3(b)(2) of Pub. L. 101–335","children":[],"tail":" effective as of second election period described in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432/b"},"text":"section 8432(b) of this title","children":[],"tail":" beginning after "},{"tag":"date","attrib":{"date":"1990-07-17"},"text":"July 17, 1990","children":[],"tail":", or as of such earlier date as Executive Director may by regulation prescribe, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/335/s3/c"},"text":"section 3(c) of Pub. L. 101–335","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8351"},"text":"section 8351 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/335/s6/b/2"},"text":"section 6(b)(2) of Pub. L. 101–335","children":[],"tail":" effective as of second election period described in "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8432/b"},"text":"section 8432(b) of this title","children":[],"tail":" beginning after "},{"tag":"date","attrib":{"date":"1990-07-17"},"text":"July 17, 1990","children":[],"tail":", or such earlier date as Executive Director may by regulation prescribe, and applicable with respect to separations occurring before, on, or after that effective date, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/335/s6/c"},"text":"section 6(c) of Pub. L. 101–335","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8351"},"text":"section 8351 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
