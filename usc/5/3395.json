{"tag":"section","attrib":{"id":"idb81e66d0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395"},"text":null,"children":[{"tag":"num","attrib":{"value":"3395"},"text":"§ 3395.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reassignment and transfer within the Senior Executive Service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idb81e66d1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81e66d2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A career appointee in an agency—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81e66d3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, subject to paragraph (2) of this subsection, be reassigned to any Senior Executive Service position in the same agency for which the appointee is qualified; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e66d4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may transfer to a Senior Executive Service position in another agency for which the appointee is qualified, with the approval of the agency to which the appointee transfers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81e66d5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81e66d6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B) of this paragraph, a career appointee may be reassigned to any Senior Executive Service position only if the career appointee receives written notice of the reassignment at least 15 days before the effective date of such reassignment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e66d7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb81e66d8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A career appointee may not be reassigned to a Senior Executive Service position outside the career appointee’s commuting area unless—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idb81e66d9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/a/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before providing notice under subclause (II) of this clause (or seeking or obtaining the consent of the career appointee under clause (ii) of this subparagraph to waive such notice), the agency consults with the career appointee on the reasons for, and the appointee’s preferences with respect to, the proposed reassignment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idb81e66da-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/a/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the career appointee receives written notice of the reassignment, including a statement of the reasons for the reassignment, at least 60 days before the effective date of the reassignment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb81e66db-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notice of reassignment under clause (i)(II) of this subparagraph may be waived with the written consent of the career appointee involved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81e66dc-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81e66dd-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3394/b"},"text":"section 3394(b) of this title","children":[],"tail":", a limited emergency appointee may be reassigned to another Senior Executive Service position in the same agency established to meet a bona fide, unanticipated, urgent need, except that the appointee may not serve in one or more positions in such agency under such appointment in excess of 18 months."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81e66de-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3394/b"},"text":"section 3394(b) of this title","children":[],"tail":", a limited term appointee may be reassigned to another Senior Executive Service position in the same agency the duties of which will expire at the end of a term of 3 years or less, except that the appointee may not serve in one or more positions in the agency under such appointment in excess of 3 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81e66df-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A limited term appointee or a limited emergency appointee may not be appointed to, or continue to hold, a position under such an appointment if, within the preceding 48 months, the individual has served more than 36 months, in the aggregate, under any combination of such types of appointment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81e66e0-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A noncareer appointee in an agency—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81e66e1-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be reassigned to any general position in the agency for which the appointee is qualified; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81e66e2-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may transfer to a general position in another agency with the approval of the agency to which the appointee transfers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idb81e66e3-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idb81e66e4-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, a career appointee in an agency may not be involuntarily reassigned—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81e66e5-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 120 days after an appointment of the head of the agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e66e6-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" within 120 days after the appointment in the agency of the career appointee’s most immediate supervisor who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idb81e66e7-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a noncareer appointee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idb81e66e8-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the authority to make an initial appraisal of the career appointee’s performance under subchapter II of chapter 43.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81e66e9-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) of this subsection does not apply with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idb81e66ea-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any reassignment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s4314/b/3"},"text":"section 4314(b)(3) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idb81e66eb-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any disciplinary action initiated before an appointment referred to in paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idb81e66ec-5e84-11f1-a692-ec26948f6fea","identifier":"/us/usc/t5/s3395/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purpose of applying paragraph (1) to a career appointee, any days (not to exceed a total of 60) during which such career appointee is serving pursuant to a detail or other temporary assignment apart from such appointee’s regular position shall not be counted in determining the number of days that have elapsed since an appointment referred to in subparagraph (A) or (B) of such paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idb81e66ed-5e84-11f1-a692-ec26948f6fea"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIV/s403/a"},"text":"Pub. L. 95–454, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1163"},"text":"92 Stat. 1163","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/tIII/s304/a"},"text":"Pub. L. 98–615, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3218"},"text":"98 Stat. 3218","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/175/s3"},"text":"Pub. L. 102–175, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-02"},"text":"Dec. 2, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1222"},"text":"105 Stat. 1222","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idb81e66ee-5e84-11f1-a692-ec26948f6fea"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idb81e66ef-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idb81e66f0-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3395, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/437/s3/a"},"text":"Pub. L. 95–437, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-10"},"text":"Oct. 10, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1057"},"text":"92 Stat. 1057","children":[],"tail":", which related to nonapplicability of part-time career employment opportunities program was renumbered as "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3405"},"text":"section 3405 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/95/454/tIX/s906/c/1/B"},"text":"Pub. L. 95–454, title IX, § 906(c)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1226"},"text":"92 Stat. 1226","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idb81e66f1-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (e)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/175/s3/1"},"text":"Pub. L. 102–175, § 3(1)","children":[],"tail":", amended cl. (ii) generally. Prior to amendment, cl. (ii) read as follows: “has the authority to reassign the career appointee.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/175/s3/2"},"text":"Pub. L. 102–175, § 3(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" designated existing provisions as subpar. (A), inserted exception relating to subpar. (B), and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idb81e66f2-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idb81e66f3-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/615"},"text":"Pub. L. 98–615","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/615/s307"},"text":"section 307 of Pub. L. 98–615","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3393"},"text":"section 3393 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idb81e66f4-5e84-11f1-a692-ec26948f6fea"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 9 months after ","children":[{"tag":"date","attrib":{"date":"1978-10-13"},"text":"Oct. 13, 1978","children":[],"tail":", and congressional review of provisions of sections 401 through 412 of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", see section 415(a)(1), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s3131"},"text":"section 3131 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
